    "Title": [
        "xslt_format_number"
    ],
    "Feature": [
        "xslt_format_number(number, format_string)"
    ],
    "Description": [
        "returns formatted string representation of a numeric value",
        "xslt_format_number is an function wrapper for the format-number() XSLT function.",
        "It always uses the default formatting parameters described in the XSLT standard."
    ],
    "Examples": [
        "xslt_format_number (5351, '#,###'),        5,351\nxslt_format_number ('5351', '#.00'),       5351.00\nxslt_format_number (53.51, '#.0000'),      53.5100\nxslt_format_number (53.51, '0000.0000'),   0053.5100\nxslt_format_number (53.51, '0000.####'),   0053.51\nxslt_format_number (53.56, '0.0');\t      53.6"
    ],
    "Category": [
        "XML function"
    ]
}