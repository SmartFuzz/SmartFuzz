    "Title": [
        "datestring_GMT"
    ],
    "Feature": [
        "datestring_GMT(dt)"
    ],
    "Description": [
        "convert a timestamp to external format string in GMT",
        "Converts the local datetime to GMT and returns its\n    external representation as a string."
    ],
    "Examples": [
        "SQL> use Demo;\n Done. -- 3 msec.\n SQL> select (datestring_GMT (stringdate ('2000-01-01 22:00')));\n callret\n VARCHAR\n _______________________________________________________________________________\n 2000-01-01 21:00:00.000000\n 1 Rows. -- 45 msec."
    ],
    "Category": [
        "Date & Time Manipulation function"
    ]
}