    "Description": [
        "concatenate vectors",
        "vector_concat takes a variable number of\n      vectors (heterogeneous arrays) and constructs a new vector containing\n      copies of each (top level) element in the arguments."
    ],
    "Examples": [
        "dbg_obj_print (vector_concat (vector (now(), 'black', 'crow'),\n\t                      vector ('said', 'nevermore')));\ndbg_obj_print (vector_concat (vector ('a','b'),\n                              vector (vector ('c', 'd'), 'e')));",
        "({ts 2001-08-07 16:57:12.000000}  \"black\" \"crow\" \"said\" \"nevermore\" )\n(\"a\" \"b\" (\"c\" \"d\" ) \"e\" )"
