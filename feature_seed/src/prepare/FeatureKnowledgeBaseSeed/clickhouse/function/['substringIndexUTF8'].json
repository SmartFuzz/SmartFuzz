[
    "CREATE TABLE test_strings (url String);",
    "INSERT INTO test_strings VALUES ('www.stra\u00dfen-in-europa.de');",
    "INSERT INTO test_strings VALUES ('example.com/test/path');",
    "INSERT INTO test_strings VALUES ('singleDelimiter|test');",
    "INSERT INTO test_strings VALUES ('noDelimiter');",
    "INSERT INTO test_strings VALUES ('||multiple|delimiters|||here');",
    "SELECT substringIndexUTF8(url, '.', 2) FROM test_strings;",
    "SELECT substringIndexUTF8(url, '|', 1) FROM test_strings;",
    "SELECT substringIndexUTF8(url, '|', -1) FROM test_strings;",
    "SELECT substringIndexUTF8(url, '|', 2) FROM test_strings;",
    "SELECT substringIndexUTF8('abc::def::ghi', '::', 1) AS first_part;",
    "SELECT substringIndexUTF8('abc::def::ghi', '::', -1) AS last_part;",
    "SELECT substringIndexUTF8('validUTF8\u00e9\u5b57\u7b26', '\u00e9', 1);",
    "SELECT substringIndexUTF8('abc|def|ghi|jkl', '|', 3);",
    "SELECT substringIndexUTF8('abc|def|ghi|jkl', '|', -2);",
    "SELECT substringIndexUTF8('abcdef', 'x', 1);",
    "SELECT substringIndexUTF8('abcdef', 'x', -1);",
    "SELECT substringIndexUTF8(CONCAT('value1', '.', 'value2', '.', 'value3'), '.', 2);",
    "SELECT substringIndexUTF8(CONCAT('value1', '.', 'value2', '.', 'value3'), '.', -3);",
    "SELECT substringIndexUTF8(url, '.', 0) FROM test_strings;",
    "SELECT substringIndexUTF8(url, '.', 999) FROM test_strings;"
]