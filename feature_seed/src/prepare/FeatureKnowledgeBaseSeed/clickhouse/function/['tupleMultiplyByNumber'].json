[
    "CREATE TABLE tuples_test (my_tuple Tuple(int, float), multiplier Float);",
    "INSERT INTO tuples_test VALUES ((1, 2.0), 2.0);",
    "INSERT INTO tuples_test VALUES ((-1, -2.5), -3.0);",
    "INSERT INTO tuples_test VALUES ((0, 0.0), 5.0);",
    "INSERT INTO tuples_test VALUES ((1, 3.5), 1.0);",
    "INSERT INTO tuples_test VALUES ((10, 20.0), -1.0);",
    "SELECT tupleMultiplyByNumber(my_tuple, multiplier) FROM tuples_test;",
    "SELECT tupleMultiplyByNumber((10, 5.5), 2.0);",
    "SELECT tupleMultiplyByNumber((1, 2), 0);",
    "SELECT tupleMultiplyByNumber((2147483647, -2147483648), 1);",
    "SELECT tupleMultiplyByNumber((1.1, 2.2), 3.0);",
    "SELECT tupleMultiplyByNumber((1, 2), -2.5);",
    "SELECT tupleMultiplyByNumber((1.5, 3.5), 0.5) FROM tuples_test WHERE multiplier > 0;",
    "SELECT tupleMultiplyByNumber((1, 2.0), multiplier) FROM tuples_test WHERE multiplier < 0;",
    "SELECT tupleMultiplyByNumber((1, 2), (SELECT max(multiplier) FROM tuples_test));",
    "CREATE TABLE another_table (val Tuple(int, float));",
    "INSERT INTO another_table VALUES ((5, 10.0)), ((-3, 4.0));",
    "SELECT tupleMultiplyByNumber(val, 2.5) FROM another_table;",
    "SELECT t1.val, tupleMultiplyByNumber(t1.val, t2.multiplier) FROM another_table AS t1 JOIN tuples_test AS t2 ON t1.val.2 = t2.my_tuple.2;"
]