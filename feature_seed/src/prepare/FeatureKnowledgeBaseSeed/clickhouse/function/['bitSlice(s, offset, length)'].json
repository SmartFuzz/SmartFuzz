[
    "CREATE TABLE test_table (s String);",
    "INSERT INTO test_table VALUES ('Hello');",
    "SELECT bin('Hello'), bin(bitSlice(s, 1, 8)) FROM test_table;",
    "SELECT bin('Hello'), bin(bitSlice(s, 1, 2)) FROM test_table;",
    "SELECT bin('Hello'), bin(bitSlice(s, 1, 9)) FROM test_table;",
    "SELECT bin('Hello'), bin(bitSlice(s, -4, 8)) FROM test_table;",
    "SELECT bin('Hello'), bin(bitSlice(s, -1)) FROM test_table;",
    "SELECT bin('Hello'), bin(bitSlice(s, 1, -3)) FROM test_table;",
    "SELECT bin('Hello'), bin(bitSlice(s, -5)) FROM test_table;",
    "SELECT s, bin(bitSlice(s, 1, 16)) FROM test_table;",
    "SELECT bin('Sample'), bin(bitSlice(s, 2, 4)) FROM test_table;",
    "SELECT bin('Example'), bin(bitSlice(s, 1)) FROM test_table;",
    "CREATE TABLE another_table (s String);",
    "INSERT INTO another_table VALUES ('World');",
    "SELECT a.s, bin(a.s), bin(bitSlice(a.s, 1, 4)), bin(bitSlice(b.s, 1, 2)) FROM test_table AS a JOIN another_table AS b;",
    "SELECT s, bin(bitSlice(s, 1, length(s))) FROM test_table;",
    "SELECT bin(bitSlice(s, -3, 8)), bin(bitSlice(s, -1, 4)) FROM test_table;",
    "SELECT s, bin(bitSlice(s, 3)), bin(bitSlice(s, 3, 8)) FROM test_table;",
    "CREATE TEMPORARY TABLE temp_table (s String);",
    "INSERT INTO temp_table VALUES ('FuzzTesting');",
    "SELECT bin(s), bin(bitSlice(s, 1, 16)) FROM temp_table;",
    "SELECT s, bin(bitSlice(s, 2, length(s) - 4)), bin(bitSlice(s, -length(s) + 1, 8)) FROM temp_table;"
