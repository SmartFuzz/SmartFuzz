[
    "CREATE TABLE test_array (arr Array(Int32));",
    "INSERT INTO test_array VALUES ([10, 20, 10, 30]), ([1, 2, 1, 3, 2]), ([]);",
    "SELECT arrayEnumerateDense(arr) FROM test_array;",
    "SELECT arrayEnumerateDense([5, 5, 5, 5, 5]) AS result;",
    "SELECT arrayEnumerateDense([NULL, 10, NULL, 20]) AS result;",
    "SELECT arrayEnumerateDense([1, 2, 3, 1, 2, 4, 5, 2]) AS result;",
    "SELECT arrayEnumerateDense([100, 200, 100, 200, 300]) AS result;",
    "CREATE TABLE array_test AS SELECT arrayEnumerateDense(arr) AS enumerated_arr FROM test_array;",
    "SELECT * FROM array_test;",
    "SELECT arrayEnumerateDense(arr) FROM (SELECT arr FROM test_array WHERE size(arr) > 0);",
    "WITH (SELECT arrayEnumerateDense([9, 1, 3, 2, 1]) AS nums) SELECT nums;",
    "SELECT arrayEnumerateDense(arrayJoin([['a', 'b', 'a'], ['x', 'y', 'x']])) FROM test_array;"
]