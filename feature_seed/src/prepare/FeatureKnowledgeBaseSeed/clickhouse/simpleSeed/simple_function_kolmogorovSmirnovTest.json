    "feature_type": "function",
    "feature_name": "kolmogorovSmirnovTest",
    "sql_array": [
        "CREATE TABLE sample_data (value Float64, num Int32) ENGINE = Memory;",
        "INSERT INTO sample_data VALUES (randNormal(0, 10), 0), (randNormal(0, 10), 1);",
        "SELECT kolmogorovSmirnovTest('two-sided', 'auto')(value, num) FROM sample_data;",
        "UPDATE sample_data SET value = value + 5 WHERE num = 0;",
        "SELECT kolmogorovSmirnovTest('greater', 'asymp')(value, num) FROM sample_data;"
