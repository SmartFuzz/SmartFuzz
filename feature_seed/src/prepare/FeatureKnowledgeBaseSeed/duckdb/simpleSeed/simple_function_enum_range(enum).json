    "feature_name": "enum_range(enum)",
    "sql_array": [
        "CREATE TYPE mood AS ENUM ('happy', 'sad', 'neutral');",
        "INSERT INTO (SELECT enum_range(NULL::mood));",
        "SELECT enum_range(NULL::mood) AS mood_values;",
        "UPDATE (SELECT enum_range(NULL::mood)) SET value = 'happy' WHERE value = 'sad';",
        "DELETE FROM (SELECT enum_range(NULL::mood)) WHERE value = 'neutral';"
