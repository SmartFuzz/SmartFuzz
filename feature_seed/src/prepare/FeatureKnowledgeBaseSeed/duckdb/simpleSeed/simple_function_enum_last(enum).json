    "feature_type": "function",
    "feature_name": "enum_last(enum)",
    "sql_array": [
        "CREATE TYPE mood AS ENUM('happy', 'sad', 'neutral');",
        "INSERT INTO mood VALUES ('happy');",
        "SELECT enum_last(ARRAY['happy', 'sad', 'neutral']::mood[]) AS last_mood;",
        "UPDATE mood SET mood = 'sad' WHERE mood = 'happy';",
        "SELECT enum_last(NULL::mood) AS last_null_mood;"
    ]
}