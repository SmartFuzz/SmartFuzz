[
    "SET VARIABLE my_var = 0;",
    "SELECT getvariable('my_var') AS initial_value;",
    "SET VARIABLE my_var = -1;",
    "SELECT getvariable('my_var') AS negative_value;",
    "SET VARIABLE my_var = 2147483647;",
    "SELECT 1 + getvariable('my_var') AS overflow_test;",
    "SET VARIABLE my_float_var = CAST(3.14 AS FLOAT);",
    "SELECT getvariable('my_float_var') AS pi;",
    "SET VARIABLE my_string_var = 'Test';",
    "SELECT getvariable('my_string_var') AS test_string;",
    "SET VARIABLE my_date_var = DATE '2023-10-01';",
    "SELECT getvariable('my_date_var') AS test_date;",
    "SET VARIABLE my_map_var = MAP {'key1': 10, 'key2': 20};",
    "SELECT getvariable('my_map_var') AS test_map;",
    "SET VARIABLE list_of_numbers = (SELECT LIST(1, 2, 3, 4, 5));",
    "SELECT getvariable('list_of_numbers') AS number_list;",
    "SET VARIABLE column_to_exclude = 'col1';",
    "CREATE TABLE test_table AS SELECT 1 AS col1, 2 AS col2, 3 AS col3;",
    "SELECT COLUMNS(c -> c != getvariable('column_to_exclude')) FROM test_table;",
    "SET VARIABLE my_var = 30;",
    "SET VARIABLE my_var = 100;",
    "SELECT 20 + getvariable('my_var') AS updated_total;",
    "SET VARIABLE undefined_var = (SELECT COUNT(*) FROM test_table WHERE 0);",
    "SELECT getvariable('undefined_var') AS count_result;",
    "SET VARIABLE my_var = 30;",
    "RESET VARIABLE my_var;",
    "SELECT getvariable('my_var') AS reset_var;",
    "CREATE TABLE another_table (id INTEGER, value VARCHAR);",
    "INSERT INTO another_table VALUES (1, 'One'), (2, 'Two'), (3, 'Three');",
    "SET VARIABLE string_list = (SELECT LIST(value) FROM another_table WHERE id > 1);",
    "SELECT getvariable('string_list') AS string_output;",
    "SET VARIABLE multi_var = (SELECT SUM(id) FROM another_table);",
    "SELECT getvariable('multi_var') AS sum_ids;",
    "SET VARIABLE complex_var = (SELECT COUNT(*) FROM (SELECT DISTINCT value FROM another_table));",
    "SELECT getvariable('complex_var') AS distinct_count;"
]