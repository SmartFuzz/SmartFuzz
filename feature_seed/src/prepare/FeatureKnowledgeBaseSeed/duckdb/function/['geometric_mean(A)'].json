[
    "CREATE TABLE numbers (value FLOAT);",
    "INSERT INTO numbers VALUES (1), (2), (3), (4), (5);",
    "SELECT geometric_mean(value) FROM numbers;",
    "CREATE TABLE empty_table (value FLOAT);",
    "SELECT geometric_mean(value) FROM empty_table;",
    "CREATE TABLE mixed (value FLOAT);",
    "INSERT INTO mixed VALUES (1), (NULL), (3), (4);",
    "SELECT geometric_mean(value) FROM mixed;",
    "SELECT geometric_mean(value) AS geo_mean FROM (SELECT value FROM numbers WHERE value > 0);",
    "CREATE TABLE small_numbers (num FLOAT);",
    "INSERT INTO small_numbers VALUES (0.1), (0.01), (0.001);",
    "SELECT geometric_mean(num) FROM small_numbers;",
    "CREATE TABLE negative_numbers (num FLOAT);",
    "INSERT INTO negative_numbers VALUES (-1), (-2), (-3);",
    "SELECT geometric_mean(num) FROM negative_numbers;",
    "CREATE TABLE nested_test AS SELECT value FROM (SELECT value FROM numbers WHERE value < 3) AS temp;",
    "SELECT geometric_mean(value) FROM nested_test;",
    "CREATE TABLE join_test (id INT, value FLOAT);",
    "INSERT INTO join_test VALUES (1, 2), (2, 3), (3, 4);",
    "SELECT geometric_mean(value) FROM join_test WHERE id IN (SELECT id FROM join_test WHERE value > 2);"
]