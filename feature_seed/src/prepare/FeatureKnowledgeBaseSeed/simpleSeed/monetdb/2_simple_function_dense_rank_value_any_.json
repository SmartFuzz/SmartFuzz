CREATE TABLE sales (id INT PRIMARY KEY, amount DECIMAL(10,2), category VARCHAR(50));
INSERT INTO sales (id, amount, category) VALUES (1, 100.00, 'electronics'), (2, 150.00, 'furniture'), (3, 150.00, 'furniture'), (4, 200.00, 'clothing');
SELECT id, amount, dense_rank() OVER (PARTITION BY category ORDER BY amount DESC) AS rank FROM sales;
UPDATE sales SET amount = amount * 1.1 WHERE id = 1;
SELECT category, sum(amount) AS total_sales, dense_rank() OVER (ORDER BY sum(amount) DESC) as sales_rank FROM sales GROUP BY category;