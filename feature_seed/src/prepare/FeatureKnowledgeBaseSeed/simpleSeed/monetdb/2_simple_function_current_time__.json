CREATE TABLE test_time_zones (id INT PRIMARY KEY, event_time TIMETZ DEFAULT current_time());
INSERT INTO test_time_zones (id) VALUES (1);
UPDATE test_time_zones SET event_time = current_time() WHERE id = 1;
SELECT id, event_time FROM test_time_zones WHERE event_time > current_time() - INTERVAL '1 hour';
SELECT id, current_time() AS current_time_zone FROM test_time_zones;