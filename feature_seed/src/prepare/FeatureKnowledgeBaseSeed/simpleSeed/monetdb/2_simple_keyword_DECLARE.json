DECLARE var1 integer, var2 integer;
SET var1 = 10;
SET var2 = 20;
SELECT var1 + var2 AS sum_result;
DECLARE name_var varchar(50);
SET name_var = 'MonetDB';
CREATE TABLE test_table (name varchar(50));
INSERT INTO test_table (name) VALUES (name_var);
DECLARE current_time timestamp;
SET current_time = now();
SELECT current_time AS current_time_value;
DECLARE count_var integer;
SET count_var = (SELECT COUNT(*) FROM sys.tables);
SELECT count_var AS table_count;
DECLARE temp_var float;
SET temp_var = 3.14;
UPDATE sys.tables SET name = CONCAT(name, '_updated') WHERE table_id < temp_var;