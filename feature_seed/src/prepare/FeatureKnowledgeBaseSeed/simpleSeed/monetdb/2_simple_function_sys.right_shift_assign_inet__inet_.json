CREATE TABLE inet_test (id INT PRIMARY KEY, ip_address INET);
INSERT INTO inet_test (id, ip_address) VALUES (1, inet '192.168.1.1');
INSERT INTO inet_test (id, ip_address) VALUES (2, inet '192.168.1.0/24');
