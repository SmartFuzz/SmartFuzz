CREATE TABLE test_timestamps (id INT, start_timestamp TIMESTAMP, end_timestamp TIMESTAMP);
INSERT INTO test_timestamps (id, start_timestamp, end_timestamp) VALUES (1, timestamp '2021-12-31 18:40:40', timestamp '2024-02-20 16:30:20');
INSERT INTO test_timestamps (id, start_timestamp, end_timestamp) VALUES (2, timestamp '2000-01-01 00:00:00', timestamp '2023-12-31 23:59:59');
