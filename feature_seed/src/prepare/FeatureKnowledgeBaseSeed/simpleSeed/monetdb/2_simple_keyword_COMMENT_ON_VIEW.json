CREATE VIEW mysch.articles_aggr AS SELECT author, COUNT(*) as article_count FROM mysch.articles GROUP BY author;
COMMENT ON VIEW mysch.articles_aggr IS 'view lists aggregated info on articles';
INSERT INTO mysch.articles (title, author) VALUES ('New Insights on SQL', 'Alice');
UPDATE mysch.articles SET title = 'Advanced SQL Techniques' WHERE author = 'Bob';
SELECT * FROM mysch.articles_aggr WHERE article_count > 5;