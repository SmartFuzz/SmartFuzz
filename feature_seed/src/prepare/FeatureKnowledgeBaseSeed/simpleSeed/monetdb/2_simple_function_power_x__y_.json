CREATE TABLE test_power (id INT PRIMARY KEY, base DOUBLE, exponent DOUBLE, result DOUBLE);
INSERT INTO test_power (id, base, exponent, result) VALUES (1, 2, 5, power(2, 5));
INSERT INTO test_power (id, base, exponent, result) VALUES (2, 3, 3, power(3, 3));
UPDATE test_power SET result = power(base, exponent) WHERE id = 1;
SELECT id, base, exponent, result FROM test_power WHERE result > 10;