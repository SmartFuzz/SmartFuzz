CREATE TABLE test_table (id INT, value VARCHAR(100));
INSERT INTO test_table (id, value) VALUES (1, 'Apple'), (2, 'Banana'), (3, NULL), (4, 'Cherry');
UPDATE test_table SET value = 'Orange' WHERE id = 2;
SELECT id, listagg(value) OVER () AS aggregated_values FROM test_table;
SELECT listagg(value) AS fruits FROM test_table WHERE value IS NOT NULL GROUP BY id;