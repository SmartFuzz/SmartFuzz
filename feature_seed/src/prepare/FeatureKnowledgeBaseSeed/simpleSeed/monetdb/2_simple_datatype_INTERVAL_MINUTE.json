CREATE TABLE time_intervals (id INT PRIMARY KEY, event_time TIMESTAMP, duration INTERVAL MINUTE);
INSERT INTO time_intervals (id, event_time, duration) VALUES (1, '2023-10-01 12:00:00', INTERVAL MINUTE '5');
UPDATE time_intervals SET event_time = event_time + duration WHERE id = 1;
SELECT id, event_time, duration FROM time_intervals WHERE duration > INTERVAL MINUTE '3';
DELETE FROM time_intervals WHERE duration = INTERVAL MINUTE '5';