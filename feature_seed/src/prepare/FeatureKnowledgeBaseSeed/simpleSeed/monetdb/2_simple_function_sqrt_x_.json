CREATE TABLE test_sqrt (id INT, value DOUBLE);
INSERT INTO test_sqrt (id, value) VALUES (1, 4.0), (2, 9.0), (3, 16.0);
UPDATE test_sqrt SET value = sqrt(value) WHERE id = 1;
SELECT id, sqrt(value) AS sqrt_value FROM test_sqrt;
CREATE TABLE sqrt_results AS SELECT id, sqrt(value) AS sqrt_value FROM test_sqrt;