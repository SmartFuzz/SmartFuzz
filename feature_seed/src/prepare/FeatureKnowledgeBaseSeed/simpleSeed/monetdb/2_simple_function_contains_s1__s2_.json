CREATE TABLE test_strings (id INT, str1 VARCHAR(20), str2 VARCHAR(20));
INSERT INTO test_strings (id, str1, str2) VALUES (1, 'hello', 'lo');
UPDATE test_strings SET str2 = 'world' WHERE id = 1;
SELECT id, str1, str2, contains(str1, str2) AS is_contained FROM test_strings;
SELECT * FROM test_strings WHERE contains(str1, 'e') AND id = 1;