CREATE TABLE test_strings (id INT PRIMARY KEY, text STRING);
INSERT INTO test_strings (id, text) VALUES (1, 'abc');
UPDATE test_strings SET text = replace(text, 'b', 'X') WHERE id = 1;
SELECT replace(text, 'a', 'A') AS modified_text FROM test_strings;
INSERT INTO test_strings (id, text) VALUES (2, replace('defg', 'd', 'D'));