CREATE TABLE ip_addresses (id INT PRIMARY KEY, addr INET);
INSERT INTO ip_addresses (id, addr) VALUES (1, inet '192.168.1.5/24');
UPDATE ip_addresses SET addr = sys.setmasklen(addr, 16) WHERE id = 1;
SELECT id, addr, sys.setmasklen(addr, 8) AS masked_addr FROM ip_addresses;
DELETE FROM ip_addresses WHERE addr = sys.setmasklen(inet '172.16.0.1/12', 12);