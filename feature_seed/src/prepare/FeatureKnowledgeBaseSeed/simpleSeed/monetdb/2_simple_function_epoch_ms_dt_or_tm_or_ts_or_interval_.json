CREATE TABLE timestamps (event_time TIMESTAMP);
INSERT INTO timestamps (event_time) VALUES (TIMESTAMP '2023-01-01 12:00:00');
UPDATE timestamps SET event_time = TIMESTAMP '2023-01-01 13:00:00' WHERE event_time = TIMESTAMP '2023-01-01 12:00:00';
SELECT epoch_ms(event_time) AS milliseconds FROM timestamps;
DELETE FROM timestamps WHERE event_time < TIMESTAMP '2023-01-01 12:00:00';