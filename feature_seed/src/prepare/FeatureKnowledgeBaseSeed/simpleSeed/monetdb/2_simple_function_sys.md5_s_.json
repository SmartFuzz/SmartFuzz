CREATE TABLE test_md5 (id INT, original_string CLOB, md5_hash CLOB);
INSERT INTO test_md5 (id, original_string, md5_hash) VALUES (1, 'hello', sys.md5('hello'));
UPDATE test_md5 SET md5_hash = sys.md5(original_string) WHERE id = 1;
SELECT id, original_string, md5_hash FROM test_md5 WHERE md5_hash = sys.md5('hello');
DELETE FROM test_md5 WHERE md5_hash = sys.md5('hello');