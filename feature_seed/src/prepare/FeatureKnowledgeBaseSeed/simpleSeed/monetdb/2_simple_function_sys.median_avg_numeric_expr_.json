CREATE TABLE test_data (id SERIAL PRIMARY KEY, value DOUBLE);
INSERT INTO test_data (value) VALUES (5.0), (7.0), (3.0), (9.0), (NULL), (2.0);
UPDATE test_data SET value = value * 2 WHERE id = 1;
SELECT sys.median_avg(value) FROM test_data WHERE value IS NOT NULL;
SELECT id, value, sys.median_avg(value) OVER () AS overall_median FROM test_data;