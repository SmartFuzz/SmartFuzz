CREATE TABLE test_times (id INT, start_time TIME, end_time TIME);
INSERT INTO test_times (id, start_time, end_time) VALUES (1, time '15:15:15', time '16:16:16');
INSERT INTO test_times (id, start_time, end_time) VALUES (2, time '14:14:14', time '17:17:17');
UPDATE test_times SET start_time = least(start_time, time '13:13:13') WHERE id = 1;
SELECT id, least(start_time, end_time) AS earliest_time FROM test_times;