CREATE TABLE daily_schedule (activity VARCHAR(255), start_time TIME(0));
INSERT INTO daily_schedule (activity, start_time) VALUES ('Morning Meeting', TIME '09:00:00');
UPDATE daily_schedule SET start_time = TIME '10:00:00' WHERE activity = 'Morning Meeting';
SELECT activity FROM daily_schedule WHERE start_time BETWEEN TIME '08:00:00' AND TIME '12:00:00';
DELETE FROM daily_schedule WHERE start_time < TIME '09:00:00';