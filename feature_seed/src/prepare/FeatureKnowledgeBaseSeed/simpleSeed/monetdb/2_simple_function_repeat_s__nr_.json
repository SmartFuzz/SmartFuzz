CREATE TABLE test_strings (id INT PRIMARY KEY, str_val VARCHAR(100));
INSERT INTO test_strings (id, str_val) VALUES (1, repeat('foo', 2));
UPDATE test_strings SET str_val = repeat(str_val, 5) WHERE id = 1;
SELECT id, repeat(str_val, 3) AS repeated_string FROM test_strings;
CREATE TABLE test_repeated (repeat_str VARCHAR(255));
INSERT INTO test_repeated (repeat_str) VALUES (repeat('abc ', 4));