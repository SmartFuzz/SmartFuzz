CREATE TABLE events (id SERIAL PRIMARY KEY, event_time TIMESTAMPTZ DEFAULT current_timestamp());
INSERT INTO events (event_time) VALUES (current_timestamp());
UPDATE events SET event_time = current_timestamp() WHERE id = 1;
SELECT id, event_time, current_timestamp() AS current_time FROM events;
CREATE TABLE time_log (log_time TIMESTAMPTZ);
INSERT INTO time_log (log_time) VALUES (current_timestamp());