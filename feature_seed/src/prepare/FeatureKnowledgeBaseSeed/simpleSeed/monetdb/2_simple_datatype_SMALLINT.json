CREATE TABLE test_smallint (id SMALLINT PRIMARY KEY, value SMALLINT);
INSERT INTO test_smallint (id, value) VALUES (1, 100), (2, -200);
UPDATE test_smallint SET value = SMALLINT(150) WHERE id = 1;
SELECT id, value FROM test_smallint WHERE value > SMALLINT(0);
DELETE FROM test_smallint WHERE value = SMALLINT(-200);