CREATE TABLE test_strings (id int, str varchar(32));
INSERT INTO test_strings (id, str) VALUES (1, 'abcdef');
UPDATE test_strings SET str = sys.ms_stuff(str, 3, 2, 'XY') WHERE id = 1;
SELECT str, sys.ms_stuff(str, 1, 3, '123') AS modified_str FROM test_strings;
SELECT sys.ms_stuff('Hello World', 7, 5, 'SQL') AS final_str;