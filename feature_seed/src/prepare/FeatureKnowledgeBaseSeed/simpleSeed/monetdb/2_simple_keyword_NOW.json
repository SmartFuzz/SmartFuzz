CREATE TABLE test_time (id INT PRIMARY KEY, event_time DATETIME DEFAULT NOW());
INSERT INTO test_time (id) VALUES (1);
UPDATE test_time SET event_time = NOW() WHERE id = 1;
SELECT id, event_time FROM test_time WHERE event_time > NOW() - INTERVAL '1 DAY';
DELETE FROM test_time WHERE event_time < NOW() - INTERVAL '30 DAYS';