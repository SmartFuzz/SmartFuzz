CREATE TABLE test_time_strings (id INT, time_entry TIMETZ);
INSERT INTO test_time_strings (id, time_entry) VALUES (1, timetz '14:15:30');
UPDATE test_time_strings SET time_entry = timetz '16:45:00' WHERE id = 1;
SELECT sys.time_to_str(time_entry, '%H:%M:%S %Z') FROM test_time_strings;
SELECT sys.time_to_str(time_entry, '%l hour %M:%S %p') AS formatted_time FROM test_time_strings;