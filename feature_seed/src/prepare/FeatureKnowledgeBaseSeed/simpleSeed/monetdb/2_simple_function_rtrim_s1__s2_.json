CREATE TABLE test_strings (id SERIAL PRIMARY KEY, str_value VARCHAR(255));
INSERT INTO test_strings (str_value) VALUES ('helloaaa'), ('worldaaa'), ('testaaa');
UPDATE test_strings SET str_value = rtrim(str_value, 'a') WHERE id IN (1, 2);
SELECT str_value, rtrim(str_value, 'a') AS trimmed_value FROM test_strings;
DELETE FROM test_strings WHERE rtrim(str_value, 'a') = 'test';