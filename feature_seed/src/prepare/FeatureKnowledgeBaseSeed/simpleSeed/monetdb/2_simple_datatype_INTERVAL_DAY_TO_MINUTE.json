CREATE TABLE test_intervals (id INT, duration INTERVAL DAY TO MINUTE);
INSERT INTO test_intervals (id, duration) VALUES (1, INTERVAL '2 DAYS 3 MINUTES');
UPDATE test_intervals SET duration = INTERVAL '1 DAY 15 MINUTES' WHERE id = 1;
SELECT id, duration, duration + INTERVAL '3 HOURS' AS extended_duration FROM test_intervals;
DELETE FROM test_intervals WHERE duration < INTERVAL '1 DAY';