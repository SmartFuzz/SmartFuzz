CREATE TABLE sales (id INT, region VARCHAR(100), amount DECIMAL(10, 2));
INSERT INTO sales (id, region, amount) VALUES (1, 'North', 100.00), (2, 'South', 150.00), (3, 'East', 200.00);
SELECT region, amount, diff(amount) OVER (PARTITION BY region ORDER BY id) AS is_different FROM sales;
UPDATE sales SET amount = amount * 1.10 WHERE region = 'North';
SELECT region, COUNT(*) AS count, diff(amount) OVER (PARTITION BY region ORDER BY id) AS is_different FROM sales GROUP BY region;