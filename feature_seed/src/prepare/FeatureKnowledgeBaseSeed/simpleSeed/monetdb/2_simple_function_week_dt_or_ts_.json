CREATE TABLE test_dates (id INT, dt DATE);
INSERT INTO test_dates (id, dt) VALUES (1, DATE '2020-03-22');
UPDATE test_dates SET dt = DATE '2020-12-31' WHERE id = 1;
SELECT id, week(dt) AS week_number FROM test_dates WHERE dt IS NOT NULL;
SELECT id, week(dt) AS week_number FROM test_dates WHERE week(dt) > 50;