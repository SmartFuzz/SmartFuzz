CREATE TABLE test_table (id INT, description VARCHAR(10));
INSERT INTO test_table (id, description) VALUES (1, rpad('abc', 6));
UPDATE test_table SET description = rpad('def', 4) WHERE id = 1;
SELECT id, rpad(description, 10) FROM test_table;
SELECT rpad(description, 5) || 'Suffix' AS modified_description FROM test_table;