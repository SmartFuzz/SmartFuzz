CREATE TABLE timestamps_test (id SERIAL PRIMARY KEY, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO timestamps_test (start_time, end_time) VALUES (timestamp '2021-12-31 18:40:40', timestamp '2021-12-20 16:30:20');
UPDATE timestamps_test SET end_time = timestamp '2021-12-31 20:40:40' WHERE id = 1;
SELECT id, timestampdiff_hour(start_time, end_time) AS hour_difference FROM timestamps_test;
SELECT COUNT(*) FROM timestamps_test WHERE timestampdiff_hour(start_time, end_time) > 100;