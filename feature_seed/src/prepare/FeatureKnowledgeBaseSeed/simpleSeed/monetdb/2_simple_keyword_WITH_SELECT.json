CREATE TABLE employees (id INT PRIMARY KEY, name VARCHAR(100), department VARCHAR(100));
INSERT INTO employees (id, name, department) VALUES (1, 'Alice', 'HR');
WITH dept_totals AS (SELECT department, COUNT(*) AS emp_count FROM employees GROUP BY department) SELECT * FROM dept_totals;
UPDATE employees SET department = 'Finance' WHERE id = 1;
WITH updated_dept AS (SELECT id, name FROM employees WHERE department = 'Finance') SELECT * FROM updated_dept;