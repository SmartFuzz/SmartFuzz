CREATE TABLE events (event_name VARCHAR(100), event_time TIME(0) WITH TIME ZONE);
INSERT INTO events (event_name, event_time) VALUES ('Conference', TIME '2023-10-10 10:00:00+01:00');
UPDATE events SET event_time = TIME '2023-10-11 14:00:00+02:00' WHERE event_name = 'Conference';
SELECT event_name, event_time AT TIME ZONE 'UTC' FROM events WHERE event_time > TIME '2023-10-10 12:00:00+01:00';
DELETE FROM events WHERE event_time < TIME '2023-10-10 09:00:00+01:00';