CREATE TABLE test_strings (id INT, str1 VARCHAR, str2 VARCHAR);
INSERT INTO test_strings (id, str1, str2) VALUES (1, 'Hello', 'World');
UPDATE test_strings SET str2 = concat(str1, ' Everyone') WHERE id = 1;
SELECT id, concat(str1, ' ', str2) AS full_string FROM test_strings;
SELECT concat(NULL, 'Test') AS result;