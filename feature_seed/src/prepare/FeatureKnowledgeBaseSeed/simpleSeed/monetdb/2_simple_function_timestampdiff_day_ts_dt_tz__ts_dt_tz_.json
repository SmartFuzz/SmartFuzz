CREATE TABLE test_timestamps (id integer, start_time timestamp, end_time timestamp);
INSERT INTO test_timestamps (id, start_time, end_time) VALUES (1, timestamp '2021-12-31 18:40:40', timestamp '2021-12-20 16:30:20');
