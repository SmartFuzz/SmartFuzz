CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255));
INSERT INTO test_strings (id, str1, str2) VALUES (1, 'banana', 'apple');
INSERT INTO test_strings (id, str1, str2) VALUES (2, 'cherry', 'berry');
UPDATE test_strings SET str1 = sql_min(str1, str2) WHERE id = 1;
SELECT id, sql_min(str1, str2) AS min_string FROM test_strings;