CREATE TABLE test_interval (id INT PRIMARY KEY, duration INTERVAL DAY TO HOUR);
INSERT INTO test_interval (id, duration) VALUES (1, INTERVAL '2 05:30' DAY TO HOUR);
INSERT INTO test_interval (id, duration) VALUES (2, INTERVAL '1 12:15' DAY TO HOUR);
UPDATE test_interval SET duration = duration + INTERVAL '0 03:45' DAY TO HOUR WHERE id = 1;
SELECT id, duration FROM test_interval WHERE duration < INTERVAL '3 00:00' DAY TO HOUR;