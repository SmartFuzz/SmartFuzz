CREATE TABLE test_table (id INT, name CLOB);
INSERT INTO test_table (id, name) VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');
SELECT sys.group_concat(name, ', ') FROM test_table;
UPDATE test_table SET name = sys.group_concat(name, ' & ') WHERE id IN (1, 2);
SELECT id, sys.group_concat(name, ';
') AS all_names FROM test_table GROUP BY id;