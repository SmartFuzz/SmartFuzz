CREATE TABLE test_ifnull (id INT, name VARCHAR(50));
INSERT INTO test_ifnull (id, name) VALUES (1, {fn IFNULL(null, 'John Doe')});
UPDATE test_ifnull SET name = {fn IFNULL(name, 'Anonymous')} WHERE id = 1;
SELECT id, {fn IFNULL(name, 'Unknown')} AS display_name FROM test_ifnull;
INSERT INTO test_ifnull (id, name) VALUES (2, {fn IFNULL('Jane Doe', null)});