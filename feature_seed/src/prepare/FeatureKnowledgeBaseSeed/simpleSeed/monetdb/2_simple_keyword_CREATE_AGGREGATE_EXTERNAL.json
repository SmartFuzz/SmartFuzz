CREATE TABLE test_aggregate (id serial PRIMARY KEY, value bigint);
CREATE AGGREGATE quantile(val bigint, q double) RETURNS bigint EXTERNAL NAME 'aggr.quantile';
INSERT INTO test_aggregate (value) VALUES (10), (20), (30), (40), (50);
SELECT quantile(value, 0.5) FROM test_aggregate;
UPDATE test_aggregate SET value = value * 2 WHERE id = 1;