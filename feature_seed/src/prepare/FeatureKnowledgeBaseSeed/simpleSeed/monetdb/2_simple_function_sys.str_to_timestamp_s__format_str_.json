CREATE TABLE orders (id INT PRIMARY KEY, order_time TIMESTAMPTZ);
INSERT INTO orders (id, order_time) VALUES (1, sys.str_to_timestamp('4/30/2021 09:30:49','%m/%d/%Y %H:%M:%S'));
UPDATE orders SET order_time = sys.str_to_timestamp('5/15/2021 14:22:30','%m/%d/%Y %H:%M:%S') WHERE id = 1;
