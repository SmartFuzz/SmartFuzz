CREATE TABLE time_intervals (start_time TIME, end_time TIME);
INSERT INTO time_intervals (start_time, end_time) VALUES (TIME '09:00:00', TIME '17:00:00');
UPDATE time_intervals SET end_time = TIME '16:30:00' WHERE start_time = TIME '09:00:00';
SELECT sql_sub(start_time, end_time) AS duration FROM time_intervals WHERE start_time < end_time;
SELECT sql_sub(TIME '12:00:00', TIME '08:30:00') AS lunch_duration;