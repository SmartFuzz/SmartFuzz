CREATE TABLE time_intervals (id SERIAL PRIMARY KEY, interval_data INTERVAL);
INSERT INTO time_intervals (interval_data) VALUES (INTERVAL '30' SECOND);
INSERT INTO time_intervals (interval_data) VALUES (INTERVAL '45' SECOND);
SELECT id, second(interval_data) AS extracted_seconds FROM time_intervals;
UPDATE time_intervals SET interval_data = INTERVAL '50' SECOND WHERE id = 1;