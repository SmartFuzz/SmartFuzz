CREATE TABLE test_dates(id INT, event_time TIMESTAMP);
INSERT INTO test_dates VALUES (1, TIMESTAMP '2023-10-01 12:00:00');
UPDATE test_dates SET event_time = sql_sub(event_time, INTERVAL '1:30' MINUTE TO SECOND) WHERE id = 1;
SELECT event_time, sql_sub(event_time, INTERVAL '2:15' MINUTE TO SECOND) AS adjusted_time FROM test_dates;
DELETE FROM test_dates WHERE event_time < sql_sub(TIMESTAMP '2023-10-02 00:00:00', INTERVAL '24:00' HOUR TO SECOND);