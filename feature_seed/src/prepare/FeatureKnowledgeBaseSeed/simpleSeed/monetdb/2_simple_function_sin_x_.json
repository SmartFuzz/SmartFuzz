CREATE TABLE angles (id SERIAL PRIMARY KEY, angle DOUBLE PRECISION);
INSERT INTO angles (angle) VALUES (1.0), (1.5), (2.0), (2.5);
UPDATE angles SET angle = angle + 0.1 WHERE id = 2;
SELECT id, sin(angle) AS sine_value FROM angles;
SELECT id, angle, sin(angle) * 100 AS scaled_sine FROM angles WHERE angle > 1;