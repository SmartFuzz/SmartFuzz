CREATE TABLE test_dates (event_date DATE, event_name VARCHAR(50));
INSERT INTO test_dates (event_date, event_name) VALUES ({d '2020-03-22'}, 'Spring Equinox');
UPDATE test_dates SET event_name = 'Spring Start' WHERE event_date = {d '2020-03-22'};
SELECT event_name, {fn DAYNAME(event_date)} AS day_name FROM test_dates;
SELECT COUNT(*) FROM test_dates WHERE {fn DAYNAME(event_date)} = 'Sunday';