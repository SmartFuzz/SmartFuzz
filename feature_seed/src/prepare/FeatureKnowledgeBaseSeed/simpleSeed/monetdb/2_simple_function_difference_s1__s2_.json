CREATE TABLE test_strings (id SERIAL PRIMARY KEY, str1 VARCHAR(100), str2 VARCHAR(100));
INSERT INTO test_strings (str1, str2) VALUES ('MonetDB', 'MonetD3');
UPDATE test_strings SET str2 = 'DB3' WHERE str1 = 'MonetDB';
SELECT id, difference(str1, str2) AS soundex_difference FROM test_strings WHERE difference(str1, str2) > 0;
