CREATE TABLE test_timestamps (id SERIAL PRIMARY KEY, start_time TIMESTAMP WITH TIME ZONE, end_time TIMESTAMP WITH TIME ZONE);
INSERT INTO test_timestamps (start_time, end_time) VALUES (timestamp '2021-12-31 18:40:40', timestamp '2021-02-20 16:30:20');
SELECT timestampdiff_month(start_time, end_time) AS month_difference FROM test_timestamps WHERE id = 1;
UPDATE test_timestamps SET end_time = timestamp '2021-01-15 12:00:00' WHERE id = 1;
SELECT timestampdiff_month(start_time, end_time) AS new_month_difference FROM test_timestamps WHERE id = 1;