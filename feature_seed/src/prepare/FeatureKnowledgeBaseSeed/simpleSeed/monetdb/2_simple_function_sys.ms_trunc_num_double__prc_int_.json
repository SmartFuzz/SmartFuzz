CREATE TABLE test_truncations (id INT, original_value DOUBLE, truncated_value DOUBLE);
INSERT INTO test_truncations (id, original_value, truncated_value) VALUES (1, 1.2359, sys.ms_trunc(1.2359, 2));
UPDATE test_truncations SET truncated_value = sys.ms_trunc(original_value, 1) WHERE id = 1;
SELECT id, original_value, truncated_value FROM test_truncations WHERE truncated_value = sys.ms_trunc(original_value, 3);
SELECT id, sys.ms_trunc(SUM(original_value), 1) AS truncated_sum FROM test_truncations GROUP BY id;