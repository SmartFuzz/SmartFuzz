CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE);
INSERT INTO test_dates (id, event_date) VALUES (1, date '2021-12-31');
UPDATE test_dates SET event_date = sql_add(event_date, interval '3' month) WHERE id = 1;
SELECT id, sql_add(event_date, interval '1' month) AS new_event_date FROM test_dates;
INSERT INTO test_dates (id, event_date) VALUES (2, sql_add(date '2022-05-15', interval '6' month));