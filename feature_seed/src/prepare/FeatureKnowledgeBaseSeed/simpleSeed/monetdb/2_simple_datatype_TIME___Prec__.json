CREATE TABLE test_time_data (id INT PRIMARY KEY, event_time TIME(3));
INSERT INTO test_time_data (id, event_time) VALUES (1, TIME('12:30:45.123'));
UPDATE test_time_data SET event_time = TIME('15:45:00.456') WHERE id = 1;
SELECT id, event_time FROM test_time_data WHERE event_time < TIME('13:00:00');
SELECT id, event_time FROM test_time_data ORDER BY event_time DESC;