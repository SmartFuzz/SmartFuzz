CREATE FUNCTION my_addition(a INT, b INT) RETURNS INT LANGUAGE PYTHON '{ return a + b;
}';
CREATE FUNCTION my_multiplication(a INT, b INT) RETURNS INT LANGUAGE PYTHON '{ return a * b;
}';
INSERT INTO my_table (value) SELECT my_addition(2, 3);
UPDATE my_table SET value = my_multiplication(value, 2) WHERE id = 1;
SELECT id, my_addition(value, 5) FROM my_table;