CREATE TABLE test_data (id INT, value_a DOUBLE, value_b DOUBLE);
INSERT INTO test_data (id, value_a, value_b) VALUES (1, 10.0, 20.0), (2, 20.0, 25.0), (3, 30.0, 30.0);
UPDATE test_data SET value_b = value_b + 5.0 WHERE id = 1;
SELECT sys.covar_samp(value_a, value_b) as covariance FROM test_data;
SELECT id, sys.covar_samp(value_a, value_b) OVER (PARTITION BY id) as partition_covariance FROM test_data;