CREATE TABLE test_strings (id INT PRIMARY KEY, str_value VARCHAR(100));
INSERT INTO test_strings VALUES (1, 'Hello World'), (2, 'Goodbye World'), (3, 'Test String');
SELECT id, str_value FROM test_strings WHERE startswith(str_value, 'Hello', true);
UPDATE test_strings SET str_value = 'Hello Everyone' WHERE startswith(str_value, 'Hello', true);
SELECT id FROM test_strings WHERE startswith(str_value, 'good', false) IS NULL;