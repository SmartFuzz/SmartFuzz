CREATE SCHEMA my_schema;
SET SCHEMA my_schema;
CREATE TABLE test_table (id INT, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
SELECT CURRENT_SCHEMA, id, name FROM test_table;
UPDATE test_table SET name = 'Bob' WHERE id = 1;
SELECT CURRENT_SCHEMA AS current_schema, COUNT(*) FROM test_table;