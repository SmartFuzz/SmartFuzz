CREATE TABLE test_data (id INT PRIMARY KEY, value DOUBLE);
INSERT INTO test_data (id, value) VALUES (1, 10.5), (2, 20.0), (3, 30.5);
UPDATE test_data SET value = value + 5 WHERE id = 1;
SELECT sys.stddev_pop(value) FROM test_data;
SELECT id, sys.stddev_pop(value) OVER () AS population_stddev FROM test_data;