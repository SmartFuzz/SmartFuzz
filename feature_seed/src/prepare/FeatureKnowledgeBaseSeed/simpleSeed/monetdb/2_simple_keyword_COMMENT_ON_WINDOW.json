CREATE WINDOW my_window AS SELECT id, AVG(value) OVER (PARTITION BY category ORDER BY date) AS avg_value FROM my_table;
COMMENT ON WINDOW FUNCTION my_window IS 'Calculates the average value for each category based on the date';
INSERT INTO my_table (id, category, value, date) VALUES (1, 'A', 10, '2023-01-01');
UPDATE my_table SET value = 20 WHERE id = 1;
SELECT id, category, avg_value FROM my_table WINDOW my_window;