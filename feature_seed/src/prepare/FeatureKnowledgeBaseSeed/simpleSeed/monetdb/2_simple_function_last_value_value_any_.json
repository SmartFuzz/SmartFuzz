CREATE TABLE sales (id INT, amount INT);
INSERT INTO sales (id, amount) VALUES (1, 100), (2, 200), (3, 300);
SELECT id, last_value(amount) OVER (ORDER BY id) AS last_amount FROM sales;
UPDATE sales SET amount = last_value(amount) OVER (ORDER BY id) WHERE id = 2;
SELECT id, last_value(amount) OVER (ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS last_amount FROM sales;