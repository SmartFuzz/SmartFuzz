CREATE TABLE test_strings (id INT PRIMARY KEY, str_value VARCHAR(10));
INSERT INTO test_strings (id, str_value) VALUES (1, 'abc');
UPDATE test_strings SET str_value = lpad(str_value, 6) WHERE id = 1;
SELECT id, lpad(str_value, 5) AS padded_value FROM test_strings;
SELECT lpad('xyz', 7) AS example_pad;