CREATE TABLE test_timestamps (id INT, start_time TIMESTAMPTZ, end_time TIMESTAMPTZ);
INSERT INTO test_timestamps (id, start_time, end_time) VALUES (1, timestamptz '2021-12-31 18:00:00+02:00', timestamptz '2022-01-01 18:00:00+02:00');
SELECT sql_sub(start_time, end_time) AS duration FROM test_timestamps WHERE id = 1;
UPDATE test_timestamps SET end_time = timestamptz '2022-01-02 00:00:00+03:00' WHERE id = 1;
SELECT sql_sub(start_time, end_time) AS updated_duration FROM test_timestamps WHERE id = 1;