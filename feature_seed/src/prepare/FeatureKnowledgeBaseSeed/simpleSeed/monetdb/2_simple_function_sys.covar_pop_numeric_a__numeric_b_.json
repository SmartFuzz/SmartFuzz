CREATE TABLE test_covariance (id INT, value_a DOUBLE, value_b DOUBLE);
INSERT INTO test_covariance (id, value_a, value_b) VALUES (1, 10.0, 20.0), (2, 30.0, 60.0), (3, 50.0, 100.0);
UPDATE test_covariance SET value_a = value_a * 1.1 WHERE id = 1;
SELECT sys.covar_pop(value_a, value_b) AS population_covariance FROM test_covariance;
DELETE FROM test_covariance WHERE id = 2;