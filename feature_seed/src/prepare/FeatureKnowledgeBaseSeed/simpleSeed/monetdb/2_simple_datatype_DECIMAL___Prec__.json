CREATE TABLE test_decimals (id INT PRIMARY KEY, value DECIMAL(10));
INSERT INTO test_decimals (id, value) VALUES (1, DECIMAL(10, 2)(123.45));
UPDATE test_decimals SET value = DECIMAL(10, 2)(678.90) WHERE id = 1;
SELECT id, value FROM test_decimals WHERE value > DECIMAL(10, 2)(100.00);
DELETE FROM test_decimals WHERE value < DECIMAL(10, 2)(500.00);