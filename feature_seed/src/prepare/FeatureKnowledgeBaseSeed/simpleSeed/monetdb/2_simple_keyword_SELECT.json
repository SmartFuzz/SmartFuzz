CREATE TABLE employees (id INT, name VARCHAR(100), salary DECIMAL(10,2), department VARCHAR(50));
INSERT INTO employees (id, name, salary, department) VALUES (1, 'Alice', 70000.00, 'HR');
UPDATE employees SET salary = salary * 1.10 WHERE department = 'HR';
SELECT name, salary FROM employees WHERE salary > 50000 ORDER BY salary DESC;
DELETE FROM employees WHERE id = 1;