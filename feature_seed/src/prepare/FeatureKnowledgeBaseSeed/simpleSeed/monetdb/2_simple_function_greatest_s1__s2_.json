CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(100), str2 VARCHAR(100));
INSERT INTO test_strings (id, str1, str2) VALUES (1, 'apple', 'orange');
INSERT INTO test_strings (id, str1, str2) VALUES (2, 'banana', 'avocado');
SELECT greatest(str1, str2) AS max_string FROM test_strings;
UPDATE test_strings SET str2 = greatest(str1, 'kiwi') WHERE id = 1;