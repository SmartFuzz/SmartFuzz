CREATE TABLE test_strings (id INT, content VARCHAR(100));
INSERT INTO test_strings (id, content) VALUES (1, 'highigh'), (2, 'stringtest'), (3, 'searching');
UPDATE test_strings SET content = 'updatedhigh' WHERE id = 1;
SELECT id, charindex('gh', content, 1) AS position FROM test_strings;
SELECT id, content, charindex('test', content, 1) > 0 AS contains_test FROM test_strings;