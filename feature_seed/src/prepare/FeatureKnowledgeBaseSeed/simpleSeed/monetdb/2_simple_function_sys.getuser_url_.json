CREATE TABLE users (id INT PRIMARY KEY, url CLOB);
INSERT INTO users (id, url) VALUES (1, 'http://user@example.com');
SELECT sys.getuser(url) FROM users WHERE id = 1;
UPDATE users SET url = 'http://newuser@example.com' WHERE id = 1;
SELECT id, sys.getuser(url) AS user FROM users WHERE sys.getuser(url) IS NOT NULL;