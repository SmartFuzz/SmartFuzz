CREATE TABLE test_filter_func (id INT PRIMARY KEY, name TEXT);
CREATE FILTER FUNCTION my_like(text, text) RETURNS boolean AS $$ SELECT $1 LIKE '%' || $2 || '%';
$$;
INSERT INTO test_filter_func (id, name) VALUES (1, 'example');
SELECT * FROM test_filter_func WHERE my_like(name, 'ex');
DROP ALL FILTER FUNCTION my_like CASCADE;