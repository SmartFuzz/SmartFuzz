CREATE TABLE events (event_id INT PRIMARY KEY, event_time TIMESTAMP(3));
INSERT INTO events (event_id, event_time) VALUES (1, TIMESTAMP(3) '2023-10-10 10:10:10.123');
UPDATE events SET event_time = TIMESTAMP(6) '2023-10-10 11:11:11.654321' WHERE event_id = 1;
SELECT event_id, event_time, TIMESTAMP(2) '2023-10-10 12:12:12.34' AS comparison_time FROM events WHERE event_time > TIMESTAMP(3) '2023-10-10 00:00:00.000';
DELETE FROM events WHERE event_time < TIMESTAMP(0) '2023-01-01 00:00:00';