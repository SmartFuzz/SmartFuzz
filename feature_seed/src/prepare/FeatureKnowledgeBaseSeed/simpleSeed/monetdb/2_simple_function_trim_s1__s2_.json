CREATE TABLE test_strings (id INT, data VARCHAR(100));
INSERT INTO test_strings (id, data) VALUES (1, '  aabcdaa  ');
UPDATE test_strings SET data = trim(data, ' ') WHERE id = 1;
SELECT id, trim(data, 'a') AS trimmed_data FROM test_strings;
