CREATE TABLE intervals (id INT, duration INTERVAL SECOND);
INSERT INTO intervals (id, duration) VALUES (1, INTERVAL '5 second'), (2, INTERVAL '10 second'), (3, INTERVAL '15 second');
UPDATE intervals SET duration = duration + INTERVAL '5 second' WHERE id = 1;
SELECT sum(cast(duration as interval second)) FROM intervals;
SELECT id, sum(cast(duration as interval second)) OVER (PARTITION BY id) AS total_duration FROM intervals;