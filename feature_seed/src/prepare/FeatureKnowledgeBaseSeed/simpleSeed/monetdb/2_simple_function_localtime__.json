CREATE TABLE current_time_test (id INTEGER PRIMARY KEY, current_time TIME);
INSERT INTO current_time_test (id, current_time) VALUES (1, localtime());
UPDATE current_time_test SET current_time = localtime() WHERE id = 1;
SELECT id, current_time FROM current_time_test;
SELECT id, localtime() as current_local_time FROM current_time_test WHERE current_time < localtime();