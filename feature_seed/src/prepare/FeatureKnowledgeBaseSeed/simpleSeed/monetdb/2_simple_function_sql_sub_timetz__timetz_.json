CREATE TABLE test_times (time1 timetz, time2 timetz, interval_sec sec_interval);
INSERT INTO test_times (time1, time2) VALUES (timetz '08:30:00+01:00', timetz '09:30:00+01:00');
UPDATE test_times SET interval_sec = sql_sub(time2, time1) WHERE time1 = timetz '08:30:00+01:00';
SELECT time1, time2, interval_sec FROM test_times WHERE interval_sec IS NOT NULL;
SELECT sql_sub(timetz '20:00:00+05:00', timetz '19:00:00+03:00') AS interval_result;