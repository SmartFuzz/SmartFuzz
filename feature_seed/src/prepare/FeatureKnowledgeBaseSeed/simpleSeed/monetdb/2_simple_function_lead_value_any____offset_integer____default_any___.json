CREATE TABLE sales (id INT, amount DECIMAL(10, 2), sale_date DATE);
INSERT INTO sales (id, amount, sale_date) VALUES (1, 100.00, '2023-01-01');
INSERT INTO sales (id, amount, sale_date) VALUES (2, 150.00, '2023-01-02');
SELECT id, lead(amount, 1, 0) OVER (ORDER BY sale_date) AS next_amount FROM sales;
UPDATE sales SET amount = lead(amount, 1, 0) OVER (ORDER BY sale_date) WHERE id = 1;