CREATE TABLE sales (id INT, amount DECIMAL(10, 2), region VARCHAR(50));
INSERT INTO sales (id, amount, region) VALUES (1, 250.00, 'North'), (2, 150.50, 'South'), (3, 300.75, 'East');
SELECT region, MAX(amount) OVER (PARTITION BY region) AS max_amount FROM sales;
UPDATE sales SET amount = amount * 1.1 WHERE region = 'South';
SELECT region, amount, MAX(amount) OVER (ORDER BY amount DESC) AS max_running FROM sales;