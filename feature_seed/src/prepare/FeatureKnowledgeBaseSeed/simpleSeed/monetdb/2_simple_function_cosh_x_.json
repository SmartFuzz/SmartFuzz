CREATE TABLE hyperbolic_values (id SERIAL PRIMARY KEY, value DOUBLE PRECISION);
INSERT INTO hyperbolic_values (value) VALUES (cosh(0));
UPDATE hyperbolic_values SET value = cosh(2.5) WHERE id = 1;
SELECT id, value, cosh(value) AS hyperbolic_cosh FROM hyperbolic_values;
DELETE FROM hyperbolic_values WHERE value < cosh(1);