CREATE TABLE test_time_data (id INT PRIMARY KEY, time_value TIMETZ);
INSERT INTO test_time_data (id, time_value) VALUES (1, sys.str_to_time('14:45:00', '%H:%M:%S'));
UPDATE test_time_data SET time_value = sys.str_to_time('23:59:59', '%H:%M:%S') WHERE id = 1;
SELECT * FROM test_time_data WHERE time_value > sys.str_to_time('12:00:00', '%H:%M:%S');
SELECT id, sys.str_to_time('18:30:00', '%H:%M:%S') AS converted_time FROM test_time_data;