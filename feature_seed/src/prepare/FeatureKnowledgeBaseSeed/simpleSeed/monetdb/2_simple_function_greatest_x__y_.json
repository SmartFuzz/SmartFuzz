CREATE TABLE test_dates (date1 DATE, date2 DATE);
INSERT INTO test_dates (date1, date2) VALUES (date '2020-03-22', date '2020-03-25');
UPDATE test_dates SET date2 = greatest(date1, date2) WHERE date1 < date2;
SELECT greatest(date1, date2) AS max_date FROM test_dates;
DELETE FROM test_dates WHERE greatest(date1, date2) = date '2020-03-25';