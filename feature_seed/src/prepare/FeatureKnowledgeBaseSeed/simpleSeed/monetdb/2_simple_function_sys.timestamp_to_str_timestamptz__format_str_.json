CREATE TABLE test_timestamps (id INT PRIMARY KEY, event_time TIMESTAMPTZ);
INSERT INTO test_timestamps (id, event_time) VALUES (1, TIMESTAMPTZ '2022-07-15 14:30:00');
UPDATE test_timestamps SET event_time = TIMESTAMPTZ '2023-01-01 10:00:00' WHERE id = 1;
SELECT sys.timestamp_to_str(event_time, '%Y-%m-%d %H:%M:%S %Z') FROM test_timestamps;
SELECT sys.timestamp_to_str(event_time, '%A, %d %B %Y %I:%M:%S %p') AS formatted_time FROM test_timestamps;