CREATE TABLE test_negation (value FLOAT);
INSERT INTO test_negation (value) VALUES (sql_neg(-3.5));
UPDATE test_negation SET value = sql_neg(value) WHERE value < 0;
SELECT value, sql_neg(value) AS negated_value FROM test_negation;
SELECT sql_neg(2 + 3) AS negated_sum, sql_neg(10.5 * 2) AS negated_product;