CREATE TABLE test_floats (id INT PRIMARY KEY, value FLOAT(24));
INSERT INTO test_floats (id, value) VALUES (1, 3.14);
INSERT INTO test_floats (id, value) VALUES (2, 2.718281828459045);
UPDATE test_floats SET value = value + FLOAT(53)(1.0) WHERE id = 1;
SELECT id, value, value * FLOAT(24)(2) AS doubled_value FROM test_floats;