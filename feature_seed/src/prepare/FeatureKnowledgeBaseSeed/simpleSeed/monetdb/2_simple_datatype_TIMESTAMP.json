CREATE TABLE events (event_id INT PRIMARY KEY, event_time TIMESTAMP(6));
INSERT INTO events (event_id, event_time) VALUES (1, TIMESTAMP('2023-10-05 14:30:00.123456'));
UPDATE events SET event_time = TIMESTAMP('2023-10-06 09:00:00.654321') WHERE event_id = 1;
SELECT event_id, event_time FROM events WHERE event_time > TIMESTAMP('2023-10-05 00:00:00.000000');
DELETE FROM events WHERE event_time < TIMESTAMP('2023-10-01 00:00:00.000000');