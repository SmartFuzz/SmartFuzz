CREATE TABLE test_strings (id INT, str_value TEXT);
INSERT INTO test_strings VALUES (1, 'bar'), (2, 'foo'), (3, 'baz');
UPDATE test_strings SET str_value = 'new_foo' WHERE id = 2;
SELECT field('foo', str_value) FROM test_strings;
SELECT id, field('foo', str_value, 'bar', 'baz') AS position FROM test_strings;