CREATE TABLE test_timestamps (id INT, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO test_timestamps (id, start_time, end_time) VALUES (1, timestamp '2021-12-31 18:00:00', timestamp '2021-12-31 17:00:00');
SELECT id, sql_sub(end_time, start_time) AS time_difference FROM test_timestamps;
UPDATE test_timestamps SET end_time = timestamp '2021-12-31 19:00:00' WHERE id = 1;
SELECT id, sql_sub(end_time, start_time) AS updated_time_difference FROM test_timestamps;