CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255));
INSERT INTO test_strings (id, str1, str2) VALUES (1, 'hello world', 'world');
INSERT INTO test_strings (id, str1, str2) VALUES (2, 'fizzbuzz', 'buzz');
SELECT id, endswith(str1, str2) AS is_endswith FROM test_strings WHERE endswith(str1, str2) IS TRUE;
UPDATE test_strings SET str2 = 'world!' WHERE id = 1;