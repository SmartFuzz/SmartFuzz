CREATE TABLE test_strings (id INT, data CLOB);
INSERT INTO test_strings (id, data) VALUES (1, 'abcdefghijklm');
UPDATE test_strings SET data = substring(data, 4, 5) WHERE id = 1;
SELECT substring(data, 1, 3) FROM test_strings WHERE id = 1;
SELECT substring(data, 2, 4) AS extracted FROM test_strings;