CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table (id, value) VALUES (1, ifthenelse((1 = 1), 100, 200));
UPDATE test_table SET value = ifthenelse((id = 1), 300, 400) WHERE id = 1;
SELECT id, ifthenelse((value > 150), 'High', 'Low') AS value_category FROM test_table;
DELETE FROM test_table WHERE id = ifthenelse((SELECT COUNT(*) FROM test_table) > 0, 1, 2);