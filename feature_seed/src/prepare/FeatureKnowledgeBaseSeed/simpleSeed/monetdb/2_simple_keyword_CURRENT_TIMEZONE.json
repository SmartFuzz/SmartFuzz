CREATE TABLE user_timezones (id INT PRIMARY KEY, user_name VARCHAR(100), timezone VARCHAR(50));
INSERT INTO user_timezones (id, user_name, timezone) VALUES (1, 'Alice', CURRENT_TIMEZONE);
UPDATE user_timezones SET timezone = CURRENT_TIMEZONE WHERE user_name = 'Alice';
SELECT user_name, timezone FROM user_timezones WHERE timezone = CURRENT_TIMEZONE;
SELECT COUNT(*) FROM user_timezones WHERE timezone != CURRENT_TIMEZONE;