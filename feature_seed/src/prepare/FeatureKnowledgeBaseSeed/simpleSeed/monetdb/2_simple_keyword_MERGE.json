CREATE TABLE ProductTarget (ProductID INT, Name VARCHAR(100), ProductNumber VARCHAR(50), Color VARCHAR(30));
CREATE TABLE ProductSource (ProductID INT, Name VARCHAR(100), ProductNumber VARCHAR(50), Color VARCHAR(30));
INSERT INTO ProductSource (ProductID, Name, ProductNumber, Color) VALUES (1, 'Widget', 'W123', 'Blue');
INSERT INTO ProductSource (ProductID, Name, ProductNumber, Color) VALUES (2, 'Gadget', 'G456', 'Red');
MERGE INTO ProductTarget T USING ProductSource S ON S.ProductID = T.ProductID WHEN MATCHED THEN UPDATE SET Name = S.Name, ProductNumber = S.ProductNumber, Color = S.Color WHEN NOT MATCHED THEN INSERT (ProductID, Name, ProductNumber, Color) VALUES (S.ProductID, S.Name, S.ProductNumber, S.Color);