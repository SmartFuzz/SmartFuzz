CREATE TABLE test_dates(id INT, event_date DATE);
INSERT INTO test_dates VALUES (1, DATE '2023-10-01');
UPDATE test_dates SET event_date = DATE '2022-01-01' WHERE id = 1;
SELECT extract(year from event_date) FROM test_dates;
SELECT id, extract(month from event_date) as month FROM test_dates WHERE extract(year from event_date) > 2020;