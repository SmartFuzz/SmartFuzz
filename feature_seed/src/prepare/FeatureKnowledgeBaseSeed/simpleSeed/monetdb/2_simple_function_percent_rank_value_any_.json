CREATE TABLE test_rank (id INT, score DOUBLE);
INSERT INTO test_rank (id, score) VALUES (1, 95.0), (2, 85.0), (3, 75.0), (4, 65.0);
SELECT id, score, percent_rank(score) OVER (ORDER BY score DESC) AS rank FROM test_rank;
UPDATE test_rank SET score = 90.0 WHERE id = 2;
SELECT id, score, percent_rank(score) OVER (PARTITION BY id ORDER BY score) AS rank FROM test_rank;