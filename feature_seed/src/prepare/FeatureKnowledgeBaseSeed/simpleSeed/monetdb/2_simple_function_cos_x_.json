CREATE TABLE angles (id SERIAL PRIMARY KEY, angle_value DOUBLE PRECISION);
INSERT INTO angles (angle_value) VALUES (0), (1.57), (3.14), (6.28);
SELECT angle_value, cos(angle_value) AS cosine_value FROM angles;
UPDATE angles SET angle_value = angle_value + 1.0 WHERE id = 2;
SELECT id, angle_value, cos(angle_value) AS cosine_value FROM angles WHERE angle_value > 0;