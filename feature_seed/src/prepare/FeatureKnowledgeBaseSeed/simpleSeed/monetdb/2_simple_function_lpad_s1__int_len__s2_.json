CREATE TABLE test_strings (id INT, str_val VARCHAR(10));
INSERT INTO test_strings (id, str_val) VALUES (1, 'abc');
UPDATE test_strings SET str_val = lpad(str_val, 6, 'DB') WHERE id = 1;
SELECT lpad(str_val, 6, 'DB') AS padded_string FROM test_strings WHERE id = 1;
INSERT INTO test_strings (id, str_val) VALUES (2, lpad('xyz', 5, '123'));