CREATE TABLE test_math (id INT, value FLOAT);
INSERT INTO test_math (id, value) VALUES (1, 6.8);
UPDATE test_math SET value = sql_div(value, 2) WHERE id = 1;
SELECT id, sql_div(value, 3) AS divided_value FROM test_math;
SELECT id, value, value * 2 AS double_value, sql_div(value, 4) AS quarter_value FROM test_math;