CREATE LOADER json_loader(filename STRING) LANGUAGE PYTHON {
    import json
    f = open(filename)
    emit.emit(json.load(f))
    f.close()
};
CREATE TABLE test_data (id INT, data STRING);
INSERT INTO test_data VALUES (1, 'Sample Data');
SELECT * FROM test_data WHERE id = 1;
UPDATE test_data SET data = 'Updated Data' WHERE id = 1;