CREATE TABLE sales_data (id INTEGER, amount INTEGER, category STRING);
INSERT INTO sales_data VALUES (1, 100, 'electronics'), (2, 200, 'furniture'), (3, 150, 'groceries');
CREATE AGGREGATE total_sales(amount INTEGER) RETURNS INTEGER LANGUAGE PYTHON {
    return sum(amount);
};
SELECT category, total_sales(amount) FROM sales_data GROUP BY category;
UPDATE sales_data SET amount = amount * 1.1 WHERE category = 'electronics';