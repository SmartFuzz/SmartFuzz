CREATE TABLE sales (id INT, amount DECIMAL, sale_date DATE);
INSERT INTO sales (id, amount, sale_date) VALUES (1, 100.00, '2023-01-01');
INSERT INTO sales (id, amount, sale_date) VALUES (2, 150.50, '2023-01-02');
SELECT first_value(amount) OVER (ORDER BY sale_date) AS first_sale FROM sales;
UPDATE sales SET amount = first_value(amount) OVER (PARTITION BY id ORDER BY sale_date) WHERE id = 1;