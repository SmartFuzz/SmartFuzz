CREATE TABLE test_dates (id INT, event_date TIMESTAMP);
INSERT INTO test_dates (id, event_date) VALUES (1, TIMESTAMP '2023-10-01 10:00:00');
UPDATE test_dates SET event_date = TIMESTAMP '2023-10-15 12:00:00' WHERE id = 1;
SELECT day(event_date) AS day_of_event FROM test_dates;
SELECT id, event_date, day(event_date) FROM test_dates WHERE day(event_date) > 15;