CREATE TABLE test_json (id INT PRIMARY KEY, data JSON);
INSERT INTO test_json (id, data) VALUES (1, json '{"a":[1, 2, 3], "b":true}');
INSERT INTO test_json (id, data) VALUES (2, json '{"c":[4, 5], "d":"example"}');
SELECT id, json.length(data) AS length FROM test_json WHERE json.length(data) > 2;
UPDATE test_json SET data = json '{"e":[6, 7], "f":false}' WHERE id = 1;