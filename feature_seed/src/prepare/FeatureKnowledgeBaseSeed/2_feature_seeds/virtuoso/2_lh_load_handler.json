CREATE TABLE lang_handlers (id INT PRIMARY KEY, iso_code VARCHAR(10), rfc_code VARCHAR(10), handler VARCHAR(255));
INSERT INTO lang_handlers VALUES (1, 'en', 'en-US', 'English US'), (2, 'fr', 'fr-FR', 'French'), (3, 'es', 'es-ES', 'Spanish');
SELECT lh_load_handler(SELECT iso_code FROM lang_handlers WHERE id IN (1, 2)) FROM dual;
SELECT lh_load_handler(SELECT iso_code FROM lang_handlers WHERE rfc_code IN ('fr-FR', 'en-US')) FROM dual;
SELECT lh_load_handler(COALESCE((SELECT handler FROM lang_handlers WHERE iso_code IN (SELECT DISTINCT iso_code FROM lang_handlers)), 'default_handler'));
SELECT lh_load_handler(SELECT iso_code FROM lang_handlers WHERE iso_code IN ('de', 'fr') OR rfc_code IN ('le-FR')) FROM dual;
SELECT COUNT(*) OVER (PARTITION BY iso_code) FROM lang_handlers WHERE id IN (SELECT id FROM lang_handlers WHERE handler IN ('Spanish', NULL));
SELECT lh_load_handler(SELECT iso_code FROM lang_handlers WHERE NULLIF(iso_code, 'es') IS NOT NULL) FROM dual;
UPDATE lang_handlers SET handler = 'Updated English US' WHERE id IN (SELECT id FROM lang_handlers WHERE iso_code IN ('en', 'fr')) AND iso_code IN (SELECT iso_code FROM lang_handlers);
SELECT lh_load_handler((SELECT iso_code FROM lang_handlers WHERE id = (SELECT MIN(id) FROM lang_handlers))) FROM dual;