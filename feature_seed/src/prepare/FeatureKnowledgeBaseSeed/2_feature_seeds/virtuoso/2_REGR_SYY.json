CREATE TABLE sales_data (id INT PRIMARY KEY, amount DECIMAL(10, 2), category VARCHAR(50), sale_date DATE);
INSERT INTO sales_data (id, amount, category, sale_date) VALUES (1, 100.00, 'Electronics', '2023-01-01'), (2, 150.50, 'Clothing', '2023-01-02'), (3, NULL, 'Sports', '2023-01-03'), (4, 250.75, 'Groceries', '2023-01-04');
SELECT REGR_SYY(amount, amount / NULLIF(id, 0)) AS reg_stat FROM sales_data GROUP BY category HAVING REGR_SYY(amount, amount / NULLIF(id, 0)) > 0 ORDER BY category;
SELECT category, REGR_SYY(amount, amount / (SELECT AVG(amount) FROM sales_data WHERE amount IS NOT NULL)) AS reg_stat FROM sales_data GROUP BY category HAVING COUNT(*) > 1;
SELECT category, REGR_SYY(amount, 100 / (COALESCE(NULLIF(MAX(amount), 0), 1))) AS reg_stat FROM sales_data GROUP BY category;
SELECT category, REGR_SYY(amount, amount / (CASE WHEN id = 1 THEN NULL ELSE id END)) AS reg_stat FROM sales_data WHERE amount IS NOT NULL GROUP BY category HAVING reg_stat IS NOT NULL;
DROP TABLE IF EXISTS temp_sales;
CREATE TABLE temp_sales AS SELECT id, amount, category FROM sales_data WHERE sale_date >= '2023-01-01' AND sale_date < '2023-01-05';
SELECT REGR_SYY(amount, CASE WHEN id > 2 THEN amount / 2 ELSE amount END) AS reg_stat FROM temp_sales GROUP BY category HAVING COUNT(*) > 1;