CREATE TABLE TEST_XML_SPATIAL (I integer primary key, XMLVAL XMLType, location geometry);
INSERT INTO TEST_XML_SPATIAL VALUES (1, XMLType('<emp><empno>221</empno><ename>John</ename></emp>'), 'POINT(1 1)');
INSERT INTO TEST_XML_SPATIAL VALUES (2, XMLType('<po><pono>331</pono><poname>PO_1</poname></po>'), 'POINT(2 2)');
INSERT INTO TEST_XML_SPATIAL VALUES (3, XMLType('<oil-rig xml:id="14a_05" water="0.413"/><oil-rig xml:id="14b_05" water="0.402"/>'), NULL);
SELECT e.I, e.XMLVAL.getRootElement().getClobVal(), bif:st_distance(e.location, 'POINT(1 1)') as distance FROM TEST_XML_SPATIAL e WHERE e.XMLVAL.getRootElement() IS NOT NULL ORDER BY distance;
SELECT e.I, e.XMLVAL.getClobVal() FROM TEST_XML_SPATIAL e WHERE e.XMLVAL.getRootElement() IS NULL AND bif:st_distance(e.location, 'POINT(5 5)') IS NULL;
SELECT e.I, e.XMLVAL.getRootElement().getClobVal(), SUM(bif:st_distance(e.location, 'POINT(2 3)')) OVER (PARTITION BY e.I) AS total_distance FROM TEST_XML_SPATIAL e GROUP BY e.I, e.XMLVAL.getRootElement().getClobVal() HAVING total_distance > 0;
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM TEST_XML_SPATIAL e WHERE e.XMLVAL.getRootElement() IS NOT NULL AND bif:st_distance(e.location, 'POINT(0 0)') < 500;
INSERT INTO TEST_XML_SPATIAL VALUES (4, XMLType('<root><child><subchild>test</subchild></child></root>'), NULL);
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM (SELECT e.I, e.XMLVAL.getRootElement() FROM TEST_XML_SPATIAL e WHERE e.location IS NOT NULL) sub WHERE sub.XMLVAL.getRootElement() IS NOT NULL;