CREATE TABLE soap_test (id INT PRIMARY KEY, wsdl_url VARCHAR(255), imported_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO soap_test (id, wsdl_url) VALUES (1, 'http://example.com/chemistry.wsdl');
SELECT * FROM soap_test WHERE imported_at <= NOW();
SELECT SOAP_WSDL_IMPORT(wsdl_url) FROM soap_test WHERE id = 1;
SELECT id, (SELECT COUNT(*) FROM soap_test) AS url_count FROM soap_test WHERE SOAP_WSDL_IMPORT(wsdl_url) <= 0;
SELECT id, xml_tree_doc (Chemistry.getElementBySymbol('H')) AS element_info FROM soap_test WHERE id <= (SELECT MAX(id) FROM soap_test);
CREATE TABLE elements (element_id INT PRIMARY KEY, symbol VARCHAR(5), atomic_number INT NOT NULL);
INSERT INTO elements (element_id, symbol, atomic_number) VALUES (1, 'H', 1), (2, 'He', 2);
SELECT e.symbol, e.atomic_number FROM elements e JOIN soap_test st ON e.atomic_number <= 10 WHERE st.id <= 1;
SELECT XML_TREE_DOC(Chemistry.getElementBySymbol('He')) AS helium_info WHERE helium_info IS NOT NULL AND helium_info <= '<response>';