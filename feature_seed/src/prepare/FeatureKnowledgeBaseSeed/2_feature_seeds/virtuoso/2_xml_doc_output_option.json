CREATE TABLE xml_test (id INT PRIMARY KEY, xml_content XML, some_value INT);
INSERT INTO xml_test (id, xml_content, some_value) VALUES (1, '<data><item>Value1</item></data>', 10), (2, '<data><item>Value2</item></data>', 20);
SELECT id, xml_doc_output_option(xtree_doc(xml_content, 2, '', 'UTF-8'), 'doctype-system', 'http://www.example.com/test.dtd') > some_value AS is_greater FROM xml_test WHERE some_value IS NOT NULL;
SELECT id, xml_doc_output_option(xtree_doc('<data><item>Value1</item></data>', 2, '', 'UTF-8'), 'method', 'xml') > 0 FROM xml_test HAVING COUNT(*) > 0;
SELECT id, xml_content, (SELECT xml_doc_output_option(xtree_doc(xml_content, 2, '', 'UTF-8'), 'version') FROM xml_test WHERE id = 1) AS version_output FROM xml_test WHERE xml_content IS NOT NULL;
SELECT id, xml_doc_output_option(xtree_doc(xml_content, 2, '', 'UTF-8'), 'omit-xml-declaration', 'yes') AS omission FROM xml_test WHERE some_value > 5;
CREATE TABLE xml_storage (id INT PRIMARY KEY, xml_data XML);
INSERT INTO xml_storage (id, xml_data) VALUES (1, '<root><child>Hello</child></root>'), (2, '<root><child>World</child></root>');
SELECT id, xml_doc_output_option(xtree_doc(xml_data, 2, '', 'UTF-8'), 'encoding', 'UTF-16') > 0 FROM xml_storage;
SELECT x.id, xml_doc_output_option(xtree_doc(x.xml_content, 2, '', 'UTF-8'), 'standalone', 'yes') AS standalone_output FROM xml_test x JOIN xml_storage y ON xml_doc_output_option(xtree_doc(x.xml_content, 2, '', 'UTF-8'), 'indent') > 2;
SELECT x.id, xml_doc_output_option(xtree_doc(x.xml_content, 2, '', 'UTF-8'), 'doctype-public', NULLIF('public_id', '')) AS public_id_output FROM xml_test x WHERE EXISTS (SELECT 1 FROM xml_storage y WHERE x.id = y.id);