CREATE TABLE ldap_entries (id SERIAL PRIMARY KEY, dn VARCHAR(255) NOT NULL, mail VARCHAR(255), c VARCHAR(2), o VARCHAR(255));
INSERT INTO ldap_entries (dn, mail, c, o) VALUES ('cn=John Atanasov,mail=hellraisor@hotmail.com,c=US,o=hotmail.com', 'hellraisor@hotmail.com', 'US', 'hotmail.com');
INSERT INTO ldap_entries (dn, mail, c, o) VALUES ('cn=Jane Doe,mail=jane@example.com,c=US,o=example.com', 'jane@example.com', 'US', 'example.com');
SELECT ldap_delete('ldap://localhost', 0, (SELECT dn FROM ldap_entries WHERE mail REGEXP '.*hotmail.com$' LIMIT 1), NULL);
SELECT dn FROM ldap_entries WHERE LENGTH(dn) > 0 AND dn REGEXP 'cn=.*' GROUP BY dn HAVING COUNT(*) > 0 ORDER BY dn DESC;
SELECT dn, ldap_delete('ldap://localhost', 0, dn, NULL) FROM ldap_entries WHERE dn REGEXP 'cn=John.*' AND LENGTH(dn) = (SELECT MAX(LENGTH(dn)) FROM ldap_entries);
SELECT CASE WHEN ldap_delete('ldap://localhost', 0, (SELECT dn FROM ldap_entries WHERE mail IS NULL LIMIT 1), NULL) IS NULL THEN 'Failed' ELSE 'Success' END AS DeletionStatus;
CREATE TEMPORARY TABLE temp_results AS SELECT dn FROM ldap_entries WHERE dn REGEXP 'cn=Jane.*';
SELECT * FROM temp_results WHERE dn REGEXP '^cn=.*' AND (SELECT COUNT(*) FROM temp_results) > 1;
DROP TABLE IF EXISTS temp_results;