CREATE TABLE test_dict (id INT PRIMARY KEY, data STRING);
INSERT INTO test_dict (id, data) VALUES (1, 'example'), (2, 'test'), (3, NULL);
CREATE TABLE test_data (key_col STRING, value_col STRING);
INSERT INTO test_data (key_col, value_col) VALUES ('key1', 'value1'), ('key2', 'value2'), (NULL, 'value3');
SELECT dict_new( dict_new( (SELECT key_col FROM test_data WHERE bif:contains(value_col, 'value')) ) ) AS nested_dict FROM test_data WHERE data IS NOT NULL;
SELECT id, bif:contains(data, dict_new(NULL)) AS match FROM test_dict WHERE bif:contains(data, dict_new('example'));
SELECT dict_new( 'key', SUM(value_col) ) FROM (SELECT value_col FROM test_data WHERE value_col IS NOT NULL GROUP BY key_col HAVING COUNT(*) > 1) AS subquery WHERE bif:contains(value_col, 'value1') OR value_col IS NULL;
SELECT DISTINCT id, data, dict_new(CAST(data AS STRING), SUM(id)) AS aggregated_dict FROM test_dict JOIN test_data ON bif:contains(data, key_col) GROUP BY id, data HAVING COUNT(*) > 0;
SELECT id, dict_new( 'min', MIN(data), 'max', MAX(data) ) FROM (SELECT data FROM test_dict) AS inner_query WHERE bif:contains(data, 'example') GROUP BY id;
INSERT INTO test_dict (id, data) VALUES (4, 'edge_case_string');
SELECT dict_new( 'test_key', AVG(CAST(data AS FLOAT)) ) AS average_dict FROM test_dict WHERE data IS NOT NULL AND bif:contains(data, 'edge_case_string');