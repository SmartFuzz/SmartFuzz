CREATE TABLE Contacts (ID INT NOT NULL, Data VARCHAR(255), CreatedAt TIMESTAMP DEFAULT CURRENT_TIMESTAMP, PRIMARY KEY(ID));
INSERT INTO Contacts (ID, Data) VALUES (1, 'John Doe, john.doe@example.com, 123 Main St'), (2, 'Jane Smith, jane.smith@example.com, 456 Elm St');
SELECT ID, csv_table_def((SELECT Data FROM Contacts WHERE ID = 1)) AS TableDef WHERE Data REGEXP '.*Doe.*';
SELECT ID, REGEXP_REPLACE(Data, 'St$', '') AS Address FROM Contacts WHERE Data REGEXP '.*Elm.*';
SELECT ID, (SELECT COUNT(*) FROM Contacts WHERE Data REGEXP '.*Doe.*') AS DoeCount, csv_table_def((SELECT Data FROM Contacts)) AS FullTableDef FROM Contacts GROUP BY ID HAVING DoeCount > 0;
CREATE TABLE CSVData AS SELECT Data FROM Contacts WHERE Data REGEXP '.*Doe.*' AND csv_table_def('tmp/FilteredContacts.csv') IS NOT NULL;
SELECT Data, NULLIF(Data, '') AS CleanData FROM Contacts WHERE CleanData IS NOT NULL ORDER BY CleanData;
INSERT INTO Contacts (ID, Data) VALUES (3, 'NULL'), (4, '');
SELECT ID, REGEXP(Data, '^[A-Za-z]+$') AS IsAlpha FROM Contacts WHERE ID IN (SELECT ID FROM Contacts WHERE Data IS NOT NULL);
CREATE TABLE TempContacts AS SELECT ID, REGEXP(Data, '.*@example.com') AS IsExampleEmail FROM Contacts;
SELECT COUNT(ID) AS TotalContacts, SUM(CASE WHEN Data REGEXP '.*@example.com' THEN 1 ELSE 0 END) AS ExampleContacts FROM Contacts;
SELECT ID, csv_table_def('tmp/MyContactsLong.csv') AS LongCSVDef FROM Contacts WHERE Data REGEXP '^[A-Z].*';
SELECT ID, REGEXP_LIKE(Data, '.*St.*') AS ContainsStreet, csv_table_def(NULLIF(Data, '')) AS NullSafeTableDef FROM Contacts;
CREATE TABLE EachContact AS SELECT ID, Data, csv_table_def('tmp/EachContact.csv') AS ContactCSVDef FROM Contacts WHERE Data IS NOT NULL;
SELECT AVG(LENGTH(Data)) AS AvgDataLength, csv_table_def('tmp/DataStatistics.csv') AS DataStatsDef FROM Contacts WHERE Data REGEXP '^.{0,100}$';