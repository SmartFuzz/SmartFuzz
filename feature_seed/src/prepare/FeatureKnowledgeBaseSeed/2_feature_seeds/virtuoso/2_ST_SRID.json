CREATE TABLE geospatial_data (id INT PRIMARY KEY, geom GEOMETRY, description VARCHAR(255));
INSERT INTO geospatial_data VALUES (1, ST_Point(10, 30), 'Point A'), (2, ST_Point(20, 40), 'Point B');
SELECT id, ST_SRID(geom) + 1 AS updated_srid FROM geospatial_data WHERE ST_SRID(geom) IS NOT NULL;
SELECT id, geom FROM geospatial_data WHERE ST_SRID(geom) + ST_SRID(ST_Point(10, 30)) > 4326;
SELECT id, ST_SRID(geom) + 10 AS adjusted_srid FROM geospatial_data GROUP BY id HAVING adjusted_srid < 4430;
SELECT g1.id, g1.geom AS geom1, g2.geom AS geom2 FROM geospatial_data g1 JOIN geospatial_data g2 ON ST_SRID(g1.geom) + ST_SRID(g2.geom) = 8646;
SELECT id, geom FROM geospatial_data WHERE ST_SRID(geom) IS NULL OR ST_SRID(geom) + 10 IS NULL;
SELECT id, ST_SRID(geom) AS srid_value FROM geospatial_data WHERE NOT EXISTS (SELECT 1 FROM geospatial_data g WHERE g.id = geospatial_data.id AND ST_SRID(g.geom) = ST_SRID(geospatial_data.geom));
CREATE TEMPORARY TABLE temp_geospatial_data AS SELECT id, geom FROM geospatial_data;
SELECT id, ST_SRID(geom) + (SELECT COUNT(*) FROM temp_geospatial_data WHERE ST_SRID(temp_geospatial_data.geom) = ST_SRID(geospatial_data.geom)) AS complex_srid FROM geospatial_data;