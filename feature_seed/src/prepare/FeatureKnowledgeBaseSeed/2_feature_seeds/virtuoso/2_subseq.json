CREATE TABLE test_data (id INT PRIMARY KEY, value VARCHAR(50), coordinates GEOMETRY);
INSERT INTO test_data (id, value, coordinates) VALUES (1, 'Example/test/string', ST_GeomFromText('POINT(1 1)'));
INSERT INTO test_data (id, value, coordinates) VALUES (2, 'AnotherEx//ample', ST_GeomFromText('POINT(2 2)'));
SELECT id, subseq(value, 0, 10) AS substring_value FROM test_data WHERE value IS NOT NULL;
SELECT id, bif:st_overlaps(coordinates, ST_GeomFromText('POINT(1 1)')) AS overlap_check FROM test_data WHERE id = (SELECT id FROM test_data WHERE value = subseq(value, 0, 5));
SELECT id, value, subseq(value, 0, LENGTH(value)/2) AS half_value FROM test_data WHERE bif:st_overlaps(coordinates, ST_GeomFromText('POINT(1 1)')) ORDER BY half_value DESC;
SELECT id, subseq(value, 0, 5) AS short_value FROM test_data WHERE value IS NULL OR value = '' ORDER BY short_value;
SELECT id, COUNT(*) AS overlap_count FROM test_data WHERE bif:st_overlaps(coordinates, ST_GeomFromText('POINT(2 2)')) GROUP BY subseq(value, 0, 5) HAVING overlap_count > 0;
SELECT id FROM (SELECT id, subseq(value, 0, 50) AS long_value FROM test_data) AS subquery WHERE long_value LIKE 'Example%';
SELECT id, subseq(value, 0, 20) FROM test_data WHERE 1 = bif:st_overlaps(coordinates, ST_GeomFromText('POINT(2 3)')) AND value IS NOT NULL;