CREATE TABLE test_table (id INT, data STRING, num FLOAT, array_data ARRAY);
INSERT INTO test_table VALUES (1, 'example', 10.5, [1.0, 2.5, 3.1]), (2, NULL, NULL, [NULL]), (3, '', 0.0, []);
SELECT bif_string_arg(data) AS string_value, bif_long_arg(num) % 2 AS modulus FROM test_table WHERE num IS NOT NULL;
SELECT id, bif_array_arg(array_data) AS array_val FROM test_table WHERE bif_float_arg(num) % 2 = 1;
SELECT id, bif_entity_arg(data) AS entity_val FROM test_table WHERE array_data IS NOT NULL ORDER BY bif_double_arg(num) DESC;
SELECT id, bif_string_or_null_arg(data) AS string_or_null FROM test_table WHERE bif_long_or_char_arg(id) % 2 = 0;
SELECT id, bif_strses_arg(data), COUNT(*) OVER (PARTITION BY bif_float_arg(num) % 2) AS count_modulus FROM test_table GROUP BY id, data, num, array_data HAVING COUNT(*) > 1;
SELECT t1.id, t1.data, t2.num FROM test_table t1 JOIN test_table t2 ON bif_string_arg(t1.data) = bif_string_arg(t2.data) AND bif_long_arg(t1.id) % bif_long_arg(t2.id) = 1;
SELECT t1.id, bif_float_arg(t1.num) + bif_float_arg(t2.num) AS summed FROM test_table t1 CROSS JOIN test_table t2 WHERE t1.array_data IS NOT EMPTY;
CREATE TABLE temp_table (id INT PRIMARY KEY, description STRING, created_at TIMESTAMP NOT NULL DEFAULT NOW());
INSERT INTO temp_table VALUES (1, 'test', NOW()), (2, NULL, NOW()), (3, '', NOW());
SELECT bif_string_or_null_arg(description), bif_bin_arg(CAST(created_at AS STRING)) % 10 AS time_mod FROM temp_table WHERE bif_string_arg(description) IS NULL;
ALTER TABLE temp_table DROP COLUMN description;