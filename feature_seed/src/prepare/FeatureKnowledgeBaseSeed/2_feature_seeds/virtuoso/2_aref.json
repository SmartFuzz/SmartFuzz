CREATE TABLE my_table (id INT PRIMARY KEY, name VARCHAR(100), values_array VECTOR(3));
INSERT INTO my_table (id, name, values_array) VALUES (1, 'Sample', vector('A', 1, 5.5));
SELECT aref(values_array, 1) AS second_value, aref(name, 0) AS first_char FROM my_table WHERE aref(values_array, 0) > 0;
SELECT * FROM my_table WHERE id IN (SELECT id FROM my_table WHERE aref(values_array, aref(vector(1, 2, 3), 0)) = 1);
SELECT name, COUNT(*) FROM my_table GROUP BY aref(values_array, 1) HAVING aref(values_array, 0) <= aref(values_array, 2);
CREATE TABLE my_other_table (id INT, class VARCHAR(50), value FLOAT);
INSERT INTO my_other_table (id, class, value) VALUES (1, 'ExampleClass', 3.14);
SELECT * FROM my_table mt JOIN my_other_table mot ON mot.id = mt.id WHERE mot.class = 'ExampleClass' AND aref(values_array, 2) IS NOT NULL;
SELECT mt.name, aref(mot.class, 0) FROM my_table mt JOIN my_other_table mot ON mot.id = mt.id WHERE aref(values_array, 0) = 0 AND aref(values_array, 1) IS NULL;
SELECT aref(ARRAY(SELECT id FROM my_table WHERE name LIKE '%Sample%'), 0) AS first_id WHERE first_id IS NOT NULL;
SELECT mot.class AS rdf_type WHERE mot.value > aref(mot.value, 0) AND mot.id IN (SELECT id FROM my_table) { ?s a <Class> } ORDER BY aref(ARRAY(SELECT value FROM my_other_table), 0);
ALTER TABLE my_table ADD COLUMN new_value VARCHAR(100);
UPDATE my_table SET new_value = aref(values_array, 1) WHERE id = 1;
DROP TABLE my_other_table;