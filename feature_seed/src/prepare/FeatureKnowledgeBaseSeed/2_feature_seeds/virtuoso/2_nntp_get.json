CREATE TABLE my_extended_news (m_id integer, m_group varchar, m_text long varchar, m_date datetime, PRIMARY KEY (m_id, m_group));
INSERT INTO my_extended_news (m_id, m_group, m_text, m_date) VALUES (1, 'comp.lang.java.api', 'First Article', '2023-01-01 12:00:00'), (2, 'comp.lang.java.api', 'Second Article', NULL), (3, 'comp.lang.java.api', 'NULL Handling Test', NULL);
CREATE PROCEDURE fetch_articles (IN server varchar, IN grp varchar) BEGIN DECLARE res, ent any;
DECLARE i, l integer;
res := nntp_get(server, 'article', grp, 0, 1000);
SET i = 0;
SET l = length(res);
WHILE i < l DO SET ent = res[i];
INSERT INTO my_extended_news (m_id, m_group, m_text, m_date) VALUES (ent[0], grp, ent[1], NOW());
SET i = i + 1;
END WHILE;
END;
CALL fetch_articles('news.techno-link.com:119', 'comp.lang.java.api');
SELECT m_id, m_group, mail_header(m_text, 'Subject') AS subject FROM my_extended_news WHERE m_date IS NULL AND m_group = 'comp.lang.java.api';
SELECT AVG(length(m_text)), m_group FROM my_extended_news GROUP BY m_group HAVING AVG(length(m_text)) > 10;
SELECT DISTINCT m_group, COUNT(*) FROM my_extended_news WHERE m_text IS NOT NULL GROUP BY m_group HAVING COUNT(*) > 1;
CREATE TABLE temp_articles AS SELECT ent[0] AS article_id, ent[1] AS article_text FROM nntp_get('news.techno-link.com:119', 'article', 'comp.lang.java.api', 0, 10);
SELECT m_id, XPath('@id', xml_data) AS id FROM my_xml_table WHERE m_id IN (SELECT m_id FROM my_extended_news WHERE m_text LIKE '%Test%');
WITH ranked_articles AS (SELECT m_id, m_text, ROW_NUMBER() OVER (PARTITION BY m_group ORDER BY m_date DESC) AS rank FROM my_extended_news) SELECT m_id, m_text FROM ranked_articles WHERE rank = 1;