CREATE TABLE test_table (id INT NOT NULL, value VARCHAR(255), timestamp DATETIME DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, value) VALUES (1, 'value1'), (2, NULL), (3, 'value2'), (4, '');
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.value) FROM (SELECT value FROM test_table WHERE value IS NOT NULL) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG((CASE WHEN id IS NOT NULL THEN value ELSE 'default' END)) FROM test_table;
SELECT id, DB.DBA.VECTOR_OF_NONNULLS_AGG(value) FROM test_table GROUP BY id HAVING COUNT(value) > 1;
SELECT DISTINCT DB.DBA.VECTOR_OF_NONNULLS_AGG(value) OVER (PARTITION BY id ORDER BY value) FROM test_table;
CREATE TABLE another_table (id INT NOT NULL, ref_id INT, CONSTRAINT fk_ref FOREIGN KEY (ref_id) REFERENCES test_table(id));
INSERT INTO another_table (id, ref_id) VALUES (1, 1), (2, NULL), (3, 3);
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(value) FROM (SELECT t.value FROM test_table t JOIN another_table a ON t.id = a.ref_id WHERE a.ref_id IS NOT NULL) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(CAST(value AS CHAR)) FROM (SELECT value FROM test_table WHERE value IS NOT NULL OR value = '') as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(COALESCE(timestamp, '1970-01-01 00:00:00')) FROM test_table WHERE id < 10;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(DISTINCT value) FROM test_table WHERE value IS NOT NULL GROUP BY value HAVING COUNT(*) >= 2;