CREATE TABLE test_dict (id INT PRIMARY KEY, data_dict STRING);
INSERT INTO test_dict (id, data_dict) VALUES (1, '{"key1": 10, "key2": 20, "key3": 30}');
INSERT INTO test_dict (id, data_dict) VALUES (2, '{"key1": null, "key2": 25}');
INSERT INTO test_dict (id, data_dict) VALUES (3, '{"key4": 40}');
SELECT dict_get(data_dict, 'key2') % 5 AS mod_value FROM test_dict WHERE id = 1;
SELECT dict_get(data_dict, 'key1') %% NULL AS null_mod FROM test_dict WHERE id = 2;
SELECT dict_get(data_dict, 'key3') % (SELECT COUNT(*) FROM test_dict) AS mod_count FROM test_dict;
SELECT id, dict_get(data_dict, 'key1') % 3 AS mod_value FROM test_dict WHERE dict_get(data_dict, 'key2') IS NOT NULL;
SELECT id, dict_get(data_dict, 'key2') % dict_get(data_dict, 'key1') AS mod_self_ref FROM test_dict;
SELECT id FROM test_dict WHERE dict_get(data_dict, 'key2') IS NULL GROUP BY id HAVING dict_get(data_dict, 'key1') % 2 = 0;
SELECT id, dict_get(data_dict, 'key5', 100) % 7 AS default_mod FROM test_dict;
SELECT dict_get(data_dict, 'key3') AS key_value, (dict_get(data_dict, 'key2') % 10) AS mod_value FROM test_dict WHERE id IN (SELECT id FROM test_dict WHERE dict_get(data_dict, 'key1') IS NOT NULL);
SELECT id, CASE WHEN dict_get(data_dict, 'key1') IS NULL THEN 0 ELSE dict_get(data_dict, 'key1') % 2 END AS mod_case FROM test_dict;