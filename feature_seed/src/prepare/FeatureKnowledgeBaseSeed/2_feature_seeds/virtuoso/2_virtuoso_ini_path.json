CREATE TABLE test_config (id INT PRIMARY KEY, path VARCHAR(255), description VARCHAR(255));
INSERT INTO test_config (id, path, description) VALUES (1, virtuoso_ini_path(), 'Default ini file path');
SELECT id, path, description FROM test_config WHERE path = (SELECT virtuoso_ini_path() FROM test_config WHERE id = 1);
SELECT id, path FROM test_config WHERE path IS NULL OR path = '';
CREATE TABLE file_stats (file_name VARCHAR(255), file_size INT);
INSERT INTO file_stats (file_name, file_size) VALUES ('config.ini', 2048);
SELECT file_name, file_size FROM file_stats WHERE file_size > (SELECT COUNT(*) FROM test_config);
SELECT virtuoso_ini_path() AS config_path, 1 = 1 AS check_true, 0 = NULL AS check_null;
CREATE TABLE config_associations (config_id INT, associated_file VARCHAR(255), PRIMARY KEY (config_id, associated_file));
INSERT INTO config_associations (config_id, associated_file) VALUES (1, virtuoso_ini_path());
SELECT config_id, associated_file FROM config_associations WHERE associated_file = (SELECT virtuoso_ini_path());
SELECT * FROM test_config WHERE (SELECT COUNT(*) FROM config_associations WHERE config_id = test_config.id) >= 1;
SELECT path, LENGTH(path) FROM test_config GROUP BY path HAVING LENGTH(path) > 50;
CREATE TABLE edge_cases (num_value INT, str_value VARCHAR(255));
INSERT INTO edge_cases (num_value, str_value) VALUES (2147483647, 'max_int'), (-2147483648, 'min_int'), (0, NULL);
SELECT str_value FROM edge_cases WHERE num_value = 2147483647 AND str_value IS NOT NULL;
SELECT virtuoso_ini_path() FROM (SELECT DISTINCT path FROM test_config) AS subquery WHERE EXISTS (SELECT 1 FROM edge_cases WHERE num_value IS NOT NULL);