CREATE TABLE People (id INT, name VARCHAR(255), age INT, interest VARCHAR(255), occupation VARCHAR(255));
INSERT INTO People VALUES (1, 'Alice', 30, 'http://example.com/interest1', NULL), (2, 'Bob', NULL, 'http://example.com/interest2', 'Engineer'), (3, 'Charlie', 25, NULL, 'Artist');
SELECT sql:SAMPLE(?name), sql:SAMPLE(?interest) FROM (SELECT ?name, ?interest WHERE { ?p a foaf:Person . ?p foaf:name ?name . ?p foaf:interest ?interest . }) AS subquery WHERE ?name != '' && ?interest IS NOT NULL;
SELECT sql:SAMPLE(?interest) AS random_interest FROM People WHERE age IS NOT NULL && (interest = 'http://example.com/interest1' || interest = 'http://example.com/interest2') GROUP BY occupation HAVING COUNT(*) > 1;
SELECT sql:SAMPLE(?nick) FROM (SELECT ?nick WHERE { ?p a foaf:Person . ?p foaf:nick ?nick . }) AS subquery WHERE (LENGTH(?nick) > 0) && (sql:SAMPLE(?age) IS NULL);
SELECT p1.name, p2.name FROM People AS p1 JOIN People AS p2 ON p1.age = p2.age WHERE sql:SAMPLE(p1.occupation) = 'Engineer' && sql:SAMPLE(p2.interest) IS NOT NULL;
SELECT sql:SAMPLE(?name) FROM (SELECT ?name, ?interest WHERE { ?p a foaf:Person . ?p foaf:name ?name . ?p foaf:interest ?interest . }) AS subquery GROUP BY ?name HAVING COUNT(?interest) > 1 && COUNT(?interest) < 3;
SELECT sql:SAMPLE(?age) FROM People WHERE (age <= 30) && (age >= 0) ORDER BY age DESC LIMIT 5;
SELECT sql:SAMPLE(NULLIF(?interest, '')) FROM People WHERE age IS NOT NULL && (interest IS NOT NULL || occupation IS NOT NULL);
INSERT INTO People VALUES (4, 'Diana', 40, 'http://example.com/interest3', 'NULL');