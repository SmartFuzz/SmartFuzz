CREATE TABLE test_table (id INT PRIMARY KEY, TIME_CHANGED DATETIME, value VARCHAR(100));
INSERT INTO test_table (id, TIME_CHANGED, value) VALUES (1, now(), 'test1'), (2, now() - INTERVAL '1' HOUR, 'test2'), (3, NULL, 'test3');
SELECT * FROM test_table WHERE TIME_CHANGED NOT IN (SELECT TIME_CHANGED FROM test_table WHERE value IS NULL);
SELECT id, value FROM test_table WHERE id NOT IN (SELECT id FROM test_table WHERE TIME_CHANGED IS NOT NULL) AND TIME_CHANGED >= now() - INTERVAL '1' DAY;
SELECT count(*) FROM test_table GROUP BY value HAVING TIME_CHANGED NOT IN (now() - INTERVAL '2' HOUR, now());
SELECT id, TIME_CHANGED FROM test_table WHERE TIME_CHANGED NOT IN (SELECT cast(now() + INTERVAL '1' DAY AS DATETIME) WHERE value = 'test1');
CREATE TABLE other_table (ref_id INT, ref_time DATETIME);
INSERT INTO other_table (ref_id, ref_time) VALUES (1, now()), (2, NULL), (3, now() - INTERVAL '5' MINUTE);
SELECT ot.ref_id FROM other_table ot JOIN test_table tt ON ot.ref_time NOT IN (tt.TIME_CHANGED) WHERE tt.value NOT IN (SELECT value FROM test_table WHERE TIME_CHANGED IS NULL);
SELECT value, COUNT(*) FROM test_table GROUP BY value HAVING COUNT(*) NOT IN (SELECT COUNT(*) FROM test_table WHERE TIME_CHANGED IS NOT NULL) AND now() - TIME_CHANGED < INTERVAL '1' DAY;