CREATE TABLE TestTable (id INT PRIMARY KEY, value1 FLOAT, value2 FLOAT, category VARCHAR(50));
INSERT INTO TestTable (id, value1, value2, category) VALUES (1, 10.5, NULL, 'A'), (2, 20.0, 30.5, 'B'), (3, 30.0, 25.5, 'A'), (4, NULL, 40.0, 'C'), (5, 15.5, NULL, 'B');
SELECT REGR_SXX(value1, value2) AS regression_stats FROM TestTable WHERE category = 'A' AND value1 IS NOT NULL;
SELECT REGR_SXX(value1, (SELECT AVG(value2) FROM TestTable WHERE category = 'B' AND value2 IS NOT NULL)) FROM TestTable WHERE category = 'A';
SELECT t1.id, REGR_SXX(t1.value1, t1.value2) AS regression_stats FROM TestTable t1 LEFT JOIN TestTable t2 ON t1.category = t2.category WHERE t1.value1 IS NOT NULL GROUP BY t1.id HAVING REGR_SXX(t1.value1, t1.value2) IS NOT NULL;
SELECT REGR_SXX(COALESCE(t2.value1, 0), t1.value2) AS regression_stats FROM TestTable t1 JOIN TestTable t2 ON t1.category = t2.category WHERE t1.value1 IS NOT NULL AND t2.value2 IS NOT NULL GROUP BY t1.category HAVING MAX(t1.value1) > 10 ORDER BY regression_stats DESC;
CREATE TABLE ClassTable (id INT PRIMARY KEY, class_type VARCHAR(50));
INSERT INTO ClassTable (id, class_type) VALUES (1, 'TypeA'), (2, 'TypeB'), (3, 'TypeA');
SELECT REGR_SXX(value1, value2) AS regression_stats FROM TestTable WHERE id IN (SELECT id FROM ClassTable WHERE class_type = 'TypeA') GROUP BY id;
SELECT REGR_SXX(AVG(value1), MAX(value2)) AS regression_stats FROM TestTable WHERE value1 > 0 AND id IN (SELECT id FROM ClassTable WHERE class_type = 'TypeB');
SELECT t1.category, REGR_SXX(t1.value1, t2.value2) FROM TestTable t1 JOIN TestTable t2 ON t1.category = t2.category WHERE t1.value1 IS NOT NULL AND t2.value2 IS NOT NULL GROUP BY t1.category HAVING COUNT(t1.id) > 1;