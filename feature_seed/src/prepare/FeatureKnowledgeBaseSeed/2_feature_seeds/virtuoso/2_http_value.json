CREATE TABLE test_data (id INT, value VARCHAR(255), created_at TIMESTAMP);
INSERT INTO test_data (id, value, created_at) VALUES (1, '<script>alert(1)</script>', NOW()), (2, NULL, NULL), (3, 'normal', NOW());
SELECT http_value(value) FROM test_data WHERE value ILIKE '%<scri%';
SELECT id, http_value(value) AS escaped_value FROM test_data WHERE value IS NOT NULL;
SELECT COUNT(*) FROM (SELECT http_value(value) AS html_escaped FROM test_data WHERE id ILIKE '1%') AS subquery;
SELECT id, value FROM test_data WHERE value ILIKE CONCAT('%', http_value('normal'), '%') OR value IS NULL;
SELECT http_value(count(1)::VARCHAR), AVG(id) FROM test_data GROUP BY http_value(value) HAVING http_value(value) IS NOT NULL;
SELECT DISTINCT http_value(sub.value) FROM (SELECT value FROM test_data WHERE created_at IS NOT NULL) AS sub;
CREATE TABLE another_table (ref_id INT REFERENCES test_data(id), description TEXT);
INSERT INTO another_table (ref_id, description) VALUES (1, '<b>sample</b>'), (2, NULL), (3, 'valid entry');
SELECT t.id, a.description FROM test_data t JOIN another_table a ON t.id = a.ref_id WHERE a.description ILIKE http_value('%sample%');
SELECT t.id, a.ref_id FROM test_data t LEFT JOIN another_table a ON t.id = a.ref_id WHERE a.description IS NULL;
SELECT http_value(MAX(created_at)::VARCHAR) FROM test_data;
SELECT value FROM test_data WHERE value ILIKE '%' || http_value(NULLIF(value, '')) || '%';
SELECT t1.value, t2.value FROM test_data t1 FULL OUTER JOIN test_data t2 ON t1.id = t2.id WHERE t1.value ILIKE http_value('<script>%');
SELECT http_value(AVG(NULLIF(id, 0)::VARCHAR)) AS average_id FROM test_data WHERE created_at IS NOT NULL;