CREATE TABLE certificates (id INT PRIMARY KEY, cert_data TEXT, cert_type INT);
INSERT INTO certificates (id, cert_data, cert_type) VALUES (1, '-----BEGIN CERTIFICATE-----...', 1);
INSERT INTO certificates (id, cert_data, cert_type) VALUES (2, '-----BEGIN CERTIFICATE-----...', 2);
SELECT GET_CERTIFICATE_INFO(NULL, cert_type) AS info WHERE EXISTS (SELECT 1 FROM certificates WHERE cert_type = 0);
SELECT EXISTS (SELECT m.mail FROM (SELECT get_certificate_info(10, cert_data, cert_type, '', 'emailAddress') AS mail FROM certificates) m WHERE m.mail IS NOT NULL);
CREATE PROCEDURE test_certificates (IN cert any, IN cert_type INT) BEGIN DECLARE info any;
SET info = get_certificate_info(cert, cert_type);
IF (info IS NULL) THEN SELECT EXISTS (SELECT 1 FROM certificates WHERE cert_data IS NOT NULL AND cert_type = cert_type);
END IF;
END;
SELECT EXISTS (SELECT 1 FROM certificates WHERE cert_type = 2 HAVING COUNT(cert_data) > 1);
SELECT get_certificate_info(CAST(cert_data AS TEXT), 3) FROM certificates WHERE EXISTS (SELECT 1 FROM certificates WHERE cert_type = 1);
