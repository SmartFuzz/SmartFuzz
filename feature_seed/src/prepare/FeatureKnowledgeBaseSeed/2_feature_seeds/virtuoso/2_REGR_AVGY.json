CREATE TABLE regression_test (id INT PRIMARY KEY, x_val FLOAT, y_val FLOAT, data JSON);
INSERT INTO regression_test (id, x_val, y_val, data) VALUES (1, 10.5, 20.5, '{"score": 5, "comments": ["good", "average", null]}'), (2, 12.3, 22.3, '{"score": 15, "comments": [null, "excellent"]}'), (3, 0, 0, '{"score": null, "comments": []}');
SELECT REGR_AVGY(x_val, y_val) AS avg_x FROM regression_test WHERE json_array_length(data->'comments') > 0 GROUP BY x_val HAVING avg_x IS NOT NULL;
SELECT id, REGR_AVGY(CAST(x_val AS FLOAT), CAST(y_val AS FLOAT)) OVER (PARTITION BY json_array_length(data->'comments')) AS avg_y FROM regression_test WHERE x_val IS NOT NULL;
WITH subquery AS (SELECT x_val, y_val FROM regression_test WHERE x_val BETWEEN 0 AND 10) SELECT REGR_AVGY(x_val, y_val) AS avg_x FROM subquery WHERE x_val IS NOT NULL AND y_val IS NOT NULL;
CREATE TABLE complex_data (id INT PRIMARY KEY, json_data JSON, numeric_data FLOAT);
INSERT INTO complex_data (id, json_data, numeric_data) VALUES (1, '{"data": [100, 200, 300]}', 100.0), (2, '{"data": []}', 200.0), (3, '{"data": [null]}', NULL);
SELECT REGR_AVGY((SELECT json_array_length(json_data->'data') FROM complex_data WHERE id = 1), numeric_data) AS reg_avg FROM complex_data WHERE json_array_length(json_data->'data') > 0;
SELECT REGR_AVGY(x_val::FLOAT, y_val::FLOAT) AS regression_avg FROM (SELECT x_val, y_val FROM regression_test WHERE x_val IS NOT NULL) AS subquery JOIN complex_data ON complex_data.numeric_data < 200 GROUP BY x_val;
CREATE TABLE edge_case_test (id INT PRIMARY KEY, num_value FLOAT, str_value VARCHAR(255));
INSERT INTO edge_case_test (id, num_value, str_value) VALUES (1, 1.5, '1.5'), (2, 2.5, '2.5'), (3, NULL, 'NULL'), (4, 0, '');
SELECT REGR_AVGY(num_value, CAST(str_value AS FLOAT)) AS avg_regression FROM edge_case_test WHERE str_value IS NOT NULL AND num_value IS NOT NULL;
WITH test AS (SELECT id, x_val, y_val FROM regression_test) SELECT id, REGR_AVGY(x_val, y_val) AS avg FROM test WHERE json_array_length(data->'comments') > 1 GROUP BY id HAVING avg IS NOT NULL;