CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(255), description TEXT, value DECIMAL(10, 2));
INSERT INTO test_table (id, name, description, value) VALUES (1, ' Alice ', ' Sample description ', 12.34);
INSERT INTO test_table (id, name, description, value) VALUES (2, ' Bob ', NULL, 23.45);
INSERT INTO test_table (id, name, description, value) VALUES (3, NULL, ' Another description ', 0.01);
SELECT trim(name) || ' - ' || trim(description) AS result FROM test_table WHERE value > 0;
SELECT id, trim(name) || '(' || COALESCE(description, 'No description') || ')' AS combined_info FROM test_table WHERE value IS NOT NULL;
SELECT id, trim(trim(name) || ' ' || COALESCE(description, '')) AS trimmed_result FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value > 10);
SELECT COUNT(*) FROM (SELECT id, trim(name) AS trimmed_name FROM test_table GROUP BY trimmed_name HAVING COUNT(*) > 1) AS sub;
SELECT name, trim(name) || ' has value: ' || CAST(value AS VARCHAR) AS description FROM test_table ORDER BY value DESC;
WITH trimmed_values AS (SELECT id, trim(name) AS trimmed_name, value FROM test_table WHERE value IS NOT NULL) SELECT trimmed_name || ' has a value of ' || trim(CAST(SUM(value) AS VARCHAR)) FROM trimmed_values GROUP BY trimmed_name HAVING SUM(value) > 15;