CREATE TABLE spatial_data (id INT PRIMARY KEY, geom GEOMETRY, properties XML);
INSERT INTO spatial_data (id, geom, properties) VALUES (1, ST_GeomFromText('POINT(1 1)'), xte_nodebld_init(NULL));
INSERT INTO spatial_data (id, geom, properties) VALUES (2, ST_GeomFromText('POINT(2 2)'), xte_nodebld_init(NULL));
SELECT id, bif:st_intersects(geom, ST_GeomFromText('LINESTRING(0 0, 3 3)')) AS intersects, xte_nodebld_init(NULL) FROM spatial_data WHERE intersects IS NOT NULL;
CREATE TEMPORARY TABLE temp_data AS SELECT id, geom, properties FROM spatial_data WHERE bif:st_intersects(geom, ST_GeomFromText('POLYGON((0 0, 3 0, 3 3, 0 3, 0 0))'));
SELECT id FROM temp_data GROUP BY id HAVING COUNT(*) > 1;
SELECT MAX(bif:st_intersects(geom, ST_GeomFromText('POINT(3 3)'))) OVER() AS max_intersect FROM spatial_data;
SELECT a.id FROM spatial_data AS a JOIN spatial_data AS b ON bif:st_intersects(a.geom, b.geom) AND a.id <> b.id;
INSERT INTO spatial_data (id, geom, properties) VALUES (3, ST_GeomFromText('POINT(3 3)'), xte_nodebld_init(NULL));
SELECT bif:st_intersects(a.geom, b.geom) FROM spatial_data AS a, spatial_data AS b WHERE a.id = 1 AND b.id IS NOT NULL;
SELECT id FROM spatial_data WHERE properties IS NOT NULL AND bif:st_intersects(geom, ST_GeomFromText('POINT(1 0)'));