CREATE TABLE t_authors (author_id int NOT NULL, author_name varchar(255) NOT NULL, author_data long varchar);
INSERT INTO t_authors (author_id, author_name, author_data) VALUES (1, 'John', '<author><book title="Book One"/></author>');
INSERT INTO t_authors (author_id, author_name, author_data) VALUES (2, 'Jane', '<author><book title="Book Two"/><book title="Book Three"/></author>');
SELECT xpath_eval('//book/@title', xml_tree_doc(author_data), 0) AS book_titles, author_name FROM t_authors WHERE author_id + 1 = 2;
SELECT author_name, (SELECT COUNT(*) FROM t_authors a WHERE xpath_eval('count(//book)', xml_tree_doc(a.author_data)) > 1) AS book_count FROM t_authors WHERE author_id = 2;
SELECT DISTINCT author_name, xpath_eval('//book', xml_tree_doc(author_data), 1) AS first_book FROM t_authors WHERE xpath_contains(author_data, '<book title=') + 1 > 1;
SELECT xpath_eval('//book[@title="Book Two"]', xml_tree_doc(author_data), 1) AS selected_book, author_name FROM t_authors WHERE author_id = 2 AND author_name LIKE 'J%';
CREATE TABLE t_books (book_id int NOT NULL, book_info long varchar);
INSERT INTO t_books (book_id, book_info) VALUES (1, '<book><title>Book A</title><price>9.99</price></book>');
INSERT INTO t_books (book_id, book_info) VALUES (2, '<book><title>Book B</title><price>14.99</price></book>');
SELECT xpath_eval('//title', xml_tree_doc(book_info), 0) AS titles, book_id + 2 AS adjusted_id FROM t_books WHERE book_id IN (SELECT book_id FROM t_books WHERE xpath_eval('//price', xml_tree_doc(book_info), 1) + 1 < 15);