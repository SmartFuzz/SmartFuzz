CREATE TABLE test_data (id INT PRIMARY KEY, value1 INT, value2 INT, str_value VARCHAR(255));
INSERT INTO test_data (id, value1, value2, str_value) VALUES (1, 18, 6, 'abc'), (2, -18, -6, 'def'), (3, NULL, 0, 'xyz');
SELECT bit_xor((SELECT value1 FROM test_data WHERE str_value NOT LIKE 'd%'), (SELECT value2 FROM test_data WHERE id = 1)) AS xor_result;
SELECT id, bit_xor(value1, value2) AS xor_result FROM test_data GROUP BY id HAVING str_value NOT LIKE 'a%';
SELECT id, COUNT(*) FROM (SELECT id, bit_xor(value1, value2) AS xor_result FROM test_data WHERE (str_value NOT LIKE '%def%') GROUP BY id) AS subq WHERE xor_result NOT LIKE '12' GROUP BY id HAVING COUNT(*) > 0;
SELECT t1.id, bit_xor(t1.value1) AS xor_res FROM test_data AS t1 JOIN test_data AS t2 ON t1.value1 NOT LIKE t2.str_value WHERE t1.value2 IS NOT NULL GROUP BY t1.id HAVING xor_res NOT LIKE '0';
INSERT INTO test_data (id, value1, value2, str_value) VALUES (4, 0, 0, NULL);
SELECT bit_xor(NULL, 5) AS result UNION SELECT bit_xor(10, NULL);
SELECT bit_xor(1.5, 2.5) AS float_xor, bit_xor(CAST('5' AS INT), CAST('10' AS INT)) AS string_cast_xor;
CREATE TEMPORARY TABLE temp_data AS SELECT id, str_value FROM test_data WHERE str_value NOT LIKE '%yam%';
SELECT id FROM temp_data WHERE id NOT IN (SELECT id FROM test_data WHERE value1 NOT LIKE value2);