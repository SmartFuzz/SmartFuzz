CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(100), created_at TIMESTAMP);
INSERT INTO test_table (id, value, created_at) VALUES (1, 'test', NOW());
INSERT INTO test_table (id, value, created_at) VALUES (2, 'sample', NOW());
INSERT INTO test_table (id, value, created_at) VALUES (3, 'example', NULL);
CREATE PROCEDURE fuzz_test (IN file_name VARCHAR(255), IN start_pos INT DEFAULT 0) AS BEGIN DECLARE log_data ANY;
DECLARE position INT DEFAULT start_pos;
WHILE (position < 10) DO log_data := read_log(file_name, position);
IF log_data IS NOT NULL THEN SELECT id, value FROM test_table WHERE (SELECT COUNT(*) FROM test_table) > 0;
SET position := position + 1;
END IF;
END;
END;
CALL fuzz_test('tmp/Virtuoso.trx', 0);
SELECT value FROM test_table WHERE LENGTH(value) > (SELECT AVG(LENGTH(value)) FROM test_table);
SELECT value FROM test_table WHERE created_at IS NULL OR created_at > NOW() - INTERVAL '1 DAY';
SELECT id, COUNT(*) FROM test_table GROUP BY id HAVING COUNT(*) > 1;
SELECT id, value FROM test_table WHERE id > (SELECT MAX(id) FROM test_table) - 1;
SELECT id FROM test_table WHERE value LIKE '%sample%' AND id > (SELECT MIN(id) FROM test_table) ORDER BY id;
SELECT id, value, LEAD(value) OVER (ORDER BY id) AS next_value FROM test_table;