CREATE TABLE test_data (id INT PRIMARY KEY, col1 VARCHAR(255), col2 INT, col3 TIMESTAMP, col4 TEXT);
INSERT INTO test_data (id, col1, col2, col3, col4) VALUES (1, 'apple', 10, '2023-01-01 10:00:00', 'This is a test description');
INSERT INTO test_data (id, col1, col2, col3, col4) VALUES (2, 'banana', NULL, '2023-01-01 11:00:00', NULL);
INSERT INTO test_data (id, col1, col2, col3, col4) VALUES (3, '', 20, '2023-01-01 12:00:00', 'Another description');
INSERT INTO test_data (id, col1, col2, col3, col4) VALUES (4, 'cherry', 30, '2023-01-01 13:00:00', '');
INSERT INTO test_data (id, col1, col2, col3, col4) VALUES (5, 'date', 40, '2023-01-01 14:00:00', 'more text');
SELECT id, gvector_sort(ARRAY(SELECT col1, col2 FROM test_data WHERE col2 IS NOT NULL), 2, 0, TRUE) AS sorted_keys FROM test_data WHERE bif:contains(col4, 'test');
SELECT id, gvector_sort(ARRAY(SELECT col1, col2 FROM test_data WHERE col2 IS NULL), 1, 0, FALSE) AS sorted_keys FROM test_data WHERE bif:contains(col4, 'Another');
SELECT id, gvector_sort(ARRAY(SELECT col1, col2 FROM test_data WHERE bif:contains(col4, 'more')), 2, 1, TRUE) AS sorted_keys FROM test_data GROUP BY col2 HAVING COUNT(*) > 0;
SELECT id, gvector_sort(ARRAY(SELECT col1, col2 FROM test_data WHERE col2 BETWEEN 10 AND 40), 2, 0, TRUE) AS sorted_keys FROM test_data WHERE bif:contains(col1, 'a');