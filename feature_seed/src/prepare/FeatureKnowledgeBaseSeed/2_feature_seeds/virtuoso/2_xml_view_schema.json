CREATE TABLE xml_test (id INT PRIMARY KEY, data XML);
INSERT INTO xml_test (id, data) VALUES (1, '<cat><category CategoryID="1" description="Electronics"><product ProductName="Smartphone"/></category></cat>');
INSERT INTO xml_test (id, data) VALUES (2, '<cat><category CategoryID="2" description="Books"><product ProductName="Novel"/></category></cat>');
SELECT xml_view_schema((SELECT data FROM xml_test WHERE id = 1), 'root') AS schema_output;
SELECT xpath_integer('/cat/category/@CategoryID', data) AS extracted_id FROM xml_test WHERE id = 1;
SELECT xml_view_schema('cat', 'root') FROM xml_test WHERE xpath_integer('/cat/category/@CategoryID', data) IS NOT NULL;
SELECT COUNT(*) FROM xml_test GROUP BY xpath_integer('/cat/category/@CategoryID', data) HAVING COUNT(*) > 1;
CREATE TEMPORARY TABLE temp_schema AS SELECT xml_view_schema('cat', '') AS schema FROM xml_test WHERE data IS NOT NULL;
SELECT data FROM xml_test WHERE xpath_integer('/cat/category/@CategoryID', data) = (SELECT MAX(xpath_integer('/cat/category/@CategoryID', data)) FROM xml_test);
SELECT xml_view_schema('cat', 'root') AS cat_schema, xpath_integer('/cat/category/@CategoryID', data) FROM xml_test WHERE data IS NOT NULL ORDER BY xpath_integer('/cat/category/@CategoryID', data);