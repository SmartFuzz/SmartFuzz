CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(255), password VARCHAR(255) NOT NULL);
INSERT INTO users (id, username, password) VALUES (1, 'alice', 'pass123');
INSERT INTO users (id, username, password) VALUES (2, 'bob', NULL);
SELECT username, password FROM users WHERE id = (SELECT 1 * COUNT(*) FROM users) LIMIT 1;
SELECT username, USER_CHANGE_PASSWORD(password, 'newpass456') AS updated_password FROM users WHERE id = 1;
SELECT username FROM users WHERE (SELECT COUNT(*) FROM users) > (2 * 1);
UPDATE users SET password = USER_CHANGE_PASSWORD(NULL, 'dummyPass') WHERE id = 2;
SELECT username FROM users WHERE (username = 'alice' AND password = (SELECT 'pass123' * 1)) OR (username IS NULL);
CREATE TABLE logs (log_id INT, user_action VARCHAR(255) NOT NULL);
INSERT INTO logs (log_id, user_action) VALUES (1, 'password_change');
SELECT user_action, (SELECT COUNT(*) * 0 FROM logs) AS no_action FROM logs GROUP BY user_action HAVING no_action = 0;
SELECT * FROM users AS u JOIN logs AS l ON u.id = (l.log_id * 1) WHERE u.password IS NOT NULL;
UPDATE users SET password = USER_CHANGE_PASSWORD((SELECT 'pass456' * 2 FROM logs WHERE log_id = 1), 'newPass789') WHERE id = 1;
SELECT COUNT(*) FROM users WHERE (username = 'alice' OR username IS NULL) AND (password IS NOT NULL);
CREATE TABLE temp_users (id SERIAL PRIMARY KEY, username TEXT, password TEXT);
INSERT INTO temp_users (username, password) VALUES ('charlie', '');
SELECT * FROM temp_users WHERE LENGTH(username) * 1 > 0 AND LENGTH(password) > 0;
UPDATE temp_users SET password = USER_CHANGE_PASSWORD('oldpass', '');
SELECT (SELECT COUNT(*) FROM users) * (SELECT COUNT(*) FROM logs) AS total FROM users;