CREATE TABLE test_dir (id INT PRIMARY KEY, dir_name VARCHAR(255) NOT NULL);
INSERT INTO test_dir (id, dir_name) VALUES (1, 'test_dir_1'), (2, 'test_dir_2');
SELECT file_mkdir((SELECT dir_name FROM test_dir WHERE id = 1) || '_sub') AS result;
SELECT id, dir_name FROM test_dir WHERE dir_name LIKE (SELECT '%' || dir_name || '%' FROM test_dir WHERE id = 2);
SELECT file_mkdir(CASE WHEN dir_name IS NULL THEN 'default_dir' ELSE dir_name END) AS mkdir_result FROM test_dir;
SELECT DIR_NAME FROM test_dir WHERE dir_name LIKE '%' || (SELECT dir_name FROM test_dir WHERE id = 1) || '%';
CREATE TABLE test_nested (id INT, str_col VARCHAR(100));
INSERT INTO test_nested (id, str_col) VALUES (1, 'abc'), (2, 'def');
SELECT file_mkdir('parent_directory_' || (SELECT MAX(id) FROM test_nested) || '_child') FROM test_nested WHERE str_col LIKE 'a%';
SELECT file_mkdir('test_directory_' || CAST(COALESCE((SELECT MIN(id) FROM test_nested), 0) AS VARCHAR)) WHERE str_col LIKE 'd%';
CREATE TEMP TABLE temp_data AS SELECT id, dir_name FROM test_dir WHERE dir_name IS NOT NULL;
SELECT COUNT(*) FROM temp_data WHERE EXISTS (SELECT 1 FROM test_nested WHERE id = temp_data.id AND str_col LIKE 'de%') HAVING COUNT(*) > 0;