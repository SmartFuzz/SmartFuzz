CREATE TABLE geo_data (id INT PRIMARY KEY, geom GEOMETRY NOT NULL);
INSERT INTO geo_data (id, geom) VALUES (1, ST_GeomFromText('POINT(0 0)'));
INSERT INTO geo_data (id, geom) VALUES (2, ST_GeomFromText('POINT(1 1)'));
SELECT id FROM geo_data WHERE geom <> ST_GeomFromText('POINT(2 2)';
SELECT id, geo_insert('geo_data', geom), geom <> ST_GeomFromText('POINT(0 0)') FROM geo_data;
SELECT id FROM geo_data WHERE geom IS NULL <> geo_insert('geo_data', ST_GeomFromText('POINT(2 2)'));
CREATE TABLE users (user_id INT, user_geom GEOMETRY);
INSERT INTO users (user_id, user_geom) VALUES (1, ST_GeomFromText('POINT(5 5)'));
INSERT INTO users (user_id, user_geom) VALUES (2, ST_GeomFromText('POINT(3 3)'));
SELECT u.user_id FROM users u LEFT JOIN geo_data g ON u.user_geom <> g.geom;
SELECT COUNT(*) FROM geo_data GROUP BY id HAVING geo_insert('geo_data', geom) <> NULL;
SELECT id, COUNT(*) OVER (PARTITION BY id) AS count FROM geo_data WHERE geom IS NOT NULL;
SELECT * FROM geo_data WHERE geom <> NULL AND id < (SELECT MAX(id) FROM geo_data);
SELECT id FROM geo_data WHERE geom IS NOT NULL AND geo_insert('geo_data', geom) <> ST_GeomFromText('POINT(100 100)');
CREATE TABLE temp_data (temp_id INT, temp_geom GEOMETRY DEFAULT NULL);
INSERT INTO temp_data (temp_id, temp_geom) VALUES (1, NULL);
SELECT temp_id, geo_insert('temp_data', ST_GeomFromText('POINT(0.1 0.1)')) <> NULL AS is_inserted FROM temp_data;
SELECT temp_id FROM temp_data WHERE temp_geom IS NOT NULL <> geo_insert('temp_data', ST_GeomFromText('POINT(1.1 1.1)'));