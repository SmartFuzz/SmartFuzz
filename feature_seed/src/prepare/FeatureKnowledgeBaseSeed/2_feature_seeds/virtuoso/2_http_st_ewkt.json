CREATE TABLE spatial_shapes (id SERIAL PRIMARY KEY, geom GEOMETRY NOT NULL, attribute INT);
INSERT INTO spatial_shapes (geom, attribute) VALUES (st_ewkt_read('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))'), 5), (st_ewkt_read('POLYGON((1 1, 8 1, 8 8, 1 8, 1 1))'), NULL);
CREATE TABLE spatial_data (sess TEXT, shape GEOMETRY);
INSERT INTO spatial_data (sess, shape) VALUES (string_output(), st_ewkt_read('POLYGON((2 2, 5 3, 5 5, 2 5, 2 2))'));
SELECT http_st_ewkt(geom, string_output()) FROM spatial_shapes WHERE attribute IS NULL OR attribute < 10;
SELECT id, http_st_ewkt(geom, output_sess) FROM spatial_shapes, (SELECT string_output() AS output_sess) AS subquery WHERE attribute IS NOT NULL;
WITH shape_results AS (SELECT http_st_ewkt(geom, string_output()) AS ewkt_output FROM spatial_shapes GROUP BY attribute HAVING COUNT(*) > 1) SELECT * FROM shape_results WHERE ewkt_output IS NOT NULL;
SELECT shape FROM spatial_data WHERE http_st_ewkt(geom, sess) IS NOT NULL AND attribute < (SELECT COUNT(*) FROM spatial_shapes);
SELECT 1 < (SELECT COUNT(*) FROM spatial_data WHERE geom IS NOT NULL) as result;
SELECT (SELECT COUNT(*) FROM spatial_shapes) < (SELECT COUNT(*) FROM spatial_data WHERE http_st_ewkt(geom, sess) IS NOT NULL) AS comparison_result;