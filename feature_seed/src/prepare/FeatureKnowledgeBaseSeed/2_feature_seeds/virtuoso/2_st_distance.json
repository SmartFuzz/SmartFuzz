CREATE TABLE location_data (id INT PRIMARY KEY, geom GEOMETRY, name VARCHAR(100), created_at TIMESTAMP);
INSERT INTO location_data (id, geom, name, created_at) VALUES (1, ST_Point(0, 52), 'Point A', NOW()), (2, ST_Point(0, 70), 'Point B', NOW());
SELECT id, ST_Distance(geom, (SELECT ST_Point(0, 70) FROM location_data WHERE name = 'Point B')) AS distance FROM location_data WHERE ST_Distance(geom, ST_Point(0, 70)) IS NOT NULL;
WITH distances AS (SELECT id, ST_Distance(geom, ST_Point(0, 70)) AS distance FROM location_data) SELECT AVG(distance) AS avg_distance FROM distances WHERE avg_distance IS NOT NULL;
SELECT id, (SELECT xpath_string('//item', '<item>data</item>')) AS item_data FROM location_data WHERE ST_Distance(geom, ST_Point(0, 70)) < 2000 AND item_data IS NOT NULL;
CREATE TEMPORARY TABLE temp_distances AS SELECT id, ST_Distance(geom, ST_Point(0, 70)) AS distance FROM location_data WHERE geom IS NOT NULL;
SELECT temp.id, temp.distance FROM temp_distances AS temp LEFT JOIN location_data AS loc ON temp.id = loc.id WHERE loc.name IS NOT NULL AND temp.distance > 1000 GROUP BY temp.id HAVING COUNT(loc.id) > 0;
SELECT ST_Distance(ST_Point(1, 52), NULL) AS null_distance UNION ALL SELECT ST_Distance(ST_Point(0, 70), ST_Point(NULL, NULL));