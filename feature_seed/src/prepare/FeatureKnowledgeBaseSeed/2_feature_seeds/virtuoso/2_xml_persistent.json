CREATE TABLE xml_test (id INT PRIMARY KEY, data XML);
INSERT INTO xml_test (id, data) VALUES (1, xml_persistent('<root><value>1</value></root>'));
INSERT INTO xml_test (id, data) VALUES (2, xml_persistent('<root><value>2</value></root>'));
INSERT INTO xml_test (id, data) VALUES (3, xml_persistent('<root><value>3</value></root>'));
SELECT id FROM xml_test WHERE NOT (id IN (SELECT id FROM xml_test WHERE xml_persistent(data) IS NOT NULL));
SELECT id, xml_persistent('<root><value>' || id || '</value></root>') AS xml_data FROM xml_test WHERE NOT (id NOT IN (1, 2, 4));
SELECT id, COUNT(*) OVER (PARTITION BY NOT (id IN (1, 3))) AS cnt FROM xml_test ORDER BY cnt DESC;
SELECT id FROM xml_test WHERE xml_persistent(data) IS NOT NULL AND NOT EXISTS (SELECT 1 FROM xml_test AS t2 WHERE t2.id = xml_test.id);
CREATE TABLE join_test (id INT, value INT, xml_data XML);
INSERT INTO join_test (id, value, xml_data) VALUES (1, 10, xml_persistent('<data><value>10</value></data>'));
INSERT INTO join_test (id, value, xml_data) VALUES (2, 20, xml_persistent('<data><value>20</value></data>'));
SELECT j.id FROM join_test j JOIN xml_test x ON x.id NOT IN (SELECT id FROM join_test WHERE value > 15) WHERE xml_persistent(x.data) IS NOT NULL;
SELECT id FROM xml_test GROUP BY id HAVING COUNT(*) > (SELECT COUNT(*) FROM join_test) AND NOT id IN (SELECT id FROM xml_test WHERE xml_persistent(data) IS NULL);
SELECT id, xml_persistent('<root><value>' || COALESCE(NULLIF(value, 20), 'default') || '</value></root>') AS xml_data FROM join_test WHERE NOT id IN (SELECT id FROM xml_test WHERE xml_persistent(data) IS NOT NULL);
CREATE TEMPORARY TABLE temp_test AS SELECT xml_persistent(data) AS xml_data FROM xml_test UNION SELECT xml_persistent('<empty/>') AS xml_data WHERE NOT EXISTS (SELECT * FROM xml_test);