CREATE TABLE rdf_data (id INT PRIMARY KEY, data_value VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO rdf_data (id, data_value) VALUES (1, 'example1'), (2, NULL), (3, 'example2');
SELECT id, data_value FROM rdf_data WHERE data_value IS NOT NULL;
SELECT DB.DBA.RDF_REPL_SYNC('demo-rdf-srv', 'repl_user', 'repl_passwd') FROM rdf_data WHERE id >= (SELECT MAX(id) FROM rdf_data);
SELECT id, SUM(CASE WHEN data_value IS NULL THEN 1 ELSE 0 END) as null_count FROM rdf_data GROUP BY id HAVING null_count >= 1;
CREATE TABLE additional_data (ref_id INT, description VARCHAR(100), FOREIGN KEY (ref_id) REFERENCES rdf_data(id));
INSERT INTO additional_data (ref_id, description) VALUES (1, 'related1'), (1, NULL), (3, 'related2');
SELECT d.id, a.description FROM rdf_data d JOIN additional_data a ON d.id >= a.ref_id WHERE d.data_value IS NOT NULL;
SELECT d.id, DB.DBA.RDF_REPL_SYNC('demo-rdf-srv', 'repl_user', 'repl_passwd') AS sync_status FROM rdf_data d WHERE d.id >= 1 ORDER BY sync_status;
CREATE TABLE temp_table AS SELECT d.id, a.description FROM rdf_data d LEFT JOIN additional_data a ON d.id >= a.ref_id WHERE a.description IS NULL;