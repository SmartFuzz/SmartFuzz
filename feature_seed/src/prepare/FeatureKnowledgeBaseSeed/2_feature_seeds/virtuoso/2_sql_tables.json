CREATE TABLE TestData (ID INT PRIMARY KEY, Name VARCHAR(100), Value DECIMAL(10, 2), CreatedAt TIMESTAMP);
INSERT INTO TestData (ID, Name, Value, CreatedAt) VALUES (1, 'Test A', 10.50, CURRENT_TIMESTAMP), (2, 'Test B', NULL, CURRENT_TIMESTAMP);
SELECT sql_tables('Local Virtuoso', 'Demo', NULL, NULL, NULL) WHERE Value < (SELECT AVG(Value) FROM TestData WHERE Value IS NOT NULL);
SELECT t.ID, t.Name FROM TestData t WHERE EXISTS (SELECT 1 FROM TestData d WHERE d.Value < t.Value) HAVING COUNT(*) < 3;
SELECT d.ID, d.Name, COUNT(*) OVER (PARTITION BY d.Name) as NameCount FROM (SELECT sql_tables('Local Virtuoso', 'Demo', '%', NULL, NULL) AS remote_table FROM TestData) AS d WHERE d.ID < (SELECT MAX(ID) FROM TestData);
SELECT * FROM TestData WHERE CreatedAt > CURRENT_TIMESTAMP - INTERVAL '1 DAY' AND (Value IS NULL OR Value < 20.00);
SELECT COUNT(*) FROM (SELECT DISTINCT NULL AS dummy FROM TestData) AS subquery WHERE dummy < 'A';
SELECT T.ID FROM TestData T LEFT JOIN (SELECT * FROM TestData WHERE Value < 5) AS T2 ON T.ID = T2.ID WHERE T2.ID IS NULL ORDER BY T.Value DESC;
SELECT DISTINCT t.Name FROM (SELECT sql_tables('Local Virtuoso', 'Demo', 'Temp%', NULL, NULL) AS remote_names FROM TestData) AS t WHERE t.Name < 'Test Z';
CREATE TABLE RemoteData (ID INT PRIMARY KEY, Value VARCHAR(255), AdditionalData DECIMAL(10, 2));