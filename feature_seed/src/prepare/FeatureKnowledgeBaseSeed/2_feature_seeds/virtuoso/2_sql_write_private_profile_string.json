CREATE TABLE Profiles (ID INT PRIMARY KEY, Name VARCHAR(100), AttributeType VARCHAR(10), AttributeValue VARCHAR(255));
INSERT INTO Profiles (ID, Name, AttributeType, AttributeValue) VALUES (1, 'Profile1', 'user', 'TestValue1'), (2, 'Profile2', 'system', 'TestValue2');
SELECT sql_write_private_profile_string( (SELECT AttributeType || ' attribute: ' || AttributeValue FROM Profiles WHERE ID = 1), 'user');
SELECT sql_write_private_profile_string('user', (SELECT 'Profile for: ' || Name FROM Profiles WHERE ID = 2));
SELECT (SELECT CONCAT(Name, ' has ', COUNT(*) ) FROM Profiles GROUP BY Name) AS UserProfileDescriptions;
SELECT sql_write_private_profile_string('system', (SELECT STRING_AGG(AttributeValue, ', ') FROM Profiles WHERE AttributeType = 'user' GROUP BY AttributeType));
SELECT sql_write_private_profile_string('user', (SELECT COALESCE(MIN(AttributeValue), 'No Value') FROM Profiles));
SELECT sql_write_private_profile_string('system', (SELECT 'Aggregated: ' || MAX(AttributeValue) FROM Profiles WHERE AttributeValue IS NOT NULL));
SELECT sql_write_private_profile_string((SELECT AttributeType || ' | ' || NULLIF(AttributeValue, '') FROM Profiles WHERE ID = 1), 'user');
INSERT INTO Profiles (ID, Name, AttributeType, AttributeValue) VALUES (3, '', 'user', NULL);
SELECT sql_write_private_profile_string('user', (SELECT CONCAT(Name, ' : ', COALESCE(AttributeValue, 'DefaultValue')) FROM Profiles));
SELECT sql_write_private_profile_string('user', (SELECT CONCAT(COALESCE(nullif(AttributeValue, ''), 'empty'), ' | ', Name) || ' active' FROM Profiles WHERE ID = 3));
SELECT sql_write_private_profile_string('system', (SELECT Name || ' deleted' FROM Profiles WHERE ID = 2));
CREATE TABLE TestAttributes (TestID INT PRIMARY KEY, TestName VARCHAR(100));
INSERT INTO TestAttributes (TestID, TestName) VALUES (1, 'Attribute1');
SELECT sql_write_private_profile_string('user', (SELECT CONCAT(t.TestName, ' - ', p.AttributeValue) FROM TestAttributes t JOIN Profiles p ON t.TestID = p.ID));