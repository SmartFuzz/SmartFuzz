CREATE TABLE People (id INT PRIMARY KEY, name VARCHAR(100), location VARCHAR(255), birth_date DATE);
INSERT INTO People (id, name, location, birth_date) VALUES (1, 'Alice', 'New York', '1990-01-01');
INSERT INTO People (id, name, location, birth_date) VALUES (2, 'Bob', NULL, NULL);
INSERT INTO People (id, name, location, birth_date) VALUES (3, 'Charlie', 'Los Angeles', '1985-05-15');
SELECT name, (sql:GROUP_CONCAT(NOT(location IS NULL), ' | ')) AS location_status FROM People GROUP BY name HAVING NOT (COUNT(*) < 3);
SELECT DISTINCT name, (sql:GROUP_CONCAT(NOT(NULLIF(location, '') IS NULL), ' , ')) FROM People WHERE birth_date > '1980-01-01' GROUP BY name ORDER BY (CASE WHEN location IS NULL THEN 1 ELSE 0 END), name;
SELECT * FROM (SELECT id, (sql:GROUP_CONCAT(name, ', ')) AS names_grouped FROM People GROUP BY location) AS subquery WHERE NOT (names_grouped IS NULL);
SELECT COUNT(*) FROM (SELECT DISTINCT location, (sql:GROUP_CONCAT(name || ' - ' || (NOT birth_date IS NULL))) AS loc_names FROM People GROUP BY location HAVING NOT (COUNT(name) < 1));
SELECT name, (sql:GROUP_CONCAT(location, ', ')) FROM People WHERE NOT (birth_date = '2000-01-01') GROUP BY name HAVING COUNT(*) > 0;
SELECT TRUE AS is_valid, (sql:GROUP_CONCAT(NOT(location IS NULL), ' , ')) AS contains_locations FROM People WHERE (birth_date >= '1980-01-01' OR NOT(name = 'Alice'));