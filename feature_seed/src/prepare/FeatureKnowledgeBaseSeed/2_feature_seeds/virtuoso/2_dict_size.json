CREATE TABLE test_table (id INT PRIMARY KEY, data_dict STRING, empty_dict STRING DEFAULT '{}');
INSERT INTO test_table (id, data_dict) VALUES (1, '{"key1": "value1", "key2": "value2"}'), (2, NULL), (3, '{}');
SELECT id, dict_size(data_dict) AS dict_count FROM test_table;
SELECT id, dict_size(data_dict) AS dict_count FROM test_table WHERE dict_size(data_dict) > 0;
SELECT id, dict_size(data_dict) AS dict_count FROM test_table WHERE data_dict IS NOT NULL AND dict_size(data_dict) = (SELECT MAX(dict_size(data_dict)) FROM test_table);
SELECT t1.id, dict_size(t1.data_dict) AS dict_count FROM test_table t1 JOIN (SELECT id FROM test_table WHERE dict_size(data_dict) = 2) t2 ON t1.id = t2.id;
SELECT COUNT(*), dict_size(data_dict) AS dict_count FROM test_table GROUP BY dict_size(data_dict) HAVING dict_count >= 1;
SELECT dict_size(data_dict) AS dict_count FROM test_table WHERE dict_count = 0 AND (SELECT COUNT(*) FROM test_table) > 0;
SELECT id, bif:exec('SELECT dict_size(data_dict) FROM test_table WHERE id = ' || id) AS dyn_dict_count FROM test_table;