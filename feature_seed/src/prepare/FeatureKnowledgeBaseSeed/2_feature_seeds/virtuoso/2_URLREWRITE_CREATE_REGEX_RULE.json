CREATE TABLE test_table ( id INT PRIMARY KEY, name VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, url VARCHAR(512), category VARCHAR(50) );
INSERT INTO test_table (id, name, url, category) VALUES (1, 'Sample Item', 'http://example.com/item?id=1', 'sample');
INSERT INTO test_table (id, name, url, category) VALUES (2, 'Another Item', 'http://example.com/item?id=2&user=123', 'another');
SELECT * FROM test_table WHERE EXISTS (SELECT 1 FROM test_table t2 WHERE t2.id = test_table.id AND t2.category IS NOT NULL);
DB.DBA.URLREWRITE_CREATE_REGEX_RULE('complex_rule1', 1, '^/item/[0-9]+$', vector('url'), 1, '/item/%s', vector('url'), null, null, 1, null, null);
SELECT name, (SELECT COUNT(*) FROM test_table t3 WHERE t3.category = test_table.category) AS category_count FROM test_table WHERE name LIKE '%Item%';
CREATE TABLE category_table ( id INT PRIMARY KEY, name VARCHAR(255) NOT NULL UNIQUE );
INSERT INTO category_table (id, name) VALUES (1, 'sample'), (2, 'another'), (3, 'different');
SELECT a.id, a.name, URLREWRITE_CREATE_REGEX_RULE(CONCAT('rule_for_', a.id), 1, '^/different.*$', vector('url'), 1, '/something/%s', vector('url'), null, null, 1, null, null) AS fuzzy_rule FROM test_table a JOIN category_table b ON a.category = b.name WHERE b.name IS NOT NULL;
DB.DBA.URLREWRITE_CREATE_REGEX_RULE('null_handling_rule', 1, '(.*)', vector('url'), 1, '/default/%s', vector('url'), null, null, 1, null, null);
SELECT COUNT(*) AS total, MAX(created_at) AS last_created, MIN(created_at) AS first_created FROM test_table WHERE category IS NULL GROUP BY category HAVING COUNT(*) > 0;