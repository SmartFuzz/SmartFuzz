CREATE TABLE clients (id INT PRIMARY KEY, ip_address VARCHAR(45) NOT NULL, request_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO clients (id, ip_address) VALUES (1, '192.168.1.1'), (2, '::1'), (3, '0.0.0.0'), (4, 'invalid_ip');
SELECT id, ip_address, http_client_ip() AS client_ip, ip_address REGEXP '^(192\.168\.)' AS internal FROM clients WHERE ip_address IS NOT NULL;
SELECT id, COUNT(*) AS request_count FROM clients GROUP BY id HAVING COUNT(*) > 1;
SELECT id, ip_address FROM clients WHERE http_client_ip() REGEXP ip_address ORDER BY request_time DESC;
SELECT id, (SELECT COUNT(*) FROM clients) AS total_requests, http_client_ip() AS client_ip FROM clients WHERE client_ip IS NOT NULL;
CREATE TABLE logs (log_id INT PRIMARY KEY, action VARCHAR(255), timestamp TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO logs (log_id, action) VALUES (1, 'Accessed'), (2, 'Failed Login'), (3, 'Request with IP: ' || http_client_ip());
SELECT action FROM logs WHERE action REGEXP 'Accessed' AND EXISTS (SELECT 1 FROM clients WHERE ip_address REGEXP '192\.168\..*');
SELECT id, ip_address FROM clients WHERE LENGTH(ip_address) < 16 AND ip_address NOT REGEXP '\\d+\\.\\d+\\.\\d+\\.\\d+';