CREATE TABLE test_config (section_id INT PRIMARY KEY, section_name VARCHAR(100));
INSERT INTO test_config (section_id, section_name) VALUES (0, 'Main'), (1, 'Database'), (2, NULL), (3, 'Performance');
SELECT cfg_section_name(virtuoso_ini_path(), section_id) AS section FROM test_config WHERE section_id >= 0;
SELECT cfg_section_name(virtuoso_ini_path(), (SELECT MAX(section_id) FROM test_config)) AS section_name FROM test_config WHERE section_name IS NOT NULL;
SELECT section_name, section_id FROM test_config WHERE cfg_section_name(virtuoso_ini_path(), section_id) >= 'Database';
SELECT section_id FROM test_config WHERE section_name IS NULL HAVING cfg_section_name(virtuoso_ini_path(), section_id) >= 'Performance';
WITH RankedSections AS (SELECT section_id, cfg_section_name(virtuoso_ini_path(), section_id) AS section, ROW_NUMBER() OVER (ORDER BY section_id) AS rank FROM test_config) SELECT * FROM RankedSections WHERE rank >= 2;
SELECT cfg_section_name(virtuoso_ini_path(), section_id) AS section FROM test_config GROUP BY section_id HAVING MAX(section_id) >= 1;
SELECT section_id, cfg_section_name(virtuoso_ini_path(), section_id) FROM test_config WHERE section_name IS NOT NULL AND section_id >= 1 AND section_id < 10;
SELECT DISTINCT section_name FROM test_config WHERE section_id >= (SELECT MIN(section_id) FROM test_config WHERE section_name IS NOT NULL);