CREATE TABLE temp_files (id INT PRIMARY KEY, name VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO temp_files (id, name) VALUES (1, tmp_file_name('TEST', 'TXT'));
INSERT INTO temp_files (id, name) VALUES (2, tmp_file_name('FOO', 'EXT'));
SELECT id, name FROM temp_files WHERE id BETWEEN (SELECT MIN(id) FROM temp_files) AND (SELECT MAX(id) FROM temp_files);
SELECT name FROM temp_files WHERE name BETWEEN tmp_file_name('A', '') AND tmp_file_name('Z', 'DOC');
SELECT COUNT(*) FROM temp_files WHERE name IS NULL OR name = '';
SELECT id, name FROM temp_files WHERE name LIKE CONCAT('%', tmp_file_name('T', '')) AND id BETWEEN 1 AND 2;
SELECT id FROM temp_files WHERE id BETWEEN 1 AND (SELECT COUNT(*) FROM temp_files) AND (SELECT COUNT(*) FROM temp_files WHERE name LIKE 'FOO%') > 0;
SELECT tmp_file_name('FILE', 'LOG') AS unique_file FROM dual WHERE EXISTS (SELECT 1 FROM temp_files WHERE id > 1) AND tmp_file_name('FILE', '') IS NOT NULL;
INSERT INTO temp_files (id, name) SELECT id, tmp_file_name('TEMP', 'DATA') FROM (SELECT DISTINCT id FROM temp_files WHERE id BETWEEN 1 AND 2) AS subquery;
CREATE TEMPORARY TABLE temp_stats AS SELECT AVG(id) AS average_id FROM temp_files;
SELECT name FROM temp_files WHERE id NOT BETWEEN (SELECT COUNT(*) FROM temp_files) AND 0;
SELECT id, tmp_file_name('', 'CSV') FROM temp_files WHERE id BETWEEN 0 AND (SELECT MAX(id) FROM temp_files) HAVING AVG(id) > 0;
DROP TABLE IF EXISTS temp_files;