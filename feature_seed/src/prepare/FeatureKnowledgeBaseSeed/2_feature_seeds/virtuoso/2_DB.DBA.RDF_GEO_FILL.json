CREATE TABLE geo_data ( id INT PRIMARY KEY, latitude FLOAT, longitude FLOAT, graph_name VARCHAR(255) NOT NULL );
INSERT INTO geo_data (id, latitude, longitude, graph_name) VALUES (1, 34.0522, -118.2437, 'Los Angeles'), (2, 40.7128, -74.0060, 'New York'), (3, 34.0522, -118.2437, 'Los Angeles Duplicate');
CREATE TABLE geo_iri_check ( subject VARCHAR(255), geo_lat FLOAT, geo_long FLOAT );
INSERT INTO geo_iri_check (subject, geo_lat, geo_long) VALUES ('http://example.org/point1', 34.0522, -118.2437), ('http://example.org/point2', NULL, -100.1234);
SELECT DB.DBA.RDF_GEO_FILL() FROM geo_data WHERE DB.DBA.RDF_GEO_FILL() IS NOT NULL;
SELECT * FROM geo_iri_check WHERE SPARQL.isIRI(subject) AND geo_lat IS NOT NULL;
SELECT subject, geo_lat, geo_long, COUNT(*) OVER (PARTITION BY subject) as occurrences FROM geo_iri_check GROUP BY subject, geo_lat, geo_long HAVING COUNT(*) > 1;
SELECT DISTINCT subject, DB.DBA.RDF_GEO_FILL() AS geometry FROM geo_iri_check WHERE geo_long >= -180 AND geo_long <= 180;
SELECT subject, CASE WHEN geo_lat IS NULL THEN 'Latitude is NULL' ELSE 'Latitude is valid' END AS lat_status FROM geo_iri_check WHERE SPARQL.isIRI(subject);
SELECT COUNT(*) FROM (SELECT subject FROM geo_iri_check GROUP BY subject HAVING COUNT(*) > 1) AS dup_subjects;