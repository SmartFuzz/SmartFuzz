CREATE TABLE demo.customers (id INT PRIMARY KEY, postalcode VARCHAR(10), data JSON);
INSERT INTO demo.customers (id, postalcode, data) VALUES (1, 'WA1 1DP', '{"addresses": ["123 Main St", "456 Elm St"]}');
INSERT INTO demo.customers (id, postalcode, data) VALUES (2, 'S-958 22', '{"addresses": []}');
INSERT INTO demo.customers (id, postalcode, data) VALUES (3, 'T2F 8M4', '{"addresses": ["789 Pine St", "101 Maple St"]}');
INSERT INTO demo.customers (id, postalcode, data) VALUES (4, 'EC2 5NT', '{"addresses": [""]}');
INSERT INTO demo.customers (id, postalcode, data) VALUES (5, NULL, '{"addresses": ["202 Oak St"]}');
SELECT c1.id, c1.postalcode FROM demo.customers c1 WHERE REGEXP_LIKE(c1.postalcode, '[0-9]{1,3}[[:space:]][A-Z]{1,2}[0-9]{1,2}[[:space:]][A-Z]{2}') AND json_array_length(c1.data->'addresses') > 0;
SELECT c2.id FROM demo.customers c2 WHERE c2.postalcode IS NOT NULL AND json_array_length(c2.data) = 0 HAVING AVG(NULLIF(NULL, 1)) IS NULL;
SELECT c3.id, c3.postalcode, JSON_ARRAY_LENGTH(c3.data) AS addr_count FROM demo.customers c3 WHERE REGEXP_LIKE(c3.postalcode, '[^[:digit:]]') GROUP BY c3.id, c3.postalcode HAVING addr_count < 5;
SELECT id, postalcode FROM demo.customers WHERE NULLIF(postalcode, '') IS NULL OR REGEXP_LIKE(postalcode, '^[A-Z]{2,2}[0-9]{1,2}') AND json_array_length(data) <= 1;
UPDATE demo.customers SET postalcode = NULL WHERE id = 5 AND json_array_length(data->'addresses') > 0;
SELECT COUNT(*) FROM demo.customers WHERE REGEXP_LIKE(postalcode, '^([A-Z]{1,2}\d{1,2}|\d{1,3})$') GROUP BY json_array_length(data);