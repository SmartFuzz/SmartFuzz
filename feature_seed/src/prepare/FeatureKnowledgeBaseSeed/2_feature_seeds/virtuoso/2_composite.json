CREATE TABLE test_table (id INT, value VARCHAR(255), num_value INT);
INSERT INTO test_table (id, value, num_value) VALUES (1, 'test', 10);
INSERT INTO test_table (id, value, num_value) VALUES (2, NULL, 20);
INSERT INTO test_table (id, value, num_value) VALUES (3, '', 30);
INSERT INTO test_table (id, value, num_value) VALUES (4, 'maximum_length_string_exceeding_composite_function_limits', 40);
SELECT composite_ref(composite(num_value, id), 5) || value AS combined_value FROM test_table WHERE num_value IS NOT NULL;
SELECT id, composite(value || ' appended', NULL) FROM test_table;
SELECT id, composite_ref(composite(num_value, cast(value AS VARCHAR)), 2) FROM test_table WHERE value IS NOT NULL;
SELECT id, composite(composite(value || ' ', 'extra'), num_value) FROM test_table HAVING LENGTH(composite(value || ' ', 'extra')) < 255;
SELECT id, value, composite(num_value || 5, (SELECT COUNT(*) FROM test_table AS inner_table WHERE inner_table.num_value > num_value)) AS composed_value FROM test_table ORDER BY composed_value DESC;
SELECT id, composite(NULL, value || 5) AS null_concatenation FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);
SELECT DISTINCT composite(value || (SELECT COUNT(*) FROM test_table), num_value) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE num_value < 30);
DELETE FROM test_table WHERE composite(num_value, value) = composite(10, 'test');
ALTER TABLE test_table ADD COLUMN extra_value VARCHAR(255);
UPDATE test_table SET extra_value = composite(value, num_value) WHERE id = 1;
SELECT * FROM test_table WHERE composite(num_value, (SELECT MAX(num_value) FROM test_table)) IS NULL;