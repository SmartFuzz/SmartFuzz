CREATE TABLE test_table_a (id INT PRIMARY KEY, value VARCHAR(255), ref_id INT REFERENCES test_table_b(id));
CREATE TABLE test_table_b (id INT PRIMARY KEY, data VARCHAR(100));
INSERT INTO test_table_b (id, data) VALUES (1, 'A'), (2, 'B'), (3, 'C');
INSERT INTO test_table_a (id, value, ref_id) VALUES (1, 'test', 1), (2, 'check', 2), (3, NULL, 3), (4, 'example', NULL);
SELECT fk_check_input_values() AS previous_state, value FROM test_table_a WHERE id IN (SELECT ref_id FROM test_table_b WHERE data = 'A');
SELECT value FROM test_table_a WHERE fk_check_input_values() IN (1);
SELECT COUNT(*) FROM test_table_a WHERE ref_id IN (SELECT id FROM test_table_b WHERE data IN (SELECT data FROM test_table_b WHERE LENGTH(data) > 1));
SELECT fk_check_input_values() AS is_fk_checking ON, COUNT(*) AS total FROM test_table_a GROUP BY ref_id HAVING total > 1;
SELECT DISTINCT value FROM test_table_a WHERE ref_id IS NULL OR ref_id IN (SELECT id FROM test_table_b WHERE LENGTH(data) >= 1) ORDER BY value;
ALTER TABLE test_table_a ADD CONSTRAINT fk_ref_id FOREIGN KEY (ref_id) REFERENCES test_table_b(id);
SELECT value FROM test_table_a WHERE (SELECT fk_check_input_values() FROM dual IN (1, 0)) = 1;
SELECT fk_check_input_values() AS fk_status, COUNT(*) FROM test_table_a WHERE ref_id IN (NULL) GROUP BY value HAVING fk_status = 1;