CREATE TABLE replication_test (id INT PRIMARY KEY, server_name VARCHAR(255), replicated_on DATETIME);
INSERT INTO replication_test (id, server_name, replicated_on) VALUES (1, 'localhost:1121', '2023-01-01 00:00:00'), (2, 'localhost:1122', NULL), (3, 'localhost:1123', '2050-12-31 23:59:59');
SELECT r.id, REPL_SNP_SERVER(r.server_name, 'dba', 'dba') AS snapshot_info FROM replication_test AS r WHERE r.replicated_on BETWEEN '2000-01-01' AND '2025-01-01';
SELECT r1.id, (SELECT COUNT(*) FROM replication_test r2 WHERE r2.server_name BETWEEN 'localhost:1121' AND 'localhost:1123') AS server_count FROM replication_test r1 HAVING server_count > 1;
CREATE TABLE secondary_test (id INT PRIMARY KEY, replication_info VARCHAR(255), last_checked DATETIME);
INSERT INTO secondary_test (id, replication_info, last_checked) VALUES (1, 'Active', '2023-01-01 12:00:00'), (2, 'Inactive', NULL);
SELECT s.id, s.replication_info, REPL_SNP_SERVER((SELECT r.server_name FROM replication_test r WHERE r.replicated_on BETWEEN '2000-01-01' AND NOW() LIMIT 1), 'dba', 'dba') AS server_info FROM secondary_test s JOIN replication_test r ON s.id = r.id WHERE r.replicated_on IS NOT NULL;
CREATE TABLE complex_test (id INT, amount DECIMAL(10, 2), status VARCHAR(50));
INSERT INTO complex_test (id, amount, status) VALUES (1, 999.99, 'complete'), (2, 0.00, 'pending'), (3, NULL, 'failed');
SELECT c.id, REPL_SNP_SERVER(CAST(c.amount AS VARCHAR(20)), 'admin', 'pass') AS replication_name FROM complex_test c WHERE c.amount BETWEEN 0 AND 1000 AND c.status IS NOT NULL;
SELECT COUNT(*), MAX(amount) AS max_amount FROM complex_test WHERE REPL_SNP_SERVER(CAST(max_amount AS VARCHAR(20)), 'admin', 'pass') IS NOT NULL GROUP BY status;