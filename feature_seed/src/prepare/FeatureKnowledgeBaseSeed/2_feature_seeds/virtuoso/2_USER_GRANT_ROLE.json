CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(50) NOT NULL, role_id INT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
CREATE TABLE roles (id INT PRIMARY KEY, role_name VARCHAR(50) NOT NULL);
INSERT INTO roles (id, role_name) VALUES (1, 'admin'), (2, 'editor'), (3, 'viewer');
INSERT INTO users (id, username, role_id) VALUES (1, 'alice', 1), (2, 'bob', NULL), (3, 'charlie', 2);
SELECT username FROM users WHERE role_id IS NULL OR role_id IN (SELECT id FROM roles WHERE role_name = 'editor');
SELECT username FROM users WHERE USER_GRANT_ROLE((SELECT role_name FROM roles WHERE id = 2), username) IS NOT NULL OR username IS NULL;
SELECT username, (SELECT COUNT(*) FROM roles) AS total_roles FROM users GROUP BY username HAVING total_roles > 1 OR username LIKE '';
SELECT username, USER_GRANT_ROLE('viewer', username) AS granted_role FROM users WHERE granted_role IS NOT NULL OR username = '';
SELECT username, (SELECT COUNT(role_id) FROM users WHERE role_id IS NOT NULL) AS assigned_count FROM users HAVING assigned_count < 5 OR assigned_count > 0;
SELECT username, NULL AS dummy_role FROM users WHERE USER_GRANT_ROLE((SELECT role_name FROM roles WHERE id = (SELECT MAX(id) FROM roles)), username) IS NULL OR dummy_role IS NULL;