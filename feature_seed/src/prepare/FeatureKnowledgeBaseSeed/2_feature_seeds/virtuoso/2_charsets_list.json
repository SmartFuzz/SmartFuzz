CREATE TABLE charsets_test (id INT PRIMARY KEY, charset_name VARCHAR(255), example_value VARCHAR(255));
INSERT INTO charsets_test (id, charset_name, example_value) VALUES (1, 'UTF-8', 'example1'), (2, 'ISO-8859-1', 'example2'), (3, NULL, 'example3');
SELECT id, charset_name, bif:sha1(charset_name) AS hashed_name FROM charsets_test WHERE charset_name IS NOT NULL;
SELECT id, charset_name, bif:sha1(charset_name || example_value) AS combined_hash FROM charsets_test WHERE example_value IS NOT NULL;
WITH CharsetList AS (SELECT aref(charsets_list(1), 0) AS charset_name) SELECT cl.charset_name, bif:sha1(cl.charset_name) AS hashed_name FROM CharsetList cl LEFT JOIN charsets_test ct ON cl.charset_name = ct.charset_name;
SELECT ct.id, ct.charset_name, bif:sha1(ct.example_value) AS example_hash FROM charsets_test ct WHERE example_value LIKE 'example%';
INSERT INTO charsets_test (id, charset_name, example_value) VALUES (4, 'UTF-16', NULL);
SELECT COUNT(*) FROM charsets_test WHERE charset_name IS NULL;
CREATE TABLE temp_charsets_test AS SELECT ct.id, ct.charset_name, bif:sha1(charset_name || 'check') AS checksum FROM charsets_test ct WHERE ct.charset_name IS NOT NULL;
SELECT ct1.id, ct1.charset_name, COUNT(*) AS example_count FROM charsets_test ct1 JOIN charsets_test ct2 ON ct1.example_value = ct2.example_value GROUP BY ct1.charset_name HAVING COUNT(*) > 1;
SELECT id, bif:sha1(COALESCE(charset_name, 'default')) AS secured_charset FROM charsets_test;