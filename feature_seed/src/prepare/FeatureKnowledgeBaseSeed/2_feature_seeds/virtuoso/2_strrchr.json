CREATE TABLE test_table (id INT, name VARCHAR(255), description VARCHAR(255));
INSERT INTO test_table (id, name, description) VALUES (1, 'Alice', 'Sample description'), (2, 'Bob', 'Another sample description'), (3, NULL, 'Description with NULL');
SELECT strrchr(name, 'A' || 'l') AS last_idx FROM test_table WHERE strrchr(name || 'extra', 'e') IS NOT NULL;
SELECT id, strrchr((name || description), 's') AS last_occurrence FROM test_table WHERE id > 0 ORDER BY last_occurrence;
SELECT name, strrchr(description || '', 's') AS last_s_index FROM test_table WHERE strrchr(description, 'x') IS NULL;
SELECT id, strrchr(COALESCE(NULLIF(name, ''), 'default'), 'd') AS last_character FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name IS NOT NULL);
CREATE TABLE join_table (join_id INT, test_id INT, details VARCHAR(255) NOT NULL, FOREIGN KEY(test_id) REFERENCES test_table(id));
INSERT INTO join_table (join_id, test_id, details) VALUES (1, 1, 'Join details for Alice'), (2, 2, 'Join details for Bob'), (3, 3, 'Join with NULL');
SELECT j.join_id, strrchr(j.details || ' additional', 'd') AS detail_index FROM join_table j JOIN test_table t ON j.test_id = t.id WHERE strrchr(t.name, 'A') IS NOT NULL;
SELECT AVG(LENGTH(strrchr(name, 'a' || 'b'))) FROM test_table WHERE id < 10 GROUP BY id HAVING COUNT(name) > 0;