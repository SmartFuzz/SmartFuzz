CREATE TABLE test_data (id INT, value NUMERIC, description TEXT, created_at TIMESTAMP, nullable_col NUMERIC);
INSERT INTO test_data (id, value, description, created_at, nullable_col) VALUES (1, 10, 'test 1', '2023-01-01 00:00:00', NULL), (2, 20, 'test 2', '2023-01-02 00:00:00', 15), (3, 30, 'test 3', '2023-01-03 00:00:00', 25), (4, NULL, 'test 4', '2023-01-04 00:00:00', NULL), (5, 50, 'test 5', '2023-01-05 00:00:00', NULL);
SELECT VAR_POP(value) FROM test_data WHERE created_at > '2023-01-01' AND value > (SELECT AVG(value) FROM test_data WHERE value IS NOT NULL);
SELECT id, VAR_POP(value) AS population_variance FROM test_data GROUP BY id HAVING population_variance > 5;
SELECT id FROM test_data WHERE VAR_POP(value) IS NOT NULL AND value > (SELECT VAR_POP(value) FROM test_data WHERE value IS NOT NULL AND id < 4);
SELECT id, VAR_POP(value) OVER (PARTITION BY description) AS variance_partition FROM test_data ORDER BY variance_partition DESC;
SELECT (SELECT VAR_POP(value) FROM test_data WHERE value IS NOT NULL AND id = 1) > 5 AS variance_check;
SELECT * FROM test_data WHERE value IS NOT NULL AND Nullable_col > (SELECT VAR_POP(nullable_col) FROM test_data WHERE nullable_col IS NOT NULL);
SELECT VAR_POP(CAST(NULLIF(description, '') AS NUMERIC)) AS nullif_variance FROM test_data;
CREATE TEMPORARY TABLE stats AS SELECT id, VAR_POP(value) AS population_variance FROM test_data GROUP BY id HAVING population_variance IS NOT NULL;
SELECT tbl.id FROM (SELECT id, population_variance FROM stats) AS tbl WHERE tbl.population_variance > (SELECT VAR_POP(value) FROM test_data WHERE value IS NOT NULL);
SELECT VAR_POP(COALESCE(nullable_col, 0)) AS coalesce_variance FROM test_data WHERE nullable_col IS NOT NULL;
SELECT * FROM test_data WHERE (SELECT VAR_POP(value) FROM test_data WHERE id > 1) < 30 AND value > CAST(NULL AS NUMERIC);