CREATE TABLE test_table (id INT PRIMARY KEY, price1 FLOAT, price2 FLOAT, price3 FLOAT, xml_data XML);
INSERT INTO test_table (id, price1, price2, price3, xml_data) VALUES (1, NULL, 1.0, NULL, xml_tree_doc('<root><a>1</a><b>2</b></root>')), (2, 6.0, NULL, 5.0, xml_tree_doc('<root><c>3</c></root>'));
SELECT id, __max_notnull(price1, price2, price3) AS max_price, xml_data FROM test_table WHERE __max_notnull(price1, price3) IS NOT NULL;
SELECT id, (SELECT __max_notnull(price2, price3) FROM test_table t2 WHERE t2.id = t1.id) AS max_nested FROM test_table t1 WHERE xml_data IS NOT NULL;
SELECT t1.id, t1.price1, t2.price2 FROM test_table t1 JOIN test_table t2 ON t1.price1 = t2.price2 WHERE __max_notnull(t1.price1, t2.price2) > 5;
CREATE TABLE another_table (value INT NOT NULL);
INSERT INTO another_table (value) VALUES (1), (NULL), (NULL), (5);
SELECT t.id, __max_notnull(t.price1, (SELECT MAX(value) FROM another_table WHERE value IS NOT NULL)) AS combined_max FROM test_table t;
SELECT xml_data, __max_notnull(value) FROM (SELECT xml_tree_doc('<root><value>1</value></root>') AS xml_data, 1 AS value UNION ALL SELECT xml_tree_doc('<root><value>NULL</value></root>'), NULL) AS subquery GROUP BY xml_data HAVING __max_notnull(value) IS NOT NULL;