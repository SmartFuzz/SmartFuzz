CREATE TABLE Orders (OrderID INTEGER PRIMARY KEY, CustomerID VARCHAR(12), OrderDate DATETIME, RequiredDate DATE, Freight DOUBLE PRECISION);
INSERT INTO Orders (OrderID, CustomerID, OrderDate, RequiredDate, Freight) VALUES (1, 'Cust1', '2023-01-01', '2023-01-10', 15.5), (2, 'Cust2', '2023-01-02', NULL, 20.0);
SELECT * FROM (SELECT OrderID, CustomerID, OrderDate, RequiredDate FROM Orders WHERE RequiredDate LIKE '%' OR RequiredDate IS NULL) AS SubQuery1;
SELECT OrderID, CustomerID FROM Orders WHERE OrderID = (SELECT MAX(OrderID) FROM Orders WHERE CustomerID LIKE 'Cust%') AND Freight > 10.0;
SELECT O1.OrderID, O1.CustomerID, O1.Freight, O2.Freight FROM Orders AS O1 JOIN Orders AS O2 ON O1.OrderID <> O2.OrderID AND O1.Freight LIKE '2%' WHERE O1.OrderDate IS NOT NULL;
SELECT COUNT(OrderID) FROM Orders GROUP BY CustomerID HAVING AVG(Freight) > (SELECT AVG(Freight) FROM Orders WHERE CustomerID LIKE '%1');
SELECT OrderID, CustomerID FROM Orders WHERE CustomerID LIKE '%2%' ORDER BY CASE WHEN Freight IS NULL THEN 1 ELSE 0 END, Freight DESC;
CREATE TABLE Products (ProductID INTEGER PRIMARY KEY, ProductName VARCHAR(50), Price DOUBLE PRECISION NOT NULL);
INSERT INTO Products (ProductID, ProductName, Price) VALUES (1, 'ProductA', 10.5), (2, 'ProductB', NULL);
SELECT O.OrderID, P.ProductName FROM Orders AS O JOIN (SELECT * FROM Products WHERE Price IS NULL OR Price LIKE '10%') AS P ON O.OrderID = P.ProductID WHERE O.Freight IS NOT NULL;
SELECT O.OrderID, CAST(O.Freight AS VARCHAR) AS FreightString FROM Orders AS O WHERE O.Freight > (SELECT MIN(Freight) FROM Orders WHERE CustomerID LIKE 'Cust%') AND O.OrderDate < NOW();
SELECT * FROM sql_columns('Local Virtuoso', 'Demo', NULL, 'Orders', NULL) WHERE 'Orders' LIKE 'Ord%';
SELECT * FROM (SELECT OrderID, COUNT(*) AS OrderCount FROM Orders GROUP BY CustomerID HAVING OrderCount < (SELECT COUNT(OrderID) FROM Orders WHERE CustomerID LIKE 'Cust%')) AS GroupedOrders;
SELECT DISTINCT OrderID FROM Orders WHERE OrderDate <= (SELECT MAX(OrderDate) FROM Orders) AND CustomerID IS NOT NULL ORDER BY OrderDate DESC;
CREATE TABLE Customers (CustomerID VARCHAR(12) PRIMARY KEY, ContactName VARCHAR(50));
INSERT INTO Customers (CustomerID, ContactName) VALUES ('Cust1', 'John Doe'), ('Cust2', 'Jane Smith');
SELECT C.ContactName, COUNT(O.OrderID) FROM Customers AS C LEFT JOIN Orders AS O ON C.CustomerID = O.CustomerID GROUP BY C.ContactName HAVING COUNT(O.OrderID) = (SELECT COUNT(OrderID) FROM Orders WHERE Freight IS NOT NULL);