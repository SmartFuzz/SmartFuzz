CREATE TABLE test_timezones (id INT, event_time DATETIME, description VARCHAR(255));
INSERT INTO test_timezones VALUES (1, CAST('2023-10-01 12:00:00' AS DATETIME), 'Event A');
INSERT INTO test_timezones VALUES (2, CAST('2023-10-01 12:00:00' AS DATETIME), 'Event B');
SELECT adjust_timezone(event_time, 3, 1) AS adjusted_time, description FROM test_timezones WHERE description ILIKE 'event%';
SELECT DISTINCT adjust_timezone(min(event_time), 5, 1) AS min_adjusted_time FROM test_timezones;
SELECT T.description, adjust_timezone((SELECT MAX(event_time) FROM test_timezones WHERE id = T.id), 0, 1) AS latest_time_adjusted FROM test_timezones T GROUP BY T.description HAVING MAX(event_time) IS NOT NULL;
CREATE TABLE test_strings (id INT, search_text VARCHAR(50));
INSERT INTO test_strings VALUES (1, 'Sample Text'), (2, 'Other TEXT'), (3, NULL);
SELECT id FROM test_strings WHERE search_text ILIKE adjust_timezone(CAST('2023-10-01' AS DATETIME), 0, 1);
SELECT id, adjust_timezone(event_time, 2, 0) FROM test_timezones WHERE event_time IS NOT NULL AND adjust_timezone(event_time, 0, 1) ILIKE '2023-10-01%';
SELECT adjust_timezone(event_time, 0, 1), COUNT(*) FROM test_timezones WHERE adjust_timezone(event_time, 0, 1) IS NOT NULL GROUP BY adjust_timezone(event_time, 0, 1) HAVING COUNT(*) > 1;