CREATE TABLE geometry_data (id INTEGER PRIMARY KEY, geom GEOMETRY NOT NULL, value DOUBLE PRECISION NOT NULL);
INSERT INTO geometry_data (id, geom, value) VALUES (1, ST_GeomFromText('POINT(1 1)'), 10.0);
INSERT INTO geometry_data (id, geom, value) VALUES (2, ST_GeomFromText('POINT(2 2)'), 20.0);
INSERT INTO geometry_data (id, geom, value) VALUES (3, ST_GeomFromText('POINT(3 3)'), NULL);
SELECT id, power(value, 2) AS squared_value FROM geometry_data WHERE value IS NOT NULL;
SELECT id, bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')) AS distance FROM geometry_data WHERE bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')) < power(2, 3);
SELECT id, power(bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')), 2) AS squared_distance FROM geometry_data;
SELECT id, SUM(power(value, 2)) AS total_squared_value FROM geometry_data GROUP BY id HAVING total_squared_value > 50.0;
CREATE TABLE geo_results AS SELECT id, power(value, 2) AS squared_value, bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')) AS distance FROM geometry_data WHERE value IS NOT NULL ORDER BY distance;
INSERT INTO geo_results (id, squared_value, distance) SELECT id, power(2 * value, 1), bif:st_distance(geom, ST_GeomFromText('POINT(1 1)')) FROM geometry_data WHERE value IS NOT NULL;