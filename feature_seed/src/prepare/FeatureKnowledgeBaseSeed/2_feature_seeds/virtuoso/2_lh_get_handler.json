CREATE TABLE local_language (id INT PRIMARY KEY, lang_code VARCHAR(10), description TEXT);
INSERT INTO local_language (id, lang_code, description) VALUES (1, 'en', 'English'), (2, 'fr', 'French'), (3, 'de', 'German');
SELECT lh_get_handler(lang_code) || ' - ' || description AS full_description FROM local_language WHERE id = 1;
SELECT lh_get_handler(lang_code) || ' - ' || (SELECT COUNT(*) FROM local_language WHERE lang_code IS NOT NULL) FROM local_language;
SELECT SUM(NULLIF(lh_get_handler(lang_code), '')) AS valid_handlers FROM local_language GROUP BY lang_code HAVING valid_handlers IS NOT NULL;
CREATE TABLE translations (id INT PRIMARY KEY, lang_code VARCHAR(10), translation TEXT);
INSERT INTO translations (id, lang_code, translation) VALUES (1, 'en', 'Hello'), (2, 'fr', 'Bonjour'), (3, 'de', 'Hallo');
SELECT tl.lang_code, lh_get_handler(tl.lang_code) || ' says: ' || tl.translation FROM translations tl JOIN local_language ll ON tl.lang_code = ll.lang_code WHERE ll.id IN (SELECT id FROM local_language WHERE description IS NOT NULL);
SELECT lh_get_handler(lang_code) || ' messages: ' || GROUP_CONCAT(translation) FROM translations GROUP BY lang_code HAVING COUNT(*) > 0;
SELECT lh_get_handler(lang_code) AS handler, COUNT(*) AS count FROM translations GROUP BY handler ORDER BY count DESC;
SELECT CASE WHEN lh_get_handler(lang_code) IS NULL THEN 'Unknown' ELSE ln.lang_code || ' Handle' END AS language_desc FROM local_language ln;