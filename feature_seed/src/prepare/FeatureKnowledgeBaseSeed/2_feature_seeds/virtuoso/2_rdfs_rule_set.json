CREATE TABLE test_data (id INT PRIMARY KEY, data VARCHAR(255), xml_data XML);
INSERT INTO test_data (id, data, xml_data) VALUES (1, 'value1', '<root><item>1</item></root>');
INSERT INTO test_data (id, data, xml_data) VALUES (2, 'value2', '<root><item>2</item></root>');
INSERT INTO test_data (id, data, xml_data) VALUES (3, NULL, '<root><item>3</item></root>');
INSERT INTO test_data (id, data, xml_data) VALUES (4, '', '<root><item>4</item></root>');
SELECT id, xpath_string('//item', xml_data) AS item_value FROM test_data WHERE data IS NOT NULL;
SELECT MAX(id) AS max_id, COUNT(*) FROM test_data GROUP BY data HAVING MAX(id) > 0;
CREATE TABLE named_graphs (graph_name VARCHAR(255), graph_url VARCHAR(255));
INSERT INTO named_graphs (graph_name, graph_url) VALUES ('http://mygraph.com', 'http://mygraph.com');
SELECT rdfs_rule_set('schema_stock_quotes', xpath_string('//item', xml_data)) FROM test_data JOIN named_graphs ON named_graphs.graph_url = 'http://mygraph.com';
SELECT id, COUNT(*) OVER (PARTITION BY data) AS data_count FROM test_data ORDER BY data_count;
SELECT rdfs_rule_set('fuzz_test', xpath_string('//item', xml_data)) FROM test_data WHERE id = (SELECT MAX(id) FROM test_data WHERE data IS NULL);
SELECT * FROM test_data WHERE data IS NOT NULL AND xpath_string('//item', xml_data) = '2';
UPDATE test_data SET data = CAST(data AS VARCHAR(255)) WHERE id = 1;
SELECT * FROM test_data WHERE data IN (SELECT data FROM test_data WHERE data IS NOT NULL);
ALTER TABLE test_data ADD COLUMN new_column INT DEFAULT 0;
DROP TABLE named_graphs;