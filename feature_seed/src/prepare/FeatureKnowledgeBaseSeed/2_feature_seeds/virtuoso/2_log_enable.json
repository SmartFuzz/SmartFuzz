CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(255), value DECIMAL(10, 2));
INSERT INTO test_table (id, name, value) VALUES (1, 'alpha', 10.00), (2, 'beta', 20.00), (3, NULL, 30.00);
SELECT log_enable(1 | 2) WHERE EXISTS (SELECT 1 FROM test_table WHERE value LIKE '20%');
SELECT name, value FROM test_table WHERE value IS NOT NULL AND log_enable(1 | 0) LIKE 'a%';
SELECT name FROM test_table WHERE id IN (SELECT id FROM test_table WHERE log_enable(1) = 1) AND value LIKE '%.0';
SELECT name FROM test_table WHERE log_enable(2) LIKE CONCAT('%', (SELECT MAX(value) FROM test_table), '%');
SELECT COUNT(*) FROM test_table WHERE log_enable(1 | 2) AND name LIKE 'be%';
CREATE TABLE temp_table (temp_id INT, temp_value DECIMAL(10, 2));
INSERT INTO temp_table (temp_id, temp_value) SELECT id, value FROM test_table WHERE log_enable(3) AND value IS NOT NULL;
SELECT DISTINCT temp_value FROM temp_table WHERE temp_id IN (SELECT id FROM test_table WHERE log_enable(1 | 1) LIKE 'al%') ORDER BY temp_value DESC;