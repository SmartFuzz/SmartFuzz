CREATE TABLE users (user_id INT PRIMARY KEY, username VARCHAR(50) NOT NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO users (user_id, username) VALUES (1, 'user1');
INSERT INTO users (user_id, username) VALUES (2, 'user2');
INSERT INTO users (user_id, username) VALUES (3, 'user3');
SELECT USER_SET_QUALIFIER('user1') AND (SELECT COUNT(*) FROM users WHERE username LIKE 'user%');
SELECT USER_SET_QUALIFIER('user3') AND (SELECT COUNT(*) FROM users WHERE user_id IN (SELECT user_id FROM users WHERE created_at IS NULL));
SELECT * FROM users WHERE USER_SET_QUALIFIER('user2') AND user_id = (SELECT MAX(user_id) FROM users);
SELECT USER_SET_QUALIFIER('user1') AS qualifier FROM DUAL WHERE 'user' AND '1' = '1' AND NULL;
SELECT USER_SET_QUALIFIER('user1') AND (SELECT AVG(user_id) FROM users GROUP BY user_id HAVING AVG(user_id) > 2);
CREATE TABLE sessions (session_id INT PRIMARY KEY, user_id INT not null FOREIGN KEY REFERENCES users(user_id));
INSERT INTO sessions (session_id, user_id) VALUES (1, 1);
INSERT INTO sessions (session_id, user_id) VALUES (2, 2);
SELECT USER_SET_QUALIFIER('user1') AND (SELECT COUNT(*) FROM sessions WHERE session_id = (SELECT MAX(session_id) FROM sessions WHERE user_id IS NOT NULL) OR user_id = 1);
SELECT USER_SET_QUALIFIER('user1') AND (SELECT AVG(user_id) FROM sessions JOIN users ON sessions.user_id = users.user_id WHERE USER_SET_QUALIFIER(username) IS NOT NULL);