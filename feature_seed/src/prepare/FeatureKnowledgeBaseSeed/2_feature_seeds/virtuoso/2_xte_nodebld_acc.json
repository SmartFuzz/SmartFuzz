CREATE TABLE xml_test (id INT PRIMARY KEY, xml_col XML, data_col STRING);
INSERT INTO xml_test (id, xml_col, data_col) VALUES (1, '<root><a>Sample</a><b>Data</b></root>', 'TestString');
INSERT INTO xml_test (id, xml_col, data_col) VALUES (2, '<root><a></a><b>Example</b></root>', '');
INSERT INTO xml_test (id, xml_col, data_col) VALUES (3, '<root><a>Edge1</a></root>', NULL);
SELECT xte_nodebld_acc(data_col, xpath_string('/root/a', xml_col), xpath_string('/root/b', xml_col)) FROM xml_test WHERE id = 1;
SELECT xte_nodebld_acc('', xpath_string('/root/a', xml_col), data_col) FROM xml_test WHERE id = 2;
SELECT id, xte_nodebld_acc(data_col, xpath_string('/root/a', xml_col), xpath_string('/root/b', xml_col)) AS combined_data FROM xml_test GROUP BY id HAVING combined_data IS NOT NULL;
SELECT xte_nodebld_acc(NULL, xpath_string('/root/a', xml_col)) AS result FROM xml_test WHERE id = 3;
SELECT DISTINCT xte_nodebld_acc(data_col, xpath_string('/root/a', xml_col)) FROM xml_test ORDER BY xte_nodebld_acc(data_col, xpath_string('/root/a', xml_col));
CREATE TABLE temp_xml AS SELECT id, xml_col, data_col FROM xml_test WHERE data_col IS NOT NULL;
INSERT INTO temp_xml (id, xml_col, data_col) VALUES (4, '<root><a>New</a></root>', 'Additional');
SELECT xte_nodebld_acc(data_col, xpath_string('/root/a', xml_col), 'ExtraData') AS concatenated_result FROM temp_xml WHERE id = 4;
DROP TABLE IF EXISTS temp_xml;