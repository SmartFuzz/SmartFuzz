CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(255), value DECIMAL(10, 4), created_at TIMESTAMP);
INSERT INTO test_table (id, name, value, created_at) VALUES (1, 'test1', 10.1234, CURRENT_TIMESTAMP);
INSERT INTO test_table (id, name, value, created_at) VALUES (2, 'test2', NULL, NULL);
INSERT INTO test_table (id, name, value, created_at) VALUES (3, 'test3', -5.0001, CURRENT_TIMESTAMP);
CALL sys_lockdown(1);
SELECT NEW test_table(name) AS new_record FROM test_table WHERE value > 5.0;
UPDATE test_table SET value = (SELECT NEW test_table(value) FROM test_table WHERE id = 1) WHERE id = 2;
SELECT id, name, NEW test_table(value) AS new_value FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value < 0);
CALL sys_lockdown(0);
SELECT count(*) AS total FROM test_table GROUP BY NEW test_table(value) HAVING total > 1;
SELECT id, value FROM test_table ORDER BY NEW test_table(value) DESC LIMIT 5;
CREATE TABLE another_table (ref_id INT, description TEXT NOT NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO another_table (ref_id, description) SELECT id, CONCAT('Record ', id) FROM test_table;
SELECT a.ref_id, NEW another_table(description) AS new_desc FROM another_table AS a JOIN test_table AS t ON a.ref_id = t.id WHERE t.value IS NOT NULL;
SELECT id, name, CASE WHEN value IS NULL THEN 'NULL' ELSE 'VALUE' END AS value_status FROM test_table WHERE value IS NOT NULL;
SELECT id, NEW test_table(name) AS new_name, value FROM test_table WHERE created_at >= (CURRENT_TIMESTAMP - INTERVAL '1 DAY') GROUP BY id HAVING COUNT(*) > 0;
CALL sys_lockdown(1);
UPDATE test_table SET value = NULL WHERE id = (SELECT id FROM test_table WHERE value IS NOT NULL LIMIT 1);
SELECT DISTINCT NEW test_table(value) FROM test_table WHERE created_at < (CURRENT_TIMESTAMP - INTERVAL '7 DAY');