CREATE TABLE TestRDFData (id INT PRIMARY KEY, data VARCHAR(255), updated_at TIMESTAMP);
INSERT INTO TestRDFData (id, data, updated_at) VALUES (1, 'Sample Data 1', CURRENT_TIMESTAMP);
INSERT INTO TestRDFData (id, data, updated_at) VALUES (2, NULL, NULL);
INSERT INTO TestRDFData (id, data, updated_at) VALUES (3, 'Sample Data 3', 'invalid_date');
SELECT RDF_VIEW_SYNC_TO_PHYSICAL (NOT (SELECT COUNT(*) FROM TestRDFData WHERE data IS NULL), 0, 'urn:rdf:materialized:view:testdata');
SELECT RDF_VIEW_SYNC_TO_PHYSICAL (NOT (SELECT AVG(COALESCE(LENGTH(data), 0)) FROM TestRDFData), 1, 'urn:rdf:materialized:view:avgDataLength');
SELECT RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcTestData#', 0, 'urn:rdf:materialized:view:TestData', 1, NOT (SELECT COUNT(*) FROM TestRDFData WHERE updated_at < NOW() - INTERVAL '1 DAY'));
CREATE TABLE TestJoinData (id INT PRIMARY KEY, ref_id INT, value FLOAT);
INSERT INTO TestJoinData (id, ref_id, value) VALUES (1, 1, 3.14), (2, 1, NULL), (3, 2, 2.71);
SELECT RDF_VIEW_SYNC_TO_PHYSICAL (NOT (SELECT SUM(value) FROM TestJoinData WHERE value IS NOT NULL), 1, 'urn:rdf:materialized:view:joinTestData');
SELECT RDF_VIEW_SYNC_TO_PHYSICAL ('http://localhost/testView#', NOT (SELECT COUNT(*) FROM TestRDFData INNER JOIN TestJoinData ON TestRDFData.id = TestJoinData.ref_id WHERE TestRDFData.data IS NOT NULL), 'urn:rdf:materialized:view:joinData', 0, 0);