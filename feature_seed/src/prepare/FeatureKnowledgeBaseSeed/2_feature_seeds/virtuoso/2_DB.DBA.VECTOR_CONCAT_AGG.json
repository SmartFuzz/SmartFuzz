CREATE TABLE TestUsers (ID INT PRIMARY KEY, Name VARCHAR(100), Age INT, CreatedAt TIMESTAMP);
INSERT INTO TestUsers (ID, Name, Age, CreatedAt) VALUES (1, 'Alice', 30, CURRENT_TIMESTAMP), (2, 'Bob', NULL, CURRENT_TIMESTAMP), (3, '', 25, CURRENT_TIMESTAMP), (4, NULL, 40, CURRENT_TIMESTAMP);
SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(Name, Age + 1)) FROM TestUsers GROUP BY Age HAVING Age IS NOT NULL;
SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(Name, Age)) FROM TestUsers WHERE CreatedAt > CURRENT_TIMESTAMP - INTERVAL '7' DAY ORDER BY Age + 1;
SELECT (SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(Name)) FROM TestUsers t WHERE t.Age IS NOT NULL) + ' - Total Users: ' + (SELECT COUNT(*) FROM TestUsers) AS UserSummary;
SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(Name, CAST(Age AS VARCHAR))) FROM TestUsers WHERE Name <> '' OR Age IS NOT NULL;
SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(Name, Age + (CASE WHEN Age IS NULL THEN 0 ELSE Age END))) FROM TestUsers WHERE Age IS NOT NULL;
SELECT * FROM (SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(U.Name, U.Age)) AS UserInfo FROM TestUsers U JOIN TestUsers B ON U.ID <> B.ID GROUP BY U.Name) AS Subquery;
CREATE TABLE TestOrders (OrderID INT PRIMARY KEY, UserID INT, OrderAmount DECIMAL(10,2), OrderDate TIMESTAMP);
INSERT INTO TestOrders (OrderID, UserID, OrderAmount, OrderDate) VALUES (1, 1, 150.00, CURRENT_TIMESTAMP), (2, 2, 250.00, CURRENT_TIMESTAMP), (3, 1, 300.00, CURRENT_TIMESTAMP);
SELECT DB.DBA.VECTOR_CONCAT_AGG(vector(OrderID, (SELECT COUNT(*) FROM TestOrders WHERE UserID = T.UserID))) FROM TestUsers T JOIN TestOrders O ON T.ID = O.UserID WHERE O.OrderAmount > 100 GROUP BY T.Name;