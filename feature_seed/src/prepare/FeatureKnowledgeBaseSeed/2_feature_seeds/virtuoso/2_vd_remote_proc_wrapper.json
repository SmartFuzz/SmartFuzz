CREATE TABLE Customers (CustomerID VARCHAR(5) NOT NULL, CustomerName VARCHAR(50) NOT NULL, PRIMARY KEY (CustomerID));
INSERT INTO Customers (CustomerID, CustomerName) VALUES ('ALFKI', 'Alfreds Futterkiste'), ('ANATR', 'Ana Trujillo Emparedados y helados');
CREATE TABLE Orders (OrderID INT NOT NULL, CustomerID VARCHAR(5) NOT NULL, TotalAmount DECIMAL(10, 2) NOT NULL, PRIMARY KEY (OrderID), FOREIGN KEY (CustomerID) REFERENCES Customers(CustomerID));
INSERT INTO Orders (OrderID, CustomerID, TotalAmount) VALUES (1, 'ALFKI', 1234.56), (2, 'ANATR', 654.32);
SELECT * FROM Orders WHERE bif:contains(CustomerID, 'ALFKI') AND TotalAmount > 1000;
SELECT o.OrderID, (SELECT COUNT(*) FROM Orders WHERE CustomerID = o.CustomerID) AS OrderCount FROM Orders AS o WHERE bif:contains(CustomerID, 'Trujillo');
SELECT CustomerID, SUM(TotalAmount) AS TotalSpent FROM Orders GROUP BY CustomerID HAVING SUM(TotalAmount) > 500;
SELECT CustomerID, ROW_NUMBER() OVER (PARTITION BY CustomerID ORDER BY TotalAmount DESC) AS RN FROM Orders WHERE bif:contains(CustomerID, 'ALF');
DECLARE state, msg VARCHAR;
vd_remote_proc_wrapper('Northwind.dbo.CustOrderHist', 'MS.SQL.CustOrderHist', 'sql_lite', vector(vector('IN', '_CustomerID', 'VARCHAR', '')), state, msg, 1, 'Test Call with Precedence');
SELECT * FROM Orders WHERE bif:contains(CustomerID, 'ALFKI') OR (TotalAmount + 100) IS NULL;
SELECT CustomerID FROM Orders WHERE bif:contains(CustomerID, 'ANATR') AND TotalAmount IS NOT NULL;
CREATE TABLE TempOrders (OrderID INT NOT NULL PRIMARY KEY, Amount DECIMAL(10,2), OrderDate DATE DEFAULT CURRENT_DATE);
INSERT INTO TempOrders (OrderID, Amount) VALUES (3, 100.50), (4, NULL), (5, 200.75);
SELECT OrderID, Amount, COALESCE(Amount, 0) AS AmountAdjusted FROM TempOrders WHERE bif:contains(OrderID::VARCHAR, '3');
SELECT * FROM Orders WHERE bif:contains(CustomerID, CASE WHEN TotalAmount > 1000 THEN 'ALFKI' ELSE 'ANATR' END);
SELECT CustomerID, AVG(TotalAmount) AS AverageAmount FROM Orders GROUP BY CustomerID HAVING AVG(TotalAmount) < (SELECT MAX(TotalAmount) FROM Orders);