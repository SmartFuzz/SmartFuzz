CREATE TABLE test_urls (id INT PRIMARY KEY, url VARCHAR(255) NOT NULL);
INSERT INTO test_urls (id, url) VALUES (1, 'http://example.com/page1'), (2, 'http://example.com/page2');
SELECT id, http_physical_path(url) AS physical_path FROM test_urls WHERE url IS NOT NULL;
SELECT id, http_physical_path(url) AS physical_path FROM test_urls WHERE LENGTH(url) * 2 > 10;
SELECT id, COUNT(*) * (SELECT COUNT(*) FROM test_urls) AS total_count FROM test_urls GROUP BY id HAVING total_count > 1;
SELECT id, http_physical_path(url) * 2 AS scaled_physical FROM test_urls WHERE id IN (SELECT id FROM test_urls) ORDER BY scaled_physical;
CREATE TABLE test_numbers (val INT NOT NULL);
INSERT INTO test_numbers (val) VALUES (NULL), (10), (20);
SELECT val, (http_physical_path(NULL) * val) AS implicit_casting FROM test_numbers WHERE val IS NOT NULL;
SELECT SUM(val) AS total, COUNT(url) * (SELECT COUNT(DISTINCT id) FROM test_urls) AS multiplied_count FROM test_numbers JOIN test_urls ON val = LENGTH(url) GROUP BY total HAVING total > 10;
CREATE TABLE test_floats (value FLOAT);
INSERT INTO test_floats (value) VALUES (NULL), (3.14), (1.61);
SELECT value, http_physical_path(url) * CAST(value AS INT) FROM test_urls CROSS JOIN test_floats WHERE value IS NOT NULL;
SELECT id, http_physical_path(url) FROM test_urls WHERE url LIKE '%' || (SELECT MIN(url) FROM test_urls) || '%';