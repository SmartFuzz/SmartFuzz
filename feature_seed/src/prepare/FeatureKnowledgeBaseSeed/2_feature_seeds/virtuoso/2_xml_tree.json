CREATE TABLE xml_test (id INT PRIMARY KEY, data XML, keyword VARCHAR(255));
INSERT INTO xml_test (id, data, keyword) VALUES (1, xml_tree('<root><child>Example</child></root>'), 'Example');
INSERT INTO xml_test (id, data, keyword) VALUES (2, xml_tree('<root><child>Sample</child></root>'), 'Sample');
SELECT id, xml_tree(data) AS parse_tree, keyword FROM xml_test WHERE bif:contains(keyword, 'Example');
SELECT * FROM xml_test WHERE bif:contains(data, 'child') AND id IN (SELECT id FROM xml_test WHERE keyword IS NOT NULL);
SELECT id, COUNT(*) FROM xml_test GROUP BY keyword HAVING COUNT(*) > 1;
SELECT id, xml_tree(data) AS parse_tree FROM xml_test WHERE bif:contains(data, 'Invalid') OR id IS NULL;
CREATE TABLE xml_edge_case (id INT, xml_content XML NOT NULL DEFAULT xml_tree('<root></root>'));
INSERT INTO xml_edge_case (id, xml_content) VALUES (1, null), (2, xml_tree('<root><empty></empty></root>'));
SELECT id, bif:contains(xml_content, 'empty') AS has_empty FROM xml_edge_case WHERE xml_content IS NOT NULL AND id < 5;
CREATE TABLE xml_join_test (id INT, parent_id INT REFERENCES xml_test(id), data XML);
INSERT INTO xml_join_test (id, parent_id, data) VALUES (1, 1, xml_tree('<root><child>Child1</child></root>'));
SELECT x.id, xml_tree(data) AS parsed_data FROM xml_join_test x JOIN xml_test p ON x.parent_id = p.id WHERE bif:contains(p.keyword, 'Example');
SELECT id, xml_tree(data) AS tree_structure FROM xml_test WHERE LENGTH(keyword) IN (SELECT MAX(LENGTH(keyword)) FROM xml_test);
SELECT DISTINCT id FROM xml_test WHERE bif:contains(data, (SELECT keyword FROM xml_test WHERE id = 1));