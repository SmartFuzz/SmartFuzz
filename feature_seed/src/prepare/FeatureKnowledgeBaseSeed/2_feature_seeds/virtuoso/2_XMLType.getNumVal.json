CREATE TABLE TEST_XMLS (I integer primary key, XMLVAL XMLType, SPATIAL_COL geography);
INSERT INTO TEST_XMLS VALUES (1, XMLType('<emp><empno>10</empno><ename>John</ename></emp>'), 'POINT(30 10)');
INSERT INTO TEST_XMLS VALUES (2, XMLType('<emp><empno>20</empno><ename>Jane</ename></emp>'), 'POINT(40 20)');
INSERT INTO TEST_XMLS VALUES (3, XMLType('<emp><empno>30</empno><ename>Doe</ename></emp>'), 'POINT(50 30)');
SELECT DISTINCT e.XMLVAL.extract('//empno').getNumVal() AS EMPNO, SPATIAL_COL FROM TEST_XMLS e WHERE bif:st_overlaps(SPATIAL_COL, 'POLYGON((30 10, 30 20, 40 20, 40 10, 30 10))') AND e.XMLVAL.existsNode('/emp/empno');
SELECT COUNT(*), e.XMLVAL.extract('//empno').getNumVal() AS EMPNO FROM TEST_XMLS e GROUP BY e.XMLVAL;
HAVING EMPNO IS NOT NULL;
SELECT * FROM (SELECT e.XMLVAL.extract('//empno').getNumVal() AS EMPNO, e.SPATIAL_COL FROM TEST_XMLS e WHERE e.XMLVAL.existsNode('/emp/empno')) AS SUB WHERE EMPNO > 15;
CREATE TABLE TEMP_XML_TEST (ID integer primary key, XMLVAL XMLType);
INSERT INTO TEMP_XML_TEST VALUES (1, XMLType('<record><num>1000</num><desc>Test Record</desc></record>'));
SELECT XMLVAL, bif:st_overlaps(geography 'POINT(100 100)', geography 'POINT(30 10)') AS OVERLAPS FROM TEMP_XML_TEST WHERE XMLVAL.extract('//num').getNumVal() IS NOT NULL;
CREATE TABLE BOUNDARY_TEST (ID integer, MIN_VALUE integer DEFAULT 0, MAX_VALUE integer DEFAULT 100);
INSERT INTO BOUNDARY_TEST VALUES (1, NULL, 50);
INSERT INTO BOUNDARY_TEST VALUES (2, 0, 0);
INSERT INTO BOUNDARY_TEST VALUES (3, 100, 1000);
SELECT * FROM BOUNDARY_TEST WHERE (MIN_VALUE IS NULL OR MAX_VALUE IS NULL OR MIN_VALUE > MAX_VALUE);