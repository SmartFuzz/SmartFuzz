CREATE TABLE test_table (id INT PRIMARY KEY, xml_data XML, data_file TEXT);
INSERT INTO test_table (id, xml_data, data_file) VALUES (1, '<root><element id="1">Test</element></root>', file_open('tmp/file1.n3'));
INSERT INTO test_table (id, xml_data, data_file) VALUES (2, '<root><element id="2">Example</element></root>', file_open('tmp/file2.n3'));
SELECT id, xpath_string('/root/element/@id', xml_data) AS extracted_id FROM test_table WHERE extracted_id IS NOT NULL;
SELECT id, COUNT(*) OVER (PARTITION BY xpath_string('/root/element/@id', xml_data)) AS id_count FROM test_table;
SELECT id, xml_data FROM test_table WHERE data_file IS NULL OR data_file = '' OR xml_data IS NOT NULL;
SELECT id, xpath_string('/root/element/@id', xml_data) AS extracted_id FROM test_table WHERE extracted_id::INT > 1;
SELECT DISTINCT xpath_string('/root/element/@id', xml_data) FROM test_table ORDER BY extracted_id;
SELECT id, data_file, xpath_string('/root/element/@id', xml_data) AS extracted_id FROM test_table WHERE data_file LIKE 'tmp/%';
CREATE TEMPORARY TABLE temp_test_table AS SELECT id, xpath_string('/root/element/@id', xml_data) AS extracted_id FROM test_table WHERE xml_data IS NOT NULL;