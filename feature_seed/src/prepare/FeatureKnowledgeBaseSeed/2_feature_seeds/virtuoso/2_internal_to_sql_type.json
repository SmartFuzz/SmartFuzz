CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255), num_value DECIMAL(10,5), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, value, num_value) VALUES (1, '123', 15.75);
INSERT INTO test_table (id, value, num_value) VALUES (2, NULL, NULL);
INSERT INTO test_table (id, value, num_value) VALUES (3, '', 0.0);
SELECT id, internal_to_sql_type(num_value + CAST(value AS DECIMAL)) AS sql_type FROM test_table WHERE num_value IS NOT NULL;
SELECT id, num_value + 2 AS add_result FROM test_table WHERE value IS NOT NULL;
SELECT id, internal_to_sql_type(num_value + (SELECT MAX(num_value) FROM test_table)) AS nested_type FROM test_table;
SELECT id, value, internal_to_sql_type(COALESCE(num_value, 0) + 1) AS coerced_sql_type FROM test_table;
SELECT id, internal_to_sql_type(value) AS value_type FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NOT NULL);
SELECT id, num_value * (SELECT COUNT(*) FROM test_table) + internal_to_sql_type(num_value - 5) AS complex_calc FROM test_table WHERE id < 3 GROUP BY id HAVING internal_to_sql_type(num_value) > 10;