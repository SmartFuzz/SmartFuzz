CREATE TABLE Orders (OrderID INT PRIMARY KEY, OrderDate DATE, CustomerName VARCHAR(255), OrderAmount DECIMAL(10, 2));
INSERT INTO Orders (OrderID, OrderDate, CustomerName, OrderAmount) VALUES (1, '2023-10-01', 'John Doe', 150.00);
INSERT INTO Orders (OrderID, OrderDate, CustomerName, OrderAmount) VALUES (2, NULL, 'Jane Smith', NULL);
INSERT INTO Orders (OrderID, OrderDate, CustomerName, OrderAmount) VALUES (3, '2023-10-03', 'Alice Johnson', -50.75);
INSERT INTO Orders (OrderID, OrderDate, CustomerName, OrderAmount) VALUES (4, '2023-10-05', '', 0);
SELECT OrderID, OrderAmount FROM Orders WHERE OrderAmount > 100.00 ORDER BY OrderID DESC;
SELECT * FROM (SELECT OrderID, COUNT(CustomerName) as CustomerCount FROM Orders GROUP BY OrderAmount HAVING AVG(OrderAmount) > 0) AS SubQuery;
CREATE TABLE RemoteStats (DSN VARCHAR(255), TableQualifier VARCHAR(255), OrdersArray ARRAY);
INSERT INTO RemoteStats VALUES ('Local Virtuoso', 'Demo', sql_statistics('Local Virtuoso', 'Demo', NULL, 'Orders', 0, 1));
SELECT xpath_string('/root/@id', (SELECT OrdersArray FROM RemoteStats WHERE DSN = 'Local Virtuoso')) AS OrderIDList;
SELECT OrderID FROM Orders WHERE OrderDate = (SELECT MAX(OrderDate) FROM Orders);
SELECT OrderID, SUM(OrderAmount) OVER (PARTITION BY CustomerName ORDER BY OrderDate) AS RunningTotal FROM Orders;
SELECT * FROM Orders WHERE CustomerName LIKE '%' || NULL || '%';
SELECT COUNT(*) FROM Orders WHERE OrderAmount IS NULL OR OrderAmount < 0;
SELECT *, sql_statistics('Local Virtuoso', 'Demo', NULL, NULL, 0, 1) AS Statistics FROM Orders ORDER BY OrderAmount ASC;
CREATE TABLE TempOrders AS SELECT * FROM Orders WHERE OrderAmount > 100;
DROP TABLE IF EXISTS TempOrders;