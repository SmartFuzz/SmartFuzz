CREATE TABLE geo_shapes (id INT, geom GEOMETRY, xml_col XML);
INSERT INTO geo_shapes VALUES (1, POINT(1.0 1.0), '<root><a>Value1</a></root>');
INSERT INTO geo_shapes VALUES (2, POLYGON((0 0, 0 2, 2 2, 2 0, 0 0)), '<root><b>Value2</b></root>');
SELECT bif:st_get_bounding_box(geom) AS bounding_box, xpath_string('/root/a', xml_col) AS extracted_value FROM geo_shapes WHERE geom IS NOT NULL;
SELECT id, bif:st_get_bounding_box(geom) AS bounding_box FROM geo_shapes WHERE xpath_string('/root/a', xml_col) = 'Value1';
SELECT COUNT(*) AS shape_count FROM geo_shapes WHERE bif:st_get_bounding_box(geom) IS NOT NULL HAVING COUNT(geom) > 1;
SELECT g1.id, bif:st_get_bounding_box(g1.geom) FROM geo_shapes g1 JOIN geo_shapes g2 ON g1.id != g2.id WHERE xpath_string('/root/b', g2.xml_col) IS NULL;
INSERT INTO geo_shapes VALUES (3, LINESTRING(0 0, 5 5), NULL);
SELECT bif:st_get_bounding_box(geom), xpath_string('/root/a', xml_col) FROM geo_shapes WHERE geom IS NOT NULL OR xml_col IS NULL;
SELECT bif:st_get_bounding_box(geom) FROM geo_shapes WHERE geom IS NOT NULL ORDER BY xpath_string('/root/a', xml_col) DESC;