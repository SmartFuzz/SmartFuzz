CREATE TABLE test_table (id INT PRIMARY KEY, data VARCHAR(255), xml_data XML);
INSERT INTO test_table (id, data, xml_data) VALUES (1, 'Test data', xml_tree_doc('<root><a>1</a></root>'));
INSERT INTO test_table (id, data, xml_data) VALUES (2, NULL, xml_tree_doc('<root><a>2</a></root>'));
INSERT INTO test_table (id, data, xml_data) VALUES (3, '', xml_tree_doc('<root><a></a></root>'));
SELECT http_rewrite();
SELECT id, http_rewrite() AS http_output FROM test_table WHERE data IS NOT NULL;
SELECT data, http_rewrite() AS rewritten_output FROM test_table WHERE XML_EXISTS(xml_data, '/root/a');
SELECT t1.id, COUNT(*) OVER (PARTITION BY t1.data) AS data_count FROM test_table t1 WHERE t1.data <> (SELECT MAX(data) FROM test_table t2 WHERE t2.id != t1.id);
SELECT CASE WHEN xml_data IS NULL THEN 'No XML' ELSE 'Has XML' END AS xml_status FROM test_table;
SELECT COUNT(*), AVG(COALESCE(id, 0)) FROM test_table GROUP BY http_rewrite();
SELECT http_rewrite() FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t2.data IS NOT NULL;
SELECT http_rewrite(), xml_tree_doc('<root><msg>Success</msg></root>') FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);