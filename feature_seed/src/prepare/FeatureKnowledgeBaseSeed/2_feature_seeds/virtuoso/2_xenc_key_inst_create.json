CREATE TABLE encryption_keys (id SERIAL PRIMARY KEY, key_name VARCHAR(255), created_at TIMESTAMP DEFAULT NOW());
INSERT INTO encryption_keys (key_name) VALUES ('testKey1'), ('testKey2');
SELECT id, xenc_key_inst_create('myAES', xenc_key_inst_create('rsa-test')) * 2 FROM encryption_keys WHERE created_at IS NOT NULL;
SELECT id, (SELECT COUNT(*) * 1.5 FROM encryption_keys) AS total_keys, xenc_key_inst_create('myAES', NULL) AS derived_key FROM encryption_keys GROUP BY id HAVING total_keys > 0;
SELECT (xenc_key_inst_create('myAES', id::TEXT) * (SELECT MAX(id) FROM encryption_keys)) AS key_multiplier FROM encryption_keys;
SELECT id, xenc_key_inst_create('myAES', xenc_key_inst_create(NULL)) * (NULLIF(id, 0) + 1) FROM encryption_keys;
CREATE TABLE user_data (user_id SERIAL PRIMARY KEY, user_key VARCHAR(255), score INT, created_at TIMESTAMP DEFAULT NOW());
INSERT INTO user_data (user_key, score) VALUES ('userKey1', 10), ('userKey2', NULL), ('userKey3', 20);
SELECT user_id, xenc_key_inst_create(user_key, xenc_key_inst_create('myAES')) * COALESCE(score, 0) FROM user_data ORDER BY created_at DESC;
SELECT user_id, xenc_key_inst_create('myAES', (SELECT COUNT(*) FROM user_data) * 1) AS user_key_influence FROM user_data WHERE score > (SELECT AVG(score) FROM user_data) GROUP BY user_id;
ALTER TABLE encryption_keys ADD COLUMN is_active BOOLEAN DEFAULT TRUE;
UPDATE encryption_keys SET is_active = FALSE WHERE created_at < NOW() - INTERVAL '1 day';
DROP TABLE IF EXISTS temp_data;
CREATE TEMP TABLE temp_data AS SELECT id, xenc_key_inst_create('myAES', 'staticKey') * score AS modified_score FROM user_data;
SELECT id, xenc_key_inst_create('myAES', temp.modified_score) * (SELECT SUM(score) FROM user_data) FROM temp_data AS temp WHERE temp.modified_score IS NOT NULL;
CREATE TABLE random_data (rand_id SERIAL PRIMARY KEY, rand_value FLOAT, inserted_at TIMESTAMP DEFAULT NOW());
INSERT INTO random_data (rand_value) VALUES (NULL), (1.234567), (NULLIF(42, 42)), (3.14);
SELECT rand_id, xenc_key_inst_create('myAES', (rand_value::TEXT || (SELECT COUNT(*) FROM random_data))) * randomness AS fuzzed_value FROM random_data;
SELECT xenc_key_inst_create('myAES', (1.7976931348623157E+308 * NULLIF(rand_value, 0))) * (SELECT MAX(rand_value) FROM random_data WHERE rand_value IS NOT NULL) FROM random_data;
SELECT json_agg(xenc_key_inst_create('myAES', rand_value::TEXT)) AS json_keys FROM random_data;