CREATE TABLE test_table (id INT PRIMARY KEY, num_col NUMERIC, xml_col XML);
INSERT INTO test_table (id, num_col, xml_col) VALUES (1, -3.14, '<root><a>Sample</a></root>');
INSERT INTO test_table (id, num_col, xml_col) VALUES (2, 2.99, '<root><a>Another Sample</a></root>');
SELECT abs(num_col), xpath_string('/root/a', xml_col) FROM test_table WHERE abs(num_col) > 2;
SELECT id, abs(num_col) AS abs_value, xpath_string('/root/a', xml_col) AS extracted_string FROM test_table WHERE extracted_string IS NOT NULL;
SELECT id, abs(num_col) AS abs_value, (SELECT MAX(abs(num_col)) FROM test_table WHERE id <> t.id) AS max_other FROM test_table t;
SELECT id, COUNT(*) OVER() AS total_count, abs(num_col) AS abs_value FROM test_table WHERE abs(num_col) < 5 GROUP BY id, abs_value HAVING abs_value > 0;
SELECT t.id, xpath_string('/root/a', t.xml_col) FROM test_table t JOIN (SELECT abs(num_col) AS abs_value FROM test_table) sub ON abs_value > 2.0;
SELECT id, abs(num_col) + (SELECT COUNT(*) FROM test_table) AS adjusted_value FROM test_table WHERE xpath_string('/root/a', xml_col) LIKE 'Sample';