CREATE TABLE spatial_test (id SERIAL PRIMARY KEY, geom VARCHAR NOT NULL, srid INTEGER NOT NULL);
INSERT INTO spatial_test (geom, srid) VALUES ('POLYGON((-16 20.25, -16.1 20.35, -15.9 20.35, -16 20.25))', 1);
INSERT INTO spatial_test (geom, srid) VALUES ('POLYGON((743238 2967416, 743238 2967450, 743265 2967450, 743265.625 2967416, 743238 2967416))', 2249);
SELECT ST_AsText(ST_Transform(ST_GeomFromText((SELECT geom FROM spatial_test WHERE srid = 1), NULL), 4326)) AS transformed_geom;
SELECT ST_AsText(ST_Transform(ST_GeomFromText('LINESTRING(-75 20, -70 25)', NULL), 4326)), id FROM spatial_test WHERE geom IS NOT NULL;
SELECT a.id, ST_AsText(ST_Transform(a.geom, b.srid)), b.srid FROM spatial_test a JOIN spatial_test b ON a.srid = b.srid WHERE a.geom IS NOT NULL AND b.geom IS NOT NULL;
SELECT ST_AsText(ST_Transform(ST_GeomFromText('POINT(1 2)', 4326), 1)) AS transformed_geom, NULLIF(NULL, 'This will be NULL') AS null_example;
SELECT ST_AsText(ST_Transform(ST_GeomFromText('POLYGON((-100 50, -100 60, -90 60, -90 50, -100 50))', 1), 4326)), CAST('-75' AS INTEGER) AS cast_example FROM spatial_test;
WITH transformed AS (SELECT ST_Transform(ST_GeomFromText(geom, NULL), 4326) AS transformed_geom FROM spatial_test) SELECT COUNT(*) FROM transformed WHERE transformed_geom IS NOT NULL;
SELECT ST_AsText(ST_Transform(ST_GeomFromText(COALESCE(a.geom, b.geom), 1), 4326)) FROM spatial_test a FULL OUTER JOIN spatial_test b ON a.id = b.id;
SELECT AVG(ST_Area(ST_Transform(ST_GeomFromText(geom, 2249), 4326))) AS avg_area FROM spatial_test GROUP BY srid HAVING COUNT(*) > 0;