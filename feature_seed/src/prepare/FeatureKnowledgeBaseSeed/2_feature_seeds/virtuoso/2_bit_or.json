CREATE TABLE test_table (id INT, value1 INT, value2 INT, value3 VARCHAR(255));
INSERT INTO test_table (id, value1, value2, value3) VALUES (1, 18, -6, 'test1'), (2, 11, NULL, 'test2'), (3, 0, 0, NULL);
SELECT id, bit_or(value1) AS bitwise_result FROM test_table WHERE value2 IS NOT NULL GROUP BY id HAVING bit_or(value1) IN (bit_or(11), bit_or(0));
SELECT t1.id, bit_or(t1.value1) AS result FROM test_table t1 JOIN test_table t2 ON bit_or(t1.value2) IN (t2.value2, 6) GROUP BY t1.id HAVING result > 0;
SELECT id, value3 FROM test_table WHERE (value1 IN (SELECT value2 FROM test_table WHERE value3 IS NULL) OR bit_or(value1) IN (18, -6));
CREATE TABLE temp_table (temp_id INT, temp_value INT);
INSERT INTO temp_table (temp_id, temp_value) VALUES (1, 8), (2, 15);
SELECT temp_id, bit_or(temp_value) AS temp_result FROM temp_table GROUP BY temp_id HAVING temp_result IN (SELECT bit_or(value2) FROM test_table WHERE value3 IS NOT NULL);
SELECT id, value3, bit_or(NULLIF(value2, 0)) FROM test_table WHERE bit_or(value1) IN (SELECT bit_or(temp_value) FROM temp_table) GROUP BY id HAVING id IS NOT NULL;