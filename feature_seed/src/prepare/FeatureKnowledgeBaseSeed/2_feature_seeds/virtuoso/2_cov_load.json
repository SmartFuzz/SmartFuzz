CREATE TABLE test_coverage (id INT PRIMARY KEY, coverage_data VARCHAR(255));
INSERT INTO test_coverage VALUES (1, 'Coverage data 1'), (2, 'Coverage data 2');
SELECT * FROM test_coverage WHERE id != (SELECT MAX(id) FROM test_coverage);
SELECT id, coverage_data FROM test_coverage WHERE coverage_data != (SELECT coverage_data FROM test_coverage WHERE id = 1);
SELECT COUNT(*) FROM (SELECT id FROM test_coverage WHERE coverage_data != 'Coverage data 2') AS subquery;
SELECT id, coverage_data FROM test_coverage WHERE coverage_data != NULL;
SELECT * FROM test_coverage WHERE id IN (SELECT id FROM test_coverage WHERE coverage_data != 'Coverage data 1');
SELECT id, coverage_data FROM test_coverage HAVING COUNT(*) != (SELECT COUNT(*) FROM test_coverage WHERE coverage_data IS NOT NULL);
CREATE TEMP TABLE temp_test (temp_id INT PRIMARY KEY, temp_data INT);
INSERT INTO temp_test VALUES (1, 100), (2, NULL);
SELECT * FROM temp_test WHERE temp_data != (SELECT temp_data FROM temp_test WHERE temp_id = 1);
SELECT DISTINCT a.id FROM test_coverage a JOIN temp_test b ON a.id != b.temp_id WHERE b.temp_data IS NOT NULL;
SELECT MAX(id) FROM test_coverage GROUP BY coverage_data HAVING COUNT(*) != (SELECT COUNT(*) FROM test_coverage WHERE coverage_data IS NOT NULL);
SELECT id, coverage_data FROM test_coverage WHERE (SELECT COUNT(*) FROM temp_test) != (SELECT COUNT(*) FROM test_coverage);
SELECT * FROM test_coverage WHERE coverage_data != (SELECT substring(coverage_data FROM 1 FOR 5) FROM test_coverage WHERE id = 2);
SELECT id FROM test_coverage WHERE id != (SELECT MIN(id) FROM test_coverage WHERE id IS NOT NULL) AND coverage_data IS NOT NULL;