CREATE TABLE business_services (id INT PRIMARY KEY, name VARCHAR(255), created_at TIMESTAMP, updated_at TIMESTAMP);
INSERT INTO business_services VALUES (1, 'Service A', NOW(), NOW());
INSERT INTO business_services VALUES (2, 'Service B', NOW(), NOW());
INSERT INTO business_services VALUES (3, NULL, NOW(), NOW());
SELECT uddi_save_service(name, id) FROM (SELECT name, id FROM business_services WHERE id >= 1) AS subquery WHERE created_at >= NOW() - INTERVAL '1 DAY';
SELECT uddi_save_service(name, id) FROM (SELECT name, id FROM business_services) AS sub WHERE SUBSTRING(name, 1, 1) IS NOT NULL AND id >= (SELECT MAX(id) FROM business_services) - 1;
SELECT uddi_save_service(name, id) FROM business_services WHERE id IS NULL OR created_at >= NOW() - INTERVAL '1 DAY' HAVING COUNT(id) >= 1;
SELECT uddi_save_service(name, id) FROM (SELECT name, id FROM business_services WHERE created_at IS NOT NULL) AS bs WHERE (id >= 2 AND id < 5) + (id IS NULL)::INT > 0;
SELECT uddi_save_service(name, id) FROM business_services WHERE name IS NOT NULL AND id >= (SELECT MAX(id) FROM business_services WHERE name IS NOT NULL) HAVING COUNT(*) > 0;
SELECT uddi_save_service(name, id) FROM (SELECT name, id FROM business_services) AS b JOIN (SELECT MAX(id) AS max_id FROM business_services) AS sub ON b.id >= sub.max_id WHERE (strlen(name) >= 0);