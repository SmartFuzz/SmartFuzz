CREATE TABLE test_table (id INT PRIMARY KEY, xml_content XML, varbinary_col VARBINARY);
INSERT INTO test_table (id, xml_content, varbinary_col) VALUES (1, '<root><data>example</data></root>', 0x1234), (2, '<root><data>test</data><data>another</data></root>', 0xABCD);
SELECT id, isbinary(varbinary_col) AS is_varbinary, xpath_contains(xml_content, '/root/data[text()="example"]') AS contains_example FROM test_table WHERE isbinary(varbinary_col) = 1;
SELECT id, varbinary_col, (SELECT COUNT(*) FROM test_table AS t2 WHERE xpath_contains(t2.xml_content, '/root/data')) AS xml_count FROM test_table HAVING xml_count > 0;
SELECT id, varbinary_col, isbinary(CONVERT(varbinary_col, VARCHAR(20))) AS varbinary_to_string FROM test_table WHERE xpath_contains(xml_content, '/root/data[text()="test"]') OR varbinary_col IS NULL;
CREATE TABLE temp_table (data_id INT, data_value VARBINARY, XMLData XML);
INSERT INTO temp_table (data_id, data_value, XMLData) VALUES (1, 0xDEADBEEF, '<root><data>deadbeef</data></root>'), (2, 0x00000000, '<root><data>empty</data></root>');
SELECT data_id, xpath_contains(XMLData, '/root/data[text()="empty"]') AS contains_empty, isbinary(data_value) AS is_valid_varbinary FROM temp_table WHERE data_value IS NOT NULL;
SELECT id, COUNT(*) OVER() AS total_records, MAX(isbinary(varbinary_col)) AS max_varbinary_status FROM test_table GROUP BY id HAVING MAX(varbinary_col) IS NOT NULL;