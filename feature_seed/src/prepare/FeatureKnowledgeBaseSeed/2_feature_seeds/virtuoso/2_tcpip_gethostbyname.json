CREATE TABLE hosts (id INT PRIMARY KEY, domain VARCHAR(255), active BOOLEAN, description TEXT);
INSERT INTO hosts (id, domain, active, description) VALUES (1, 'example.com', TRUE, NULL), (2, 'nonexistent.domain', FALSE, 'Host does not exist');
SELECT domain, tcpip_gethostbyname(domain) AS ip_address FROM hosts WHERE active = TRUE;
SELECT d.domain, tcpip_gethostbyname(d.domain) AS ip, (CASE WHEN ip IS NOT NULL THEN 'Exists' ELSE 'Does not exist' END) AS status FROM hosts d WHERE (d.active IS NOT NULL) || (tcpip_gethostbyname('localhost') = '127.0.0.1');
SELECT DISTINCT h.domain FROM hosts h JOIN (SELECT domain FROM hosts WHERE active = FALSE) inactive ON h.id <> inactive.id WHERE h.domain LIKE '%domain' || tcpip_gethostbyname(inactive.domain);
CREATE TABLE resolutions (id INT PRIMARY KEY, host_id INT, resolved_ip VARCHAR(15), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, FOREIGN KEY (host_id) REFERENCES hosts(id));
INSERT INTO resolutions (id, host_id, resolved_ip) VALUES (1, 1, tcpip_gethostbyname('example.com')), (2, 2, tcpip_gethostbyname('nonexistent.domain'));
SELECT r.host_id, COUNT(r.resolved_ip) AS total_resolutions FROM resolutions r GROUP BY r.host_id HAVING (COUNT(r.resolved_ip) > 1) || (tcpip_gethostbyname('invalid.domain') = '') ORDER BY total_resolutions DESC;
SELECT (SELECT AVG(LENGTH(tcpip_gethostbyname(h.domain))) FROM hosts h WHERE h.active = TRUE) AS avg_ip_length || ' characters for active domains' AS ip_length_info FROM (SELECT COUNT(*) FROM hosts) AS total_hosts;
SELECT h.domain, (SELECT tcpip_gethostbyname(h.domain)) AS ip, CASE WHEN (SELECT count(*) FROM resolutions r WHERE r.resolved_ip = tcpip_gethostbyname(h.domain)) > 0 THEN TRUE ELSE FALSE END AS has_resolution FROM hosts h WHERE h.domain IS NOT NULL AND (h.active = TRUE) || (tcpip_gethostbyname('invalid.domain') IS NOT NULL);
DROP TABLE IF EXISTS resolutions;