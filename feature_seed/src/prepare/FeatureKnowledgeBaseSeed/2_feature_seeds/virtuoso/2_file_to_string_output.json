CREATE TABLE file_table (ft_name varchar, ft_cont long varbinary, PRIMARY KEY (ft_name));
CREATE TABLE temp_table (tt_name varchar, tt_value int, PRIMARY KEY (tt_name));
CREATE PROCEDURE insert_files (IN fname varchar) { DECLARE strout_handle any;
strout_handle := file_to_string_output(fname);
INSERT INTO file_table (ft_name, ft_cont) VALUES (fname, strout_handle);
SELECT CONCAT('Inserted: ', fname) AS confirmation WHERE NULLIF(strout_handle, '') IS NOT NULL;
};
INSERT INTO temp_table (tt_name, tt_value) VALUES ('foo', 10);
INSERT INTO temp_table (tt_name, tt_value) VALUES ('bar', NULL);
INSERT INTO temp_table (tt_name, tt_value) VALUES ('baz', 2147483647);
INSERT INTO temp_table (tt_name, tt_value) VALUES ('qux', -2147483648);
SELECT ft_name || ' - size: ' || LENGTH(ft_cont) FROM file_table WHERE LENGTH(ft_cont) > 0;
SELECT DISTINCT tt_name || ': ' || COALESCE(tt_value, 'NULL') AS value FROM temp_table ORDER BY tt_name;
SELECT ft_name, SUM(tt_value) OVER (PARTITION BY ft_name) AS total_value FROM temp_table JOIN file_table ON tt_name = ft_name || '_source' GROUP BY ft_name HAVING total_value > 10;
INSERT INTO file_table (ft_name, ft_cont) VALUES (CONCAT('test_', CAST(RANDOM() * 1000 AS varchar)), file_to_string_output('random_test.dat'));
CREATE TABLE boundary_table (bt_id int, bt_val varchar(10), PRIMARY KEY (bt_id));
INSERT INTO boundary_table (bt_id, bt_val) VALUES (1, '');
INSERT INTO boundary_table (bt_id, bt_val) VALUES (2, 'maximumvalue');
SELECT * FROM boundary_table WHERE bt_val = '' OR bt_val IS NULL;
INSERT INTO boundary_table (bt_id, bt_val) VALUES (3, NULL);
SELECT * FROM boundary_table WHERE bt_val IS NULL;
INSERT INTO file_table (ft_name, ft_cont) SELECT 'sample_' || bt_id, file_to_string_output('data_' || bt_id || '.dat') FROM boundary_table;
INSERT INTO file_table (ft_name, ft_cont) SELECT CONCAT('example_', CAST(tt_value AS varchar)), file_to_string_output(CONCAT('example_', tt_value, '.dat')) FROM temp_table WHERE tt_value IS NOT NULL;