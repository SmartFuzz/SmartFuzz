CREATE TABLE test_data (id INT PRIMARY KEY, value DOUBLE PRECISION, description VARCHAR(255));
INSERT INTO test_data (id, value, description) VALUES (1, 0.513513, 'test entry 1'), (2, NULL, 'test entry 2'), (3, 2.71828, 'test entry 3');
SELECT id, exp(value) AS exponent_value, description FROM test_data WHERE description ILIKE 'test%';
SELECT id, exp(value + 1) AS exponent_offset, description FROM test_data WHERE COALESCE(description, '') ILIKE 'test%';
SELECT id, description, exp(value) AS exp_value FROM test_data WHERE id IN (SELECT id FROM test_data WHERE value IS NOT NULL);
SELECT id, exp(COALESCE(value, 0)) AS exp_with_null_handling, description FROM test_data HAVING exp_with_null_handling > 1;
CREATE TABLE another_table (name VARCHAR(100) NOT NULL, ref_id INT REFERENCES test_data(id));
INSERT INTO another_table (name, ref_id) VALUES ('Entry A', 1), ('Entry B', 2), ('Entry C', NULL);
SELECT a.name, exp(t.value) AS exp_value FROM another_table a JOIN test_data t ON a.ref_id = t.id WHERE a.name ILIKE 'Entry%';
SELECT id, exp(NULLIF(value, 0)) AS exp_non_zero, description FROM test_data WHERE value IS NOT NULL ORDER BY exp_non_zero DESC;
SELECT avg(exp(value)) AS average_exp FROM test_data WHERE description ILIKE '%entry%';
SELECT id, exp(value) AS exp_value, ROW_NUMBER() OVER (PARTITION BY description ORDER BY exp(value) DESC) AS rn FROM test_data WHERE description ILIKE 'test%';
CREATE TABLE edge_cases (number_val DOUBLE PRECISION, str_val VARCHAR(100));
INSERT INTO edge_cases (number_val, str_val) VALUES (1e-10, 'negligible'), (1e10, 'huge'), (0.0, 'zero'), (NULL, 'null_value');
SELECT str_val, exp(number_val) AS exp_val FROM edge_cases WHERE str_val ILIKE 'h%';
SELECT exp(COALESCE((SELECT AVG(number_val) FROM edge_cases WHERE str_val IS NOT NULL), 0)) AS avg_exp_value;
SELECT exp(CASE WHEN number_val IS NOT NULL THEN number_val ELSE 0 END) AS safe_exp FROM edge_cases WHERE str_val ILIKE 'ne%';
UPDATE test_data SET value = exp(0.0) WHERE id = 1;
DROP TABLE IF EXISTS temp_test;
CREATE TEMPORARY TABLE temp_test AS SELECT id, exp(value) AS exp_value FROM test_data;
SELECT * FROM temp_test WHERE exp_value ILIKE '1.0%';