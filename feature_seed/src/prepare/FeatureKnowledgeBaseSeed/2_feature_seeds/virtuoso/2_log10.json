CREATE TABLE geometries (id INT PRIMARY KEY, geom GEOMETRY, attr FLOAT);
INSERT INTO geometries VALUES (1, ST_GeomFromText('POINT(1 1)'), 0.5), (2, ST_GeomFromText('POINT(2 2)'), 0.75), (3, ST_GeomFromText('POINT(3 3)'), NULL);
SELECT id, log10(attr) AS log_attr, bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')) AS distance FROM geometries WHERE log10(attr) IS NOT NULL;
SELECT id, log10(attr) AS log_attr, bif:st_distance(geom, (SELECT ST_GeomFromText('POINT(0 0)')) AS target_geom) AS distance FROM geometries WHERE attr IS NOT NULL AND distance < 3;
SELECT id, COUNT(*) AS count, AVG(log10(COALESCE(attr, 1))) AS avg_log FROM geometries GROUP BY id HAVING avg_log > -0.5;
SELECT id, log10(bif:st_distance(geom, ST_GeomFromText('POINT(0 0)'))) AS log_distance FROM geometries WHERE attr IS NOT NULL ORDER BY log_distance DESC;
CREATE TABLE test_numbers (num VARCHAR(255));
INSERT INTO test_numbers VALUES ('0.513513'), ('-1'), ('NULL'), ('Infinity'), (''), (CAST(NULL AS VARCHAR));
SELECT CONCAT('Log10 of ', num, ' is: ', CAST(log10(CAST(num AS FLOAT)) AS VARCHAR)) FROM test_numbers;
SELECT id, log10(attr) AS log_attr FROM geometries WHERE log10(attr) BETWEEN -1 AND 0 HAVING attr IS NOT NULL ORDER BY log_attr;
INSERT INTO geometries VALUES (4, ST_GeomFromText('POINT(-1 -1)'), 1.5);
SELECT id, log10(ABS(attr)) AS log_abs_attr, bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')) AS distance FROM geometries WHERE distance < (SELECT MAX(bif:st_distance(geom, ST_GeomFromText('POINT(0 0)')) ) FROM geometries);