CREATE TABLE test_files (id INT, filename VARCHAR(255), user_group VARCHAR(100));
INSERT INTO test_files (id, filename, user_group) VALUES (1, 'file1.txt', 'user1');
INSERT INTO test_files (id, filename, user_group) VALUES (2, 'file2.txt', 'group1');
SELECT os_chown(virtuoso_ini_path(), (SELECT user_group FROM test_files WHERE id = 1) || CAST(2 AS VARCHAR), 'group1');
SELECT os_chown(virtuoso_ini_path(), 'non_existent_user', 'non_existent_group');
SELECT os_chown(virtuoso_ini_path(), 'user1', (SELECT user_group FROM test_files WHERE id = (SELECT MAX(id) FROM test_files)));
SELECT os_chown(virtuoso_ini_path(), NULL, (SELECT user_group FROM test_files WHERE id = 2));
SELECT os_chown(virtuoso_ini_path(), 'user1', 1 * 2 * 3);
CREATE TEMPORARY TABLE temp_users (username VARCHAR(50) NOT NULL, user_id INT PRIMARY KEY);
INSERT INTO temp_users (username, user_id) VALUES ('temp_user', 1);
SELECT os_chown(virtuoso_ini_path(), (SELECT MAX(username) FROM temp_users WHERE user_id > 0) || '!', 'temp_group');
SELECT os_chown(virtuoso_ini_path(), 'user1', (SELECT COUNT(*) FROM temp_users) * (SELECT id FROM test_files WHERE id = 1));
SELECT os_chown(virtuoso_ini_path(), 'user' || CAST(MAX(user_id) AS VARCHAR), 'group' || CAST(MIN(user_group) AS VARCHAR)) FROM test_files GROUP BY user_group HAVING COUNT(*) > 0;
SELECT os_chown(virtuoso_ini_path(), 'user1' || 'invalid', 'group1' || CAST(NULL AS VARCHAR));
SELECT os_chown(virtuoso_ini_path(), (SELECT SUBSTRING(user_group, 1, 3) FROM test_files WHERE id = 2), 'group2');
SELECT os_chown(virtuoso_ini_path(), 'user1', (SELECT MAX(NULLIF(user_id, 0)) FROM temp_users));