CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(50), status INT NULL);
INSERT INTO test_table (id, name, status) VALUES (1, 'abc', NULL), (2, 'def', 1), (3, '', 0), (4, 'xyz', 2);
SELECT id, name, status FROM test_table WHERE dbg_printf('Testing status: %d', status) IS NOT NULL AND name LIKE 'a%';
SELECT id FROM test_table WHERE status LIKE dbg_printf('Success: %d', 1);
SELECT id, COUNT(*) OVER (PARTITION BY status) AS count_status FROM test_table WHERE dbg_printf('Count Status: %d', COUNT(*)) IS NOT NULL GROUP BY status HAVING count_status > 1;
SELECT DISTINCT id FROM test_table WHERE dbg_printf('ID: %d', id) IS NOT NULL AND name LIKE '%d';
SELECT t1.id, t1.name, t2.status FROM test_table t1 JOIN (SELECT id, status FROM test_table WHERE status IS NOT NULL) AS t2 ON t1.status = t2.status WHERE t1.name LIKE dbg_printf('Filtering: %s', 'a%');
SELECT id, (dbg_printf('Name Length: %d', LENGTH(name)) IS NOT NULL) AS length_check FROM test_table WHERE name LIKE dbg_printf('Filtered Name: %s', '%');
CREATE TABLE temp_table (temp_id INT, temp_value VARCHAR(100));
INSERT INTO temp_table (temp_id, temp_value) VALUES (1, 'One'), (2, 'Two'), (3, 'Three');
SELECT t1.temp_id, dbg_printf('Temp Value: %s', t1.temp_value) FROM temp_table t1 JOIN test_table t2 ON t1.temp_id = t2.id WHERE t2.name LIKE 'T%';