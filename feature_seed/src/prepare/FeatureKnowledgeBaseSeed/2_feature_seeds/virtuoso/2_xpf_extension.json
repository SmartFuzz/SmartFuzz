CREATE TABLE test_data (id INT, name VARCHAR(50), description VARCHAR(100), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_data (id, name, description) VALUES (1, 'Sample', 'This is a sample description');
INSERT INTO test_data (id, name, description) VALUES (2, 'Test', NULL);
INSERT INTO test_data (id, name, description) VALUES (3, '', '');
INSERT INTO test_data (id, name, description) VALUES (4, 'Another Test', 'This string is very very long to test the boundary conditions of the character limit for this VARCHAR field that we have set up. It should exceed the usual length and help test how the database handles such cases.');
CREATE PROCEDURE DB.DBA.str_concat (in a VARCHAR, in b VARCHAR) { return concat (a, ':', b);
};
CALL xpf_extension('http://example.com/virtuoso/xslt:concat_strings', 'DB.DBA.str_concat');
SELECT name, xpf_extension('http://example.com/virtuoso/xslt:concat_strings', 'DB.DBA.str_concat')(name, description) AS concatenated FROM test_data WHERE isLiteral(description) AND description IS NOT NULL;
SELECT DISTINCT t1.name, t2.description FROM test_data t1 JOIN test_data t2 ON isLiteral(t1.description) AND t1.id != t2.id WHERE LENGTH(t1.description) > 10;
SELECT id, name FROM test_data WHERE (name = '' OR name IS NULL) AND created_at > CURRENT_TIMESTAMP - INTERVAL '1 day' GROUP BY id HAVING COUNT(*) > 1;
SELECT id, name, SUM(CASE WHEN isLiteral(description) THEN 1 ELSE 0 END) AS literal_count FROM test_data GROUP BY name HAVING literal_count > 0 ORDER BY literal_count DESC;