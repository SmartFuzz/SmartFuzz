CREATE TABLE test_table (id INT PRIMARY KEY, xml_data XML, num_value INT, random_seed INT);
INSERT INTO test_table (id, xml_data, num_value, random_seed) VALUES (1, '<root><item>Value1</item><item>Value2</item></root>', 10, 1);
INSERT INTO test_table (id, xml_data, num_value, random_seed) VALUES (2, '<root><item>Value3</item></root>', 20, 2);
SELECT id, xpath_contains(xml_data, '/root/item[fn:substring(., 0, rnd(2))]') AS contains_check FROM test_table WHERE random_seed IS NOT NULL;
SELECT id, num_value, xpath_contains(xml_data, '/root/item[fn:substring(., 0, rnd(num_value))]') AS extracted_value FROM test_table WHERE num_value >= rnd(30);
WITH RandomData AS (SELECT id, rnd(10) as random_number, xml_data FROM test_table) SELECT id, random_number, xpath_contains(xml_data, '/root/item') FROM RandomData WHERE random_number BETWEEN 0 AND num_value;
SELECT id, num_value, avg(rnd(10)) OVER (PARTITION BY id) AS avg_random FROM test_table WHERE num_value IS NOT NULL GROUP BY id, num_value HAVING avg_random < 5;
SELECT t1.id, xpath_contains(t1.xml_data, '/root/item[fn:substring(., 0, rnd(3))]') AS item_check FROM test_table t1 JOIN test_table t2 ON t1.random_seed = t2.random_seed WHERE t1.num_value IS NULL AND t2.num_value IS NOT NULL;
SELECT COUNT(*) FROM test_table WHERE xpath_contains(xml_data, '/root/item[fn:substring(., 0, rnd(num_value))]') AND num_value IS NOT NULL;
CREATE TEMPORARY TABLE temp_test AS SELECT id, xpath_contains(xml_data, '/root/item') AS temp_check FROM test_table WHERE num_value > rnd(15);