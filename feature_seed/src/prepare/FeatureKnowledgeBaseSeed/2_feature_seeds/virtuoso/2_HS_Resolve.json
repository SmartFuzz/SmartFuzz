CREATE TABLE articles (id INT PRIMARY KEY, doi VARCHAR(255), title VARCHAR(255) NOT NULL);
INSERT INTO articles (id, doi, title) VALUES (1, '10.1038/35057062', 'Article 1');
INSERT INTO articles (id, doi, title) VALUES (2, '10.1234/example', 'Article 2');
SELECT HS_Resolve(doi || ' - ' || title) AS full_url FROM articles;
SELECT id, HS_Resolve(doi) || ' - ' || title AS resolved_title FROM articles WHERE id IN (SELECT id FROM articles WHERE doi IS NOT NULL);
SELECT id, COUNT(*) AS count, HS_Resolve(MIN(doi)) || ' | ' || MAX(title) AS resolved_info FROM articles GROUP BY doi HAVING COUNT(*) > 1;
SELECT a.id, b.doi, HS_Resolve(a.doi || b.doi) AS combined_url FROM articles a JOIN articles b ON a.id <> b.id;
SELECT id, json_agg(HS_Resolve(doi) || '') AS resolved_dois FROM articles GROUP BY id HAVING id IS NOT NULL;
CREATE TABLE authors (author_id INT PRIMARY KEY, name VARCHAR(255) NOT NULL, article_id INT REFERENCES articles(id));
INSERT INTO authors (author_id, name, article_id) VALUES (1, 'Author One', 1);
INSERT INTO authors (author_id, name, article_id) VALUES (NULL, 'Author Two', 2);
SELECT a.author_id, HS_Resolve(a.name || ' - DOI: ' || b.doi) AS author_info FROM authors a LEFT JOIN articles b ON a.article_id = b.id WHERE a.author_id IS NOT NULL;
UPDATE articles SET doi = NULL WHERE id = 1;
SELECT 'DOI: ' || HS_Resolve(COALESCE(doi, '10.0/invalid')) AS resolved_doi FROM articles;
CREATE TABLE temp_urls AS SELECT HS_Resolve(doi) AS temp_url FROM articles WHERE doi IS NOT NULL;
SELECT id, HS_Resolve(doi) || ' (' || TRIM(title) || ')' AS complete_info FROM articles ORDER BY RANDOM();