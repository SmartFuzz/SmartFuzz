CREATE PROCEDURE complex_test() { DECLARE temp VARCHAR;
SET temp := (SELECT vol_id FROM volume_data WHERE status = 'available' AND isLiteral(vol_id));
IF temp IS NOT NULL THEN DB.DBA.AMAZON_DELETE_VOLUME('AKIAJI7ZL427TI5EDF5A', temp, 'CGI/UMaXf2LRUctaj/HGJ57UNy/t7fNCshh8wpJg');
