SELECT vol_id FROM volume_data WHERE vol_id = (SELECT vol_id FROM volume_data WHERE status = 'in-use') AND isLiteral(vol_id) GROUP BY vol_id HAVING COUNT(vol_id) > 0;
DELETE FROM volume_data WHERE vol_id IN (SELECT vol_id FROM volume_data WHERE status IS NULL AND LENGTH(vol_id) > 0) AND isLiteral(vol_id);
UPDATE volume_data SET status = 'available' WHERE vol_id = 'vol-1a2b3c4d' AND isLiteral(vol_id);
SELECT COUNT(vol_id) OVER (PARTITION BY status) AS volume_count FROM volume_data WHERE isLiteral(vol_id) OR vol_id IS NULL;
CREATE TEMPORARY TABLE temp_volumes AS SELECT vol_id FROM volume_data WHERE status = 'available';
SELECT MAX(CASE WHEN status = 'available' THEN vol_id ELSE NULL END) FROM volume_data WHERE isLiteral(vol_id) GROUP BY status HAVING COUNT(*) > 0;