CREATE TABLE spatial_data (id INT PRIMARY KEY, location GEOGRAPHY, value NUMERIC);
INSERT INTO spatial_data (id, location, value) VALUES (1, ST_GeomFromText('POINT(1 1)', 4326), 10.5);
INSERT INTO spatial_data (id, location, value) VALUES (2, ST_GeomFromText('POINT(2 2)', 4326), 20.0);
INSERT INTO spatial_data (id, location, value) VALUES (3, NULL, NULL);
SELECT sparql_to_sql_text('SELECT * WHERE { ?s ?p ?o } WHERE bif:st_within(?s, ST_GeomFromText("POLYGON((1 1, 1 2, 2 2, 2 1, 1 1))"))');
SELECT id, value FROM spatial_data WHERE location IS NOT NULL AND value > 0;
SELECT id, value, bif:st_within(location, ST_GeomFromText('POLYGON((0 0, 0 3, 3 3, 3 0, 0 0))', 4326)) AS is_within FROM spatial_data;
SELECT id, value FROM spatial_data WHERE id IN (SELECT id FROM spatial_data WHERE value IS NULL);
SELECT COUNT(*), AVG(value) FROM spatial_data GROUP BY bif:st_within(location, ST_GeomFromText('POLYGON((1 1, 2 1, 2 2, 1 2, 1 1))'));
UPDATE spatial_data SET value = 0 WHERE value IS NULL;
SELECT id, sparql_to_sql_text('SELECT ?s WHERE { ?s ?p ?o }') FROM spatial_data LIMIT 10;