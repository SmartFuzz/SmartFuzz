CREATE TABLE Categories (ID INT PRIMARY KEY, Description LONG VARCHAR);
INSERT INTO Categories (ID, Description) VALUES (1, 'Soft drinks, coffees, teas'), (2, 'Sweet and savory sauces, relishes'), (3, 'Desserts, candies, and sweet breads');
SELECT string_output_string(blob_to_string_output(CONCAT(Description, ' - Value: ', 10 / 2))) AS Output FROM Categories WHERE ID < 4;
SELECT string_output_string(blob_to_string_output(Description)) AS Output FROM Categories WHERE string_output_string(blob_to_string_output(Description)) IS NOT NULL;
SELECT COUNT(*) AS Total, string_output_string(blob_to_string_output(Description)) AS Output FROM Categories GROUP BY Output HAVING COUNT(*) > 1;
WITH RankedCategories AS (SELECT Description, ROW_NUMBER() OVER (ORDER BY string_output_string(blob_to_string_output(Description))) AS Rank FROM Categories) SELECT string_output_string(blob_to_string_output(Description)) FROM RankedCategories WHERE Rank <= 2;
CREATE TABLE TestValues (Value1 LONG VARCHAR, Value2 LONG VARCHAR);
INSERT INTO TestValues (Value1, Value2) VALUES ('5', '10'), ('15', NULL), (NULL, '25');
SELECT string_output_string(blob_to_string_output(Value1)) || ' divided by ' || string_output_string(blob_to_string_output(Value2)) AS Calculation FROM TestValues WHERE Value1 IS NOT NULL AND Value2 IS NOT NULL;
SELECT string_output_string(blob_to_string_output('Total of: ' || (SELECT COUNT(*) FROM Categories))) AS TotalOutput;