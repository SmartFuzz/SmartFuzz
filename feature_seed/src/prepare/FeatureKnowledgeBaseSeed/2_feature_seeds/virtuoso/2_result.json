CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(255), value DECIMAL(10,2), created_at TIMESTAMP);
INSERT INTO test_table (id, name, value, created_at) VALUES (1, 'test_one', 123.45, '2023-01-01 10:00:00'), (2, 'test_two', NULL, '2023-01-02 11:00:00'), (3, 'test_three', 678.90, '2023-01-03 12:00:00');
CREATE PROCEDURE fuzz_test (IN I INTEGER)
{
  DECLARE CONCAT_NAME VARCHAR;
RESULT_NAMES (I, CONCAT_NAME);
RESULT (I, 'Record: ' || name) FROM (SELECT name FROM test_table WHERE id = I);
RESULT (I + 1, NULL);
END_RESULT ();
RESULT (I, 'First Record: ' || (SELECT name || ' has value: ' || COALESCE(value, 'Unknown') FROM test_table WHERE id = I));
RESULT (I + 1, 'Second Record: ' || (SELECT name || ' has value: ' || COALESCE(value, 'Unknown') FROM test_table WHERE id = I + 1));
RESULT (I + 2, 'Third Record: ' || (SELECT name || ' has value: ' || COALESCE(value, 'Unknown') FROM test_table WHERE id = I + 2));
RETURN 1;
};
SELECT id || ': ' || name AS record_info FROM test_table WHERE value IS NULL OR created_at > '2023-01-01';
SELECT id, name, value, COUNT(*) OVER (PARTITION BY value) AS value_count FROM test_table WHERE value IS NOT NULL ORDER BY value_count DESC;
SELECT id, 'Concat: ' || name AS full_description FROM test_table WHERE EXISTS (SELECT 1 FROM test_table WHERE value > 500) AND NOT (value IS NULL);
CREATE TABLE another_table (related_id INTEGER, description VARCHAR(255), CONSTRAINT fk_related FOREIGN KEY(related_id) REFERENCES test_table(id));
INSERT INTO another_table (related_id, description) VALUES (1, 'Description One'), (2, 'Description Two', (SELECT name FROM test_table WHERE id = 1)), (3, 'Description Three');
SELECT a.related_id, a.description || ' linked to ' || (SELECT name FROM test_table WHERE id = a.related_id) AS linked_info FROM another_table a WHERE related_id IN (SELECT id FROM test_table WHERE value IS NOT NULL);
CALL fuzz_test(1);