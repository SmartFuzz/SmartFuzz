CREATE TABLE test_table (id INTEGER PRIMARY KEY, value VARCHAR(50), timestamp_column TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, value) VALUES (1, 'first'), (2, 'second'), (3, NULL), (4, 'third');
CREATE PROCEDURE check_delay (IN _val INTEGER) BEGIN IF (_val <> 0) THEN delay(_val);
END IF;
END;
SELECT id, value, EXISTS (SELECT 1 FROM test_table WHERE value IS NOT NULL AND id <> 1) AS check_value, delay(2) FROM test_table WHERE id <> 4;
SELECT id, value, delay(3), COUNT(value) OVER (PARTITION BY value) FROM test_table GROUP BY id, value HAVING delay(COUNT(value)) <> 1;
SELECT A.id, A.value FROM test_table AS A JOIN test_table AS B ON A.id <> B.id WHERE delay(1) IS NOT NULL;
CREATE TEMPORARY TABLE temp_table AS SELECT id, value, delay(0) AS sleep_time FROM test_table WHERE value IS NOT NULL;
SELECT COUNT(*) FROM temp_table HAVING delay(1) <> 0;
SELECT id, delay(2) AS suspend_time FROM test_table WHERE id = (SELECT MAX(id) FROM test_table WHERE value <> 'first' AND delay(1) <> 0);