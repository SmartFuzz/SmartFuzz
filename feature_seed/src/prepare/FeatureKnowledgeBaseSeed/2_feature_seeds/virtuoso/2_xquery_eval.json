CREATE TABLE xml_data (id INT PRIMARY KEY, xt_text NVARCHAR(MAX));
INSERT INTO xml_data VALUES (1, '<library><book><author>John Doe</author><title>Introduction</title></book></library>');
INSERT INTO xml_data VALUES (2, '<library><book><author>Jane Smith</author><title>Advanced Topics</title></book></library>');
SELECT xt_text, xquery_eval('<authors>//author</authors>', xt_text) FROM xml_data WHERE xquery_eval('<books count="1"><book><title>Introduction</title></book></books>', xt_text) IS NOT NULL;
SELECT id, xquery_eval('<titles>{for $b in //book return $b/title}</titles>', xt_text) AS titles FROM xml_data WHERE (SELECT COUNT(*) FROM xml_data WHERE xt_text LIKE '%John%') <= 1;
SELECT xt_text, AVG(LEN(xquery_eval('<authors>{//author/text()}</authors>', xt_text))) AS avg_length FROM xml_data GROUP BY xt_text HAVING AVG(LEN(xquery_eval('<authors>{//author/text()}</authors>', xt_text))) <= 20;
SELECT xt_text FROM xml_data WHERE xquery_eval('<author>exists</author>', xt_text) IS NOT NULL AND (SELECT COUNT(*) FROM xml_data WHERE xt_text IS NOT NULL) <= 2;
SELECT xquery_eval('<titles>{for $t in //book/title return $t/text()}</titles>', xt_text) FROM xml_data ORDER BY LEN(xquery_eval('<titles>{for $t in //book/title return $t/text()}</titles>', xt_text)) DESC;
CREATE TABLE temp_data (id INT PRIMARY KEY, context_data NCLOB);
INSERT INTO temp_data VALUES (1, '<root><item>data1</item></root>');
INSERT INTO temp_data VALUES (2, '<root><item>data2</item></root>');
SELECT xquery_eval('<items>{for $i in //item return $i/text()}</items>', context_data) FROM temp_data WHERE id <= (SELECT MAX(id) FROM temp_data) AND context_data IS NOT NULL;