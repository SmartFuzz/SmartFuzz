CREATE TABLE books (id INT PRIMARY KEY, title VARCHAR(255), author VARCHAR(100), published_date DATE, price DECIMAL(10,2), description TEXT);
INSERT INTO books (id, title, author, published_date, price, description) VALUES (1, 'Introduction to SQL', 'Alice Smith', '2022-01-15', 29.99, NULL);
INSERT INTO books (id, title, author, published_date, price, description) VALUES (2, 'Advanced SPARQL', 'Bob Johnson', NULL, 39.95, 'An in-depth look at SPARQL.');
INSERT INTO books (id, title, author, published_date, price, description) VALUES (3, 'Understanding Data Types', 'Charlie Brown', '2023-02-28', NULL, 'Explore different data types and their implications.');
SELECT DB.DBA.SPARQL_EVAL_TO_ARRAY('SELECT ?s ?p ?o WHERE { ?s ?p ?o . FILTER(isLiteral(?o)) }','http://example/bookStore', 1) AS results;
SELECT DB.DBA.SPARQL_EVAL_TO_ARRAY('SELECT ?title WHERE { ?s <http://example.org/title> ?title }','http://example/bookStore', 2) FROM books WHERE price IS NOT NULL;
SELECT b.title, COUNT(*) AS total FROM books b LEFT JOIN DB.DBA.SPARQL_EVAL_TO_ARRAY('SELECT ?author WHERE { ?s <http://example.org/author> ?author }','http://example/bookStore', 2) AS authors ON b.author = authors[0] GROUP BY b.title HAVING total > 0;
SELECT * FROM (SELECT title, isLiteral(description) AS is_desc_literal FROM books) AS sub WHERE is_desc_literal = TRUE;
SELECT title FROM books WHERE id IN (SELECT id FROM books WHERE price IS NULL) AND title NOT IN (SELECT title FROM books WHERE description IS NOT NULL);
SELECT * FROM (SELECT title, price FROM books ORDER BY price DESC LIMIT 5 OFFSET 2) AS top_books WHERE price > (SELECT AVG(price) FROM books);
SELECT DB.DBA.SPARQL_EVAL_TO_ARRAY('SELECT ?o WHERE { ?s <http://example.org/price> ?o }','http://example/bookStore', 2) AS prices WHERE isLiteral(prices);