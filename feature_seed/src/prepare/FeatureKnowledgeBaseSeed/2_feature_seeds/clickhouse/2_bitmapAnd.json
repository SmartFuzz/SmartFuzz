CREATE TABLE test_table (id UInt32, bitmap_col Array(UInt32), value_date Date, nullable_col Nullable(String));
INSERT INTO test_table VALUES (1, [1,2,3], '2023-10-01', NULL), (2, [3,4,5], '2023-10-02', 'Value 2'), (3, [6,7,8], '2023-10-03', 'Value 3');
CREATE TABLE temp_table AS SELECT id, bitmapToArray(bitmapAnd(bitmapBuild(bitmap_col), bitmapBuild([3,4,5]))) AS result_bitmap FROM test_table;
SELECT id, result_bitmap, tupleElement((SELECT bitmapAnd(bitmapBuild(bitmap_col), bitmapBuild([1,3])), 1) AS tuple_result FROM temp_table) AS first_elem FROM temp_table;
SELECT id, bitmapToArray(bitmapAnd(bitmapBuild(bitmap_col), (SELECT bitmapBuild([5,6,7]) WHERE id = 1))) AS combined_bitmap FROM test_table WHERE value_date = '2023-10-01' HAVING count(id) = 1;
SELECT id, bitmapToArray(bitmapAnd(bitmapBuild(bitmap_col), (SELECT bitmapBuild([3,4]) WHERE id = 1))) AS combined_bitmap FROM test_table GROUP BY id HAVING count(if(nullable_col IS NULL, 1, NULL)) = 1;
SELECT id, bitmapToArray(bitmapAnd((SELECT bitmapBuild([1,2]) WHERE value_date < '2023-10-04'), bitmapAnd(bitmapBuild(bitmap_col), (SELECT bitmapBuild([4,5,6]))))) AS dual_combined FROM test_table;
SELECT bitmapToArray(bitmapAnd(bitmapBuild(bitmap_col), (SELECT bitmapBuild([])))) AS empty_case FROM test_table;
ALTER TABLE test_table ADD COLUMN new_col Nullable(Int32);
INSERT INTO test_table (id, bitmap_col, value_date, nullable_col, new_col) VALUES (4, [1,2,3], '2023-10-01', 'Value 4', NULL);
SELECT id, tupleElement((SELECT bitmapAnd(bitmapBuild((SELECT arrayMap(x -> x * 2, bitmap_col))), bitmapBuild([6,7,8]))), 1) AS processed_bitmap FROM test_table WHERE nullable_col IS NOT NULL;