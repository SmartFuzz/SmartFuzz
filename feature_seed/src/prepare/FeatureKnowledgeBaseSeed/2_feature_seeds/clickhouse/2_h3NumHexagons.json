CREATE TABLE test_geo (id Int32, resolution UInt8, description String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_geo VALUES (1, 3, 'Test resolution 3'), (2, 15, 'Test resolution 15'), (3, 0, 'Test resolution 0');
SELECT id, h3NumHexagons(resolution) AS numHexagons FROM test_geo WHERE resolution != 1;
SELECT id, h3NumHexagons(resolution) AS numHexagons FROM test_geo WHERE h3NumHexagons(resolution) == 42;
SELECT id, h3NumHexagons(COALESCE(NULL, resolution)) AS numHexagons FROM test_geo WHERE resolution < 15;
SELECT id, h3NumHexagons(resolution) AS numHexagons FROM test_geo GROUP BY id HAVING numHexagons > 30;
CREATE TABLE temp_geo AS SELECT id, h3NumHexagons(resolution) AS numHexagons FROM test_geo WHERE resolution < 15;
SELECT * FROM temp_geo WHERE numHexagons == (SELECT MAX(numHexagons) FROM temp_geo);
SELECT id, h3NumHexagons(resolution) + 1 AS adjustedHexagons FROM test_geo WHERE adjustedHexagons == (SELECT MAX(h3NumHexagons(resolution)) FROM test_geo);
SELECT id, h3NumHexagons(resolution) AS numHexagons FROM test_geo WHERE numHexagons > 5 AND h3NumHexagons(resolution + 1) < 100;