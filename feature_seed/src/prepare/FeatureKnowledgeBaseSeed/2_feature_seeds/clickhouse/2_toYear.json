CREATE TABLE test_dates (id UInt32, event_time DateTime, event_date Date);
INSERT INTO test_dates (id, event_time, event_date) VALUES (1, toDateTime('2023-01-01 00:00:00'), toDate('2023-01-01'));
INSERT INTO test_dates (id, event_time, event_date) VALUES (2, toDateTime('2022-12-31 23:59:59'), NULL);
INSERT INTO test_dates (id, event_time, event_date) VALUES (3, toDateTime('2022-01-15 12:00:00'), toDate('2022-01-15'));
SELECT id, toYear(event_time) AS event_year, event_time + INTERVAL 1 DAY AS event_next_day FROM test_dates WHERE event_date IS NOT NULL;
SELECT id, COUNT(*) AS event_count, toYear(event_time) AS event_year FROM test_dates GROUP BY event_year HAVING event_count > 1;
SELECT id, event_time, toYear(event_time + INTERVAL 3 MONTH) AS future_year FROM test_dates WHERE event_time < now() - INTERVAL 1 YEAR ORDER BY future_year ASC;
SELECT id, event_time, event_date, toYear(IFNULL(event_date, event_time)) AS year FROM test_dates;
CREATE TABLE temp_dates AS SELECT id, event_time + INTERVAL 4 DAY AS new_event_time FROM test_dates;
SELECT id, new_event_time, toYear(new_event_time) AS adjusted_year FROM temp_dates WHERE new_event_time > toDateTime('2023-01-05 00:00:00');
SELECT A.id, A.event_time FROM test_dates AS A JOIN (SELECT id, event_time FROM test_dates WHERE event_date IS NULL) AS B ON A.id = B.id;