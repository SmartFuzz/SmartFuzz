CREATE TABLE test_data (id Int32, value String, amount String, description String DEFAULT 'No Description');
INSERT INTO test_data (id, value, amount) VALUES (1, '10.5', '100'), (2, 'abc', '20'), (3, '32768', '0'), (4, 'inf', '30'), (5, '0xc0fe', '50');
SELECT id, toInt16OrZero(value) AS converted_value, amount, toInt16OrZero(amount) AS converted_amount FROM test_data;
SELECT id, CASE WHEN toInt16OrZero(value) < 0 THEN 'Negative' ELSE 'Non-Negative' END AS value_sign FROM test_data;
SELECT t1.id, toInt16OrZero(t1.value) - toInt16OrZero(t2.amount) AS balance FROM test_data AS t1 JOIN test_data AS t2 ON t1.id = t2.id WHERE toInt16OrZero(amount) > 0;
SELECT id, value, amount FROM test_data WHERE toInt16OrZero(value) IS NOT NULL AND amount IS NOT NULL;
SELECT id, AVG(toInt16OrZero(amount)) AS avg_amount FROM test_data GROUP BY id HAVING avg_amount > 0;
SELECT t.id, t.value, (toInt16OrZero(t.value) - toInt16OrZero(t.amount)) AS result FROM (SELECT id, value, amount FROM test_data) AS t;
SELECT id, toInt16OrZero(value) AS value_converted, COALESCE(NULLIF(amount, '0'), '1') AS fallback_amount FROM test_data;
SELECT id, toInt16OrZero(value) - toInt16OrZero(COALESCE(NULLIF(amount, ''), '0')) AS adjusted_value FROM test_data;
SELECT * FROM (SELECT id, toInt16OrZero(value) AS int_value FROM test_data WHERE toInt16OrZero(value) > 0) AS subquery WHERE int_value = (SELECT MAX(toInt16OrZero(value)) FROM test_data);