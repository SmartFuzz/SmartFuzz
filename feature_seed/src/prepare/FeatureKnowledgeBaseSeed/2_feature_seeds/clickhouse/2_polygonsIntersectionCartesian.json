CREATE TABLE test_polygons (id UInt32, geom String);
INSERT INTO test_polygons VALUES (1, 'POLYGON(((0 0),(0 3),(1 2.9),(2 2.6),(2.6 2),(2.9 1),(3 0),(0 0)))'), (2, 'POLYGON(((1 1),(1 4),(4 4),(4 1),(1 1)))');
SELECT wkt(polygonsIntersectionCartesian(geom, (SELECT geom FROM test_polygons WHERE id = 2))) AS intersection FROM test_polygons WHERE id = 1;
SELECT id, geom, wkt(polygonsIntersectionCartesian(geom, wkt(polygonsIntersectionCartesian(geom, 'POLYGON(((2 2),(0 0),(0 2),(2 0),(2 2)))')))) AS nested_intersection FROM test_polygons;
SELECT id FROM test_polygons WHERE id GLOBAL IN (SELECT id FROM test_polygons WHERE id > 0) AND geom IS NOT NULL;
SELECT wkt(polygonsIntersectionCartesian(geom, 'POLYGONEMPTY')) AS empty_intersection FROM test_polygons HAVING intersection IS NOT NULL;
SELECT COUNT(*) FROM (SELECT wkt(polygonsIntersectionCartesian(geom, 'POLYGON(((0.1 0.1),(0.1 2.1),(2.1 2.1),(2.1 0.1),(0.1 0.1)))')) AS intersection FROM test_polygons) AS subquery;
CREATE TABLE temp_polygon_test (id UInt32, value Float64 DEFAULT 0, geom String, created_at DateTime DEFAULT now());
INSERT INTO temp_polygon_test VALUES (1, NULL, 'POLYGON(((0 0),(0 2),(2 2),(2 0),(0 0)))'), (2, 1.5, 'POLYGON(((1 1),(1 2),(2 2),(2 1),(1 1)))');
SELECT id, value, wkt(polygonsIntersectionCartesian(geom, 'POLYGON(((0.5 0.5),(0.5 1.5),(1.5 1.5),(1.5 0.5),(0.5 0.5)))')) AS empty_polygon FROM temp_polygon_test WHERE created_at >= '2023-01-01 00:00:00' HAVING COUNT(value) > 0;