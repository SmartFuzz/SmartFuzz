CREATE TABLE test_dates (date_val DateTime, string_val String) ENGINE = Memory;
INSERT INTO test_dates VALUES (toDateTime('2022-02-28 17:30:00'), '123'), (toDateTime('2023-01-01 00:00:01'), 'abc'), (toDateTime('2023-03-31 23:59:59'), 'NaN');
SELECT EXTRACT(MONTH FROM date_val) AS month_val, toInt64OrZero(string_val) AS converted_val FROM test_dates WHERE converted_val > 0 ORDER BY month_val;
SELECT EXTRACT(DAY FROM date_val) AS day_val, toInt64OrZero(string_val), COUNT(*) FROM test_dates GROUP BY day_val, toInt64OrZero(string_val) HAVING day_val > 0;
SELECT EXTRACT(YEAR FROM date_val), toInt64OrZero(string_val) FROM test_dates WHERE string_val = '' OR string_val IS NULL;
SELECT toInt64OrZero(EXTRACT(HOUR FROM date_val) || '') AS hour_val, COUNT(*) FROM test_dates GROUP BY hour_val;
CREATE TABLE temp_table AS SELECT date_val, toInt64OrZero(NULLIF(string_val, '')) AS int_val FROM test_dates WHERE string_val IS NOT NULL;
SELECT EXTRACT(MINUTE FROM date_val), SUM(int_val) FROM temp_table GROUP BY EXTRACT(MINUTE FROM date_val);