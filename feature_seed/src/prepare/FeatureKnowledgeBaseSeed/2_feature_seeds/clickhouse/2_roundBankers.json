CREATE TABLE test_table (id UInt32, values Array(Float64), secondary_value Float64);
INSERT INTO test_table VALUES (1, [1.5, 2.5, 3.5], 4.5), (2, [4.5, 5.5, 6.5], 2.5), (3, [7.5, 8.5, 9.5], NULL);
SELECT id, roundBankers(arrayAvg(values), 1) AS avg_rounded, roundBankers(secondary_value, -1) AS sec_value_rounded FROM test_table;
SELECT id, roundBankers(sum(arrayElement(values, 1)), 0) AS first_element_rounded FROM test_table GROUP BY id HAVING first_element_rounded > 2;
SELECT id, roundBankers(arraySum(values) / NULLIF(count(values), 0), 0) AS adjusted_avg FROM test_table GROUP BY id;
SELECT id, roundBankers(arraySum(values), 0) AS total_rounded, roundBankers(NULLIF(secondary_value, 0), 0) AS sec_value_adjusted FROM test_table WHERE NOT isNull(secondary_value);
SELECT id, arrayMap(x -> roundBankers(x, 1), values) AS rounded_array FROM test_table;
SELECT id, arrayJoin(arrayMap(x -> roundBankers(x, 0), values)) AS rounded_values FROM test_table;
CREATE TABLE test_table_2 (id UInt32, value String);
INSERT INTO test_table_2 VALUES (1, '1.5'), (2, '2.5'), (3, '3.5');
SELECT t1.id, roundBankers(toFloat64(t2.value), 0) AS rounded_value FROM test_table t1 JOIN test_table_2 t2 ON t1.id = t2.id WHERE roundBankers(toFloat64(t2.value), 0) IS NOT NULL;
SELECT id, roundBankers((SELECT AVG(NULLIF(secondary_value, 0)) FROM test_table WHERE id = t.id), 0) AS avg_sec_value FROM test_table t;
SELECT id, arrayJoin(arraySlice(values, 1, 2)) AS sliced_values, roundBankers(arraySum(sliced_values), 0) AS summed FROM test_table GROUP BY id;