CREATE TABLE test_table (id UInt64, value Float64, status String, created_at DateTime, score UInt32 DEFAULT intExp10(0));
INSERT INTO test_table (id, value, status, created_at) VALUES (1, 1.0, 'active', now()), (2, 2.5, 'inactive', now() - INTERVAL 1 DAY), (3, NULL, 'active', now()), (4, 4.5, 'inactive', now() - INTERVAL 2 DAY);
SELECT id, value, intExp10(value) AS exp_value FROM test_table WHERE intExp10(value) >= 100;
WITH (SELECT AVG(value) AS avg_val FROM test_table WHERE status = 'active') AS avg_data SELECT id, value, intExp10(value) AS exp_value FROM test_table WHERE value >= avg_data.avg_val;
SELECT id, value, score FROM test_table WHERE intExp10(value + 1) >= intExp10(NULLIF(value, 0));
CREATE TABLE test_table_2 (ref_id UInt64, ref_value Float64);
INSERT INTO test_table_2 (ref_id, ref_value) VALUES (1, 3.0), (2, 4.0);
SELECT t1.id, t1.value, intExp10(t1.value) AS exp_value FROM test_table t1 JOIN test_table_2 t2 ON t1.id >= t2.ref_id WHERE intExp10(t1.value) >= 1;
SELECT id, value FROM test_table WHERE status IS NOT NULL GROUP BY status HAVING intExp10(MAX(value)) >= 10;
SELECT id, value, score FROM test_table WHERE intExp10(NULLIF(value, 0)) >= (SELECT intExp10(MIN(value)) FROM test_table WHERE status = 'active');