CREATE TABLE test_table (id UInt32, data String, bitData FixedString(10)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'Hello', bitSlice('Hello', 1, 8)), (2, NULL, 'World'), (3, 'Test', bitSlice('Test', -4, 8));
SELECT id, data, bin(bitSlice(data, 1, 8)), tupleElement((SELECT bitSlice(data, -5, 7) FROM test_table WHERE id = 2), 1) AS subquery_result FROM test_table WHERE bitSlice(data, 1, 5) IS NOT NULL;
SELECT id, data, bin(bitSlice(data, 1, 16)) AS bits FROM test_table WHERE id IN (SELECT id FROM test_table WHERE data IS NULL) GROUP BY id, data HAVING length(data) < 10;
SELECT id, data, bin(bitSlice(data, 1, 9)), tupleElement((SELECT bitSlice(data, 1, 3) FROM test_table WHERE data LIKE 'H%'), 1) AS extracted_bits FROM test_table;
SELECT id, bitSlice(bin(bitData), 1, 8) FROM test_table WHERE id NOT IN (SELECT id FROM test_table WHERE data = 'Hello') ORDER BY id DESC;
SELECT tupleElement(bitSlice('BinaryData', -4, 8), 1) AS extracted_bit FROM test_table WHERE id = 1 UNION SELECT id, data FROM test_table WHERE data IS NOT NULL;
SELECT count(*) FROM (SELECT bitSlice(data, 1, 8) AS bits FROM test_table WHERE bitSlice(data, 1, 2) != '00') AS subquery WHERE bits IS NOT NULL;
SELECT id, data, bitSlice(bin(data), -4, 5) AS bits FROM test_table WHERE data != '' ORDER BY tupleElement((SELECT bitSlice(data, 1, 4) FROM test_table WHERE id = 3), 1);
ALTER TABLE test_table ADD COLUMN newColumn UInt32 DEFAULT 0;
INSERT INTO test_table (id, data, bitData) VALUES (4, 'BoundaryTest', bitSlice('BoundaryTest', 1, 16));
SELECT id, bitSlice(data, 1, 10) AS bits, tupleElement((SELECT bitSlice(data, 1, 5) FROM test_table), 1) AS nested_bit FROM test_table WHERE id = 1;