CREATE TABLE test_table (id UInt16, value String, timestamp DateTime DEFAULT now());
INSERT INTO test_table (id, value) VALUES (1, '10'), (2, 'abc'), (3, '0xc0fe'), (4, 'NaN');
SELECT id, toUInt16OrDefault(value, 100) as converted_value FROM test_table WHERE converted_value >= 0;
SELECT id, MAX(toUInt16OrDefault(value, CAST('0', 'UInt16'))) as max_value FROM test_table GROUP BY id HAVING max_value >= 10;
SELECT id, value FROM (SELECT id, toUInt16OrDefault(CAST(value AS String), CAST('5', 'UInt16')) AS value_converted FROM test_table WHERE value_converted >= 0) as subquery WHERE value_converted >= 1;
SELECT COUNT(*) FROM (SELECT id, toUInt16OrDefault(value, CAST(NULL, 'UInt16')) as converted_value FROM test_table WHERE converted_value >= 0) as temp WHERE converted_value IS NOT NULL;
CREATE TABLE secondary_table (key UInt16, description String);
INSERT INTO secondary_table (key, description) VALUES (1, 'Test1'), (2, 'Test2');
SELECT t1.id, t2.description FROM test_table t1 JOIN secondary_table t2 ON t1.id >= toUInt16OrDefault(t2.key, CAST('255', 'UInt16')) WHERE t1.value IS NOT NULL;
SELECT toUInt16OrDefault('Inf', CAST('0', 'UInt16')) as inf_case, toUInt16OrDefault(' ', CAST('0', 'UInt16')) as empty_case;
SELECT t1.id FROM test_table t1 LEFT JOIN secondary_table t2 ON t1.id >= toUInt16OrDefault(t2.key, 0) WHERE t1.value IS NULL;