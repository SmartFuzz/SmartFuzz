CREATE TABLE angles (angle_id UInt32, degrees Float64, description String) ENGINE = MergeTree ORDER BY angle_id;
INSERT INTO angles VALUES (1, 0.0, 'Zero degrees'), (2, 360.0, 'Full circle'), (3, 180.0, 'Straight angle'), (4, -90.5, 'Negative angle');
CREATE TABLE radians_table AS SELECT angle_id, radians(degrees) AS radians_value FROM angles;
SELECT angle_id, radians_value FROM radians_table WHERE radians_value BETWEEN radians(0) AND radians(360);
SELECT angle_id, radians_value FROM radians_table WHERE radians_value IS NULL OR radians_value < 0;
SELECT angle_id, radians_value FROM radians_table GROUP BY angle_id HAVING radians_value > radians(0) AND radians_value < radians(6.28319);
SELECT angle_id, radians(degrees) AS radians_value, (radians(degrees), angle_id) AS angle_tuple FROM angles ORDER BY angle_tuple;
SELECT angle_id FROM (SELECT angle_id, degrees, radians(degrees) AS rad_val FROM angles WHERE rad_val <= radians(180)) AS filtered_angles WHERE angle_id IN (SELECT angle_id FROM radians_table WHERE radians_value IS NOT NULL UNION SELECT angle_id FROM angles WHERE degrees < 0.0);