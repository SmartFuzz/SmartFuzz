CREATE TABLE test_dates (date_field DateTime, value Int32);
INSERT INTO test_dates (date_field, value) VALUES (toDateTime('2023-01-01 00:00:00'), 1), (toDateTime('2023-07-01 12:00:00'), 2), (toDateTime('2023-10-01 18:00:00'), 3), (NULL, 4);
SELECT toRelativeQuarterNum(date_field) AS quarter_num, COUNT(*) FROM test_dates GROUP BY quarter_num HAVING quarter_num < 3;
SELECT (SELECT toRelativeQuarterNum(date_field) FROM test_dates WHERE date_field IS NOT NULL) < (SELECT COUNT(value) FROM test_dates) AS comparison_result;
SELECT value, toRelativeQuarterNum(date_field) AS quarter_num FROM test_dates WHERE toRelativeQuarterNum(date_field) < 2 ORDER BY quarter_num DESC;
SELECT toRelativeQuarterNum(date_field) < 2 AS is_first_half, COUNT(value) FROM test_dates GROUP BY is_first_half;
SELECT toRelativeQuarterNum(toDateTime(date_field)) < 2 AS is_first_quarter, SUM(value) FROM test_dates WHERE date_field IS NOT NULL GROUP BY is_first_quarter HAVING is_first_quarter AND (SUM(value) IS NOT NULL);
CREATE TABLE test_join (id Int32, date_field DateTime, info String);
INSERT INTO test_join (id, date_field, info) VALUES (1, toDateTime('2023-01-01 00:00:00'), 'test1'), (2, toDateTime('2023-04-01 00:00:00'), 'test2'), (3, NULL, 'test3');
SELECT a.info, toRelativeQuarterNum(a.date_field) AS quarter FROM test_dates a JOIN test_join b ON toRelativeQuarterNum(a.date_field) < toRelativeQuarterNum(b.date_field) WHERE b.id IS NOT NULL;
SELECT toRelativeQuarterNum(date_field) FROM (SELECT date_field FROM test_dates WHERE date_field IS NOT NULL ORDER BY date_field DESC LIMIT 1) AS subquery;