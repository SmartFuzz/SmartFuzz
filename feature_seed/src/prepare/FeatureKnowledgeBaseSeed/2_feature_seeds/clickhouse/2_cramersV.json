CREATE TABLE test_table (id UInt32, valueA Float64, valueB String, valueC Int32);
INSERT INTO test_table (id, valueA, valueB, valueC) VALUES (1, 2.5, 'text', NULL), (2, 3.0, 'example', 1), (3, 4.5, 'test', 2), (4, NULL, 'another', 3), (5, 5.0, '', 4);
SELECT cramersV(valueA, valueB NOT IN (SELECT valueB FROM test_table WHERE valueC IS NOT NULL)) FROM (SELECT valueA, valueB, valueC FROM test_table) GROUP BY valueC HAVING valueA > 3.0;
SELECT valueC, cramersV(valueA, valueB) AS association FROM (SELECT valueA, valueB, valueC FROM test_table WHERE valueA IS NOT NULL) WHERE valueB NOT IN (SELECT valueB FROM test_table WHERE valueA < 3.0) GROUP BY valueC HAVING association IS NOT NULL;
SELECT cramersV((SELECT MAX(valueA) FROM test_table), (SELECT MIN(valueB) FROM (SELECT DISTINCT valueB, valueC FROM test_table))) NOT IN (1, 0) AS test_result;