CREATE TABLE test_table (id Int32, value1 Int64, value2 Int64, str_value String, is_active UInt8);
INSERT INTO test_table (id, value1, value2, str_value, is_active) VALUES (1, 5, 10, '20', 1), (2, 0, -1, '', 0), (3, -5, 15, NULL, 1);
SELECT id, lcm(value1, value2) AS lcm_value FROM test_table WHERE is_active = 1 AND lcm(value1, value2) > 0;
SELECT id, (SELECT COUNT(*) FROM test_table t2 WHERE t2.id > t1.id) AS subsequent_count, lcm(value1, value2) AS lcm_value FROM test_table t1 WHERE lcm(value1, value2) IS NOT NULL AND is_active = 1;
SELECT id, lcm(value1, value2) AS lcm_value FROM test_table WHERE is_active = 1 AND lcm(value1, value2) IS NOT NULL AND str_value IS NOT NULL AND str_value != '';
SELECT id, (lcm(value1, value2) AND is_active) AS active_lcm FROM test_table WHERE str_value != '' OR (SELECT MIN(value1) FROM test_table WHERE is_active = 0) < 0;
SELECT id, lcm(T1.value1, T2.value2) AS cross_lcm FROM test_table T1 JOIN test_table T2 ON T1.id != T2.id WHERE T1.is_active = 1 AND (lcm(T1.value1, T1.value2) > 5 AND lcm(T2.value1, T2.value2) < 100);
SELECT MIN(lcm(value1, value2)) AS min_lcm FROM test_table WHERE is_active = 1 GROUP BY id HAVING min_lcm IS NOT NULL;
SELECT id, value1, value2, lcm(value1, value2) AS lcm_value, (SELECT MAX(value1) FROM test_table WHERE is_active = 0) AS max_inactive FROM test_table WHERE value1 < (SELECT MIN(value2) FROM test_table WHERE is_active = 0);