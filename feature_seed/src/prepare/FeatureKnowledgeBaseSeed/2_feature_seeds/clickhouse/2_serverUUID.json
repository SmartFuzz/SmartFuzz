CREATE TABLE test_table (id UUID DEFAULT serverUUID(), name String, age Int32, created_at DateTime DEFAULT now());
INSERT INTO test_table (name, age) VALUES ('Alice', 30), ('Bob', 25), (NULL, 35);
SELECT serverUUID() || ' - ' || name AS combined_name FROM test_table WHERE age IS NOT NULL;
SELECT id, serverUUID() || ' - ' || name AS full_info FROM test_table WHERE created_at > now() - INTERVAL 1 DAY;
CREATE TABLE join_table (user_id UUID, description String);
INSERT INTO join_table (user_id, description) VALUES (serverUUID(), 'Test description 1'), (serverUUID(), NULL);
SELECT t1.id, t1.name, t2.description || ' (' || t1.age || ' years old)' AS user_info FROM test_table AS t1 JOIN join_table AS t2 ON t1.id = t2.user_id;
SELECT COUNT(*) FROM (SELECT serverUUID() AS unique_id, name FROM test_table GROUP BY unique_id, name HAVING age > 28);
WITH (SELECT serverUUID() || ' Info' AS info) AS alias_info SELECT info || ' - CREATED' FROM alias_info;
SELECT serverUUID() || ' - joined - ' || (SELECT COUNT(*) FROM test_table) AS combined_output WHERE name IS NOT NULL;