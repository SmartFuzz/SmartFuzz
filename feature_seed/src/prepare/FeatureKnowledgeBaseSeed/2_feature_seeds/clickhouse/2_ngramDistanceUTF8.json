CREATE TABLE test_ngram (id UInt32, haystack String, needle String);
INSERT INTO test_ngram VALUES (1, 'abcdefg', 'xyz'), (2, 'hello', 'world');
SELECT id, ngramDistanceUTF8(haystack, needle) AS similarity FROM test_ngram WHERE similarity > 0.5;
SELECT id, transform(ngramDistanceUTF8(haystack, needle), [0.0, 0.5, 1.0], [0, 1, 2], 0) AS transformed_similarity FROM test_ngram;
SELECT id, multiIf(ngramDistanceUTF8(haystack, needle) < 0.2, 'Very Different', ngramDistanceUTF8(haystack, needle) < 0.5, 'Different', 'Similar') AS similarity_category FROM test_ngram;
SELECT id, ngramDistanceUTF8(haystack, transform(needle, [NULL, ''], [NULL, 'a'], '')) AS adjusted_similarity FROM test_ngram WHERE adjusted_similarity IS NOT NULL;
SELECT id, ngramDistanceUTF8(haystack, needle) AS similarity FROM (SELECT id, CONCAT(haystack, '') AS haystack, needle FROM test_ngram WHERE haystack NOT LIKE '%abc%');
CREATE TABLE test_ngram_temp AS SELECT id, ngramDistanceUTF8(CONCAT(haystack, RANDOM()), needle) AS random_similarity FROM test_ngram;
SELECT multiIf(random_similarity < 0.1, 'Low', random_similarity < 0.5, 'Medium', 'High') AS similarity_level FROM test_ngram_temp;
CREATE TABLE max_test (num UInt32, text String);
INSERT INTO max_test VALUES (4294967295, 'High value'), (0, 'Zero value');
SELECT ngramDistanceUTF8(text, 'High value') AS high_value_similarity FROM max_test WHERE num = 4294967295;
SELECT NULLIF(ngramDistanceUTF8(text, '') * 100, 0) AS similarity_percentage FROM max_test WHERE text IS NOT NULL;