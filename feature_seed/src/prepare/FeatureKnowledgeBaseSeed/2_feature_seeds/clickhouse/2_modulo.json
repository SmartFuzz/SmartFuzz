CREATE TABLE test_table (id Int32, value1 Float64, value2 Int32, str_value String);
INSERT INTO test_table VALUES (1, 3.5, 2, 'test'), (2, -2.5, -1, 'edge case'), (3, 0.0, 0, 'boundary');
SELECT id, modulo(value1, value2) AS remainder FROM test_table WHERE remainder > 0;
SELECT id, value1, value2, modulo(value1, value2) AS remainder FROM test_table WHERE value1 > value2;
WITH (SELECT id, modulo(value1, value2) AS sub_remainder FROM test_table) AS subquery SELECT id FROM subquery WHERE sub_remainder IS NOT NULL;
SELECT id, CAST(modulo(CAST(str_value AS Int32), value2) AS Float64) AS division FROM test_table WHERE value2 != 0;
SELECT id, IF(modulo(value2, 1) = 0, 'Integer', 'Not Integer') AS type FROM test_table;
SELECT id, value1, modulo(value1, (SELECT AVG(value2) FROM test_table)) AS avg_remainder FROM test_table GROUP BY id, value1 HAVING avg_remainder > 0;
CREATE TABLE secondary_table (group_id Int32, group_value Int32);
INSERT INTO secondary_table VALUES (1, 10), (1, 20), (2, 25);
SELECT t.id, t.value1, s.group_value FROM test_table t JOIN secondary_table s ON modulo(t.value2, s.group_value) > 5;
CREATE TABLE aggregate_table (agg_id Int32, fixed_value Float64) ENGINE = MergeTree() ORDER BY agg_id;
INSERT INTO aggregate_table VALUES (1, 1.5), (1, 3.2), (1, NULL), (2, 4.0);
SELECT agg_id, SUM(IF(fixed_value IS NULL, 0, fixed_value)) AS total FROM aggregate_table GROUP BY agg_id HAVING total > 0;
WITH (SELECT id, modulo(value1, value2) AS calculated_mod FROM test_table WHERE value2 <> 0) SELECT id, calculated_mod FROM calculated_mod WHERE calculated_mod IS NOT NULL;