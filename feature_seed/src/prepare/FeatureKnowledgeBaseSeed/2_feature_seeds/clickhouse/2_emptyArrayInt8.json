CREATE TABLE test_table (id Int32, data String, nums Array(Int8));
INSERT INTO test_table (id, data, nums) VALUES (1, 'test', [1, 2, 3]), (2, 'example', emptyArrayInt8());
SELECT id, data || CAST(nums AS String) AS combined FROM test_table WHERE emptyArrayInt8() || data = '';
SELECT id, (data || ' extended') AS modified_data FROM test_table WHERE arrayJoin(nums) IN (SELECT number FROM system.numbers LIMIT 10);
SELECT id, SUM(arrayJoin(nums)) || ' total' AS total_string FROM test_table GROUP BY id HAVING total_string LIKE '%total';
CREATE TABLE another_table (ref_id Int32, value Nullable(String));
INSERT INTO another_table (ref_id, value) VALUES (1, NULL), (2, 'data');
SELECT a.ref_id, a.value || ' updated' AS updated_value FROM another_table AS a JOIN test_table AS b ON a.ref_id = b.id WHERE a.value IS NULL OR emptyArrayInt8() = [] ORDER BY updated_value;
SELECT id, emptyArrayInt8() || (data || CAST(NULL AS String)) AS concat_result FROM test_table WHERE concat_result LIKE '%NULL%';
SELECT id, COUNT(*) OVER (PARTITION BY id) AS count_per_id FROM test_table WHERE nums = emptyArrayInt8();
SELECT a.id, (a.data || CAST(ARRAY_LENGTH(a.nums) AS String)) AS length_string FROM test_table AS a WHERE a.nums = emptyArrayInt8() OR a.nums IS NOT NULL ORDER BY length_string DESC;