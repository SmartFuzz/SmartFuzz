CREATE TABLE geo_data (index UInt64, description String) ENGINE = MergeTree() ORDER BY index;
INSERT INTO geo_data VALUES (617420388352917503, 'Point A'), (617420388352917504, NULL), (617420388352917505, 'Point C');
SELECT h3ToString(index) AS h3_string FROM geo_data WHERE index != ANY (SELECT index FROM geo_data WHERE description IS NOT NULL) ORDER BY h3_string;
SELECT h3ToString(index) AS h3_string FROM geo_data GROUP BY h3_string HAVING h3_string != ANY (SELECT h3ToString(index) FROM geo_data WHERE description LIKE 'Point%') ORDER BY h3_string;
SELECT h3ToString(index) AS h3_string FROM geo_data WHERE index != ANY (SELECT index FROM (SELECT index FROM geo_data WHERE description IS NULL)) OR h3_string = 'NULL';
CREATE TABLE alt_geo_data (index UInt64, value Null(UInt64)) ENGINE = MergeTree() ORDER BY index;
INSERT INTO alt_geo_data VALUES (617420388352917503, NULL), (617420388352917504, 617420388352917505);
SELECT h3ToString(index) AS h3_string FROM alt_geo_data WHERE index != ANY (SELECT index FROM alt_geo_data WHERE value IS NOT NULL) OR h3_string IS NULL ORDER BY h3_string;
SELECT h3ToString(index) AS h3_string FROM alt_geo_data WHERE index != ANY (SELECT index FROM alt_geo_data WHERE value IS NOT NULL AND index = 617420388352917504) OR index > 617420388352917505;
CREATE TABLE temp_geo (index UInt64, description String) ENGINE = MergeTree() ORDER BY index;
INSERT INTO temp_geo VALUES (617420388352917503, 'Test A'), (617420388352917504, 'Test B'), (617420388352917505, 'Test C');
SELECT h3ToString(index) AS h3_string FROM temp_geo WHERE h3_string != ANY (SELECT h3ToString(index) FROM temp_geo WHERE description = 'Test B') AND index <= 617420388352917505 ORDER BY h3_string;