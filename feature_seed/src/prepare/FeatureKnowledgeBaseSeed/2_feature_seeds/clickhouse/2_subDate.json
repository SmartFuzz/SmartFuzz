CREATE TABLE test_dates (id UInt32, dt DateTime, val Float64, description String);
INSERT INTO test_dates VALUES (1, '2023-10-01 00:00:00', 100.5, 'Initial Entry'), (2, '2020-01-01 12:00:00', 200.0, 'Edge Case Entry');
SELECT id, subDate(dt, INTERVAL (val % 3) DAY) AS modified_date FROM test_dates WHERE modified_date < toDateTime('2021-01-01 00:00:00') AND description IS NOT NULL;
SELECT id, (subDate(dt, INTERVAL 1 MONTH) % 2) AS mod_result FROM test_dates HAVING mod_result > 0;
SELECT id, val, subDate(dt, INTERVAL (val % 5) DAY) AS new_date FROM test_dates WHERE new_date IS NOT NULL ORDER BY new_date DESC;
CREATE TABLE temp_dates AS SELECT *, subDate(dt, INTERVAL (id % 10) YEAR) AS adjusted_date FROM test_dates;
SELECT COUNT(*) FROM temp_dates WHERE adjusted_date IS NOT NULL GROUP BY adjusted_date HAVING COUNT(*) > 0;
INSERT INTO test_dates SELECT id + 10, subDate(toDateTime('2023-01-01'), INTERVAL (val % 7) DAY), val + 50, description FROM test_dates;
SELECT dt, subDate(dt, INTERVAL (val % 3) HOUR) FROM (SELECT dt, val FROM test_dates WHERE val < 300) AS subquery;
DROP TABLE IF EXISTS temp_dates;