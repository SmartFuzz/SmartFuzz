CREATE TABLE colors (id UInt32, color String, nullable_color Nullable(String));
INSERT INTO colors VALUES (1, 'red', NULL), (2, 'green', 'light-green'), (3, 'blue', 'light-blue'), (4, '', 'light-yellow');
SELECT id, groupArraySample(2)(color) AS sampled_colors FROM colors WHERE color IS NOT NULL GROUP BY id;
SELECT id, groupArraySample(3, 98765432)(nullable_color) AS sampled_nullable_colors FROM colors WHERE nullable_color IS NOT NULL GROUP BY id;
SELECT DISTINCT id FROM (SELECT id, groupArraySample(2)(color) AS sampled_colors FROM colors WHERE color IS NOT NULL GROUP BY id HAVING sampled_colors[1] IS NOT NULL);
SELECT id, groupArraySample(5)(color) AS sampled_colors FROM (SELECT color, id FROM colors WHERE color = concat('', 'red') OR color IS NULL) GROUP BY id HAVING groupArraySample(1)(color) IS NOT NULL;
SELECT id, groupArraySample(3)(CAST(nullable_color AS String)) AS sampled_colors FROM colors WHERE nullable_color IS NOT NULL GROUP BY id HAVING sampled_colors[1] IS NOT NULL;
SELECT id, groupArraySample(2)(color) AS sampled_colors FROM colors WHERE (color IS NOT NULL) OR (nullable_color IS NOT NULL) GROUP BY id HAVING arrayCount(sampled_colors) > 0;
CREATE TABLE temp_colors (id UInt32, color String DEFAULT '', nullable_color Nullable(String) DEFAULT NULL);
INSERT INTO temp_colors SELECT id, color, nullable_color FROM colors WHERE color IS NOT NULL OR nullable_color IS NOT NULL;
SELECT id, groupArraySample(2)(CAST(nullable_color AS String)) AS sampled_nullable_colors FROM temp_colors WHERE nullable_color IS NOT NULL GROUP BY id HAVING sampled_nullable_colors[1] IS NOT NULL;