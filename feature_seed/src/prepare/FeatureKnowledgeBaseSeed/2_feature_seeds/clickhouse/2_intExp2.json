CREATE TABLE t_null (id UInt64, x Nullable(Int32));
INSERT INTO t_null VALUES (1, NULL), (2, 5), (3, -3);
SELECT id, intExp2(x) AS exp_x FROM t_null WHERE x IS NOT NULL;
SELECT id, intExp2(x) AS exp_x FROM t_null WHERE x IS NOT NULL AND exp_x > 0;
CREATE TABLE t_join (id UInt64, y Nullable(Int32));
INSERT INTO t_join VALUES (1, NULL), (2, 10), (3, 20);
SELECT t_null.id, intExp2(t_join.y) AS exp_y FROM t_null JOIN t_join ON t_null.id = t_join.id WHERE t_join.y IS NOT NULL;
SELECT t_null.id, COUNT(*) FROM t_null LEFT JOIN t_join ON t_null.id = t_join.id WHERE t_join.y IS NOT NULL GROUP BY t_null.id HAVING intExp2(max(t_null.x)) > 10;
SELECT id, intExp2(CASE WHEN x IS NOT NULL THEN x ELSE -1 END) AS exp_case FROM t_null HAVING exp_case IS NOT NULL;
CREATE TABLE t_complex (id UInt64, z Nullable(String));
INSERT INTO t_complex VALUES (1, '10'), (2, NULL), (3, '20');
SELECT t_complex.id, intExp2(toInt32(z)) AS exp_z FROM t_complex WHERE z IS NOT NULL AND exp_z IS NOT NULL;
SELECT id, intExp2(x) FROM t_null WHERE intExp2(y IS NOT NULL) > 0;
SELECT id, intExp2(x) FROM t_null WHERE IS NOT NULL(intExp2(x));