CREATE TABLE test_nullable (id UInt32, val Nullable(Int32), str String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_nullable VALUES (1, null, 'test'), (2, 2, 'example'), (3, 3, 'foo');
SELECT id, nullIf(val, 3) AS null_value FROM test_nullable WHERE nullIf(str, 'example') IS NULL;
SELECT id, (nullIf(val, 2) - 1) AS value_minus_one FROM test_nullable WHERE val IS NOT NULL;
SELECT id, str, (val - nullIf(1, 1)) AS adjusted_value FROM test_nullable WHERE val > 0 GROUP BY id, str HAVING adjusted_value IS NOT NULL;
SELECT id, (SELECT COUNT() FROM test_nullable WHERE nullIf(val, 2) IS NOT NULL) AS count_non_null FROM test_nullable;
SELECT id, (val - (SELECT nullIf(MAX(val), 3) FROM test_nullable)) AS diff_from_max FROM test_nullable;
CREATE TABLE test_complex (id UInt32, a Nullable(Int32), b Nullable(Int32), str_value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_complex VALUES (1, NULL, NULL, 'data1'), (2, 2, NULL, 'data2'), (3, 1, 1, 'data3');
SELECT a, b, nullIf(a, b) AS null_compared FROM test_complex WHERE (a - b) > 0;
SELECT id, (nullIf(a, b) - 1) * 10 AS transformed_value FROM test_complex WHERE str_value LIKE '%data%' GROUP BY id HAVING transformed_value IS NOT NULL;