CREATE TABLE test_dates (id UInt32, date_string String, nullable_date Nullable(DateTime));
INSERT INTO test_dates VALUES (1, '2023-10-01 12:00:00', NULL), (2, 'Not a date', NULL), (3, '2023-11-01', NULL);
SELECT EXISTS(SELECT 1 FROM test_dates WHERE parseDateTimeBestEffortOrZero(date_string) = 0) AS is_invalid_date;
SELECT count() FROM test_dates WHERE EXISTS(SELECT id FROM test_dates WHERE parseDateTimeBestEffortOrZero(date_string) > 0);
SELECT id, parseDateTimeBestEffortOrZero(date_string) AS parsed_date FROM test_dates WHERE EXISTS(SELECT * FROM test_dates t2 WHERE t2.id = test_dates.id AND parseDateTimeBestEffortOrZero(date_string) IS NOT NULL);
SELECT id, date_string FROM test_dates WHERE EXISTS(SELECT 1 FROM test_dates t3 WHERE t3.nullable_date IS NULL AND parseDateTimeBestEffortOrZero(date_string) = 0);
CREATE TABLE test_numbers (number UInt32);
INSERT INTO test_numbers VALUES (1), (2), (3), (4), (5);
SELECT EXISTS(SELECT * FROM (SELECT number FROM test_numbers) WHERE number > 3) AS has_high_numbers;
SELECT COUNT() FROM test_numbers WHERE EXISTS(SELECT number FROM test_numbers WHERE parseDateTimeBestEffortOrZero('2023-10-15') > 0);
SELECT id, parseDateTimeBestEffortOrZero(date_string) FROM test_dates GROUP BY id HAVING EXISTS(SELECT * FROM test_dates WHERE parseDateTimeBestEffortOrZero(date_string) = 0) ORDER BY parsed_date;
SELECT EXISTS(SELECT * FROM test_dates WHERE parseDateTimeBestEffortOrZero('2022-01-01') IS NOT NULL) AND COUNT(*) FROM test_dates;