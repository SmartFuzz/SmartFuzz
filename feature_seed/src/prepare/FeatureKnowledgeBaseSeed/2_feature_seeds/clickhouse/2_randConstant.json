CREATE TABLE test_table (id Int32, rand_value UInt32 DEFAULT randConstant(), str_value String, date_value DateTime);
INSERT INTO test_table (id, str_value, date_value) VALUES (1, 'Sample', now()), (2, 'Test', now() - INTERVAL 1 DAY);
SELECT id, tupleElement((SELECT randConstant(5) FROM system.numbers LIMIT 1), 1) AS random_sub, rand_value FROM test_table WHERE str_value LIKE 'S%';
SELECT id, str_value, date_value, randConstant(8) AS random_col FROM test_table WHERE rand_value = tupleElement((SELECT randConstant() FROM test_table), 1) GROUP BY id, random_col HAVING COUNT(*) > 1;
SELECT id, rand_value, rand_value + tupleElement((SELECT randConstant(10) FROM test_table WHERE id = 1), 1) AS complex_expression FROM test_table ORDER BY complex_expression;
SELECT id FROM (SELECT id, rand_value, tupleElement((SELECT randConstant() FROM test_table), 1) AS constant_tuple FROM test_table) AS subquery WHERE constant_tuple < 10;
CREATE TABLE temp_table (id Int32, value Nullable(Int32));
INSERT INTO temp_table (id, value) VALUES (1, NULL), (2, 3), (3, 5);
SELECT id, value FROM temp_table WHERE value IS NULL OR value = randConstant() OR value > 0;
SELECT id, randConstant(-3) AS negative_rand FROM temp_table WHERE id IN (SELECT id FROM temp_table WHERE value IS NOT NULL) ORDER BY negative_rand;