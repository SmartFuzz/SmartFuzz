CREATE TABLE test_strings (id UInt8, text String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'ClickHouse'), (2, 'Test'), (3, 'SQL Fuzzing');
SELECT ngramMinHashArg(text, 3, 6) AS result FROM test_strings WHERE id + 1 < 5;
SELECT id, ngramMinHashArg(text, id % 5 + 1, 6) AS ngram_hash FROM test_strings WHERE text LIKE '%House%';
SELECT a.id, b.text, ngramMinHashArg(b.text, 2, 5) FROM test_strings a JOIN test_strings b ON a.id + 1 = b.id WHERE a.text IS NOT NULL;
SELECT id, ngramMinHashArg(text, 1, 3) AS ngram_hash FROM test_strings GROUP BY id HAVING id + 2 < 5;
SELECT id, ngramMinHashArg(text, 3) AS hashes FROM (SELECT text FROM test_strings WHERE id > 0) AS subquery WHERE ngramMinHashArg(text, 3) IS NOT NULL;
SELECT id, ngramMinHashArg(text, id, id + 1) FROM test_strings WHERE EXISTS (SELECT 1 FROM test_strings WHERE text = 'Test') AND text IS NOT NULL;
CREATE TABLE temp_test (id UInt8, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO temp_test SELECT id, ngramMinHashArg(text, 3, 6) FROM test_strings;
SELECT DISTINCT value + ' - ' + id AS combined FROM temp_test WHERE ngramMinHashArg(value, 4, 2) IS NOT NULL;
DROP TABLE temp_test;