CREATE TABLE snowflake_test (id UInt64, created_at DateTime, data String);
INSERT INTO snowflake_test (id, created_at, data) VALUES (7204436857747984384, NOW(), 'test1');
INSERT INTO snowflake_test (id, created_at, data) VALUES (1288834974657, NOW(), 'test2');
INSERT INTO snowflake_test (id, created_at, data) VALUES (0, '1970-01-01 00:00:01', 'test3');
SELECT snowflakeIDToDateTime(id) AS snowflake_time, created_at FROM snowflake_test WHERE snowflakeIDToDateTime(id) <= NOW();
SELECT COUNT(*) FROM snowflake_test WHERE snowflakeIDToDateTime(id) <= snowflakeIDToDateTime(7204436857747984384);
SELECT data, snowflakeIDToDateTime(id) FROM snowflake_test WHERE created_at > NOW() - INTERVAL 1 DAY HAVING snowflakeIDToDateTime(id) IS NOT NULL;
SELECT id, (snowflakeIDToDateTime(id) <= created_at) AS comparison_result FROM snowflake_test;
SELECT AVG(snowflakeIDToDateTime(id)) OVER() AS avg_snowflake_time FROM snowflake_test;
SELECT id FROM (SELECT id, snowflakeIDToDateTime(id) AS snowflake_time FROM snowflake_test) AS subquery WHERE snowflake_time <= toDateTime('2023-01-01 00:00:00');