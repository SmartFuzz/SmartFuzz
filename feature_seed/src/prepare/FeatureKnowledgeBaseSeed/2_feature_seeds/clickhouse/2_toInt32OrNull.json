CREATE TABLE test_table (id Int32, value String, nullable_value Nullable(String));
INSERT INTO test_table VALUES (1, '123'), (2, 'abc'), (3, '-45'), (4, '2147483647'), (5, '0'), (6, NULL);
SELECT id, value, toInt32OrNull(value) AS converted_value, nullable_value IS NOT NULL AS is_not_null FROM test_table WHERE toInt32OrNull(value) IS NOT NULL;
SELECT id, value, toInt32OrNull(value) AS converted_value FROM (SELECT id, value FROM test_table) subquery WHERE toInt32OrNull(value) IS NOT NULL;
SELECT COUNT(*) AS valid_count FROM test_table WHERE toInt32OrNull(value) IS NOT NULL GROUP BY toInt32OrNull(value);
SELECT id, value, toInt32OrNull(value) AS converted_value FROM test_table WHERE (nullable_value IS NOT NULL AND toInt32OrNull(nullable_value) IS NULL) OR (nullable_value IS NULL AND toInt32OrNull(value) IS NOT NULL);
CREATE TABLE another_table (id Int32, num_value Nullable(String));
INSERT INTO another_table VALUES (1, '9999999999'), (2, 'NaN'), (3, '-2147483648'), (4, '0'), (5, '123abc');
SELECT a.id, a.num_value, toInt32OrNull(a.num_value) AS converted_num_value, a.num_value IS NOT NULL AS is_not_null_num FROM another_table a WHERE toInt32OrNull(a.num_value) IS NULL;
SELECT a.id, a.num_value, toInt32OrNull(a.num_value) AS converted_num_value FROM another_table a JOIN test_table t ON a.id = t.id WHERE t.value IS NOT NULL AND toInt32OrNull(t.value) IS NOT NULL;