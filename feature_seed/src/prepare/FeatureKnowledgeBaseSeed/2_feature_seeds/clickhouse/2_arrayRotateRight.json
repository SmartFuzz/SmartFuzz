CREATE TABLE test_arrays (id UInt32, arr Array(Int32), desc String);
INSERT INTO test_arrays VALUES (1, [1, 2, 3, 4, 5, 6], 'First'), (2, [7, 8, 9, 10, 11, 12], 'Second'), (3, [13, 14, 15], 'Third');
SELECT id, arrayRotateRight(arr, toUInt32(NULLIF(desc = 'First', false))) AS rotated_arr FROM test_arrays;
SELECT id, arr, arrayRotateRight(arr, (id % 3) - 2) AS rotated_arr FROM test_arrays WHERE id > 1;
WITH (arrayRotateRight(arr, id)) AS modified_arr SELECT id, modified_arr FROM (SELECT id, arr FROM test_arrays);
SELECT id, arrayRotateRight(arr, id * 2) AS rotated_arr FROM test_arrays WHERE rotated_arr IS NOT NULL;
SELECT id, (SELECT arrayRotateRight(arr, arraySum(arr)) FROM test_arrays WHERE id < 3) AS complex_subquery_result FROM test_arrays;
CREATE TEMPORARY TABLE temp_test AS SELECT id, arrayRotateRight(arr, -1) AS arr_copy FROM test_arrays;
SELECT a.id, a.arr, b.arr_copy FROM test_arrays AS a JOIN temp_test AS b ON arrayLength(a.arr) = arrayLength(b.arr_copy);
SELECT id, arrayRotateRight(arr, (arraySum(arrayMap(x -> x, arr)))) AS fuzzed_result FROM test_arrays HAVING fuzzed_result IS NOT NULL;