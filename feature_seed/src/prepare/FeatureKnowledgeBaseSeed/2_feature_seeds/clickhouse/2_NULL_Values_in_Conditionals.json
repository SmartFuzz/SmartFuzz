CREATE TABLE LEFT_RIGHT (left Nullable(Int32), right Nullable(Int32));
INSERT INTO LEFT_RIGHT VALUES (NULL, 4), (1, 3), (2, 2), (3, 1), (4, NULL);
SELECT left, right, multiIf(NULL < right, 'left is smaller', NULL > right, 'right is smaller', 'Both equal') AS result FROM LEFT_RIGHT;
SELECT left, right, (CASE WHEN NULL < right THEN 'left is smaller' ELSE NULL END) AS conditional_result, (left / right) AS division_result FROM LEFT_RIGHT;
SELECT left, right, multiIf((left / NULL) IS NULL, 'Undefined', 'Defined') AS div_check FROM LEFT_RIGHT;
WITH (SELECT AVG(right) FROM LEFT_RIGHT) AS average_right SELECT NULL / average_right AS division_with_null FROM LEFT_RIGHT;
CREATE TABLE TEST_DATA (id UInt32, value Nullable(Float64));
INSERT INTO TEST_DATA VALUES (1, NULL), (2, 10.5), (3, NULL), (4, 20.1);
SELECT id, value, value / NULL AS faulty_division, multiIf(value IS NULL, 'Unknown', CAST(value AS String)) AS safe_casting FROM TEST_DATA;
SELECT id, value, multiIf(value IS NULL, 'No Value', (value / 0.0)) AS special_case_handling FROM TEST_DATA WHERE (NULL = NULL) OR (value IS NOT NULL);
SELECT value, (NULL + value) AS null_addition, value AS original_value FROM TEST_DATA WHERE value IS NOT NULL;