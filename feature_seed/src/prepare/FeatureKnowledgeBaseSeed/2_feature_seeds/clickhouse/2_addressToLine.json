CREATE TABLE test_addresses (id UInt64, address UInt64, value String);
INSERT INTO test_addresses VALUES (1, 94784076370703, 'test1'), (2, 40000000000000, 'test2');
SELECT addressToLine(address) AS trace FROM test_addresses WHERE address < 50000000000000;
SELECT arrayStringConcat(arrayMap(x -> addressToLine(x), array_filter(addresses, x -> x < 10000000000000)), '\n') AS detail FROM (SELECT arrayJoin([94784076370703, 40000000000000]) AS addresses);
SELECT id, address, addressToLine(address) FROM test_addresses WHERE address < (SELECT max(address) FROM test_addresses) - 1;
CREATE TABLE temp_log AS SELECT address, addressToLine(address) AS trace FROM test_addresses GROUP BY address, trace HAVING count(address) < 3;
WITH (SELECT min(address) FROM test_addresses) AS min_address SELECT addressToLine(min_address) AS trace FROM test_addresses WHERE min_address < address;
SELECT count(*) FROM (SELECT address, addressToLine(address) FROM test_addresses WHERE address < 50000000000000) AS subquery GROUP BY address;
SELECT id, addressToLine(address) FROM test_addresses WHERE address < (SELECT arrayMax(address) FROM test_addresses WHERE value = 'test1') - 50000000000000;