CREATE TABLE test_table (id Int32, value Float64, name String, created_at DateTime DEFAULT now());
INSERT INTO test_table (id, value, name) VALUES (1, e(), 'Alice'), (2, 2.5, NULL), (3, -3.0, 'Bob'), (4, e() * 2, 'Charlie'), (5, 0, 'NULL_TEST');
SELECT id, value, name, (x -> e() + value) AS computed_value FROM test_table WHERE value > 0 ORDER BY computed_value;
SELECT id, e() AS e_value, (x -> x + e())(value) AS incremented_value FROM test_table;
SELECT COUNT(id) AS total_count, name FROM test_table GROUP BY name HAVING total_count > 0;
SELECT t1.id, t1.value, (x -> e() * x)(t1.value) AS multiplied_e FROM test_table t1 JOIN (SELECT id, name FROM test_table WHERE name IS NOT NULL) t2 ON t1.id = t2.id;
SELECT id, value, name, (x -> x * e())(value) AS multiplied_e FROM test_table WHERE value IS NOT NULL OR name IS NULL;
SELECT MIN(value) AS min_value, MAX(value) AS max_value FROM test_table WHERE value BETWEEN e() - 5 AND e() + 5;
CREATE TABLE temp_table AS SELECT id, e() AS e_value FROM test_table;
INSERT INTO temp_table SELECT id, value FROM test_table WHERE value < e() ORDER BY value DESC;
SELECT AVG((x -> e() + x)(value)) AS average_plus_e FROM test_table WHERE name IS NOT NULL GROUP BY name HAVING average_plus_e < 10;
WITH (SELECT e() AS e_val) AS constants SELECT id, value, (x -> e_val + x)(value) AS increased_value FROM test_table;