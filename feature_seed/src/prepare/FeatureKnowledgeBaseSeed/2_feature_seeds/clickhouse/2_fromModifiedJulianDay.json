CREATE TABLE test_dates (id UInt32, modified_julian_day Int32);
INSERT INTO test_dates VALUES (1, 58849), (2, -678942), (3, 2973484), (4, 0);
SELECT fromModifiedJulianDay(modified_julian_day) AS date FROM test_dates WHERE EXISTS(SELECT * FROM test_dates WHERE modified_julian_day BETWEEN -678941 AND 2973483) GROUP BY date HAVING date IS NOT NULL;
SELECT EXISTS(SELECT * FROM test_dates WHERE fromModifiedJulianDay(modified_julian_day) IS NOT NULL) AS valid_dates, EXISTS(SELECT * FROM test_dates WHERE fromModifiedJulianDay(modified_julian_day) = '0000-01-01') AS start_date, EXISTS(SELECT * FROM test_dates WHERE fromModifiedJulianDay(modified_julian_day) = '9999-12-31') AS end_date;
SELECT COUNT(*) FROM (SELECT EXISTS(SELECT * FROM test_dates WHERE modified_julian_day < 0) AS negative_days) AS subquery WHERE negative_days = 1;
CREATE TABLE temp_data (num UInt32, str_field String);
INSERT INTO temp_data VALUES (1, '2023-01-01'), (2, '2023-01-02'), (3, NULL);
SELECT EXISTS(SELECT * FROM temp_data WHERE str_field IS NOT NULL AND fromModifiedJulianDay(toInt32(num)) = '2023-01-01') AS example_case;
SELECT EXISTS(SELECT * FROM test_dates WHERE modified_julian_day = 58849) AND fromModifiedJulianDay(58849) = '2023-01-01';
SELECT fromModifiedJulianDay(CASE WHEN EXISTS(SELECT * FROM test_dates WHERE modified_julian_day > 100) THEN modified_julian_day ELSE -678942 END) AS test_date FROM test_dates;