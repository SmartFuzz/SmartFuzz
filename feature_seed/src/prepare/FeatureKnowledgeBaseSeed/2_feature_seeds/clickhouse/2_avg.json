CREATE TABLE test_avg (val Nullable(Int32)) ENGINE = Memory;
INSERT INTO test_avg (val) VALUES (1), (2), (NULL), (4), (5);
CREATE TABLE test_check (val Nullable(Int32)) ENGINE = Memory;
INSERT INTO test_check (val) VALUES (NULL), (10), (NULL), (20);
SELECT avg(val) FROM (SELECT val FROM test_avg WHERE val IS NOT NULL) AS subquery;
SELECT avg(val) FROM test_check WHERE val IS NOT NULL GROUP BY val HAVING avg(val) > 0;
SELECT t1.val, avg(t2.val) FROM test_avg AS t1 JOIN test_check AS t2 ON t1.val IS NOT NULL AND t2.val IS NOT NULL GROUP BY t1.val;
SELECT avg(val) FROM test_avg HAVING avg(val) IS NOT NULL;
SELECT avg(val) FROM (SELECT val FROM test_avg WHERE val IS NOT NULL UNION ALL SELECT val FROM test_check WHERE val IS NOT NULL) AS combined WHERE combined IS NOT NULL;
CREATE TEMPORARY TABLE temp_avg (num Nullable(Float64)) ENGINE = Memory;
INSERT INTO temp_avg (num) VALUES (1.1), (2.2), (NULL), (4.4), (5.5);
SELECT avg(num) FROM temp_avg WHERE num IS NOT NULL;
SELECT avg(CASE WHEN val IS NOT NULL THEN val ELSE 0 END) FROM test_avg;
CREATE TABLE edge_case_test (num Nullable(Int32)) ENGINE = Memory;
INSERT INTO edge_case_test (num) VALUES (2147483647), (NULL), (0), (-2147483648);
SELECT avg(num) FROM edge_case_test WHERE num IS NOT NULL AND num > -2147483648;
SELECT avg(num) AS average FROM edge_case_test GROUP BY num HAVING average IS NOT NULL;