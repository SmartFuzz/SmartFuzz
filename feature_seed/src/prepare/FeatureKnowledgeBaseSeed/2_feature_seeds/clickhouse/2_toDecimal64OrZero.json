CREATE TABLE test_decimal (id UInt32, value String);
INSERT INTO test_decimal VALUES (1, '123.456'), (2, '0.0001'), (3, 'Inf'), (4, 'NaN'), (5, '99999999999999999999'), (6, '');
CREATE TABLE test_nullable (id UInt32, value Nullable(Decimal(18, 6)));
INSERT INTO test_nullable VALUES (1, toDecimal64OrZero(toString(123.456), 6)), (2, NULL), (3, toDecimal64OrZero(toString('Inf'), 6));
SELECT id, toDecimal64OrZero(value, 2) AS decimal_val FROM test_decimal WHERE value IS NULL;
SELECT a.id, toDecimal64OrZero(a.value, 5) AS decimal_val FROM test_decimal AS a JOIN test_nullable AS b ON a.id = b.id WHERE b.value IS NOT NULL;
SELECT id, toDecimal64OrZero(toString(value), 2) AS decimal_val FROM test_decimal WHERE toDecimal64OrZero(value, 2) IS NULL;
SELECT id, COUNT(*) FROM test_decimal WHERE toDecimal64OrZero(value, 5) IS NOT NULL GROUP BY id HAVING COUNT(*) > 0;
SELECT id, value, toDecimal64OrZero(value, 3) AS decimal_val, value IS NULL as value_is_null FROM test_nullable;
SELECT a.id, toDecimal64OrZero(a.value, 6) AS decimal_val, b.value IS NULL AS nullable_check FROM test_decimal a CROSS JOIN test_nullable b WHERE toDecimal64OrZero(a.value, 6) > 0 AND b.value IS NOT NULL;