CREATE TABLE test1 (a UInt8 NULL, b Float32 NULL) ENGINE=Log;
INSERT INTO test1 (a, b) VALUES (NULL, NULL), (1, 2.5), (1, 2.5), (2, 3.5), (NULL, 4.0);
SELECT singleValueOrNull(a * b) FROM test1 WHERE a IS NOT NULL;
CREATE TABLE test2 (x String NULL, y Int32 NULL) ENGINE=Log;
INSERT INTO test2 (x, y) VALUES (NULL, NULL), ('hello', 1), ('world', 2), ('hello', NULL), ('data', 1);
SELECT singleValueOrNull(CAST(x AS Int32) * singleValueOrNull(y)) FROM test2 WHERE x IS NOT NULL;
CREATE TABLE test3 (m UInt16, n Nullable(Int32)) ENGINE=Log;
INSERT INTO test3 (m, n) VALUES (1, 10), (2, 20), (3, NULL), (1, 30), (2, NULL);
SELECT singleValueOrNull(m * (SELECT MAX(n) FROM test3 WHERE n IS NOT NULL)) FROM test3 GROUP BY m HAVING m > 0;
CREATE TABLE test4 (c Nullable(Float64), d DateTime) ENGINE=Log;
INSERT INTO test4 (c, d) VALUES (NULL, '2023-01-01 00:00:00'), (1.5, '2023-01-01 00:01:00'), (1.5, '2023-01-01 00:02:00'), (2.5, '2023-01-01 00:03:00');
SELECT singleValueOrNull(AVG(c) * singleValueOrNull(d) * 2) FROM test4 WHERE c IS NOT NULL;
CREATE TABLE test5 (p Nullable(Int64), q Int8) ENGINE=Log;
INSERT INTO test5 (p, q) VALUES (NULL, 1), (NULL, 2), (5, 3), (5, 4), (NULL, NULL);
SELECT singleValueOrNull(q * p) FROM test5 GROUP BY q HAVING singleValueOrNull(q) IS NOT NULL;