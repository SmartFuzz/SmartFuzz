CREATE TABLE test_table (id UInt32, value Nullable(Int32)) ENGINE = Log;
INSERT INTO test_table (id, value) VALUES (1, NULL), (2, 10), (3, -5), (4, NULL);
SELECT id, isNullable(value), -a(value) AS negated_value FROM test_table WHERE isNullable(value) = 1;
SELECT id, -a(COALESCE(value, 0)) AS negated_COALESCE FROM test_table GROUP BY id HAVING negated_COALESCE < -5;
CREATE TABLE temp_table AS SELECT id, -a(value) AS negated_value FROM test_table WHERE value IS NOT NULL;
SELECT t.id, isNullable(t.value), (SELECT -a(MAX(nt.value)) FROM temp_table nt WHERE nt.id = t.id) AS max_negated_value FROM test_table t;
SELECT t1.id, -a(t2.value) FROM test_table t1 JOIN test_table t2 ON t2.id = t1.id WHERE isNullable(t1.value) = 1;
WITH (SELECT id FROM test_table WHERE value IS NOT NULL) AS non_null_ids SELECT id, -a(value) FROM test_table WHERE id IN non_null_ids;
SELECT id, -a(CASE WHEN value IS NULL THEN 1 ELSE value END) AS negated_case FROM test_table GROUP BY id HAVING negated_case < -10;
INSERT INTO test_table (id, value) VALUES (5, (SELECT MAX(-a(value)) FROM test_table));