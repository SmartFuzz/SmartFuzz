CREATE TABLE test_strings(haystack String, pattern Array(String));
INSERT INTO test_strings VALUES('this is a test string', ['test', 'string', 'notfound']);
SELECT haystack, multiMatchAllIndices(haystack, pattern) AS indices FROM test_strings WHERE indices <> [];
SELECT haystack, multiMatchAllIndices(haystack, ['test', 'string', 'this']) AS indices FROM test_strings HAVING indices <> [] AND length(haystack) > 10;
SELECT DISTINCT multiMatchAllIndices('abcxyzdef', ['xyz', 'abc', 'def']) FROM test_strings WHERE haystack <> 'no match';
CREATE TABLE nested_test(haystack String, pattern Array(String) DEFAULT ['test', 'string'], id UInt32);
INSERT INTO nested_test VALUES ('match here', ['match', 'here']), ('no match', ['notfound', 'missing']);
SELECT haystack, pattern, COUNT(*) AS match_count FROM nested_test GROUP BY haystack, pattern HAVING match_count <> 0;
SELECT haystack, multiMatchAllIndices(haystack, arrayJoin(pattern)) AS indices FROM nested_test WHERE haystack <> '' AND indices <> [];
CREATE TEMPORARY TABLE temp_test AS SELECT haystack FROM test_strings;
SELECT haystack, arrayJoin(multiMatchAllIndices(haystack, pattern)) AS indices FROM temp_test WHERE indices <> [];
ALTER TABLE test_strings ADD COLUMN new_col Nullable(UInt32) DEFAULT NULL;
INSERT INTO test_strings VALUES('another test', ['test'], 1), ('check nullable', ['nullable'], NULL);
SELECT haystack, multiMatchAllIndices(haystack, pattern) AS indices FROM test_strings WHERE new_col IS NULL AND indices <> [];
SELECT haystack, COUNT(*) AS count FROM test_strings WHERE haystack <> '' GROUP BY haystack HAVING count >= 1 AND length(haystack) < 20;
SELECT min(length(haystack)), max(length(haystack)) FROM test_strings WHERE haystack <> '' AND length(haystack) <> 0;
CREATE TABLE values_test(id UInt32, value Float64);
INSERT INTO values_test VALUES (1, 1.5), (2, 2.5), (3, 3.5), (4, NULL);
SELECT id, value, value <> 2.5 AS is_not_two_point_five FROM values_test WHERE value IS NOT NULL;
SELECT multiMatchAllIndices(haystack, ['test', 'no match']) AS indices FROM test_strings HAVING indices <> [] ORDER BY length(haystack) DESC;