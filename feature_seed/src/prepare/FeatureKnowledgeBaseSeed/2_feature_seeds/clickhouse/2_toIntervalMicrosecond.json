CREATE TABLE fuzz_test (id UInt32, timestamp DateTime, microseconds String, values Array(UInt32));
INSERT INTO fuzz_test VALUES (1, toDateTime('2024-06-15 12:00:00'), '1000000', [1, 2, 3]), (2, toDateTime('2023-12-01 15:30:00'), '2000000', [4, 5, 6]), (3, toDateTime('2023-05-10 07:15:00'), '3000000', [7, 8, 9]);
SELECT id, timestamp + toIntervalMicrosecond(CAST(microseconds AS Int64)), values[1] AS first_value FROM fuzz_test WHERE timestamp IS NOT NULL;
SELECT id, values[arrayElement([1, 2, 3], 2)], timestamp + toIntervalMicrosecond(NULLIF(microseconds, '')) AS adjusted_time FROM fuzz_test WHERE adjusted_time > toDateTime('2023-06-01 00:00:00') ORDER BY adjusted_time;
WITH (SELECT MAX(timestamp) FROM fuzz_test) AS max_timestamp SELECT id, toIntervalMicrosecond(CAST(values[arrayElement([1, 2, 3], 2)] AS UInt32) * 100) AS interval_generated FROM fuzz_test WHERE MAX(timestamp) >= max_timestamp GROUP BY id HAVING interval_generated IS NOT NULL;
SELECT id, timestamp + toIntervalMicrosecond(CAST('5000000' AS Int64)), arrayElement(values, id % 3 + 1) AS selected_value FROM fuzz_test WHERE selected_value IS NOT NULL;
CREATE TABLE fuzz_test_temp AS SELECT * FROM fuzz_test WHERE microseconds != '' AND microseconds IS NOT NULL;
INSERT INTO fuzz_test_temp SELECT id, timestamp, CAST(CONCAT(microseconds, '0') AS String), values FROM fuzz_test WHERE microseconds != '';
SELECT id, timestamp + toIntervalMicrosecond(CAST(NULLIF(microseconds, '0') AS Int64)) AS microsecond_adjusted FROM fuzz_test_temp WHERE microsecond_adjusted IS NOT NULL;
DROP TABLE IF EXISTS fuzz_test_temp;