CREATE TABLE test_dates (id UInt32, date_str String, created_at DateTime64(3));
INSERT INTO test_dates VALUES (1, '12/31/2023', now()), (2, '01/01/2024', now()), (3, NULL, now());
SELECT id, date_str, created_at, parseDateTime64BestEffortUS(date_str, 3) AS parsed_date FROM test_dates WHERE parsed_date NOT IN (SELECT parseDateTime64BestEffortUS(date_str, 3) FROM test_dates WHERE date_str IS NOT NULL);
CREATE TABLE secondary_data (id UInt32, parent_id UInt32, other_data String);
INSERT INTO secondary_data VALUES (1, 1, 'Sample A'), (2, 1, 'Sample B'), (3, 2, 'Sample C');
SELECT t.id, t.date_str, t.created_at, s.other_data FROM test_dates AS t JOIN secondary_data AS s ON s.parent_id NOT IN (SELECT t1.id FROM test_dates AS t1 WHERE parseDateTime64BestEffortUS(t1.date_str, 3) IS NULL) WHERE parseDateTime64BestEffortUS(t.date_str, 3) IS NOT NULL;
SELECT COUNT(*) FROM test_dates WHERE parseDateTime64BestEffortUS(date_str, 3) NOT IN (SELECT parseDateTime64BestEffortUS(date_str, 3) FROM test_dates WHERE date_str IS NOT NULL GROUP BY date_str HAVING COUNT(*) > 1);
SELECT id, date_str, created_at, parseDateTime64BestEffortUS(date_str, 3) AS parsed_date FROM test_dates WHERE parsed_date NOT IN (SELECT parseDateTime64BestEffortUS(date_str, 3) FROM test_dates WHERE date_str NOT LIKE '____/__/____') ORDER BY parsed_date DESC;