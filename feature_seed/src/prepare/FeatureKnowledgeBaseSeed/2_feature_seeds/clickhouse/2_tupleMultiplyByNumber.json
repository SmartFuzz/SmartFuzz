CREATE TABLE test_table (id Int32, value Float64, tuple_value Tuple(Int32, Int32));
INSERT INTO test_table VALUES (1, 2.5, (1, 2)), (2, NULL, (3, 4));
SELECT id, tupleMultiplyByNumber(tuple_value, value * 2) AS multiplied_tuple FROM test_table WHERE value IS NOT NULL;
SELECT id, tupleMultiplyByNumber((value + 1, value * -1), 2.0) AS new_tuple FROM test_table WHERE value IS NOT NULL;
SELECT id, tupleMultiplyByNumber((value, NULL), 3.5) AS fuzzed_tuple, value * 3.5 AS multiplied_value FROM test_table HAVING multiplied_value > 5;
CREATE TABLE temp_table AS (SELECT id, tupleMultiplyByNumber(tuple_value, 1.2) AS transformed_tuple FROM test_table) ENGINE = MergeTree() ORDER BY id;
INSERT INTO temp_table SELECT id, tupleMultiplyByNumber(tuple_value, NULL) FROM test_table WHERE value IS NOT NULL;
SELECT id, tupleMultiplyByNumber(tuple_value, (SELECT AVG(value) FROM test_table)) AS avg_multiplied FROM test_table;
SELECT id, (value * 2.0) AS scaled_value, tupleMultiplyByNumber((value, scaled_value), NULL) AS null_tuple FROM test_table WHERE value IS NOT NULL;
SELECT id, tupleMultiplyByNumber((1, 1), (SELECT COUNT(*) FROM test_table WHERE value > 1)) AS outer_query_tuple FROM test_table;