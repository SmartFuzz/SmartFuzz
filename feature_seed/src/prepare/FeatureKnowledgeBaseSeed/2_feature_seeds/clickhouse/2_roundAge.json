CREATE TABLE test_ages (id UInt32, age Float64, name String);
INSERT INTO test_ages VALUES (1, 0.5, 'Alice'), (2, 15, 'Bob'), (3, 20, 'Charlie'), (4, 30, NULL), (5, 40, 'Eve'), (6, 55, 'David'), (7, 80, 'Grace');
SELECT id, age, roundAge(age) AS rounded_age FROM test_ages WHERE age BETWEEN 0 AND 100;
SELECT id, age, roundAge(COALESCE(age, 0)) AS rounded_age FROM test_ages WHERE age BETWEEN roundAge(1) AND roundAge(80);
SELECT age, roundAge(age) AS rounded_age FROM test_ages WHERE roundAge(age) BETWEEN 0 AND 5;
SELECT id, age, roundAge(age) AS rounded_age FROM (SELECT id, age FROM test_ages WHERE age IS NOT NULL) AS filtered_ages HAVING rounded_age > 0;
SELECT b.id, b.age FROM test_ages AS a JOIN (SELECT id, age, roundAge(age) AS rounded_age FROM test_ages) AS b ON a.id = b.id WHERE b.rounded_age BETWEEN 18 AND 24;
SELECT COUNT(*) FROM test_ages WHERE roundAge(age) BETWEEN 25 AND 35 GROUP BY roundAge(age) HAVING COUNT(*) > 1;
SELECT id, age, roundAge(age) AS rounded_age FROM test_ages WHERE roundAge(CASE WHEN age IS NOT NULL THEN age ELSE 1 END) BETWEEN 0 AND 5;
SELECT AVG(age), MAX(age), MIN(age), roundAge(AVG(age)) AS average_rounded_age FROM test_ages WHERE roundAge(age) IN (SELECT roundAge(15), roundAge(35));