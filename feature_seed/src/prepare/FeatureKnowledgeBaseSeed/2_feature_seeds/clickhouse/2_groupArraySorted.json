CREATE TABLE test_numbers (id UInt32, number UInt32, str String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_numbers VALUES (1, 10, '10'), (2, 20, '20'), (3, 30, '30'), (4, 40, '40'), (5, 50, '50');
SELECT groupArraySorted(SELECT number % 3 FROM test_numbers WHERE number > 15)(number) FROM test_numbers WHERE id <= 4;
SELECT id, groupArraySorted(5)(str) FROM (SELECT id, toString(number % 2) AS str FROM test_numbers) GROUP BY id HAVING id > 2;
SELECT groupArraySorted(3)(number) FROM (SELECT number, CASE WHEN number % 5 = 0 THEN NULL ELSE number END AS filtered_number FROM test_numbers) WHERE filtered_number IS NOT NULL;
CREATE TABLE test_strings (id UInt32, str_col String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'a'), (2, 'b'), (3, 'c'), (4, NULL), (5, 'f');
SELECT groupArraySorted(2)(str_col) FROM (SELECT str_col, LENGTH(str_col) % 3 AS mod_length FROM test_strings WHERE str_col IS NOT NULL) GROUP BY mod_length;
SELECT groupArraySorted(5)(CAST(str_col AS UInt32) % 7) FROM (SELECT str_col FROM test_strings HAVING str_col IS NOT NULL) GROUP BY str_col;
SELECT number, groupArraySorted(10)(str) FROM (SELECT number, toString(number % 10) AS str FROM test_numbers) GROUP BY number HAVING number < 50 ORDER BY number DESC;