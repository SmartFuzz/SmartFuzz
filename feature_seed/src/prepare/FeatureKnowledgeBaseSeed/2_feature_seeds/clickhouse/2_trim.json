CREATE TABLE test_strings (id UInt32, content String) ENGINE = Memory;
INSERT INTO test_strings VALUES (1, '   Hello, World!   '), (2, '   Example String! '), (3, '    '), (4, NULL);
SELECT id, trim(BOTH ' ' FROM content) AS trimmed_content FROM test_strings;
SELECT id FROM test_strings WHERE trim(' ' FROM content) < 'Hello';
SELECT id FROM (SELECT id, trim(' !' FROM content) AS trimmed_content FROM test_strings) AS trimmed WHERE trimmed_content < 'Example';
CREATE TABLE another_table (id UInt32, value String) ENGINE = Memory;
INSERT INTO another_table VALUES (1, ' !'), (2, '   Hello'), (3, '   ');
SELECT a.id, a.content FROM test_strings a JOIN another_table b ON trim(BOTH ' ' FROM a.content) < trim(BOTH ' ' FROM b.value);
SELECT id, trim(' ' FROM content) AS trimmed_content FROM test_strings GROUP BY trimmed_content HAVING trimmed_content < 'Example';
SELECT id, trim(BOTH ' ' FROM content) AS trimmed_content FROM test_strings WHERE trimmed_content IS NOT NULL;
SELECT trim(BOTH ' ' FROM content) AS trimmed_content, COUNT(*) FROM test_strings GROUP BY trimmed_content HAVING trimmed_content < 'A';
CREATE TABLE test_numbers (num_id UInt32, numeric_value String) ENGINE = Memory;
INSERT INTO test_numbers VALUES (1, '100'), (2, '200'), (3, '300'), (4, NULL);
SELECT num_id FROM test_numbers WHERE trim(' ' FROM numeric_value) < '200';
SELECT num_id FROM (SELECT num_id, trim(' ' FROM numeric_value) AS trimmed_value FROM test_numbers) AS nums WHERE trimmed_value < '250';
SELECT a.num_id FROM test_numbers a JOIN test_strings b ON trim(' ' FROM b.content) < trim(' ' FROM a.numeric_value);