CREATE TABLE test_strings (id UInt32, haystack String, needle String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'Hello World', 'hello'), (2, 'CLICKHOUSE is Great', 'clickhouse'), (3, 'Another Test', 'test'), (4, 'Case Insensitive Test', 'TEST'), (5, '', 'empty');
SELECT id, ngramSearchCaseInsensitive(haystack, needle) AS match_likelihood FROM test_strings WHERE match_likelihood > 0.5;
SELECT id, haystack, needle, ngramSearchCaseInsensitive(haystack, needle) AS match_percentage FROM test_strings WHERE ngramSearchCaseInsensitive(haystack, needle) BETWEEN 0.1 AND 0.9 ORDER BY match_percentage DESC;
SELECT id, arrayJoin([1, 2, 3]) AS idx, ngramSearchCaseInsensitive(arrayJoin([haystack]), needle) AS match_likelihood FROM test_strings HAVING match_likelihood IS NOT NULL;
SELECT t1.id, ngramSearchCaseInsensitive(t1.haystack, t2.needle) AS match_likelihood FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.id != t2.id WHERE match_likelihood > 0.3 GROUP BY t1.id, t1.haystack, t2.needle HAVING COUNT(*) > 1;
SELECT id, ngramSearchCaseInsensitive(arrayJoin([haystack]), arrayJoin([needle])) AS likelihood FROM test_strings LIMIT 2;
SELECT id, COUNT(*) AS count, ngramSearchCaseInsensitive(haystack, 'hello') AS match_likelihood FROM test_strings GROUP BY id HAVING match_likelihood = 1 OR count > 1;
CREATE TABLE temp_strings AS SELECT * FROM test_strings WHERE haystack IS NOT NULL;
INSERT INTO temp_strings SELECT *, 'default' FROM test_strings WHERE haystack = '';