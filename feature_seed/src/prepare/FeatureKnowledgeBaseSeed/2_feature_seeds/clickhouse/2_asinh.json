CREATE TABLE test_values (id Int32, value Float64, description String);
INSERT INTO test_values (id, value, description) VALUES (1, 0.0, 'zero'), (2, -1.0, 'negative one'), (3, 1.0, 'positive one'), (4, NULL, 'null value');
SELECT id, asinh(value) FROM test_values WHERE value IS NOT NULL AND (value == -1.0 OR value == 0.0);
SELECT id, value, asinh(value) AS asinh_value FROM test_values WHERE asinh(value) == 0.0;
SELECT id, value FROM test_values WHERE asinh(value) == asinh(1.0);
SELECT id, COUNT(*) FROM (SELECT id, value, asinh(value) AS asinh_value FROM test_values GROUP BY id, value HAVING asinh_value IS NOT NULL) AS subquery GROUP BY id;
SELECT t1.id, asinh(t1.value) FROM test_values t1 JOIN test_values t2 ON t1.value == t2.value WHERE t2.description == 'positive one';
SELECT t1.id, asinh(t1.value) FROM test_values t1 LEFT JOIN test_values t2 ON t1.value == t2.value WHERE t2.id IS NULL OR t2.value IS NULL;
SELECT id, asinh(value) FROM test_values WHERE asinh(-10.0) < asinh(value) AND asinh(value) < asinh(10.0);
CREATE TEMPORARY TABLE if_needed (temp_value Float64 NOT NULL);
INSERT INTO if_needed (temp_value) VALUES (1.0), (2.0), (3.5);
SELECT t.id, asinh(t.value) FROM test_values t WHERE t.value IN (SELECT temp_value FROM if_needed) AND t.value IS NOT NULL;