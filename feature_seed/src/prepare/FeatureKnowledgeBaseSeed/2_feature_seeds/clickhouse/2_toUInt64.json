CREATE TABLE test_table (id UInt64, value Float64, str_value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 64.64, '64'), (2, 128.128, '128'), (3, NULL, 'NULL'), (4, 18446744073709551616, '18446744073709551616');
SELECT id, toUInt64(value), toUInt64(str_value), [toUInt64(value), toUInt64(str_value)] AS converted_array FROM test_table WHERE value IS NOT NULL;
SELECT id, arraySum([toUInt64(value), toUInt64(str_value)]) AS total FROM test_table GROUP BY id HAVING total > 100;
SELECT t1.id, toUInt64(t1.value) FROM test_table t1 JOIN (SELECT id, str_value FROM test_table WHERE id > 1) t2 ON toUInt64(t1.str_value) = t2.id;
SELECT id, arrayJoin([toUInt64(value), toUInt64(NULL)]) AS joined_array FROM test_table WHERE str_value IS NOT NULL;
CREATE TEMPORARY TABLE temp_table AS SELECT toUInt64(value) AS temp_value, str_value FROM test_table WHERE value IS NOT NULL;
SELECT AVG(temp_value) FROM temp_table GROUP BY str_value HAVING AVG(temp_value) > 50;
SELECT id, toUInt64(0.0001) AS small_value, toUInt64('') AS empty_string_val FROM test_table;
SELECT id, arrayMap(x -> toUInt64(x), [value, str_value]) AS mapped_values FROM test_table WHERE str_value IS NOT NULL;