CREATE TABLE test_strings (id Int32, text String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'â'), (2, 'normal text'), (3, NULL), (4, '');
CREATE TABLE test_subquery (val String) ENGINE = MergeTree() ORDER BY val;
INSERT INTO test_subquery VALUES ('â'), ('normal text'), ('non matching'), ('another text');
SELECT id, normalizeUTF8NFKD(text) AS normalized, length(normalizeUTF8NFKD(text)) AS norm_length FROM test_strings WHERE text != ALL (SELECT val FROM test_subquery WHERE val != 'normal text') ORDER BY norm_length;
SELECT id, COUNT(*) OVER (PARTITION BY normalizeUTF8NFKD(text)) AS countNorm, IF(text IS NULL, 0, 1) AS is_not_null FROM test_strings HAVING countNorm != ALL (SELECT COUNT(*) FROM test_strings WHERE text IS NOT NULL) ORDER BY id;
SELECT AVG(length(normalizeUTF8NFKD(text))) AS avg_length, 'Average Length' AS description FROM test_strings GROUP BY description HAVING avg_length != ALL (SELECT length FROM (SELECT length(normalizeUTF8NFKD(text)) AS length FROM test_strings WHERE text IS NOT NULL) GROUP BY length) ORDER BY avg_length;
SELECT DISTINCT normalizeUTF8NFKD(text) AS unique_text FROM test_strings WHERE normalizeUTF8NFKD(text) IS NOT NULL;
CREATE TABLE test_types (id Int32, varchar_col String, float_col Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_types VALUES (1, '100', 100.0), (2, '200', 200.2), (3, '300', NULL);
SELECT id, varchar_col != ALL (SELECT toString(float_col) FROM test_types WHERE float_col IS NOT NULL GROUP BY float_col) AS is_unique FROM test_types;
SELECT id, normalizeUTF8NFKD(toString(id)) AS nfkd_id FROM (SELECT id FROM test_types WHERE id < 2) WHERE id != ALL (SELECT id FROM test_types WHERE varchar_col = '100') ORDER BY id;