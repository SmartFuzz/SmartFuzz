CREATE TABLE test_data (id UInt32, name String, value Float64, created_at DateTime);
INSERT INTO test_data VALUES (1, 'apple', 13.5, '2021-01-01 00:00:00'), (2, 'banana', NULL, '2021-01-02 00:00:00'), (3, 'carrot', 25.0, '2021-01-01 12:00:00'), (4, '', 50.25, '2021-01-03 00:00:00');
SELECT id FROM test_data WHERE name LIKE '%a%';
SELECT id FROM test_data WHERE value = ALL (SELECT value FROM test_data WHERE name LIKE 'b%');
SELECT id, name, value FROM test_data WHERE created_at >= (SELECT MIN(created_at) FROM test_data WHERE name LIKE 'c%') AND value = ALL (SELECT value FROM test_data WHERE created_at IS NOT NULL);
SELECT id FROM test_data WHERE COALESCE(name, '') LIKE '\_%';
SELECT id, COUNT(*) FROM test_data GROUP BY value HAVING COUNT(*) > (SELECT COUNT(*) FROM test_data WHERE value IS NULL);
SELECT id FROM test_data WHERE value = ALL (SELECT value + 10 FROM test_data WHERE name LIKE 'a%') OR name LIKE '\%ance';
SELECT AVG(value) FROM test_data WHERE name LIKE 'c\_r%' AND created_at < (SELECT MAX(created_at) FROM test_data);
SELECT id FROM test_data WHERE name LIKE (SELECT CONCAT('%', name, '%') FROM test_data WHERE id = 4);
SELECT name FROM test_data WHERE id IN (SELECT id FROM test_data WHERE value = ALL (SELECT value FROM test_data WHERE name LIKE '%a%'));