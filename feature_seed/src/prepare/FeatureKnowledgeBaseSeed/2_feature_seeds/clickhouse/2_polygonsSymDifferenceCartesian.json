CREATE TABLE geo_shapes (id Int32, shape1 Array(LowCardinality(String)), shape2 Array(LowCardinality(String)), created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO geo_shapes VALUES (1, [[[(0, 0), (0, 3), (1, 2.9), (2, 2.6), (2.6, 2), (2.9, 1), (3, 0), (0, 0)]]], [[[(1., 1.), (1., 4.), (4., 4.), (4., 1.), (1., 1.)]]]], now());
INSERT INTO geo_shapes VALUES (2, [[[(5, 5), (5, 7), (7, 7), (7, 5), (5, 5)]]], [[[(6., 6.), (6., 8.), (8., 8.), (8., 6.), (6., 6.)]]]], now());
SELECT id, wkt(polygonsSymDifferenceCartesian(shape1, shape2)) FROM geo_shapes WHERE id = ALL (SELECT id FROM geo_shapes WHERE created_at >= now() - INTERVAL 1 DAY);
SELECT id, wkt(polygonsSymDifferenceCartesian(shape1, [[[(NULL, NULL), (1.1, 1.1), (NULL, 2.5), (2.5, NULL), (2.9, 1.1), (3.5, 0)]]]])) FROM geo_shapes WHERE shape2 IS NULL;
CREATE TABLE temp_shapes AS SELECT id, wkt(polygonsSymDifferenceCartesian(shape1, [[[(0, 0), (1, 1), (0, 1), (1, 0), (0, 0)]]]])) AS diff_shape FROM geo_shapes WHERE id IN (SELECT id FROM geo_shapes WHERE created_at IS NOT NULL);
SELECT COUNT(*) FROM temp_shapes WHERE diff_shape = ALL (SELECT wkt(polygonsSymDifferenceCartesian(shape1, shape2)) FROM geo_shapes);
SELECT DISTINCT shape1 FROM geo_shapes WHERE id = ALL (SELECT id FROM geo_shapes WHERE shape2 != shape1 AND id IS NOT NULL) HAVING COUNT(*) > 1;
SELECT AVG(length(shape1)) FROM geo_shapes WHERE EXISTS (SELECT 1 FROM temp_shapes WHERE temp_shapes.id = geo_shapes.id) GROUP BY id;