CREATE TABLE test_sqid (id UInt64, sqid String, value Nullable(Int32));
INSERT INTO test_sqid VALUES (1, 'gXHfJ1C6dN', 100), (2, 'invalid_sqid', NULL), (3, '', 50), (4, 'gXHfJ1C6dN', 75);
SELECT id, sqidDecode(sqid) AS decoded_sqid FROM test_sqid WHERE decoded_sqid NOT IN (SELECT value FROM test_sqid WHERE value IS NOT NULL) ORDER BY id;
SELECT id, sqid, value FROM test_sqid WHERE value IS NOT NULL AND sqidDecode(sqid) NOT IN (SELECT value FROM test_sqid WHERE value > 50) ORDER BY value DESC;
SELECT id, sqid, sqidDecode(sqid) AS decoded_sqid FROM test_sqid GROUP BY id, sqid HAVING decoded_sqid NOT IN (SELECT value FROM test_sqid WHERE value IS NULL) ORDER BY decoded_sqid;
SELECT id, sqidDecode(sqid) AS decoded_sqid FROM test_sqid WHERE (sqidDecode(sqid) NOT IN (SELECT value FROM test_sqid WHERE (value IS NOT NULL AND value = 100)) OR value IS NULL) ORDER BY id;
CREATE TABLE test_sqid_numbers AS SELECT id, sqidDecode(sqid) AS decoded_sqid FROM test_sqid WHERE sqid IS NOT NULL;
INSERT INTO test_sqid_numbers SELECT id, sqidDecode(sqid) FROM test_sqid WHERE sqidDecode(sqid) NOT IN (SELECT decoded_sqid FROM test_sqid_numbers);
SELECT decoded_sqid, COUNT(*) AS count FROM test_sqid_numbers GROUP BY decoded_sqid HAVING count > 1;
SELECT a.id, a.sqid, a.value FROM test_sqid a JOIN test_sqid b ON a.value NOT IN (SELECT value FROM test_sqid WHERE sqidDecode(sqid) LIKE '3%') WHERE a.sqid IS NOT NULL ORDER BY a.id;