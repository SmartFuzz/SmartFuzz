CREATE TABLE test_strings (id UInt32, haystack String, needle String) ENGINE = Memory;
INSERT INTO test_strings VALUES (1, 'aaaa', 'a'), (2, 'abcdefg', 'abc'), (3, '', 'test'), (4, 'abcabc', 'abc');
SELECT id, countSubstrings(haystack, needle) AS occurrences FROM test_strings WHERE countSubstrings(haystack, needle) > 0;
SELECT id, countSubstrings(haystack, needle) AS occurrences FROM test_strings HAVING occurrences > countSubstrings(haystack, 'c');
SELECT countSubstrings(haystack, needle) AS count, id FROM test_strings WHERE count > 1 GROUP BY id HAVING count > countSubstrings('abc', 'a');
SELECT id, (SELECT countSubstrings(haystack, needle) FROM test_strings) AS substring_count FROM test_strings WHERE id > (SELECT COUNT(*) FROM test_strings);
CREATE TABLE another_table (elem String) ENGINE = Memory;
INSERT INTO another_table VALUES ('test1'), ('test2'), ('test3');
SELECT at.id, countSubstrings(at.haystack, at.needle) AS substring_count FROM test_strings AS at JOIN another_table AS bt ON countSubstrings(at.haystack, bt.elem) > 0;
SELECT *, (countSubstrings(haystack, needle) + countSubstrings('aaa', 'a')) / countSubstrings(haystack, '') AS calculation FROM test_strings WHERE calculation > 0;
CREATE TEMPORARY TABLE temp_table AS SELECT id, countSubstrings(haystack, needle) AS total FROM test_strings;
SELECT total FROM temp_table WHERE total > (SELECT countSubstrings('abababab', 'ab'));
SELECT countSubstrings(haystack, needle) FROM test_strings WHERE needle IS NOT NULL AND haystack = '' OR countSubstrings(haystack, needle) > 2;