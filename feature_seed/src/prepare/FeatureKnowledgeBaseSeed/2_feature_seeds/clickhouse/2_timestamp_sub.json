CREATE TABLE test_timestamps (id Int32, event_time DateTime, interval_value Int32, date_unit String);
INSERT INTO test_timestamps VALUES (1, toDateTime('2023-01-01 00:00:00'), 5, 'MONTH'), (2, toDateTime('2023-06-30 12:30:45'), 3, 'YEAR');
SELECT id, event_time, timestamp_sub(date_unit, interval_value, event_time) as subtracted_time FROM test_timestamps WHERE interval_value < 10;
SELECT id, event_time, (timestamp_sub('DAY', 1, event_time) - timestamp_sub('HOUR', 3, event_time)) as time_difference FROM test_ttimestamps;
SELECT id, event_time, timestamp_sub('MONTH', interval_value, event_time + INTERVAL NULL) as invalid_subtraction FROM test_timestamps;
SELECT id, timestamp_sub('HOUR', 10, event_time) as ten_hours_ago FROM test_timestamps WHERE event_time > toDateTime('2023-01-01 00:00:00');
SELECT id, event_time, timestamp_sub('MONTH', (MAX(interval_value) - 1), event_time) as max_subtraction FROM test_ttimestamps GROUP BY id, event_time HAVING max_subtraction > toDateTime('2022-01-01 00:00:00');
CREATE TABLE temp_timestamps AS SELECT id, timestamp_sub('MINUTE', interval_value, event_time) as new_time FROM test_timestamps WHERE event_time IS NOT NULL;
SELECT a.id, a.event_time, b.new_time FROM test_timestamps a JOIN temp_timestamps b ON timestamp_sub('SECOND', 10, a.event_time) = b.new_time;
SELECT id, date_unit, COUNT(*) as count FROM test_timestamps GROUP BY date_unit HAVING count > 1;