CREATE TABLE test_dates (id Int32, dateString String);
INSERT INTO test_dates VALUES (1, '2023-01-01 10:20:30'), (2, 'Invalid Date'), (3, '2020-02-30'), (4, '');
SELECT id, parseDateTime32BestEffortOrNull(dateString) AS parsedDate FROM test_dates;
SELECT id, parsedDate - toUnixTimestamp(currentDate()) AS dateDiff FROM (SELECT id, parseDateTime32BestEffortOrNull(dateString) AS parsedDate FROM test_dates);
SELECT id, dateDiff FROM (SELECT id, parseDateTime32BestEffortOrNull(dateString) - toUnixTimestamp(currentDate()) AS dateDiff FROM test_dates) WHERE dateDiff IS NOT NULL;
CREATE TABLE test_num_dates (num Int32, dateString String, anotherDate String);
INSERT INTO test_num_dates VALUES (1, '2023-01-01 10:20:30', '2023-06-01 12:15:45'), (2, 'Invalid', 'Invalid'), (3, '2020-02-30', '2020-03-01'), (4, NULL, '2022-12-15');
SELECT num, parseDateTime32BestEffortOrNull(dateString) - parseDateTime32BestEffortOrNull(anotherDate) AS dateDifference FROM test_num_dates;
SELECT num, dateDifference FROM (SELECT num, parseDateTime32BestEffortOrNull(dateString) - parseDateTime32BestEffortOrNull(anotherDate) AS dateDifference FROM test_num_dates WHERE parseDateTime32BestEffortOrNull(dateString) IS NOT NULL AND parseDateTime32BestEffortOrNull(anotherDate) IS NOT NULL);
SELECT id, (parseDateTime32BestEffortOrNull(dateString) - 1609459200) AS dateOffset FROM test_dates WHERE dateString IS NOT NULL;
SELECT id, parsedDate FROM (SELECT id, parseDateTime32BestEffortOrNull(dateString) AS parsedDate FROM test_dates) HAVING parsedDate IS NOT NULL ORDER BY parsedDate DESC;