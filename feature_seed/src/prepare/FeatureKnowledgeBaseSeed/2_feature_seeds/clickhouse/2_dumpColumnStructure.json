CREATE TABLE test_table (id UInt32, event_time DateTime, value Float64, description String);
INSERT INTO test_table VALUES (1, '2023-01-01 00:00:00', 1.23, 'Initial event'), (2, '2023-01-02 00:00:00', 3.45, 'Second event');
SELECT dumpColumnStructure(GLOBAL IN (SELECT event_time FROM test_table WHERE value > 0));
SELECT id, dumpColumnStructure(GLOBAL IN (event_time, description)) AS col_structure FROM test_table WHERE id IN (SELECT id FROM test_table WHERE event_time > '2023-01-01 00:00:00');
SELECT value, dumpColumnStructure(CAST(NULL AS Float64)) AS null_structure FROM test_table GROUP BY value HAVING value IS NOT NULL;
SELECT event_time, dumpColumnStructure(CAST(value AS String)) AS str_structure FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value < 5) ORDER BY event_time DESC;
SELECT id, dumpColumnStructure(GLOBAL IN (SELECT CAST(value AS String) FROM test_table WHERE event_time = '2023-01-01 00:00:00')) AS nested_structure FROM test_table WHERE event_time BETWEEN '2023-01-01 00:00:00' AND '2023-01-02 00:00:00';
SELECT dumpColumnStructure(GLOBAL IN (SELECT DISTINCT event_time FROM test_table)) AS global_structure, COUNT(*) AS event_count FROM test_table GROUP BY value HAVING event_count > 0;