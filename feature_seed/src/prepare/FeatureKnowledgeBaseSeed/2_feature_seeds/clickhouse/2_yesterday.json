CREATE TABLE test_dates (id Int32, event_date Date, event_time DateTime);
INSERT INTO test_dates VALUES (1, yesterday(), yesterday() + INTERVAL 1 HOUR);
INSERT INTO test_dates VALUES (2, yesterday() - INTERVAL 2 DAY, yesterday() - INTERVAL 1 HOUR);
SELECT id, event_date, event_time FROM test_dates WHERE event_date <= yesterday();
SELECT id, COUNT(*) AS events FROM test_dates WHERE event_date <= yesterday() GROUP BY id HAVING events > 1;
SELECT id, max(event_date) AS latest_date FROM test_dates WHERE event_time <= yesterday() + INTERVAL 1 DAY GROUP BY id HAVING latest_date <= yesterday();
SELECT id FROM (SELECT id, COUNT(*) AS count FROM test_dates GROUP BY id HAVING count > 0) AS subquery WHERE id <= (SELECT yesterday());
SELECT id, event_date, event_time FROM test_dates WHERE event_time <= (SELECT yesterday() + INTERVAL 1 DAY) AND event_date <= yesterday();
CREATE TABLE test_null (id Int32, nullable_date Date DEFAULT NULL);
INSERT INTO test_null VALUES (1, NULL), (2, yesterday());
SELECT id FROM test_null WHERE nullable_date <= yesterday();
SELECT id FROM test_null WHERE nullable_date IS NULL OR nullable_date <= yesterday();
CREATE TABLE test_join (user_id Int32, login_time DateTime);
INSERT INTO test_join VALUES (1, yesterday() + INTERVAL 3 HOUR), (2, yesterday() - INTERVAL 1 DAY);
SELECT t1.id FROM test_dates AS t1 JOIN test_join AS t2 ON t1.event_time <= t2.login_time WHERE t2.login_time <= yesterday();
SELECT t1.id, (SELECT COUNT(*) FROM test_dates WHERE event_date <= yesterday()) AS date_count FROM test_dates AS t1 WHERE EXISTS (SELECT 1 FROM test_join WHERE user_id = t1.id AND login_time <= yesterday());