CREATE TABLE test_data_1 (x UInt8, y Float64) ENGINE = Memory;
INSERT INTO test_data_1 VALUES (3, 2.0), (3, NULL), (4, 4.5), (4, 5.1), (5, 5.5), (7, 8.0);
CREATE TABLE test_data_2 (group_id UInt8, value UInt8) ENGINE = Memory;
INSERT INTO test_data_2 VALUES (1, 1), (1, 2), (1, 3), (2, 10), (2, 11), (2, NULL);
SELECT group_id, varPop(array(x)) AS var_pop FROM (SELECT x, y FROM test_data_1 WHERE y IS NOT NULL) GROUP BY group_id;
SELECT t1.group_id, varPop([y, y + 1.5]) AS var_variance FROM test_data_2 t1 JOIN (SELECT x, y FROM test_data_1 WHERE x > 3) t2 ON t1.value = t2.x GROUP BY t1.group_id HAVING var_variance IS NOT NULL;
CREATE TABLE test_data_3 AS SELECT arrayJoin([1, 2, 3]) AS a, varPop(a) AS population_variance FROM test_data_1;
SELECT varPop(COALESCE(array[NULL, 5, 8], [2, 3])) AS adjusted_variance;
SELECT varPop(array(SELECT distinct x FROM test_data_1 WHERE x IS NOT NULL)) AS distinct_variance;
SELECT t1.x, varPop(array(t1.y, COALESCE(t1.y, 0))) AS variance_with_coalesce FROM test_data_1 t1 LEFT JOIN test_data_2 t2 ON t1.x = t2.value GROUP BY t1.x;
SELECT group_id, varPop(arrayJoin(array[y, y + 2, y * 2])) AS multi_expression_variance FROM test_data_2 GROUP BY group_id HAVING multi_expression_variance > 0;