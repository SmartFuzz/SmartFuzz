CREATE TABLE test_arrays (id UInt32, values Array(Int32));
INSERT INTO test_arrays VALUES (1, [NULL, 1, 2, 3, 4, 5]), (2, [10, 20, NULL, 40]), (3, []);
SELECT id FROM test_arrays WHERE arraySlice(values, 1, 2) NOT BETWEEN [1] AND [4];
SELECT id, arraySlice(values, -2, 1) AS sliced_value FROM test_arrays WHERE sliced_value NOT BETWEEN 1 AND 5;
SELECT id, arraySlice(values, 2) AS sliced FROM test_arrays WHERE arraySlice(sliced, 1) NOT BETWEEN 2 AND 3;
CREATE TABLE test_join (id UInt32, val Int32);
INSERT INTO test_join VALUES (1, 5), (2, 8), (3, NULL);
SELECT a.id FROM test_arrays a JOIN test_join b ON arraySlice(a.values, 1, 1) NOT BETWEEN [b.val] AND [10];
SELECT a.id, arraySlice(b.values, -1) AS last_elem FROM test_arrays a LEFT JOIN test_arrays b ON a.id NOT BETWEEN b.id AND b.id + 1;
SELECT arraySlice(values, IF(arraySlice(values, -1, 1) IS NULL, 1, -1)) AS adjusted_slice FROM test_arrays GROUP BY adjusted_slice HAVING adjusted_slice NOT BETWEEN arraySlice(values, 1, 1) AND 3;