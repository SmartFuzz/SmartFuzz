CREATE TABLE test_arrays (id UInt32, arr Array(Int32));
INSERT INTO test_arrays VALUES (1, [1, 2, 3]), (2, []), (3, [4, 5, -6]);
SELECT arrayPopFront(arr) AS first_elem FROM test_arrays WHERE id > 0;
SELECT id, arrayPopFront(arr) * -1 AS neg_first FROM test_arrays WHERE arr IS NOT NULL;
SELECT id, arrayPopFront(arr) AS first_elem FROM test_arrays HAVING first_elem + 10 < 0;
WITH (SELECT COUNT(*) FROM test_arrays) AS total_count SELECT id, arrayPopFront(arr) FROM test_arrays WHERE id = total_count;
CREATE TABLE test_joins (id UInt32, value UInt32);
INSERT INTO test_joins VALUES (1, 10), (2, 20), (3, NULL);
SELECT t1.id, arrayPopFront(t1.arr) * -1 FROM test_arrays t1 JOIN test_joins t2 ON t1.id = t2.id AND t2.value IS NOT NULL;
SELECT id, arrayPopFront(arr) + IF(arrayPopFront(arr) IS NULL, 3, 0) AS adjusted_value FROM test_arrays GROUP BY id HAVING adjusted_value > 0;
WITH (SELECT arrayPopFront(arr) FROM test_arrays WHERE id = 1) AS first_value SELECT -first_value AS negated_value;
SELECT id, arrayPopFront(arr), -arrayPopFront(arr) AS neg_value FROM test_arrays WHERE arrayPopFront(arr) != 0;
SELECT arrayPopFront(NULL) AS result;
CREATE TABLE temp_table AS test_arrays ENGINE = Memory;
SELECT arrayPopFront(arr) FROM temp_table WHERE arr = [];
INSERT INTO temp_table VALUES (4, [7, 8, 9]), (5, [NULL]);
SELECT -arrayPopFront(arr) AS neg_before FROM temp_table WHERE arr IS NOT NULL;