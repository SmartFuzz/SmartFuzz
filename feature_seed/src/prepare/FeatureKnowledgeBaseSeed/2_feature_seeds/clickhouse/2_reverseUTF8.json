CREATE TABLE test_table (id UInt32, name String, value Float64, created_at DateTime DEFAULT now());
INSERT INTO test_table (id, name, value) VALUES (1, 'abc', 123.456), (2, 'def', NULL), (3, '', 0.0);
SELECT id, reverseUTF8(name) AS reversed_name FROM test_table WHERE value + (SELECT COUNT(*) FROM test_table WHERE value IS NOT NULL) > 123;
SELECT id, reverseUTF8(name) AS reversed_name FROM (SELECT id, name, value + 0 AS adjusted_value FROM test_table) WHERE adjusted_value IS NOT NULL;
SELECT id, reverseUTF8(name) AS reversed_name, value FROM test_table WHERE reverseUTF8(name) + CAST(value AS String) LIKE 'a%';
SELECT id, reverseUTF8(name) AS reversed_name FROM test_table WHERE value IS NULL OR value + 1 > (SELECT MAX(value) FROM test_table WHERE value IS NOT NULL);
WITH (SELECT reverseUTF8(name) FROM test_table WHERE id = 1) AS reversed_name SELECT id, reversed_name, value FROM test_table WHERE reversed_name + 'xyz' = 'abcxyz';
SELECT id, reverseUTF8(name) AS reversed_name FROM (SELECT id, name, CAST(value AS String) AS value_str FROM test_table) WHERE value_str LIKE '%.5f';
CREATE TABLE secondary_table (id UInt32, description String, ref_id UInt32, FOREIGN KEY (ref_id) REFERENCES test_table(id));
INSERT INTO secondary_table (id, description, ref_id) VALUES (1, 'Test ', 1), (2, 'Edge Case', NULL);
SELECT a.id, reverseUTF8(a.name) AS reversed_name, b.description FROM test_table a JOIN secondary_table b ON a.id = b.ref_id WHERE b.id IS NOT NULL AND (a.value + 0.1) > (SELECT AVG(value) FROM test_table);
SELECT id, reverseUTF8(name) AS reversed_name FROM test_table WHERE reverseUTF8(name + '') <> '' AND (value IS NULL OR value > 0);
SELECT id, reverseUTF8(name) AS reversed_name, SUM(value) OVER (PARTITION BY created_at ORDER BY id) AS running_total FROM test_table;
SELECT reverseUTF8(GROUP_CONCAT(name)) AS all_reversed_names FROM (SELECT name FROM test_table GROUP BY id HAVING COUNT(*) > 1);