CREATE TABLE test_table (id Int32, value String, float_value Float64);
INSERT INTO test_table VALUES (1, '-2147483649'), (2, '3.14'), (3, 'NaN'), (4, '42.99999');
SELECT id, toInt32(value), NOT toInt32(value = '42.99999') AS negated FROM test_table WHERE NOT value = 'NaN';
SELECT id, toInt32(float_value), NOT (SELECT toInt32(value) FROM test_table WHERE id = 1) AS negated_subquery FROM test_table;
SELECT id, NOT (toInt32(value) + 1) AS negated_addition FROM test_table GROUP BY id HAVING negated_addition < -42;
SELECT t1.id, t2.value, NOT (toInt32(t1.value) = toInt32(t2.value)) AS negation_check FROM test_table AS t1 JOIN test_table AS t2 ON NOT t1.id = t2.id;
SELECT id, value, toInt32(NOT (value = '3.14')) AS negated_converted FROM test_table WHERE NOT value = '';
SELECT id, NOT toInt32(value) - (SELECT MAX(toInt32(float_value)) FROM test_table) AS result FROM test_table WHERE NOT value = '-2147483649' GROUP BY id ORDER BY result DESC;