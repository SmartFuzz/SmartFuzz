CREATE TABLE test_strings (id UInt32, text1 String, text2 String, multiplier UInt8);
INSERT INTO test_strings VALUES (1, 'clickhouse', 'mouse', 2), (2, 'test', 'jest', 1), (3, '', '', 5);
SELECT editDistance(text1, text2) * multiplier AS adjusted_distance FROM test_strings WHERE adjusted_distance > 0;
SELECT id, editDistance(text1, text2) * multiplier AS distance FROM test_strings HAVING distance < 5;
WITH (SELECT text1, text2 FROM test_strings WHERE id = 1) AS subquery SELECT editDistance((SELECT text1 FROM subquery), (SELECT text2 FROM subquery)) AS distance;
SELECT id, editDistance(text1, text2) * 10 AS scaled_distance FROM test_strings WHERE scaled_distance IS NOT NULL;
SELECT text1, text2, editDistance(text1, text2) * multiplier AS calculated_distance FROM test_strings GROUP BY text1, text2 HAVING calculated_distance < 5;
CREATE TABLE test_numeric (id UInt32, value1 Float64, value2 String);
INSERT INTO test_numeric VALUES (1, 3.14, '2'), (2, 0.001, '0.0001'), (3, -1, '-0.1');
SELECT value1 * editDistance(value2, '0') AS distance_product FROM test_numeric WHERE distance_product < 10;