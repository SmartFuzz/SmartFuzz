CREATE TABLE test_dates (id UInt32, event_time DateTime, description String);
INSERT INTO test_dates VALUES (1, '2023-05-20 14:11:29', 'Event 1'), (2, '1993-10-05 05:20:36', 'Event 2'), (3, NULL, 'Event 3');
SELECT id, toRelativeSecondNum(event_time) AS seconds_elapsed FROM test_dates WHERE toRelativeSecondNum(event_time) > 0;
SELECT id, event_time, toRelativeSecondNum(event_time) AS seconds FROM test_dates WHERE event_time IS NOT NULL AND seconds > 1000000;
SELECT id, toRelativeSecondNum(event_time) AS seconds_1, toRelativeSecondNum(toDateTime('1990-01-01 00:00:00')) AS seconds_2 FROM test_dates HAVING seconds_1 > seconds_2;
SELECT id FROM (SELECT id, toRelativeSecondNum(event_time) AS seconds_elapsed FROM test_dates WHERE event_time IS NOT NULL) AS derived WHERE seconds_elapsed > (SELECT max(toRelativeSecondNum(event_time)) FROM test_dates);
CREATE TABLE secondary_dates (rel_id UInt32, event_time DateTime);
INSERT INTO secondary_dates VALUES (1, '2000-01-01 00:00:01'), (2, '2001-01-01 00:00:01'), (3, NULL);
SELECT sd.rel_id, toRelativeSecondNum(sd.event_time) AS seconds_rel FROM secondary_dates sd JOIN test_dates td ON sd.rel_id = td.id WHERE toRelativeSecondNum(td.event_time) > toRelativeSecondNum(td.event_time) + 10000;
SELECT MAX(toRelativeSecondNum(td.event_time)) FROM test_dates GROUP BY id HAVING MAX(toRelativeSecondNum(td.event_time)) > 10000 AND MAX(toRelativeSecondNum(td.event_time)) IS NOT NULL;
ALTER TABLE test_dates ADD COLUMN additional_info String DEFAULT '';
SELECT id, toRelativeSecondNum(event_time) AS seconds_elapsed, additional_info FROM test_dates WHERE additional_info = '' AND seconds_elapsed > 0;