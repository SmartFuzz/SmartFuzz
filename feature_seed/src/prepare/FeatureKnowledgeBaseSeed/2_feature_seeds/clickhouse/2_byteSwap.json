CREATE TABLE test_table (id UInt32, value Int32, text_value String, nullable_value Nullable(Int32));
INSERT INTO test_table (id, value, text_value, nullable_value) VALUES (1, 2147483647, 'test', NULL), (2, -2147483648, 'example', 100);
SELECT id, byteSwap(value) AS swapped_value FROM test_table WHERE byteSwap(value) >= 0;
SELECT id, value, byteSwap(value) AS swapped_value FROM test_table WHERE swapped_value >= (SELECT byteSwap(MAX(value)) FROM test_table);
SELECT id, COUNT(*) AS count FROM test_table GROUP BY byteSwap(value) HAVING count > 1;
SELECT t1.id, t1.value FROM test_table t1 JOIN test_table t2 ON byteSwap(t1.value) >= byteSwap(t2.value) WHERE t1.id <> t2.id;
SELECT id, byteSwap(nullable_value) AS swapped_nullable FROM test_table WHERE swapped_nullable >= 0 AND text_value IS NOT NULL;
SELECT id, byteSwap(value) AS swapped_value FROM test_table WHERE swapped_value >= (SELECT byteSwap(0) FROM test_table WHERE id = 1);
DROP TABLE IF EXISTS temp_table;
CREATE TABLE temp_table AS SELECT id, byteSwap(value) AS swapped_value FROM test_table;
SELECT * FROM temp_table WHERE swapped_value IS NOT NULL;
SELECT id FROM test_table WHERE NOT (byteSwap(value) >= 0) AND (text_value = '');