CREATE TABLE file_sizes (id UInt32, filesize_bytes UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO file_sizes VALUES (1, 1), (2, 1024), (3, 1048576), (4, 192851925), (5, NULL);
SELECT id, formatReadableSize(filesize_bytes) AS readable_size FROM file_sizes WHERE filesize_bytes IS NOT NULL;
SELECT id, NOT (filesize_bytes IS NULL) AS is_not_null FROM file_sizes;
SELECT id, formatReadableSize(NOT filesize_bytes) AS inverted_readable_size FROM file_sizes WHERE filesize_bytes IS NOT NULL;
SELECT id, formatReadableSize(filesize_bytes) AS readable_size FROM (SELECT filesize_bytes FROM file_sizes WHERE filesize_bytes IS NOT NULL) AS subquery;
SELECT id, formatReadableSize(filesize_bytes) AS readable_size FROM file_sizes WHERE NOT (filesize_bytes < 0) AND filesize_bytes IS NOT NULL;
SELECT id, NOT (filesize_bytes IS NULL) AS is_not_null, formatReadableSize(filesize_bytes + 1) AS incremented_readable_size FROM file_sizes;
SELECT id, formatReadableSize(filesize_bytes) AS readable_size FROM file_sizes GROUP BY id HAVING NOT (count(filesize_bytes) = 0);
WITH (SELECT SUM(filesize_bytes) FROM file_sizes) AS total_bytes SELECT formatReadableSize(total_bytes) AS total_readable_size;
SELECT id, formatReadableSize(COALESCE(filesize_bytes, 0)) AS safe_readable_size FROM file_sizes;
SELECT id, formatReadableSize(CASE WHEN filesize_bytes IS NULL THEN 0 ELSE filesize_bytes END) AS conditional_readable_size FROM file_sizes;
ALTER TABLE file_sizes ADD COLUMN description String;
UPDATE file_sizes SET description = 'File size in readable format: ' || formatReadableSize(filesize_bytes) WHERE filesize_bytes IS NOT NULL;
INSERT INTO file_sizes VALUES (6, 0), (7, 999999999999999), (8, 4294967295);