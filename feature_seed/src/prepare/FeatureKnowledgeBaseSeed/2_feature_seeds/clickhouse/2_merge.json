CREATE TABLE test_table_1 (id UInt32, value Float64, date DateTime, str_value String);
INSERT INTO test_table_1 VALUES (1, 10.5, '2023-10-01 12:00:00', 'text1'), (2, 20.75, '2023-10-01 12:00:01', 'text2'), (3, NULL, NULL, 'text3');
SELECT merge('default', 'test_table_.*') AS merged_table, AVG(value) * 2 AS avg_doubled FROM test_table_1 GROUP BY merged_table HAVING avg_doubled > 15.0;
SELECT id, value * (SELECT MAX(value) FROM test_table_1 WHERE value IS NOT NULL) AS adjusted_value FROM test_table_1 WHERE str_value LIKE '%text%' ORDER BY adjusted_value DESC;
SELECT id, value, str_value, merge('default', 'test_table_.*') AS merged FROM test_table_1 WHERE value * (CASE WHEN str_value IS NULL THEN 0 ELSE 1 END) > 5.0;
SELECT DISTINCT id, value * CAST(NULL AS Float64) AS null_cast FROM test_table_1 WHERE str_value IS NOT NULL AND date >= '2023-10-01 00:00:00' ORDER BY null_cast DESC;
CREATE TABLE test_table_2 (col1 Nullable(Int32), col2 Float32, col3 String, PRIMARY KEY (col1));
INSERT INTO test_table_2 VALUES (1, 0.5, 'row1'), (2, NULL, 'row2'), (NULL, 10.5, 'row3');
SELECT id, merge('default', 'test_table_.*') AS merged_tables, COUNT(1) * ((SELECT COUNT(*) FROM test_table_1) + 1) AS total_count FROM test_table_1 GROUP BY merged_tables HAVING total_count < 5;
DROP TABLE IF EXISTS test_table_1;