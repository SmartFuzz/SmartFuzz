CREATE TABLE test_table (id UInt32, name String, tags Array(String), created_at DateTime DEFAULT now());
INSERT INTO test_table (id, name, tags) VALUES (1, 'Test', ['Tag1', 'Tag2']), (2, 'Another Test', []);
SELECT displayName() AS hostname, tags[1] FROM test_table WHERE id = 1;
SELECT displayName() AS hostname, arrayJoin(tags) AS tag FROM test_table WHERE name LIKE '%Test%';
SELECT displayName() AS hostname, count(*) FROM test_table GROUP BY tags[1];
SELECT displayName() AS hostname, COUNT(*) OVER (PARTITION BY tags[1]) AS tag_count FROM test_table;
SELECT displayName() AS hostname, (SELECT count(*) FROM test_table WHERE name LIKE '%Test%') AS test_count FROM test_table LIMIT 1;
SELECT displayName() AS hostname, tags[0] FROM test_table WHERE created_at < toDateTime(NOW() - INTERVAL 1 DAY);
CREATE TABLE test_table2 (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table2 (id, value) VALUES (1, 1.234), (2, NULL), (3, 0.00004321);
SELECT displayName() AS hostname, (value + 0.0001) AS adjusted_value FROM test_table2 WHERE value IS NOT NULL;
SELECT displayName(), arrayReduce('max', tags) AS max_tag FROM test_table GROUP BY id HAVING max_tag IS NOT NULL;
SELECT displayName(), ARRAY_JOIN(tags, ',') AS tag_list FROM test_table WHERE NOT isEmpty(tags);
ALTER TABLE test_table ADD COLUMN extra_info String;
CREATE TEMPORARY TABLE temp_table AS SELECT * FROM test_table WHERE name IS NULL;
SELECT displayName() AS hostname, arrayReverse(tags)[1] FROM test_table WHERE id = (SELECT id FROM test_table WHERE name = 'Another Test');