CREATE TABLE test_table (id UInt32, value String, decimal_value Decimal(18, 3), scale UInt8);
INSERT INTO test_table (id, value, decimal_value, scale) VALUES (1, '123.456', toDecimal64('123.456', 3), 3), (2, '200.0001', toDecimal64(200.0001, 4), 4), (3, '0.999999999999', toDecimal64('0.999999999999', 12), 12), (4, 'NaN', NULL, 0);
SELECT id, value, decimal_value FROM test_table WHERE toDecimal64(value, scale) NOT BETWEEN toDecimal64('100.000', 3) AND toDecimal64('200.000', 3);
SELECT id, value, decimal_value FROM test_table WHERE NOT (scale < 3 OR scale > 4);
SELECT id, toDecimal64(value, 5) AS converted_value FROM test_table WHERE toDecimal64(value, 5) NOT BETWEEN toDecimal64('100.00', 2) AND toDecimal64('500.00', 2) HAVING converted_value IS NOT NULL;
SELECT id, SUM(toDecimal64(value, 3)) AS total_decimals FROM test_table GROUP BY id HAVING total_decimals NOT BETWEEN 100 AND 300;
SELECT t1.id, t1.value, t2.value AS other_value FROM test_table t1 JOIN test_table t2 ON toDecimal64(t1.value, 2) NOT BETWEEN toDecimal64(t2.value, 3) AND toDecimal64('400.00', 2) WHERE t1.scale IS NOT NULL;
SELECT id, COUNT(*) FROM test_table GROUP BY id HAVING NOT (toDecimal64(value, scale) NOT BETWEEN 50 AND 150);
SELECT value, toDecimal64(NULLIF(value, ''), 2) AS safe_decimal FROM test_table WHERE NOT (toDecimal64(value, scale) > 100) OR (toDecimal64(value, 4) NOT BETWEEN 10 AND 20);