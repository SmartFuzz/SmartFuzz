CREATE TABLE test_table (id UInt32, text_column String, num_column UInt8, date_column Date) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'ClickHouse is efficient for OLAP.', 255, '2023-10-01'), (2, NULL, NULL, '2023-10-02'), (3, '', 0, '2023-10-03');
SELECT id, wordShingleMinHashArg(text_column, 1, 3) AS hashes FROM test_table WHERE num_column GLOBAL IN (SELECT DISTINCT num_column FROM test_table WHERE id > 1);
SELECT id, wordShingleMinHashArg(COALESCE(text_column, 'default'), 5, 1) AS hashes FROM test_table WHERE id IN (SELECT id FROM test_table WHERE text_column != '');
SELECT id, (SELECT wordShingleMinHashArg(text_column, 2, 4) FROM test_table t2 WHERE t2.id = t1.id AND t2.date_column < '2023-10-02') AS min_hash FROM test_table t1 WHERE text_column IS NOT NULL;
SELECT id, wordShingleMinHashArg(text_column, 3, 2) AS hashes, num_column + 1 AS incremented_num FROM test_table WHERE incremented_num > 0 HAVING incremented_num < 10;
SELECT id, wordShingleMinHashArg(CONCAT(text_column, ' additional text'), 1, 3) AS hashes FROM test_table WHERE date_column > '2023-10-01' AND num_column GLOBAL IN (0, 255);
WITH (SELECT DISTINCT text_column FROM test_table WHERE text_column IS NOT NULL LIMIT 1) AS subquery SELECT id, wordShingleMinHashArg((SELECT * FROM subquery), 10, 5) AS hashes FROM test_table WHERE id < 3;
SELECT id, wordShingleMinHashArg(text_column, 20, 6) AS hashes FROM test_table WHERE num_column = 255 AND (id < 3) GLOBAL IN (SELECT id FROM test_table WHERE date_column < '2023-10-02');
CREATE TABLE test_table_2 (id UInt32, value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_2 VALUES (1, 1.1), (2, 2.2), (3, NULL);
SELECT t1.id, t2.id, wordShingleMinHashArg(t1.text_column, 3, 6) AS hashes FROM test_table t1 JOIN test_table_2 t2 ON t1.num_column GLOBAL IN (t2.value);