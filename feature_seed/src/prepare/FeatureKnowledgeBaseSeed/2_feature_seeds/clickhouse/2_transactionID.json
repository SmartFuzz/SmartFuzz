CREATE TABLE test_transactions (id UInt32, val String, created_at DateTime DEFAULT now());
INSERT INTO test_transactions (id, val) VALUES (1, 'Test 1'), (2, 'Test 2'), (3, NULL);
BEGIN TRANSACTION;
SELECT transactionID(), val % (SELECT count() FROM test_transactions WHERE id > 1) FROM test_transactions WHERE id <= 2;
ROLLBACK;
BEGIN TRANSACTION;
SELECT val, COUNT(*) OVER (PARTITION BY val % (SELECT count() FROM test_transactions) ORDER BY created_at) FROM test_transactions GROUP BY val;
ROLLBACK;
BEGIN TRANSACTION;
SELECT transactionID(), max(val) % min(ifNULL(id, 0)) FROM test_transactions HAVING max(val) IS NOT NULL;
ROLLBACK;
BEGIN TRANSACTION;
SELECT transactionID(), val % CAST((SELECT id FROM test_transactions ORDER BY created_at DESC LIMIT 1) AS UInt32) FROM test_transactions WHERE val IS NOT NULL;
ROLLBACK;
BEGIN TRANSACTION;
SELECT transactionID(), avg(id + (SELECT count() FROM test_transactions) % 2) FROM test_transactions GROUP BY val;
ROLLBACK;
BEGIN TRANSACTION;
SELECT transactionID(), val % (SELECT COUNT(*) FROM (SELECT DISTINCT val FROM test_transactions));
ROLLBACK;
BEGIN TRANSACTION;
SELECT transactionID(), val FROM test_transactions WHERE id = (SELECT id FROM test_transactions WHERE val IS NULL LIMIT 1);
ROLLBACK;
BEGIN TRANSACTION;
SELECT transactionID(), val % (SELECT count() FROM test_transactions where val IS NOT NULL AND id < 3) FROM test_transactions WHERE id > 0;
ROLLBACK;