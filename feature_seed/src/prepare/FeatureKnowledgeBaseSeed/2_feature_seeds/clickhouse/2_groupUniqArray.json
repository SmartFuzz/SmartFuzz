CREATE TABLE test_table (id UInt64, value Array(Int32), created_at DateTime, status Nullable(String));
INSERT INTO test_table VALUES (1, [1, 2, 2, 3], '2023-10-01 00:00:00', 'active'), (2, [3, 4, 5], '2023-10-02 00:00:00', NULL), (3, [], '2023-10-03 00:00:00', 'inactive');
SELECT id, groupUniqArray(value) AS unique_values FROM test_table GROUP BY id HAVING arrayExists(x -> x > 2, unique_values);
SELECT id, value[n] AS nth_value FROM (SELECT id, groupUniqArray(value) AS value FROM test_table GROUP BY id) WHERE id = 1 AND n = arrayLength(value);
SELECT id, groupUniqArray(max_size)(value) AS limited_unique_values FROM test_table WHERE status IS NOT NULL GROUP BY id HAVING arrayLength(limited_unique_values) <= 2;
WITH (SELECT id, groupUniqArray(value)[1] AS first_value FROM test_table WHERE status IS NOT NULL) AS subquery SELECT * FROM subquery WHERE first_value IS NOT NULL;
SELECT a.id, groupUniqArray(a.value) AS unique_elements FROM test_table AS a JOIN test_table AS b ON a.id = b.id WHERE a.created_at < b.created_at GROUP BY a.id;
SELECT id, groupUniqArray(value) AS unique_values FROM test_table GROUP BY id HAVING status IS NULL AND arrayJoin(unique_values) > 1;
CREATE TEMPORARY TABLE temp_table (temp_value Nullable(Int32), temp_created_at DateTime);
INSERT INTO temp_table VALUES (NULL, '2023-10-04 00:00:00'), (10, '2023-10-05 00:00:00');
SELECT t.temp_value, groupUniqArray(test.value) FROM temp_table AS t LEFT JOIN test_table AS test ON test.created_at > t.temp_created_at GROUP BY t.temp_value;
SELECT groupUniqArray(temp_value) FROM temp_table WHERE temp_value NOT IN (SELECT arrayElement(value, 1) FROM test_table WHERE status = 'active');
SELECT id, groupUniqArray(value) AS unique_values FROM test_table WHERE created_at <= '2023-10-02 00:00:00' GROUP BY id HAVING arrayLength(unique_values) > 0;