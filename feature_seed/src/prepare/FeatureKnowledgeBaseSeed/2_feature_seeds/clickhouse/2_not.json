CREATE TABLE test_table (id UInt32, value Nullable(Float64));
INSERT INTO test_table VALUES (1, 3.14), (2, NULL), (3, 0.0), (4, 1.0);
SELECT id, NOT(value) AS negation FROM test_table WHERE id != ANY (SELECT id FROM test_table WHERE value IS NULL);
SELECT id, NOT(value > 0) AS negation FROM test_table WHERE id != ANY (SELECT id FROM test_table WHERE value = 0.0);
CREATE TABLE another_table (user_id UInt32, score Nullable(Int32));
INSERT INTO another_table VALUES (1, 10), (2, NULL), (3, 5);
SELECT a.id, a.value, NOT(a.value) AS negation FROM test_table a JOIN another_table b ON NOT(a.id != b.user_id) WHERE b.score IS NOT NULL AND a.id != ANY (SELECT user_id FROM another_table WHERE score = 5);
SELECT id, NOT(NULLIF(value, 0.0)) AS negation FROM test_table WHERE value != ANY (SELECT score FROM another_table WHERE score IS NULL);
SELECT id, NOT(MAX(value)) FROM test_table GROUP BY id HAVING id != ANY (SELECT id FROM test_table WHERE value IS NOT NULL) ORDER BY id ASC;