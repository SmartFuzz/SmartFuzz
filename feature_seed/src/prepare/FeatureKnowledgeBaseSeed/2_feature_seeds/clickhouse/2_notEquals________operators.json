CREATE TABLE test_table (id UInt32, value String, timestamp DateTime, amount Float64);
INSERT INTO test_table (id, value, timestamp, amount) VALUES (1, 'test1', '2023-01-01 00:00:00', 100.0), (2, 'test2', '2023-01-02 00:00:00', 200.0), (3, NULL, '2023-01-03 00:00:00', 300.0), (4, 'test4', '2023-01-04 00:00:00', NULL);
SELECT id, value FROM test_table WHERE value NOT IN (SELECT value FROM test_table WHERE amount < 150.0) AND (amount != 300.0);
SELECT * FROM test_table a JOIN (SELECT id, value FROM test_table WHERE amount > 100.0) b ON a.id = b.id WHERE a.value NOT IN (SELECT value FROM test_table WHERE id = ANY(SELECT id FROM test_table WHERE amount > 200.0));
SELECT COUNT(*) OVER() AS total_count FROM test_table WHERE NOT (amount < 150.0) HAVING total_count NOT BETWEEN 0 AND 5;
SELECT id, value FROM test_table WHERE id <> ANY (SELECT id FROM test_table WHERE value = 'test2' OR amount IS NULL);
SELECT id, value FROM test_table WHERE (value IS NULL OR value NOT IN (SELECT value FROM test_table WHERE NOT (id != 4)));
CREATE TEMPORARY TABLE temp_table AS SELECT id, amount FROM test_table WHERE timestamp > '2023-01-01 00:00:00';
INSERT INTO temp_table SELECT id, amount FROM test_table WHERE NOT EXISTS (SELECT 1 FROM temp_table WHERE temp_table.amount = test_table.amount);
SELECT MAX(id) AS max_id, MIN(amount) AS min_amount FROM test_table WHERE NOT (value = 'test3' OR value IS NULL) GROUP BY value HAVING MAX(id) NOT BETWEEN 1 AND 2;