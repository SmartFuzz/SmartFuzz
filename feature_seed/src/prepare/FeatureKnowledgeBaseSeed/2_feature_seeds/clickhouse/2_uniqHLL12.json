CREATE TABLE test_table (id UInt32, value String, created_at DateTime DEFAULT now());
INSERT INTO test_table (id, value) VALUES (1, 'Hello'), (2, 'World'), (3, NULL), (4, 'Test');
SELECT uniqHLL12(value + id) as unique_count FROM test_table GROUP BY created_at HAVING unique_count > 1;
SELECT uniqHLL12(ARRAY[value, CAST(id AS String)]) as unique_array_count FROM test_table;
SELECT (SELECT COUNT(*) FROM (SELECT DISTINCT id + 1 FROM test_table)) + uniqHLL12(value) AS combined_count FROM test_table;
SELECT uniqHLL12(NULLIF(value, '')) + uniqHLL12(value WHERE value IS NOT NULL) AS non_null_unique_count FROM test_table;
SELECT uniqHLL12(CASE WHEN value IS NULL THEN 'No Value' ELSE value END) AS case_unique_count FROM test_table;
WITH (SELECT COUNT(*) FROM test_table) as cnt SELECT uniqHLL12(value) + cnt as count_with_value FROM test_table;
SELECT a.id, uniqHLL12(a.value) + b.value AS combined_uniq FROM test_table a JOIN (SELECT value FROM test_table) b ON a.id = b.id;
INSERT INTO test_table (id, value) VALUES (5, 'Zero'), (6, CAST(3.14 AS String));
SELECT uniqHLL12(CONCAT(CAST(value AS String), toString(id))) FROM test_table;
SELECT uniqHLL12(value) + CAST(NULL AS UInt64) AS null_propagation_test FROM test_table;
SELECT uniqHLL12(Tuple(value, id + 10)) AS tuple_unique_count FROM test_table GROUP BY created_at;
SELECT uniqHLL12((SELECT GROUP_CONCAT(value) FROM test_table WHERE id < 3)) AS correlated_subquery_test;
SELECT COUNT(*) FROM (SELECT DISTINCT uniqHLL12(value + IFNULL(CAST(NULL AS String), value)) FROM test_table) AS unique_counts;