CREATE TABLE ip_addresses (id UInt32, addr String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO ip_addresses VALUES (1, '::'), (2, '1111::ffff'), (3, '::ffff:127.0.0.1'), (4, '127.0.0.1'), (5, ''), (6, NULL);
SELECT id, isIPv6String(addr) AS is_ipv6 FROM ip_addresses WHERE addr != '' GROUP BY id HAVING is_ipv6 = 1;
SELECT id, (addr || ' - ' || toString(isIPv6String(addr))) AS combined FROM ip_addresses ORDER BY combined;
SELECT id, isIPv6String(addr) FROM (SELECT addr || '.1' AS addr FROM ip_addresses) WHERE len(addr) < 20;
SELECT addr, isIPv6String((addr || '::1')) AS check_ipv6 FROM ip_addresses WHERE NOT isIPv6String(addr) AND addr IS NOT NULL;
SELECT addr, count(*) FROM ip_addresses GROUP BY isIPv6String(addr) HAVING count(*) > 1;
SELECT addr FROM (SELECT addr, ROW_NUMBER() OVER (PARTITION BY addr ORDER BY id) as rn FROM ip_addresses) WHERE rn = 1;
SELECT addr, isIPv6String(addr || '::') AS result FROM ip_addresses WHERE addr IS NULL OR addr = '';
SELECT addr, isIPv6String(NULLIF(addr, '')) AS nullable_check FROM ip_addresses;