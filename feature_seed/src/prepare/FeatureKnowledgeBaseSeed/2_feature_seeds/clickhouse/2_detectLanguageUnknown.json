CREATE TABLE lang_test (id UInt32, text String, lang_detected String);
INSERT INTO lang_test VALUES (1, 'Ich bleibe für ein paar Tage.', NULL), (2, 'Привет мир', NULL), (3, 'Hello world', NULL);
UPDATE lang_test SET lang_detected = detectLanguageUnknown(text) WHERE lang_detected IS NULL;
SELECT id, detectLanguageUnknown(text) AS detected_language, a.N FROM (SELECT id, text, lang_detected FROM lang_test) AS a WHERE lang_detected IS NULL;
SELECT id, detectLanguageUnknown(text) AS detected_language FROM lang_test WHERE text LIKE '%';
SELECT id, a.N FROM (SELECT detectLanguageUnknown(text) AS lang_detected, id, text FROM lang_test GROUP BY id, text HAVING lang_detected IS NOT NULL) AS a;
CREATE TABLE test_strings (str String);
INSERT INTO test_strings VALUES (''), (''), ('😀'), ('long text that is unknown and is used to stress test the language detection mechanism');
SELECT detectLanguageUnknown(str), a.N FROM (SELECT tupleElement(collect(str), 1) AS str FROM test_strings GROUP BY str) AS a;
SELECT lang_detected, COUNT(*) FROM lang_test GROUP BY lang_detected HAVING lang_detected IS NOT NULL;
SELECT detectLanguageUnknown(NULL), a.N FROM (SELECT id, text FROM lang_test WHERE id IN (SELECT id FROM lang_test WHERE text != '')) AS a;
SELECT detectLanguageUnknown(text), a.N FROM lang_test JOIN (SELECT id, text FROM lang_test WHERE id % 2 = 0) AS a ON lang_test.id = a.id;