CREATE TABLE test_division_dates (id Int32, num_tuple Tuple(Int32, Int32, Float64), div_tuple Tuple(Int32, Float64, Int32), event_date DateTime);
INSERT INTO test_division_dates VALUES (1, (15, 10, 5), (5, 5.5, 5), '2023-01-01 12:00:00'), (2, (20, 50, 80), (3, 4.0, 0), '2023-02-02 15:30:10');
SELECT id, EXTRACT(YEAR FROM event_date) AS year, tupleIntDiv(num_tuple, div_tuple) AS results FROM test_division_dates WHERE div_tuple.1 > 0;
SELECT id, tupleIntDiv((EXTRACT(DAY FROM event_date), 12, 5), (EXTRACT(MONTH FROM event_date), 0, 3)) AS year_div_results FROM test_division_dates;
CREATE TABLE test_dates (event_id Int32, date_time DateTime, description String);
INSERT INTO test_dates VALUES (1, '2023-01-01 00:00:00', 'New Year'), (2, '2023-02-02 12:30:00', 'Groundhog Day');
SELECT d.event_id, d.description, tupleIntDiv((EXTRACT(SECOND FROM d.date_time), 60), (EXTRACT(MINUTE FROM d.date_time), 1)) AS second_min_div FROM test_dates d JOIN test_division_dates td ON d.event_id = td.id;
SELECT id, tupleIntDiv((EXTRACT(DAY FROM event_date), 12), (EXTRACT(YEAR FROM event_date), 0.0)) AS day_year_results FROM test_division_dates WHERE num_tuple.2 > 5;
WITH (SELECT AVG(EXTRACT(HOUR FROM event_date)) FROM test_division_dates) AS avg_hour SELECT id, tupleIntDiv(num_tuple, (avg_hour, 1)) AS divisor_results FROM test_division_dates WHERE id = 1;
INSERT INTO test_division_dates SELECT 3, (NULL, NULL, NULL), (NULL, NULL, NULL), '2023-03-03 18:00:00';
SELECT tupleIntDiv((EXTRACT(DAY FROM toDate(NULL)), 30), (EXTRACT(MONTH FROM toDate('2023-05-01')), 0)) AS edge_case_div from test_dates;