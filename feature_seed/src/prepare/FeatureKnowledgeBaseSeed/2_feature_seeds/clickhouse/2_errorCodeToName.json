CREATE TABLE test_table (id Int32, value Float64, description LowCardinality(String));
INSERT INTO test_table VALUES (1, 1.5, 'Test'), (2, 0.0, NULL), (3, 100.5, 'Alpha'), (4, -10.75, 'Beta');
SELECT id, errorCodeToName(CAST(value AS Int32)) AS error_name FROM test_table WHERE value BETWEEN -20 AND 0;
SELECT id, errorCodeToName(CAST(SUM(value) OVER (PARTITION BY NULL) AS Int32)) AS aggregate_error FROM test_table GROUP BY id HAVING aggregate_error IN (errorCodeToName(1), errorCodeToName(2));
SELECT a.id, errorCodeToName(b.value) AS error_description FROM test_table a JOIN (SELECT id, value FROM test_table WHERE value IS NOT NULL) b ON a.id BETWEEN 1 AND b.id;
SELECT DISTINCT errorCodeToName(value) FROM test_table WHERE description IS NULL OR description = '';
CREATE TABLE temp_table (grp_id Int32, val Int64) ENGINE = Memory;
INSERT INTO temp_table VALUES (1, 0), (1, 1), (1, 2);
SELECT errorCodeToName(MIN(val)) FROM temp_table WHERE grp_id BETWEEN 1 AND 2;
SELECT errorCodeToName(COALESCE(MAX(val), 0)) AS max_error FROM temp_table GROUP BY grp_id HAVING max_error = errorCodeToName(1);