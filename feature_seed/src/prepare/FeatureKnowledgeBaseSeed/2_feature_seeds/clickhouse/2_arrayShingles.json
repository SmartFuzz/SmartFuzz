CREATE TABLE test_table (id Int32, values Array(Int32), created_at DateTime DEFAULT now());
INSERT INTO test_table (id, values) VALUES (1, [1, 2, 3]), (2, [2, 3]), (3, []), (4, [4, 5, 6, 7, 8, 9]);
SELECT id, arrayShingles(values, 2) AS shingles FROM test_table WHERE arrayShingles(values, 2) = [[1,2],[2,3]];
SELECT id, arrayShingles(values, 3) AS shingles FROM test_table WHERE NOT (arrayShingles(values, 3) = arrayShingles([100, 200, 300], 3));
SELECT id, arrayShingles(values, 2) AS shingles FROM test_table WHERE arrayJoin(shingles) = 1 OR (values = [2, 3] AND shingles IS NOT NULL);
SELECT id, count(*) AS total_shingles FROM (SELECT id, arrayShingles(values, 2) AS shingles FROM test_table GROUP BY id HAVING length(shingles) > 1) GROUP BY id;
SELECT id FROM test_table WHERE arrayLength(arrayShingles(values, 1)) = (SELECT count() FROM test_table WHERE values IS NOT NULL) OR values = [NULL];
SELECT id, sum(if(arrayJoin(arrayShingles(values, 2)) = 2, 1, 0)) AS count_of_twos FROM test_table GROUP BY id HAVING count_of_twos > 0;
CREATE TEMPORARY TABLE temp_table AS SELECT arrayJoin(arrayShingles(values, 3)) AS shingle_values FROM test_table;
SELECT id, value FROM (SELECT id, arrayJoin(temp_table.shingle_values) AS value FROM test_table) WHERE value = 3;