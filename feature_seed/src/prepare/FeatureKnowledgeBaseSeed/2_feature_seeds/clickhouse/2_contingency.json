CREATE TABLE test_table1 (id UInt32, a String, b UInt32, c DateTime);
INSERT INTO test_table1 VALUES (1, 'test', 3, '2023-01-01 10:00:00'), (2, 'sample', 5, '2023-01-01 12:00:00'), (3, 'example', NULL, '2023-01-02 14:00:00');
CREATE TABLE test_table2 (a Float64, b Float64);
INSERT INTO test_table2 VALUES (NULL, 1.5), (2.5, 4.0), (8.0, NULL);
SELECT contingency(a, b) FROM (SELECT id, a, b FROM test_table1 WHERE b NOT BETWEEN 2 AND 6) AS filtered;
SELECT contingency(a, b) FROM (SELECT a, COUNT(b) AS b_count FROM test_table1 GROUP BY a HAVING b_count NOT BETWEEN 1 AND 3) AS grouped;
SELECT t1.id, contingency(t1.a, t2.b) FROM test_table1 t1 JOIN test_table2 t2 ON (t1.b NOT BETWEEN t2.a AND 10) WHERE t1.c < NOW();
SELECT contingency(CAST(a AS Float64), CAST(b AS Float64)) FROM (SELECT a, b FROM test_table1 WHERE a NOT BETWEEN 'A' AND 'Z') AS filtered;
SELECT DISTINCT t1.a, contingency(t1.a, t2.b) FROM test_table1 t1 JOIN test_table2 t2 ON (t1.b NOT BETWEEN 1 AND 10) WHERE t1.c IS NULL GROUP BY t1.a HAVING contingency(t1.a, t2.b) > 0.5;
SELECT a, COUNT(*) as cnt FROM (SELECT a, b FROM test_table1 WHERE b IS NOT NULL AND a NOT BETWEEN 'A' AND 'Z') GROUP BY a HAVING cnt NOT BETWEEN 0 AND 5;
SELECT contingency(a, b) OVER (PARTITION BY a) FROM (SELECT a, b, ROW_NUMBER() OVER (ORDER BY c) as rn FROM test_table1) AS ranked WHERE rn NOT BETWEEN 1 AND 3;