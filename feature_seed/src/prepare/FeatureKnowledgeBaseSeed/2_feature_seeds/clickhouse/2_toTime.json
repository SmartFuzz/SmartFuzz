CREATE TABLE test_dates (id UInt32, event_date DateTime64(3), description String);
INSERT INTO test_dates VALUES (1, toDateTime64('2021-05-20 14:30:45.123', 3), 'Event 1'), (2, toDateTime64('2021-05-20 16:45:55.456', 3), 'Event 2');
SELECT * FROM test_dates WHERE event_date != ALL (SELECT toTime(event_date) FROM test_dates WHERE description = 'Event 1');
SELECT id, toTime(event_date) AS event_time FROM test_dates WHERE event_time != ALL (SELECT toTime(event_date) FROM test_dates WHERE id > 1);
SELECT id, COUNT(*) AS event_count FROM (SELECT DISTINCT id, toTime(event_date) AS event_time FROM test_dates) GROUP BY event_time HAVING event_count > 1;
CREATE TABLE test_numbers (num UInt64, nullable_num Nullable(UInt64));
INSERT INTO test_numbers VALUES (1, NULL), (2, 2), (3, NULL);
SELECT num FROM test_numbers WHERE num != ALL (SELECT toUInt64(NULL) FROM test_numbers WHERE nullable_num IS NULL);
SELECT num, (toTime(toDateTime64(concat('1970-12-01 ', CAST(num AS String)), 3)) > toTime(toDateTime64('1970-12-05 00:00:00',3))) AS is_after FROM test_numbers;
CREATE TABLE temp_join (id UInt32, fk UInt32, value String);
INSERT INTO temp_join VALUES (1, 1, 'A'), (2, 1, 'B'), (3, 2, 'C');
SELECT tj.id, tj.value FROM temp_join tj JOIN test_dates td ON tj.fk != ALL (SELECT toUInt32(td.id) FROM test_dates WHERE td.event_date < toTime(toDateTime64('1970-01-01 01:00:00', 0)));