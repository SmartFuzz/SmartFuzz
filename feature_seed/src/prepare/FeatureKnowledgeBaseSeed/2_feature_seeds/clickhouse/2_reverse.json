CREATE TABLE test_strings (id Int32, value String, created_at DateTime) ENGINE = Memory;
INSERT INTO test_strings (id, value, created_at) VALUES (1, 'Hello World', now()), (2, '', now()), (3, '1234567890', now()), (4, 'Test String', now());
SELECT id, reverse(value) AS reversed_value FROM test_strings WHERE value IS NOT NULL;
SELECT id, reverse(value) AS reversed_value FROM test_strings WHERE multiIf(value = '', true, value IS NOT NULL, false, true) = true;
SELECT id, multiIf(value = '', reverse('empty_string'), reverse(value)) AS processed_value FROM test_strings WHERE id IN (SELECT DISTINCT id FROM test_strings WHERE value LIKE 'Test%');
SELECT id, reverse(value) AS reversed_value FROM test_strings WHERE reverse(value) LIKE multiIf(value = '', 'empty_string', '%World%');
SELECT id, COUNT(*) AS count FROM test_strings GROUP BY multiIf(value = '', 'empty', 'non_empty') HAVING count > 0;
CREATE TABLE secondary_table (group_id Int32, description String) ENGINE = Memory;
INSERT INTO secondary_table (group_id, description) VALUES (1, 'Group A'), (2, NULL), (3, 'Group C');
SELECT s.id, reverse(s.value) AS reversed_value, st.description FROM test_strings s JOIN secondary_table st ON multiIf(s.id = 1, st.group_id = 1, s.id = 2, st.group_id IS NULL) WHERE st.description IS NOT NULL;
SELECT id, reverse(value) FROM test_strings WHERE created_at > (SELECT max(created_at) FROM test_strings WHERE id = (SELECT id FROM test_strings ORDER BY created_at LIMIT 1)) ORDER BY id;
CREATE TABLE edge_cases (case_id Int32, case_value Nullable(String)) ENGINE = Memory;
INSERT INTO edge_cases (case_id, case_value) VALUES (1, NULL), (2, 'test'), (3, 'example');
SELECT case_id, multiIf(case_value IS NULL, 'no value', reverse(case_value)) AS processed_value FROM edge_cases;
SELECT case_id, reverse(CAST(case_id AS String)) AS reversed_id FROM edge_cases;
SELECT multiIf(case_value IS NULL, 'UNCHANGED', reverse(case_value)) AS modified_value FROM edge_cases HAVING modified_value LIKE '%test%';