CREATE TABLE test_table (id UInt32, value String, timestamp DateTime);
INSERT INTO test_table VALUES (1, '100'), (2, '200'), (3, NULL), (4, '300.50');
SELECT * FROM loop(test_table);
SELECT * FROM loop(test_table) WHERE id NOT BETWEEN (SELECT min(id) FROM test_table) AND (SELECT max(id) FROM test_table);
SELECT id, value, timestamp, COUNT(*) OVER (PARTITION BY value) as cnt FROM loop(test_table) GROUP BY value HAVING cnt NOT BETWEEN 1 AND 3;
CREATE TABLE test_table_2 (num Float32, category String) ENGINE = Memory;
INSERT INTO test_table_2 VALUES (1.5, 'A'), (-3.5, 'B'), (2.0, 'C'), (NULL, 'D');
SELECT * FROM loop(test_table_2) WHERE num NOT BETWEEN (SELECT min(num) FROM test_table_2) AND (SELECT max(num) FROM test_table_2) AND category != 'A';
SELECT * FROM loop(test_table) WHERE value NOT BETWEEN CAST('150' AS Int32) AND CAST('500' AS Int32) OR timestamp IS NULL;
SELECT id, value, NULL AS untyped FROM loop(test_table) WHERE untyped NOT BETWEEN (SELECT min(id) FROM test_table) AND (SELECT max(id) FROM test_table);
CREATE TABLE test_table_3 (id UInt16, score Nullable(Int32), created_at Date);
INSERT INTO test_table_3 VALUES (1, 90, '2023-01-01'), (2, NULL, '2023-01-02'), (3, 75, '2023-01-03');
SELECT * FROM loop(test_table_3) WHERE score NOT BETWEEN (SELECT score FROM test_table_3 WHERE id = 2) AND 100;