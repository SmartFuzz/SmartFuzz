CREATE TABLE test_hypot (id UInt32, cathetus_a Float64, cathetus_b Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_hypot VALUES (1, 3.0, 4.0), (2, NULL, 5.0), (3, -3.0, -4.0), (4, 1.0, 1.0), (5, 1e-10, 1e-10);
SELECT hypot(cathetus_a, cathetus_b) AS hypotenuse FROM test_hypot WHERE hypot(cathetus_a, cathetus_b) <= 5.0;
SELECT id, hypot(cathetus_a, cathetus_b) AS hypotenuse FROM test_hypot HAVING hypot(cathetus_a, cathetus_b) <= (SELECT MAX(cathetus_a) FROM test_hypot WHERE cathetus_a IS NOT NULL);
SELECT id, hypot(ABS(cathetus_a), ABS(cathetus_b)) AS hypotenuse FROM test_hypot WHERE hypot(ABS(cathetus_a), ABS(cathetus_b)) IS NOT NULL;
SELECT id, hypot(-cathetus_a, -cathetus_b) AS hypotenuse FROM test_hypot WHERE hypot(-cathetus_a, -cathetus_b) <= (SELECT AVG(cathetus_a) FROM test_hypot WHERE cathetus_a IS NOT NULL);
CREATE TABLE test_hypot_edge (id UInt32, cathetus_a Nullable(Float64), cathetus_b Nullable(Float64)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_hypot_edge VALUES (1, 0.0, 0.0), (2, NULL, 5.0), (3, -1e+308, -1e+308), (4, -20.0, 15.0);
SELECT id, hypot(cathetus_a, cathetus_b) AS hypotenuse FROM test_hypot_edge WHERE hypot(cathetus_a, cathetus_b) <= 15.0;
SELECT id, hypot(ROUND(cathetus_a, 5), ROUND(cathetus_b, 5)) AS hypotenuse FROM test_hypot_edge WHERE hypot(ROUND(cathetus_a, 5), ROUND(cathetus_b, 5)) IS NOT NULL;