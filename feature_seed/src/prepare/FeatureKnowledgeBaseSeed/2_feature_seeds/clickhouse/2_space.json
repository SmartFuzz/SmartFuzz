CREATE TABLE test_cases (id UInt32, value String, num Int32);
INSERT INTO test_cases VALUES (1, 'test', 3), (2, 'edge case', -1), (3, '', 0), (4, 'long space', 100);
SELECT id, space(2 + num) AS repeated_space FROM test_cases WHERE repeated_space > space(0);
SELECT id, value, space(num) AS spaced_value FROM test_cases WHERE num > 0 HAVING spaced_value > space(0) ORDER BY spaced_value;
SELECT id, (SELECT COUNT(*) FROM test_cases t2 WHERE t2.num > test_cases.num AND value > space(0)) AS greater_count FROM test_cases;
SELECT id, space(num) AS spaced_value, count() OVER (PARTITION BY space(num)) AS value_count FROM test_cases GROUP BY id, spaced_value HAVING value_count > 1;
CREATE TABLE temp_table AS SELECT id, space(num) AS spaced_column FROM test_cases WHERE num > -5;
SELECT id, value, space(num * 2) AS double_space FROM test_cases WHERE value IS NOT NULL AND double_space > space(1);
SELECT id FROM test_cases WHERE (space(num) || value) > space(3) ORDER BY id;
ALTER TABLE test_cases ADD COLUMN extra_space String DEFAULT space(num);
SELECT id, space(num) AS repeated_space FROM test_cases WHERE repeated_space IS NOT NULL AND repeated_space > space(5);