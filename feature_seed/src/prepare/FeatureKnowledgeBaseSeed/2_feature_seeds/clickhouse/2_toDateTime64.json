CREATE TABLE test_dates (id UInt32, date_col String, precision UInt32, timezone String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_dates VALUES (1, '2023-01-01 00:00:00', 3, 'UTC'), (2, 'not a date', 5, 'Europe/London'), (3, NULL, 2, 'America/New_York');
SELECT id, toDateTime64(date_col, precision) AS datetime_value, timezone, (date_col IS NOT NULL ? toDateTime64(date_col, precision) : NULL) AS conditional_datetime FROM test_dates;
SELECT id, toDateTime64(date_col, precision) AS datetime_value, (SELECT COUNT() FROM test_dates WHERE toDateTime64(date_col, precision) IS NOT NULL) AS valid_dates_count FROM test_dates WHERE precision > 2;
SELECT id, toDateTime64(CAST(NULLIF(date_col, ''), '1970-01-01 00:00:00'), precision) AS datetime_value FROM test_dates WHERE (precision > 0 ? 1 : 0) = 1 GROUP BY id HAVING toString(datetime_value) IS NOT NULL;
SELECT id, (CASE WHEN date_col LIKE '202%' THEN toDateTime64(date_col, precision) ELSE toDateTime64('1970-01-01 00:00:00', 2) END) AS conditional_datetime FROM test_dates WHERE precision < 4 ORDER BY conditional_datetime;
SELECT A.id, A.date_col, B.other_value, toDateTime64(CASE WHEN A.date_col IS NOT NULL THEN A.date_col ELSE '1970-01-01 00:00:00' END, A.precision) AS conditionally_converted FROM test_dates AS A JOIN (SELECT id, precision FROM test_dates WHERE id = 1) AS B ON A.id = B.id;
CREATE TABLE temp_dates AS SELECT id, toDateTime64(date_col, precision, timezone) FROM test_dates WHERE date_col IS NOT NULL;
INSERT INTO temp_dates SELECT id, '2024-02-29 12:00:00' AS date_col, 5 FROM test_dates WHERE precision = 2;
SELECT id, toDateTime64(CAST(COALESCE(name, ''), '1970-01-01 00:00:00'), 3) AS datetime_value FROM (SELECT 1 AS id, NULL AS name UNION ALL SELECT 2, '2023-01-01 12:00:00') WHERE (id ? 1 : 0) = 1;