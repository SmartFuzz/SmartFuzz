CREATE TABLE events (id UInt32, start DateTime, end DateTime DEFAULT now()) ENGINE = MergeTree() ORDER BY start;
INSERT INTO events (id, start, end) VALUES (1, '2023-10-01 10:00:00', '2023-10-01 11:00:00'), (2, '2023-10-01 10:30:00', '2023-10-01 10:45:00'), (3, '2023-10-01 11:00:00', '2023-10-01 12:00:00'), (4, '2023-10-01 11:15:00', '2023-10-01 11:30:00');
SELECT start, runningConcurrency(start, end) FROM events WHERE end <> start;
SELECT start, COUNT(*) OVER (PARTITION BY start ORDER BY end) AS concurrent_count FROM events WHERE runningConcurrency(start, end) <> 1;
CREATE TABLE event_stats AS SELECT runningConcurrency(start, end) AS concurrent_events FROM events GROUP BY start HAVING concurrent_events <> 0;
INSERT INTO event_stats SELECT DISTINCT start, runningConcurrency(start, end) FROM events WHERE end < start;
SELECT id, runningConcurrency(start, end) FROM events WHERE start <> NULL ORDER BY start DESC;
SELECT *, (SELECT COUNT(*) FROM events e2 WHERE e2.start < e1.start AND e2.end > e1.start) AS overlap_count FROM events e1 WHERE start <> end;
CREATE TABLE temp_events AS SELECT start, runningConcurrency(start, end) AS concurrency FROM events WHERE start <> end AND NOT (start = end);
ALTER TABLE events ADD COLUMN duration UInt32 DEFAULT (toUnixTimestamp(end) - toUnixTimestamp(start)) WHERE runningConcurrency(start, end) <> 0;