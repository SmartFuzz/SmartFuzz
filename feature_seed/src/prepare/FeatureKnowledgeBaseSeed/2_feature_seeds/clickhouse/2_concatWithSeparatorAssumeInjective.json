CREATE TABLE test_table (id UInt32, name String, created_at DateTime, value Float64, category Nullable(String));
INSERT INTO test_table VALUES (1, 'alpha', '2023-01-01 10:00:00', 23.5, 'A'), (2, 'beta', '2023-01-02 11:00:00', 47.0, NULL), (3, 'gamma', '2023-01-03 12:00:00', NULL, 'B');
SELECT CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE(' - ', name, CONCAT(CAST(value AS String), ' units')) AS combined_info FROM test_table WHERE created_at >= '2023-01-01 00:00:00' AND value IS NOT NULL;
SELECT id, CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE(' | ', category, name) AS category_info FROM test_table WHERE (category IS NOT NULL AND category != '') GROUP BY category_info HAVING COUNT(*) > 1;
SELECT id FROM test_table WHERE value <= (SELECT MAX(value) FROM test_table WHERE category IS NOT NULL) AND CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE('-', CAST(id AS String), category) IS NOT NULL;
SELECT AVG(value) FROM test_table WHERE CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE(',', status, CAST(id AS String)) <= (SELECT CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE(',', MAX(value), 'Final') FROM test_table WHERE id <= 2);
SELECT COUNT(*) FROM (SELECT id, CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE('|', name, CAST(NULL AS String)) AS info FROM test_table WHERE name IS NOT NULL) AS subquery HAVING LENGTH(info) > 5;
SELECT value FROM test_table a JOIN test_table b ON a.category = b.category WHERE a.id <= b.id AND CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE(';
', CAST(a.value AS String), CAST(b.value AS String)) IS NOT NULL;
SELECT name FROM test_table WHERE (value IS NULL OR (value <= 0 OR value > (SELECT COUNT(*) FROM test_table WHERE category IS NOT NULL))) AND CONCAT_WITH_SEPARATOR_ASSUME_INJECTIVE(' - ', name, 'Check') IS NOT NULL;