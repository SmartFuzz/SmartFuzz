CREATE TABLE test_dict (id UInt64, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_dict VALUES (1, '100'), (2, '200'), (3, NULL), (4, 'not_a_number');
CREATE TABLE test_data (key UInt64, attr_value String) ENGINE = MergeTree() ORDER BY key;
INSERT INTO test_data VALUES (1, '1'), (2, '2'), (3, '3'), (4, '4');
SELECT NOT dictGetInt64('test_dict', 'value', (SELECT key FROM test_data WHERE key = 2)) AS neg_value;
SELECT dictGetInt32OrDefault('test_dict', 'value', key, -1) AS dict_value FROM test_data;
SELECT key, dictGetUInt16('test_dict', 'value', key) AS value_16 FROM test_data WHERE NOT dictGetInt32('test_dict', 'value', key) IS NULL;
SELECT key, COUNT(*) OVER (PARTITION BY dictGetUUID('test_dict', 'value', key)) AS uuid_count FROM test_data;
WITH dictGetInt32OrDefault('test_dict', 'value', (SELECT MAX(key) FROM test_data), -1) AS default_value SELECT NOT default_value AS neg_default_value;
SELECT dictGetString('test_dict', 'value', key) as str_value, NOT str_value IS NULL AS is_valid FROM test_data;
SELECT key, dictGetFloat64OrDefault('test_data', 'attr_value', key, 0.0) AS float_value FROM test_data HAVING NOT float_value < 0.0;
SELECT a.key as a_key, b.key as b_key FROM test_data AS a JOIN test_data AS b ON NOT a.key = b.key WHERE NOT dictGetInt8('test_dict', 'value', b.key) IS NULL;
SELECT key, dictGetDateOrDefault('test_datas', 'attr_value', key, toDate('1970-01-01')) AS date_value FROM test_data GROUP BY dictGetInt16('test_dict', 'value', key) HAVING NOT date_value < toDate('2000-01-01');
SELECT key, COUNT(*) AS cnt FROM test_data GROUP BY dictGetFloat32('test_dict', 'value', key) HAVING NOT cnt > 2;