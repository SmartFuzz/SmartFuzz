CREATE TABLE test_geo_data (edge UInt64, data String, origin UInt64) ENGINE = Memory;
INSERT INTO test_geo_data (edge, data) VALUES (1248204388774707197, 'some data'), (0, NULL), (18446744073709551615, 'max value');
SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin, data FROM test_geo_data;
SELECT h3GetOriginIndexFromUnidirectionalEdge(a.edge) AS origin, a.data FROM (SELECT edge, data FROM test_geo_data AS a) AS subquery;
SELECT a.edge, h3GetOriginIndexFromUnidirectionalEdge(a.edge) AS origin FROM test_geo_data AS a WHERE a.edge IS NOT NULL;
SELECT h3GetOriginIndexFromUnidirectionalEdge(NULLIF(a.edge, 0)) AS origin FROM test_geo_data AS a WHERE data IS NOT NULL;
SELECT h3GetOriginIndexFromUnidirectionalEdge(a.edge) AS origin, COUNT(*) FROM test_geo_data AS a GROUP BY origin HAVING origin IS NOT NULL;
SELECT h3GetOriginIndexFromUnidirectionalEdge(a.edge) AS origin FROM (SELECT edge FROM test_geo_data WHERE data LIKE '%data%') AS a;
CREATE TABLE temp_edge_data (edge UInt64) ENGINE = Memory;
INSERT INTO temp_edge_data (edge) VALUES (1), (2), (3), (4), (5);
SELECT a.origin, MAX(b.edge) FROM (SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM temp_edge_data AS a WHERE edge IS NOT NULL) AS a JOIN (SELECT edge FROM temp_edge_data) AS b ON a.origin = b.edge GROUP BY a.origin;
SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM test_geo_data WHERE edge IN (SELECT edge FROM temp_edge_data);
CREATE TABLE mixed_types_data (id UInt32, value String, edge UInt64 DEFAULT h3GetOriginIndexFromUnidirectionalEdge(id)) ENGINE = Memory;
INSERT INTO mixed_types_data (id, value) VALUES (NULL, 'first'), (1, 'second');
SELECT id, value, h3GetOriginIndexFromUnidirectionalEdge(COALESCE(edge, 0)) AS origin FROM mixed_types_data;
ALTER TABLE mixed_types_data ADD COLUMN new_edge UInt64;
UPDATE mixed_types_data SET new_edge = h3GetOriginIndexFromUnidirectionalEdge(COALESCE(edge, 1));
SELECT h3GetOriginIndexFromUnidirectionalEdge(a.new_edge) + 1 AS adjusted_origin FROM mixed_types_data AS a WHERE new_edge > 0;
DROP TABLE IF EXISTS temp_edge_data;