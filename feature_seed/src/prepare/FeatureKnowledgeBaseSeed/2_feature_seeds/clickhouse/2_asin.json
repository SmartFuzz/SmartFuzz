CREATE TABLE test_asin (id Int32, value Float64, status Nullable(String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_asin VALUES (1, 0.5, 'active'), (2, NULL, 'inactive'), (3, 1.0, NULL), (4, -1.0, 'active');
SELECT id, asin(value) AS arc_sine_from_value FROM test_asin WHERE status = 'active';
SELECT id, asin(value) AS arc_sine, (value, asin(value)) AS tuple_values FROM test_asin WHERE value IS NOT NULL ORDER BY arc_sine;
SELECT id, asin(value) AS arc_sine FROM test_asin WHERE value IN (SELECT other_value FROM (SELECT 0.5 AS other_value) tmp) AND id > 1;
SELECT id, value, asin(value) AS arc_sine FROM test_asin GROUP BY id, value HAVING arc_sine < 1.57;
SELECT id, asin(value) AS arc_sine, tuple(value, status) AS value_status FROM test_asin WHERE status IS NOT NULL ORDER BY (arc_sine, status);
SELECT id, asin(if(value IS NULL, 0.0, value)) AS arc_sine_checked FROM test_asin;
CREATE TABLE temp_values (val Float64) ENGINE = Memory;
INSERT INTO temp_values VALUES (0.0), (1.0), (-1.0), (2.0);
SELECT t.id, t.value, t.status, tuple(t.value, asin(t.value)) AS result_tuple FROM test_asin t JOIN temp_values v ON t.value = v.val WHERE v.val BETWEEN -1.0 AND 1.0;