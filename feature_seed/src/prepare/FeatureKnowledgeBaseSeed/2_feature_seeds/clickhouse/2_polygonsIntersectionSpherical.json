CREATE TABLE geo_test (id UInt32, polygon_polygon Polygon, valid BOOL) ENGINE = Memory;
INSERT INTO geo_test VALUES (1, polygonsFromWKT('POLYGON((4.3613577 50.8651821, 4.349556 50.8535879, 4.3602419 50.8435626, 4.3830299 50.8428851, 4.3904543 50.8564867, 4.3613148 50.8651279, 4.3613577 50.8651821))'), TRUE);
INSERT INTO geo_test VALUES (2, polygonsFromWKT('POLYGON((4.346693 50.858306, 4.367945 50.852455, 4.366227 50.840809, 4.344961 50.833264, 4.338074 50.848677, 4.346693 50.858306))'), TRUE);
SELECT EXISTS(SELECT id FROM geo_test WHERE valid = TRUE AND polygon_polygon = polygonsIntersectionSpherical((SELECT polygon_polygon FROM geo_test WHERE id = 1), (SELECT polygon_polygon FROM geo_test WHERE id = 2)));
SELECT count() FROM geo_test WHERE EXISTS(SELECT id FROM geo_test WHERE valid = FALSE) AND EXISTS(SELECT polygon_polygon FROM geo_test WHERE polygon_polygon = polygonsIntersectionSpherical([[[(4.3613577, 50.8651821), (4.349556, 50.8535879), (4.3602419, 50.8435626), (4.3830299, 50.8428851), (4.3904543, 50.8564867), (4.3613148, 50.8651279)]]], [[[(4.346693, 50.858306), (4.367945, 50.852455), (4.366227, 50.840809), (4.344961, 50.833264), (4.338074, 50.848677), (4.346693, 50.858306)]]]));
CREATE TABLE numbers_test AS SELECT number FROM numbers(5);
SELECT count() FROM numbers_test WHERE EXISTS(SELECT * FROM numbers_test WHERE number > 4) AND EXISTS(SELECT number FROM numbers_test WHERE number < 3);
SELECT EXISTS(SELECT * FROM numbers_test WHERE number > 4) as num_exists, wkt(arrayMap(a -> arrayMap(b -> (round(b.1, 6), round(b.2, 6)), a), polygonsIntersectionSpherical([[[(4.3613577, 50.8651821), (4.349556, 50.8535879), (4.3602419, 50.8435626), (4.3830299, 50.8428851), (4.3904543, 50.8564867), (4.3613148, 50.8651279)]]], [[[(4.346693, 50.858306), (4.367945, 50.852455), (4.366227, 50.840809), (4.344961, 50.833264), (4.338074, 50.848677), (4.346693, 50.858306)]]])) WHERE num_exists = 1;
DROP TABLE IF EXISTS geo_test;