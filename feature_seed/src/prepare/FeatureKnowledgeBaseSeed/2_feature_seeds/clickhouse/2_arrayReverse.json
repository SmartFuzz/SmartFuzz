CREATE TABLE test_table (id UInt32, created_at DateTime, data Array(Int32), value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table (id, created_at, data, value) VALUES (1, now(), [10, 20, 30], 1.23), (2, now() + INTERVAL 1 DAY, [40, NULL, 60], NULL), (3, now() - INTERVAL 2 WEEK, [], 2.34);
SELECT id, arrayReverse(data) AS reversed_data, created_at + INTERVAL 2 HOUR AS updated_time FROM test_table WHERE value IS NOT NULL;
SELECT id, arrayReverse(data) AS reversed_data, updated_time FROM (SELECT id, data, created_at + INTERVAL 1 DAY AS updated_time FROM test_table) WHERE updated_time > now() - INTERVAL 1 WEEK;
SELECT id, arrayReverse(data) AS reversed_data FROM test_table WHERE empty_array := NULL AND empty_array IS NULL;
SELECT id, arrayReverse(data) AS reversed_data FROM test_table WHERE value > 1.0 UNION ALL SELECT id, arrayReverse(NULL) FROM test_table WHERE data IS NOT NULL;
SELECT id, created_at, arrayReverse(data) AS reversed_data FROM test_table GROUP BY id, created_at HAVING COUNT(value) < 3;
SELECT id, created_at + INTERVAL (CASE WHEN data IS NOT NULL THEN arrayLength(data) ELSE 0 END) DAY AS computed_date FROM test_table WHERE id < 3;
SELECT t1.id, arrayReverse(t1.data) AS t1_reversed, t2.value FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id + 1 WHERE t2.value IS NOT NULL;
SELECT id, arrayReverse(data) AS reversed_data FROM (SELECT id, created_at, arrayReverse(data) AS arr FROM test_table WHERE created_at IS NOT NULL UNION DISTINCT SELECT id, now(), [] FROM test_table WHERE created_at IS NULL) ORDER BY id;