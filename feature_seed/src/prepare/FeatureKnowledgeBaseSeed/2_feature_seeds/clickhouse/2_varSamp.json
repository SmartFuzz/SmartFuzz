CREATE TABLE test_data_float (value Float64, nullable_value Float64) ENGINE = Memory;
INSERT INTO test_data_float VALUES (10.5, 9.5), (12.3, NULL), (9.8, 11.3), (11.2, 10.7), (NULL, 8.9);
SELECT round(varSamp(value) - varSamp(nullable_value), 3) AS var_samp_diff FROM test_data_float;
CREATE TABLE test_data_int (id Int32, val Float64) ENGINE = Memory;
INSERT INTO test_data_int VALUES (1, 10.5), (2, 12.3), (3, 9.8), (4, 11.2), (5, NULL);
SELECT id, round(varSamp(val), 3) AS sample_variance FROM test_data_int GROUP BY id HAVING id > (SELECT avg(id) FROM test_data_int);
CREATE TABLE test_joined (a Int32, b Int32) ENGINE = Memory;
INSERT INTO test_joined VALUES (1, 2), (2, 3), (3, 4);
SELECT j.a, round(varSamp(j.a - j.b), 3) AS variance_diff FROM test_joined j JOIN test_data_float d ON j.a = d.value GROUP BY j.a;
CREATE TABLE test_kafka (num Int32, str_value String) ENGINE = Memory;
INSERT INTO test_kafka VALUES (1, '10.5'), (2, '12.3'), (3, 'invalid'), (4, '9.8');
SELECT round(varSamp(toFloat64(str_value)) - 5, 2) AS float_diff FROM test_kafka WHERE isNumeric(str_value);
CREATE TABLE test_edge_cases (edge_val Decimal(10, 4), edge_val_null Decimal(10, 4)) ENGINE = Memory;
INSERT INTO test_edge_cases VALUES (10.0001, NULL), (9.9999, 8.8888), (NULL, NULL);
SELECT round(varSamp(edge_val) - varSamp(edge_val_null), 4) AS var_samp_null_diff FROM test_edge_cases;
CREATE TABLE test_empty (empty_val Float64) ENGINE = Memory;
INSERT INTO test_empty VALUES ();
SELECT round(varSamp(empty_val), 3) AS variance_empty FROM test_empty;