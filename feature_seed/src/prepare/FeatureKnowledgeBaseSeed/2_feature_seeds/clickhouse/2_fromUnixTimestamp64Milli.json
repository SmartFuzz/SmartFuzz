CREATE TABLE test_data (id Int64, timestamp_val Int64, value Nullable(String));
INSERT INTO test_data VALUES (1, 1234567891011, 'first'), (2, 9876543210001, NULL), (3, 1622548800000, 'third'), (4, 0, 'fourth'), (5, 86400000000, 'fifth');
SELECT id, fromUnixTimestamp64Milli(timestamp_val, 'UTC') AS converted_time, value FROM test_data WHERE value IS NOT NULL ORDER BY id;
SELECT id, array[fromUnixTimestamp64Milli(timestamp_val, 'UTC'), timestamp_val] AS mixed_data FROM test_data;
SELECT id, toTypeName(fromUnixTimestamp64Milli(timestamp_val, 'UTC')) AS type_name FROM test_data WHERE arrayJoin([1, 2]) = (SELECT COUNT(*) FROM test_data);
WITH (SELECT arraySum(arrayJoin([timestamp_val, 0, 100, 200])) AS total FROM test_data) AS total_sum SELECT id, fromUnixTimestamp64Milli(total_sum, 'UTC') AS total_time FROM test_data;
SELECT id, value, FROM_UNIXTIME(CAST(timestamp_val AS UInt32)) AS unix_time FROM test_data WHERE services('final_magic') IS NOT NULL;
CREATE TABLE temp_data AS SELECT id, fromUnixTimestamp64Milli(timestamp_val, 'UTC') AS datetime_val FROM test_data WHERE id > 0;
SELECT id, datetime_val FROM temp_data WHERE datetime_val > fromUnixTimestamp64Milli(1622548800000, 'UTC') ORDER BY datetime_val DESC;
SELECT SUM(arrayLength(value)) AS total_length FROM (SELECT value, fromUnixTimestamp64Milli(timestamp_val, 'UTC') AS conversion FROM test_data GROUP BY value);