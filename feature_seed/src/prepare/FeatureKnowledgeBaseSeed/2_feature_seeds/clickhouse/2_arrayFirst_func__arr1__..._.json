CREATE TABLE test_arrays (id UInt32, arr Array(Int32), val Int32 DEFAULT 0);
INSERT INTO test_arrays (id, arr, val) VALUES (1, [1, 2, 3], 1), (2, [4, 5, 0], 0), (3, [], -1), (4, [10, -1, 0], 0);
SELECT id, arrayFirst(x -> x > 0, arr) AS first_positive FROM test_arrays WHERE val = 1;
SELECT id, arrayFirst(x -> x > 3, arrayConcat(arr, [6])) AS first_greater_than_3 FROM test_arrays WHERE arr != [] ORDER BY id DESC;
SELECT id, arrayFirst(x -> x IS NULL, arr) AS first_null FROM test_arrays HAVING first_null IS NULL;
SELECT id, arrayFirst(x -> x > 0, arr) FROM (SELECT id, arr FROM test_arrays WHERE val IS NOT NULL) WHERE id IN (SELECT id FROM test_arrays WHERE val = 0) ORDER BY id;
SELECT id, arrayFirst(x -> x = 1, arr) AS first_equal_1 FROM test_arrays GROUP BY id HAVING first_equal_1 IS NOT NULL;
SELECT id, arrayFirst(x -> toString(x) IS NOT NULL, arr) AS first_non_null_string FROM test_arrays ORDER BY id;
WITH (SELECT arrayFirst(x -> x > 0, arr) AS valid_first FROM test_arrays) AS valid_value SELECT id, (CASE WHEN valid_value IS NOT NULL THEN valid_value ELSE -1 END) AS final_value FROM test_arrays ORDER BY final_value DESC;
ALTER TABLE test_arrays ADD COLUMN additional_val UInt32 DEFAULT 1;
INSERT INTO test_arrays (id, arr, val, additional_val) VALUES (5, [0, NULL, 3], 1, 5);