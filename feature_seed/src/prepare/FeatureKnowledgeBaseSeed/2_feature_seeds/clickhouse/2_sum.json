CREATE TABLE salaries (`id` UInt32, `amount` Float64, `description` String) ENGINE = Log;
INSERT INTO salaries VALUES (1, 1000.50, 'Monthly Salary'), (2, 1200.75, 'Monthly Salary'), (3, NULL, 'Missing Salary'), (4, 900.00, 'Monthly Salary'), (5, 300.00, 'Monthly Salary');
SELECT sum(amount) FROM salaries WHERE amount IS NOT NULL;
CREATE TABLE departments (`dept_id` UInt32, `dept_name` String) ENGINE = Log;
INSERT INTO departments VALUES (1, 'Engineering'), (2, 'HR'), (3, 'Sales');
CREATE TABLE employee_dept (`emp_id` UInt32, `dept_id` UInt32) ENGINE = Log;
INSERT INTO employee_dept VALUES (1, 1), (2, 1), (3, 2), (4, 1), (5, 3);
SELECT dept_id, sum(amount) FROM salaries JOIN employee_dept ON salaries.id = employee_dept.emp_id GROUP BY dept_id HAVING sum(amount) <= 1000;
SELECT (SELECT sum(amount) FROM salaries) - (SELECT sum(amount) FROM salaries WHERE amount > 1000) AS difference;
SELECT sum(amount) FROM salaries WHERE amount <= (SELECT avg(amount) FROM salaries);
CREATE TABLE bonus (`emp_id` UInt32, `bonus_amount` Decimal(10, 2)) ENGINE = Log;
INSERT INTO bonus VALUES (1, 500.00), (3, NULL), (5, 250.50);
SELECT sum(amount) + COALESCE((SELECT sum(bonus_amount) FROM bonus), 0) FROM salaries WHERE amount <= 1000;
SELECT sum(IF(dept_id = 1, amount, 0)) AS engineering_salaries FROM salaries JOIN employee_dept ON salaries.id = employee_dept.emp_id;
CREATE TEMPORARY TABLE temp_salaries AS SELECT amount * 1.05 AS adjusted_salary FROM salaries;
SELECT sum(adjusted_salary) FROM temp_salaries WHERE adjusted_salary < 1200;
SELECT count(*) FROM salaries WHERE amount IS NULL;
SELECT sum(amount) FROM salaries WHERE amount >= 0 OR (amount IS NULL AND 1 <= 1);
CREATE TABLE edge_cases (`id` UInt32, `value` String) ENGINE = Log;
INSERT INTO edge_cases VALUES (1, ''), (2, '1000'), (3, 'N/A');
SELECT sum(CAST(value AS Float64)) FROM edge_cases WHERE value != 'N/A';