CREATE TABLE test_data (id UInt32, value Float64, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_data VALUES (1, 0.0, '2023-01-01 00:00:00'), (2, NULL, '2023-01-02 00:00:00'), (3, 3.14159, '2023-01-03 00:00:00'), (4, 2.71828, '2023-01-04 00:00:00');
SELECT EXISTS(SELECT * FROM test_data WHERE value IS NOT NULL) AS exist_case_1, EXISTS(SELECT * FROM test_data WHERE value > 10) AS exist_case_2;
SELECT formatReadableSize(filesystemUnreserved()) AS free_space, EXISTS(SELECT value FROM test_data WHERE value IS NULL) AS null_case;
SELECT EXISTS(SELECT id FROM test_data WHERE value > (SELECT AVG(value) FROM test_data) AND created_at < '2023-01-03 00:00:00') AS complex_exist;
SELECT count() FROM test_data WHERE EXISTS(SELECT * FROM test_data WHERE value < 1) AND (formatReadableSize(filesystemUnreserved()) > 0);
CREATE TABLE data_check (check_id UInt32, check_value Float64) ENGINE = Memory;
INSERT INTO data_check VALUES (1, 2.0), (2, NULL), (3, 5.0);
SELECT EXISTS(SELECT * FROM (SELECT id, value FROM test_data) tmp WHERE tmp.value IS NOT NULL) AS inner_exist, formatReadableSize(filesystemUnreserved()) AS free_space;
SELECT count() FROM (SELECT check_id, check_value FROM data_check WHERE check_value IS NOT NULL) tmp WHERE EXISTS (SELECT * FROM test_data WHERE value > tmp.check_value);