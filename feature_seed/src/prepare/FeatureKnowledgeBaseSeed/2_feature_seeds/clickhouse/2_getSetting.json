CREATE TABLE test_table (id UInt32, value String, setting_val Int32 DEFAULT getSetting('custom_a'));
INSERT INTO test_table (id, value) VALUES (1, 'A'), (2, 'B'), (3, NULL), (4, '123'), (5, '456.78');
SELECT id, value, getSetting('custom_a') AS current_setting FROM test_table WHERE (value GLOBAL IN ('A', 'B')) AND (setting_val IS NOT NULL);
SELECT id, value, getSetting('custom_a') AS current_setting FROM test_table WHERE (value GLOBAL IN (SELECT value FROM test_table WHERE id < 3)) AND (setting_val > 100);
CREATE TABLE another_table (user_id UInt32, score Float64);
INSERT INTO another_table (user_id, score) VALUES (1, 100.0), (2, NULL), (3, -50.5), (4, 200.25);
SELECT t.id, t.value, SUM(a.score) AS total FROM test_table t JOIN another_table a ON t.id = a.user_id WHERE (getSetting('custom_a') < 200) GROUP BY t.id, t.value HAVING total > 150;
SELECT *, getSetting('custom_a') AS current_setting FROM test_table WHERE value GLOBAL IN (SELECT SUBSTRING(value, 1, 1) FROM test_table WHERE value IS NOT NULL) GROUP BY id;
CREATE TABLE temp_table AS SELECT * FROM test_table WHERE false;
INSERT INTO temp_table SELECT * FROM test_table WHERE id % 2 = 0;
SELECT getSetting('custom_a'), value FROM temp_table WHERE value GLOBAL IN (SELECT value FROM test_table WHERE value IS NOT NULL AND (setting_val = 123 OR setting_val IS NULL));