CREATE TABLE test_table (id Int32, value Nullable(Int32), data String, created_at DateTime);
INSERT INTO test_table VALUES (1, NULL, 'example1', '2023-01-01 00:00:00'), (2, 10, 'example2', '2023-01-02 00:00:00'), (3, NULL, 'example3', '2023-01-03 00:00:00'), (4, 20, 'example4', '2023-01-04 00:00:00');
SELECT id FROM test_table WHERE isNotDistinctFrom(value, (SELECT MAX(value) FROM test_table WHERE data != 'example1')) != ANY (SELECT DISTINCT value FROM test_table WHERE data LIKE '%example%') AND created_at > '2023-01-01 00:00:00';
SELECT id, value FROM test_table WHERE isNotDistinctFrom(value, (SELECT AVG(value) FROM (SELECT value FROM test_table WHERE id != 3))) AND value != ANY (SELECT id FROM test_table WHERE value < 15);
SELECT COUNT(*) FROM test_table WHERE value != ANY (SELECT value FROM test_table WHERE isNotDistinctFrom(value, 10) OR data LIKE '%example3%') GROUP BY created_at HAVING COUNT(value) > 1;
SELECT data FROM test_table WHERE created_at <= '2023-01-03 00:00:00' AND value != ANY (SELECT DISTINCT value FROM test_table WHERE value IS NULL) OR isNotDistinctFrom(value, NULL);