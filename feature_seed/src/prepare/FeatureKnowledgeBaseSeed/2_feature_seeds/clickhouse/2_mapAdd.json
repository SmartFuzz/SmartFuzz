CREATE TABLE test_map_negation (id Int64, key_arr Array(Int64), value_arr Array(Float64));
INSERT INTO test_map_negation VALUES (1, [1, 2, 3], [1.5, 2.5, 3.0]), (2, [2, 1, 3], [4.0, 5.0, 6.0]);
SELECT mapAdd(key_arr, value_arr) as summed_map, -a(summed_map) FROM (SELECT key_arr, value_arr FROM test_map_negation) AS subquery;
SELECT mapAdd(map(-1, 10), map(1, -10)) as negative_addition WHERE NULL IS NOT NULL;
SELECT mapAdd(([toUInt8(255), 0], [-1, 1]), ([toUInt8(1), 3], [1.5, -1])) as res, toTypeName(res) as type, -a((SELECT sum(value) FROM (SELECT value_arr FROM test_map_negation))) as negated_sum;
SELECT key, mapAdd(key, -a(value)) FROM (SELECT key_arr AS key, value_arr AS value FROM test_map_negation) GROUP BY key HAVING key > -1;
SELECT mapAdd(map(1, 1), map(NULL, 2)) as null_case, -a(null_case) as negated_null_case;
CREATE TABLE temp_data (num Int64, val Nullable(Float64));
INSERT INTO temp_data VALUES (1, 123.45), (2, NULL), (3, 678.90);
SELECT mapAdd(map(num, val), map(0, 0.0)) as added_result FROM temp_data WHERE val IS NOT NULL OR val IS NULL;
SELECT DISTINCT -a(mapAdd(([1, 2], [1.0, 1.0]), ([1, 2], [NULL, 1.0]))) as distinct_negated_result FROM test_map_negation;
SELECT key, -a(value) FROM (SELECT count(*) AS key, sum(val) AS value FROM temp_data GROUP BY num HAVING key < 5) AS aggregated_data;