CREATE TABLE test_data (id UInt32, value Array(Int32), created_at DateTime, name String);
INSERT INTO test_data VALUES (1, [5, 3, 8, 1], '2023-01-01 10:00:00', 'Alice'), (2, [5, NULL, 7, NULL], '2023-01-01 10:05:00', 'Bob'), (3, [], '2023-01-01 10:10:00', 'Charlie');
SELECT EXTRACT(YEAR FROM created_at) AS year, arrayPartialSort(2, value) AS partial_sorted_values FROM test_data GROUP BY year HAVING arrayLength(partial_sorted_values) > 0;
SELECT id, value, EXTRACT(MONTH FROM created_at) AS month FROM test_data WHERE arrayExists(x -> x > 5, value) AND name LIKE 'A%';
SELECT t1.id, arrayPartialSort(3, t1.value), EXTRACT(DAY FROM t2.created_at) FROM test_data AS t1 JOIN test_data AS t2 ON t1.id != t2.id WHERE arraySize(t2.value) > 0 GROUP BY t1.id HAVING arrayCount(x -> x IS NOT NULL, value) < 4;
WITH (SELECT count() FROM test_data WHERE name IS NULL) AS null_count SELECT EXTRACT(HOUR FROM created_at) AS hour, null_count, arrayPartialSort(1, value) FROM test_data GROUP BY hour, null_count HAVING null_count > 0;
CREATE TABLE temp_data AS SELECT id, name, arrayPartialSort(1, value) AS sorted_value FROM test_data;
ALTER TABLE temp_data ADD COLUMN created_at Nullable(DateTime);
INSERT INTO temp_data (id, name, sorted_value) SELECT id, name, arrayPartialSort(1, value) FROM test_data WHERE value IS NOT NULL;
SELECT id, EXTRACT(MINUTE FROM created_at) AS minute, COUNT() FROM temp_data GROUP BY minute HAVING COUNT() > 1;
DROP TABLE IF EXISTS test_data;