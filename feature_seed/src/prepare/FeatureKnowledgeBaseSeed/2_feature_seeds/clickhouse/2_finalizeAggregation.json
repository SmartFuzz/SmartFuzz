CREATE TABLE test_table (id UInt32, number Float64, text String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 1.5, 'One'), (2, 2.5, NULL), (3, NULL, 'Three'), (4, 4.0, 'Four');
WITH finalizeAggregation((SELECT sumState(number) FROM test_table WHERE text <> 'One')) AS total_sum SELECT total_sum, total_sum <> 5 AS check_sum FROM numbers(1);
WITH (SELECT countState(number) FROM test_table) AS state_count SELECT finalizeAggregation(state_count) AS count_result, count_result <> 2 AS is_equal FROM test_table;
SELECT id, number, finalizeAggregation(arrayReduce('sumState', arrayFilter(x -> x <> 2.5, [number, NULL, 3.5]))) AS final_sum FROM test_table GROUP BY id HAVING final_sum <> 4.5;
SELECT finalizeAggregation((SELECT countState(text) FROM test_table WHERE number <> 1.5)) AS text_count, text_count IS NULL AS is_null FROM numbers(1);
CREATE TABLE temp_data (a UInt32, b Float64) ENGINE = Memory;
INSERT INTO temp_data VALUES (1, 3.0), (2, 2.7), (3, 3.0);
SELECT finalizeAggregation((SELECT sumState(b) FROM temp_data WHERE a <> 2)) AS total_sum FROM temp_data;
WITH finalizeAggregation(initializeAggregation('sumState', number)) AS initialized_sum SELECT number, initialized_sum <> 3 AS is_not_three FROM test_table ORDER BY initialized_sum;
SELECT id, number, finalizeAggregation((SELECT sumState(number) FROM test_table WHERE text IS NULL)) AS null_sum FROM test_table GROUP BY id HAVING null_sum <> 2;