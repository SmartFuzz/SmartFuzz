CREATE TABLE test_table (id UInt32, values Array(Int32));
INSERT INTO test_table VALUES (1, [1, 2, -3, 4]), (2, [-1, -2, -3, -4]), (3, [5, NULL, 7, -2]);
SELECT id, arrayCumSumNonNegative(values) AS cumulative_values FROM test_table;
SELECT id, arrayCumSumNonNegative([val / 2.0 for val in values]) AS cumulative_half_values FROM test_table;
SELECT id, arrayCumSumNonNegative([1, -1 * (-3 + 2), 3.5, NULL]) AS cumulative_expression FROM test_table WHERE id = 1;
SELECT id, arraySumNonNegative(arrayCumSumNonNegative(values)) AS total_non_negative FROM test_table GROUP BY id HAVING total_non_negative > 5;
SELECT id FROM test_table WHERE arrayCumSumNonNegative(values)[2] IS NOT NULL;
CREATE TABLE temp_table (x Float64, y Float64) ENGINE = MergeTree() ORDER BY x;
INSERT INTO temp_table VALUES (1.1, 2.2), (3.3, NULL), (NULL, 5.5);
SELECT x, arrayCumSumNonNegative([y / x for x in [x, NULL] IF x IS NOT NULL]) AS safe_cumulative FROM temp_table;
SELECT id, arrayCumSumNonNegative(arrayJoin(values)) AS flattened_cumulative FROM test_table GROUP BY id HAVING flattened_cumulative[1] < 3;