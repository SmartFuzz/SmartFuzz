CREATE TABLE regions (id UInt32, name String, continent_id UInt32);
INSERT INTO regions VALUES (1, 'Region A', 100), (2, 'Region B', NULL), (3, 'Region C', 200);
CREATE TABLE continents (id UInt32, name String);
INSERT INTO continents VALUES (100, 'Continent X'), (200, 'Continent Y');
SELECT regionToTopContinent(id) AS top_continent, regionToTopContinent(COALESCE(continent_id, 0)) AS coalesced_top_continent FROM regions;
SELECT r.name, (SELECT COUNT(*) FROM regions r2 WHERE r2.continent_id = r.continent_id) / (SELECT COUNT(*) FROM regions) AS ratio FROM regions r GROUP BY r.name ORDER BY ratio DESC;
SELECT r.id, regionToTopContinent(r.id) / NULLIF(regionToTopContinent(r.continent_id), 0) AS division_result FROM regions r WHERE r.continent_id IS NOT NULL;
SELECT DISTINCT r.name, regionToTopContinent(r.id) FROM regions r JOIN continents c ON c.id = r.continent_id WHERE c.name LIKE 'Continent%';
SELECT regionToTopContinent(NULL) AS null_top_continent, regionToTopContinent(3) AS valid_top_continent FROM regions;
ALTER TABLE regions ADD COLUMN description String;
INSERT INTO regions VALUES (4, 'Region D', 0), (5, 'Region E', NULL);
SELECT COUNT(*), SUM(regionToTopContinent(id)) AS total_continent_id FROM regions GROUP BY continent_id HAVING SUM(regionToTopContinent(id)) > 50;