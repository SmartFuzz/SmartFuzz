CREATE TABLE roles_test (id UInt32, role_name String, user_id UInt32, role_level UInt8) ENGINE = Log;
INSERT INTO roles_test VALUES (1, 'admin', 1001, 5), (2, 'user', 1002, 1), (3, 'editor', 1003, 3);
CREATE TABLE users (id UInt32, username String, role_level UInt8) ENGINE = Log;
INSERT INTO users VALUES (1001, 'Alice', 5), (1002, 'Bob', 1), (1003, 'Charlie', 3), (1004, 'David', NULL);
SELECT username, (SELECT role_name FROM roles_test WHERE roles_test.user_id = users.id AND currentRoles() < role_level) AS roles FROM users WHERE currentRoles() IS NOT NULL ORDER BY username;
SELECT id, role_name FROM roles_test WHERE role_level < (SELECT MIN(role_level) FROM users WHERE currentRoles() IS NOT NULL);
SELECT user_id, count(*) FROM roles_test WHERE role_level < (SELECT COUNT(*) FROM users WHERE currentRoles() IS NULL GROUP BY role_level HAVING MIN(role_level) > 0) GROUP BY user_id;
SELECT username, currentRoles() AS current_roles FROM users WHERE currentRoles() < role_level HAVING COUNT(currentRoles()) > 0;
SELECT users.username, roles_test.role_name FROM users JOIN roles_test ON users.role_level < roles_test.role_level WHERE currentRoles() IS NOT NULL;
SELECT currentRoles() FROM roles_test WHERE user_id IN (SELECT id FROM users WHERE username LIKE 'A%') ORDER BY role_level DESC;