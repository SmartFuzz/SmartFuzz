CREATE TABLE test_groupBitAnd (num1 Int32, num2 Int32, num3 Int32, num4 Int32, str_val String);
INSERT INTO test_groupBitAnd VALUES (15, 7, 3, NULL, 'test'), (10, 2, NULL, 8, 'test2'), (30, 14, 2, 4, 'test3'), (NULL, NULL, 0, 1, 'test4');
SELECT groupBitAnd(tuple(num1, num2, num3)) FROM test_groupBitAnd GROUP BY str_val HAVING groupBitAnd(tuple(num1, num2)) > 0;
SELECT groupBitAnd(num1) + groupBitAnd(num3) FROM (SELECT num1, num3 FROM test_groupBitAnd WHERE str_val IS NOT NULL) GROUP BY num2;
SELECT groupBitAnd((num1, num2, num3)) AS agg_result, count() FROM test_groupBitAnd GROUP BY str_val HAVING agg_result IS NOT NULL;
SELECT x, groupBitAnd(y) FROM (SELECT (num1 + num2, num3) AS x, (num2 - num3) AS y FROM test_groupBitAnd) GROUP BY x;
WITH (SELECT num1 FROM test_groupBitAnd WHERE str_val = 'test2') AS sub_num1 SELECT groupBitAnd(num1) FROM test_groupBitAnd WHERE num1 IN (SELECT * FROM sub_num1);
CREATE TABLE test_null (a Int32, b Int32 DEFAULT NULL);
INSERT INTO test_null VALUES (1, NULL), (2, 3), (NULL, 5);
SELECT groupBitAnd(a) FROM test_null WHERE b IS NULL OR a IS NULL GROUP BY b;
SELECT b, groupBitAnd(((a + 10) * 2, (b + 5) * 2)) FROM test_null GROUP BY b HAVING groupBitAnd(a) IS NOT NULL;
SELECT groupBitAnd((num1, 0)) AS and_result FROM test_groupBitAnd WHERE str_val LIKE '%test%';