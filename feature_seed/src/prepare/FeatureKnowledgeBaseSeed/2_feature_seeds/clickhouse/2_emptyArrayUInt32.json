CREATE TABLE test_table (id UInt32, value UInt32, nullable_value Nullable(UInt32));
INSERT INTO test_table VALUES (1, 1), (2, 2), (3, NULL), (4, 4);
SELECT id, value FROM test_table WHERE value IN (SELECT NULL) AND nullable_value IS NULL;
SELECT id, value FROM test_table WHERE value IN (SELECT emptyArrayUInt32());
CREATE TABLE join_table (id UInt32, ref_id UInt32);
INSERT INTO join_table VALUES (1, 1), (2, 3), (3, 2);
SELECT t1.id, t1.value FROM test_table t1 JOIN join_table t2 ON t1.id = t2.ref_id WHERE t1.value IN (SELECT emptyArrayUInt32());
SELECT id, COUNT() FROM test_table GROUP BY id HAVING COUNT() > 0 AND id IN (SELECT value FROM test_table WHERE nullable_value IS NULL);
SELECT id, value FROM test_table WHERE value IN (SELECT arrayJoin(emptyArrayUInt32()));
CREATE TABLE aggregated_table (group_id UInt32, score Float64);
INSERT INTO aggregated_table VALUES (1, 1.1), (1, 1.2), (2, 2.1), (2, 2.2);
SELECT group_id, AVG(score) FROM aggregated_table WHERE group_id IN (SELECT id FROM test_table WHERE value = 4) GROUP BY group_id HAVING AVG(score) > (SELECT COUNT() FROM test_table WHERE value IS NOT NULL);
SELECT (SELECT emptyArrayUInt32()) AS empty_array_result, value FROM test_table WHERE id IN (1, 2);
SELECT id, value, tuple(id, value) FROM test_table WHERE value IN (SELECT emptyArrayUInt32()) AND id = 1;
ALTER TABLE test_table ADD COLUMN new_value Nullable(UInt32);
UPDATE test_table SET new_value = NULL WHERE id = 3;
SELECT id, new_value FROM test_table WHERE new_value IN (SELECT value FROM test_table WHERE value IS NULL) AND value = 2;