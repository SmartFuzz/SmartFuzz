CREATE TABLE test_timestamps (id UInt32, event_time String, duration String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_timestamps VALUES (1, '2023-12-31', '12:00:00.11'), (2, '2023-12-30 23:59:59', '00:00:01'), (3, '', ''), (4, '2022-01-01', NULL);
SELECT id, timestamp(event_time, duration) AS computed_time FROM test_timestamps WHERE timestamp(event_time, duration) != timestamp('2023-12-30') ORDER BY computed_time;
SELECT t1.id, t1.event_time, COUNT(*) AS event_count FROM test_timestamps t1 JOIN test_timestamps t2 ON t1.id != t2.id WHERE timestamp(t1.event_time) != timestamp(t2.event_time) GROUP BY t1.id, t1.event_time HAVING event_count > 1;
SELECT id, timestamp(event_time) AS ts FROM test_timestamps WHERE ts IS NOT NULL AND ts != timestamp('2023-01-01') ORDER BY ts DESC;
SELECT t.id, timestamp(t.event_time, '00:00:00') AS start_time, timestamp(t.event_time, '23:59:59') AS end_time FROM test_timestamps AS t WHERE NOT (timestamp(t.event_time) IS NULL) AND start_time != end_time;