CREATE TABLE test_dates (id UInt32, event_date DateTime, event_text String);
INSERT INTO test_dates VALUES (1, toDateTime('2023-04-21 10:20:30'), 'Event A'), (2, toDateTime('2023-04-24 12:00:00'), 'Event B'), (3, toDateTime(NULL), 'Event C');
SELECT id, toStartOfWeek(event_date) AS week_start, event_text FROM test_dates WHERE event_date IS NOT NULL OR event_text = 'Event C';
SELECT id, toStartOfWeek(toDateTime('2023-04-21 10:20:30'), 1) AS week_start FROM test_dates WHERE id = 1 OR (event_date = toDateTime('2023-04-24 12:00:00') OR event_text = 'Event B');
SELECT id, toStartOfWeek(event_date) AS week_start FROM test_dates WHERE event_date < toDateTime('2023-04-26 10:00:00') OR event_date IS NULL;
CREATE TABLE events (event_id UInt32, event_date DateTime, location String);
INSERT INTO events VALUES (1, toDateTime('2023-01-01 08:00:00'), 'Location A'), (2, toDateTime('2023-01-08 09:00:00'), 'Location B'), (3, toDateTime('2023-01-15 10:00:00'), NULL);
SELECT e.event_id, toStartOfWeek(e.event_date) AS week_start FROM events e JOIN test_dates d ON e.event_id = d.id WHERE d.event_date IS NOT NULL OR d.event_text = 'Event C';
CREATE TABLE mixed_data (data_id UInt32, mixed_data Nullable(String), processed_date DateTime);
INSERT INTO mixed_data VALUES (1, '2023-04-21', toDateTime('2023-04-21 10:20:30')), (2, NULL, toDateTime('2023-04-24 12:00:00')), (3, 'invalid date', toDateTime('2023-05-01 09:30:00'));
SELECT data_id, toStartOfWeek(CASE WHEN mixed_data IS NULL THEN toDateTime('2023-04-01 00:00:00') ELSE toDate(mixed_data) END) FROM mixed_data WHERE mixed_data IS NOT NULL OR data_id = 3;
SELECT COUNT(*) FROM (SELECT DISTINCT toStartOfWeek(event_date) AS week_start FROM test_dates GROUP BY week_start HAVING week_start OR event_date IS NULL);