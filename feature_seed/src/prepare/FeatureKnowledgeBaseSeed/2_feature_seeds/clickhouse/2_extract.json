CREATE TABLE test_data (id Int32, value String, timestamp DateTime DEFAULT now());
INSERT INTO test_data (id, value) VALUES (1, 'number: 1, number: 2'), (2, 'string: test, string: example');
SELECT extract(value, '[0-9]+') - (id) AS calc FROM test_data WHERE extract(value, '[0-9]+') != '';
SELECT id, value, (extract(value, '[0-9]+') - 1) AS extracted_value FROM test_data WHERE value IS NOT NULL;
SELECT id, count(*) FROM (SELECT extract(value, '[0-9]+') AS number FROM test_data) GROUP BY number HAVING number > 1;
CREATE TABLE condensed_data AS SELECT id, extract(value, '([0-9]+)') AS first_number FROM test_data;
INSERT INTO condensed_data (id, first_number) SELECT id, extract(value, '(\d+)') FROM test_data WHERE value != '';
SELECT d.id, extract(d.value, '\d+') - count(*) AS calculation FROM condensed_data d JOIN test_data t ON d.id = t.id GROUP BY d.id HAVING calculation > 0;
SELECT extract((value), '\d+') - (SELECT COUNT(value) FROM test_data WHERE value LIKE '%string%') AS adjusted FROM test_data WHERE NOT(value IS NULL);
SELECT extract(value, '[a-z]+') AS extracted_alpha FROM test_data WHERE extract(value, '[a-z]+') IS NOT NULL ORDER BY extracted_alpha DESC;