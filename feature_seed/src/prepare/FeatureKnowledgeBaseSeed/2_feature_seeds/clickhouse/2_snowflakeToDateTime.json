CREATE TABLE test_snowflake (id Int64, data String, created_at DateTime, uuid UUID);
INSERT INTO test_snowflake VALUES (1426860702823350272, 'test1', NOW(), generateUUIDv4());
INSERT INTO test_snowflake VALUES (1426860702823350273, 'test2', NOW(), generateUUIDv4());
SELECT snowflakeToDateTime(id) AS datetime_value FROM test_snowflake WHERE datetime_value > (SELECT max(snowflakeToDateTime(id)) FROM test_snowflake WHERE data = 'test2');
SELECT COUNT(*) FROM (SELECT snowflakeToDateTime(id) AS actual_time FROM test_snowflake WHERE actual_time > (CAST(1426860702823350272 AS Int64)));
SELECT data, COUNT(*) FROM test_snowflake WHERE snowflakeToDateTime(id) > (SELECT min(snowflakeToDateTime(id)) FROM test_snowflake) GROUP BY data HAVING COUNT(*) > 1;
CREATE TABLE temp_table AS (SELECT id, snowflakeToDateTime(id) AS parsed_time FROM test_snowflake) ENGINE = Memory;
SELECT parsed_time, COUNT(*) FROM temp_table WHERE parsed_time IS NOT NULL GROUP BY parsed_time HAVING COUNT(*) > 0;
SELECT A.id FROM test_snowflake A JOIN test_snowflake B ON snowflakeToDateTime(A.id) > snowflakeToDateTime(B.id);
SELECT snowflakeToDateTime(id) AS converted_time FROM (SELECT DISTINCT id FROM test_snowflake) WHERE converted_time > '1970-01-01 00:00:00' ORDER BY converted_time DESC;