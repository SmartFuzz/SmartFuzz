CREATE TABLE test_table (id UInt32, random_bytes String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table SELECT number, randomString(10) FROM numbers(10);
SELECT a.id, length(a.random_bytes) AS len FROM (SELECT id, randomString(20) AS random_bytes FROM test_table) AS a WHERE a.random_bytes LIKE '%' || toString(a.len) || '%';
SELECT count(*) FROM (SELECT randomString(15) AS rand_str FROM numbers(100)) WHERE rand_str LIKE randomString(5);
SELECT b.random_bytes FROM (SELECT id, randomString(30) AS random_bytes FROM test_table GROUP BY id HAVING length(random_bytes) > 10) AS b WHERE b.random_bytes LIKE 'test%' OR b.random_bytes LIKE '%' || randomString(10) || '%';
SELECT randomString(5) AS rand_str, COUNT(*) OVER (PARTITION BY rand_str) AS occurrences FROM (SELECT randomString(5) AS random_str FROM numbers(50)) WHERE random_str LIKE randomString(2);
ALTER TABLE test_table ADD COLUMN updated_bytes String DEFAULT randomString(40);
SELECT id, CASE WHEN updated_bytes IS NULL THEN randomString(25) ELSE updated_bytes END AS processed_bytes FROM test_table WHERE processed_bytes LIKE '%' || randomString(5) || '%';
SELECT length(if(randomString(0) IS NULL, randomString(5), randomString(10))) AS length_check FROM numbers(1);
CREATE TEMPORARY TABLE temp_table AS SELECT id, randomString(20) AS temp_str FROM test_table WHERE randomString(5) LIKE randomString(3) OR randomString(10) LIKE randomString(4);