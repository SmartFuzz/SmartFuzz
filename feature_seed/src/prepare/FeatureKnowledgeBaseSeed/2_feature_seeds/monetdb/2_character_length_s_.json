CREATE TABLE test_table (id INT, description VARCHAR(255), amount DECIMAL(10, 2));
INSERT INTO test_table (id, description, amount) VALUES (1, 'Test entry 1', 42.50), (2, 'Edge case €', 100.25), (3, NULL, NULL);
SELECT character_length(description || ' ' || amount::TEXT) AS length_descriptor FROM test_table WHERE amount IS NOT NULL;
SELECT id, character_length(CONCAT('ID: ', id) || ' - ' || COALESCE(description, 'No Description')) AS length_id FROM test_table;
SELECT id, character_length(description) AS desc_length FROM test_table WHERE character_length(description) > 10 HAVING desc_length < 15;
SELECT id, CONCAT('Length of: ', character_length(description)) AS length_info FROM test_table WHERE amount > (SELECT AVG(amount) FROM test_table WHERE amount IS NOT NULL);
SELECT id, character_length(description || ' ' || (CASE WHEN amount IS NULL THEN '0' ELSE amount::TEXT END)) AS full_length FROM test_table;
SELECT T1.id, character_length(T1.description || T2.description) AS combined_length FROM test_table AS T1 JOIN test_table AS T2 ON T1.id = T2.id WHERE T1.id != T2.id;
CREATE TABLE additional_table (row_num INT PRIMARY KEY, title VARCHAR(100));
INSERT INTO additional_table (row_num, title) VALUES (1, 'First'), (2, 'Second'), (3, 'Third');
SELECT a.row_num, character_length(CONCAT(a.title, ' ', b.description)) AS combined_char_length FROM additional_table AS a JOIN test_table AS b ON a.row_num = b.id WHERE b.description IS NOT NULL;
CREATE TEMPORARY TABLE temp_table AS SELECT id, character_length(description) AS desc_length FROM test_table;
SELECT desc_length FROM temp_table WHERE desc_length > 5 ORDER BY desc_length DESC;