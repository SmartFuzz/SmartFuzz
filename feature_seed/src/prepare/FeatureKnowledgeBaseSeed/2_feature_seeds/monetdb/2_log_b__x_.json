CREATE TABLE test_table (id INT PRIMARY KEY, ip_address INET, value DOUBLE);
INSERT INTO test_table VALUES (1, inet '192.168.1.1', 64.0);
INSERT INTO test_table VALUES (2, inet '192.168.1.2', NULL);
INSERT INTO test_table VALUES (3, inet '192.168.1.3', 32.0);
INSERT INTO test_table VALUES (4, inet '192.168.1.4', 0.0);
SELECT id, log(2, CASE WHEN value IS NULL THEN 1 ELSE value END) AS log_value FROM test_table WHERE ip_address <= inet '192.168.1.3';
SELECT t1.id, t1.value, log(2, t1.value) AS log_of_value FROM (SELECT id, value FROM test_table WHERE value IS NOT NULL) t1 JOIN (SELECT inet '192.168.1.5' AS min_ip) t2 ON t1.ip_address <= t2.min_ip;
SELECT id, value FROM test_table WHERE log(2, value) >= (SELECT AVG(log(2, value)) FROM test_table) HAVING value IS NOT NULL ORDER BY value ASC;
SELECT COUNT(*) FROM (SELECT id, log(2, value) AS log_value FROM test_table WHERE value IS NOT NULL GROUP BY id HAVING log_value <= 6) AS derived;
CREATE TEMP TABLE temp_table AS SELECT id, log(2, value) FROM test_table WHERE value IS NOT NULL;
INSERT INTO temp_table SELECT id, log(2, CASE WHEN value IS NULL THEN 1 ELSE value END) FROM test_table WHERE ip_address <= inet '192.168.1.4';
SELECT ip_address, log(2, MAX(value)) FROM test_table GROUP BY ip_address HAVING MAX(value) <= 32.0;