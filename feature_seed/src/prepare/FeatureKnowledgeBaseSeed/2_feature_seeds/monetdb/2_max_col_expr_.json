CREATE TABLE test_timestamps (id INT PRIMARY KEY, event_time TIMESTAMP(6), value INT);
INSERT INTO test_timestamps (id, event_time, value) VALUES (1, timestamp(6) '2020-09-28 18:40:05.123456', 10);
INSERT INTO test_timestamps (id, event_time, value) VALUES (2, NULL, 20);
INSERT INTO test_timestamps (id, event_time, value) VALUES (3, timestamp(6) '2020-09-28 18:50:00.654321', NULL);
SELECT max(value) FROM (SELECT value FROM test_timestamps WHERE event_time IS NOT NULL) AS subquery;
SELECT max(value) FROM (SELECT value FROM test_timestamps WHERE event_time > timestamp(6) '2020-09-28 18:00:00.000000') AS filtered_sub;
SELECT max(value) FROM test_timestamps WHERE event_time IS NULL GROUP BY id HAVING COUNT(*) > 0;
SELECT id, max(value) OVER (PARTITION BY event_time) AS max_value FROM (SELECT id, value, event_time FROM test_timestamps) AS x ORDER BY max_value DESC;
SELECT max(timestamp(6) '2020-09-28 18:59:59.999999') FROM test_timestamps WHERE event_time BETWEEN timestamp(6) '2020-09-28 18:40:00.000000' AND timestamp(6) '2020-09-28 19:00:00.000000';
SELECT id FROM test_timestamps WHERE value = (SELECT max(value) FROM test_timestamps WHERE event_time IS NOT NULL) + 1;
SELECT timestamp(6) '2020-09-28 19:00:00.000000' AS boundary_time, max(value) FROM test_timestamps WHERE event_time IS NULL;
CREATE TABLE test_aggregate (id SERIAL PRIMARY KEY, reference_date DATE, measurement INT);
INSERT INTO test_aggregate (reference_date, measurement) VALUES (DATE '2020-09-28', 100), (DATE '2020-09-29', NULL), (DATE '2020-09-30', 200);
SELECT max(measurement) FROM test_aggregate WHERE reference_date < DATE '2020-09-29';