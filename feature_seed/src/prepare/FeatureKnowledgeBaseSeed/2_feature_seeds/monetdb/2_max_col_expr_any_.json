CREATE TABLE test_table (id INT, event_date VARCHAR(10), value FLOAT);
INSERT INTO test_table VALUES (1, '2020-01-01', 100.0), (2, '2020-05-15', 150.5), (3, NULL, 200.0), (4, '2020-12-31', NULL);
SELECT max(value) OVER (PARTITION BY date(event_date) ORDER BY id) FROM test_table WHERE event_date IS NOT NULL;
SELECT max(value) FROM test_table WHERE CAST(event_date AS date) BETWEEN date '2020-01-01' AND date '2020-12-31';
SELECT id, value, max(value) OVER (PARTITION BY event_date) AS max_value FROM (SELECT id, value, date(event_date) AS event_day FROM test_table WHERE event_date IS NOT NULL) AS subquery WHERE max_value IS NOT NULL;
SELECT max(date(event_date)) FROM test_table WHERE event_date IS NOT NULL GROUP BY event_date HAVING max(date(event_date)) < date '2021-01-01';
SELECT DISTINCT id FROM test_table WHERE value IS NULL AND event_date IS NOT NULL;
CREATE TABLE another_table (related_id INT, description VARCHAR(50));
INSERT INTO another_table VALUES (1, 'Test1'), (2, 'Test2'), (3, 'Test3');
SELECT t1.id, max(t1.value) FROM test_table t1 JOIN another_table t2 ON t1.id = t2.related_id WHERE t1.value IS NOT NULL GROUP BY t1.id HAVING max(t1.value) > 100;
SELECT max(value) FROM (SELECT value, date(event_date) AS event_day FROM test_table) AS derived WHERE event_day IS NOT NULL;