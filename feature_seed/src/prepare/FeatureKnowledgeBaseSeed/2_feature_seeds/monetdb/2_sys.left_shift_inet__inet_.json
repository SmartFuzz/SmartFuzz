CREATE TABLE ip_address_data (id SERIAL PRIMARY KEY, ip_range INET, specific_ip INET);
INSERT INTO ip_address_data (ip_range, specific_ip) VALUES (inet '192.168.1.0/24', inet '192.168.1.5');
INSERT INTO ip_address_data (ip_range, specific_ip) VALUES (inet '10.0.0.0/8', inet '10.0.0.10');
SELECT id FROM ip_address_data WHERE sys.left_shift(ip_range, specific_ip) AND specific_ip % 2 = 0;
CREATE TABLE test_values (val1 INT, val2 INT);
INSERT INTO test_values (val1, val2) VALUES (5, 3), (2, 2), (NULL, 5);
SELECT val1, val2, (val1 % 2) AS odd_check FROM test_values WHERE val1 IS NOT NULL HAVING odd_check = 1;
SELECT id, (sys.left_shift(ip_range, specific_ip::INET) OR specific_ip % CAST(NULL AS INT)) AS shift_result FROM ip_address_data;
CREATE TABLE complex_join_data (ref_id INT, ref_val INT);
INSERT INTO complex_join_data (ref_id, ref_val) VALUES (1, 6), (2, 9), (3, NULL);
SELECT a.id, COALESCE(b.ref_val % 5, 0) AS mod_value FROM ip_address_data a LEFT JOIN complex_join_data b ON a.id = b.ref_id WHERE sys.left_shift(a.ip_range, a.specific_ip) AND a.id IS NOT NULL;
SELECT COUNT(*) FROM (SELECT neat.id, ROW_NUMBER() OVER (PARTITION BY neat.id ORDER BY neat.specific_ip) AS rn FROM ip_address_data neat) AS ranked WHERE rn = 1;
CREATE TABLE boundary_test (b_value NUMERIC(10, 5), b_ip INET);
INSERT INTO boundary_test (b_value, b_ip) VALUES (1.55555, inet '192.168.2.1'), (9999999999.99999, inet '192.168.3.1');
SELECT b_value % 3 AS rem_value, sys.left_shift(b_ip, inet '192.168.2.5') AS shifted FROM boundary_test WHERE b_value IS NOT NULL HAVING rem_value > 1;