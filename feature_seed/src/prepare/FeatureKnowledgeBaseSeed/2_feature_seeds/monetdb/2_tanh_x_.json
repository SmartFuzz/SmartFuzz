CREATE TABLE test_table (id SERIAL PRIMARY KEY, angle DOUBLE PRECISION, uuid_col UUID, value_col DOUBLE PRECISION);
INSERT INTO test_table (angle, uuid_col, value_col) VALUES (1.4, uuid 'e31960fb-dc8b-452d-ab30-b342723e756a', 0.5);
INSERT INTO test_table (angle, uuid_col, value_col) VALUES (NULL, uuid 'f8f29afa-acd2-4a8d-aeb5-6bc8e3801837', 1.0);
INSERT INTO test_table (angle, uuid_col, value_col) VALUES (2.0, NULL, 0.75);
SELECT id, tanh(angle + 1) AS hyperbolic_tangent, uuid_col FROM test_table WHERE uuid_col IS NOT NULL;
SELECT id, angle, tanh(NULLIF(value_col, 0)) AS adjusted_tanh FROM test_table WHERE value_col IS NOT NULL;
SELECT angle, tanh(angle) AS hyper_tanh FROM test_table WHERE angle IS NOT NULL ORDER BY hyper_tanh;
SELECT id, angle, tanh(angle) AS result FROM test_table WHERE result > 0.5;
SELECT id, angle, value_col FROM test_table WHERE uuid_col = (SELECT uuid_col FROM test_table WHERE id = 1);
SELECT id, uuid_col, AVG(value_col) OVER (PARTITION BY uuid_col) AS avg_value FROM test_table GROUP BY id, uuid_col HAVING avg_value > 0.5;
SELECT t.id, t.angle, t.value_col FROM test_table t JOIN (SELECT uuid_col FROM test_table WHERE angle < 2) AS sub ON t.uuid_col = sub.uuid_col;
SELECT angle, tanh(tanh(value_col)) FROM test_table WHERE value_col IS NOT NULL;
SELECT uuid_col, COUNT(*) FROM test_table GROUP BY uuid_col HAVING COUNT(*) > 1;
INSERT INTO test_table (angle, uuid_col, value_col) VALUES (3.14, uuid 'f3c2b53f-db60-482f-aed3-450483cb8f85', NULL);
SELECT tanh(angle) AS value, CAST(uuid_col AS VARCHAR) AS uuid_string FROM test_table WHERE value_col IS NULL;
CREATE TABLE temp_table AS SELECT uuid_col, tanh(angle) AS hyper_tanh_value FROM test_table WHERE angle IS NOT NULL;
SELECT id, uuid_col, tanh(angle + CAST('1.5' AS DOUBLE PRECISION)) FROM test_table ORDER BY uuid_col;
DROP TABLE temp_table;