CREATE TABLE angles (id INT PRIMARY KEY, degree_value DOUBLE);
INSERT INTO angles (id, degree_value) VALUES (1, 0), (2, 45), (3, 90), (4, 180), (5, NULL), (6, -360);
CREATE TABLE ip_addresses (id INT PRIMARY KEY, ip_address INET);
INSERT INTO ip_addresses (id, ip_address) VALUES (1, inet '192.168.1.5'), (2, inet '192.168.1.5'), (3, inet '192.168.2.1'), (4, NULL);
SELECT id, radians(degree_value) AS rad_value FROM angles WHERE radians(degree_value) >= 0;
SELECT a.id, a.degree_value, b.ip_address FROM angles a JOIN ip_addresses b ON a.id = CASE WHEN b.ip_address IS NOT NULL THEN 1 ELSE a.id END;
SELECT MAX(radians(degree_value)) FROM angles GROUP BY id HAVING MAX(radians(degree_value)) IS NOT NULL;
SELECT a.id, radians(a.degree_value) AS radians_value, b.ip_address FROM angles a LEFT JOIN ip_addresses b ON a.id = b.id WHERE radians(degree_value) >= radians(0) AND b.ip_address IS NULL;
SELECT id, COUNT(*) FROM (SELECT a.id, radians(degree_value) FROM angles a WHERE radians(degree_value) < radians(180) UNION SELECT a.id, radians(degree_value) FROM angles a WHERE degree_value IS NULL) subquery GROUP BY id;
SELECT degrees, radians(radians(degree_value)) AS radians_twice FROM (SELECT a.degree_value AS degrees FROM angles a) final_result WHERE degrees > 0;
SELECT inet '192.168.1.1' = inet '192.168.1.5' AS is_equal, radians(90) AS radians_val FROM angles WHERE degree_value IS NULL;
SELECT id, radians(degree_value) * 3.14159 AS calculated_radians FROM angles ORDER BY calculated_radians DESC;
SELECT id, radians(degree_value) FROM (SELECT id, degree_value FROM angles WHERE degree_value IS NOT NULL) temp WHERE id IN (SELECT id FROM ip_addresses WHERE ip_address IS NOT NULL);
SELECT b.id, b.ip_address, a.degree_value, radians(degree_value) AS rad FROM angles a FULL JOIN ip_addresses b ON a.id = b.id WHERE radians(degree_value) IS NOT NULL AND (b.ip_address IS NULL OR b.ip_address = inet '192.168.1.5');