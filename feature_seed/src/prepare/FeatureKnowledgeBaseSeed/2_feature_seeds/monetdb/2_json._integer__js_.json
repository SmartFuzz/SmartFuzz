CREATE TABLE json_test (id int, js json, value bigint);
INSERT INTO json_test (id, js, value) VALUES (1, '{"n": 10}', 5), (2, '{"n": "invalid"}', 15), (3, '{"n": 0}', 20);
SELECT id, json."integer"(js) % value AS mod_result FROM json_test WHERE json."integer"(js) IS NOT NULL;
SELECT id, value, (json."integer"(js) % value) * 2 AS double_mod_result FROM json_test WHERE value > 0;
SELECT id, (CASE WHEN json."integer"(js) IS NULL THEN value ELSE (json."integer"(js) % value) END) AS conditional_mod FROM json_test;
SELECT id, (json."integer"(js) + 20) % (value - 1) AS complex_mod FROM json_test WHERE id IN (SELECT id FROM json_test WHERE value < 10);
CREATE TABLE another_test (a int, b int);
INSERT INTO another_test (a, b) VALUES (5, 2), (10, 0), (15, 3);
SELECT a, b, (SELECT COUNT(*) FROM json_test WHERE json."integer"(js) % another_test.b = 0) AS count_mod_zero FROM another_test;
SELECT a, (json."integer"(js) % b) AS nested_mod FROM another_test JOIN json_test ON json."integer"(js) > 0;
SELECT json."integer"(js) AS js_value, (js_value % 3) AS mod_three FROM (SELECT json."integer"(js) FROM json_test WHERE js IS NOT NULL) AS js_values;