CREATE TABLE test_data (id SERIAL PRIMARY KEY, value NUMERIC, ip_address INET, description TEXT);
INSERT INTO test_data (value, ip_address, description) VALUES (-23.7, inet '192.168.1.5', 'Negative value');
INSERT INTO test_data (value, ip_address, description) VALUES (NULL, inet '192.168.1.6', 'NULL value');
INSERT INTO test_data (value, ip_address, description) VALUES (48.3, inet '192.168.1.7', 'Positive extreme value');
INSERT INTO test_data (value, ip_address, description) VALUES (0, inet '192.168.1.8', 'Zero value');
INSERT INTO test_data (value, ip_address, description) VALUES (1.123456789012345678, inet '192.168.1.9', 'High precision value');
SELECT id, abs(value) AS abs_value FROM test_data WHERE abs(value) < 20;
SELECT id, abs(value) AS abs_value FROM test_data WHERE ip_address < inet '192.168.1.10' AND abs(value) < 50;
SELECT id, abs(value) AS abs_value FROM test_data WHERE value IS NOT NULL HAVING abs(value) < (SELECT AVG(value) FROM test_data);
SELECT d.id, abs(d.value) AS abs_value FROM test_data d JOIN (SELECT value FROM test_data WHERE value IS NOT NULL) AS sub_query ON abs(d.value) < 10;
SELECT id, abs(value) FROM test_data WHERE value < (SELECT max(value) FROM test_data WHERE value > 0);
SELECT d.id, abs(d.value) FROM test_data d LEFT JOIN test_data t ON abs(d.value) < abs(t.value) WHERE d.value IS NOT NULL ORDER BY d.value DESC;