CREATE TABLE ip_addresses (id SERIAL PRIMARY KEY, ip inet NOT NULL);
INSERT INTO ip_addresses (ip) VALUES (inet '10.1.0.1/16'), (inet '192.168.1.1/24'), (inet '10.0.0.0/8');
SELECT sys.abbrev(ip) + ' is the abbreviated format' AS description FROM ip_addresses;
SELECT (SELECT COUNT(*) FROM ip_addresses WHERE sys.abbrev(ip) = 'abbreviated') + (SELECT COUNT(*) FROM ip_addresses WHERE ip IS NOT NULL) AS total_count;
SELECT sys.abbrev(ip) FROM ip_addresses WHERE (sys.abbrev(ip) IS NOT NULL) + (ip IS NULL);
SELECT AVG(LENGTH(sys.abbrev(ip))) FROM ip_addresses GROUP BY ip HAVING COUNT(*) > 1;
SELECT sys.abbrev(ip) FROM ip_addresses JOIN ip_addresses AS temp ON LENGTH(sys.abbrev(temp.ip)) < 10 WHERE ip_addresses.id = temp.id;
SELECT sys.abbrev(ip) AS abbreviated_ip, COUNT(*) OVER(PARTITION BY sys.abbrev(ip)) AS abbrev_count FROM ip_addresses;
CREATE TEMPORARY TABLE temp_ip (ip inet);
INSERT INTO temp_ip (ip) VALUES (inet '0.0.0.0'), (inet '255.255.255.255');
SELECT sys.abbrev(ip) + CAST(' - max value' AS clob) FROM temp_ip WHERE ip IS NOT NULL;
SELECT sys.abbrev(ip) + ' is the abbreviated format' FROM ip_addresses WHERE sys.abbrev(ip) IN (SELECT sys.abbrev(ip) FROM ip_addresses) LIMIT 5;
SELECT COUNT(*) FROM ip_addresses WHERE sys.abbrev(ip) IS NOT NULL GROUP BY (sys.abbrev(ip) + ' unique');
SELECT ip + cast('1' AS inet) AS incremented_ip FROM ip_addresses WHERE ip IS NOT NULL;
SELECT sys.abbrev(ip) + '' AS trivial_concatenation FROM ip_addresses WHERE ip IS NULL;
CREATE TABLE more_ips (ip inet, description clob);
INSERT INTO more_ips (ip, description) VALUES (inet '172.16.0.1', 'local network'), (inet '8.8.8.8', 'Google DNS') ON CONFLICT DO NOTHING;
SELECT sys.abbrev(ip) + ' - ' + description FROM more_ips WHERE description IS NOT NULL;
SELECT AVG(COALESCE(LENGTH(sys.abbrev(ip)), 0)) FROM more_ips;
SELECT SUM(NULLIF(sys.abbrev(ip), '')) + 1 AS adjusted_sum FROM ip_addresses;
CREATE TABLE edge_case_ips (ip inet NOT NULL UNIQUE, invalid clob DEFAULT 'invalid');
INSERT INTO edge_case_ips (ip) VALUES (inet '10.1.0.0/16'), (inet '::1') ON CONFLICT DO NOTHING;
SELECT sys.abbrev(ip) + ' -> mapped' AS mapped_ip FROM edge_case_ips WHERE ip IS NOT NULL;