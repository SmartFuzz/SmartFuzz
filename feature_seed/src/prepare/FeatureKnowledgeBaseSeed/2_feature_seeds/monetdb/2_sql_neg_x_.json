CREATE TABLE test_table (id INT, value DECIMAL(10, 5), description TEXT);
INSERT INTO test_table (id, value, description) VALUES (1, 5.0, 'Initial value'), (2, 0.0, 'Zero value'), (3, -15.5, 'Negative value');
SELECT sql_neg(value) / (SELECT COUNT(*) FROM test_table WHERE id > 1) AS neg_division FROM test_table;
SELECT id, value, sql_neg(value) AS neg_value FROM test_table WHERE sql_neg(value) / 2 < -1;
SELECT id, SUM(sql_neg(value) / NULLIF(value, 0)) AS adjusted_sum FROM test_table GROUP BY id HAVING adjusted_sum IS NOT NULL;
SELECT id, sql_neg(SUM(value) / (SELECT COUNT(DISTINCT id) FROM test_table WHERE value < 0)) AS average_neg FROM test_table GROUP BY id;
CREATE TABLE another_table (ref_id INT, more_value DECIMAL(10, 5), FOREIGN KEY(ref_id) REFERENCES test_table(id));
INSERT INTO another_table (ref_id, more_value) VALUES (1, 3.14), (2, -2.71), (3, NULL);
SELECT a.ref_id, sql_neg(a.more_value) / (SELECT COUNT(*) FROM another_table WHERE more_value IS NOT NULL) AS neg_avg FROM another_table a JOIN test_table t ON a.ref_id = t.id;
SELECT CASE WHEN value IS NULL THEN 'No Value' ELSE CAST(sql_neg(value) AS TEXT) END AS neg_value_msg FROM test_table;
SELECT id, value, (sql_neg(value) + 1.5) / (SELECT COUNT(*) FROM test_table) AS adjusted_value FROM test_table WHERE value IS NOT NULL ORDER BY adjusted_value DESC;