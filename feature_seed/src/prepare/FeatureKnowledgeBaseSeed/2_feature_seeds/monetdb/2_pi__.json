CREATE TABLE test_table (id INT PRIMARY KEY, value DOUBLE, str_value VARCHAR(50));
INSERT INTO test_table VALUES (1, pi(), 'foo'), (2, pi() * 2, NULL), (3, NULL, 'bar');
CREATE TABLE join_table (join_id INT PRIMARY KEY, join_value INT);
INSERT INTO join_table VALUES (1, ~1), (2, ~2), (3, NULL);
SELECT t1.id, t1.value, ~CAST(t1.value AS INT) AS neg_value FROM test_table t1 WHERE t1.str_value IS NULL;
SELECT t1.id, (SELECT COUNT(*) FROM join_table j WHERE j.join_value = ~2) AS count_value FROM test_table t1;
SELECT t1.id, t1.value, SUM(t1.value) OVER (PARTITION BY (CASE WHEN t1.value > 0 THEN ~1 ELSE t1.id END)) AS summed_value FROM test_table t1 GROUP BY t1.id, t1.value HAVING COUNT(t1.str_value) < 2;
SELECT t1.id, CASE WHEN t1.value IS NOT NULL THEN ~CAST(t1.value AS INT) ELSE 0 END AS computed_value FROM test_table t1 JOIN join_table j ON j.join_value = ~1;
SELECT t1.id, t1.value, pi() + ~CAST(t1.value AS INT) AS result FROM test_table t1 WHERE (SELECT COUNT(*) FROM join_table j WHERE j.join_value IS NOT NULL) = 3;
DROP TABLE IF EXISTS test_table;
DROP TABLE IF EXISTS join_table;