CREATE TABLE users (id INT PRIMARY KEY, metadata JSON, age INT);
INSERT INTO users (id, metadata, age) VALUES (1, '{"n":4}', 25);
INSERT INTO users (id, metadata, age) VALUES (2, '{"m":5}', 30);
INSERT INTO users (id, metadata, age) VALUES (3, NULL, 28);
INSERT INTO users (id, metadata, age) VALUES (4, '{"k":4}', NULL);
CREATE TABLE orders (id INT PRIMARY KEY, user_id INT, order_details JSON, amount DECIMAL(10,2));
INSERT INTO orders (id, user_id, order_details, amount) VALUES (1, 1, '{"item":"A"}', 150.75);
INSERT INTO orders (id, user_id, order_details, amount) VALUES (2, 2, '{"item":"B"}', 100.50);
INSERT INTO orders (id, user_id, order_details, amount) VALUES (3, NULL, '{"item":"C"}', 200.00);
INSERT INTO orders (id, user_id, order_details, amount) VALUES (4, 2, NULL, 50.00);
SELECT user_id, json.isobject(order_details) AS is_json_object FROM orders WHERE amount < 100.00;
SELECT u.id, u.age, (SELECT COUNT(*) FROM orders o WHERE o.user_id = u.id) AS order_count FROM users u WHERE json.isobject(u.metadata) AND u.age < 30;
SELECT u.id, AVG(o.amount) AS avg_amount FROM users u JOIN orders o ON u.id = o.user_id WHERE json.isobject(o.order_details) GROUP BY u.id HAVING avg_amount < 200.00;
SELECT u.id, (CASE WHEN json.isobject(u.metadata) THEN 'Valid' ELSE 'Invalid' END) AS metadata_status FROM users u WHERE u.age IS NOT NULL;
SELECT DISTINCT (SELECT MAX(amount) FROM orders WHERE user_id < 3) AS max_amount, json.isobject(NULLIF(('{"test":3}'),'{}')) AS is_not_empty;
SELECT u.id, json.isobject(o.order_details) AS details_check FROM users u LEFT JOIN orders o ON u.id = o.user_id WHERE (u.age < (SELECT MIN(age) FROM users)) OR (u.metadata IS NULL);