CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE, user_ip INET, value INT);
INSERT INTO test_dates (id, event_date, user_ip, value) VALUES (1, current_date(), inet '192.168.1.1', 10);
INSERT INTO test_dates (id, event_date, user_ip, value) VALUES (2, current_date() - INTERVAL '1 week', inet '192.168.1.2', 20);
INSERT INTO test_dates (id, event_date, user_ip, value) VALUES (3, NULL, inet '192.168.1.3', 30);
INSERT INTO test_dates (id, event_date, user_ip, value) VALUES (4, current_date() + INTERVAL '1 month', inet '192.168.1.4', NULL);
SELECT *, (event_date >= current_date()) AS is_today FROM test_dates WHERE user_ip >= inet '192.168.1.1' OR value IS NULL;
SELECT AVG(COALESCE(value, 0)) AS avg_value FROM test_dates GROUP BY (CASE WHEN event_date IS NULL THEN 1 ELSE 0 END) HAVING AVG(value) >= 15;
SELECT id, user_ip, (current_date() - event_date) AS days_since_event FROM test_dates WHERE user_ip >= inet '192.168.1.5' AND event_date >= current_date() - INTERVAL '1 month';
SELECT * FROM (SELECT id, user_ip, COUNT(*) AS total_events FROM test_dates GROUP BY user_ip) AS user_counts WHERE total_events >= 2;
SELECT id, event_date, user_ip FROM test_dates WHERE (event_date IS NOT NULL AND user_ip >= inet '192.168.1.5') ORDER BY current_date() - event_date;
SELECT (current_date() - MAX(event_date)) AS days_since_last_event FROM test_dates WHERE user_ip IS NOT NULL;