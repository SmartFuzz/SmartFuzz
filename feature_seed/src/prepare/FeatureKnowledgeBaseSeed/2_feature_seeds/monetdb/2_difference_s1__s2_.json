CREATE TABLE test_table (id int PRIMARY KEY, name varchar(255), address inet);
INSERT INTO test_table (id, name, address) VALUES (1, 'MonetDB', inet '192.168.1.1');
INSERT INTO test_table (id, name, address) VALUES (2, 'DB4', inet '192.168.2.1');
INSERT INTO test_table (id, name, address) VALUES (3, 'MonetDB', NULL);
INSERT INTO test_table (id, name, address) VALUES (4, NULL, inet '192.168.1.2');
SELECT id, name, address, difference((SELECT name FROM test_table WHERE id = 1), (SELECT name FROM test_table WHERE id = 2)) AS soundex_diff FROM test_table;
SELECT id, address, (SELECT COUNT(*) FROM test_table t2 WHERE t2.address <<= test_table.address) AS contained_count FROM test_table HAVING contained_count > 1;
SELECT id, difference(name, (SELECT name FROM test_table WHERE id = 3)) AS soundex_difference FROM test_table WHERE address IS NOT NULL;
SELECT id, address, difference( (SELECT name FROM test_table WHERE id = 1), (SELECT name FROM test_table WHERE id = 4) ) AS soundex FROM test_table WHERE address <<= inet '192.168.1.0/24';
SELECT t1.id, t1.name, COUNT(*) AS count_diff FROM test_table t1 JOIN test_table t2 ON difference(t1.name, t2.name) > 0 GROUP BY t1.id, t1.name HAVING count_diff > 0;