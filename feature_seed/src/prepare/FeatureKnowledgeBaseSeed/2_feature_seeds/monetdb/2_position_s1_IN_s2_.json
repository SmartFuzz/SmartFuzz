CREATE TABLE test_strings (id INT PRIMARY KEY, str_value VARCHAR(255));
CREATE TABLE test_dates (id INT PRIMARY KEY, date_value DATE);
INSERT INTO test_strings VALUES (1, 'MonetDB is awesome'), (2, 'SQL Fuzz Testing');
INSERT INTO test_dates VALUES (1, date '2020-01-01'), (2, date '2023-01-01');
SELECT position('DB' IN str_value), date_value FROM test_strings JOIN test_dates ON position('DB' IN str_value) > 0 WHERE date_value > date '2020-01-01' ORDER BY position('DB' IN str_value);
SELECT str_value, (SELECT count(*) FROM test_dates WHERE date_value < date '2021-01-01') AS count_before FROM test_strings GROUP BY str_value HAVING position('DB' IN str_value) > 0;
SELECT str_value, date_value FROM test_strings, test_dates WHERE NULLIF(date_value, date '2020-01-01') IS NOT NULL AND position('SQL' IN str_value) > 0;
SELECT str_value, date_value FROM (SELECT str_value, date_value FROM test_strings CROSS JOIN test_dates) AS combined WHERE position('is' IN str_value) > 0 AND date_value = date '2023-01-01';
SELECT DISTINCT str_value, date_value FROM test_strings JOIN test_dates ON position('awesome' IN str_value) > 0 AND date_value < date '2024-01-01' WHERE str_value IS NOT NULL UNION SELECT str_value, date_value FROM test_strings WHERE str_value LIKE '';
SELECT position(NULL IN str_value), date_value FROM test_strings LEFT JOIN test_dates ON position('DB' IN str_value) IS NULL WHERE date_value IS NOT NULL;