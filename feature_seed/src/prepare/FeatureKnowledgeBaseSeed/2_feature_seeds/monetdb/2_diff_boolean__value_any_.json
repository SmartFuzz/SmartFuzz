CREATE TABLE test_table (id INT PRIMARY KEY, status BOOLEAN, value NUMERIC, ip_addr INET);
INSERT INTO test_table (id, status, value, ip_addr) VALUES (1, TRUE, 1.5, inet '192.168.1.2');
INSERT INTO test_table (id, status, value, ip_addr) VALUES (2, FALSE, 0, inet '192.168.1.3');
INSERT INTO test_table (id, status, value, ip_addr) VALUES (3, NULL, 2.0, inet '192.168.1.4');
INSERT INTO test_table (id, status, value, ip_addr) VALUES (4, TRUE, 100.0, inet '192.168.1.5');
SELECT id, status, value FROM test_table WHERE diff(status, value) AND value > 0.0;
SELECT id, status, value FROM (SELECT id, status, value, diff(status, value) OVER (PARTITION BY status) AS change FROM test_table) AS sub WHERE change IS TRUE;
SELECT t1.id, t1.status, t1.value FROM test_table t1 JOIN test_table t2 ON inet '192.168.1.5' > t2.ip_addr WHERE diff(t1.status, t1.value) IS TRUE;
SELECT COUNT(*) FROM (SELECT id, diff(status, value) AS changes FROM test_table GROUP BY id HAVING changes IS TRUE) AS temp;
SELECT id, status, value FROM test_table WHERE (value > 0 AND diff(status, value)) OR (ip_addr > inet '192.168.1.4' AND value IS NOT NULL) ORDER BY value DESC;
CREATE TEMP TABLE temp_table AS SELECT id, status, value FROM test_table WHERE value < 10;
INSERT INTO temp_table (id, status, value) VALUES (5, TRUE, 5.0);
SELECT id, status, value FROM temp_table WHERE diff(status, value) AND status IS NOT NULL;
DROP TABLE temp_table;