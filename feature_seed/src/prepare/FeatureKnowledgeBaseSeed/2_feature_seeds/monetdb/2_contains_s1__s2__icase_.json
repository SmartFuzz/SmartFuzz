CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(50), join_date TIMESTAMP, value DECIMAL(10, 2));
INSERT INTO test_table (id, name, join_date, value) VALUES (1, 'Alice', '2020-09-28 10:00:00', 100.00);
INSERT INTO test_table (id, name, join_date, value) VALUES (2, 'Bob', '2020-09-28 11:00:00', NULL);
INSERT INTO test_table (id, name, join_date, value) VALUES (3, NULL, '2020-09-28 12:00:00', 200.00);
INSERT INTO test_table (id, name, join_date, value) VALUES (4, 'Charlie', '2020-09-28 13:00:00', -50.00);
SELECT id, name, join_date + (interval '1' second * (3 * 24 * 60 * 60)) AS updated_date FROM test_table WHERE value > 0;
SELECT id, name, value, contains(name, 'a', true) AS contains_a FROM test_table WHERE contains(name, '', true) IS NULL;
SELECT t1.id, t1.name FROM test_table AS t1 JOIN test_table AS t2 ON t1.id = t2.id WHERE contains(t1.name, SUBSTRING(t2.name, 1, 3), true) IS TRUE;
SELECT COUNT(*) FROM test_table WHERE contains(name, 'a', true) = FALSE GROUP BY value HAVING AVG(value) < 0;
SELECT id, name, join_date, value FROM test_table WHERE (join_date + (interval '1' second * (1 * 24 * 60 * 60))) IS NOT NULL AND (contains(name, NULL, false) IS NULL);
CREATE TEMPORARY TABLE temp_table AS SELECT id, value + 10.00 AS adjusted_value FROM test_table WHERE value IS NOT NULL;
SELECT id, adjusted_value FROM temp_table WHERE adjusted_value > (SELECT AVG(value) FROM test_table) ORDER BY adjusted_value DESC;