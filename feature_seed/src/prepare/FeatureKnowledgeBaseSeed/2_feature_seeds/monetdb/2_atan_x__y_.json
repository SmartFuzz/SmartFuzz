CREATE TABLE test_table (id INT PRIMARY KEY, angle_x DOUBLE, angle_y DOUBLE, angle_date DATE);
INSERT INTO test_table (id, angle_x, angle_y, angle_date) VALUES (1, 1.0, 2.0, date '2020-01-01');
INSERT INTO test_table (id, angle_x, angle_y, angle_date) VALUES (2, 3.0, 4.0, date '2020-01-02');
INSERT INTO test_table (id, angle_x, angle_y, angle_date) VALUES (3, NULL, 5.0, date '2020-01-03');
SELECT atan(angle_x, angle_y) AS angle_radians FROM test_table WHERE angle_date = date '2020-01-01';
SELECT angle_date, atan(angle_x, angle_y) FROM test_table WHERE angle_y IS NOT NULL;
SELECT a.id, atan(a.angle_x, a.angle_y) AS angle_radians FROM test_table a JOIN test_table b ON a.id <> b.id WHERE a.angle_date > b.angle_date;
SELECT angle_date, COUNT(*) AS count_angles FROM test_table GROUP BY angle_date HAVING atan(MAX(angle_x), MIN(angle_y)) IS NOT NULL;
SELECT DISTINCT angle_date, atan(angle_x, angle_y) AS angle_radians FROM test_table WHERE angle_date < date '2020-01-05' ORDER BY angle_radians DESC;
SELECT angle_date, atan(angle_x, angle_y) AS angle_radians FROM (SELECT * FROM test_table WHERE angle_y > 0) AS subquery HAVING angle_radians > 0;