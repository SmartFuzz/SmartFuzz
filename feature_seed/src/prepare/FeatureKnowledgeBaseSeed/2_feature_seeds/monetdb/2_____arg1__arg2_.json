CREATE TABLE test_table (id INT, name TEXT, created_at TIMESTAMP, amount NUMERIC, status BOOLEAN);
INSERT INTO test_table VALUES (1, 'John', '2022-01-01 12:00:00', 200.50, TRUE);
INSERT INTO test_table VALUES (2, 'Jane', '2022-01-02 12:00:00', 150.75, NULL);
INSERT INTO test_table VALUES (3, 'Alice', '2022-01-03 12:00:00', NULL, TRUE);
INSERT INTO test_table VALUES (4, 'Bob', '2022-01-04 12:00:00', 300.00, FALSE);
SELECT name, (created_at + (interval '1' second * (amount IS NULL OR amount::int))) AS adjusted_time FROM test_table WHERE status IS NOT NULL AND amount >= 100.00;
SELECT id, name FROM test_table WHERE id <= (SELECT MIN(id) FROM test_table WHERE status IS NULL) + (1);
SELECT SUM(amount) AS total_amount FROM test_table GROUP BY status HAVING status IS TRUE OR (amount IS NULL AND amount <= 100.00);
SELECT COUNT(*) FROM test_table WHERE status IS NOT NULL AND (name <= (SELECT name FROM test_table ORDER BY created_at LIMIT 1));
WITH adjusted_values AS (SELECT id, (created_at + (interval '1' second * (amount IS NOT NULL)::int)) AS new_time FROM test_table) SELECT id FROM adjusted_values WHERE new_time <= '2022-01-02 12:00:00';
CREATE TEMPORARY TABLE temp_table AS SELECT id, amount, name FROM test_table WHERE amount IS NOT NULL AND name + 'Test' <= 'JaneTest';