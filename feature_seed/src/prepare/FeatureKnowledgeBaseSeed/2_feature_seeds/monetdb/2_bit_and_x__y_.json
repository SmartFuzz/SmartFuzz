CREATE TABLE test_data (id int, flag varchar(10), timestamp_col timestamp, value int);
INSERT INTO test_data (id, flag, timestamp_col, value) VALUES (1, 'a', '2023-10-01 10:00:00', 95);
INSERT INTO test_data (id, flag, timestamp_col, value) VALUES (2, 'b', '2023-10-01 11:00:00', 5);
INSERT INTO test_data (id, flag, timestamp_col, value) VALUES (3, 'c', NULL, 15);
INSERT INTO test_data (id, flag, timestamp_col, value) VALUES (4, 'd', '2023-10-01 12:00:00', NULL);
SELECT id, bit_and(value, 15) FROM test_data GROUP BY id HAVING bit_and(value, 15) > 0;
SELECT id, time(6) '2023-10-01 10:00:00' AS event_time, bit_and(value, 15) AS combined_value FROM test_data WHERE flag IS NOT NULL ORDER BY combined_value DESC;
SELECT id, time(6) value::text FROM test_data WHERE value IS NOT NULL AND bit_and(value, 7) = 7;
SELECT id, bit_and(value, (SELECT MAX(value) FROM test_data WHERE id <> 3)) AS max_bitwise_value FROM test_data GROUP BY id;
INSERT INTO test_data (id, flag, timestamp_col, value) VALUES (5, 'e', '2023-10-01 10:15:00', -1);
SELECT COUNT(*) FROM (SELECT id, bit_and(value, 8) AS and_result FROM test_data GROUP BY id HAVING and_result IS NOT NULL) AS temp;
CREATE TABLE another_data (id int, event_time time(6), remarks text);
INSERT INTO another_data (id, event_time, remarks) VALUES (1, time(6) '12:30:45.678912', 'Test remark 1');
INSERT INTO another_data (id, event_time, remarks) VALUES (2, time(6) '10:15:00.123456', 'Test remark 2');
SELECT t.id, t.flag, a.event_time FROM test_data t JOIN another_data a ON time(6) '10:15:00.123456' = a.event_time WHERE bit_and(t.value, 3) > 1;
DELETE FROM test_data WHERE flag IS NULL OR value IS NULL;
SELECT DISTINCT t.id, bit_and((SELECT value FROM test_data WHERE id = t.id), 5) AS bitwise_value FROM test_data t WHERE flag LIKE 'a%' ORDER BY bitwise_value DESC;
CREATE TEMP TABLE temp_table AS SELECT id, bit_and(value, 15) AS computed_value FROM test_data WHERE value IS NOT NULL;