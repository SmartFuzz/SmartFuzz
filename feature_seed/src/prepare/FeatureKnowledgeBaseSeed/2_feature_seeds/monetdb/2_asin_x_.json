CREATE TABLE test_table (id INT PRIMARY KEY, value DOUBLE, hex_value VARCHAR(20));
INSERT INTO test_table (id, value, hex_value) VALUES (1, 0.5, 'abcde'), (2, -1.0, '10ff'), (3, 0.9999999999, 'ffffff');
SELECT id, asin(value), x'68656c6c6f' AS binary_data FROM test_table WHERE value > 0;
SELECT id, asin(CAST(x'40a8' AS DOUBLE)) AS arc_sine_value FROM test_table WHERE hex_value NOT LIKE 'a%';
SELECT id, value, x'4d617274' AS hex_string FROM test_table WHERE value IS NOT NULL HAVING asin(value) IS NOT NULL;
SELECT t1.id, t1.value, t2.hex_value FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE asin(t1.value) < 1 AND x'abcdef' IS NOT NULL;
SELECT id, value, x'22' AS hex_value FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value < 0) ORDER BY asin(value);
CREATE TEMPORARY TABLE temp_table AS SELECT id, asin(value) AS arc_value FROM test_table WHERE value BETWEEN -1 AND 1;
INSERT INTO temp_table (id, arc_value) SELECT id, x'ff' FROM test_table WHERE value > 0.99;
SELECT id, value, x'1a' AS hex_val FROM test_table WHERE id NOT IN (SELECT id FROM temp_table) HAVING asin(value) IS NOT NULL;