CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(50), value INTEGER);
INSERT INTO test_table (id, name, value) VALUES (1, 'aabcc', 16), (2, 'bbbdd', 32), (3, NULL, 64), (4, 'aaaa', 128);
SELECT ltrim(name, 'a') << 2 AS shifted_name FROM test_table WHERE value > 12;
SELECT id, ltrim(name, 'a') AS trimmed_name, value << 3 AS shifted_value FROM test_table WHERE value IS NOT NULL ORDER BY shifted_value;
SELECT ltrim(name, 'b') << (SELECT MAX(value) FROM test_table WHERE value IS NOT NULL) AS final_shifted FROM test_table;
SELECT id, ltrim(name, 'a') << 5 AS complex_shift FROM test_table WHERE ltrim(name, 'b') IS NOT NULL AND ltrim(name, 'a') <> '';
CREATE TABLE another_table (id INTEGER PRIMARY KEY, test_id INTEGER REFERENCES test_table(id), created_at TIMESTAMP);
INSERT INTO another_table (id, test_id, created_at) VALUES (1, 1, '2023-01-01 00:00:00'), (2, 2, NULL), (3, 3, '2023-01-03 12:30:00');
SELECT A.id, ltrim(B.name, 'a') << (CASE WHEN B.value IS NULL THEN 0 ELSE B.value END) AS shifted_result FROM another_table A JOIN test_table B ON A.test_id = B.id WHERE B.value < 64;
SELECT ltrim(name, 'a') AS trimmed_name, COUNT(*) AS count FROM test_table GROUP BY trimmed_name HAVING COUNT(*) > 1;