CREATE TABLE test_table (id INT, value FLOAT, label TEXT);
INSERT INTO test_table (id, value, label) VALUES (1, 1.5, 'A'), (2, 3.7, 'B'), (3, NULL, 'C');
SELECT sql_max(value + 2, (SELECT sql_max(value) FROM test_table WHERE label = 'A')) AS max_value FROM test_table;
SELECT id, sql_max(value - 2, 0) AS adjusted_value FROM test_table GROUP BY id HAVING adjusted_value > 0;
SELECT t1.id, t1.value, sql_max(t1.value - 1, t2.value) AS max_difference FROM test_table t1 JOIN test_table t2 ON t1.id <> t2.id WHERE t1.value IS NOT NULL;
SELECT id, sql_max(sql_max(value, 10) - 2, sql_max(value - 1, 0)) AS computed_value FROM test_table GROUP BY id ORDER BY computed_value DESC;
SELECT sql_max(NULL, 5 - 2) AS result WHERE NOT EXISTS (SELECT * FROM test_table WHERE id = 4);
SELECT t1.id, sql_max(t1.value, (SELECT sql_max(value) FROM test_table WHERE label IS NULL)) AS max_condition FROM test_table t1 LEFT JOIN test_table t2 ON t1.label = t2.label;
CREATE TABLE another_table (key INT PRIMARY KEY, amount DECIMAL(10,2), notes VARCHAR(255));
INSERT INTO another_table (key, amount, notes) VALUES (1, NULL, 'Test1'), (2, 123.4567, 'Test2');
SELECT sql_max(t1.amount, 100 - t2.amount) AS max_adjusted FROM another_table t1 JOIN another_table t2 ON t1.key = t2.key;
CREATE TEMPORARY TABLE temp_table AS SELECT id, sql_max(NULLIF(value, 0), 1) AS safe_value FROM test_table;
SELECT t.key, sql_max(t.safe_value, (SELECT sql_max(amount) FROM another_table)) AS final_max FROM temp_table t GROUP BY t.key HAVING final_max > 1;