CREATE TABLE test_table1 (id INT PRIMARY KEY, value1 BOOLEAN, value2 INT, value3 VARCHAR(255));
INSERT INTO test_table1 (id, value1, value2, value3) VALUES (1, TRUE, 5, 'Test'), (2, FALSE, 0, 'Sample'), (3, NULL, 3, 'Edge');
CREATE TABLE test_table2 (id INT PRIMARY KEY, ref_id INT, amount DECIMAL(10, 2));
INSERT INTO test_table2 (id, ref_id, amount) VALUES (1, 1, 10.00), (2, 1, 15.50), (3, 3, NULL);
SELECT id, value1, (SELECT COUNT(*) FROM test_table2 WHERE ref_id = test_table1.id AND NOT (amount IS NULL)) AS valid_counts FROM test_table1 WHERE NOT (value1 IS NULL) AND value2 % 2 = 0;
SELECT t1.id, t2.amount, NOT (t1.value1) AS negated_value FROM test_table1 t1 JOIN test_table2 t2 ON t1.id = t2.ref_id WHERE NOT (t1.value1) OR t2.amount % 5 = 0 ORDER BY NOT (t1.value1) DESC, t2.amount ASC;
SELECT t2.ref_id, COUNT(*) AS cnt FROM test_table2 t2 WHERE amount IS NOT NULL GROUP BY t2.ref_id HAVING NOT (COUNT(*) % 2 = 0);
WITH summarized AS (SELECT value2, COUNT(*) AS cnt FROM test_table1 GROUP BY value2) SELECT value2, cnt, NOT (cnt > 1) AS is_unique FROM summarized WHERE value2 % 3 = 0;
SELECT t1.value3, (SELECT SUM(amount) FROM test_table2 t2 WHERE NOT (t2.amount IS NULL) AND t1.id = t2.ref_id) AS total_amount FROM test_table1 t1 WHERE NOT (t1.value2 % 3 = 0) AND (SELECT COUNT(*) FROM test_table2 t2 WHERE NOT (t2.amount IS NULL)) > 1;
CREATE TABLE test_table3 (id INT PRIMARY KEY, is_active BOOLEAN, created_at TIMESTAMP);
INSERT INTO test_table3 (id, is_active, created_at) VALUES (1, TRUE, NOW()), (2, FALSE, NOW()), (3, NULL, NOW());
SELECT id, NOT (is_active) AS inactive_flag, (created_at % INTERVAL '1 day') AS mod_days FROM test_table3 WHERE NOT (is_active) OR id % 2 = 0 ORDER BY inactive_flag;