CREATE TABLE test_table (id INT, data JSON, value DECIMAL(10, 2));
INSERT INTO test_table (id, data, value) VALUES (1, json '[1, 2, 3]', 10.00), (2, json '[]', NULL), (3, json '[100,200,300]', 20.50);
SELECT id, json.text(data, 'x') AS glued_data FROM test_table WHERE json.text(data, 'x') <= '100x200x300';
SELECT id, COUNT(*) FROM test_table WHERE json.text(data, ',') <= '1' GROUP BY id HAVING COUNT(*) >= 1;
SELECT id, json.text(data, ' ') FROM test_table WHERE (value + 0) <= 20;
SELECT id, (SELECT MAX(value) FROM test_table) AS max_value FROM test_table WHERE json.text(data, '-') <= (SELECT json.text(data, ',') FROM test_table WHERE id = 1);
CREATE TABLE another_table (id INT, foreign_id INT, CONSTRAINT fk FOREIGN KEY (foreign_id) REFERENCES test_table(id));
INSERT INTO another_table (id, foreign_id) VALUES (1, 1), (2, 2), (3, 3);
SELECT at.id, json.text(tt.data, '|') AS joined_data FROM another_table at JOIN test_table tt ON tt.id = at.foreign_id WHERE json.text(tt.data, '|') <= (SELECT json.text(data, '|') FROM test_table WHERE id = 3);
SELECT id, json.text(data, 'X') AS concatenated FROM test_table WHERE data IS NOT NULL AND value IS NOT NULL AND (json.text(data, ',') <= '1X2X3');
DROP TABLE IF EXISTS test_table;
DROP TABLE IF EXISTS another_table;