CREATE TABLE angles (id INT PRIMARY KEY, angle DOUBLE);
INSERT INTO angles (id, angle) VALUES (1, 0.0), (2, 1.5708), (3, 3.1416), (4, 4.7124), (5, 16.0);
SELECT id, cot(angle) AS cotangent FROM angles WHERE cot(angle) <= 1;
CREATE TABLE measurements (id INT PRIMARY KEY, angle_id INT, value DOUBLE, FOREIGN KEY (angle_id) REFERENCES angles(id));
INSERT INTO measurements (id, angle_id, value) VALUES (1, 1, NULL), (2, 1, 0.1), (3, 2, 2.0), (4, 3, 3.0), (5, 4, 5.0);
SELECT m.id, m.value, cot(m.value) AS cot_value FROM measurements m WHERE m.value IS NOT NULL AND cot(m.value) <= 5;
SELECT m.id, m.value, cot(m.value) AS cot_value FROM measurements m WHERE m.value IS NULL OR (m.value <= 2 AND cot(m.value) <= 1);
SELECT m.id, cot(m.value) AS cot_value, (SELECT COUNT(*) FROM measurements WHERE value > 2) AS count_above_2 FROM measurements m GROUP BY m.id HAVING cot_value <= (SELECT AVG(cot(value)) FROM measurements WHERE value IS NOT NULL);
SELECT m.id, cot(m.angle_id * 2.0) FROM measurements m JOIN angles a ON m.angle_id = a.id WHERE a.angle <= 3.0 ORDER BY cot(m.angle_id * 2.0) ASC;
CREATE TEMP TABLE temp_results AS SELECT id, value FROM measurements WHERE value IS NOT NULL ORDER BY value DESC;
SELECT tr.id, COALESCE(cot(tr.value), 0) AS cot_value FROM temp_results tr WHERE cot_value <= 1 AND tr.value IS NOT NULL;