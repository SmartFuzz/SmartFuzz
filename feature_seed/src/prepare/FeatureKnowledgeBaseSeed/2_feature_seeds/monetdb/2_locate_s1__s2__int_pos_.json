CREATE TABLE TestStrings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255));
INSERT INTO TestStrings (id, str1, str2) VALUES (1, 'DB', 'DBMonetDB'), (2, 'ABC', 'ABCDDB'), (3, NULL, 'TestDB');
SELECT id, locate(r'A\D', str2, 1) AS position FROM TestStrings WHERE locate(str1, r'A\D') > 0;
SELECT str1, str2, locate(r'A\Z', str2, 0) AS position FROM TestStrings WHERE str1 IS NULL;
SELECT id, str1, str2, CASE WHEN locate(r'A\B', str2, 1) > 0 THEN 'Found' ELSE 'Not Found' END AS search_result FROM TestStrings;
CREATE TABLE JoinTest (id INT PRIMARY KEY, foreign_id INT, str_value VARCHAR(255));
INSERT INTO JoinTest (id, foreign_id, str_value) VALUES (1, 1, 'ABCD'), (2, 2, 'DCBA');
SELECT TT.id, TT.str_value, T.str1 FROM JoinTest TT JOIN TestStrings T ON TT.foreign_id = T.id WHERE locate(r'A\B', T.str2, 1) = 0;
WITH RankedStrings AS (SELECT id, str1, str2, locate(str1, str2, 1) AS loc FROM TestStrings ORDER BY loc DESC) SELECT * FROM RankedStrings WHERE loc IS NOT NULL;
SELECT count(*) AS total_found FROM TestStrings WHERE locate(r'DB', str2, 1) > 0 GROUP BY locate(str1, str2);