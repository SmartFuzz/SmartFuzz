CREATE TABLE test_table (id INT, name VARCHAR(255), data BLOB);
INSERT INTO test_table (id, name, data) VALUES (1, 'Alice', x'48656c6c6f'), (2, 'Bob', x'776f726c64'), (3, NULL, x'');
SELECT ucase(name) AS upper_name, id, data FROM test_table WHERE data IS NOT NULL AND id < (SELECT MAX(id) FROM test_table) ORDER BY upper_name;
SELECT ucase(name), id FROM test_table WHERE id IN (SELECT id FROM test_table WHERE data IS NOT NULL) AND name IS NOT NULL;
SELECT COUNT(*) FROM (SELECT ucase(name) FROM test_table WHERE data = x'48656c6c6f') AS subquery GROUP BY ucase(name) HAVING COUNT(*) > 1;
CREATE TABLE another_table (value INT NOT NULL CHECK (value > 0), description VARCHAR(255));
INSERT INTO another_table (value, description) VALUES (10, 'Valid Entry'), (0, 'Invalid Entry'), (NULL, 'Null Entry');
SELECT a.value, ucase(a.description) FROM another_table a JOIN test_table t ON a.value = (SELECT id FROM test_table WHERE name IS NOT NULL LIMIT 1) WHERE a.description IS NOT NULL;
SELECT ucase('TEST ' || name) AS upper_combined FROM test_table WHERE LENGTH(ucase(name)) > 5;
CREATE TEMPORARY TABLE temp_table AS SELECT id, ucase(name) AS name_upper FROM test_table WHERE name IS NOT NULL;
SELECT ucase(name_upper) FROM temp_table WHERE id IN (SELECT id FROM test_table WHERE data IS NOT NULL) ORDER BY name_upper DESC;
DELETE FROM test_table WHERE id = (SELECT id FROM temp_table WHERE name_upper = ucase('ALICE')) OR data IS NULL;
ALTER TABLE test_table ADD COLUMN additional_info VARCHAR(255);
UPDATE test_table SET additional_info = ucase(LEADING '0x' FROM hex_value::VARCHAR) WHERE id = 2;
SELECT ucase(data::VARCHAR) FROM test_table WHERE ucase(name) <> '' AND id > (SELECT COUNT(*) FROM test_table);