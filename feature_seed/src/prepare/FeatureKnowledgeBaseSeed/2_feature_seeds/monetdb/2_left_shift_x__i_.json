CREATE TABLE test_table (id INT, value INT, str_value VARCHAR(10), null_value INT);
INSERT INTO test_table (id, value, str_value, null_value) VALUES (1, 2, '42', NULL), (2, 5, 'NULL', 3), (3, 1, '123', NULL), (4, NULL, 'text', 20);
SELECT id, left_shift(value, 1) AS shifted_value FROM test_table WHERE left_shift(value, 2) = 8;
SELECT id FROM test_table WHERE str_value = 'NULL' AND left_shift(COALESCE(value, 0), 3) <= 40;
SELECT id, left_shift(value, 1) AS shifted_value FROM test_table WHERE shifted_value = left_shift((SELECT AVG(value) FROM test_table WHERE null_value IS NOT NULL), 1);
SELECT id, left_shift(value, 1) FROM test_table WHERE EXISTS (SELECT 1 FROM test_table t2 WHERE t2.null_value IS NULL AND t2.value = left_shift(value, 0));
SELECT id, COUNT(*) FROM (SELECT id, left_shift(value, 1) AS shifted_value FROM test_table GROUP BY left_shift(value, 1) HAVING shifted_value = 4) AS temp;
SELECT id, (SELECT left_shift(MAX(value), 2) FROM test_table WHERE null_value IS NOT NULL) AS max_shifted FROM test_table WHERE left_shift(value, 1) BETWEEN 0 AND (SELECT left_shift(MIN(value), 1) FROM test_table);
CREATE TABLE another_table (ref_id INT, val INT);
INSERT INTO another_table (ref_id, val) VALUES (1, 10), (2, 20), (3, 30);
SELECT a.ref_id, left_shift(a.val, 1) AS shifted_val FROM another_table a JOIN test_table t ON a.ref_id = t.id WHERE t.value IS NOT NULL AND left_shift(t.value, 2) >= 1;