CREATE TABLE test_table (id INT PRIMARY KEY, value INT, description VARCHAR(50));
INSERT INTO test_table (id, value, description) VALUES (1, rand() % 10, 'first row');
INSERT INTO test_table (id, value, description) VALUES (2, rand() % 20, 'second row');
INSERT INTO test_table (id, value, description) VALUES (3, rand() % 30, NULL);
SELECT id, value, description FROM test_table WHERE value IS NOT NULL AND description IS NOT NULL;
SELECT id, rand() % value AS modulo_value FROM test_table WHERE value > 5;
SELECT id, (rand() % (SELECT COUNT(*) FROM test_table)) AS subquery_modulo FROM test_table;
SELECT id, value, description FROM test_table WHERE (value % rand() = 0) OR (value IS NULL);
SELECT id, value, description FROM test_table ORDER BY (value + (rand() % 5)) DESC;
CREATE TABLE another_table (ref_id INT, random_value INT);
INSERT INTO another_table (ref_id, random_value) SELECT id, rand() FROM test_table WHERE description IS NOT NULL;
SELECT t1.id, t2.random_value FROM test_table t1 JOIN another_table t2 ON t1.id = t2.ref_id WHERE (rand() % t1.value) < 3;
SELECT t1.id, (t1.value + rand()) % 10 AS computed_value FROM test_table t1 WHERE (NULLIF(t1.value, 0) IS NOT NULL);
WITH rand_table AS (SELECT id, rand() AS random_val FROM test_table) SELECT id, random_val FROM rand_table WHERE random_val % 2 = 0;
CREATE TABLE complex_table (n1 INT, n2 INT, n3 INT);
INSERT INTO complex_table (n1, n2, n3) VALUES (10, 20, rand() % 3), (4, 5, 6);
SELECT n1, n2, n3 FROM complex_table WHERE n1 > (SELECT rand() % 10);
SELECT n1, SUM(n2) FROM complex_table GROUP BY n1 HAVING SUM(n2) % rand() = 0;
SELECT n1, n2, (rand() % n3) AS mod_example FROM complex_table WHERE n2 IS NOT NULL OR n3 IS NULL;