CREATE TABLE test_table_1 (id SERIAL PRIMARY KEY, ip_address INET, value VARCHAR(255) NOT NULL);
INSERT INTO test_table_1 (ip_address, value) VALUES (inet '192.168.1.5', 'start'), (inet '192.168.1.6', 'end'), (inet '192.168.1.7', NULL), (inet NULL, 'nullip');
CREATE TABLE test_table_2 (id SERIAL PRIMARY KEY, parent_id INT REFERENCES test_table_1(id), comparison_value VARCHAR(50) NOT NULL);
INSERT INTO test_table_2 (parent_id, comparison_value) VALUES (1, 'aa'), (2, 'ab'), (3, 'a'), (NULL, 'b');
SELECT * FROM test_table_2 WHERE comparison_value > (SELECT MAX(value) FROM test_table_1 WHERE ip_address < inet '192.168.1.6');
SELECT t1.ip_address, t2.comparison_value FROM test_table_1 t1 JOIN test_table_2 t2 ON t1.id = t2.parent_id WHERE t2.comparison_value > 'a' AND t2.comparison_value < (SELECT MIN(comparison_value) FROM test_table_2 WHERE parent_id IS NOT NULL);
SELECT COUNT(*) FROM (SELECT t1.value, t2.comparison_value FROM test_table_1 t1 JOIN test_table_2 t2 ON t1.id = t2.parent_id WHERE t1.value IS NOT NULL) as subquery HAVING MAX(t2.comparison_value) > 'aa';
SELECT t1.ip_address, COUNT(*) OVER (PARTITION BY t2.comparison_value) FROM test_table_1 t1 JOIN test_table_2 t2 ON t1.id = t2.parent_id WHERE (SELECT COUNT(*) FROM test_table_2 WHERE comparison_value < 'ab') > 1;
UPDATE test_table_1 SET value = 'updated' WHERE ip_address > (SELECT ip_address FROM test_table_1 WHERE id = 1);
SELECT id, value FROM test_table_1 WHERE value IS NOT NULL AND EXISTS (SELECT 1 FROM test_table_2 WHERE comparison_value < 'b' AND parent_id = id);
DROP TABLE IF EXISTS test_table_2;