CREATE TABLE test_table (id INT, str_col VARCHAR(255), num_col INT, date_col DATE);
INSERT INTO test_table (id, str_col, num_col, date_col) VALUES (1, 'First', 10, '2023-01-01');
INSERT INTO test_table (id, str_col, num_col, date_col) VALUES (2, NULL, 15, '2023-02-01');
INSERT INTO test_table (id, str_col, num_col, date_col) VALUES (3, 'Third', NULL, NULL);
INSERT INTO test_table (id, str_col, num_col, date_col) VALUES (4, '', 25, '2023-04-01');
INSERT INTO test_table (id, str_col, num_col, date_col) VALUES (5, 'Fifth', 0, '2023-05-01');
SELECT concat(str_col, ' entry') AS combined_str FROM test_table WHERE num_col IS NOT NULL AND num_col > 0;
SELECT id, concat('ID: ', concat(str_col, CAST(num_col AS VARCHAR))) AS combined_info FROM test_table WHERE date_col IS NOT NULL;
SELECT id, num_col + (SELECT COUNT(*) FROM test_table WHERE num_col IS NULL) AS adjusted_value FROM test_table;
SELECT id, concat(str_col, interval '1-5' year to month) AS result FROM test_table WHERE date_col IS NOT NULL;
SELECT id, (SELECT count(*) FROM test_table WHERE num_col > 0) AS positive_counts, concat(str_col, ' has ', num_col) AS description FROM test_table GROUP BY str_col, num_col HAVING positive_counts > 1;
SELECT t1.id, t1.str_col, concat(str_col, ' + ', t2.str_col) AS combined_names FROM test_table t1 JOIN test_table t2 ON t1.num_col = t2.num_col AND t1.id <> t2.id;
WITH temp AS (SELECT id, concat('ID: ', str_col) AS display FROM test_table) SELECT display FROM temp WHERE id = (SELECT MAX(id) FROM test_table);
ALTER TABLE test_table ADD COLUMN new_col VARCHAR(255);
UPDATE test_table SET new_col = concat('Updated: ', str_col) WHERE id = 1;
DELETE FROM test_table WHERE num_col IS NULL;
SELECT id, CAST(concat('', num_col) AS VARCHAR) AS string_value FROM test_table;
SELECT id, (CAST(num_col AS VARCHAR) || ' entries') AS entry_info FROM test_table;
DROP TABLE IF EXISTS test_table;