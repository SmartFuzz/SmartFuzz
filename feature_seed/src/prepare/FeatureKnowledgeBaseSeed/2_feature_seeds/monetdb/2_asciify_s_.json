CREATE TABLE test_data (id INT, ip_address INET, name VARCHAR(255));
INSERT INTO test_data VALUES (1, inet '192.168.1.5', 'John Doe'), (2, inet '192.168.1.4', '€liza');
SELECT * FROM test_data WHERE asciify(name) > asciify('Eliza');
SELECT id, ip_address FROM test_data WHERE asciify(name) > 'John';
SELECT id, asciify(name) AS clean_name FROM test_data WHERE ip_address > inet '192.168.1.3' AND asciify(name) IS NOT NULL;
SELECT a.id, a.ip_address FROM test_data a JOIN test_data b ON a.ip_address > b.ip_address WHERE asciify(b.name) = 'John';
SELECT COUNT(*) FROM (SELECT id, asciify(name) AS clean_name FROM test_data WHERE ip_address > inet '192.168.1.2') AS subquery;
CREATE TEMP TABLE temp_data AS SELECT id, asciify(name) AS clean_name FROM test_data WHERE ip_address IS NOT NULL;
SELECT ip_address, COUNT(*) FROM test_data GROUP BY ip_address HAVING COUNT(*) > 1 AND MIN(asciify(name)) > 'A';
CREATE TABLE edge_cases (test_id INT, num_value DECIMAL(10, 2), str_value VARCHAR(255));
INSERT INTO edge_cases VALUES (1, 123.456, 'Test € String'), (2, NULL, 'Another Test');
SELECT test_id, asciify(str_value) FROM edge_cases WHERE num_value > 100.00 OR asciify(str_value) IS NULL;
SELECT t1.test_id FROM edge_cases t1 WHERE t1.num_value IS NOT NULL AND EXISTS (SELECT 1 FROM edge_cases t2 WHERE t1.num_value > t2.num_value);
SELECT unique_ip, COUNT(*) FROM (SELECT DISTINCT ip_address AS unique_ip FROM test_data WHERE asciify(name) IS NOT NULL) AS subquery GROUP BY unique_ip HAVING COUNT(*) > 0;
SELECT asciify(str_value) FROM edge_cases ORDER BY num_value, asciify(str_value) DESC;