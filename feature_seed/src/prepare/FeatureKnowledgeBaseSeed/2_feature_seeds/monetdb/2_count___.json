CREATE TABLE test_ips (id SERIAL PRIMARY KEY, ip INET, data TEXT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_ips (ip, data) VALUES (inet '192.168.1.5', 'Sample data');
INSERT INTO test_ips (ip, data) VALUES (inet '192.168.1.6', NULL);
INSERT INTO test_ips (ip, data) VALUES (inet '192.168.1.7', 'More data');
INSERT INTO test_ips (ip, data) VALUES (inet '192.168.1.8', 'Another entry');
SELECT COUNT(*) FROM test_ips WHERE ip = inet '192.168.1.5' OR ip = inet '192.168.1.6';
SELECT COUNT(*) FROM (SELECT ip, data FROM test_ips WHERE data IS NOT NULL) AS subquery;
SELECT COUNT(*) FROM test_ips WHERE ip = inet '192.168.1.5' AND (SELECT COUNT(*) FROM test_ips WHERE data IS NULL) > 0;
SELECT COUNT(*) FROM test_ips GROUP BY ip HAVING COUNT(*) > 1;
SELECT ip, COUNT(*) FROM test_ips GROUP BY ip ORDER BY COUNT(*) DESC;
SELECT COUNT(*) FROM (SELECT DISTINCT ip FROM test_ips WHERE ip IS NOT NULL) AS subquery;
SELECT COUNT(*) FROM test_ips WHERE ip = inet '192.168.1.5' AND data IS NOT NULL;
SELECT COUNT(*) FROM test_ips WHERE ip IS NOT NULL OR data IS NULL;
SELECT ip, COUNT(*) FROM test_ips WHERE data IS NOT NULL GROUP BY ip HAVING COUNT(*) > 0;
SELECT COUNT(*) FROM test_ips WHERE created_at >= '2023-01-01' AND created_at < '2024-01-01';
SELECT COUNT(*) FROM test_ips WHERE ip = inet '192.168.1.5' OR ip = inet '192.168.1.9';
SELECT COUNT(*) FROM test_ips WHERE (ip = inet '192.168.1.5' AND data IS NULL) OR data IS NOT NULL;