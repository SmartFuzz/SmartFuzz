CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(50), created_at TIMESTAMP, value DECIMAL(10,5));
INSERT INTO test_table (id, name, created_at, value) VALUES (1, 'MonetDB', NOW(), 12345.67890);
INSERT INTO test_table (id, name, created_at, value) VALUES (2, 'TestString', NOW(), NULL);
SELECT id, right(name, 5) AS last_chars FROM test_table WHERE value IS NOT NULL;
SELECT id, time(6) '18:40:05.123456' AS converted_time, right(name, 3) FROM test_table WHERE created_at > CURRENT_TIMESTAMP - INTERVAL '1 DAY';
SELECT COUNT(*), AVG(value) FROM test_table GROUP BY right(name, 1) HAVING AVG(value) > 10000;
SELECT id, right(name, 2) || '!' AS modified_name FROM test_table WHERE value > (SELECT AVG(value) FROM test_table WHERE created_at < NOW());
SELECT id, right(name, LENGTH(name)) AS full_name FROM test_table WHERE NULLIF(value, 0) IS NOT NULL;
SELECT id, LAG(right(name, 4)) OVER (ORDER BY created_at) AS prev_last_chars FROM test_table;
SELECT DISTINCT right(name, 4) AS suffix, time(6) '12:30:00.000000' FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value < 20000);