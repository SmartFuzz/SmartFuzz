CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255), creation_time TIME(6));
INSERT INTO test_strings (id, str1, str2, creation_time) VALUES (1, 'abcdef', 'def', time(6) '12:30:45.123456');
INSERT INTO test_strings (id, str1, str2, creation_time) VALUES (2, 'ghijk', NULL, time(6) '10:15:00.000000');
INSERT INTO test_strings (id, str1, str2, creation_time) VALUES (3, '', 'xyz', time(6) '08:00:00.654321');
INSERT INTO test_strings (id, str1, str2, creation_time) VALUES (4, 'lmn', 'mnop', time(6) '23:59:59.999999');
SELECT id, endswith(str1, str2) AS ends FROM test_strings WHERE str1 IS NOT NULL AND str2 IS NOT NULL;
SELECT id, endswith(str1, time(6) '12:30:45.123456') AS ends FROM test_strings WHERE creation_time = time(6) '12:30:45.123456';
SELECT id, endswith(str1, (SELECT str2 FROM test_strings WHERE id = 1)) AS ends FROM test_strings WHERE str1 IS NOT NULL;
SELECT creation_time, COUNT(*) FROM test_strings GROUP BY creation_time HAVING endswith(str1, str2) IS NOT NULL;
SELECT str1, str2 FROM test_strings WHERE endswith(CAST(creation_time AS VARCHAR), str2) OR str2 IS NULL;
SELECT id, endswith(UPPER(str1), LOWER(str2)) AS ends FROM test_strings WHERE ends IS NOT NULL ORDER BY creation_time DESC;