CREATE TABLE test_table (id INT PRIMARY KEY, val1 INT, val2 INT, str_val VARCHAR(50));
INSERT INTO test_table (id, val1, val2, str_val) VALUES (1, 2, 3, 'test1'), (2, NULL, 5, 'test2'), (3, 0, 0, 'test3');
SELECT id, ifthenelse(val1 > val2, val1 ^ val2, val1 + val2) AS result FROM test_table WHERE str_val LIKE 'test%';
SELECT t1.id, ifthenelse((t1.val1 IS NULL), 0, (t1.val1 ^ (SELECT COUNT(*) FROM test_table t2 WHERE t2.val2 > t1.val2))) AS conditional_xor FROM test_table t1;
CREATE TABLE another_table (id INT, num_col INT, str_col TEXT);
INSERT INTO another_table (id, num_col, str_col) VALUES (1, 10, 'hello'), (2, 20, 'world'), (3, NULL, 'fuzz');
SELECT at.id, ifthenelse(at.str_col = 'hello', 1, 0) + (at.num_col ^ (SELECT COUNT(*) FROM test_table WHERE val1 IS NOT NULL)) AS complex_result FROM another_table at;
SELECT at.id, ifthenelse(at.num_col < 15, (at.num_col ^ 5), (SELECT MAX(val1) FROM test_table)) AS edge_case FROM another_table at GROUP BY at.id HAVING complex_result IS NOT NULL;
SELECT t.id, ifthenelse(t.val1 = t.val2, 0, 1) AS comparison, (t.val1 ^ COALESCE((SELECT MAX(val2) FROM test_table), 0)) AS xor_val FROM test_table t WHERE val1 IS NOT NULL;
ALTER TABLE test_table ADD COLUMN new_val VARCHAR(50);
UPDATE test_table SET new_val = ifthenelse(str_val IS NULL, 'NULL', str_val) WHERE id = 2;
SELECT COUNT(*) FROM test_table WHERE ifthenelse(str_val IS NOT NULL, new_val ^ 'test', 1) = 1;
DROP TABLE another_table;