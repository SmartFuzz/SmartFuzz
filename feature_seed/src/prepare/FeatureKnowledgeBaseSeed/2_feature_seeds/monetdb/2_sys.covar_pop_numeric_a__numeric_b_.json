CREATE TABLE demo_table (id SERIAL PRIMARY KEY, value_a DECIMAL(10,2), value_b DECIMAL(10,2), created_at TIMESTAMP);
INSERT INTO demo_table (value_a, value_b, created_at) VALUES (1.23, 2.34, timestamp '2020-09-28 10:10:10'), (NULL, 5.67, timestamp '2020-09-29 12:12:12'), (3.45, NULL, timestamp '2020-10-01 15:00:00'), (4.56, 7.89, NULL);
SELECT sys.covar_pop(value_a, value_b) AS covariance FROM demo_table WHERE created_at IS NOT NULL;
SELECT value_a, sys.covar_pop(value_a, value_b) OVER (PARTITION BY created_at) AS covariance_partition FROM demo_table;
SELECT t1.id, sys.covar_pop(t1.value_a, t2.value_b) FROM demo_table t1 JOIN demo_table t2 ON t1.created_at = t2.created_at WHERE t1.value_b IS NOT NULL GROUP BY t1.id;
SELECT sys.covar_pop(value_a, value_b) FROM (SELECT value_a, value_b FROM demo_table WHERE created_at > timestamp '2020-09-29 00:00:00') AS subquery WHERE value_a IS NOT NULL;
SELECT MIN(sys.covar_pop(value_a, value_b)) AS min_covariance FROM demo_table GROUP BY created_at HAVING MIN(value_a) > 0;
SELECT COUNT(*) FROM demo_table WHERE created_at < (SELECT MAX(created_at) FROM demo_table) AND sys.covar_pop(value_a, value_b) IS NOT NULL;
CREATE TABLE test_table (test_id SERIAL PRIMARY KEY, test_value STRING, test_time TIMESTAMP);
INSERT INTO test_table (test_value, test_time) VALUES ('100', timestamp '2020-09-28 20:20:20'), ('200.55', timestamp '2020-09-29 18:18:18'), (NULL, NULL);
SELECT test_id, sys.covar_pop(CAST(test_value AS DECIMAL), NULL) AS covariance_test FROM test_table WHERE test_time IS NOT NULL;