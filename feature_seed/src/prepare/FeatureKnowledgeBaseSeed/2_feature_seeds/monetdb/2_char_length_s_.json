CREATE TABLE test_data (id INT PRIMARY KEY, time_value TIME, char_value VARCHAR(20));
INSERT INTO test_data (id, time_value, char_value) VALUES (1, TIME '12:30:00', 'hello'), (2, TIME '14:45:00', 'world'), (3, TIME '00:00:00', '€'), (4, TIME '23:59:59', '');
SELECT char_length(time_value::VARCHAR) AS length, char_length(char_value) AS char_len FROM test_data WHERE char_value IS NOT NULL;
SELECT id, char_value, char_length(char_value) AS str_length, time_value FROM test_data WHERE char_length(char_value) > 0;
SELECT id, char_value, char_length(time_value::VARCHAR) + char_length(char_value) AS total_length FROM test_data ORDER BY total_length DESC;
SELECT id, char_value FROM test_data WHERE id IN (SELECT id FROM test_data WHERE time_value = TIME '12:30:00');
SELECT id, time_value, (SELECT char_length(char_value) FROM test_data WHERE id = test_data.id) AS char_len FROM test_data;
SELECT COUNT(*) FROM (SELECT id, char_length(char_value) AS len FROM test_data WHERE char_length(char_value) < 5 GROUP BY id HAVING len IS NOT NULL) AS subquery;
SELECT time_value, char_length(char_value) AS char_len FROM test_data WHERE (char_value IS NOT NULL AND char_length(char_value) > 1) OR (time_value IS NULL);
SELECT id, time_value, char_length(char_value)::VARCHAR || ' has ' || char_length(char_value) || ' characters' AS description FROM test_data WHERE char_value <> '';