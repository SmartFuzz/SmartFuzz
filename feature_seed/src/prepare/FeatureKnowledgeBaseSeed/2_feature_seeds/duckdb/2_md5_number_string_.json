CREATE TABLE test_table (id HUGEINT, data VARCHAR, status BOOLEAN);
INSERT INTO test_table VALUES (1, 'apple', TRUE), (2, '', FALSE), (3, NULL, TRUE), (4, 'banana', NULL);
SELECT id, md5_number(COALESCE(data, 'default')) AS data_hash, (md5_number(data) << 2) AS shifted_hash FROM test_table WHERE status IS NOT NULL;
SELECT id FROM test_table WHERE (md5_number(data) << 3) BETWEEN 0 AND 10000000000000;
SELECT id, COUNT(*) AS count FROM (SELECT id, md5_number(data) AS data_hash FROM test_table WHERE data IS NOT NULL) sub GROUP BY id HAVING count > 1;
SELECT id, data, (md5_number('x' || data) << 1) AS transformed_hash FROM test_table JOIN test_table t2 ON (md5_number(data) = md5_number(t2.data) AND t2.id < test_table.id) ORDER BY transformed_hash;
CREATE TABLE temp_results AS SELECT id, (md5_number(data) << 5) AS big_hash FROM test_table WHERE data IS NOT NULL;
SELECT MAX(big_hash) FROM temp_results WHERE big_hash IS NOT NULL;
SELECT data FROM test_table WHERE md5_number(COALESCE(data, 'empty'))::BIGINT = 0;
SELECT AVG(md5_number(data)::DOUBLE) AS avg_hash FROM test_table WHERE data IS NOT NULL HAVING avg_hash > 0;