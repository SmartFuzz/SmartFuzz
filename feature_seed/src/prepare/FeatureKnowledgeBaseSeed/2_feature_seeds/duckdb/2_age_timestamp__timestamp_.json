CREATE TABLE timestamps_data (id SERIAL, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO timestamps_data (start_time, end_time) VALUES (TIMESTAMP '2001-04-10', TIMESTAMP '1992-09-20'), (TIMESTAMP '2020-01-01', TIMESTAMP '2019-12-31'), (TIMESTAMP '2005-03-15', NULL);
SELECT id, age(start_time, end_time) AS age_diff, (EXTRACT(EPOCH FROM age(start_time, end_time)) % 60) AS age_modulo FROM timestamps_data WHERE end_time IS NOT NULL;
SELECT id, (SELECT COUNT(*) FROM timestamps_data AS inner_table WHERE age(start_time, end_time) IS NOT NULL) AS count_age_valid FROM timestamps_data GROUP BY id HAVING (age(start_time, end_time) % 7) = 0;
SELECT id, age(start_time, TIMESTAMP '2023-10-01') AS age_to_now, (age(start_time, end_time) % 10) AS age_remainder FROM timestamps_data ORDER BY age_to_now DESC;
CREATE TABLE edge_cases (val1 INT, val2 TIMESTAMP);
INSERT INTO edge_cases (val1, val2) VALUES (1, TIMESTAMP '2023-03-01'), (NULL, TIMESTAMP '2023-03-02'), (10, NULL);
SELECT val1, (age(val2, TIMESTAMP '1970-01-01 00:00:00') % 30) AS mod_age FROM edge_cases WHERE val1 IS NOT NULL;
WITH age_calculations AS (SELECT id, age(start_time, end_time) AS age_difference FROM timestamps_data) SELECT id, age_difference, (age_difference % 3) AS modulo_age FROM age_calculations WHERE age_difference IS NOT NULL;