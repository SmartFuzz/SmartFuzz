CREATE TABLE test_data (id INTEGER, value TEXT, other_value INTEGER);
INSERT INTO test_data VALUES (1, 'a;
b;
c', 10), (2, 'd;
e;
f', 20), (3, NULL, 30);
SELECT id, split_part(value, ';
', 2) AS split_value FROM test_data WHERE other_value | 5 > 10;
SELECT id, COUNT(*) FROM (SELECT split_part(value, ';
', 2) AS split_value, other_value FROM test_data) sub GROUP BY split_value HAVING (other_value | 3) IS NOT NULL;
SELECT id, CASE WHEN split_part(value, ';
', 3) = '' THEN NULL ELSE other_value END AS conditional_value FROM test_data;
SELECT id, (other_value | (CASE WHEN split_part(value, ';
', 1) = 'd' THEN 1 ELSE 0 END)) AS or_result FROM test_data;
SELECT id, split_part(value, ';
', (other_value | 1)) AS dynamic_split FROM test_data WHERE other_value IS NOT NULL;
SELECT id, split_part(value, ';
', 1) AS first_part, split_part(value, ';
', 2) AS second_part FROM test_data WHERE (other_value | 4) < (SELECT COUNT(*) FROM test_data) ORDER BY first_part;
WITH base_data AS (SELECT id, other_value | 2 AS modified_value FROM test_data) SELECT id, split_part((SELECT value FROM test_data WHERE id = base_data.id), ';
', 1) AS first_part FROM base_data;
CREATE TABLE temp_data AS SELECT id, split_part(value, ';
', 2) AS temp_split, other_value FROM test_data WHERE other_value IS NOT NULL;