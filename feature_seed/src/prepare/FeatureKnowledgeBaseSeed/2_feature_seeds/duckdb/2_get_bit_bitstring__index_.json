CREATE TABLE test_table (id INTEGER, bit_col BITSTRING, val DECIMAL(10,5));
INSERT INTO test_table (id, bit_col, val) VALUES (1, '0110010'::BITSTRING, NULL), (2, '1111111'::BITSTRING, 123.45678), (3, '0000000'::BITSTRING, 0);
SELECT id, get_bit(bit_col, 2) ** val AS computed_value FROM test_table WHERE val IS NOT NULL;
SELECT id, COUNT(*) FILTER (WHERE get_bit(bit_col, 1) = 1) OVER (PARTITION BY id) AS bit_count FROM test_table;
SELECT id, val, (get_bit(bit_col, 2) ** (val + 1)) AS complex_expression FROM test_table WHERE val >= 1.0 ORDER BY complex_expression;
SELECT id, SUM(get_bit(bit_col, 3) ** val) FROM test_table GROUP BY id HAVING SUM(get_bit(bit_col, 3) ** val) > 0;
SELECT id, (SELECT COUNT(*) FROM test_table t2 WHERE t2.val > test_table.val) AS higher_count FROM test_table;
SELECT t1.id, get_bit(t1.bit_col, 0) ** COALESCE(t2.val, 1) AS adjusted_value FROM test_table t1 LEFT JOIN (SELECT id, NULL AS val FROM test_table) t2 ON t1.id = t2.id;
CREATE TABLE another_table (field1 INTEGER, field2 FLOAT, field3 BITSTRING);
INSERT INTO another_table (field1, field2, field3) VALUES (5, 3.14, '1010101'::BITSTRING), (10, NULL, '1110000'::BITSTRING);
SELECT a.field1, get_bit(a.field3, 2) ** (COALESCE(a.field2, 1) + 1) AS calculated_value FROM another_table a WHERE a.field2 IS NULL;
SELECT a.field1, AVG(get_bit(a.field3, 2) ** (COALESCE(a.field2, 1))) OVER (ORDER BY a.field1) AS running_avg FROM another_table a;
SELECT field1, COUNT(*) FILTER (WHERE get_bit(field3, 0) = 1) AS bit_check FROM another_table GROUP BY field1 HAVING bit_check > 0;
ALTER TABLE test_table ADD COLUMN extra_val INTEGER DEFAULT 0;
UPDATE test_table SET extra_val = get_bit(bit_col, 0) ** (val + 10) WHERE val IS NOT NULL;
SELECT id, (SELECT SUM(extra_val) FROM test_table t3 WHERE t3.id = test_table.id) FROM test_table;