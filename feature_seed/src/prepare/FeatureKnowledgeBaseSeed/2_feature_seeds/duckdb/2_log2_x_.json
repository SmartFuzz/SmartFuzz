CREATE TABLE test_table (id INTEGER PRIMARY KEY, val DOUBLE, num_val INTEGER);
INSERT INTO test_table VALUES (1, 8, 32), (2, NULL, 3), (3, 16, NULL);
SELECT id, log2(val) | num_val AS result FROM test_table WHERE val IS NOT NULL;
SELECT id, log2(val) AS log_value, (log2(val) | 64) AS bitwise_value FROM test_table WHERE num_val IS NOT NULL ORDER BY log_value;
SELECT id, SUM(log2(val) | num_val) AS total FROM test_table GROUP BY id HAVING total > 5;
SELECT id, log2(NULLIF(num_val, 0)) | num_val AS computed_value FROM test_table WHERE num_val IS NOT NULL OR id < 0;
CREATE TABLE second_table (ref_id INTEGER, description VARCHAR);
INSERT INTO second_table VALUES (1, 'Test A'), (2, 'Test B'), (3, 'Test C');
SELECT t1.id, log2(t1.val) | COALESCE(t2.ref_id, 0) AS combined_value FROM test_table t1 LEFT JOIN second_table t2 ON t1.id = t2.ref_id;
SELECT t1.id, (log2(t1.val) | t1.num_val) AS complex_result FROM test_table t1 WHERE t1.val BETWEEN 1 AND 20 ORDER BY complex_result;
SELECT (log2(val) | (SELECT COUNT(*) FROM second_table)) AS aggregated_value FROM test_table WHERE id IN (SELECT ref_id FROM second_table) AND val IS NOT NULL;