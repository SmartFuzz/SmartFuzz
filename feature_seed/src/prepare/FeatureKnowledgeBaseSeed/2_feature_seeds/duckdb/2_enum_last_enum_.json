CREATE TABLE moods (id INTEGER, mood ENUM('happy', 'sad', 'angry', 'neutral'));
INSERT INTO moods VALUES (1, 'happy'), (2, 'sad'), (3, NULL), (4, 'angry');
SELECT enum_last(COALESCE(mood, 'neutral')) AS last_mood FROM moods GROUP BY id HAVING last_mood <= 'sad';
SELECT id, (SELECT enum_last(mood) FROM moods WHERE id <= m.id) <=> mood AS distance FROM moods m ORDER BY distance;
SELECT id, mood, (enum_last(mood) <= 'angry') AS is_angry FROM moods WHERE mood IS NOT NULL;
CREATE TABLE scores (user_id INTEGER, scores ARRAY[DOUBLE]);
INSERT INTO scores VALUES (1, [1.0, 2.0, 3.0]), (2, [4.0, 5.0, NULL]), (3, []);
SELECT s.user_id, s.scores <=> (SELECT ARRAY[4.0, 4.0, 3.0]) AS distance FROM scores s WHERE s.scores IS NOT NULL;
CREATE TABLE test_values (value DOUBLE);
INSERT INTO test_values VALUES (NULL), (1.5), (2.5), (3.5);
SELECT value, enum_last(NULL::mood) AS mood_default, value <=> (SELECT AVG(value) FROM test_values) AS distance FROM test_values WHERE value > ALL (SELECT value FROM test_values) OR value IS NULL;
SELECT COUNT(*) FROM moods WHERE mood IS NULL HAVING COUNT(mood) <=> (SELECT COUNT(*) FROM moods WHERE mood IS NOT NULL);