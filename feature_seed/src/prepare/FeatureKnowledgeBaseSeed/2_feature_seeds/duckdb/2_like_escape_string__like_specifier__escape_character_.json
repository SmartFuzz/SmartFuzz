CREATE TABLE test_table (id INTEGER, name VARCHAR, score FLOAT, created_at TIMESTAMP);
INSERT INTO test_table VALUES (1, 'example_1', 50.75, '2023-01-01 10:00:00'), (2, 'example_2', NULL, '2023-02-01 10:00:00'), (3, 'example_3%', 75.25, NULL);
SELECT id, name, score, like_escape(name, 'example_%', '_') AS like_match FROM test_table WHERE score IS NOT NULL AND score % 2 = 0;
SELECT id, name, score FROM test_table WHERE id IN (SELECT id FROM test_table WHERE like_escape(name, 'example_%', '_') AND score % 2 = 0);
SELECT COUNT(*) FROM (SELECT DISTINCT name, score % 10 AS mod_score FROM test_table GROUP BY name, mod_score HAVING mod_score < 5) AS subquery;
CREATE TABLE another_table (ref INTEGER, description VARCHAR, amount DECIMAL(10, 2));
INSERT INTO another_table VALUES (1, 'desc_1', 10.00), (2, 'desc_2%', 20.00), (3, 'desc_3', NULL);
SELECT tt.id, tt.name, at.description, at.amount / NULLIF(tt.score, 0) AS safe_division FROM test_table tt JOIN another_table at ON tt.id = at.ref WHERE at.amount IS NOT NULL;
SELECT name, COUNT(*) FROM test_table WHERE like_escape(name, 'example_%', '_') OR score % 2 = 0 GROUP BY name HAVING COUNT(*) > 1;
CREATE TABLE edge_cases (a INTEGER, b VARCHAR, c TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO edge_cases VALUES (NULL, '', NULL), (5, 'test%', '2023-03-01 10:00:00'), (2, 'test', '2023-02-01 10:00:00');
SELECT a, b, like_escape(b, 'test%', '_') AS test_pattern FROM edge_cases WHERE a % 3 = 0 OR b IS NULL;