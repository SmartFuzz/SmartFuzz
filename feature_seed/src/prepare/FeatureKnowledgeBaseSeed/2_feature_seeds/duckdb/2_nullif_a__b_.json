CREATE TABLE test_table (a INTEGER, b INTEGER, c VARCHAR, d FLOAT, e DATE, f BOOLEAN);
INSERT INTO test_table VALUES (1, 1, 'test', 1.1, '2023-01-01', TRUE), (2, 2, 'example', 2.3, '2023-01-02', FALSE), (NULL, 3, NULL, NULL, NULL, TRUE);
SELECT nullif((SELECT MAX(a) FROM test_table WHERE b IS NOT NULL) << 1, 2) AS result FROM test_table;
SELECT a, b, nullif(c, 'test') AS modified_c FROM test_table WHERE (a >> 2) > 0;
WITH temp AS (SELECT a, b, nullif(a, b) AS nullified FROM test_table) SELECT (SELECT COUNT(*) FROM temp WHERE nullified IS NULL) << 1 AS null_count;
SELECT e, nullif(a, (b >> 1)) AS adjusted_value FROM test_table GROUP BY e HAVING adjusted_value IS NOT NULL;
SELECT a, b FROM test_table t1 JOIN (SELECT c, nullif(1, 1) AS dummy FROM test_table WHERE d IS NOT NULL) t2 ON t1.c = t2.c WHERE t1.a >> t1.b > 0;
INSERT INTO test_table SELECT nullif(a, NULL) AS a, (b << 1) AS b, c, d + 1.0, e, f FROM test_table;
SELECT COUNT(*), MAX(nullif(b, 0) << 2) FROM test_table GROUP BY f HAVING MAX(b) IS NULL;
CREATE TEMP TABLE temp_agg AS SELECT nullif(a, b) AS combined_value, (c >> 3) AS shifted_value FROM test_table;