CREATE TABLE test_table (id INTEGER NOT NULL, name TEXT, tags TEXT[]);
INSERT INTO test_table (id, name, tags) VALUES (1, 'apple;
orange', regexp_split_to_array('fruit;
citrus;
berry', ';
'));
INSERT INTO test_table (id, name, tags) VALUES (2, 'banana;
grape', regexp_split_to_array('tropical;
sweet;
fast', ';
'));
SELECT id, name, regexp_split_to_array(name, ';
? ') || tags AS combined_tags FROM test_table WHERE id = 1;
SELECT id, name, (regexp_split_to_array(name, ';
? ') || (SELECT tags FROM test_table WHERE id = 2)) AS all_tags FROM test_table WHERE id = 1;
SELECT id, name, ARRAY_AGG(NULLIF(tag, '')) AS non_empty_tags FROM (SELECT id, UNNEST(regexp_split_to_array(name, ';
? ')) AS tag FROM test_table) AS split_tags GROUP BY id HAVING COUNT(tag) > 0;
SELECT id, name, (ARRAY_LENGTH(regexp_split_to_array(name, ';
? ')) || ARRAY_LENGTH(tags)) AS total_tags FROM test_table ORDER BY total_tags DESC;
SELECT t1.id, t1.name, t2.name AS joined_name FROM test_table t1 JOIN test_table t2 ON (t1.id = t2.id OR t1.name = 'apple;
orange');
SELECT id, name, ARRAY_LENGTH(regexp_split_to_array(name, ';
? ')) AS split_length FROM test_table WHERE split_length < 10 ORDER BY split_length;
SELECT id, COUNT(*) AS tag_count FROM (SELECT UNNEST(regexp_split_to_array(name, ';
? ')) AS tag FROM test_table) AS tags GROUP BY tag HAVING tag_count > 1;
DROP TABLE IF EXISTS test_table;