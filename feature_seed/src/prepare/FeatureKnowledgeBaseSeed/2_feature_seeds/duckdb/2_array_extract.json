CREATE TABLE test_lists (id INTEGER, values LIST<INTEGER>);
INSERT INTO test_lists VALUES (1, [4, 5, 6]), (2, [1, 2, NULL]), (3, [NULL, 10, 20]);
CREATE TABLE test_numbers (num INTEGER);
INSERT INTO test_numbers VALUES (15), (20), (NULL);
WITH extracted AS (SELECT id, array_extract(values, 2) AS extracted_value FROM test_lists WHERE array_extract(values, 1) IS NOT NULL) SELECT id, ~SUM(num) as negated_sum FROM extracted JOIN test_numbers ON extracted.extracted_value = ~test_numbers.num GROUP BY id HAVING COUNT(*) > 1;
SELECT id, array_extract(values, ~1) AS extracted_neg_value FROM test_lists WHERE values IS NOT NULL AND ~array_extract(values, 3) IS NOT NULL;
CREATE TABLE complex_test (data VARCHAR, num_col INTEGER, list_col LIST<BOOLEAN>);
INSERT INTO complex_test VALUES ('Row 1', 0, [TRUE, FALSE]), ('Row 2', 1, [NULL, TRUE]);
SELECT data, ~array_extract(list_col, 1) AS negated BOOLEAN_VALUE FROM complex_test WHERE num_col < 2;
CREATE TABLE edge_cases (num_value REAL);
INSERT INTO edge_cases VALUES (1.5), (NULL), (2.5), (0.0);
SELECT array_extract(ARRAY(SELECT num_value FROM edge_cases WHERE num_value IS NOT NULL), 2) AS value_2, ~COUNT(*) FROM edge_cases GROUP BY num_value HAVING value_2 IS NOT NULL;