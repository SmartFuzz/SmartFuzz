CREATE TABLE test_table (id INTEGER, values_list LIST<INTEGER>, value_sum INTEGER, NULL_column INTEGER);
INSERT INTO test_table VALUES (1, [1, 2, 3, NULL, 5], 6), (2, [NULL, 2, 3], 5), (3, [1, 2, 3, 4, 5], 15);
SELECT id, list_slice(values_list, value_sum - 2, value_sum) + 1 AS adjusted_slice FROM test_table WHERE NULL_column IS NOT NULL;
SELECT id, list_slice(values_list, 0, 3) + (SELECT COUNT(*) FROM test_table WHERE values_list[0] IS NOT NULL) FROM test_table ORDER BY value_sum;
SELECT id, list_slice(values_list, 1 + (SELECT COUNT(*) FROM test_table WHERE value_sum < 10), 4 + 2) FROM test_table WHERE values_list[0] IS NOT NULL AND value_sum IS NOT NULL;
SELECT id, list_slice(values_list, 1, 3) + (COALESCE(value_sum, 0)) AS adjusted_sum FROM test_table WHERE EXISTS (SELECT 1 FROM test_table AS t2 WHERE t2.id = test_table.id);
SELECT id, SUM(value_sum + (SELECT COUNT(*) FROM test_table WHERE values_list[2] IS NULL)) AS total_sum FROM test_table GROUP BY id HAVING total_sum > 10;
CREATE TABLE test_table2 (id INTEGER, ref_id INTEGER);
INSERT INTO test_table2 VALUES (1, 1), (2, 1), (3, 2);
SELECT t1.id, list_slice(t1.values_list, 0, 2) + (SELECT COUNT(*) FROM test_table2 t2 WHERE t2.ref_id = t1.id) AS total_list FROM test_table t1 JOIN test_table2 t2 ON t1.id = t2.ref_id WHERE t1.value_sum IS NOT NULL;
ALTER TABLE test_table RENAME COLUMN NULL_column TO old_column;
INSERT INTO test_table (id, values_list, value_sum) VALUES (4, [1, 1, NULL], 2);