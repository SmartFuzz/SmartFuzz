CREATE TABLE test_table (id INTEGER, value BITSTRING, timestamp TIMESTAMP, score FLOAT, nullable_col INTEGER);
INSERT INTO test_table (id, value, timestamp, score, nullable_col) VALUES (1, '101'::BITSTRING, '2023-01-01 00:00:00', 10.5, NULL), (2, '110'::BITSTRING, '2023-01-02 00:00:00', NULL, 5), (3, '111'::BITSTRING, '2023-01-03 00:00:00', 15.0, 10), (4, NULL, '2023-01-04 00:00:00', 20.0, NULL);
SELECT id, lead(score, 1, 0) ~ value AS transformed_score FROM test_table;
SELECT id, lead(score, 2, NULL) AS lead_score FROM test_table WHERE nullable_col IS NOT NULL GROUP BY id HAVING lead(score, 2, 0) IS NOT NULL;
SELECT id, value, ~lead(score, 3, 0) AS not_lead_score FROM (SELECT *, lead(score, 1, 0) AS lead_one FROM test_table) AS inner_table WHERE id > 1 ORDER BY token(id, 2);
SELECT id, CASE WHEN lead(nullable_col, 1, -1) IS NULL THEN ~value ELSE value END AS adjusted_value FROM test_table;
SELECT id, timestamp, lead(value, 1, 0) ~ '00'::BITSTRING AS combined_value FROM test_table WHERE score > 10.0 ORDER BY timestamp;
SELECT id, COUNT(*) FROM (SELECT id, lead(score, 1, 0) FROM test_table) AS foo GROUP BY id HAVING COUNT(*) > 1;
CREATE TEMPORARY TABLE temp_table AS SELECT id, value FROM test_table WHERE value IS NOT NULL;
SELECT lead(id, 1, 0) AS next_id, value FROM temp_table WHERE lead(value, 1, '0'::BITSTRING) ~ value::BITSTRING;