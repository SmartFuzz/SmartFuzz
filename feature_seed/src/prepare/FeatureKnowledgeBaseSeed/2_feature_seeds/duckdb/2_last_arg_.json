CREATE TABLE test_table (id INTEGER, timestamp_col TIMESTAMP, interval_col INTERVAL);
INSERT INTO test_table VALUES (1, TIMESTAMP '2023-01-01 10:00:00', INTERVAL '5 HOUR'), (2, TIMESTAMP '2023-01-02 11:00:00', INTERVAL '3 HOUR'), (3, TIMESTAMP '2023-01-03 12:00:00', INTERVAL '7 HOURS');
SELECT last(timestamp_col + interval_col) AS last_timestamp FROM test_table;
SELECT id, last(timestamp_col + INTERVAL '1 HOUR') AS adjusted_timestamp FROM test_table GROUP BY id;
SELECT last(t1.timestamp_col) FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id AND t1.timestamp_col > (SELECT MAX(timestamp_col) + INTERVAL '3 HOUR' FROM test_table);
SELECT last(CASE WHEN id IS NULL THEN NULL ELSE timestamp_col + INTERVAL '2 HOUR' END) OVER (PARTITION BY id) AS last_adjusted_timestamp FROM test_table;
SELECT last(timestamp_col + INTERVAL (SELECT MAX(id) FROM test_table) HOUR) AS last_with_dynamic_interval FROM test_table;