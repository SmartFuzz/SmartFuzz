CREATE TABLE test_table (id INTEGER, value FLOAT, interval_value INTERVAL);
INSERT INTO test_table VALUES (1, 17.4, INTERVAL '5 HOUR'), (2, NULL, INTERVAL '3 HOUR'), (3, 22.9, INTERVAL '1 DAY');
SELECT id, ceil(value) AS rounded_value, (INTERVAL '1 HOUR' - INTERVAL '30 MINUTE') AS interval_diff FROM test_table WHERE value IS NOT NULL;
SELECT id, ceil(sum(value)) OVER (PARTITION BY id) AS partition_ceiling FROM test_table GROUP BY id HAVING partition_ceiling > 20;
SELECT id, ceil(NVL(value, 0)) + (INTERVAL '1 DAY' - INTERVAL '10 MINUTE') AS complex_expression FROM test_table WHERE id IN (SELECT id FROM test_table WHERE interval_value IS NOT NULL);
CREATE TABLE second_table (date_column DATE, value INTEGER);
INSERT INTO second_table VALUES ('2023-01-01', 5), (NULL, 3), ('2023-02-01', 10);
SELECT a.id, ceil(a.value) - (SELECT MIN(b.value) FROM second_table b WHERE b.date_column IS NOT NULL) AS result FROM test_table a WHERE a.value IS NOT NULL ORDER BY result;
SELECT DISTINCT id, ceil(CASE WHEN value IS NULL THEN 0 ELSE value END) AS adjusted_value FROM test_table WHERE interval_value - INTERVAL '1 HOUR' > INTERVAL '0';
SELECT id, ceil(value - (SELECT MAX(value) FROM test_table WHERE value IS NOT NULL ORDER BY value DESC LIMIT 1)) AS adjustment FROM test_table;
SELECT id, ceil(COALESCE(value, 0)) + INTERVAL '1 HOUR' - INTERVAL (SELECT EXTRACT(HOUR FROM interval_value) FROM test_table WHERE id = 1) HOUR AS final_value FROM test_table;