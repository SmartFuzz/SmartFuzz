CREATE TABLE test_table (id INTEGER, timestamp_col TIMESTAMP, value_col DOUBLE);
INSERT INTO test_table VALUES (1, '2022-11-07 08:43:04.123456', 10.0), (2, NULL, 20.5), (3, '2021-08-03 11:59:44.123456', NULL);
SELECT id, epoch_ms(timestamp_col) // 1000 AS seconds_since_epoch FROM test_table;
SELECT id, value_col, epoch_ms(timestamp_col) // (SELECT COUNT(*) FROM test_table) AS divisive_value FROM test_table WHERE value_col IS NOT NULL;
SELECT id, epoch_ms(timestamp_col) // 2 AS half_epoch FROM test_table WHERE (epoch_ms(timestamp_col) IS NOT NULL) OR (value_col IS NULL);
CREATE TABLE another_table (id INTEGER, amount DOUBLE);
INSERT INTO another_table VALUES (1, 500.0), (2, NULL), (3, -300.5);
SELECT a.id, (epoch_ms(t.timestamp_col) // (SELECT COUNT(*) FROM another_table WHERE amount IS NOT NULL)) AS reduced_epoch FROM test_table t JOIN another_table a ON t.value_col = a.amount;
SELECT COUNT(*) FROM test_table WHERE epoch_ms(timestamp_col) IS NULL HAVING COUNT(*) // 2 > 0;
SELECT a.id, epoch_ms(t.timestamp_col) AS epoch_time, amount FROM test_table t FULL JOIN another_table a ON epoch_ms(t.timestamp_col) // 1000 = a.amount;
SELECT id, epoch_ms(timestamp_col) // (SELECT MAX(amount) FROM another_table WHERE amount IS NOT NULL) AS edge_case_value FROM test_table WHERE timestamp_col IS NOT NULL;