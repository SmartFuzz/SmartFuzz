CREATE TABLE test_dates (id INTEGER PRIMARY KEY, event_date DATE, days_to_subtract INTEGER, precision_number DOUBLE);
INSERT INTO test_dates VALUES (1, DATE '2023-01-01', 10, 2.5), (2, DATE '2023-05-05', 15, NULL), (3, DATE '2023-09-09', -5, 3.3), (4, DATE '2023-12-12', 0, 4.7);
SELECT id, even(AVG(precision_number)) AS next_even_precision, event_date - INTERVAL (days_to_subtract) DAY AS new_date FROM test_dates GROUP BY id, event_date HAVING even(AVG(precision_number)) IS NOT NULL;
WITH date_adjustment AS (SELECT id, event_date, days_to_subtract, even(precision_number) AS adjusted_precision FROM test_dates WHERE adjusted_precision IS NOT NULL) SELECT id, adjusted_precision, event_date - INTERVAL (days_to_subtract) DAY AS adjusted_date FROM date_adjustment ORDER BY adjusted_date DESC;
SELECT A.id, A.event_date, A.days_to_subtract, even(B.precision_number) FROM test_dates AS A JOIN test_dates AS B ON A.days_to_subtract + 5 = B.days_to_subtract WHERE A.id <> B.id;
CREATE TABLE temp_agg AS SELECT id, event_date, even(SUM(days_to_subtract)) AS even_total FROM test_dates GROUP BY id HAVING SUM(days_to_subtract) IS NOT NULL;
SELECT id, event_date, days_to_subtract, (event_date - INTERVAL (days_to_subtract) DAY) AS calculated_date, even(NULLIF(precision_number, 0)) FROM test_dates ORDER BY calculated_date;
SELECT MAX(even(precision_number)) AS max_even FROM test_dates WHERE precision_number IS NOT NULL;
SELECT id, event_date, even(days_to_subtract::DOUBLE) AS even_days FROM test_dates WHERE event_date - INTERVAL (days_to_subtract) DAY < DATE '2023-07-01' ORDER BY event_date;
SELECT e.date_diff, even(e.adjusted_days) FROM (SELECT id, event_date, days_to_subtract, (event_date - INTERVAL (days_to_subtract) DAY) AS date_diff, even(days_to_subtract) AS adjusted_days FROM test_dates) AS e WHERE e.date_diff IS NOT NULL;