CREATE TABLE test_table (id INTEGER, value NUMERIC, text_column TEXT);
INSERT INTO test_table VALUES (1, 0.5, 'foo'), (2, NULL, 'bar'), (3, 1.5, NULL), (4, 3.14, ''), (5, -2.7, 'baz');
CREATE TABLE second_table (ref_id INTEGER, factor_value NUMERIC);
INSERT INTO second_table VALUES (1, 4), (2, 5), (3, -3);
SELECT id, value, atan(value!) AS result FROM test_table WHERE value IS NOT NULL;
SELECT t.id, atan(t.value!) AS atan_factorial, s.factor_value FROM test_table AS t JOIN second_table AS s ON t.id = s.ref_id WHERE !(COALESCE(t.value, 0) + 1) < 4;
SELECT value, COUNT(*) AS count FROM test_table GROUP BY value HAVING count > 1 OR count = atan(0.5!);
SELECT t.id, s.factor_value, atan(t.value!) OVER (PARTITION BY s.ref_id ORDER BY t.id) AS atan_partition_value FROM test_table AS t JOIN second_table AS s ON t.id = s.ref_id;
SELECT id, value, !((atan(value) + 1) / 2) AS complex_expression FROM test_table WHERE text_column IS NOT NULL;
SELECT id, value, (atan(value) + NULLIF(text_column, '')) AS adjusted_atan FROM test_table;
CREATE TEMPORARY TABLE temp_table AS SELECT id, !value AS factorial_value FROM test_table WHERE value IS NOT NULL;
SELECT value, (SELECT COUNT(*) FROM temp_table WHERE factorial_value >= 5 AND factorial_value != 0) FROM test_table;