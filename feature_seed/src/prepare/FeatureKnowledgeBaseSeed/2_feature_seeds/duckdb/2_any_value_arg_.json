CREATE TABLE test_table (id INTEGER, val1 BITSTRING, val2 VARCHAR, val3 FLOAT);
INSERT INTO test_table VALUES (1, '101'::BITSTRING, 'Hello', 10.5), (2, '011'::BITSTRING, NULL, 20.0), (3, NULL, 'World', 0.0), (4, '000'::BITSTRING, '', 10.0);
SELECT any_value(xor(val1, '110'::BITSTRING)) FROM test_table GROUP BY id HAVING any_value(val3) > 5.0;
SELECT id, any_value(val2) AS non_null_val2, xor(val1, '001'::BITSTRING) AS result FROM test_table WHERE val3 IS NOT NULL GROUP BY id ORDER BY non_null_val2 DESC;
SELECT id, any_value(xor(val1, '111'::BITSTRING)) OVER (PARTITION BY val3) AS partitioned_result FROM test_table;
SELECT id, any_value(val2) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE xor(val1, '000'::BITSTRING) = '101'::BITSTRING) GROUP BY id HAVING any_value(val3) IS NOT NULL ORDER BY non_null_val2 ASC;
ALTER TABLE test_table ADD COLUMN val4 BOOLEAN DEFAULT TRUE;
INSERT INTO test_table (id, val1, val2, val3, val4) VALUES (5, '010'::BITSTRING, NULL, 30.0, FALSE);
SELECT id, any_value(xor(val1, '110'::BITSTRING)) AS bitwise_result FROM test_table WHERE val4 IS FALSE GROUP BY id HAVING any_value(val3) BETWEEN 10.0 AND 30.0;