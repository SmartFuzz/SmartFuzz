CREATE TABLE test_table (id INTEGER PRIMARY KEY, value NUMERIC, flag BOOLEAN);
INSERT INTO test_table (id, value, flag) VALUES (1, NULL, TRUE), (2, 42.4332, FALSE), (3, 84.5678, TRUE), (4, 0, NULL);
CREATE TABLE secondary_table (ref_id INTEGER, amount NUMERIC);
INSERT INTO secondary_table (ref_id, amount) VALUES (1, 99.9999), (2, 0), (3, NULL);
SELECT id, round(value, 2) AS rounded_value, (value % 10) AS mod_value FROM test_table WHERE flag IS TRUE;
SELECT id, (SELECT round(SUM(amount), 2) FROM secondary_table WHERE ref_id = test_table.id) AS rounded_sum FROM test_table;
SELECT id, round(value, (SELECT COUNT(*) FROM secondary_table WHERE amount IS NOT NULL) * -1) AS round_negative FROM test_table WHERE flag = TRUE;
SELECT t.id, round(SUM(s.amount), 2) AS total_round FROM test_table t JOIN secondary_table s ON (t.id % 2 = s.ref_id) GROUP BY t.id HAVING round(total_round, 1) IS NOT NULL;
SELECT t.id, round(NULLIF(SUM(s.amount), 0), 2) AS safe_round FROM test_table t LEFT JOIN secondary_table s ON t.id = s.ref_id GROUP BY t.id HAVING safe_round IS NOT NULL;
SELECT t.id, round(value, 3) AS precision_test, (ROUND(value, 2) % 2) AS mod_check FROM test_table t WHERE t.value IS NOT NULL AND round(value, 0) = 42;
SELECT t.id, (round(value, 1) % 2 = 0) AS is_even FROM test_table t WHERE value IS NOT NULL HAVING is_even IS TRUE;