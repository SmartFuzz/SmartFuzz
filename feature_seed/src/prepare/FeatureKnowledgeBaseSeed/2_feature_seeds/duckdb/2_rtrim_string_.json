CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(50), event_date DATE);
INSERT INTO test_table (id, name, event_date) VALUES (1, 'test  ', DATE '2023-01-01'), (2, 'example', DATE '2023-01-02');
SELECT rtrim(name) || ' - ' || rtrim(name) AS combined_name, event_date + INTERVAL (SELECT COUNT(*) FROM test_table) DAY AS future_event_date FROM test_table;
SELECT rtrim(name) AS trimmed_name, COUNT(*) FROM test_table GROUP BY rtrim(name) HAVING COUNT(*) > 1;
SELECT DISTINCT trimmed_name, event_date FROM (SELECT rtrim(name) AS trimmed_name, event_date FROM test_table WHERE event_date IS NOT NULL) AS subquery WHERE trimmed_name != '';
CREATE TABLE other_table (start_date DATE, end_date DATE);
INSERT INTO other_table (start_date, end_date) VALUES (DATE '2023-01-01', DATE '2023-01-10'), (DATE '2023-01-05', DATE '2023-01-15');
SELECT ot.start_date, ot.end_date, COUNT(tt.id) AS test_count FROM other_table ot LEFT JOIN test_table tt ON ot.start_date <= tt.event_date AND tt.event_date <= ot.end_date GROUP BY ot.start_date, ot.end_date ORDER BY ot.start_date;
SELECT rtrim(name) AS trim_test, event_date + INTERVAL 10 DAY FROM test_table WHERE id = (SELECT MAX(id) FROM test_table WHERE rtrim(name) IS NOT NULL);
SELECT rtrim(name) AS name_rtrim, event_date + INTERVAL CASE WHEN COUNT(*) > 2 THEN 5 ELSE 0 END DAY FROM test_table GROUP BY rtrim(name);
SELECT rtrim(name) || ' on ' || (event_date + INTERVAL 1 DAY) AS event_description FROM test_table WHERE event_date IS NOT NULL HAVING rtrim(name) != '';