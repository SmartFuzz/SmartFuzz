CREATE TABLE test_table (id INT, value FLOAT, description TEXT);
INSERT INTO test_table VALUES (1, pi() * 2, 'Value A');
INSERT INTO test_table VALUES (2, NULL, 'Value B');
INSERT INTO test_table VALUES (3, pi() * -3, 'Value C');
SELECT id, value * pi() AS multiplied_value FROM test_table WHERE value IS NOT NULL;
SELECT id, value * (SELECT pi() FROM test_table WHERE id = 1) AS correlated_value FROM test_table WHERE id <> 2;
SELECT id, COUNT(*) FROM (SELECT id, value * pi() FROM test_table GROUP BY id HAVING value * pi() > 0) AS subquery GROUP BY id;
SELECT DISTINCT id, pi() * value AS pi_multiplied FROM test_table ORDER BY pi_multiplied;
CREATE TABLE join_table (join_id INT, another_value FLOAT);
INSERT INTO join_table VALUES (1, 1.1), (2, 2.2), (3, 2.3);
SELECT t.id, t.value * j.another_value AS cross_value FROM test_table t JOIN join_table j ON j.join_id = t.id OR j.another_value > pi();
WITH recursive cte AS (SELECT id, value FROM test_table WHERE id = 1 UNION ALL SELECT id + 1, value FROM test_table WHERE id < 3) SELECT SUM(cte.value * pi()) FROM cte;
ALTER TABLE test_table ADD COLUMN new_value VARCHAR(255);
UPDATE test_table SET new_value = 'Updated ' || CAST(value AS VARCHAR) WHERE value IS NOT NULL;
SELECT id, pi() * COALESCE(new_value, '0')::FLOAT AS final_value FROM test_table;
SELECT pi() * AVG(value) FROM test_table WHERE value IS NOT NULL;
DROP TABLE join_table;