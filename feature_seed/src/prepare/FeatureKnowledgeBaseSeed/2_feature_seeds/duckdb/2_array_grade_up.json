CREATE TABLE test_data (id INTEGER, values_list LIST<INTEGER>, other_value INTEGER DEFAULT NULL);
INSERT INTO test_data (id, values_list, other_value) VALUES (1, [30, 10, 40, 20], 1), (2, [NULL, 50, 60, 70], NULL), (3, [], -5);
SELECT id, array_grade_up(values_list % 2 + other_value) AS graded_indexes FROM test_data WHERE other_value IS NOT NULL;
SELECT id, (SELECT array_grade_up(values_list) FROM test_data WHERE id = t.id) AS graded_indexes FROM test_data t;
SELECT id, array_grade_up(values_list) AS indexed_values FROM test_data WHERE id IN (SELECT id FROM test_data WHERE other_value > 0 HAVING COUNT(*) > 1);
SELECT id, SUM(other_value) AS total_value, array_grade_up(values_list) AS graded_indexes FROM test_data GROUP BY id HAVING total_value % 2 = 0;
SELECT id, array_grade_up((SELECT values_list FROM test_data WHERE id = 1) % 3) AS graded_indexes FROM test_data;
CREATE TABLE additional_data (key INTEGER PRIMARY KEY, value STRING NOT NULL);
INSERT INTO additional_data (key, value) VALUES (1, 'A'), (2, 'B'), (3, 'C');
SELECT a.id, array_grade_up(CAST(a.values_list AS LIST<INTEGER>) % COALESCE(b.key, 1)) AS graded_indexes FROM test_data a LEFT JOIN additional_data b ON a.id = b.key;
UPDATE test_data SET other_value = NULL WHERE id = 1;
SELECT id, array_grade_up(values_list % 5) AS graded_indexes FROM test_data WHERE values_list IS NOT NULL AND ARRAY_LENGTH(values_list) > 0;
SELECT id, (SELECT array_grade_up(values_list) FROM test_data x WHERE x.id = test_data.id) AS graded_indexes FROM test_data HAVING graded_indexes IS NOT NULL;
CREATE TEMPORARY TABLE temp_test AS SELECT id, array_grade_up(values_list) AS temp_indexed FROM test_data;
SELECT temp_indexed.id, temp_indexed.temp_indexed, COUNT(*) AS count_values FROM temp_test WHERE temp_indexed.temp_indexed % 2 = 0 GROUP BY temp_indexed.id HAVING count_values > 1;