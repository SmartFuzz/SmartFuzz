CREATE TABLE test_data (id INT PRIMARY KEY, values1 DOUBLE[], values2 DOUBLE[]);
INSERT INTO test_data VALUES (1, ARRAY[1.0, 2.0, NULL], ARRAY[3.0, 4.0, 5.0]), (2, ARRAY[NULL, NULL, NULL], ARRAY[1.0, 2.0, 3.0]);
SELECT id, array_negative_dot_product(values1, values2) // 2 AS resultant FROM test_data WHERE array_negative_dot_product(values1, values2) IS NOT NULL;
SELECT id, (SELECT array_negative_dot_product(values1, values2) // (SELECT COUNT(*) FROM test_data WHERE values2 IS NOT NULL) FROM test_data AS td WHERE td.id = test_data.id) AS adjusted_result FROM test_data;
SELECT id, array_negative_dot_product(values1, ARRAY[1.0, 1.0, 1.0]) // (SELECT COUNT(values2) FROM test_data WHERE values2 IS NOT NULL AND id > 1) AS ratio_result FROM test_data GROUP BY id HAVING array_negative_dot_product(values1, values2) IS NOT NULL;
SELECT T1.id, array_negative_dot_product(T1.values1, T2.values2) // 2 AS result FROM test_data AS T1 JOIN test_data AS T2 ON T1.id < T2.id WHERE T1.values1 IS NOT NULL AND T2.values2 IS NOT NULL;
CREATE TABLE additional_data (value1 STRING, value2 DOUBLE);
INSERT INTO additional_data VALUES ('3.14', 5.0), ('6.28', 10.0);
SELECT value1, CAST(array_negative_dot_product(values1, values2) AS STRING) // (SELECT COUNT(*) FROM additional_data) FROM test_data CROSS JOIN additional_data WHERE values1 IS NOT NULL;
CREATE TEMPORARY TABLE temp_data AS SELECT id, array_negative_dot_product(values1, values2) AS neg_dot FROM test_data WHERE values1 IS NOT NULL;