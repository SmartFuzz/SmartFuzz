CREATE TABLE test_data (id INTEGER, value INTEGER, date_val DATE);
INSERT INTO test_data (id, value, date_val) VALUES (1, 10, '2023-01-01'), (2, NULL, '2023-02-01'), (3, 0, '2023-03-01'), (4, 15, NULL);
SELECT id, to_days(value % 5) AS day_interval FROM test_data WHERE value IS NOT NULL AND date_val >= '2023-01-01' ORDER BY day_interval;
SELECT id, value, (to_days(value) % 3) AS day_mod FROM (SELECT id, value FROM test_data WHERE date_val IS NOT NULL) AS subquery HAVING day_mod > 0;
CREATE TABLE second_table (ref_id INTEGER, num_value INTEGER);
INSERT INTO second_table (ref_id, num_value) VALUES (1, 20), (2, 25), (3, NULL);
SELECT t.id, t.value, s.num_value, (to_days(t.value) + s.num_value) % 10 AS combined_mod FROM test_data t JOIN second_table s ON t.id = s.ref_id WHERE t.value IS NOT NULL ORDER BY combined_mod;
SELECT COUNT(*) AS cnt, (to_days(value) % 2) AS mod_value FROM test_data GROUP BY mod_value HAVING mod_value IS NOT NULL;
SELECT (SELECT to_days(MAX(value)) FROM test_data) % (SELECT COUNT(*) FROM second_table) AS cross_mod;