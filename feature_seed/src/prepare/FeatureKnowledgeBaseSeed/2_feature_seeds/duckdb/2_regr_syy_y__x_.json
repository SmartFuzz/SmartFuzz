CREATE TABLE test_data (id INTEGER PRIMARY KEY, value DOUBLE, category VARCHAR(50));
INSERT INTO test_data (id, value, category) VALUES (1, 10.0, 'A'), (2, 20.0, 'B'), (3, NULL, 'A'), (4, 30.0, 'B'), (5, 5.0, 'A'), (6, -10.0, 'B'), (7, 40.0, 'B');
SELECT category, regr_syy(value, ~id) AS regression_variance FROM test_data GROUP BY category HAVING regr_syy(value, ~id) IS NOT NULL;
SELECT category, COUNT(*), regr_syy(value, ~id) FROM (SELECT id, value, category FROM test_data WHERE value IS NOT NULL) AS filtered_data GROUP BY category;
SELECT DISTINCT category, regr_syy(value, ~id) FROM test_data WHERE category IN (SELECT category FROM test_data WHERE value > 0) AND value IS NOT NULL;
SELECT t1.category, regr_syy(t1.value, ~t2.id) AS reg_variance FROM test_data AS t1 JOIN test_data AS t2 ON t1.category = t2.category AND t1.id <> t2.id GROUP BY t1.category HAVING reg_variance < 50;
CREATE TABLE temp_data AS SELECT id, category, CAST(value AS VARCHAR) AS value_str FROM test_data;
SELECT category, regr_syy(CAST(NULLIF(value_str, '') AS DOUBLE), ~id) FROM temp_data GROUP BY category;
INSERT INTO test_data (id, value, category) VALUES (8, NULL, 'C'), (9, 100.0, 'C');
SELECT regr_syy(value, ~id) AS variance FROM (SELECT * FROM test_data WHERE category = 'C') AS subquery WHERE value IS NOT NULL;