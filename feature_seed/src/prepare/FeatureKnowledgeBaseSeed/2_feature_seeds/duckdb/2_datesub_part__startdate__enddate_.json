CREATE TABLE test_dates (id INT, timestamp_col TIMESTAMP, value FLOAT, notes STRING);
INSERT INTO test_dates (id, timestamp_col, value, notes) VALUES (1, TIMESTAMP '2023-01-01 00:00:00', 1.5, 'beginning of the year');
INSERT INTO test_dates (id, timestamp_col, value, notes) VALUES (2, TIMESTAMP '2023-01-01 01:00:00', NULL, 'an hour into the new year');
INSERT INTO test_dates (id, timestamp_col, value, notes) VALUES (3, TIMESTAMP '2023-12-31 23:59:59', 100.0, 'last moment of the year');
INSERT INTO test_dates (id, timestamp_col, value, notes) VALUES (4, TIMESTAMP '2023-02-28 23:59:59', 50.5, 'last moment of February');
INSERT INTO test_dates (id, timestamp_col, value, notes) VALUES (5, TIMESTAMP '2023-02-29 00:00:01', 0.0, 'first moment of the leap day');
SELECT id, timestamp_col, datesub('hour', timestamp_col, TIMESTAMP '2023-01-01 02:00:00') AS hours_diff FROM test_dates WHERE value IS NOT NULL;
SELECT id, timestamp_col, value + 1.0 AS incremented_value FROM test_dates WHERE notes LIKE 'beginning%';
SELECT id, timestamp_col, datesub('hour', TIMESTAMP '2023-01-01 01:00:00', timestamp_col) AS hours_diff, value + datesub('hour', TIMESTAMP '2023-01-01 00:00:00', timestamp_col) AS adjusted_value FROM test_dates;
SELECT t1.id, t1.timestamp_col, t1.value, (t1.value + COALESCE(t2.value, 0)) AS total_value FROM test_dates t1 LEFT JOIN test_dates t2 ON datesub('hour', t1.timestamp_col, t2.timestamp_col) < 0;
SELECT id, COUNT(*) AS entry_count, SUM(COALESCE(value, 0)) AS total_value FROM test_dates GROUP BY id HAVING total_value > 1.0;
SELECT id, datesub('hour', MIN(timestamp_col), MAX(timestamp_col)) AS range_hours FROM test_dates GROUP BY id HAVING range_hours > 0;