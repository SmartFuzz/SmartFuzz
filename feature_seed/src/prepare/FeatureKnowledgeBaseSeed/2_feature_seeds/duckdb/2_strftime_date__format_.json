CREATE TABLE test_dates (id INTEGER PRIMARY KEY, start_date TIMESTAMP, end_date TIMESTAMP, notes VARCHAR);
INSERT INTO test_dates (id, start_date, end_date, notes) VALUES (1, TIMESTAMP '2023-01-01', TIMESTAMP '2023-01-02', 'First entry');
INSERT INTO test_dates (id, start_date, end_date, notes) VALUES (2, TIMESTAMP '2023-01-10', TIMESTAMP '2023-01-14', NULL);
INSERT INTO test_dates (id, start_date, end_date, notes) VALUES (3, TIMESTAMP '1999-12-31', TIMESTAMP '2023-01-01', 'Boundary test');
SELECT id, strftime(start_date, '%Y-%m-%d %H:%M:%S') AS formatted_date, end_date - start_date AS duration FROM test_dates WHERE end_date IS NOT NULL;
SELECT id, strftime(start_date, '%m/%d/%Y') AS short_date FROM test_dates WHERE (strptime(notes, '%Y-%m-%d') IS NULL) OR (notes IS NULL);
SELECT id, COUNT(*) AS date_diff_count FROM (SELECT id, strftime(end_date, '%Y-%m-%d') AS formatted_end, end_date - start_date AS total_duration FROM test_dates) GROUP BY formatted_end HAVING total_duration > INTERVAL '1 day';
SELECT a.id, a.start_date, (strftime(a.start_date, '%Y-%m-%d') || ' to ' || strftime(a.end_date, '%Y-%m-%d')) AS duration_info FROM test_dates AS a JOIN (SELECT id, start_date FROM test_dates WHERE end_date IS NULL) AS b ON a.id = b.id;
SELECT id, strftime(start_date, '%Y %m %d') AS date_string, (start_date - TIMESTAMP '2000-01-01') AS days_since_2000 FROM test_dates WHERE start_date < TIMESTAMP '2023-01-05';
SELECT id, strftime(start_date, '%Y-%m-%d') AS formatted_date, (end_date - start_date) AS date_difference FROM test_dates WHERE (end_date > start_date) AND (strftime(start_date, '%Y-%m') = '2023-01');