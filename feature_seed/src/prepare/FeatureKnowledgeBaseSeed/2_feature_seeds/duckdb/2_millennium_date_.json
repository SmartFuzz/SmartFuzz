CREATE TABLE test_dates (event_date DATE, event_id INTEGER, event_name VARCHAR(255));
INSERT INTO test_dates (event_date, event_id, event_name) VALUES (NULL, 1, 'Conference'), (DATE '1999-12-31', 2, 'New Year Party'), (DATE '2000-01-01', 3, 'New Millennium Event');
SELECT event_name, millennium(event_date) << 1 AS shifted_millennium FROM test_dates WHERE event_date IS NOT NULL;
SELECT event_id, COUNT(*) AS cnt FROM (SELECT event_id, millennium(event_date) AS mill FROM test_dates WHERE event_date IS NOT NULL) AS sub WHERE mill << 2 > 2000 GROUP BY event_id HAVING cnt > 0;
CREATE TABLE bit_test (bit_val BITSTRING, num_val INTEGER);
INSERT INTO bit_test (bit_val, num_val) VALUES ('110010'::BITSTRING, 5), ('10100100'::BITSTRING, 10);
SELECT num_val, (bit_val << millennium(DATE '2023-10-31'))::INTEGER AS shifted_value FROM bit_test WHERE shifted_value > 50;
CREATE TABLE combined_test AS SELECT event_id, millennium(event_date) AS mill, (bit_val << 2) AS bit_shift FROM test_dates JOIN bit_test ON event_id = num_val WHERE num_val IS NOT NULL;
SELECT event_name, COUNT(*) FROM combined_test GROUP BY event_name HAVING COUNT(*) > (SELECT AVG(millennium(event_date)) FROM test_dates WHERE event_date IS NOT NULL);