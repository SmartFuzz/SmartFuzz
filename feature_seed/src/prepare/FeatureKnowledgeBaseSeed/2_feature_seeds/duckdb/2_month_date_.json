CREATE TABLE employees (id INTEGER, hire_date DATE, salary DECIMAL(10, 2), department VARCHAR(100));
INSERT INTO employees VALUES (1, DATE '2021-01-15', 50000.00, 'Sales'), (2, DATE '2020-05-22', 60000.50, 'Marketing'), (3, DATE '2019-11-30', NULL, 'HR');
SELECT month(hire_date) * 1000 AS month_bonus FROM employees WHERE salary IS NOT NULL;
SELECT e.id, month(e.hire_date) AS hire_month, e.salary, (e.salary * 1.1) AS adjusted_salary FROM employees e WHERE adjusted_salary > 55000;
SELECT e.id, e.department, SUM(e.salary) * month(NULLIF(e.hire_date, DATE '2019-11-30')) AS total_bonus FROM employees e GROUP BY e.department HAVING total_bonus > 60000;
CREATE TABLE departments (dep_id INTEGER, dep_name VARCHAR(100), budget DECIMAL(15, 2));
INSERT INTO departments VALUES (1, 'Sales', 200000.00), (2, 'Marketing', 150000.00), (3, NULL, 50000.00);
SELECT d.dep_name, (SUM(e.salary) * month(CURRENT_DATE)) AS avg_salary FROM employees e JOIN departments d ON e.department = d.dep_name WHERE d.dep_name IS NOT NULL GROUP BY d.dep_name HAVING avg_salary < 150000;
SELECT e.id, e.salary * month(DATE '2023-01-01') AS performance_bonus FROM employees e WHERE e.hire_date IS NOT NULL ORDER BY performance_bonus DESC;
SELECT e.id, (month(e.hire_date) * month(DATE '2023-02-01')) AS composite_value FROM employees e WHERE e.salary IS NOT NULL OR e.hire_date IS NULL;