CREATE TABLE test_strings (id INT, text_column VARCHAR);
INSERT INTO test_strings VALUES (1, '    example string    '), (2, NULL), (3, 'test    '), (4, '    '), (5, '   edge case 1'), (6, '    edge case 2   ');
CREATE TABLE test_dates (id INT, event_date DATE);
INSERT INTO test_dates VALUES (1, DATE '2023-01-01'), (2, DATE '2023-03-01'), (3, DATE '2023-12-31');
SELECT t1.id, ltrim(t1.text_column) AS trimmed_text, t2.event_date, t2.event_date - INTERVAL (SELECT COUNT(*) FROM test_strings WHERE text_column IS NOT NULL) DAY AS adjusted_date FROM test_strings t1 JOIN test_dates t2 ON ltrim(t1.text_column) <> '' AND t2.id = 1;
SELECT ltrim(text_column) AS cleaned_text, COUNT(*) FROM test_strings WHERE ltrim(text_column) IS NOT NULL GROUP BY cleaned_text HAVING COUNT(*) > 1;
SELECT t1.id, ltrim(t1.text_column) AS trimmed_text, t2.event_date, t2.event_date - INTERVAL (CASE WHEN ltrim(t1.text_column) IS NULL THEN 0 ELSE LENGTH(ltrim(t1.text_column)) END) DAY AS adjusted_date FROM test_strings t1 LEFT JOIN test_dates t2 ON t1.id = t2.id;
SELECT t1.id, ltrim(t1.text_column) AS trimmed_text, NOW() - INTERVAL (SELECT COUNT(*) FROM test_strings t3 WHERE t3.text_column IS NOT NULL AND ltrim(t3.text_column) <> '') DAY AS reference_date FROM test_strings t1 WHERE ltrim(t1.text_column) != '';