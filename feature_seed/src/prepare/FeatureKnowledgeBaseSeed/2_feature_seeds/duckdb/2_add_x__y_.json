CREATE TABLE test_table (id INT PRIMARY KEY, value1 FLOAT, value2 TIMESTAMP, value3 VARCHAR);
INSERT INTO test_table VALUES (1, 10.5, TIMESTAMP '2023-10-01', 'sample1'), (2, NULL, TIMESTAMP '2023-10-05', 'sample2'), (3, 20.0, TIMESTAMP '2023-10-10', 'sample3'), (4, 30.0, NULL, 'sample4');
SELECT id, add(value1, IFNULL(value2::FLOAT, 0)) AS adjusted_value FROM test_table WHERE value3 IS NOT NULL;
SELECT id, value1, value2 - (SELECT MIN(value2) FROM test_table WHERE value1 > 10) AS time_difference FROM test_table WHERE value1 < 15;
SELECT id, COUNT(*) OVER (PARTITION BY add(value1, 5)) AS count_per_group FROM test_table GROUP BY add(value1, 5) HAVING value2 IS NOT NULL;
SELECT t1.id, t1.value1, add(t1.value1, 5) AS new_value FROM test_table t1 JOIN (SELECT id, value3 FROM test_table WHERE value1 > 15) AS t2 ON t1.id = t2.id;
SELECT id, add(30, (TIMESTAMP '2023-10-15' - value2)::FLOAT) AS adjusted_days FROM test_table WHERE value2 IS NOT NULL ORDER BY adjusted_days DESC;
SELECT id FROM test_table WHERE add(value1, 10) < 25 OR value1 IS NULL;
SELECT MAX(add(value1, 3)) OVER (PARTITION BY value2) FROM test_table WHERE value1 BETWEEN 10 AND 30;
SELECT id, add(value1, CAST(value2 AS INT)) AS combined_value FROM test_table WHERE value2 IS NOT NULL;