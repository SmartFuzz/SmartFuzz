CREATE TABLE test_data (id INT, value DOUBLE, created_at TIMESTAMP);
INSERT INTO test_data (id, value, created_at) VALUES (1, 10.0, TIMESTAMP '2023-01-01 00:00:00'), (2, NULL, TIMESTAMP '2023-01-02 00:00:00'), (3, 15.5, TIMESTAMP '2023-01-03 00:00:00'), (4, 0.0, TIMESTAMP '2023-01-04 00:00:00'), (5, 7.0, TIMESTAMP '2023-01-05 00:00:00');
SELECT AVG(value) FROM (SELECT value, created_at - INTERVAL 1 DAY as adjusted_time FROM test_data WHERE created_at IS NOT NULL) AS subquery;
SELECT AVG(value) AS average_value, adjusted_time FROM (SELECT value, created_at - INTERVAL 5 DAY AS adjusted_time FROM test_data) AS subquery GROUP BY adjusted_time HAVING average_value > 5;
SELECT id, value, (value + 10.0) AS incremented_value FROM test_data WHERE (created_at - INTERVAL 3 DAY) < CURRENT_TIMESTAMP;
CREATE TABLE temp_stats AS SELECT AVG(value) AS avg_value, COUNT(*) AS count FROM test_data WHERE value IS NOT NULL;
SELECT t1.id, (t1.value - t2.avg_value) AS deviation FROM test_data t1 JOIN temp_stats t2 ON t1.value > t2.avg_value;
INSERT INTO test_data (id, value, created_at) VALUES (6, 20.0, NULL);
SELECT AVG(COALESCE(value, 0)) AS average_with_nulls FROM test_data;
SELECT AVG(value) AS avg_value, (MAX(created_at) - MIN(created_at)) AS time_span FROM test_data GROUP BY value HAVING AVG(value) < 15;