CREATE TABLE test_table (id INT, created_at TIMESTAMPTZ, value NUMERIC);
INSERT INTO test_table (id, created_at, value) VALUES (1, get_current_timestamp(), 10.75);
INSERT INTO test_table (id, created_at, value) VALUES (2, get_current_timestamp(), 5.25);
SELECT id, created_at, (value >> 1) AS shifted_value FROM test_table WHERE value IS NOT NULL;
SELECT id, (get_current_timestamp() IS NOT NULL) AS current_not_null, (value >> 2) AS shifted_value FROM test_table WHERE value IS NOT NULL;
WITH subquery AS (SELECT id, created_at, (value >> 1) AS shifted_value FROM test_table WHERE value > 5) SELECT *, (shifted_value + 1) AS incremented_value FROM subquery;
SELECT id, created_at, (get_current_timestamp() >> 2) AS ts_shifted FROM test_table WHERE (id = 1) OR (id = 2);
INSERT INTO test_table (id, created_at, value) VALUES (3, get_current_timestamp(), NULL);
SELECT id, created_at, value >> (CASE WHEN value IS NULL THEN 0 ELSE 1 END) AS dynamic_shift FROM test_table;
SELECT id FROM (SELECT id, (value >> 1) AS shifted_value, COUNT(*) OVER () AS total_count FROM test_table) sub WHERE total_count > 1;
SELECT COUNT(*) FROM test_table GROUP BY (value >> 1) HAVING COUNT(*) > 1;