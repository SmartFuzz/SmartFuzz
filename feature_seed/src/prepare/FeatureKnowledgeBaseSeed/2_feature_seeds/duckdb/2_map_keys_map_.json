CREATE TABLE test_map (id INTEGER, value MAP<INTEGER, INTEGER>);
INSERT INTO test_map VALUES (1, map([100, 5], [42, 43])), (2, map([200, 10], [12, 18]));
CREATE TABLE test_numbers (num INTEGER);
INSERT INTO test_numbers VALUES (1), (2), (3), (4), (5);
SELECT id, map_keys(value) << 1 AS shifted_keys FROM test_map WHERE shifted_keys IS NOT NULL;
SELECT id, value, map_keys(value) AS keys FROM test_map WHERE 100 << num < 10000;
SELECT num, (map_keys(value) << num) AS shifted_map_keys FROM test_map JOIN test_numbers ON id = num;
SELECT num, COUNT(*) FROM test_map, test_numbers WHERE map_keys(value) << num IS NOT NULL GROUP BY num HAVING COUNT(*) > 0;
SELECT id, value FROM test_map WHERE 0 << 1 IS NOT NULL AND map_keys(value) IS NOT NULL;
SELECT id, (map_keys(value) << 5) AS shifted_keys FROM (SELECT * FROM test_map WHERE id = (SELECT MAX(id) FROM test_map));