CREATE TABLE test_dates (id INT, event_date DATE, notes VARCHAR);
INSERT INTO test_dates VALUES (1, DATE '2021-02-28', NULL), (2, DATE '1992-03-07', 'Important Event'), (3, DATE '1992-03-01', 'Earlier Event');
SELECT id, date_trunc('month', event_date) AS truncated_date FROM test_dates WHERE event_date IS NOT NULL;
SELECT id, date_trunc('month', event_date) AS truncated_date, (5 / (CASE WHEN id = 1 THEN 1 ELSE NULL END)) AS division_result FROM test_dates;
SELECT id, date_trunc('month', event_date) AS truncated_date FROM test_dates WHERE (5 / NULLIF(event_date - DATE '1992-03-01', 0)) IS NULL;
SELECT A.id, date_trunc('month', A.event_date) AS truncated_date, (5 / COUNT(B.id)) AS ratio FROM test_dates A LEFT JOIN test_dates B ON A.id = B.id GROUP BY A.id, A.event_date HAVING date_trunc('month', A.event_date) < DATE '1992-03-01' OR (5 / NULLIF(COUNT(B.id), 0)) IS NULL;
SELECT id, event_date, (5 / NULLIF((EXTRACT(MONTH FROM event_date) + 1), 0)) AS month_div FROM test_dates WHERE event_date IS NOT NULL AND (SELECT COUNT(*) FROM test_dates WHERE id > 1) > 0;