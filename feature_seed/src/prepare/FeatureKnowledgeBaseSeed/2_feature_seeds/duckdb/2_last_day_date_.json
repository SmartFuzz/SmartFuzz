CREATE TABLE test_dates (id INTEGER, event_date DATE, description TEXT);
INSERT INTO test_dates VALUES (1, DATE '2023-02-28', 'Leap year check'), (2, DATE '2023-03-31', 'End of March'), (3, DATE '2023-12-31', 'End of Year');
SELECT id, last_day(event_date) AS last_day_of_month FROM test_dates WHERE last_day(event_date) > DATE '2023-02-28';
SELECT id, last_day(DATE '2023-01-01' - INTERVAL (id * 1) DAY) AS adjusted_last_day FROM test_dates;
SELECT id, last_day(event_date), event_date - INTERVAL COUNT(*) DAY AS adjusted_date FROM test_dates GROUP BY event_date HAVING last_day(event_date) IS NOT NULL;
SELECT id, last_day(DATE event_date) + INTERVAL (id - 2) DAY AS final_date FROM (SELECT id, event_date FROM test_dates) AS subquery ORDER BY final_date DESC;
CREATE TABLE temp_dates (event_id INTEGER, check_date DATE);
INSERT INTO temp_dates VALUES (1, DATE '2023-03-15'), (2, DATE NULL), (3, DATE '2023-10-10');
SELECT td.event_id, COALESCE(ld.last_day_date, DATE '1970-01-01') AS last_day_date FROM (SELECT event_id, last_day(check_date) AS last_day_date FROM temp_dates GROUP BY event_id) AS ld LEFT JOIN temp_dates td ON ld.event_id = td.event_id WHERE ld.last_day_date IS NOT NULL;
CREATE TABLE more_dates (id INTEGER, start_date DATE NOT NULL CHECK (start_date > DATE '2000-01-01'));
INSERT INTO more_dates VALUES (1, DATE '2000-02-29'), (2, DATE '2001-03-01'), (3, DATE '2003-02-28');
SELECT id, last_day(start_date) - INTERVAL (CASE WHEN id = 1 THEN 1 ELSE 0 END) DAY AS last_adj_date FROM more_dates;
SELECT id, last_day(COALESCE(start_date, DATE '2000-01-01' + INTERVAL 1 MONTH)) AS boundary_last_day FROM more_dates WHERE id <= 3;