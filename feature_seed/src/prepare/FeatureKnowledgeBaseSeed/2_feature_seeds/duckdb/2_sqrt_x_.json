CREATE TABLE test_table (id INTEGER PRIMARY KEY, value FLOAT, date_column DATE);
INSERT INTO test_table (id, value, date_column) VALUES (1, 9.0, DATE '2023-01-01'), (2, 16.0, DATE '2023-01-02'), (3, NULL, DATE '2023-01-03');
SELECT id, sqrt(value) AS sqrt_value, DATE '2023-01-05' - date_column AS days_since FROM test_table WHERE value > 0;
SELECT id, sqrt(COALESCE(value, 0)) AS coalesced_sqrt_value FROM test_table WHERE DATE '2023-01-02' - date_column > 0;
SELECT id, COUNT(*) OVER (PARTITION BY DATE '2023-01-05' - date_column) AS count_days_since FROM test_table;
SELECT id, sqrt(value) AS sqrt_value, DATE '2023-01-10' - date_column AS days_since FROM test_table GROUP BY id, value HAVING days_since > 2 OR sqrt_value < 4;
CREATE TABLE other_table (date_column DATE, description TEXT);
INSERT INTO other_table (date_column, description) VALUES (DATE '2023-01-01', 'Start'), (DATE '2023-01-03', 'Mid'), (DATE '2023-01-05', NULL);
SELECT t.id, t.value, sqrt(t.value) AS sqrt_value, o.description FROM test_table t JOIN other_table o ON t.date_column = o.date_column WHERE o.description IS NOT NULL;
SELECT id, sqrt(value) AS sqrt_value, DATE '2023-02-01' - MIN(date_column) AS days_since_min FROM test_table GROUP BY id, value HAVING sqrt_value IS NOT NULL AND days_since_min < 30;