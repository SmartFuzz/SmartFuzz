CREATE TABLE test_data (id INT, event_time TIMESTAMPTZ, value FLOAT);
INSERT INTO test_data (id, event_time, value) VALUES (1, TIMESTAMPTZ '1992-03-27 10:00:00+00', 5.5), (2, TIMESTAMPTZ '1992-03-22 10:00:00+00', NULL), (3, TIMESTAMPTZ '1992-03-25 10:00:00+00', 3.3);
SELECT first(value) FROM (SELECT id, event_time - TIMESTAMPTZ '1992-03-20 00:00:00+00' AS delta_time, value FROM test_data WHERE event_time < TIMESTAMPTZ '1992-03-26 00:00:00+00') AS subquery GROUP BY delta_time HAVING first(value) IS NOT NULL;
SELECT first(value) FROM (SELECT id, event_time, value FROM test_data WHERE value IS NULL OR event_time - TIMESTAMPTZ '1992-03-23 00:00:00+00' > INTERVAL '0 days') AS filtered_data;
CREATE TABLE test_data_2 (ref_id INT, value1 FLOAT, value2 FLOAT);
INSERT INTO test_data_2 (ref_id, value1, value2) VALUES (1, 10.5, NULL), (2, NULL, 20.4), (3, 30.7, 40.1);
SELECT first(value1) FROM (SELECT td.id, td.value1 - COALESCE(td2.value2, 0) AS adjusted_value FROM test_data td LEFT JOIN test_data_2 td2 ON td.id = td2.ref_id) AS adjusted_data WHERE adjusted_value < 10.0;
SELECT first(first_value) FROM (SELECT first(value) AS first_value FROM (SELECT value FROM test_data UNION ALL SELECT value1 AS value FROM test_data_2) AS unioned_data GROUP BY value HAVING COUNT(value) > 1) AS aggregated_data;
SELECT first(first(value)) OVER (PARTITION BY event_time - TIMESTAMPTZ '1992-03-24 00:00:00+00' ORDER BY value) FROM test_data GROUP BY event_time;
SELECT first(value) FROM (SELECT id, event_time - INTERVAL '3 days' AS adjusted_time, value FROM test_data WHERE event_time > TIMESTAMPTZ '1992-03-21 00:00:00+00') AS time_adjusted_data WHERE value IS NOT NULL GROUP BY adjusted_time HAVING COUNT(*) > 0;