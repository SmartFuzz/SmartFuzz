CREATE TABLE test_dates (id INTEGER, ts TIMESTAMP, value FLOAT);
INSERT INTO test_dates VALUES (1, TIMESTAMP '2023-10-01 12:00:00', 10.5), (2, TIMESTAMP '2023-10-01 13:00:00', NULL), (3, TIMESTAMP '2023-10-02 14:30:00', 20.0);
SELECT id, datetrunc('hour', ts) AS truncated_time, value FROM test_dates WHERE value IS NOT NULL;
SELECT id, datetrunc('minute', ts) AS truncated_time FROM test_dates WHERE (id % 2 = 0);
SELECT id, datetrunc('day', ts) AS truncated_date, SUM(value) FROM test_dates GROUP BY truncated_date HAVING COUNT(*) % 2 = 0;
WITH RankedDates AS (SELECT id, datetrunc('hour', ts) AS truncated_time, value, ROW_NUMBER() OVER (PARTITION BY datetrunc('day', ts) ORDER BY ts) AS rn FROM test_dates) SELECT id, truncated_time FROM RankedDates WHERE rn % 2 = 1;
SELECT id, (datetrunc('minute', ts) IS NULL) AS is_null_truncation FROM test_dates;
SELECT (COUNT(*) % 2) AS mod_result FROM (SELECT datetrunc('day', ts) AS truncated_date FROM test_dates) AS sub;
SELECT id, (datetrunc('minute', ts) + value) AS combined_value FROM test_dates WHERE value IS NOT NULL;
SELECT id FROM (SELECT id, (ts IS NULL) AS is_null_check FROM test_dates) AS sub WHERE is_null_check = FALSE;