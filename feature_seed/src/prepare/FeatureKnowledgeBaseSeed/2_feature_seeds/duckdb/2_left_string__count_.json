CREATE TABLE test_data (id INT PRIMARY KEY, name VARCHAR, created_at TIME, description TEXT);
INSERT INTO test_data (id, name, created_at, description) VALUES (1, 'Example1', TIME '10:00:00', 'This is a sample🦆'), (2, 'Example2', TIME '12:30:00', NULL), (3, 'Example3', TIME '15:15:15', 'Another🦆 example with text.');
SELECT id, left(name, 2) AS name_left, created_at - INTERVAL (CASE WHEN description IS NULL THEN 1 ELSE 0 END) HOUR AS adjusted_time FROM test_data WHERE left(description, 7) IS NOT NULL GROUP BY id, description HAVING COUNT(*) > 0 ORDER BY name_left;
SELECT id, left(description, 5) AS desc_left, created_at FROM test_data WHERE created_at < TIME '13:00:00' AND left(name, 3) = 'Ex' ORDER BY adjusted_time DESC;
SELECT id, COUNT(*) AS total FROM (SELECT id, left(name, 1) AS name_first FROM test_data) AS subquery GROUP BY name_first HAVING total > 1;
SELECT id, left(name, 4) AS name_partial FROM test_data WHERE id IN (SELECT id FROM test_data WHERE created_at - INTERVAL 1 HOUR < TIME '11:00:00') AND created_at IS NOT NULL ORDER BY name_partial;
SELECT id, left(name, 3) AS name_short, created_at - INTERVAL (SELECT COUNT(*) FROM test_data WHERE description IS NULL) HOUR AS calculated_time FROM test_data WHERE created_at BETWEEN TIME '10:00:00' AND TIME '15:00:00';