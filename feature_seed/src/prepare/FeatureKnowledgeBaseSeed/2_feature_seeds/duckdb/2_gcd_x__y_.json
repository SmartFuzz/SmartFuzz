CREATE TABLE numbers_table (id INTEGER PRIMARY KEY, a INTEGER, b INTEGER);
INSERT INTO numbers_table (a, b) VALUES (15, 45), (12, NULL), (0, 8), (NULL, NULL), (23, 41);
SELECT id, gcd(~a, b) AS gcd_negation FROM numbers_table WHERE b IS NOT NULL;
SELECT id, a, b, gcd(a, ~b) AS gcd_operators FROM numbers_table WHERE a > 0 AND b IS NOT NULL;
SELECT id, gcd(~(SELECT AVG(a) FROM numbers_table WHERE a IS NOT NULL), b) AS complex_gcd FROM numbers_table WHERE a IS NOT NULL;
SELECT id, gcd((SELECT MAX(a) FROM numbers_table), (SELECT MIN(b) FROM numbers_table WHERE b IS NOT NULL)) AS gcd_boundaries FROM numbers_table;
WITH derived AS (SELECT a, b, gcd(~a, ~b) AS derived_gcd FROM numbers_table WHERE a IS NOT NULL AND b IS NOT NULL) SELECT COUNT(*), derived_gcd FROM derived GROUP BY derived_gcd HAVING derived_gcd > 0;
SELECT id, gcd(NULLIF(a, 0), b) AS gcd_nullif FROM numbers_table WHERE a IS NOT NULL OR b IS NOT NULL;
SELECT a, b, gcd(a, b) AS gcd_values FROM numbers_table ORDER BY gcd_values DESC;
DROP TABLE IF EXISTS temp_table;
CREATE TEMPORARY TABLE temp_table AS SELECT id, gcd(a, b) AS gcds FROM numbers_table WHERE a IS NOT NULL AND b IS NOT NULL;
SELECT AVG(gcds) FROM temp_table WHERE gcds IS NOT NULL;