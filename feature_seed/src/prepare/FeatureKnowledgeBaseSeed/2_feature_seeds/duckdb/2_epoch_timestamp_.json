CREATE TABLE test_data (id INTEGER, timestamp_val TIMESTAMP, interval_val INTERVAL);
INSERT INTO test_data VALUES (1, '2022-01-01 00:00:00', INTERVAL '5 hour'), (2, NULL, INTERVAL '12 hour'), (3, '2023-12-31 23:59:59', INTERVAL '1 day');
SELECT id, epoch(timestamp_val + INTERVAL '1 hour') AS epoch_plus_interval FROM test_data WHERE timestamp_val IS NOT NULL;
SELECT id, epoch(timestamp_val) AS epoch_value, (epoch(timestamp_val) + INTERVAL '1 day') AS epoch_plus_one_day FROM test_data WHERE epoch(timestamp_val) < 1672531199;
WITH calculated AS (SELECT id, epoch(timestamp_val) AS epoch_value, interval_val FROM test_data) SELECT id, epoch_value + interval_val AS new_epoch_value FROM calculated WHERE epoch_value IS NOT NULL;
SELECT id, SUM(epoch(timestamp_val + INTERVAL '1 hour')) OVER (PARTITION BY id) AS sum_epoch_plus_interval FROM test_data GROUP BY id HAVING sum_epoch_plus_interval > 0;
SELECT id, epoch(timestamp_val) AS epoch_val, epoch(timestamp_val + (SELECT INTERVAL '10 minute' FROM test_data WHERE id = 1)) AS nested_epoch FROM test_data WHERE timestamp_val IS NOT NULL;
SELECT id, epoch(DATE '2022-01-01' + INTERVAL '10 days' + timestamp_val) AS final_epoch FROM test_data WHERE timestamp_val IS NOT NULL;
CREATE TEMPORARY TABLE limit_test AS SELECT timestamp_val + INTERVAL (SELECT MAX(interval_val) FROM test_data WHERE interval_val IS NOT NULL) AS max_interval_timestamp FROM test_data WHERE timestamp_val IS NOT NULL;