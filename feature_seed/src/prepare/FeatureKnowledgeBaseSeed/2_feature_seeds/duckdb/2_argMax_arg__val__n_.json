CREATE TABLE test_data (id INTEGER, val INTEGER, arg_val VARCHAR(255), bit_val BIT(5));
INSERT INTO test_data VALUES (1, 10, 'Value A', '10101'::BITSTRING), (2, 20, 'Value B', '10001'::BITSTRING), (3, 15, 'Value C', NULL), (4, NULL, 'Value D', '11100'::BITSTRING);
SELECT argMax(arg_val, val, 2) FROM test_data GROUP BY id HAVING val IS NOT NULL;
SELECT id, arg_max(arg_val, val, 3) FROM (SELECT id, arg_val, val FROM test_data WHERE bit_val & '11001'::BITSTRING = '10001'::BITSTRING) AS filtered GROUP BY id ORDER BY val DESC;
SELECT argValList FROM (SELECT arg_max(arg_val, val, 2) AS argValList FROM test_data WHERE val IS NOT NULL GROUP BY arg_val HAVING COUNT(*) > 1) AS subquery WHERE argValList IS NOT NULL;
SELECT id, val, arg_max(arg_val, val, 1) AS arg_max_value FROM test_data WHERE bit_val & '11111'::BITSTRING != '00000'::BITSTRING ORDER BY val;
SELECT (arg_max(arg_val, val, 2) || ' Combined') AS combined_value FROM test_data WHERE id IN (SELECT id FROM test_data WHERE val = 20) GROUP BY arg_val HAVING MAX(val) IS NOT NULL;
CREATE TABLE temp_table AS SELECT id, val FROM test_data WHERE val IS NULL;
SELECT arg_max(arg_val, val, 3) AS top_values FROM temp_table WHERE arg_val IS NOT NULL;
SELECT arg_max(COALESCE(arg_val, 'Default Value'), val, 2) FROM test_data WHERE (val IS NOT NULL AND bit_val & '11101'::BITSTRING = '11101'::BITSTRING) GROUP BY id ORDER BY val DESC;