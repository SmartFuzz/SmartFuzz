CREATE TABLE test_table (id INTEGER, text_column VARCHAR, value_column FLOAT);
INSERT INTO test_table VALUES (1, 'hello', 2.5), (2, 'world', NULL), (3, '', 0.0), (4, 'test', 3.14159);
SELECT id, replace(text_column, 'o', '-') AS modified_text, value_column * 2 AS doubled_value FROM test_table;
SELECT id, replace(text_column, 'x', 'y') AS modified_text, value_column * (SELECT AVG(value_column) FROM test_table WHERE value_column IS NOT NULL) AS adjusted_value FROM test_table;
SELECT id, replace(text_column, 'l', '1') AS modified_text, value_column * CASE WHEN value_column IS NULL THEN 1 ELSE value_column END AS safe_value FROM test_table HAVING safe_value > 5;
WITH multiplied AS (SELECT id, replace(text_column, 'e', '3') AS modified_text, value_column * 100 AS value_times_100 FROM test_table) SELECT * FROM multiplied WHERE modified_text IS NOT NULL;
CREATE TABLE another_table (ref_id INTEGER, description VARCHAR);
INSERT INTO another_table VALUES (1, 'medium text'), (2, NULL), (3, 'hello there'), (4, 'world');
SELECT a.ref_id, a.description, replace(b.modified_text, '3', '') AS final_text FROM another_table a JOIN (SELECT id, replace(text_column, '1', '') AS modified_text FROM test_table) b ON a.ref_id = b.id;
SELECT id, REPLACE(text_column, 'l', '*') AS altered_text, value_column * CAST(NULL AS FLOAT) AS null_mult FROM test_table ORDER BY null_mult DESC;
SELECT replace(replace(text_column, 'e', '3'), 'o', '0') AS double_modified, sum(value_column * 2) AS sum_value FROM test_table GROUP BY double_modified HAVING sum_value < 10;