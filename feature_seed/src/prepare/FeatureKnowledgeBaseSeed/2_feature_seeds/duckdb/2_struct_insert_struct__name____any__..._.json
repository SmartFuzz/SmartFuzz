CREATE TABLE test_structs (id INTEGER, data STRUCT<field1: INTEGER, field2: DATE>);
INSERT INTO test_structs VALUES (1, struct_insert(struct_insert({'field1': 5}, field2 := DATE '2023-01-01'), field2 := DATE '2023-01-02'));
INSERT INTO test_structs VALUES (2, struct_insert({'field1': NULL}, field2 := DATE '2000-01-01'));
INSERT INTO test_structs VALUES (3, struct_insert(struct_insert({'field1': 10}, field2 := DATE '2021-01-01'), field1 := 15));
SELECT id, struct_insert(data, field3 := data.field1 + 2) AS new_data FROM test_structs WHERE data.field2 + 5 > DATE '2023-01-01';
SELECT id, COUNT(*) FROM (SELECT data, struct_insert(data, field3 := data.field1 + 5) FROM test_structs) sub WHERE sub.data.field1 IS NOT NULL GROUP BY data.field2;
CREATE TABLE test_dates (event_date DATE, duration INTEGER);
INSERT INTO test_dates VALUES (DATE '1992-03-22', 5), (DATE '1995-12-31', 0), (DATE '2023-02-01', -2);
SELECT event_date, struct_insert({'duration_sum': SUM(duration)}, adjusted_date := event_date + 5) FROM test_dates GROUP BY event_date;
WITH temp AS (SELECT event_date, struct_insert({'duration_sum': SUM(duration)}, adjusted_date := event_date + duration) AS adjusted_data FROM test_dates GROUP BY event_date) SELECT *, adjusted_data.field1 AS original_sum FROM temp;