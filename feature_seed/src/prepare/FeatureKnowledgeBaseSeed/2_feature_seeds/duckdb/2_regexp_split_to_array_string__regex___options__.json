CREATE TABLE test_table (id INTEGER, description STRING, created_at TIMESTAMP);
INSERT INTO test_table (id, description, created_at) VALUES (1, 'first entry;
100', TIMESTAMP '2023-01-01 00:00:00');
INSERT INTO test_table (id, description, created_at) VALUES (2, 'second entry;
200', TIMESTAMP '2023-01-02 00:00:00');
INSERT INTO test_table (id, description, created_at) VALUES (3, 'third entry;
300', TIMESTAMP '2023-01-03 00:00:00');
SELECT id, regexp_split_to_array(description, ';
? ') AS split_desc FROM test_table WHERE id IN (SELECT id FROM test_table WHERE created_at < TIMESTAMP '2023-01-02 00:00:00');
SELECT id, (TIMESTAMP '2023-01-01 00:00:00' + INTERVAL (regexp_split_to_array(description, ';
? ')[2]::INTEGER) DAY) AS new_date FROM test_table WHERE id = 1;
SELECT description, (regexp_split_to_array(description, ';
? ')[1] || ' - processed') AS processed_desc FROM test_table WHERE id IS NOT NULL HAVING LENGTH(processed_desc) > 15;
WITH split_data AS (SELECT id, regexp_split_to_array(description, ';
? ') AS arr FROM test_table) SELECT id, arr[1] FROM split_data WHERE (SELECT COUNT(*) FROM split_data) >= 2;
SELECT id, (TIMESTAMP '2023-01-01 12:00:00' + INTERVAL (regexp_split_to_array(description, ';
? ')[3]::INTEGER) DAY) AS future_time FROM test_table WHERE description LIKE '%entry%';
SELECT id, (CASE WHEN description IS NULL THEN 'NULL description' ELSE regexp_split_to_array(description, ';
? ')[1] END) AS safe_desc FROM test_table ORDER BY safe_desc NULLS LAST;