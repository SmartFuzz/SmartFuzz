CREATE TABLE test_data (id INTEGER, content VARCHAR, num_value FLOAT, created_at TIMESTAMP);
INSERT INTO test_data (id, content, num_value, created_at) VALUES (1, read_text('file1.txt'), 123.456, NOW()), (2, read_text('file2.txt'), NULL, NOW());
SELECT id, content, num_value ^ 2 AS squared_value FROM test_data WHERE num_value IS NOT NULL;
SELECT id, read_text('file3.txt') AS file_content, num_value ^ (SELECT MAX(num_value) FROM test_data) AS powered_value FROM test_data WHERE num_value IS NOT NULL;
SELECT id, content, num_value, created_at, power(num_value, 3) AS cubed_value FROM test_data WHERE content IS NOT NULL AND num_value IS NOT NULL;
SELECT id, content, (CASE WHEN num_value IS NULL THEN 'NULL VALUE' ELSE content END) AS content_status FROM test_data WHERE num_value ^ 2 > 100;
CREATE TABLE additional_data (id INTEGER PRIMARY KEY, description VARCHAR, related_id INTEGER);
INSERT INTO additional_data (id, description, related_id) VALUES (1, 'This is a test', 1), (2, 'Another entry with NULL', NULL);
SELECT ad.id, ad.description, (SELECT SUM(num_value ^ 2) FROM test_data WHERE id = ad.related_id) AS total_squared FROM additional_data ad WHERE ad.related_id IS NOT NULL;
SELECT ad.id, read_text('testfiles/file' || ad.related_id || '.txt') AS file_content, (SELECT COUNT(*) FROM test_data WHERE num_value IS NOT NULL) AS valid_count FROM additional_data ad;
SELECT COUNT(*) AS file_count, MAX(num_value ^ 3) AS max_cubed FROM test_data GROUP BY read_text('group_info.txt');
SELECT *, NUM_VALUE ^ 2 + (SELECT COUNT(*) FROM additional_data) as expressed_value FROM test_data HAVING expressed_value > 100;