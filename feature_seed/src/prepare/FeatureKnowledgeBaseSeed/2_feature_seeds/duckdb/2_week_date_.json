CREATE TABLE test_dates (id INTEGER, event_date DATE, value NUMERIC);
INSERT INTO test_dates VALUES (1, DATE '1992-02-15', 100.0), (2, DATE '2020-01-01', NULL), (3, DATE '2000-12-31', 5.75);
CREATE TABLE test_numbers (num_id INTEGER, num_value NUMERIC);
INSERT INTO test_numbers VALUES (1, 25.5), (2, NULL), (3, 10);
SELECT week(event_date), (value // 2) AS half_value FROM test_dates WHERE event_date IS NOT NULL HAVING (half_value > 0);
SELECT d.id, d.event_date, (week(d.event_date) // n.num_value) AS week_division FROM test_dates d JOIN test_numbers n ON n.num_id = d.id WHERE n.num_value IS NOT NULL;
SELECT t.id, week(t.event_date) AS iso_week FROM (SELECT event_date, value // 3 AS adjusted_value FROM test_dates) t GROUP BY t.iso_week HAVING adjusted_value IS NOT NULL;
SELECT DISTINCT week(event_date) AS week_num, SUM(value // 5) AS total FROM test_dates WHERE event_date BETWEEN DATE '1990-01-01' AND DATE '2023-01-01' GROUP BY week_num HAVING week_num IS NOT NULL;
SELECT d.id, AVG(d.value // (SELECT COUNT(*) FROM test_numbers WHERE num_value IS NOT NULL)) AS average_half FROM test_dates d JOIN test_numbers n ON n.num_id = d.id GROUP BY d.id;
SELECT week(event_date) AS week_num FROM test_dates WHERE event_date IS NOT NULL UNION ALL SELECT week(DATE '9999-01-01') // 1;
SELECT week(event_date) FROM test_dates WHERE event_date IN (SELECT event_date FROM test_dates WHERE event_date IS NOT NULL ORDER BY event_date DESC LIMIT 1);