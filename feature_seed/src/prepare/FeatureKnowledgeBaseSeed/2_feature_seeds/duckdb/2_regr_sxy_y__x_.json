CREATE TABLE test_data (id INTEGER, value_y DOUBLE, value_x DOUBLE, created_at TIMESTAMP);
INSERT INTO test_data VALUES (1, 10.5, 2.0, '2023-01-01 10:00:00'), (2, 5.5, 0.0, '2023-01-02 11:00:00'), (3, NULL, 3.0, '2023-01-03 12:00:00'), (4, 12.0, 4.0, '2023-01-04 13:00:00');
SELECT id, regr_sxy(value_y, value_x) AS regression_result FROM test_data GROUP BY id HAVING (regr_sxy(value_y, value_x) % 2) = 0;
SELECT id, regr_sxy(value_y, value_x) FROM test_data WHERE (value_x % 2) IS NOT NULL AND value_y IS NOT NULL;
SELECT id, regr_sxy(value_y, (value_x * NULLIF(value_x, 0))) FROM test_data WHERE created_at > '2023-01-01';
SELECT t1.id, regr_sxy(t1.value_y, t2.value_x) AS reg_sxy FROM test_data t1 JOIN test_data t2 ON (t1.id % 2 = 0 AND t2.id % 3 = 0) GROUP BY t1.id;
SELECT id, regr_sxy(COALESCE(value_y, 0), ABS(value_x) % 2) AS adjusted_regression FROM test_data;
SELECT id, regr_sxy(value_y, value_x) FROM test_data WHERE strftime('%Y', created_at) = '2023' AND value_x BETWEEN 0 AND 5;
SELECT t1.id, regr_sxy(t1.value_y, t1.value_x) FROM test_data t1 WHERE value_y + (5 % 3) >= 10 GROUP BY t1.id HAVING regr_sxy(value_y, value_x) IS NOT NULL;
SELECT id, AVG(regr_sxy(value_y, value_x)) OVER (PARTITION BY MOD(id, 2)) AS avg_regression FROM test_data;