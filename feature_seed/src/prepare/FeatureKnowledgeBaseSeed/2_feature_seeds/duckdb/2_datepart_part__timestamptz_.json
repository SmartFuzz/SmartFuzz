CREATE TABLE test_data (id INT, timestamp_col TIMESTAMPTZ, numbers_list LIST<INT>);
INSERT INTO test_data VALUES (1, TIMESTAMPTZ '2023-01-01 12:00:00', [1, 2, 3, 4]), (2, TIMESTAMPTZ '2023-01-02 12:00:00', [2, 3, 4]), (3, TIMESTAMPTZ '2023-01-03 12:00:00', [1, 4]), (4, NULL, [5, NULL]);
SELECT id, datepart('minute', timestamp_col) AS minute_part FROM test_data WHERE numbers_list <@ [1, 2, 3];
SELECT id FROM test_data WHERE datepart('minute', timestamp_col) IS NOT NULL AND numbers_list <@ [2, 3, 4] AND timestamp_col IS NOT NULL;
SELECT id, COUNT(*) OVER (PARTITION BY datepart('minute', timestamp_col)) AS minute_count FROM test_data GROUP BY id, minute_part HAVING minute_count > 1;
SELECT id FROM (SELECT id, datepart('minute', timestamp_col) AS minute_part FROM test_data) AS subquery WHERE minute_part BETWEEN 0 AND 59 AND id < 4;
CREATE TABLE temp_data AS SELECT * FROM test_data WHERE timestamp_col IS NOT NULL;
INSERT INTO temp_data SELECT * FROM test_data WHERE numbers_list <@ [5];
SELECT id FROM temp_data WHERE timestamp_col IS NULL OR datepart('minute', timestamp_col) IS NOT NULL;
SELECT id, datepart('minute', timestamp_col) FROM test_data WHERE numbers_list <@ (SELECT numbers_list FROM temp_data WHERE id = 1);