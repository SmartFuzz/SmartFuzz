CREATE TABLE test_intervals (id INTEGER PRIMARY KEY, interval_val INTEGER NOT NULL);
INSERT INTO test_intervals (id, interval_val) VALUES (1, 10), (2, 20), (3, 30);
CREATE TABLE test_lists (id INTEGER PRIMARY KEY, values_list LIST<INTEGER>);
INSERT INTO test_lists (id, values_list) VALUES (1, [1, 2, 3, 4]), (2, [3, 4]), (3, [5, 6]);
SELECT id, to_millennia(interval_val) AS millennium_val FROM test_intervals WHERE interval_val @> (SELECT values_list FROM test_lists WHERE id = 1);
SELECT l.id FROM test_lists l JOIN (SELECT id, to_millennia(interval_val) AS millennium_val FROM test_intervals WHERE interval_val IS NOT NULL) t ON l.values_list @> [1, 2];
SELECT id, to_millennia(interval_val) AS millennium_val FROM test_intervals WHERE interval_val IS NULL OR interval_val = 0;
SELECT id FROM test_lists WHERE values_list @> (SELECT ARRAY_AGG(to_millennia(interval_val)) FROM test_intervals WHERE interval_val < 20) LIMIT 1;
SELECT l.id, t.millennium_val FROM test_lists l JOIN (SELECT id, to_millennia(interval_val) AS millennium_val FROM test_intervals) t ON l.values_list @> [3];
SELECT DISTINCT interval_val, to_millennia(interval_val) AS millennium_val FROM test_intervals GROUP BY interval_val HAVING COUNT(*) > 1;
SELECT t.id FROM (SELECT id, to_millennia(interval_val) AS millennium_val FROM test_intervals) t WHERE t.millennium_val IS NULL OR t.millennium_val @> [1, 2];