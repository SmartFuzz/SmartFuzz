CREATE TABLE test_data (id INTEGER, name TEXT, created_at DATE, salary DECIMAL(10, 2));
INSERT INTO test_data (id, name, created_at, salary) VALUES (1, 'Alice', DATE '2022-01-01', 50000.00);
INSERT INTO test_data (id, name, created_at, salary) VALUES (2, 'Bob', DATE '2022-01-02', NULL);
INSERT INTO test_data (id, name, created_at, salary) VALUES (3, 'Charlie', DATE '2022-01-03', 60000.45);
INSERT INTO test_data (id, name, created_at, salary) VALUES (4, 'Diana', DATE '2022-01-04', 40000.00);
SELECT id, name FROM test_data WHERE suffix(name, 'a') AND created_at - DATE '2022-01-01' >= 0;
SELECT id, salary FROM test_data WHERE salary IS NULL OR salary - 10000 > 0 HAVING suffix(name, 'b');
SELECT id, name, created_at, salary FROM test_data WHERE ends_with(name, 'y') AND salary IS NOT NULL ORDER BY created_at DESC;
SELECT id, name, (created_at - DATE '2022-01-01') AS days_since_created from test_data WHERE days_since_created IS NOT NULL AND suffix(name, 'e');
SELECT id, (SUM(salary) OVER (PARTITION BY CASE WHEN suffix(name, 'a') THEN 'A' ELSE 'Others' END)), created_at FROM test_data GROUP BY id, created_at HAVING days_since_created >= 1;