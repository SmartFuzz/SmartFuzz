CREATE TABLE test_table (id INTEGER, bit_value BIT(10), description VARCHAR);
INSERT INTO test_table (id, bit_value, description) VALUES (1, '1010101010'::BITSTRING, 'Sample data 1'), (2, NULL, 'Sample data 2');
SELECT id, bit_position(bit_value, '~' || bit_value) AS position FROM test_table WHERE bit_value IS NOT NULL;
CREATE TABLE second_table (bit_string BIT(10), other_value INTEGER);
INSERT INTO second_table (bit_string, other_value) VALUES ('1111111111'::BITSTRING, 10), ('0000000000'::BITSTRING, NULL);
SELECT st.id, bt.position FROM (SELECT id, bit_position(bit_value, bit_string) AS position FROM test_table JOIN second_table ON bit_value ~ bit_string) AS bt WHERE position > 0;
SELECT id, '~(bit_value)' AS flipped_value FROM test_table HAVING flipped_value IS NOT NULL;
SELECT MAX(bit_position(bit_value, ~bit_value)) AS max_position FROM test_table WHERE bit_value IS NOT NULL;
SELECT ST.id, (bit_position((~(ST.bit_value)), '101') + NULLIF(ST.id, 0)) AS combined_position FROM test_table AS ST WHERE ST.id IS NOT NULL;
CREATE TABLE temp_table AS SELECT id, bit_position(bit_value, '010'::BITSTRING) AS pos FROM test_table WHERE bit_value IS NOT NULL;
SELECT AVG(other_value) FROM second_table WHERE bit_string IS NOT NULL AND bit_position(bit_string, '~' || '111') > 0;