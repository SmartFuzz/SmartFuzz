CREATE TABLE dates_table (id INTEGER PRIMARY KEY, event_date DATE, event_name VARCHAR(100));
INSERT INTO dates_table VALUES (1, DATE '1992-09-20', 'Event A'), (2, DATE '1995-01-15', 'Event B'), (3, NULL, 'Event C');
SELECT id, event_name, extract('year' FROM event_date) AS event_year FROM dates_table WHERE event_date IS NOT NULL;
SELECT id, event_name, extract('month' FROM event_date) AS event_month, event_date - INTERVAL extract('day' FROM event_date) DAY AS new_date FROM dates_table WHERE event_date IS NOT NULL;
SELECT id, event_name, event_date, (extract('year' FROM event_date) - 1) AS previous_year FROM dates_table WHERE event_date IS NOT NULL HAVING previous_year < 1995;
SELECT d1.id, d1.event_name, d1.event_date, d2.event_date AS compare_date FROM dates_table d1 JOIN dates_table d2 ON d1.event_date - INTERVAL 10 DAY = d2.event_date WHERE d1.event_date IS NOT NULL AND d2.event_date IS NOT NULL;
CREATE TABLE intervals_table (id INTEGER PRIMARY KEY, start_date DATE, end_date DATE);
INSERT INTO intervals_table VALUES (1, DATE '1990-01-01', DATE '2000-12-31'), (2, DATE '1995-05-15', DATE '1995-08-15');
SELECT id, start_date, end_date, extract('year' FROM end_date) - extract('year' FROM start_date) AS duration FROM intervals_table WHERE start_date IS NOT NULL AND end_date IS NOT NULL;
SELECT id, start_date, end_date, start_date - INTERVAL (extract('year' FROM end_date) - extract('year' FROM start_date)) YEAR AS adjusted_start_date FROM intervals_table WHERE start_date < end_date;
SELECT id, event_name, LEAD(event_date) OVER (ORDER BY event_date) AS next_event_date FROM dates_table WHERE event_date IS NOT NULL;
SELECT id, event_name, new_date, NULLIF(new_date, DATE '1995-01-15') AS check_date FROM (SELECT id, event_name, event_date - INTERVAL 3 DAY AS new_date FROM dates_table) AS derived_table;