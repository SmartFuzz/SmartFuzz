CREATE TABLE test_table (id INTEGER, value DOUBLE, time_col TIME);
INSERT INTO test_table (id, value, time_col) VALUES (1, 5.0, TIME '05:00:00'), (2, 0.0, TIME '10:00:00'), (3, NULL, TIME '15:00:00');
SELECT id, fdiv(SUM(value), COUNT(*)) AS average FROM test_table GROUP BY id HAVING fdiv(SUM(value), COUNT(*)) > 1.0;
SELECT id, time_col + INTERVAL fdiv(10, 2) HOUR AS new_time FROM (SELECT id, time_col FROM test_table WHERE value IS NOT NULL) AS sub_query;
SELECT t1.id, t1.value, t1.time_col FROM test_table t1 JOIN (SELECT id, fdiv(SUM(value), COUNT(*)) AS avg_val FROM test_table GROUP BY id HAVING avg_val IS NOT NULL) AS avg_query ON t1.id = avg_query.id;
CREATE TABLE second_table (reference_id INTEGER, event_time TIME);
INSERT INTO second_table (reference_id, event_time) VALUES (1, TIME '07:30:00'), (2, TIME '12:45:00'), (3, NULL);
SELECT s.reference_id, s.event_time + INTERVAL fdiv(9, 3) HOUR AS updated_event_time FROM second_table s WHERE s.event_time IS NOT NULL;
SELECT id, fdiv(value, (SELECT COUNT(*) FROM second_table)) AS ratio FROM test_table WHERE value IS NOT NULL OR time_col IS NOT NULL;
SELECT id, fdiv(1, NULL) AS division_with_null FROM test_table;