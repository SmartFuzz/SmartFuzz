CREATE TABLE test_table (id INTEGER PRIMARY KEY, num_col INTEGER, list_col LIST<INTEGER>);
INSERT INTO test_table VALUES (1, 5, [1, 2, 3]), (2, 10, [2, 3, 4]), (3, NULL, NULL), (4, 0, []);
SELECT id, array_intersect(list_col, [1, 2, 4]) + (num_col + 1) AS result FROM test_table WHERE num_col IS NOT NULL;
SELECT id, (array_intersect(list_col, [1, 2, 3, 4]) + 10) AS intersect_plus FROM test_table WHERE id > 1;
SELECT t1.id, (SELECT COUNT(*) FROM (SELECT all_val FROM (SELECT unnest(list_col) AS all_val FROM test_table WHERE id = t1.id) AS distinct_vals GROUP BY all_val HAVING COUNT(*) > 1)) AS count_intersects FROM test_table t1 WHERE num_col IS NOT NULL;
SELECT id, array_intersect(list_col, [1, 2, 3]) AS common_elements FROM test_table WHERE common_elements IS NOT NULL;
CREATE TABLE join_table (fk_id INTEGER, join_col INTEGER);
INSERT INTO join_table VALUES (1, 5), (1, 10), (2, 10), (3, 20);
SELECT t1.id, (array_intersect(t1.list_col, [1, 2]) + coalesce(t2.join_col, 0)) AS combined_sum FROM test_table t1 LEFT JOIN join_table t2 ON t1.id = t2.fk_id WHERE array_intersect(t1.list_col, [1, 2]) IS NOT NULL;
SELECT SUM((array_intersect(list_col, [2, 3]) + 1)::INTEGER) AS total_intersect FROM test_table GROUP BY id HAVING total_intersect > 5;