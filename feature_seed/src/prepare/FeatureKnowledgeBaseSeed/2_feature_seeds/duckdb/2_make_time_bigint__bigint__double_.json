CREATE TABLE time_test (id INTEGER, hours BIGINT, minutes BIGINT, seconds DOUBLE);
INSERT INTO time_test VALUES (1, NULL, 30, 15.123456), (2, 12, 45, NULL), (3, 14, 15, 60.987654);
SELECT id, make_time(hours, minutes, seconds) AS time_val FROM time_test WHERE hours IS NOT NULL;
SELECT id, make_time(hours, minutes, seconds) AS time_val FROM time_test WHERE seconds < 30.0 AND minutes > 20;
SELECT id, xor(BIT_STRING('00000100'), BIT_STRING('00000001')) AS xor_result FROM time_test;
SELECT id, make_time(hours, minutes, seconds) AS time_val, xor(xor(BIT_STRING('111'), BIT_STRING('001')), BIT_STRING('100')) FROM time_test GROUP BY hours, minutes HAVING time_val IS NOT NULL;
SELECT id, make_time(hours, minutes, seconds) AS time_val FROM time_test WHERE xor(BIT_STRING('0101'), BIT_STRING(CAST(hours AS BITSTRING))) = BIT_STRING('0001');
WITH time_aggregation AS (SELECT hours, COUNT(*) AS count FROM time_test GROUP BY hours) SELECT make_time(hours, 0, 0) AS time_val, count FROM time_aggregation WHERE count > 1;
SELECT id, (SELECT make_time(hours, minutes, seconds) FROM time_test WHERE id = t.id) AS subquery_time FROM time_test t JOIN time_test t2 ON t.hours = t2.minutes WHERE t2.seconds IS NOT NULL;
SELECT id, make_time(hours, 60, 0) AS edge_case_time FROM time_test WHERE NOT (seconds = 0) ORDER BY edge_case_time DESC;