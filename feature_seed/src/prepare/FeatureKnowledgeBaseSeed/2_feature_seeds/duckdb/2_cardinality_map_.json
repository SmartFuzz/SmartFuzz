CREATE TABLE test_maps (id INTEGER, details MAP<STRING, INTEGER>);
INSERT INTO test_maps VALUES (1, map(['a', 'b'], [2, 4])), (2, map(['x', 'y'], [3, null])), (3, map([], []));
SELECT details, cardinality(details) AS size, (cardinality(details) >> 1) AS shifted_size FROM test_maps;
SELECT id, cardinality(details) AS size, (SELECT SUM(cardinality(details) >> 2) FROM test_maps WHERE id < outer.id) AS correlated_shifted FROM test_maps AS outer GROUP BY id HAVING size > 0;
CREATE TABLE test_join (user_id INTEGER, description STRING);
INSERT INTO test_join VALUES (1, 'Test 1'), (2, 'Test 2'), (3, NULL);
SELECT t1.id, t2.description, (cardinality(t1.details) >> 1) AS shifted_size FROM test_maps t1 LEFT JOIN test_join t2 ON cardinality(t1.details) = (CASE WHEN t1.id IS NOT NULL THEN 1 ELSE 0 END) WHERE t2.user_id IS NOT NULL;
SELECT id, details, cardinality(details) AS c, c::INTEGER + 1 AS incremented FROM test_maps WHERE c::INTEGER IS NOT NULL ORDER BY incremented;
SELECT COUNT(*) FROM test_maps WHERE cardinality(details) = 0 HAVING cardinality(details) >> 2 IS NULL;
DROP TABLE IF EXISTS temp_test;
CREATE TEMPORARY TABLE temp_test AS SELECT id, cardinality(details) AS map_size FROM test_maps;
SELECT * FROM temp_test WHERE map_size < (SELECT MAX(size) FROM (SELECT cardinality(details) AS size FROM test_maps) AS subquery);