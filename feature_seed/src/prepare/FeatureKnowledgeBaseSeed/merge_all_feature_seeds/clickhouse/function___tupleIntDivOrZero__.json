CREATE TABLE test_table (num Tuple(Int32, Int32, Int32), div Tuple(Int32, Int32, Int32));
INSERT INTO test_table VALUES ((5, 10, 15), (2, 3, 0));
SELECT tupleIntDivOrZero(num, div) FROM test_table;
INSERT INTO test_table VALUES ((25, 50, 75), (0, 0, 3));
SELECT tupleIntDivOrZero(num, div) FROM test_table;
INSERT INTO test_table VALUES ((10, 20), (0, 5));
SELECT tupleIntDivOrZero(num, div) FROM test_table;
INSERT INTO test_table VALUES ((7, 14, 21, 28), (1, 2, 0, 4));
SELECT tupleIntDivOrZero(num, div) FROM test_table;
WITH (SELECT tupleIntDivOrZero((100, 200), (0, 0))) AS result_tuple SELECT result_tuple;
WITH (SELECT num, div FROM test_table WHERE div.2 = 0) AS filtered_data SELECT tupleIntDivOrZero(filtered_data.num, filtered_data.div) FROM filtered_data;
CREATE TABLE second_table (a Tuple(Int32, Int32), b Tuple(Int32, Int32));
INSERT INTO second_table VALUES ((1, 2), (0, 0));
SELECT tupleIntDivOrZero((SELECT a FROM second_table), (SELECT b FROM second_table));
SELECT tupleIntDivOrZero((SELECT sum(num) FROM test_table), (SELECT count(div) FROM test_table));
CREATE TABLE mixed_table (n Tuple(Float32, Float32), d Tuple(Float32, Float32));
INSERT INTO mixed_table VALUES ((10.5, 20.5), (0.0, 2.0));
SELECT tupleIntDivOrZero((round(n.1), round(n.2)), (round(d.1), round(d.2))) FROM mixed_table;