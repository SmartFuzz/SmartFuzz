CREATE TABLE test_dates (date_string String);
INSERT INTO test_dates VALUES ('2023-05-01 10:00:00'), ('2022-12-30 13:44:17'), ('invalid-date'), ('');
SELECT toDateTimeOrZero(date_string) FROM test_dates;
SELECT toDateTimeOrZero(NULL) AS date_time, count(*) FROM test_dates;
SELECT date_string, toDateTimeOrZero(date_string) FROM test_dates ORDER BY date_string;
SELECT sum(toDateTimeOrZero(date_string)) FROM test_dates;
SELECT toDateTimeOrZero(substring(date_string, 1, 19)) AS parsed_date FROM test_dates;
CREATE TABLE test_results (result DateTime);
INSERT INTO test_results SELECT toDateTimeOrZero(date_string) FROM test_dates;
SELECT result, toDateTimeOrZero('2021-01-01') AS fixed_date FROM test_results WHERE result < toDateTimeOrZero('2023-01-01');
SELECT t.date_string, r.result FROM test_dates AS t JOIN test_results AS r ON toDateTimeOrZero(t.date_string) = r.result;
SELECT (SELECT count() FROM test_dates) AS total_dates, toDateTimeOrZero('2022-06-15 09:30:00') AS valid_date;
SELECT toDateTimeOrZero(CONCAT(date_string, ' 00:00:00')) AS extended_date FROM test_dates;
SELECT count(*) FROM (SELECT toDateTimeOrZero(date_string) FROM test_dates GROUP BY date_string) AS grouped_dates;