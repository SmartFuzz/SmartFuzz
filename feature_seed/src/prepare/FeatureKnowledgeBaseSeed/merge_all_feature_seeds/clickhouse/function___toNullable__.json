CREATE TABLE test_table (id Int32, value Int32);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, NULL);
SELECT toNullable(value) FROM test_table;
SELECT id, toNullable(value) AS nullable_value FROM test_table WHERE id > 1;
CREATE TABLE another_table (id Int32, description String);
INSERT INTO another_table VALUES (1, 'First'), (2, 'Second'), (3, 'Third');
SELECT a.id, a.description, toNullable(b.value) FROM another_table a LEFT JOIN test_table b ON a.id = b.id;
SELECT a.id, if(toNullable(b.value) IS NULL, 'No Value', toString(toNullable(b.value))) AS value_status FROM another_table a LEFT JOIN test_table b ON a.id = b.id;
SELECT toTypeName(toNullable(value)) FROM test_table;
SELECT id, toNullable(value) AS nullable_value FROM (SELECT id, value FROM test_table WHERE value IS NOT NULL ORDER BY id);
SELECT toNullable(AVG(value)) AS average_value FROM test_table;
CREATE TABLE nullable_test (id Int32, value Nullable(Int32));
INSERT INTO nullable_test VALUES (1, NULL), (2, 25), (3, 35);
SELECT id, coalesce(value, 0) AS value_filled FROM nullable_test;
SELECT id, value, toNullable(value) AS n_value FROM nullable_test WHERE n_value IS NOT NULL ORDER BY id;
SELECT a.id, COUNT(toNullable(b.value)) FROM another_table a JOIN test_table b ON a.id = b.id GROUP BY a.id;