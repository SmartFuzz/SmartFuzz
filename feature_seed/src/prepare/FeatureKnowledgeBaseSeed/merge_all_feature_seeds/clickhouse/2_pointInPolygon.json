CREATE TABLE polygons (id Int32, vertices Array(Tuple(Float64, Float64)) NOT NULL) ENGINE = MergeTree() ORDER BY id;
INSERT INTO polygons VALUES (1, [(0, 0), (5, 0), (5, 5), (0, 5)]), (2, [(1, 1), (2, 4), (3, 1), (1, 1)]);
SELECT id, pointInPolygon((3, 3), vertices) AS is_inside FROM polygons WHERE pointInPolygon((3, 3), vertices) = 1;
SELECT id, multiIf(pointInPolygon((3.5, 3.5), vertices) = 1, 'Inside', 'Outside') AS position FROM polygons;
CREATE TABLE test_points (id Int32, point Tuple(Float64, Float64)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_points VALUES (1, (2.5, 2.5)), (2, (6, 6)), (3, (1, 1));
SELECT tp.id, multiIf(is_inside = 1, 'Inside', 0) AS res FROM (SELECT id, pointInPolygon(tp.point, p.vertices) AS is_inside FROM test_points tp JOIN polygons p ON 1=1) AS subquery;
SELECT p.id, count(*) AS inside_count FROM polygons p JOIN test_points tp ON pointInPolygon(tp.point, p.vertices) = 1 GROUP BY p.id HAVING inside_count > 0;
SELECT count(*) AS total_inside FROM test_points WHERE pointInPolygon(point, (SELECT vertices FROM polygons WHERE id = 1)) = 1;
SELECT id, pointInPolygon((NULL, NULL), vertices) AS is_inside FROM polygons;
SELECT p.id, transform(pointInPolygon((10, 10), p.vertices), [0, 1], [1, 0], 0) FROM polygons p WHERE pointInPolygon((10, 10), p.vertices) IS NOT NULL;