CREATE TABLE timestamps_test (date_col Date, time_col String);
INSERT INTO timestamps_test VALUES ('2023-12-31', '12:00:00.11');
INSERT INTO timestamps_test VALUES ('2023-01-01', '00:00:00');
INSERT INTO timestamps_test VALUES ('2023-06-15', '23:59:59');
SELECT timestamp(date_col) AS ts FROM timestamps_test;
SELECT timestamp(date_col, time_col) AS ts FROM timestamps_test;
SELECT timestamp('2023-12-31 23:59:59', '00:00:01') AS ts;
SELECT * FROM (SELECT timestamp(date_col, '12:00:00') AS ts FROM timestamps_test) AS nested_query WHERE ts >= '2023-01-01 12:00:00';
SELECT ts, COUNT(*) FROM (SELECT timestamp(date_col) AS ts FROM timestamps_test) AS derived_table GROUP BY ts ORDER BY ts DESC;
CREATE TABLE additional_timestamps_test (date_col Date, duration String);
INSERT INTO additional_timestamps_test VALUES ('2023-12-31', '1 day 2 hours 3 minutes 4 seconds');
SELECT timestamp(date_col) + INTERVAL 1 DAY AS new_date FROM additional_timestamps_test;
SELECT timestamp('2023-12-31 12:00:00', '12:00:00.11') AS ts, COUNT(*) FROM timestamps_test GROUP BY ts;
SELECT t1.date_col, t2.time_col, timestamp(t1.date_col, t2.time_col) AS combined_timestamp FROM timestamps_test AS t1 JOIN timestamps_test AS t2 ON t1.date_col = t2.date_col WHERE timestamp(t1.date_col) > '2023-06-01';
SELECT timestamp('2023-03-01', '5:13:00') - timestamp('2023-02-28', '5:13:00') AS difference_in_seconds;