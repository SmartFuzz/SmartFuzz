CREATE TABLE complex_data (id UInt64, name String, value Float64, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO complex_data VALUES (1, 'alpha', 3.14, toDateTime('2023-01-01 01:00:00')), (2, 'beta', NULL, toDateTime('2023-01-02 01:00:00')), (3, 'gamma', 2.71, NULL), (4, 'delta', 1.41, toDateTime('2023-01-04 01:00:00'));
SELECT id, name LIKE 'alpha%' AS is_alpha FROM complex_data WHERE created_at IS NOT NULL;
SELECT id, generate_series(1, MAX(CASE WHEN value IS NOT NULL THEN id ELSE 0 END)) AS series FROM complex_data GROUP BY id;
SELECT id, AVG(value) AS avg_value FROM complex_data GROUP BY id HAVING avg_value > 1.0;
SELECT id, (SELECT count() FROM complex_data WHERE value LIKE '%1%') as count_like FROM complex_data;
SELECT id, count() OVER (PARTITION BY name LIKE 'g%') AS count_partition FROM complex_data ORDER BY count_partition DESC;
SELECT id, generate_series(0, (SELECT MAX(value) FROM complex_data WHERE value IS NOT NULL), 0.5) AS series FROM complex_data HAVING series LIKE '%.5';
SELECT name, (SELECT COUNT(*) FROM generate_series(1, 10) WHERE number LIKE '1%') AS count_match FROM complex_data ORDER BY count_match DESC;
SELECT id, COUNT(*) FROM complex_data WHERE value IS NOT NULL GROUP BY id HAVING id LIKE '1%' OR id LIKE '2%';