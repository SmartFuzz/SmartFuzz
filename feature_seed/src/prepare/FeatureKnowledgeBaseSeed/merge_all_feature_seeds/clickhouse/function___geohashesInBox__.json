CREATE TABLE geohash_test (longitude FLOAT64, latitude FLOAT64, precision UInt8);
INSERT INTO geohash_test VALUES (24.48, 40.56, 4), (24.785, 40.81, 4);
SELECT geohashesInBox(longitude, latitude, 24.785, 40.81, precision) FROM geohash_test;
SELECT geohashesInBox(-180, -90, 180, 90, 5) AS geohashes;
SELECT geohashesInBox(24.48, 40.56, 24.785, 40.81, 1) AS geohashes;
SELECT geohashesInBox(24.48, 40.56, 24.785, 40.81, 12) AS geohashes;
SELECT geohashesInBox(24.48, 40.56, 24.785, 40.81, 4) FROM (SELECT longitude, latitude, precision FROM geohash_test);
WITH (SELECT longitude, latitude FROM geohash_test) AS coordinates SELECT geohashesInBox(arrayJoin(coordinates), 24.785, 40.81, 4) AS geohashes;
SELECT DISTINCT geohashesInBox(-73.0, 40.0, -72.0, 41.0, 5) FROM geohash_test WHERE latitude > 39;
SELECT geohashesInBox(longitude_min, latitude_min, longitude_max, latitude_max, precision) FROM (SELECT -180 AS longitude_min, -90 AS latitude_min, 180 AS longitude_max, 90 AS latitude_max, 5 AS precision);
SELECT geohashesInBox(-179.999, -89.999, 179.999, 89.999, 6) AS geohashes WHERE NOT (longitude_min >= longitude_max OR latitude_min >= latitude_max);
SELECT count(geohashesInBox(24.48, 40.56, 24.785, 40.81, 4)) FROM geohash_test HAVING count > 0;
SELECT geohashesInBox(30.0, 40.0, 30.1, 40.1, 4) UNION ALL SELECT geohashesInBox(30.1, 40.1, 30.2, 40.2, 4);
SELECT geohashesInBox(0, 0, 0, 0, 4) AS geohashes WHERE length(geohashes) = 0;
SELECT geohashesInBox(24.48, 40.56, 24.785, 40.81, 4) AS geohashes ORDER BY geohashes LIMIT 10;