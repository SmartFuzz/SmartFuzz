CREATE TABLE test_points (id Int32, point_string String);
INSERT INTO test_points VALUES (1, 'POINT (1.2 3.4)');
INSERT INTO test_points VALUES (2, 'POINT (0.0 0.0)');
INSERT INTO test_points VALUES (3, 'POINT (-1.5 -2.3)');
INSERT INTO test_points VALUES (4, 'POINT (Infinity Infinity)');
INSERT INTO test_points VALUES (5, 'POINT (-Infinity -Infinity)');
INSERT INTO test_points VALUES (6, 'POINT (NaN NaN)');
SELECT readWKTPoint(point_string) FROM test_points WHERE id = 1;
SELECT readWKTPoint(point_string) AS point FROM test_points WHERE id IN (2, 3);
SELECT t.id, readWKTPoint(t.point_string) AS point FROM test_points t ORDER BY t.id;
SELECT DISTINCT readWKTPoint(point_string) FROM test_points;
CREATE TABLE test_points_join (id Int32, point_string String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_points_join VALUES (1, 'POINT (4.0 5.0)'), (2, 'POINT (6.1 7.2)');
SELECT a.id, readWKTPoint(a.point_string) AS a_point, readWKTPoint(b.point_string) AS b_point FROM test_points a JOIN test_points_join b ON a.id = b.id;
WITH (SELECT readWKTPoint('POINT (8.8 9.9)')) AS new_point SELECT * FROM test_points WHERE readWKTPoint(point_string) != new_point;