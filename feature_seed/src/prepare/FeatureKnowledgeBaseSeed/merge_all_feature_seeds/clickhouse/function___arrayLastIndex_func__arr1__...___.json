CREATE TABLE test_arrays (id UInt32, values Array(Int32));
INSERT INTO test_arrays VALUES (1, [1, 2, 3, 4, 5]), (2, [5, 4, 3, 2, 1]), (3, [0, 0, 0, 0]);
SELECT arrayLastIndex(x -> x > 3, values) FROM test_arrays;
SELECT arrayLastIndex(x -> x < 2, values) FROM test_arrays WHERE id = 1;
SELECT id, arrayLastIndex(x -> x % 2 = 0, values) AS last_even_index FROM test_arrays;
SELECT id, arrayLastIndex(x -> x = 3, values) AS last_three_index FROM test_arrays WHERE id IN (1, 2);
WITH (SELECT values FROM test_arrays WHERE id = 1) AS arr_data SELECT arrayLastIndex(x -> x >= 2, arr_data) AS last_index FROM test_arrays WHERE id = 1;
WITH (SELECT arrayJoin(values) AS v FROM test_arrays WHERE id = 2) AS expanded_values SELECT arrayLastIndex(x -> x < 3, arrayJoin((SELECT values FROM test_arrays WHERE id = 2))) AS last_less_than_three FROM test_arrays;
SELECT id, arrayLastIndex(x -> x < 0, values) AS last_negative_index FROM test_arrays GROUP BY id;
WITH (SELECT arrayDistinct(values) FROM test_arrays) AS distinct_arr SELECT arrayLastIndex(x -> x = 1, distinct_arr) FROM test_arrays;