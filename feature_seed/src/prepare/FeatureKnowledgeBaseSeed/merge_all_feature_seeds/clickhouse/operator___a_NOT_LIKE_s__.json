CREATE TABLE test_table (id UInt32, name String);
INSERT INTO test_table VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');
SELECT * FROM test_table WHERE name NOT LIKE 'A%';
SELECT * FROM test_table WHERE name NOT LIKE 'C%';
SELECT id FROM test_table WHERE name NOT LIKE 'A%' AND id < 3;
CREATE TABLE test_table2 (id UInt32, description String);
INSERT INTO test_table2 VALUES (1, 'One'), (2, 'Two'), (3, 'Three');
SELECT a.id FROM test_table a JOIN test_table2 b ON a.id = b.id WHERE b.description NOT LIKE 'T%';
SELECT * FROM test_table WHERE EXISTS (SELECT 1 FROM test_table2 WHERE test_table.id = test_table2.id AND description NOT LIKE 'F%');
SELECT name FROM (SELECT id, name FROM test_table WHERE id NOT IN (SELECT id FROM test_table2 WHERE description NOT LIKE 'O%'));
SELECT id, name FROM test_table WHERE name NOT LIKE '%o%' OR id NOT IN (SELECT id FROM test_table2 WHERE description LIKE '%h%');