CREATE TABLE test_strings (id UInt32, haystack String, needle String);
INSERT INTO test_strings VALUES (1, 'abcdefghijklmnopqrstuvwxyz', 'abc'), (2, 'HELLOWORLD', 'hello'), (3, 'SQLFUNCTION', 'FUN'), (4, '', 'test'), (5, 'NULLEXAMPLE', NULL);
SELECT id, hasSubsequenceCaseInsensitive(haystack, needle) AS has_subsequence FROM test_strings WHERE hasSubsequenceCaseInsensitive(haystack, needle) >= 1;
SELECT id FROM test_strings WHERE hasSubsequenceCaseInsensitive(haystack, 'x') >= 0 AND haystack IS NOT NULL;
SELECT id, COUNT(*) AS cnt FROM test_strings GROUP BY hasSubsequenceCaseInsensitive(haystack, needle) HAVING cnt >= 1;
CREATE TABLE test_numbers (num UInt8, str_value String);
INSERT INTO test_numbers VALUES (1, 'Test1'), (2, 'example'), (255, 'borderline');
SELECT t1.id, t2.num FROM test_strings t1 JOIN test_numbers t2 ON hasSubsequenceCaseInsensitive(t1.haystack, t2.str_value) >= 1 WHERE t1.id <= t2.num;
SELECT id, hasSubsequenceCaseInsensitive(haystack, needle) AS res FROM test_strings WHERE res >= 1 UNION ALL SELECT id FROM test_strings WHERE haystack = '';
SELECT haystack FROM test_strings WHERE haystack IS NOT NULL AND hasSubsequenceCaseInsensitive(haystack, 'Xyz') >= 1 ORDER BY hasSubsequenceCaseInsensitive(haystack, 'Xyz') DESC;
SELECT id, hasSubsequenceCaseInsensitive(haystack, needle) AS result FROM test_strings ORDER BY result, id;