CREATE TABLE test_dates (date_strings Array(String));
INSERT INTO test_dates VALUES (['2021-12-05', '12:50:00']);
SELECT arrayStringConcat(date_strings) AS DateString FROM test_dates;
INSERT INTO test_dates VALUES (['2021-12-06', '13:00:00']);
SELECT arrayStringConcat(date_strings, ' | ') AS DateString FROM test_dates;
CREATE TABLE test_composite (id Int32, date_strings Array(String));
INSERT INTO test_composite VALUES (1, ['2021-12-05', '12:50:00']), (2, ['2021-12-06', '13:00:00']);
SELECT id, arrayStringConcat(date_strings, ', ') AS DateString FROM test_composite;
CREATE TABLE test_nested (arr Array(Array(String)));
INSERT INTO test_nested VALUES ([['2021-12-05', '12:50:00'], ['2021-12-06', '13:00:00']]);
SELECT arrayStringConcat(arrayJoin(arr), ' | ') AS DateString FROM test_nested;
CREATE TABLE test_multiple (id Int32, arr1 Array(String), arr2 Array(String));
INSERT INTO test_multiple VALUES (1, ['One', 'Two'], ['Three', 'Four']);
SELECT id, arrayStringConcat(arr1, ', ') || ' and ' || arrayStringConcat(arr2, ', ') AS CombinedStrings FROM test_multiple;
CREATE TABLE test_join (id Int32, arr Array(String));
INSERT INTO test_join VALUES (1, ['A', 'B']), (2, ['C', 'D']);
SELECT j.id, arrayStringConcat(arr, ' - ') AS ConcatStrings, (SELECT COUNT(*) FROM test_join WHERE id = j.id) AS Count FROM test_join AS j;
CREATE TABLE test_empty (arr Array(String));
INSERT INTO test_empty VALUES (['']);
SELECT arrayStringConcat(arr) AS Concatenated FROM test_empty;
CREATE TABLE test_default_sep (arr Array(String));
INSERT INTO test_default_sep VALUES (['Hello', 'World']);
SELECT arrayStringConcat(arr) AS DefaultSeparator FROM test_default_sep;
SELECT arrayStringConcat(arr, NULL) AS NullSeparator FROM test_default_sep;