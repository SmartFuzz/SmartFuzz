CREATE TABLE test_strings (text String);
INSERT INTO test_strings VALUES ('ClickHouse® is a column-oriented database management system (DBMS) for online analytical processing of queries (OLAP).');
INSERT INTO test_strings VALUES ('ClickHouse is fast and scalable.');
INSERT INTO test_strings VALUES ('This is a test string for simhash functionality.');
INSERT INTO test_strings VALUES ('CLICKHOUSE IS NOT THE SAME AS CLICKHOUSE®');
INSERT INTO test_strings VALUES ('Same content but different casing');
INSERT INTO test_strings VALUES ('Partially duplicate string for detection.');
SELECT wordShingleSimHashUTF8(text, 1) AS simhash_1 FROM test_strings;
SELECT wordShingleSimHashUTF8(text, 2) AS simhash_2 FROM test_strings;
SELECT wordShingleSimHashUTF8(text, 3) AS simhash_default FROM test_strings;
SELECT wordShingleSimHashUTF8(text, 25) AS simhash_max FROM test_strings;
SELECT a.text AS string_a, b.text AS string_b, bitHammingDistance(wordShingleSimHashUTF8(a.text, 3), wordShingleSimHashUTF8(b.text, 3)) AS hamming_distance FROM test_strings a, test_strings b WHERE a.text != b.text;
SELECT COUNT(*) FROM test_strings WHERE wordShingleSimHashUTF8(text, 3) = wordShingleSimHashUTF8((SELECT text FROM test_strings LIMIT 1), 3);
SELECT wordShingleSimHashUTF8(text, 3) FROM (SELECT text FROM test_strings WHERE text LIKE '%string%') AS filtered_strings;
SELECT SUM(CASE WHEN wordShingleSimHashUTF8(text, 3) IS NULL THEN 1 ELSE 0 END) FROM test_strings;