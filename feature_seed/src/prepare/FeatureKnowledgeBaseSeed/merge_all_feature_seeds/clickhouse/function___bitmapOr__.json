CREATE TABLE bitmaps_test (id UInt32, bm Bitmap);
INSERT INTO bitmaps_test VALUES (1, bitmapBuild([1, 2, 3])), (2, bitmapBuild([3, 4, 5]));
SELECT bitmapToArray(bitmapOr(bm, bitmapBuild([6, 7]))) AS res FROM bitmaps_test WHERE id = 1;
SELECT bitmapToArray(bitmapOr(bitmapBuild([1, 2]), bitmapBuild([]))) AS res;
SELECT bitmapToArray(bitmapOr(bitmapBuild([]), bitmapBuild([3, 4, 5]))) AS res;
SELECT bitmapToArray(bitmapOr(bitmapBuild([1, 2, 3]), bitmapOr(bitmapBuild([3, 4]), bitmapBuild([5])))) AS res;
SELECT bitmapToArray(bitmapOr(bitmapOr(bitmapBuild([1, 2]), bitmapBuild([2, 3])), bitmapBuild([4, 5]))) AS res;
CREATE TABLE bitmap_data (user_id UInt32, action Bitmap);
INSERT INTO bitmap_data VALUES (1, bitmapBuild([1, 2])), (2, bitmapBuild([2, 3]));
SELECT bitmapToArray(bitmapOr(action, bitmapBuild([1, 3]))) AS res FROM bitmap_data WHERE user_id = 2;
SELECT bitmapToArray(bitmapOr((SELECT action FROM bitmap_data WHERE user_id = 1), (SELECT action FROM bitmap_data WHERE user_id = 2))) AS res;
CREATE TABLE another_bitmap_test (category UInt32, bitmap_value Bitmap);
INSERT INTO another_bitmap_test VALUES (1, bitmapBuild([5, 6])), (2, bitmapBuild([7, 8]));
SELECT bitmapToArray(bitmapOr(a.bitmap_value, b.bitmap_value)) AS combined_bm FROM another_bitmap_test a JOIN another_bitmap_test b ON a.category = b.category WHERE a.category = 1;
SELECT bitmapToArray(bitmapOr(bitmapBuild([10, 11]), bitmapOr(bitmapBuild([12]), bitmapBuild([10])))) AS res;
SELECT bitmapToArray(bitmapOr(bitmapBuild([1]), bitmapBuild([2, 3]))) AS res;