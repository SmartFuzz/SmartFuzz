CREATE TABLE test_dates (id Int32, start_date DateTime64(3), end_date DateTime64(3));
INSERT INTO test_dates VALUES (1, toDateTime64('2023-01-01 00:00:01', 3), toDateTime64('2023-01-01 00:00:05', 3)), (2, toDateTime64('2023-01-01 00:00:10', 3), toDateTime64('2023-01-01 00:00:00', 3));
SELECT id, timeDiff(start_date, end_date) AS duration FROM test_dates WHERE duration <= 5;
SELECT id, timeDiff(start_date, end_date) AS duration FROM test_dates WHERE timeDiff(start_date, end_date) IS NOT NULL;
CREATE TABLE secondary_dates (id Int32, compare_date DateTime64(3));
INSERT INTO secondary_dates VALUES (1, toDateTime64('2023-01-01 00:00:03', 3)), (2, toDateTime64('2023-01-01 00:00:12', 3));
SELECT d.id, timeDiff(d.start_date, d.end_date) AS duration FROM test_dates d JOIN secondary_dates s ON s.compare_date <= d.start_date;
SELECT d.id, timeDiff(d.start_date, d.end_date) AS duration FROM test_dates d WHERE EXISTS (SELECT 1 FROM secondary_dates s WHERE s.compare_date <= d.start_date);
WITH time_dif AS (SELECT id, timeDiff(start_date, end_date) AS duration FROM test_dates) SELECT id FROM time_dif HAVING duration <= 5;
CREATE TABLE extreme_dates (id Int32, extreme_date DateTime64(7) DEFAULT '1970-01-01 00:00:00');
INSERT INTO extreme_dates (id, extreme_date) VALUES (3, toDateTime64('9999-12-31 23:59:59.9999999', 7)), (4, toDateTime64('1970-01-01 00:00:00', 7));
SELECT e.id, timeDiff(e.extreme_date, toDateTime64('1970-01-01 00:00:00', 7)) AS diff FROM extreme_dates e WHERE e.extreme_date <= toDateTime64('2023-01-01 00:00:00', 7);