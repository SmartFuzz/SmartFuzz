CREATE TABLE test_strings (id UInt32, text String);
INSERT INTO test_strings VALUES (1, 'hello world'), (2, 'welcome to the multiMatchAnyIndex function'), (3, 'testing with various patterns'), (4, 'another example of multiMatchAnyIndex');
SELECT multiMatchAnyIndex(text, ['hello', 'world']) FROM test_strings;
SELECT multiMatchAnyIndex(text, ['example', 'function']) FROM test_strings;
SELECT multiMatchAnyIndex(text, ['to', 'with']) FROM test_strings WHERE id < 4;
SELECT id, multiMatchAnyIndex(text, ['test', 'testing']) AS match_index FROM test_strings WHERE match_index IS NOT NULL;
CREATE TABLE another_table (id UInt32, description String);
INSERT INTO another_table VALUES (1, 'This is a test'), (2, 'Testing with multiMatchAnyIndex'), (3, 'another test');
SELECT id, description, multiMatchAnyIndex(description, ['test', 'TODO']) AS match_index FROM another_table WHERE match_index IS NOT NULL;
SELECT a.id, a.text, b.description FROM test_strings AS a JOIN another_table AS b ON multiMatchAnyIndex(a.text, ['example', 'another']) > 0;
SELECT multiMatchAnyIndex(text, ['multiMatchAnyIndex', 'index']) FROM test_strings WHERE id IN (SELECT id FROM another_table WHERE description LIKE '%test%');
SELECT id, multiMatchAnyIndex(text, ['multiMatchAnyIndex', 'function']) AS match_index FROM test_strings ORDER BY match_index DESC;