CREATE TABLE test_dates (id UInt32, event_date String, value Int32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_dates (id, event_date, value) VALUES (1, '1899-01-01', 100), (2, '', 200), (3, '2023-10-01', NULL);
SELECT id, toDate32OrZero(event_date) AS converted_date, value FROM test_dates WHERE toDate32OrZero(event_date) <> toDate32OrZero('') ORDER BY id;
SELECT id, COUNT(*) AS cnt FROM (SELECT id, toDate32OrZero(event_date) AS converted_date FROM test_dates GROUP BY id, event_date) GROUP BY id HAVING cnt <> 1;
SELECT id, AVG(value) AS avg_value FROM test_dates WHERE toDate32OrZero(event_date) <> toDate32OrZero('2023-12-31') GROUP BY id;
SELECT id, toDate32OrZero(MAX(event_date)) AS max_date FROM (SELECT id, event_date FROM test_dates WHERE value <> 100) GROUP BY id;
SELECT id, toDate32OrZero(event_date) AS date_check FROM test_dates WHERE value IS NULL AND date_check <> toDate32OrZero('invalid_date');
SELECT id, toDate32OrZero(NULL) AS null_date FROM test_dates WHERE null_date <> toDate32OrZero('2000-01-01');
WITH (SELECT toDate32OrZero(event_date) AS min_date FROM test_dates) AS dates SELECT id FROM test_dates WHERE toDate32OrZero(event_date) <> min_date;
CREATE TABLE temp_dates AS SELECT id, toDate32OrZero(event_date) AS date_converted FROM test_dates WHERE value IS NOT NULL;
SELECT t1.id, t1.date_converted FROM temp_dates t1 JOIN temp_dates t2 ON t1.id <> t2.id WHERE t1.date_converted <> t2.date_converted;