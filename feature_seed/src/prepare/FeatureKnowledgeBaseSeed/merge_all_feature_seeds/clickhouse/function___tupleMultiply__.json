CREATE TABLE tuples_table (a Tuple(Int32, Int32), b Tuple(Int32, Int32));
INSERT INTO tuples_table VALUES ((1, 2), (2, 3));
SELECT tupleMultiply(a, b) FROM tuples_table;
SELECT tupleMultiply((10, 20), (5, 3));
SELECT tupleMultiply((0, 5), (5, 0));
SELECT tupleMultiply((NULL, 3), (10, 2));
CREATE TABLE test_table AS SELECT (1, 2) AS a, (3, 4) AS b;
SELECT tupleMultiply(a, b) FROM test_table;
SELECT tupleMultiply((1, 0, -1), (1, 2, 3));
SELECT tupleMultiply((25, 30), (4, 5)) AS product;
WITH (SELECT (2, 4) AS t1, (3, 8) AS t2) AS tuples FROM tuples_table SELECT tupleMultiply(t1, t2);
SELECT tupleMultiply((1, 2, 3), (4, 5, 6));
INSERT INTO tuples_table VALUES ((-1, -2), (2, 3));
SELECT tupleMultiply((2147483647, 1), (1, 2147483647));
SELECT tupleMultiply(a, b) FROM (SELECT (1, 2) AS a, (2, 3) AS b) as temp;
SELECT tupleMultiply((1, 2, 3, 4), (2, 3, 4, 5)) FROM tuples_table;
SELECT tupleMultiply((1.5, 2.5), (3.0, 4.0));
CREATE TABLE another_test_table AS SELECT (4, 5) AS c, (6, 7) AS d;
SELECT tupleMultiply(c, d) FROM another_test_table;
SELECT tupleMultiply((NULL, NULL), (1, 2));
SELECT tupleMultiply((1, 2), (NULL, 2));