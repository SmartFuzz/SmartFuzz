CREATE TABLE settings_example (id UInt32, file_path String) ENGINE = File('CSV', '/tmp/settings_example.csv');
INSERT INTO settings_example VALUES (1, '/tmp/settings_example_1.csv'), (2, '/tmp/settings_example_2.csv');
CREATE TABLE test_files (id UInt32, filename String) ENGINE = File('CSV', '/tmp/test_files.csv');
INSERT INTO test_files VALUES (1, 'data_file_1.csv'), (2, 'data_file_2.csv');
SELECT * FROM settings_example WHERE id IN (SELECT id FROM test_files WHERE filename = 'data_file_1.csv');
SELECT id, file_path FROM settings_example WHERE id NOT IN (SELECT id FROM test_files WHERE filename LIKE 'data_file_%');
CREATE TABLE settings_logs AS SELECT * FROM settings_example WHERE id = 1;
SELECT COUNT() AS total_files FROM test_files WHERE filename LIKE 'data_file_%';
SELECT id, file_path, count() OVER (PARTITION BY file_path) AS duplicate_count FROM settings_example;
SELECT id, filename FROM test_files WHERE filename IN (SELECT file_path FROM settings_example WHERE id = 1);
CREATE TABLE temp_log AS SELECT id, file_path FROM settings_example WHERE id = (SELECT min(id) FROM settings_example);
SELECT * FROM settings_example WHERE file_path = (SELECT file_path FROM settings_example LIMIT 1 OFFSET 0);
SELECT DISTINCT file_path FROM settings_example WHERE file_path NOT IN (SELECT filename FROM test_files);
CREATE TEMPORARY TABLE temp_settings AS SELECT * FROM settings_example ORDER BY file_path LIMIT 5;
INSERT INTO temp_settings SELECT id, CONCAT(file_path, '_backup') FROM settings_example WHERE file_path IS NOT NULL;
SELECT id, file_path FROM temp_settings WHERE file_path LIKE '%backup%';