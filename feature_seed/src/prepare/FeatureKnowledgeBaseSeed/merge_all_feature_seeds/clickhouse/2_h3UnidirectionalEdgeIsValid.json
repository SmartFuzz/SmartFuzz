CREATE TABLE h3_data (id UInt64, edge_index UInt64, created_at DateTime DEFAULT now());
INSERT INTO h3_data (id, edge_index) VALUES (1, 1248204388774707199), (2, 1248204388774707198), (3, 0), (4, NULL);
SELECT id, h3UnidirectionalEdgeIsValid(edge_index) AS is_valid FROM h3_data WHERE edge_index IS NOT NULL;
SELECT id, EXTRACT(MONTH FROM created_at) AS month_created FROM h3_data WHERE edge_index > 0;
SELECT id, h3UnidirectionalEdgeIsValid(edge_index) AS is_valid, EXTRACT(DAY FROM created_at) FROM h3_data HAVING is_valid = 1;
SELECT id, edge_index, h3UnidirectionalEdgeIsValid(edge_index) AS is_valid FROM h3_data WHERE id IN (SELECT id FROM h3_data WHERE h3UnidirectionalEdgeIsValid(edge_index) = 1) ORDER BY EXTRACT(YEAR FROM created_at);
CREATE TABLE temp_edge_data (temp_index UInt64);
INSERT INTO temp_edge_data (temp_index) SELECT edge_index FROM h3_data WHERE edge_index IS NOT NULL;
SELECT COUNT(*) FROM (SELECT temp_index, h3UnidirectionalEdgeIsValid(temp_index) FROM temp_edge_data WHERE temp_index IS NOT NULL GROUP BY temp_index HAVING h3UnidirectionalEdgeIsValid(temp_index) = 1) AS valid_edges;
SELECT h3UnidirectionalEdgeIsValid(CAST(1234567890123456789 AS UInt64)) AS valid_cast;
SELECT id, EXTRACT(DAY FROM toDate('2023-01-01')) AS extraction_day, h3UnidirectionalEdgeIsValid(CAST(CONCAT('12345', '6789') AS UInt64)) AS valid_concat FROM h3_data WHERE edge_index IS NOT NULL ORDER BY extraction_day;