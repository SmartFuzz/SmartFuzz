CREATE TABLE test_dates (id UInt32, event_date DateTime, secondary_date DateTime64(3) DEFAULT now());
INSERT INTO test_dates VALUES (1, '2023-01-01 00:00:00', '2023-01-01 00:00:00.000'), (2, NULL, '2023-06-15 15:30:00.123'), (3, '2022-12-31 23:59:59', NULL);
SELECT id, toDayOfYear(event_date) AS day_of_year FROM test_dates WHERE event_date NOT IN (SELECT secondary_date FROM test_dates WHERE secondary_date IS NOT NULL);
SELECT id, COUNT(*) AS event_count FROM test_dates GROUP BY NOT IN(toDayOfYear(event_date), (SELECT toDayOfYear(secondary_date) FROM test_dates)) HAVING event_count > 1;
SELECT id, (toDayOfYear(event_date) - toDayOfYear(NULL)) AS day_diff FROM test_dates HAVING day_diff NOT IN (1, 2, 3);
SELECT id, toDayOfYear(toDateTime('2023-04-21 10:20:30')) AS day_of_year FROM test_dates WHERE event_date NOT IN ('2023-01-01', '2023-01-02') AND toDayOfYear(event_date) NOT IN (select toDayOfYear(event_date) from test_dates where event_date IS NOT NULL) ORDER BY day_of_year;
DROP TABLE IF EXISTS test_dates;