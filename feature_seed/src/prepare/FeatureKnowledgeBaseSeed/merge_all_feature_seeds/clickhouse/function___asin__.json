CREATE TABLE test_asin (value Float64);
INSERT INTO test_asin VALUES (0), (0.5), (1), (-1), (0.999999999), (-0.999999999), (1.0), (-1.0);
SELECT value, asin(value) AS asin_value FROM test_asin;
SELECT asin(value) FROM (SELECT value FROM test_asin WHERE value BETWEEN -1 AND 1);
CREATE TABLE test_asin_complex (id UInt32, value Float64);
INSERT INTO test_asin_complex VALUES (1, 0.5), (2, 1), (3, -0.5), (4, 0.999999), (5, -0.999999);
SELECT id, asin(value) AS asin_value FROM test_asin_complex WHERE value != 0;
SELECT asin(value + (SELECT AVG(value) FROM test_asin_complex)) FROM (SELECT value FROM test_asin_complex);
CREATE TABLE join_table (id UInt32, join_value Float64);
INSERT INTO join_table VALUES (1, 0.1), (2, 0.3), (3, 0.5);
SELECT t.id, asin(t.value) AS asin_value, j.join_value FROM test_asin_complex t JOIN join_table j ON t.id = j.id WHERE t.value BETWEEN -1 AND 1;
SELECT DISTINCT asin(value) OVER (PARTITION BY value ORDER BY id) AS asin_partitioned FROM test_asin_complex;