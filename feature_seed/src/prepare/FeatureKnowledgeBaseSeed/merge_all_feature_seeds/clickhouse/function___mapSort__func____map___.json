CREATE TABLE test_map (id Int32, data Map(String, Int32));
INSERT INTO test_map VALUES (1, map('a', 3, 'b', 1, 'c', 2));
SELECT mapSort(map('b', 5, 'c', 1, 'a', 3)) AS sorted_map FROM test_map;
SELECT mapSort((k, v) -> v, map('b', 5, 'c', 1, 'a', 3)) AS sorted_map FROM test_map;
CREATE TABLE nested_test AS SELECT map('key1', 2, 'key2', 1) AS my_map;
SELECT id, mapSort((k, v) -> k, my_map) AS sorted_keys FROM nested_test;
SELECT id, mapSort((k, v) -> v * -1, map('key3', 1, 'key4', 4, 'key5', 2)) AS reverse_sorted_map FROM nested_test;
WITH (SELECT map('name', 'Alice', 'age', 30, 'city', 'Wonderland')) AS temp_map SELECT mapSort((k, v) -> v, temp_map) AS sorted_temp_map;
SELECT id, mapSort((k, v) -> k, map('z', 2, 'x', 5, 'y', 1)) AS multi_layer_sorted FROM test_map WHERE id = 1;
CREATE TABLE multi_map_test AS SELECT map('keyA', 3, 'keyB', 6) AS my_map1, map('keyC', 1, 'keyD', 4) AS my_map2;
SELECT mapSort((k, v) -> v, my_map1) AS sorted_map1, mapSort((k, v) -> v, my_map2) AS sorted_map2 FROM multi_map_test;