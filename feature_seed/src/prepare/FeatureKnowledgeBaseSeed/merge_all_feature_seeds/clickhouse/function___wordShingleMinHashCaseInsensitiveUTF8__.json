CREATE TABLE test_strings (id UInt32, content String);
INSERT INTO test_strings VALUES (1, 'ClickHouse® is a column-oriented database management system (DBMS) for online analytical processing of queries (OLAP).');
INSERT INTO test_strings VALUES (2, 'clickhouse Is A column-oriented DataBase management system for online Analytical Processing Of Queries.');
INSERT INTO test_strings VALUES (3, 'Clickhouse is a data warehouse solution optimized for queries.');
SELECT wordShingleMinHashCaseInsensitiveUTF8(content, 3, 6) AS hash_values FROM test_strings WHERE id = 1;
SELECT id, wordShingleMinHashCaseInsensitiveUTF8(content, 5, 10) AS hash_values FROM test_strings;
SELECT wordShingleMinHashCaseInsensitiveUTF8(content) AS default_hash FROM test_strings WHERE id = 2;
SELECT wordShingleMinHashCaseInsensitiveUTF8(content, 1, 1) AS hash_values FROM test_strings WHERE id = 3;
WITH (SELECT content FROM test_strings WHERE id = 1) AS case1, (SELECT content FROM test_strings WHERE id = 2) AS case2 SELECT wordShingleMinHashCaseInsensitiveUTF8(case1, 4, 8) AS hash_case1, wordShingleMinHashCaseInsensitiveUTF8(case2, 4, 8) AS hash_case2;
CREATE TABLE hash_results (id UInt32, min_hash UInt64, max_hash UInt64);
INSERT INTO hash_results SELECT id, tupleElement(wordShingleMinHashCaseInsensitiveUTF8(content), 1), tupleElement(wordShingleMinHashCaseInsensitiveUTF8(content), 2) FROM test_strings;
SELECT t1.id, h.min_hash, h.max_hash FROM test_strings AS t1 JOIN hash_results AS h ON t1.id = h.id;
SELECT MIN(min_hash), MAX(max_hash) FROM hash_results;