CREATE TABLE sales(    `id` UInt32,    `amount` Float64) ENGINE = Log;
INSERT INTO sales VALUES (1, 100.50), (2, 250.75), (3, 125.25);
SELECT sum(amount) FROM sales;
CREATE TABLE departments(    `id` UInt32,    `name` String) ENGINE = Log;
INSERT INTO departments VALUES (1, 'Sales'), (2, 'Engineering');
CREATE TABLE employee_details(    `employee_id` UInt32,    `department_id` UInt32,    `salary` UInt32) ENGINE = Log;
INSERT INTO employee_details VALUES (1, 1, 75000), (2, 2, 90000), (3, 1, 50000);
SELECT sum(s.salary) FROM employee_details s JOIN departments d ON s.department_id = d.id WHERE d.name = 'Sales';
SELECT (SELECT sum(amount) FROM sales) + (SELECT sum(salary) FROM employee_details) AS total_sum;
CREATE TABLE yearly_bonuses(    `employee_id` UInt32,    `bonus` Float64) ENGINE = Log;
INSERT INTO yearly_bonuses VALUES (1, 5000.50), (2, 7000.75), (3, 2500.25);
SELECT sum(b.bonus) + (SELECT sum(salary) FROM employee_details) AS total_remuneration FROM yearly_bonuses b;
SELECT sum(amount) FROM sales WHERE amount > 200;
CREATE TABLE test_table(    `value` Decimal(10, 2)) ENGINE = Log;
INSERT INTO test_table VALUES (100.50), (200.75), (300.00);
SELECT sum(value) FROM test_table;
CREATE TABLE complex_test(    `category` String,    `price` Float64,    `quantity` UInt32) ENGINE = Log;
INSERT INTO complex_test VALUES ('A', 19.99, 3), ('B', 9.99, 5), ('A', 29.99, 2), ('C', 49.99, 1);
SELECT sum(price * quantity) FROM complex_test WHERE category = 'A';
CREATE TABLE temp_sales(    `id` UInt32,    `amount` Float64,    `date` Date) ENGINE = Memory;
INSERT INTO temp_sales VALUES (1, 100.00, '2023-10-01'), (2, 200.00, '2023-10-02'), (3, 150.00, '2023-10-03');
SELECT sum(amount) OVER (ORDER BY date) AS cumulative_sum FROM temp_sales;
CREATE TABLE monthly_expenses(    `id` UInt32,    `value` UInt32) ENGINE = Log;
INSERT INTO monthly_expenses VALUES (1, 3000), (2, 4000), (3, 2500);
SELECT sum(value) FROM monthly_expenses WHERE id IN (SELECT id FROM (SELECT id FROM monthly_expenses WHERE value > 2000) AS subquery) GROUP BY id;