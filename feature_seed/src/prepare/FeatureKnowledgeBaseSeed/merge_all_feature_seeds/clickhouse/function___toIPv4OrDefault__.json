CREATE TABLE ip_test (ip_address String);
INSERT INTO ip_test VALUES ('192.168.1.1'), ('300.300.300.300'), ('::1'), ('1.1.1.1');
SELECT toIPv4OrDefault(ip_address) AS ipv4_result FROM ip_test;
SELECT toIPv4OrDefault(ip_address, '0.0.0.0') AS ipv4_with_default FROM ip_test;
WITH '::ffff:192.168.1.1' AS valid_ip_string SELECT toIPv4OrDefault(valid_ip_string) AS valid_ip;
WITH 'fe80::1' AS invalid_ip_string SELECT toIPv4OrDefault(invalid_ip_string, '0.0.0.0') AS default_ip;
CREATE TABLE ip_defaults (default_ip String);
INSERT INTO ip_defaults VALUES ('10.0.0.1'), ('20.0.0.1');
SELECT toIPv4OrDefault(ip_address, (SELECT default_ip FROM ip_defaults ORDER BY default_ip LIMIT 1)) AS resolved_ip FROM ip_test;
SELECT toIPv4OrDefault(ip_address) AS ip_check, 'Valid' AS status FROM ip_test WHERE ip_check != '0.0.0.0';
WITH (SELECT ip_address FROM ip_test WHERE ip_address = '192.168.1.1') AS selected_ip SELECT toIPv4OrDefault(selected_ip) AS verified_ip;