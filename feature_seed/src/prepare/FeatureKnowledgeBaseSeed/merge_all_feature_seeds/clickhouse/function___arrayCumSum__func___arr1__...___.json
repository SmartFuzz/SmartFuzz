CREATE TABLE test_table (id UInt32, values Array(Int32));
INSERT INTO test_table VALUES (1, [1, 2, 3]), (2, [4, 5, 6]), (3, [7, 8, 9]);
SELECT arrayCumSum(values) AS running_sum FROM test_table WHERE id = 1;
SELECT arrayCumSum(values) AS running_sum FROM test_table WHERE id > 1;
SELECT arrayCumSum([]) AS running_sum FROM test_table;
SELECT arrayCumSum([1, 1, 1, 1, 1]) AS running_sum;
SELECT arrayCumSum([MAX(values)]) AS max_running_sum FROM test_table;
SELECT arrayCumSum(arrayJoin(values)) AS flat_running_sum FROM test_table;
SELECT arrayCumSum(plus) AS total_sum FROM (SELECT arrayJoin(values) AS plus FROM test_table);
SELECT id, arrayCumSum(values) AS running_sum FROM test_table GROUP BY id;
CREATE TABLE another_table (a Int32, b Float64);
INSERT INTO another_table VALUES (1, 1.5), (2, 2.5), (3, 3.5);
SELECT arrayCumSum([values[i] + another_table.b] FROM test_table CROSS JOIN another_table WHERE test_table.id = another_table.a) AS complex_running_sum;
SELECT arrayCumSum(arrayMap(x -> x * 2, values)) AS mapped_running_sum FROM test_table WHERE id = 1;
SELECT arrayCumSum(arraySlice(values, 1, 2)) AS sliced_running_sum FROM test_table WHERE id = 2;
WITH (SELECT arrayAvg(values) FROM test_table) AS avg_val SELECT arrayCumSum([avg_val, avg_val + 2]) AS avg_running_sum;