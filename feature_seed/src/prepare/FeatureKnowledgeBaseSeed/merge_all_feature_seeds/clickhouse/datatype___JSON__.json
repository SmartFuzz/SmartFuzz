CREATE TABLE json_test (data JSON(max_dynamic_paths=5, max_dynamic_types=10)) ENGINE = Memory;
INSERT INTO json_test VALUES (parseJson('{"a": {"b": 1, "c": [2, 3, 4]}, "d": {"e": 5}}'));
INSERT INTO json_test VALUES (parseJson('{"f": {"g": 6}, "h": "hello"}'));
INSERT INTO json_test VALUES (parseJson('{"i": {"j": {"k": 7, "l": 8}}, "m": ["n", "o"]}'));
SELECT data, data.a.b, data.d.e FROM json_test;
SELECT JSONDynamicPaths(data) FROM json_test;
SELECT JSONSharedDataPaths(data) FROM json_test;
CREATE TABLE nested_json_test (json JSON) ENGINE = Memory;
INSERT INTO nested_json_test VALUES (parseJson('{"x": {"y": {"z": [1, 2, 3]}, "w": 4}}'));
SELECT json.x.y.z[0] AS first_value FROM nested_json_test;
SELECT json.x.w, json.x.y.z[1] FROM nested_json_test WHERE json.x.y.z[0] = 1;
CREATE TABLE test (json JSON(a.b UInt32, a.d SKIP a.c, SKIP REGEXP '.*e.*')) ENGINE = Memory;
INSERT INTO test VALUES (parseJson('{"a": {"b": 10, "c": 20, "d": 30}, "f": 40}'));
INSERT INTO test VALUES (parseJson('{"a": {"b": 11, "e": 50}}'));
INSERT INTO test VALUES (parseJson('{"a": {"b": 12}, "h": 60}'));
SELECT json.a.b, json.a.d, json.h FROM test;
SELECT * FROM test WHERE json.h IS NOT NULL;
SELECT JSONDynamicPaths(json) FROM test;
CREATE TABLE array_json_test (json JSON) ENGINE = Memory;
INSERT INTO array_json_test VALUES (parseJson('{"arr": [1, 2, {"nested": 3}]}'));
SELECT json.arr[0] AS first_element, json.arr[2].nested AS nested_value FROM array_json_test;
INSERT INTO array_json_test VALUES (parseJson('{"arr": [{"a": 10}, {"b": 20}]}'));
SELECT json.arr[1].b FROM array_json_test;
SELECT json.arr, JSONAllPathsWithTypes(json) FROM array_json_test;
CREATE TABLE complex_json (json_data JSON) ENGINE = Memory;
INSERT INTO complex_json VALUES (parseJson('{"id": 1, "details": {"name": "John", "age": 30, "address": {"city": "New York", "zip": 10001}}}'));
INSERT INTO complex_json VALUES (parseJson('{"id": 2, "details": {"name": "Jane", "age": 25}}'));
SELECT json_data.details.name, json_data.details.address.city FROM complex_json WHERE json_data.id = 1;
SELECT JSONDynamicPaths(json_data) FROM complex_json;
CREATE TABLE json_count (data JSON) ENGINE = Memory;
INSERT INTO json_count VALUES (parseJson('{"count": [1, 2, 3, 4]}'));
SELECT count(json_count.data.count) AS total_count FROM json_count;
SELECT sumIf(value, json_length(data.count) > 2) AS sum_if FROM json_count HAVING total_count > 3;