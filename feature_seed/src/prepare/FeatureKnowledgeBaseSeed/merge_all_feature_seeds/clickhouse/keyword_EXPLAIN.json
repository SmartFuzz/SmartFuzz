CREATE TABLE test_table (id UInt32, name String, age UInt8) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE nested_subquery_table (id UInt32, parent_id UInt32, value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'Alice', 30), (2, 'Bob', 25), (3, 'Charlie', 35);
INSERT INTO nested_subquery_table VALUES (1, NULL, 1.0), (2, 1, 2.0), (3, 1, 3.0);
EXPLAIN SELECT name FROM test_table WHERE age > (SELECT AVG(age) FROM test_table);
EXPLAIN SELECT t1.name, t2.value FROM test_table AS t1 JOIN nested_subquery_table AS t2 ON t1.id = t2.parent_id;
EXPLAIN SELECT id, count(*) FROM test_table GROUP BY id HAVING count(*) > 1;
EXPLAIN SELECT * FROM test_table ARRAY JOIN age;
EXPLAIN SELECT id, name FROM test_table WHERE id IN (SELECT parent_id FROM nested_subquery_table WHERE value > 1.0);
EXPLAIN SELECT id, sum(value) FROM nested_subquery_table GROUP BY id ORDER BY sum(value) DESC;