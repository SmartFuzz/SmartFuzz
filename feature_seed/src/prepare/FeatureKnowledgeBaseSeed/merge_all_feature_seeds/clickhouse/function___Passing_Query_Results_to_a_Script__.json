CREATE TABLE hackernews (id UInt64, comment String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO hackernews (id, comment) VALUES (1, 'Hello World'), (2, 'ClickHouse is great'), (3, 'Testing query results'), (4, 'Fuzz testing Example'), (5, 'Another comment');
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE id > 0 AND comment != '' LIMIT 5));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE comment LIKE '%test%' LIMIT 10));
CREATE TABLE other_comments (id UInt64, comment String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO other_comments (id, comment) VALUES (6, 'Some other comment'), (7, 'Testing test cases'), (8, 'Fuzzy queries should be checked');
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT hc.id, hc.comment FROM hackernews AS hc JOIN other_comments AS oc ON hc.id = oc.id WHERE hc.id < 5));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE id IN (SELECT id FROM other_comments)));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE LENGTH(comment) > 10 AND id < 4));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE comment != '' ORDER BY id DESC LIMIT 2));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE id > 2));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT id, comment FROM hackernews WHERE RegexMatch(comment, 'fuzzy|test|other')));
SELECT * FROM executable('sentiment.py', TabSeparated, 'id UInt64, sentiment Float32', (SELECT hc.id, hc.comment FROM hackernews AS hc LEFT JOIN other_comments AS oc ON hc.id = oc.id WHERE oc.id IS NULL));