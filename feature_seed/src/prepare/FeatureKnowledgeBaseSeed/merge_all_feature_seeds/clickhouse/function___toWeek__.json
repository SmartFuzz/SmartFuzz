CREATE TABLE test_dates (date Date, week_number UInt8);
INSERT INTO test_dates VALUES ('2016-12-27', toWeek('2016-12-27')), ('2016-12-31', toWeek('2016-12-31')), ('2020-01-01', toWeek('2020-01-01')), ('2021-01-03', toWeek('2021-01-03')), ('2021-01-04', toWeek('2021-01-04'));
SELECT date, week_number FROM test_dates WHERE week_number = toWeek(date, 1);
SELECT date, toWeek(date, 0) AS week0, toWeek(date, 1) AS week1, toWeek(date, 2) AS week2 FROM test_dates;
SELECT date, toWeek(date, 3) AS iso_week FROM test_dates WHERE date >= '2020-01-01' AND date <= '2020-01-07';
CREATE TABLE temp_dates AS SELECT toDate('2021-01-01') AS start_date, toDate('2021-12-31') AS end_date;
SELECT start_date, end_date, toWeek(end_date, 0) AS end_week, toWeek(start_date, 0) AS start_week FROM temp_dates;
SELECT date, toWeek(date, 4) AS week4 FROM test_dates WHERE week_number = 0;
SELECT date, toWeek(date, 5) AS week5, COUNT(*) FROM test_dates GROUP BY week5 HAVING week5 > 1;
SELECT date, toWeek(date,9) FROM test_dates WHERE toWeek(date, 0) <> toWeek(date, 6);
SELECT t1.date, t1.week_number, t2.date AS comparison_date FROM test_dates AS t1 JOIN test_dates AS t2 ON toWeek(t1.date) = toWeek(t2.date, 1) WHERE t1.date < t2.date;
SELECT date FROM test_dates WHERE toWeek(date, 2) IN (SELECT toWeek(date, 1) FROM test_dates WHERE date < '2021-01-01');