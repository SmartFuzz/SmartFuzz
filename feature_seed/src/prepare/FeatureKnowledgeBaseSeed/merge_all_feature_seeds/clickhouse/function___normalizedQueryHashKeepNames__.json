CREATE TABLE test_table_1 (id UInt32, name String, value Float64);
INSERT INTO test_table_1 VALUES (1, 'test_1', 10.5), (2, 'test_2', 20.8), (3, 'test_3', 30.1);
SELECT normalizedQueryHashKeepNames('SELECT id AS `id_alias` FROM test_table_1') AS hash_value_1;
SELECT normalizedQueryHashKeepNames('SELECT name AS `name alias` FROM test_table_1 WHERE value > 15') AS hash_value_2;
SELECT normalizedQueryHashKeepNames('SELECT id AS `xyz123`, value AS `value_alias` FROM test_table_1 WHERE value < 25') AS hash_value_3;
SELECT normalizedQueryHashKeepNames('SELECT (SELECT COUNT(*) FROM test_table_1) AS `count_subquery`') AS hash_value_4;
CREATE TABLE test_table_2 (id UInt32, foreign_id UInt32);
INSERT INTO test_table_2 VALUES (1, 1), (2, 2);
SELECT normalizedQueryHashKeepNames('SELECT t1.id AS `primary_id`, t2.foreign_id AS `foreign_id_alias` FROM test_table_1 AS t1 JOIN test_table_2 AS t2 ON t1.id = t2.foreign_id') AS hash_value_5;
SELECT normalizedQueryHashKeepNames('SELECT id AS `a_value`, SUM(value) AS `total_value` FROM test_table_1 GROUP BY id') AS hash_value_6;
SELECT normalizedQueryHashKeepNames('SELECT id AS `uuid_36_bytes` FROM test_table_1 WHERE id = 3 AND value > 25') AS hash_value_7;
SELECT normalizedQueryHashKeepNames('SELECT id AS `long_alias_name_for_count`, COUNT(*) FROM test_table_1 GROUP BY id HAVING COUNT(*) > 1') AS hash_value_8;
SELECT normalizedQueryHashKeepNames('SELECT DISTINCT value AS `1_value`, (SELECT MAX(value) FROM test_table_1) AS `max_value` FROM test_table_1') AS hash_value_9;
SELECT normalizedQueryHashKeepNames('SELECT t1.name AS `name`, (SELECT AVG(value) FROM test_table_1 WHERE value < 20) AS `avg_value` FROM test_table_1 AS t1') AS hash_value_10;