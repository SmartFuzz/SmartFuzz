CREATE TABLE entropy_test1 (`vals` UInt32, `strings` String) ENGINE = Memory;
INSERT INTO entropy_test1 VALUES (1, 'A'), (1, 'A'), (1, 'A'), (1, 'A'), (2, 'B'), (2, 'B'), (2, 'C'), (2, 'D');
SELECT entropy(vals), entropy(strings) FROM entropy_test1;
CREATE TABLE entropy_test2 (`vals` UInt32) ENGINE = Memory;
INSERT INTO entropy_test2 VALUES (1), (2), (3), (4);
SELECT entropy(vals) FROM entropy_test2;
CREATE TABLE entropy_test3 (`vals` UInt32, `category` String) ENGINE = Memory;
INSERT INTO entropy_test3 VALUES (1, 'A'), (1, 'A'), (2, 'B'), (2, 'B'), (3, 'B');
SELECT ENTROPY(vals), ENTROPY(category) FROM entropy_test3 GROUP BY category;
CREATE TABLE entropy_test4 (`id` UInt32, `value` String) ENGINE = Memory;
INSERT INTO entropy_test4 VALUES (1, 'apple'), (2, 'banana'), (3, 'apple'), (4, 'orange');
SELECT id, entropy(value) FROM (SELECT * FROM entropy_test4) AS subquery GROUP BY id;
CREATE TABLE entropy_test5 (`data` Array(UInt32)) ENGINE = Memory;
INSERT INTO entropy_test5 VALUES ([1, 2, 2, 3, 4]), ([1, 1, 1, 1, 5]);
SELECT entropy(arrayJoin(data)) FROM entropy_test5;
CREATE TABLE entropy_test6 (`src` UInt32, `dst` UInt32) ENGINE = Memory;
INSERT INTO entropy_test6 VALUES (1, 2), (2, 2), (2, 3), (3, 3);
SELECT e1.entropy, e2.entropy FROM (SELECT entropy(src) AS entropy FROM entropy_test6) AS e1, (SELECT entropy(dst) AS entropy FROM entropy_test6) AS e2;
CREATE TABLE entropy_test7 (`key` String, `value` UInt32) ENGINE = Memory;
INSERT INTO entropy_test7 VALUES ('x', 1), ('y', 2), ('x', 1), ('z', 3);
SELECT key, entropy(value) FROM entropy_test7 GROUP BY key WITH TOTALS;