CREATE TABLE test_table (id UInt32, value DateTime, number Float64, text String) ENGINE = Memory;
INSERT INTO test_table VALUES (1, CAST('2018-01-01 01:02:03' AS DateTime), 10.5, 'test1'), (2, CAST(NULL AS DateTime), 20.25, 'test2'), (3, CAST('2019-01-01 01:02:03' AS DateTime), NULL, 'test3'), (4, CAST('2023-08-01 01:02:03' AS DateTime), 0.1, NULL);
SELECT toColumnTypeName(number / value) FROM test_table WHERE value IS NOT NULL;
SELECT a.id, toColumnTypeName((SELECT AVG(number) FROM test_table WHERE number IS NOT NULL) / a.value) AS average_type FROM test_table AS a;
SELECT id, toColumnTypeName(CAST(NULL AS String) / number) FROM test_table WHERE number IS NOT NULL;
SELECT id, toColumnTypeName(CAST(text AS DateTime) / (number + 1)) AS division_type FROM test_table WHERE text != '' AND number IS NOT NULL;
CREATE TABLE temp_results AS SELECT id, text FROM test_table WHERE value IS NOT NULL;
INSERT INTO temp_results SELECT id, text FROM test_table WHERE value < '2020-01-01 00:00:00';
SELECT id, toColumnTypeName(number / NULL) AS division_with_null FROM temp_results;
SELECT id, toColumnTypeName(value / CAST('1' AS Float64)) AS division_float FROM temp_results WHERE text IS NOT NULL;