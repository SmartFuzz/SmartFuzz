CREATE TABLE my_intervals (start UInt32, end UInt32) ENGINE = MergeTree ORDER BY tuple();
INSERT INTO my_intervals VALUES (1, 5), (2, 6), (7, 8), (3, 7), (NULL, 10), (0, 4), (5, NULL);
SELECT maxIntersections(start, end) FROM my_intervals WHERE start IS NOT NULL OR end IS NOT NULL;
SELECT a, maxIntersections(start, end) FROM my_intervals GROUP BY (CASE WHEN start > 3 OR end < 6 THEN 1 ELSE 0 END);
SELECT count(*) AS total, maxIntersections(start, end) FROM (SELECT start, end FROM my_intervals WHERE start IS NOT NULL OR end IS NOT NULL GROUP BY start, end) AS grouped HAVING total > 2;
CREATE TEMPORARY TABLE temp_intervals AS SELECT start, end FROM my_intervals WHERE NOT (start BETWEEN 1 AND 2 OR end BETWEEN 7 AND 8);
SELECT maxIntersections(start, end) FROM temp_intervals WHERE start IS NOT NULL OR (end IS NOT NULL AND end > start);
SELECT maxIntersections(start, end) FROM my_intervals WHERE start = 1 OR end > 3 OR (start IS NOT NULL AND end IS NULL);
SELECT start, maxIntersections(start, end) FROM (SELECT start, end FROM my_intervals WHERE end IS NOT NULL) AS valid_intervals GROUP BY start HAVING maxIntersections(start, end) > 1;
CREATE TABLE my_events_extended (start Nullable(UInt32), end Nullable(UInt32)) ENGINE = MergeTree ORDER BY tuple();
INSERT INTO my_events_extended VALUES (1, 3), (NULL, 6), (2, 5), (3, NULL), (0, 4), (5, 7);
SELECT maxIntersections(start, end) FROM my_events_extended WHERE (start IS NULL OR end IS NULL) OR (start > 0 OR end IS NOT NULL);