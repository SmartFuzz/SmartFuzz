CREATE TABLE test_table (number UInt8);
INSERT INTO test_table VALUES (0), (1), (2), (3), (4), (5);
SELECT if(number = 0, 'zero', 'non-zero') AS result FROM test_table;
SELECT if(number > 2, 'greater than 2', '2 or less') AS complexity FROM test_table;
SELECT if(number = 0, 0, intDiv(42, number)) AS safe_division FROM test_table;
SELECT if(number % 2 = 0, 'even', 'odd') AS parity FROM test_table;
CREATE TABLE another_table (value UInt8);
INSERT INTO another_table VALUES (10), (20), (30);
SELECT if(t1.number > t2.value, 't1 is greater', 't2 is greater') AS compare FROM test_table t1, another_table t2;
SELECT if(number > 3, (SELECT COUNT(*) FROM another_table), 0) AS count_based_on_condition FROM test_table;
SELECT if(number = 4, (SELECT max(value) FROM another_table), (SELECT min(value) FROM another_table)) AS conditional_selection FROM test_table;
SELECT if(number IN (1, 2, 3), 'in range', 'out of range') AS range_check FROM test_table;
CREATE TABLE final_table (category String, score UInt8);
INSERT INTO final_table VALUES ('A', 85), ('B', 70), ('C', 50);
SELECT category, if(score >= 75, 'pass', 'fail') AS grade FROM final_table;