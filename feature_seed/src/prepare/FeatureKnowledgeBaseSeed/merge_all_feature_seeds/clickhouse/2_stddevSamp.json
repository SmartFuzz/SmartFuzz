CREATE TABLE test_data (population UInt8, group_key UInt8) ENGINE = Log;
INSERT INTO test_data VALUES (3, 1), (3, 1), (3, 2), (4, 2), (4, 1), (5, 1), (5, 2), (7, 2), (11, 1), (15, 2);
SELECT group_key, stddevSamp(population) FROM (SELECT group_key, stddevSamp(population) AS stddev FROM test_data GROUP BY group_key HAVING stddev > 1) AS temp_table;
SELECT stddevSamp(tuple(population, group_key)) FROM test_data WHERE group_key IN (SELECT DISTINCT group_key FROM test_data WHERE population > 4);
CREATE TABLE test_agg (value Float64, nullable_val Nullable(Float64)) ENGINE = Log;
INSERT INTO test_agg VALUES (1.5, NULL), (2.5, 2.0), (3.0, NULL), (4.5, 5.0);
SELECT stddevSamp(value) FROM (SELECT value, stddevSamp(nullable_val) AS stdev FROM test_agg GROUP BY value HAVING value > 2);
CREATE TABLE test_types (int_val Int32, float_val Float64, str_val String) ENGINE = Log;
INSERT INTO test_types VALUES (1, 1.5, '1'), (2, 2.5, '2.5'), (3, 3.5, NULL), (4, 4.5, 'invalid');
SELECT stddevSamp(int_val + CAST(str_val AS Float64)) FROM test_types WHERE str_val IS NOT NULL ORDER BY int_val;
SELECT group_key, stddevSamp(population) FROM test_data GROUP BY group_key HAVING stddevSamp(population) < 10 ORDER BY stddevSamp(population) DESC;