CREATE TABLE test_table_a (id UInt32, value String);
CREATE TABLE test_table_b (id UInt32, ref_id UInt32);
INSERT INTO test_table_a VALUES (1, 'apple'), (2, 'banana'), (3, 'cherry');
INSERT INTO test_table_b VALUES (1, 1), (2, 2), (3, 3);
SELECT * FROM test_table_a WHERE id GLOBAL IN (SELECT ref_id FROM test_table_b);
SELECT value FROM test_table_a WHERE id GLOBAL IN (SELECT ref_id FROM test_table_b WHERE ref_id <= 2);
SELECT value FROM test_table_a WHERE id GLOBAL IN (SELECT ref_id FROM test_table_b WHERE ref_id IN (1, 2));
SELECT a.value FROM test_table_a AS a INNER JOIN test_table_b AS b ON a.id = b.ref_id WHERE a.id GLOBAL IN (1, 2);
SELECT * FROM test_table_a WHERE value GLOBAL IN (SELECT value FROM test_table_a WHERE id < 3);
SELECT COUNT(*) FROM test_table_a WHERE id GLOBAL IN (SELECT id FROM (SELECT ref_id AS id FROM test_table_b));
WITH temp_ids AS (SELECT ref_id FROM test_table_b WHERE ref_id > 1) SELECT value FROM test_table_a WHERE id GLOBAL IN (SELECT id FROM temp_ids);
SELECT value FROM (SELECT DISTINCT value FROM test_table_a) AS unique_values WHERE id GLOBAL IN (1, 2);
WITH temp AS (SELECT ref_id FROM test_table_b WHERE ref_id < 3) SELECT COUNT(*) FROM test_table_a WHERE id GLOBAL IN (SELECT * FROM temp);