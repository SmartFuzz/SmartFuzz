CREATE TABLE test_tuples (id UInt32, values Tuple(x Float32, y Float32));
INSERT INTO test_tuples VALUES (1, (4.0, 8.0));
INSERT INTO test_tuples VALUES (2, (10.0, 20.0));
INSERT INTO test_tuples VALUES (3, (5.0, 15.0));
SELECT tupleDivideByNumber(values, 2) FROM test_tuples WHERE id = 1;
SELECT tupleDivideByNumber(values, 0.5) FROM test_tuples WHERE id = 2;
SELECT tupleDivideByNumber(values, 0) FROM test_tuples WHERE id = 3;
SELECT id, tupleDivideByNumber(values, 2) AS divided FROM test_tuples;
SELECT id, tupleDivideByNumber(values, x) AS divided FROM test_tuples, (SELECT 2 AS x);
SELECT id, tupleDivideByNumber(values, 0.01) AS divided FROM test_tuples WHERE id IN (SELECT id FROM test_tuples WHERE values.1 > 5);
SELECT id, tupleDivideByNumber(values, 1) AS divided, tupleDivideByNumber(values, 2) AS half_divided FROM test_tuples;
WITH (SELECT 4.0 AS divider) AS d SELECT id, tupleDivideByNumber(values, d.divider) AS divided FROM test_tuples;
CREATE TABLE test_join (id UInt32, fk UInt32, value Tuple(a Float32, b Float32));
INSERT INTO test_join VALUES (1, 1, (8.0, 16.0));
INSERT INTO test_join VALUES (2, 2, (50.0, 100.0));
SELECT tj.id, tupleDivideByNumber(t.values, tj.value.1) AS divided_values FROM test_tuples AS t JOIN test_join AS tj ON t.id = tj.fk;
SELECT id, tupleDivideByNumber(tupleDivideByNumber(values, 4), 2) AS quarter_divided FROM test_tuples;
SELECT tupleDivideByNumber((1, 2, 3, 4), 2);
SELECT tupleDivideByNumber((1.5, 3.0, 4.5), 0.3) AS divided FROM test_tuples;
SELECT tupleDivideByNumber((0, 0, 0), 0) AS divided_zeros;
SELECT tupleDivideByNumber((NULL, 5.0), 1) AS divided_null;