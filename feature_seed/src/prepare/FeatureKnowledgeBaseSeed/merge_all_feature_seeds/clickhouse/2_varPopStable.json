DROP TABLE IF EXISTS test_data;
CREATE TABLE test_data(x UInt8, y String) ENGINE = Memory;
INSERT INTO test_data VALUES (3, 'Three'), (4, 'Four'), (5, 'Five'), (3, 'three'), (7, NULL);
SELECT varPopStable(x) AS var_pop_stable FROM test_data WHERE y ILIKE 'three';
DROP TABLE IF EXISTS complex_table;
CREATE TABLE complex_table(a Int32, b String, c Float64) ENGINE = Memory;
INSERT INTO complex_table VALUES (1, 'One'), (2, 'Two'), (2, 'two'), (3, NULL), (NULL, 'NULL');
SELECT varPopStable(a) AS variance, count(*) AS count FROM complex_table WHERE b ILIKE 'two' GROUP BY variance HAVING count > 1;
DROP TABLE IF EXISTS join_test;
CREATE TABLE join_test(id UInt8, value Float32) ENGINE = Memory;
INSERT INTO join_test VALUES (1, 1.5), (2, 3.5), (3, 6.5);
SELECT varPopStable(jt.value) AS variance, jt.id FROM join_test jt JOIN (SELECT id, value FROM join_test) AS jt2 ON jt.id = jt2.id WHERE jt2.value > 2.0;
DROP TABLE IF EXISTS fuzz_test;
CREATE TABLE fuzz_test(num UInt32, text String, decimal_val Decimal(10, 4)) ENGINE = Memory;
INSERT INTO fuzz_test VALUES (1, 'a'), (2, 'b'), (3, 'c'), (4, 'a!'), (5, 'b@'), (NULL, NULL);
SELECT varPopStable(num) AS pop_variance, text FROM fuzz_test WHERE text ILIKE CONCAT('%', 'A', '%') GROUP BY text HAVING pop_variance IS NOT NULL;
DROP TABLE IF EXISTS mixed_types;
CREATE TABLE mixed_types(col1 String, col2 Int64) ENGINE = Memory;
INSERT INTO mixed_types VALUES ('1', 1), ('2.5', 2), ('3', 3), (NULL, 4), ('', 0);
SELECT varPopStable(toUInt32(col1)) AS variance FROM mixed_types WHERE col1 ILIKE '2%';
DROP TABLE IF EXISTS array_test;
CREATE TABLE array_test(arr Array(Int32)) ENGINE = Memory;
INSERT INTO array_test VALUES ([1, 2, 3]), ([3, NULL, 4]), ([5, 5, 5]);
SELECT varPopStable(arrayJoin(arr)) AS variance FROM array_test WHERE arr[1] ILIKE '3';