CREATE TABLE test_dates (date_str String) ENGINE = Memory;
INSERT INTO test_dates VALUES ('2021-01-01'), ('2021-01-01 12:00:00'), ('2021-01-01 12:00:00.999'), ('2021-01-01 12:00:00.123456'), ('invalid date');
SELECT parseDateTime64BestEffort(date_str, 3) AS parsed_date, toTypeName(parsed_date) AS type FROM test_dates WHERE date_str != 'invalid date';
SELECT parseDateTime64BestEffort(date_str, 6) AS parsed_date, toTypeName(parsed_date) AS type FROM test_dates;
SELECT parseDateTime64BestEffort(date_str, 3, 'Europe/London') AS parsed_date, toTypeName(parsed_date) AS type FROM test_dates WHERE date_str LIKE '%-%';
SELECT a.date_str, b.date_str, parseDateTime64BestEffort(a.date_str, 3) AS parsed_date, parseDateTime64BestEffort(b.date_str, 3) AS parsed_date_b FROM test_dates AS a JOIN test_dates AS b ON a.date_str != b.date_str;
WITH (SELECT parseDateTime64BestEffort('2021-07-01 15:30:45.123456') AS dt) AS subquery SELECT toTypeName(dt) AS type FROM subquery;
SELECT parseDateTime64BestEffort(date_str, 6, 'America/New_York') AS parsed_date, toUnixTimestamp(parsed_date) AS unix_ts FROM test_dates WHERE date_str = '2021-01-01 12:00:00.999';
SELECT parseDateTime64BestEffort(date_str, 3) AS parsed_date FROM test_dates WHERE parsed_date IS NOT NULL;
CREATE TABLE dates_test (date_time DateTime64(6, 'UTC')) ENGINE = Memory;
INSERT INTO dates_test VALUES (parseDateTime64BestEffort('2022-01-01 00:00:00.123456', 6, 'UTC'));
SELECT toTypeName(date_time) AS type FROM dates_test;