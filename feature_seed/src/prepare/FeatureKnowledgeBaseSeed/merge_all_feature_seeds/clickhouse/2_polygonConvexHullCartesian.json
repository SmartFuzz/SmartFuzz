CREATE TABLE geo_shapes (id UInt32, shape String, area Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO geo_shapes VALUES (1, 'POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))', 25.0), (2, 'POLYGON((2 1, 3 3, 5 1, 3 0, 2 1))', 7.0);
CREATE TABLE temp_polygon_data AS SELECT wkt(polygonConvexHullCartesian([shape])) AS convex_hull FROM geo_shapes;
INSERT INTO temp_polygon_data SELECT shape FROM geo_shapes WHERE area != ANY (SELECT area FROM geo_shapes WHERE area > 20);
SELECT COUNT(*) FROM temp_polygon_data WHERE convex_hull != ANY (SELECT wkt(polygonConvexHullCartesian([[[(0., 0.), (0., 5.), (5., 5.), (5., 0.)]])])) AND convex_hull IS NOT NULL GROUP BY convex_hull HAVING COUNT(convex_hull) > 1;
SELECT DISTINCT convex_hull FROM temp_polygon_data HAVING convex_hull != ANY (SELECT MAX(convex_hull) FROM temp_polygon_data);
DROP TABLE temp_polygon_data;