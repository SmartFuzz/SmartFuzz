CREATE TABLE test_time (event_time DateTime) ENGINE = Memory;
INSERT INTO test_time VALUES (toDateTime('2023-04-21 10:20:30'));
INSERT INTO test_time VALUES (toDateTime('2023-04-21 10:20:59'));
INSERT INTO test_time VALUES (toDateTime('2023-04-21 10:21:00'));
INSERT INTO test_time VALUES (toDateTime('2023-04-21 10:21:30'));
SELECT toStartOfMinute(event_time) FROM test_time;
SELECT toStartOfMinute(toDateTime('2022-01-01 23:59:59')) AS start_minute;
SELECT toStartOfMinute(toDateTime64('2023-04-21 10:20:30.123456', 6)) AS start_minute_precise;
SELECT event_time, toStartOfMinute(event_time) FROM test_time WHERE event_time > '2023-04-21 10:20:00';
SELECT t1.event_time, toStartOfMinute(t1.event_time) FROM (SELECT event_time FROM test_time) AS t1;
SELECT toStartOfMinute(event_time) AS rounded_time, COUNT(*) FROM test_time GROUP BY rounded_time;
SELECT toStartOfMinute(toDateTime('2023-07-15 15:45:30')), toStartOfMinute(toDateTime64('2023-07-15 15:45:30.5000', 4));
CREATE TABLE test_time_extended AS SELECT event_time, toStartOfMinute(event_time) AS rounded_time FROM test_time;
SELECT rounded_time, COUNT(event_time) FROM test_time_extended GROUP BY rounded_time ORDER BY rounded_time ASC;
WITH (SELECT max(event_time) FROM test_time) AS max_time SELECT toStartOfMinute(max_time);
SELECT toStartOfMinute(toDateTime('2023-01-01 00:00:00')) AS first_minute_of_year;
SELECT toStartOfMinute(toDateTime64('2023-02-28 23:59:59.999999', 6)) AS last_minute_of_february;