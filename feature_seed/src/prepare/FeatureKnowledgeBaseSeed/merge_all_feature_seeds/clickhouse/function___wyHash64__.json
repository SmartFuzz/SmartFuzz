CREATE TABLE test_hashes (id UInt64, value String);
INSERT INTO test_hashes VALUES (1, 'ClickHouse'), (2, 'wyHash64'), (3, 'Boundary'), (4, ''), (5, NULL);
SELECT wyHash64(value) AS Hash FROM test_hashes WHERE value IS NOT NULL;
SELECT wyHash64(value) + id AS EnhancedHash FROM test_hashes;
SELECT id, wyHash64(value) AS Hash FROM test_hashes ORDER BY id DESC;
SELECT id, wyHash64(value) AS Hash FROM test_hashes WHERE id IN (1, 2, 3);
WITH (SELECT wyHash64(value) FROM test_hashes WHERE id = 1) AS firstHash SELECT wyHash64('Join' || firstHash) AS CombinedHash;
CREATE TABLE another_table (hash UInt64, description String);
INSERT INTO another_table (hash, description) SELECT wyHash64(value), value FROM test_hashes;
SELECT a.hash, a.description, b.Hash FROM another_table a JOIN (SELECT id, wyHash64(value) AS Hash FROM test_hashes) b ON a.hash = b.Hash;
SELECT count(*) FROM test_hashes WHERE wyHash64(value) = wyHash64('ClickHouse') AND value IS NOT NULL;
SELECT id, value, wyHash64(value) AS Hash FROM test_hashes WHERE value LIKE '%Hash%';
CREATE TEMPORARY TABLE temp_table AS SELECT wyHash64(value) AS TempHash FROM test_hashes;
SELECT TempHash FROM temp_table WHERE TempHash = (SELECT wyHash64('')) LIMIT 1;