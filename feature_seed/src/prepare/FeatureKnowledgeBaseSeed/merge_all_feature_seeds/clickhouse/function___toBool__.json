CREATE TABLE test_table (number UInt8, text String);
INSERT INTO test_table VALUES (1, 'true');
INSERT INTO test_table VALUES (0, 'false');
INSERT INTO test_table VALUES (3, 'FALSE');
INSERT INTO test_table VALUES (5, 'True');
INSERT INTO test_table VALUES (2, 'false');
SELECT toBool(number) FROM test_table;
SELECT toBool(text) FROM test_table;
SELECT toBool(toInt8(-1)) AS negative_to_bool;
SELECT toBool(toUInt8(0)) AS zero_to_bool;
SELECT toBool(toUInt8(255)) AS max_uint8_to_bool;
SELECT toBool(toFloat32(1.0)) AS float_to_bool;
SELECT toBool(toFloat32(0.0)) AS float_zero_to_bool;
SELECT toBool(toFloat32(1.01)) AS float_positive_to_bool;
SELECT toBool(toFloat64(-0.0001)) AS float_negative_to_bool;
SELECT toBool('TRue') AS string_case_insensitive_to_bool;
SELECT toBool('faLSe') AS string_case_insensitive_to_bool;
SELECT toBool(toUInt8(1)) AND toBool(toInt16(0)) AS complex_expression;
SELECT a.number, toBool(a.text) FROM test_table AS a JOIN test_table AS b ON a.number = b.number;
SELECT CASE WHEN toBool(number) THEN 'It is true' ELSE 'It is false' END FROM test_table;