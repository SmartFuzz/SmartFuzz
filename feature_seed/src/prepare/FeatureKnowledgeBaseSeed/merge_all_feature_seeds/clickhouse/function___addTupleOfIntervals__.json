CREATE TABLE test_dates (id Int32, event_date Date);
INSERT INTO test_dates VALUES (1, toDate('2018-01-01'));
INSERT INTO test_dates VALUES (2, toDate('2020-02-29'));
INSERT INTO test_dates VALUES (3, toDate('2023-03-31'));
SELECT id, addTupleOfIntervals(event_date, (INTERVAL 1 DAY, INTERVAL 1 MONTH, INTERVAL 1 YEAR)) as new_date FROM test_dates;
WITH toDate('2021-01-01') AS base_date SELECT addTupleOfIntervals(base_date, (INTERVAL 2 DAY, INTERVAL 1 MONTH, INTERVAL 6 MONTH)) AS new_date;
WITH (SELECT event_date FROM test_dates WHERE id = 1) AS subquery_date SELECT addTupleOfIntervals(subquery_date, (INTERVAL 1 YEAR, INTERVAL 3 MONTH)) AS updated_date;
WITH toDateTime('2018-01-01 00:00:00') AS base_datetime SELECT addTupleOfIntervals(base_datetime, (INTERVAL 10 HOUR, INTERVAL 30 MINUTE)) AS updated_datetime;
SELECT id, addTupleOfIntervals(event_date, (INTERVAL 1 DAY, INTERVAL 1 MONTH)) AS updated_date FROM test_dates WHERE id IN (1, 2);
WITH toDate('2023-01-01') AS start_date, (INTERVAL 1 DAY, INTERVAL 1 WEEK) AS intervals SELECT addTupleOfIntervals(start_date, intervals) AS future_date;
CREATE TABLE date_intervals (id Int32, start_date Date, intervals Tuple(Int32, Int32));
INSERT INTO date_intervals VALUES (1, toDate('2023-01-01'), (1, 2));
SELECT id, addTupleOfIntervals(start_date, (INTERVAL intervals.1 DAY, INTERVAL intervals.2 MONTH)) AS interval_added_date FROM date_intervals;