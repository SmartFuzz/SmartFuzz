CREATE TABLE s2_cells (cell_id UInt64);
INSERT INTO s2_cells VALUES (9926595209846587392), (9926594385212866560), (9926595209846587393);
SELECT s2CellsIntersect((SELECT cell_id FROM s2_cells WHERE cell_id = 9926595209846587392), (SELECT cell_id FROM s2_cells WHERE cell_id = 9926594385212866560)) AS intersect;
SELECT s2CellsIntersect(cell_id, 9926595209846587392) AS intersect FROM s2_cells;
SELECT cell_id, s2CellsIntersect(cell_id, 9926595209846587392) AS intersect FROM s2_cells WHERE cell_id != 9926595209846587392;
WITH (SELECT cell_id FROM s2_cells WHERE cell_id = 9926595209846587392) AS cell1, (SELECT cell_id FROM s2_cells WHERE cell_id = 9926594385212866560) AS cell2 SELECT s2CellsIntersect(cell1, cell2) AS intersect;
SELECT s2CellsIntersect(9926595209846587392, (SELECT MAX(cell_id) FROM s2_cells)) AS intersect;
SELECT s2CellsIntersect((SELECT MIN(cell_id) FROM s2_cells), (SELECT MAX(cell_id) FROM s2_cells)) AS intersect;
SELECT COUNT(*) FROM s2_cells WHERE s2CellsIntersect(cell_id, 9926595209846587392) = 1;
CREATE TABLE intersect_results AS SELECT s2CellsIntersect(a.cell_id, b.cell_id) AS intersect_result FROM s2_cells a JOIN s2_cells b ON a.cell_id != b.cell_id;