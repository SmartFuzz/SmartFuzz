CREATE TABLE test_table (value String);
INSERT INTO test_table VALUES ('-8'), ('abc'), ('128'), ('-129'), ('127'), ('3.14'), ('NaN'), ('Inf'), ('0xc0fe'), ('0b101010');
SELECT toInt8OrNull(value) FROM test_table;
SELECT value, toInt8OrNull(value) AS converted_value FROM test_table WHERE value NOT LIKE 'abc';
SELECT value FROM test_table WHERE toInt8OrNull(value) IS NULL;
WITH (SELECT COUNT(*) FROM test_table) AS total_entries SELECT value, toInt8OrNull(value) AS converted_value FROM test_table WHERE total_entries > 0;
SELECT t.value, COALESCE(toInt8OrNull(t.value), 'Invalid Input') AS converted_value FROM test_table AS t JOIN (SELECT '0' AS filter_value) AS f ON t.value != f.filter_value;
SELECT CASE WHEN toInt8OrNull(value) IS NULL THEN 'Conversion Failed' ELSE 'Converted' END AS status FROM test_table;
SELECT value, CASE WHEN toInt8OrNull(value) BETWEEN -128 AND 127 THEN 'Valid' ELSE 'Out of Range' END AS validity FROM test_table;
SELECT value, toInt8OrNull(value) AS converted_value FROM (SELECT value FROM test_table WHERE value LIKE '-%') AS negative_values;