CREATE TABLE test_dates (id UInt32, event_date Date);
INSERT INTO test_dates VALUES (1, toDate('2024-06-15')), (2, toDate('2024-07-01'));
SELECT event_date + toIntervalMonth(1) AS next_month FROM test_dates;
WITH toIntervalMonth(2) AS interval_months SELECT event_date + interval_months AS two_months_later FROM test_dates;
SELECT id, event_date + toIntervalMonth(CAST('3' AS Int32)) AS three_months_later FROM test_dates;
SELECT event_date, event_date + toIntervalMonth(n) AS adjusted_date FROM test_dates CROSS JOIN (SELECT 5 AS n);
CREATE TABLE test_dates_2 (id UInt32, event_date Date);
INSERT INTO test_dates_2 VALUES (1, toDate('2023-12-15')), (2, toDate('2024-01-10'));
SELECT a.event_date, b.event_date FROM test_dates a JOIN test_dates_2 b ON a.id = b.id WHERE a.event_date + toIntervalMonth(6) < b.event_date;
WITH (SELECT COUNT(*) FROM test_dates) AS total_events SELECT total_events, event_date + toIntervalMonth(1) AS next_month FROM test_dates;
WITH toIntervalMonth(0) AS interval_zero SELECT event_date + interval_zero AS same_day FROM test_dates;