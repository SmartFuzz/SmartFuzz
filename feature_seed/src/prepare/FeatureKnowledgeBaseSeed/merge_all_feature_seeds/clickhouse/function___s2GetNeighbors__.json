CREATE TABLE s2_neighbors_test (s2index UInt64);
INSERT INTO s2_neighbors_test VALUES (5074766849661468672);
SELECT s2GetNeighbors(s2index) AS s2Neighbors FROM s2_neighbors_test;
CREATE TABLE s2_neighbors_multi (s2index UInt64, category String);
INSERT INTO s2_neighbors_multi VALUES (5074766849661468672, 'A'), (4254076641128259285690342776, 'B');
SELECT category, s2GetNeighbors(s2index) AS s2Neighbors FROM s2_neighbors_multi;
WITH (SELECT COUNT(*) FROM s2_neighbors_test) AS total_count SELECT s2index, s2GetNeighbors(s2index), total_count FROM s2_neighbors_test;
CREATE TABLE s2_neighbors_final (s2index UInt64, description String);
INSERT INTO s2_neighbors_final SELECT s2index, CONCAT('Neighbors for ', toString(s2index)) FROM s2_neighbors_multi;
SELECT description, s2GetNeighbors(s2index) AS s2Neighbors FROM s2_neighbors_final WHERE s2index IN (SELECT s2index FROM s2_neighbors_test);
WITH (SELECT s2index FROM s2_neighbors_multi WHERE category = 'A') AS selected_indices SELECT s2GetNeighbors(s2index) FROM s2_neighbors_test WHERE s2index IN selected_indices;
SELECT s2index, (SELECT s2GetNeighbors(s2index)) AS neighbors FROM (SELECT s2index FROM s2_neighbors_test ORDER BY s2index LIMIT 5) ORDER BY s2index;