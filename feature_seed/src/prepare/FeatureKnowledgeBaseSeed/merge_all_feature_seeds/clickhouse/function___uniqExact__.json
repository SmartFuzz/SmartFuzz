CREATE TABLE test_table_1 (id UInt32, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_1 VALUES (1, 'a'), (2, 'b'), (3, 'a'), (4, 'c'), (5, 'b');
SELECT uniqExact(value) FROM test_table_1;
CREATE TABLE test_table_2 (date Date, value Int32) ENGINE = MergeTree() ORDER BY date;
INSERT INTO test_table_2 VALUES ('2023-10-01', 1), ('2023-10-01', 2), ('2023-10-02', 1), ('2023-10-02', 2), ('2023-10-02', 3);
SELECT date, uniqExact(value) FROM test_table_2 GROUP BY date;
CREATE TABLE test_table_3 (id UInt32, group_id UInt32, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_3 VALUES (1, 1, 'x'), (2, 1, 'y'), (3, 2, 'x'), (4, 2, 'z'), (5, 2, 'x');
SELECT group_id, uniqExact(value) FROM test_table_3 GROUP BY group_id;
CREATE TABLE test_table_4 (id UInt32, number Array(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_4 VALUES (1, [1, 2, 3]), (2, [4, 2, 5]), (3, [5, 6]);
SELECT uniqExact(arrayJoin(number)) FROM test_table_4;
CREATE TABLE test_table_5 (id UInt32, info Tuple(name String, age Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_5 VALUES (1, ('John', 30)), (2, ('Alice', 25)), (3, ('John', 30)), (4, ('Bob', 35));
SELECT uniqExact(info.1) FROM test_table_5;
CREATE TABLE test_table_6 AS test_table_1 ENGINE = MergeTree() ORDER BY id;
SELECT t1.value, uniqExact(t2.value) FROM test_table_1 t1 JOIN test_table_1 t2 ON t1.id < t2.id GROUP BY t1.value;
CREATE TABLE test_table_7 (id UInt32, date DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_7 VALUES (1, '2023-10-01 10:00:00'), (2, '2023-10-01 10:00:00'), (3, '2023-10-02 12:00:00');
SELECT uniqExact(date) FROM test_table_7;