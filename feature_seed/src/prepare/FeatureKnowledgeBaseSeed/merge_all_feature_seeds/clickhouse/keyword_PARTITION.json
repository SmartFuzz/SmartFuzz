ALTER TABLE test_partition REMOVE PARTITION '202301';
ALTER TABLE test_partition FREEZE PARTITION '202301';
ALTER TABLE test_partition MOVE PARTITION '202301' TO VOLUME 'volume_1';
CREATE TABLE backup_partition (id Int32, created_at DateTime) ENGINE = MergeTree() PARTITION BY toYYYYMM(created_at) ORDER BY id;
INSERT INTO backup_partition SELECT * FROM test_partition WHERE created_at >= '2023-01-01 00:00:00' AND created_at < '2023-02-01 00:00:00';
ALTER TABLE test_partition ATTACH DATA FROM 'backup_partition' PARTITION '202301';
