CREATE TABLE new_table AS SELECT * FROM test_partition WHERE created_at >= '2023-01-01' AND created_at < '2023-01-31' WITH NO DATA;
INSERT INTO new_table SELECT * FROM test_partition WHERE created_at >= '2023-01-01' AND created_at < '2023-01-31';
ALTER TABLE new_table FREEZE PARTITION '202301';
ALTER TABLE test_partition ADD INDEX idx_status (status) TYPE minmax GRANULARITY 1;
