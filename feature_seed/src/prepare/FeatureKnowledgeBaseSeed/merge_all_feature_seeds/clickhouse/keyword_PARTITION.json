CREATE TABLE test_partition (id Int32, created_at DateTime) ENGINE = MergeTree() PARTITION BY toYYYYMM(created_at) ORDER BY id;
INSERT INTO test_partition VALUES (1, '2023-01-01 00:00:00'), (2, '2023-01-01 00:00:01'), (3, '2023-02-01 00:00:00');
ALTER TABLE test_partition DETACH PARTITION '202301';
ALTER TABLE test_partition ATTACH PARTITION '202301';
