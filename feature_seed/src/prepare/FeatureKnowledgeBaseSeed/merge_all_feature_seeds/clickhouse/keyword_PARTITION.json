SELECT COUNT(*) FROM test_partition WHERE status = 'active' IN PARTITION '202301';
ALTER TABLE test_partition UPDATE status = 'archived' WHERE created_at < '2023-01-15' IN PARTITION '202301';
ALTER TABLE test_partition DELETE WHERE status = 'inactive' IN PARTITION '202301';
