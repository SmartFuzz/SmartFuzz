CREATE TABLE test_dates (datetime_val DateTime, nullable_val Nullable(Int32));
INSERT INTO test_dates (datetime_val, nullable_val) VALUES ('2023-04-21 10:20:30', 1), ('2023-04-21 10:20:15', NULL), ('2023-04-21 10:21:00', 3);
SELECT toSecond(datetime_val) AS second, nullable_val IS NULL AS is_null FROM test_dates WHERE toSecond(datetime_val) > 20 AND nullable_val IS NULL;
SELECT datetime_val, (toSecond(datetime_val) + 10) IS NULL AS is_null_result FROM test_dates;
SELECT datetime_val, (SELECT avg(toSecond(datetime_val)) FROM test_dates WHERE nullable_val IS NULL) AS avg_second_null FROM test_dates GROUP BY datetime_val HAVING (toSecond(datetime_val) - avg_second_null) < 5;
CREATE TABLE test_dates_2 (datetime_val DateTime, value Nullable(Int32), PRIMARY KEY (datetime_val));
INSERT INTO test_dates_2 (datetime_val, value) VALUES ('2023-04-21 10:20:30', NULL), ('2023-04-21 10:20:30', 10), ('2023-04-21 10:20:30', 20);
SELECT value, toSecond(datetime_val) IS NULL AS is_null_second, value IS NULL AS is_null_value FROM test_dates_2 WHERE toSecond(datetime_val) < 59 OR value IS NULL;
SELECT datetime_val, count(*) AS cnt, max(toSecond(datetime_val)) AS max_second FROM test_dates GROUP BY datetime_val HAVING cnt > 1 OR max_second IS NULL;
SELECT datetime_val, CASE WHEN toSecond(datetime_val) IS NULL THEN 'NULL' ELSE 'NOT NULL' END AS second_status FROM test_dates;