CREATE TABLE test_dates (id Int32, date_str String);
INSERT INTO test_dates VALUES (1, '2022-12-30'), (2, 'invalid-date'), (3, '2023-01-01');
CREATE TABLE test_data (id Int32, value Int32);
INSERT INTO test_data VALUES (1, 10), (2, 20), (3, 30), (4, NULL);
SELECT id, toDateOrNull(date_str) AS valid_date FROM test_dates HAVING valid_date IS NOT NULL;
SELECT id, value FROM test_data WHERE value != ALL (SELECT value FROM test_data WHERE value IS NOT NULL);
SELECT id, toDateOrNull(date_str) FROM test_dates WHERE toDateOrNull(date_str) != ALL (SELECT toDateOrNull(date_str) FROM test_dates WHERE id = 2);
SELECT id, value FROM test_data WHERE value != ALL (SELECT value FROM test_data WHERE value IS NULL) AND value != ALL (SELECT value FROM test_data WHERE value > 10);
SELECT id, value FROM test_data GROUP BY value HAVING COUNT(*) > 1 AND value != ALL (SELECT value FROM test_data WHERE value IS NULL);
SELECT id, toDateOrNull(date_str) AS test_date FROM test_dates WHERE test_date != ALL (SELECT toDateOrNull(date_str) FROM test_dates WHERE date_str = '');
SELECT id, COUNT(*) FROM test_data GROUP BY value HAVING value != ALL (SELECT value FROM test_data WHERE value IS NULL) AND COUNT(*) < 3;