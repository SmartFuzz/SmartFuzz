CREATE TABLE test_dates (date Date, date_time DateTime, date_time_string String);
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
INSERT INTO test_dates VALUES (toDate('2024-12-31'), toDateTime('2024-12-31 23:59:59'), '2024-12-31 23:59:59');
INSERT INTO test_dates VALUES (toDate('2024-02-29'), toDateTime('2024-02-29 12:00:00'), '2024-02-29 12:00:00');
SELECT addQuarters(date, 1) AS add_quarters_with_date FROM test_dates WHERE date = toDate('2024-01-01');
SELECT addQuarters(date_time, 1) AS add_quarters_with_date_time FROM test_dates WHERE date_time = toDateTime('2024-01-01 00:00:00');
SELECT addQuarters(date_time_string, 1) AS add_quarters_with_date_time_string FROM test_dates WHERE date_time_string = '2024-01-01 00:00:00';
SELECT addQuarters(date, 2) AS add_quarters_with_date FROM test_dates WHERE date = toDate('2024-12-31');
SELECT addQuarters(date_time, -1) AS subtract_quarters_with_date_time FROM test_dates WHERE date_time = toDateTime('2024-02-29 12:00:00');
WITH (SELECT MIN(date) FROM test_dates) AS min_date, (SELECT MAX(date) FROM test_dates) AS max_date SELECT addQuarters(min_date, 2) AS add_quarters_min_date, addQuarters(max_date, -1) AS subtract_quarters_max_date;
SELECT addQuarters(date, 4) AS add_quarters_from_subquery FROM (SELECT date FROM test_dates WHERE date < toDate('2025-01-01')) AS subquery;
SELECT addQuarters(date_time, 3) FROM test_dates WHERE date IN (SELECT date FROM test_dates WHERE date_time > toDateTime('2024-01-01 00:00:00'));
SELECT date, addQuarters(date, 1) AS add_quarter_1, addQuarters(date, 2) AS add_quarter_2 FROM test_dates;
SELECT count(*) FROM test_dates WHERE addQuarters(date, 1) > toDate('2024-01-31');