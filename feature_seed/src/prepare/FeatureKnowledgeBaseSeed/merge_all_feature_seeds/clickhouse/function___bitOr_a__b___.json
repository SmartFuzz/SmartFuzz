CREATE TABLE test_bit_or (a UInt32, b UInt32) ENGINE = Memory;
INSERT INTO test_bit_or VALUES (1, 2), (3, 4), (5, 6), (255, 255), (0, 0);
SELECT bitOr(a, b) AS result FROM test_bit_or WHERE a < 100;
SELECT a, b, bitOr(a, b) AS bitwise_or FROM test_bit_or WHERE a != b;
CREATE TABLE another_table (x UInt8, y UInt8) ENGINE = Memory;
INSERT INTO another_table VALUES (1, 2), (2, 3), (3, 4);
SELECT t1.a, t1.b, bitOr(t1.a, t2.x) AS combined_or FROM test_bit_or t1 JOIN another_table t2 ON t2.x < 3;
SELECT bitOr(bitOr(a, b), 15) AS nested_bitOr FROM test_bit_or;
CREATE TABLE nested_table (id UInt32, value UInt32) ENGINE = Memory;
INSERT INTO nested_table VALUES (1, 2), (2, 3), (3, 4), (4, 5);
SELECT id, bitOr(value, (SELECT MAX(value) FROM nested_table)) AS final_or FROM nested_table GROUP BY id;
SELECT bitOr(a, b) FROM (SELECT a, b FROM test_bit_or WHERE a > b) AS derived_table;
SELECT COUNT(*), bitOr(a, b) AS or_result FROM test_bit_or GROUP BY or_result;
SELECT bitOr(a + 1, b * 2) FROM test_bit_or WHERE a + b > 5;