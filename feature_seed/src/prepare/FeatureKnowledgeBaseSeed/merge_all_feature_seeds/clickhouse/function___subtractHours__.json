CREATE TABLE test_dates (id UInt32, date_field Date, datetime_field DateTime, datetime64_field DateTime64(3));
INSERT INTO test_dates VALUES (1, toDate('2024-01-01'), toDateTime('2024-01-01 12:00:00'), toDateTime64('2024-01-01 12:00:00', 3));
INSERT INTO test_dates VALUES (2, toDate('2024-12-31'), toDateTime('2024-12-31 23:59:59'), toDateTime64('2024-12-31 23:59:59', 3));
SELECT subtractHours(date_field, 24) AS date_minus_24_hours FROM test_dates WHERE id = 1;
SELECT subtractHours(datetime_field, 12) AS datetime_minus_12_hours FROM test_dates WHERE id = 1;
SELECT subtractHours(datetime64_field, 14.5) AS datetime64_minus_14_5_hours FROM test_dates WHERE id = 1;
SELECT subtractHours(date_field, 1) AS start_of_new_year FROM test_dates WHERE id = 1;
SELECT subtractHours(datetime_field, 36) AS adjust_midnight FROM test_dates WHERE id = 2;
WITH toDate('2024-06-15') AS reference_date SELECT subtractHours(reference_date, 5) AS adjusted_date;
SELECT id, subtractHours(datetime_field, num) AS adjusted_time FROM test_dates, (SELECT 1 AS num) WHERE id = 2;
SELECT id, datetime_field, subtractHours(datetime_field, CAST(num AS Int32)) AS modified_time FROM test_dates CROSS JOIN (SELECT [1, 12, 24] AS num);
WITH (SELECT COUNT(*) FROM test_dates) AS total_count SELECT id, subtractHours(datetime_field, total_count) AS adjusted_time FROM test_dates;
SELECT DISTINCT subtractHours(datetime_field, 1) FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE id < 3);
SELECT id, date_field, subtractHours(datetime_field, 48) AS two_days_back FROM test_dates ORDER BY id;
WITH toDate('2024-07-01') AS summer_start, toDate('2024-09-01') AS fall_start SELECT subtractHours(summer_start, 240) AS late_march, subtractHours(fall_start, 180) AS late_july;