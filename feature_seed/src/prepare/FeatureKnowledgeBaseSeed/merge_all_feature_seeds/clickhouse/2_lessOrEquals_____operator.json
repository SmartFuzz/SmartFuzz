CREATE TABLE test_table_1 (id Int32, value String, created_at DateTime, score Float64);
INSERT INTO test_table_1 VALUES (1, '10', now(), 12.5), (2, '20', now(), 15.3), (3, NULL, now(), 18.0);
CREATE TABLE test_table_2 (user_id Int32, points Int32, feedback Nullable(String));
INSERT INTO test_table_2 VALUES (1, 200, 'Good'), (2, 150, NULL), (3, 300, 'Excellent');
SELECT t1.id, t1.value, t1.score, t2.points FROM test_table_1 t1 JOIN test_table_2 t2 ON lessOrEquals(t1.score, t2.points) WHERE t1.value != '20';
SELECT AVG(score) FROM (SELECT t1.score FROM test_table_1 t1 JOIN test_table_2 t2 ON t1.id != t2.user_id WHERE NULL IS NULL OR t1.value <= '30');
SELECT t1.id, COUNT(*) FROM test_table_1 t1 WHERE lessOrEquals(t1.score, 20.0) GROUP BY t1.id HAVING t1.value != '';
SELECT * FROM test_table_1 WHERE id IN (SELECT user_id FROM test_table_2 WHERE points <= 250) AND lessOrEquals(score, max(20.0) + 100);
SELECT COUNT(*) FROM test_table_1 WHERE lessOrEquals(NULL, score) OR score IS NULL;
SELECT * FROM test_table_2 HAVING lessOrEquals(points, 150) AND feedback != '' ORDER BY points ASC;
SELECT t1.id, t1.value FROM test_table_1 t1 WHERE (SELECT COUNT(*) FROM test_table_2 t2 WHERE t2.points > t1.score) <= 1;