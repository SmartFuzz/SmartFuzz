CREATE TABLE test_dates (date_string String, time_string String, some_number UInt32) ENGINE = MergeTree() ORDER BY date_string;
INSERT INTO test_dates VALUES ('12/05/2021', '12:50:00', 1), ('', '', 2), (NULL, NULL, 3);
SELECT arrayStringConcat([date_string, time_string, arrayStringConcat(['sample_data', CAST(some_number AS String)], ' ')], ' ') AS FullString FROM test_dates WHERE date_string IS NOT NULL;
SELECT arrayStringConcat(['Value1', arrayStringConcat(['Value2', IF(some_number > 1, 'Greater', 'Smaller')])]) AS CombinedValue FROM test_dates GROUP BY IF(some_number IS NULL, 'N/A', CAST(some_number AS String)) HAVING COUNT(*) > 1;
SELECT date_string, time_string, arrayStringConcat([date_string, time_string], ' - ') AS DateTimeString FROM test_dates WHERE (some_number = 1 AND time_string IS NOT NULL) OR (some_number IS NOT NULL AND date_string = '') ORDER BY DateTimeString;
SELECT arrayStringConcat([date_string, time_string], ' | ') AS Concatenated FROM (SELECT date_string, time_string FROM test_dates WHERE some_number < 5) WHERE Concatenated IS NOT NULL;
CREATE TABLE temp_dates (temp_date String, temp_time String) ENGINE = MergeTree() ORDER BY temp_date;
INSERT INTO temp_dates VALUES (NULL, NULL), ('01/01/2023', '13:00:00');
SELECT arrayStringConcat([temp_date, IFNULL(temp_time, ''), arrayStringConcat(['extra_string', 'sample'])], ';
') AS ResultString FROM temp_dates HAVING ResultString IS NOT NULL;
SELECT a AND b AS Result FROM (SELECT arrayStringConcat([date_string, time_string], ' ') AS a, some_number > 1 AS b FROM test_dates) WHERE Result IS TRUE;