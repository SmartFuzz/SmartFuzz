CREATE TABLE test_ifnull (id UInt32, name Nullable(String), value Nullable(Int32));
INSERT INTO test_ifnull VALUES (1, 'Alice', 100), (2, NULL, 200), (3, 'Charlie', NULL), (4, NULL, NULL);
SELECT ifNull(name, 'Unknown') AS resolved_name FROM test_ifnull;
SELECT ifNull(value, 0) AS resolved_value FROM test_ifnull;
SELECT id, ifNull(name, 'Unknown') AS resolved_name, ifNull(value, 0) AS resolved_value FROM test_ifnull WHERE id <= 3;
SELECT id, ifNull((SELECT AVG(value) FROM test_ifnull WHERE value IS NOT NULL), 0) AS avg_value FROM test_ifnull;
CREATE TABLE test_join (id UInt32, test_id UInt32, description Nullable(String));
INSERT INTO test_join VALUES (1, 1, 'Test A'), (2, 2, NULL), (3, 3, 'Test C');
SELECT tj.id, ifNull(ti.name, 'Not Found') AS resolved_name FROM test_ifnull ti LEFT JOIN test_join tj ON ti.id = tj.test_id;
SELECT ifNull((SELECT name FROM test_ifnull WHERE id = 2), 'No Name') AS fallback_name;
SELECT id, ifNull(name, 'N/A') || ': ' || ifNull(value, -1) AS summary FROM test_ifnull;