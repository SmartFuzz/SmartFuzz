CREATE TABLE test_float (value String);
INSERT INTO test_float VALUES ('42.7');
INSERT INTO test_float VALUES ('NaN');
INSERT INTO test_float VALUES ('Inf');
INSERT INTO test_float VALUES ('-Inf');
INSERT INTO test_float VALUES ('9999999999999999');
INSERT INTO test_float VALUES ('-9999999999999999');
INSERT INTO test_float VALUES ('0');
INSERT INTO test_float VALUES ('1');
INSERT INTO test_float VALUES ('-1');
SELECT toFloat64(value) FROM test_float;
SELECT toFloat64('42.7'), toFloat64('-Inf'), toFloat64('NaN') FORMAT Vertical;
SELECT toFloat64(10), toFloat64(3.14159) * toFloat64(2) FORMAT Vertical;
SELECT COUNT(*) FROM (SELECT toFloat64(value) FROM test_float WHERE toFloat64(value) > 0) AS t;
SELECT a.value, b.value, toFloat64(a.value) + toFloat64(b.value) FROM test_float a JOIN test_float b ON a.value = '1' AND b.value = '1' FORMAT Vertical;
WITH '42' AS example_value SELECT toFloat64(example_value) AS converted_value;
SELECT toFloat64(value) FROM (SELECT value FROM test_float WHERE value != 'NaN') AS subquery;
SELECT toFloat64(value) FROM test_float WHERE value IN ('42.7', '-9999999999999999', 'Inf') ORDER BY value;
CREATE TABLE float_results AS SELECT toFloat64(value) AS float_value FROM test_float;
INSERT INTO float_results SELECT toFloat64(value) FROM test_float;