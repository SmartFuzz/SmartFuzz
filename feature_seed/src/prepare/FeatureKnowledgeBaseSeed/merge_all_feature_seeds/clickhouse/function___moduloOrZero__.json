CREATE TABLE test_table (id UInt32, value1 UInt32, value2 UInt32);
INSERT INTO test_table VALUES (1, 10, 3), (2, 20, 5), (3, 30, 0), (4, 40, 8), (5, 50, 0);
SELECT id, moduloOrZero(value1, value2) AS result FROM test_table;
SELECT id, moduloOrZero(value1, value2) AS result FROM test_table WHERE value2 < 10;
SELECT id, moduloOrZero(value1, value2) AS result FROM (SELECT value1, value2 FROM test_table WHERE id > 2) AS subquery;
CREATE TABLE secondary_table (id UInt32, multiplier UInt32);
INSERT INTO secondary_table VALUES (1, 100), (2, 0), (3, 25);
SELECT t.id, moduloOrZero(t.value1, s.multiplier) AS modulo_result FROM test_table t JOIN secondary_table s ON t.id = s.id;
SELECT COUNT(*) AS count FROM test_table WHERE moduloOrZero(value1, value2) = 0;
WITH (SELECT AVG(value1) FROM test_table) AS avg_value SELECT id, moduloOrZero(value1, avg_value) AS modulo_result FROM test_table;
SELECT id, moduloOrZero(value1, (SELECT multiplier FROM secondary_table LIMIT 1)) AS result FROM test_table;
SELECT id, moduloOrZero(value1, 0) AS result FROM test_table;
SELECT moduloOrZero(15, 0) AS direct_zero_modulo;
SELECT moduloOrZero(id, moduloOrZero(value1, value2)) AS nested_result FROM test_table;
SELECT id, moduloOrZero(moduloOrZero(value1, value2), 3) AS nested_modulo FROM test_table;