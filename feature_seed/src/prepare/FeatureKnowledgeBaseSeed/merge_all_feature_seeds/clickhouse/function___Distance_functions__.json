CREATE TABLE locations (id UInt32, coordinates Tuple(Float64, Float64));
INSERT INTO locations VALUES (1, (37.7749, -122.4194)), (2, (34.0522, -118.2437)), (3, (40.7128, -74.0060));
CREATE TABLE users (user_id UInt32, home Coordinates Tuple(Float64, Float64));
INSERT INTO users VALUES (1, (37.7749, -122.4194)), (2, (34.0522, -118.2437)), (3, (40.7128, -74.0060));
SELECT id, distance(coordinates, (34.0522, -118.2437)) AS distance FROM locations ORDER BY distance LIMIT 2;
SELECT user_id, distance(home, (40.7128, -74.0060)) AS home_distance FROM users WHERE home_distance < 5000 ORDER BY home_distance;
SELECT l.id, u.user_id, distance(l.coordinates, u.home) AS distance FROM locations AS l JOIN users AS u ON distance(l.coordinates, u.home) < 1000;
SELECT DISTINCT id FROM locations WHERE distance(coordinates, (0.0, 0.0)) < 1000000;
SELECT user_id FROM users WHERE user_id IN (SELECT id FROM locations WHERE distance(coordinates, (34.0522, -118.2437)) < 500) ORDER BY user_id;
SELECT l.id, distance(l.coordinates, u.home) AS distance FROM locations l JOIN users u ON distance(l.coordinates, u.home) < 5000 GROUP BY l.id HAVING distance < 100;