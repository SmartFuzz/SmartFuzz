CREATE TABLE strings_table (id UInt32, text String);
INSERT INTO strings_table VALUES (1, 'Hello World'), (2, 'ClickHouse Documentation'), (3, 'Test string for locate function');
SELECT locate('o', text) AS position FROM strings_table WHERE id = 1;
SELECT locate('ClickHouse', text) AS position FROM strings_table WHERE id = 2;
SELECT locate('string', text, 1) AS position FROM strings_table WHERE id = 3;
SELECT id, locate('T', text) AS position FROM strings_table WHERE position IS NOT NULL;
SELECT id, locate('Test', text) AS position FROM strings_table WHERE location IS NOT NULL UNION ALL SELECT id, locate('o', text) FROM strings_table WHERE id = 1;
WITH (SELECT id, text FROM strings_table WHERE text LIKE '%string%') AS subquery SELECT id, locate('string', text) FROM subquery;
CREATE TABLE more_strings_table (id UInt32, text String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO more_strings_table VALUES (4, 'locate function usage'), (5, 'another test string');
SELECT a.id, a.text, locate('locate', b.text) AS position FROM strings_table AS a JOIN more_strings_table AS b ON a.id = 1;
SELECT id, locate(text, 'locate') AS position FROM strings_table HAVING position > 0;
SELECT text, locate('e', text, 4) AS position FROM strings_table WHERE id = 2;
CREATE TABLE complex_table (id UInt32, text1 String, text2 String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO complex_table VALUES (1, 'needle', 'haystack'), (2, 'another needle', 'different haystack');
SELECT id, locate(text1, text2) AS position FROM complex_table;
SELECT text, locate('Z', text, -1) AS position FROM strings_table WHERE id = 3;