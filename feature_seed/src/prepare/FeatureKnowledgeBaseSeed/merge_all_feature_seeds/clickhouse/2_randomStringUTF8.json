CREATE TABLE test_table (id UInt32, random_text String, created_at DateTime DEFAULT now());
INSERT INTO test_table (id, random_text) VALUES (1, randomStringUTF8(10)), (2, randomStringUTF8(20)), (3, randomStringUTF8(30));
SELECT id, random_text FROM test_table WHERE id GLOBAL IN (SELECT id FROM test_table WHERE random_text != '');
SELECT id, random_text, LENGTH(random_text) AS text_length FROM test_table HAVING text_length >= 10;
SELECT id, (SELECT COUNT() FROM test_table WHERE random_text LIKE '%' || randomStringUTF8(5) || '%') AS like_count FROM test_table;
CREATE TEMPORARY TABLE temp_table AS SELECT randomStringUTF8(15) AS random_string, 1 AS fixed_val UNION ALL SELECT randomStringUTF8(5), 2;
SELECT * FROM temp_table WHERE fixed_val GLOBAL IN (1, 2);
SELECT id, random_text, created_at FROM test_table WHERE random_text IS NULL OR random_text = randomStringUTF8(20);
SELECT id, COUNT(*) AS total_count FROM (SELECT id, random_text FROM test_table) GROUP BY id HAVING total_count > 1;
ALTER TABLE test_table ADD COLUMN description String DEFAULT randomStringUTF8(10);
CREATE TABLE join_test_table (join_id UInt32, join_text String);
INSERT INTO join_test_table (join_id, join_text) VALUES (1, randomStringUTF8(5)), (2, 'Sample Text');
SELECT t.id, t.random_text, j.join_text FROM test_table t JOIN join_test_table j ON t.id = j.join_id WHERE t.random_text GLOBAL IN (SELECT random_text FROM test_table WHERE LENGTH(random_text) >= 15);