CREATE TABLE test_dates (id Int32, event_date DateTime, month_change Int32);
INSERT INTO test_dates VALUES (1, toDateTime('2023-01-01 12:00:00'), 2), (2, toDateTime('2023-05-15 15:30:00'), 14);
SELECT id, changeMonth(event_date, month_change) AS new_date, new_date + INTERVAL 1 MONTH AS next_date FROM (SELECT id, event_date, month_change FROM test_dates) AS sub;
SELECT id, event_date, month_change FROM test_dates WHERE event_date < changeMonth(now(), 2) + INTERVAL 5 DAY;
SELECT id, changeMonth(event_date, month_change) AS new_date FROM test_dates GROUP BY new_date HAVING new_date IS NOT NULL;
SELECT id, changeMonth(event_date, month_change) AS updated_date FROM test_dates WHERE updated_date = changeMonth(now() + INTERVAL 1 MONTH, -1);
CREATE TABLE edge_cases (data String, some_date DateTime);
INSERT INTO edge_cases VALUES ( '', toDateTime('2023-01-01 00:00:00')), ( 'NULL', NULL);
SELECT IFNULL(changeMonth(toDate(data), 2), 'no value') AS month_change_result FROM edge_cases;
SELECT COUNT(*) FROM edge_cases WHERE changeMonth(some_date, INTERVAL -1 MONTH) IS NOT NULL;
SELECT event_date, changeMonth(event_date, month_change) AS changed_date FROM test_dates JOIN edge_cases ON changeMonth(event_date, 1) = changeMonth(some_date, 1);
SELECT changeMonth(now(), 3) + INTERVAL 10 DAY AS future_date, toUnixTimestamp(changeMonth(now(), 4)) AS unix_timestamp;
SELECT changeMonth(toDateTime64('2023-01-15 23:59:59.999', 3), 2) + INTERVAL 5 MINUTE AS updated_timestamp, now();