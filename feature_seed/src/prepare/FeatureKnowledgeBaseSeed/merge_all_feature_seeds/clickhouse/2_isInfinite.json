CREATE TABLE test_table (id UInt32, value Float64, description String);
INSERT INTO test_table VALUES (1, 1.0), (2, 0.0), (3, Inf), (4, NaN), (5, -Inf);
CREATE TABLE reference_table (ref_id UInt32, ref_value Float64);
INSERT INTO reference_table VALUES (1, 1.0), (2, 2.0);
SELECT COUNT(*) FROM (SELECT id, value FROM test_table WHERE isInfinite(value) = 1) AS subquery;
SELECT ref_id, AVG(value) FROM test_table JOIN reference_table ON isInfinite(value) BETWEEN 0 AND 1 GROUP BY ref_id HAVING AVG(value) > 0;
SELECT id, value FROM test_table WHERE value BETWEEN Inf AND -Inf;
SELECT isInfinite(value) AS is_infinite_value FROM (SELECT value FROM test_table WHERE value != 0) HAVING is_infinite_value = 1;
SELECT id, value FROM (SELECT id, value, isInfinite(value) AS infinite_check FROM test_table) WHERE infinite_check BETWEEN 0 AND 1 ORDER BY id;
SELECT * FROM (SELECT value FROM test_table WHERE value NOT BETWEEN 0 AND 1) WHERE isInfinite(value) = 0 ORDER BY value DESC;