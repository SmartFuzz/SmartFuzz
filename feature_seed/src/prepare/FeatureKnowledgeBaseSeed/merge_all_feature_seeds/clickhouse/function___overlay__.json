CREATE TABLE test_strings (id UInt32, original String) ENGINE = Memory;
INSERT INTO test_strings VALUES (1, 'My father is from Mexico.');
INSERT INTO test_strings VALUES (2, 'The quick brown fox jumps over the lazy dog.');
INSERT INTO test_strings VALUES (3, 'ClickHouse is a fast analytic DBMS.');
INSERT INTO test_strings VALUES (4, 'abcdef');
INSERT INTO test_strings VALUES (5, 'test string for overlay function');
SELECT overlay(original, 'mother', 4) AS res FROM test_strings WHERE id = 1;
SELECT overlay(original, 'dinosaur', 0) AS res FROM test_strings WHERE id = 1;
SELECT overlay(original, 'data', -5) AS res FROM test_strings WHERE id = 1;
SELECT overlay(original, 'inserted', 1, 2) AS res FROM test_strings WHERE id = 4;
SELECT overlay(original, 'replaced', 5, 20) AS res FROM test_strings WHERE id = 5;
SELECT overlay(original, 'my', 16, 4) AS res FROM test_strings WHERE id = 2;
SELECT overlay('a long and complex string', 'short', 10, 4) AS res;
SELECT overlay('hello world', 'world', -5, 5) AS res;
SELECT overlay(original, replace, offset, length) FROM (SELECT original, 'new string' AS replace, 9 AS offset, 5 AS length FROM test_strings WHERE id = 3);
SELECT overlay(original, 'complete', 1, 5) AS res FROM (SELECT original FROM test_strings WHERE id IN (2, 1));
SELECT overlay(s, 'filled', offset) FROM (SELECT overlay(original, 'hole', 5) AS s, 7 AS offset FROM test_strings) WHERE id = 5;