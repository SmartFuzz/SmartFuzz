CREATE TABLE test_cos (value FLOAT);
INSERT INTO test_cos VALUES (0), (3.14159), (1), (-1), (1.5708), (-3.14159), (1.0E-10), (NaN), (Infinity), (-Infinity);
SELECT cos(value) FROM test_cos;
SELECT value, cos(value) FROM test_cos WHERE value BETWEEN -10 AND 10;
SELECT cos(2 * value) AS double_angle FROM test_cos;
SELECT cos(value) + 1 AS shifted_cosine FROM test_cos;
SELECT SUM(cos(value)) FROM test_cos;
WITH (SELECT AVG(value) FROM test_cos) AS avg_val SELECT cos(avg_val) FROM test_cos;
CREATE TABLE test_values (value FLOAT, category String);
INSERT INTO test_values VALUES (0, 'zero'), (1, 'one'), (3.14159, 'pi'), (-1, 'negative');
SELECT t.category, cos(t.value) FROM test_values t WHERE t.value != 0;
SELECT AVG(cos(value)) AS avg_cos FROM (SELECT value FROM test_cos ORDER BY value DESC LIMIT 5);
SELECT COUNT(*) FROM test_cos WHERE cos(value) > 0;
SELECT value, cos(value) AS cosine_val FROM test_cos WHERE value IN (SELECT value FROM test_values WHERE category = 'one');
SELECT DISTINCT cos(value) FROM (SELECT value FROM test_cos UNION SELECT value FROM test_values);