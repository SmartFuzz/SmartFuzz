CREATE TABLE test_table (id Int32, name String, value Nullable(Float64), created_at DateTime) ENGINE = Memory;
INSERT INTO test_table (id, name, value, created_at) VALUES (1, 'test1', NULL, now()), (2, 'test2', 3.14, now()), (3, 'test3', -1.5, now());
SELECT formatQuery('SELECT id, name FROM test_table WHERE value IS NULL');
SELECT id, formatQuery('SELECT value FROM test_table WHERE created_at > NOW() - INTERVAL 1 DAY') AS formatted_query FROM test_table WHERE value IS NULL;
SELECT id, name, formatQuery('SELECT value + 100 FROM test_table WHERE value IS NOT NULL') AS adjusted_value FROM test_table WHERE name IS NULL;
SELECT id, formatQuery('SELECT COUNT(*) FROM (SELECT id FROM test_table WHERE created_at IS NULL) AS subquery') AS count_null_created_at FROM test_table GROUP BY id HAVING id IS NULL;
SELECT id, formatQueryOrNull('SELECT sum(value) FROM test_table WHERE value IS NULL') AS total_value FROM test_table;
SELECT id as another_id FROM test_table WHERE created_at IS NOT NULL;
CREATE TABLE temp_table AS SELECT id, name FROM test_table WHERE value IS NOT NULL;
INSERT INTO temp_table (id, name) VALUES (4, 'test4'), (5, 'test5');
SELECT formatQuery('SELECT * FROM temp_table WHERE name IS NULL OR name = ''') AS formatted_temp_query FROM temp_table WHERE id IS NOT NULL;
SELECT id, formatQuery('SELECT AVG(value) FROM test_table WHERE value IS NOT NULL') AS average_value FROM test_table GROUP BY id HAVING average_value IS NULL;
SELECT id FROM (SELECT id, value, formatQuery('SELECT name FROM test_table WHERE id = t.id') AS names_query FROM test_table AS t) AS subquery WHERE value < 0 AND names_query IS NULL;