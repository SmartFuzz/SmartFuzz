CREATE TABLE test_dates (date_string String, time_zone String, default_value DateTime) ENGINE = Memory;
INSERT INTO test_dates VALUES ('2022-12-30 13:44:17', 'UTC', '2023-01-01 00:00:00'), ('invalid-date', 'UTC', '2023-01-01 00:00:00'), ('2023-03-15 09:30:00', 'UTC', '2023-01-01 00:00:00');
SELECT toDateTimeOrDefault(date_string, time_zone, default_value) FROM test_dates;
SELECT SUM(toDateTimeOrDefault(date_string, 'UTC', '2023-01-01 00:00:00')) FROM test_dates WHERE date_string NOT IN ('', 'invalid-date');
SELECT COUNT(*) FROM (SELECT toDateTimeOrDefault(date_string, 'UTC', '2023-01-01 00:00:00') AS adjusted_date FROM test_dates) AS subquery WHERE adjusted_date > '2022-12-31 23:59:59';
CREATE TABLE other_dates (simple_date String) ENGINE = Memory;
INSERT INTO other_dates VALUES ('2023-01-01'), ('2022-12-30'), ('invalid-date'), ('2023-03-16');
SELECT a.simple_date, toDateTimeOrDefault(a.simple_date, 'UTC', '2023-01-01 00:00:00') FROM other_dates AS a LEFT JOIN test_dates AS b ON a.simple_date = b.date_string;
CREATE TABLE more_dates (id Int32, event_time String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO more_dates VALUES (1, '2022-12-30 13:44:17'), (2, 'invalid-date'), (3, '2023-03-15 09:30:00');
SELECT id, toDateTimeOrDefault(event_time, 'Europe/London', now()) AS event_time_converted FROM more_dates WHERE event_time IS NOT NULL;