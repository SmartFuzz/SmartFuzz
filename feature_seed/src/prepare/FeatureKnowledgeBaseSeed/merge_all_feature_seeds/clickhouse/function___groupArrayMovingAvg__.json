CREATE TABLE t1 (id UInt8, int_col UInt8, float_col Float32, dec_col Decimal32(2)) ENGINE = TinyLog;
INSERT INTO t1 VALUES (1, 10, 10.5, 10.25), (2, 20, 20.5, 20.25), (3, 30, 30.5, 30.25), (4, 40, 40.5, 40.25);
SELECT groupArrayMovingAvg(int_col) AS avg_int, groupArrayMovingAvg(float_col) AS avg_float, groupArrayMovingAvg(dec_col) AS avg_dec FROM t1;
CREATE TABLE t2 (user_id UInt8, score Float32) ENGINE = TinyLog;
INSERT INTO t2 VALUES (1, 50.0), (1, 60.0), (1, 70.0), (2, 80.0), (2, 90.0);
SELECT user_id, groupArrayMovingAvg(score) AS avg_score FROM t2 GROUP BY user_id;
SELECT groupArrayMovingAvg(3)(int_col) AS avg_int_3, groupArrayMovingAvg(3)(float_col) AS avg_float_3 FROM t1;
SELECT groupArrayMovingAvg(1)(int_col) AS avg_int_1, groupArrayMovingAvg(1)(float_col) AS avg_float_1 FROM (SELECT int_col, float_col FROM t1 WHERE int_col > 5);
CREATE TABLE t3 (category UInt8, value UInt8) ENGINE = TinyLog;
INSERT INTO t3 VALUES (1, 10), (1, 20), (2, 30), (2, 40);
SELECT category, groupArrayMovingAvg(value) AS moving_avg FROM t3 GROUP BY category;
SELECT t1.id, groupArrayMovingAvg(t1.int_col) AS avg_int, t2.user_id, groupArrayMovingAvg(t2.score) AS avg_score FROM t1 JOIN t2 ON t1.id = t2.user_id GROUP BY t1.id, t2.user_id;
SELECT groupArrayMovingAvg(5)(float_col) AS avg_float_5 FROM (SELECT float_col FROM t1 WHERE int_col <= 3);
SELECT AVG(moving_avg) FROM (SELECT groupArrayMovingAvg(2)(int_col) AS moving_avg FROM t1 GROUP BY int_col);
SELECT groupArrayMovingAvg(float_col) AS avg_float FROM (SELECT float_col FROM t1 ORDER BY float_col DESC LIMIT 2) ORDER BY float_col;
SELECT groupArrayMovingAvg(2)(dec_col) FROM (SELECT dec_col FROM t1 ORDER BY dec_col ASC);