CREATE TABLE test_buildId (id UInt32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_buildId VALUES (1), (2), (3);
SELECT buildId() FROM test_buildId;
SELECT buildId() AS current_buildid, id FROM test_buildId;
SELECT id, buildId() OVER (PARTITION BY id) AS build FROM test_buildId;
CREATE TABLE distributed_test AS test_buildId ENGINE = Distributed('cluster_name', 'default', 'test_buildId');
SELECT buildId(), COUNT(*) FROM distributed_test GROUP BY buildId();
WITH (SELECT buildId() AS build) AS build_info SELECT build FROM build_info;
SELECT x.buildId, t.id FROM (SELECT buildId() AS buildId) AS x JOIN test_buildId AS t ON x.buildId = t.id;
SELECT buildId() FROM (SELECT buildId() AS inner_build_id FROM system.build_options) AS subquery;
SELECT buildId() as build_id, COUNT(*) FROM (SELECT buildId() AS buildId FROM test_buildId GROUP BY id) AS subquery GROUP BY build_id;