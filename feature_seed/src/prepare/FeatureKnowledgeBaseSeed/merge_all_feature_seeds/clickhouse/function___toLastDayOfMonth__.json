CREATE TABLE test_dates (event_date DateTime);
INSERT INTO test_dates VALUES (toDateTime('2023-01-15 08:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-02-28 15:45:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-03-31 23:59:59'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-01 00:00:01'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-30 12:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-05-15 10:20:30'));
INSERT INTO test_dates VALUES (toDateTime('2023-02-29 00:01:00'));
SELECT toLastDayOfMonth(event_date) FROM test_dates;
SELECT event_date, toLastDayOfMonth(event_date) AS last_day FROM test_dates WHERE event_date < toDateTime('2023-06-01 00:00:00');
SELECT toLastDayOfMonth(toDateTime('2023-02-28')), toLastDayOfMonth(toDateTime('2023-01-31'));
SELECT t1.event_date, toLastDayOfMonth(t1.event_date) AS last_day, t2.other_info FROM test_dates t1 JOIN (SELECT event_date AS other_info FROM test_dates) t2 ON t1.event_date = t2.other_info;
SELECT event_date, toLastDayOfMonth(event_date) AS last_day FROM test_dates WHERE event_date BETWEEN toDateTime('2023-01-01') AND toDateTime('2023-04-30') ORDER BY last_day DESC;
CREATE TABLE dates_summary AS SELECT toLastDayOfMonth(event_date) AS last_day, COUNT(*) AS total_events FROM test_dates GROUP BY last_day;
SELECT last_day, total_events FROM dates_summary WHERE total_events > 1;