CREATE TABLE test_data (x Int8, w Int8) ENGINE = Memory;
INSERT INTO test_data VALUES (4, 1), (1, 0), (10, 2), (0, 0), (1, 0), (10, 0);
SELECT avgWeighted(x, NOT w) FROM test_data GROUP BY x HAVING avgWeighted(x, NOT w) > 0;
CREATE TABLE complex_data (x Float64, w Int8) ENGINE = Memory;
INSERT INTO complex_data VALUES (4.5, 1), (1.2, 0), (10.0, 2), (NULL, 0);
SELECT avgWeighted(NOT w, x) OVER (PARTITION BY w) FROM complex_data;
CREATE TABLE nested_test (x Int8, w Float64) ENGINE = Memory;
INSERT INTO nested_test VALUES (0, 0), (5, 10), (NULL, NULL), (10, 0);
SELECT NOT avgWeighted(x, COALESCE(w, 1.0)) FROM nested_test GROUP BY x HAVING NOT avgWeighted(x, COALESCE(w, 1.0)) IS NULL;
CREATE TABLE multi_table_test (a Int8, b Int8) ENGINE = MergeTree() ORDER BY a;
CREATE TABLE join_table (c Int8, d Float64) ENGINE = MergeTree() ORDER BY c;
INSERT INTO multi_table_test VALUES (1, 10), (2, 20);
INSERT INTO join_table VALUES (1, 0.5), (2, 0.0);
SELECT avgWeighted(t.a, NOT t.b) FROM multi_table_test t JOIN join_table j ON t.a = j.c WHERE NOT j.d = 0 GROUP BY t.a HAVING avgWeighted(t.a, NOT t.b) < 5;
CREATE TABLE edge_case_test (value Float64, weight Int8) ENGINE = Memory;
INSERT INTO edge_case_test VALUES (NULL, 1), (1.5, 0), (3.0, 3), (4.0, 3);
SELECT NOT avgWeighted(value, weight) AS weighted_avg FROM edge_case_test;