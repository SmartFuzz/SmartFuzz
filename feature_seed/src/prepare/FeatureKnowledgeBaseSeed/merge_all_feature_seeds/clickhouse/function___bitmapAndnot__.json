CREATE TABLE bitmaps_table (id UInt32, bitmap_col1 AggregateFunction(bitMap, UInt32), bitmap_col2 AggregateFunction(bitMap, UInt32));
INSERT INTO bitmaps_table VALUES (1, bitmapBuild([1,2,3])), (2, bitmapBuild([3,4,5])), (3, bitmapBuild([]));
SELECT bitmapToArray(bitmapAndnot(bitmap_col1, bitmap_col2)) AS res FROM bitmaps_table;
CREATE TABLE another_table (id UInt32, value UInt32);
INSERT INTO another_table VALUES (1, 10), (2, 20), (3, 30);
SELECT bitmapToArray(bitmapAndnot(bitmapBuild([1,2,3]), bitmapBuild([1,2]))) AS complex_res FROM another_table WHERE id = 1;
SELECT bitmapToArray(bitmapAndnot(bitmapBuild([1,2,3,4]), bitmapBuild([2,3,5]))) AS res FROM bitmaps_table WHERE id = 2;
SELECT id, bitmapToArray(bitmapAndnot(bitmap_col1, bitmap_col2)) AS res FROM bitmaps_table WHERE id IN (SELECT id FROM another_table WHERE value > 15);
SELECT bitmapToArray(bitmapAndnot(bitmapBuild([1,2,3,4,5]), bitmapBuild([3,4,5,6]))) AS nested_res, id FROM (SELECT id FROM bitmaps_table) AS subquery;
SELECT id, bitmapToArray(bitmapAndnot(bitmap_col1, bitmapBuild([7,8,9]))) AS negated_res FROM bitmaps_table WHERE id BETWEEN 1 AND 3;
SELECT bitmapToArray(bitmapAndnot(bitmapBuild([1,2,3]), bitmapBuild([]))) AS empty_bitmap_result;