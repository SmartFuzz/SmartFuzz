CREATE TABLE test_shingles (text String);
INSERT INTO test_shingles VALUES ('ClickHouse® is a column-oriented database management system (DBMS) for online analytical processing of queries (OLAP).');
SELECT wordShingleMinHashArgCaseInsensitive(text, 3, 6) FROM test_shingles;
SELECT wordShingleMinHashArgCaseInsensitive(text, 1, 6) FROM test_shingles WHERE text LIKE '%column-oriented%';
SELECT wordShingleMinHashArgCaseInsensitive(text, 25, 25) FROM test_shingles;
SELECT wordShingleMinHashArgCaseInsensitive(text, 2, 1) AS shingles FROM (SELECT text FROM test_shingles WHERE text ILIKE '%database%');
CREATE TABLE test_shingles_complex (id UInt64, text String);
INSERT INTO test_shingles_complex VALUES (1, 'ClickHouse is fast.'), (2, 'Database management systems are crucial.');
SELECT id, wordShingleMinHashArgCaseInsensitive(text, 3, 5) FROM test_shingles_complex WHERE id IN (SELECT id FROM test_shingles_complex WHERE text LIKE '%ClickHouse%');
SELECT wordShingleMinHashArgCaseInsensitive(text, 4, 3) FROM (SELECT text FROM test_shingles);
WITH (SELECT MAX(text) FROM test_shingles) AS max_text SELECT wordShingleMinHashArgCaseInsensitive(max_text, 2, 4);
SELECT wordShingleMinHashArgCaseInsensitive(text, 6) FROM (SELECT text FROM test_shingles WHERE LENGTH(text) > 50) AS filtered_text;
SELECT id, wordShingleMinHashArgCaseInsensitive(text, 5, 5) FROM test_shingles_complex ORDER BY id DESC;