CREATE TABLE numbers (a Int32, b Int32);
INSERT INTO numbers VALUES (0, 5), (5, 0), (1, -1), (-1, 1), (4, 6), (15, 25);
SELECT lcm(a, b) FROM numbers;
SELECT lcm(a, 10) AS lcm_with_ten FROM numbers WHERE a > 0;
SELECT lcm(a, b) AS lcm_ab FROM numbers WHERE b != 0 AND a != 0;
SELECT (SELECT lcm(a, b) FROM numbers WHERE a > 0 AND b > 0) AS positive_lcm;
CREATE TABLE more_numbers (x Int32, y Int32);
INSERT INTO more_numbers VALUES (3, 7), (8, 12), (0, 9);
SELECT lcm(a, b) FROM numbers N JOIN more_numbers M ON N.a = M.x;
SELECT lcm(a, (SELECT MAX(y) FROM more_numbers)) AS lcm_with_max_y FROM numbers;
WITH (SELECT MIN(a) FROM numbers) AS min_a, (SELECT MAX(b) FROM numbers) AS max_b SELECT lcm(min_a, max_b) AS lcm_min_max;