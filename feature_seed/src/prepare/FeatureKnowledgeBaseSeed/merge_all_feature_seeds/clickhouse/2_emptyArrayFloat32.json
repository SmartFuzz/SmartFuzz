CREATE TABLE test_table (id UInt32, value Float32, arr Array(Float32));
INSERT INTO test_table VALUES (1, 1.5, [1.1, 1.2]), (2, NULL, emptyArrayFloat32()), (3, 3.0, [2.8, 2.9]);
SELECT id, value, arr FROM test_table WHERE value GLOBAL IN (SELECT value FROM test_table WHERE id = 1);
SELECT id, value, arr, emptyArrayFloat32() AS empty_arr FROM test_table WHERE value IS NULL OR value > (SELECT MIN(value) FROM test_table);
SELECT id, value, arr FROM test_table WHERE arr GLOBAL IN (SELECT emptyArrayFloat32());
SELECT id, value * 2 AS doubled_value FROM test_table GROUP BY id HAVING doubled_value > 3.0 OR (arr GLOBAL IN (SELECT emptyArrayFloat32()));
CREATE TABLE temp_table AS SELECT id, value FROM test_table WHERE arr != emptyArrayFloat32() SETTINGS finish_on_timeout = 1;
SELECT COUNT(*) OVER() AS total_count FROM (SELECT id, value, arr FROM test_table);
CREATE TABLE join_table (join_id UInt32, join_val Float32) ENGINE = MergeTree() ORDER BY join_id;
INSERT INTO join_table VALUES (1, 1.0), (2, NULL), (3, 3.5);
SELECT t1.id, t1.value, t2.join_val FROM test_table t1 JOIN join_table t2 ON t1.id GLOBAL IN (SELECT join_id FROM join_table WHERE join_val IS NOT NULL);
SELECT id, COUNT(*) AS arr_count FROM test_table GROUP BY id HAVING arr_count = (SELECT COUNT(*) FROM test_table WHERE arr = emptyArrayFloat32());