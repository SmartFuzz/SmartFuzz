CREATE TABLE test_db.table_1 (col1 UInt32) ENGINE = MergeTree() ORDER BY col1;
CREATE TABLE test_db.table_2 (col2 UInt32) ENGINE = MergeTree() ORDER BY col2;
GRANT SELECT ON test_db.table_1 TO current_user;
GRANT SELECT(con) ON test_db.table_1 TO current_user;
GRANT SELECT ON test_db.table_2 TO user_role;
CHECK GRANT SELECT ON test_db.table_1;
CHECK GRANT SELECT ON test_db.table_2;
CHECK GRANT SELECT(con) ON test_db.table_1;
CHECK GRANT SELECT ON test_db.table_3;
CREATE TABLE test_db.table_3 (col3 UInt32) ENGINE = MergeTree() ORDER BY col3;
CHECK GRANT SELECT ON test_db.*;
CHECK GRANT SELECT(*) ON test_db.table_1;
SELECT (SELECT COUNT(*) FROM test_db.table_1) AS row_count;
CHECK GRANT SELECT ON (SELECT col1 FROM test_db.table_1) AS inner_query;
CHECK GRANT SELECT ON (SELECT col2 FROM test_db.table_2 WHERE col2 > 10) AS filtered_query;
CHECK GRANT SELECT ON (SELECT DISTINCT col1 FROM test_db.table_1 JOIN test_db.table_2 ON table_1.col1 = table_2.col2) AS join_query;