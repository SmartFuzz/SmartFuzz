CREATE TABLE test_array (id UInt32, values Array(Int32));
INSERT INTO test_array VALUES (1, [1, 2, 3]), (2, [0, 0, 0]), (3, [5, 4, 3]), (4, []);
SELECT arrayLastOrNull(x -> x > 2, values) FROM test_array;
SELECT id, arrayLastOrNull(x -> x > 0, values) FROM test_array WHERE id < 3;
SELECT arrayLastOrNull(x -> x >= 2, values) FROM test_array WHERE values != [];
SELECT id, arrayLastOrNull(x -> x < 1, values) FROM test_array;
SELECT arrayLastOrNull(x -> arrayLastOrNull(y -> y < 5, values), values) FROM test_array;
SELECT id, arrayLastOrNull(x -> x % 2 = 0, values) + 1 FROM test_array;
SELECT arrayLastOrNull(x -> x + 1, [1, 2, 3]);
SELECT arrayLastOrNull(x -> x < 3, arrayJoin([1, 2, 3, 4]));
SELECT arrayLastOrNull(x -> x >= 3, arrayJoin([5, 4, 3, 2]));
WITH (SELECT arrayJoin([1, 2, 3]) AS numbers) AS arr SELECT arrayLastOrNull(x -> x >= 2, numbers);
SELECT arrayLastOrNull(x -> x = 2, [1, 2, 2, 3, 4]) FROM test_array;
SELECT arrayLastOrNull(x -> x = 0, [1, 2, 3]) AS last_element WHERE last_element IS NULL;