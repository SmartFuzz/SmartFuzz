CREATE TABLE test_strings (id UInt32, value String);
INSERT INTO test_strings VALUES (1, 'number: 1, number: 2, number: 3'), (2, 'abc123xyz'), (3, 'no digits here'), (4, '1st match: 45, 2nd match: 78');
SELECT extract(value, '\\d+') AS first_match FROM test_strings WHERE id = 1;
SELECT extract(value, '\\d+') AS first_match FROM test_strings WHERE value LIKE '%digits%';
SELECT id, extract(value, '\\d+') AS first_match FROM test_strings WHERE value LIKE '%match%';
SELECT id, extract(value, '([a-zA-Z]+)(\\d+)') AS first_alphabet_and_digit FROM test_strings;
SELECT id, extract(value, '\\D+') AS first_non_digit FROM test_strings WHERE id = 2;
SELECT id, extract(value, '\\d+') AS first_match FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE value LIKE '%number%');
CREATE TABLE additional_strings (user_id UInt32, description String);
INSERT INTO additional_strings VALUES (1, 'The code for 200 error is not found'), (2, 'No valid numbers'), (3, 'Success: 100, Failure: 404');
SELECT t.id, extract(t.value, '\\d+') AS first_num, extract(a.description, '\\d+') AS additional_num FROM test_strings t JOIN additional_strings a ON t.id = a.user_id;
SELECT extract(value, '^\D*(\\d+)') AS leading_number FROM test_strings WHERE id = 3;
SELECT extract(value, '(\\d+)(?:,|$)') AS number_list FROM test_strings WHERE id = 4;