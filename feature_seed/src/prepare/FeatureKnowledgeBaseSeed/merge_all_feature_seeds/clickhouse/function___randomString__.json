CREATE TABLE test_strings (id UInt32, random_str String);
INSERT INTO test_strings SELECT number, randomString(10) FROM numbers(5);
SELECT random_str, length(random_str) AS len FROM test_strings WHERE len = 10;
SELECT randomString(1) AS short_str, length(short_str) AS len FROM numbers(3);
SELECT randomString(1024) AS long_str, length(long_str) AS len FROM numbers(1);
SELECT randomString(0) AS empty_str, length(empty_str) AS len FROM numbers(1);
SELECT id, randomString(50) AS random_bytes FROM test_strings WHERE id < 3 ORDER BY id ASC;
WITH randomString(16) AS rnd_str, randomString(8) AS rnd_str_2 SELECT rnd_str, rnd_str_2, length(rnd_str) + length(rnd_str_2) AS total_length FROM numbers(1);
SELECT randomString(number + 5) AS variable_length_str, length(variable_length_str) FROM numbers(3);
CREATE TABLE random_data AS SELECT randomString(32) AS rand_str FROM numbers(100);
SELECT COUNT(*) AS random_string_count FROM random_data WHERE length(rand_str) = 32;