CREATE TABLE test_vectors (vec Tuple(Float64, Float64));
INSERT INTO test_vectors VALUES ((3, 4));
INSERT INTO test_vectors VALUES ((1, 1));
INSERT INTO test_vectors VALUES ((0, 0));
INSERT INTO test_vectors VALUES ((-3, -4));
SELECT LpNormalize(vec, 2) FROM test_vectors;
SELECT LpNormalize(vec, 1.5) FROM test_vectors;
SELECT LpNormalize(vec, 10) FROM test_vectors;
WITH (SELECT avg(x) FROM (SELECT LpNormalize((a, b), 2) AS x FROM test_vectors)) AS avg_normalized SELECT avg_normalized;
SELECT LpNormalize(tuple, p) FROM (SELECT (x.1, x.2) AS tuple, 2 AS p FROM test_vectors AS x) WHERE (x.1, x.2) != (0, 0);
CREATE TABLE dense_vectors (val Tuple(Float64, Float64, Float64));
INSERT INTO dense_vectors VALUES ((3, 4, 5));
SELECT LpNormalize(val, 3) FROM dense_vectors;
CREATE TABLE multi_vectors (id UInt32, vec Tuple(Float64, Float64));
INSERT INTO multi_vectors VALUES (1, (3, 4)), (2, (1, 1));
SELECT id, LpNormalize(vec, 2) FROM multi_vectors;
SELECT id, LpNormalize(vec, 1) FROM (SELECT id, vec FROM multi_vectors WHERE id = 1);
SELECT id, LpNormalize(vec, 4) FROM (SELECT id, LpNormalize((vec.1, vec.2), 2) AS vec FROM multi_vectors);
SELECT LpNormalize((sqrt(sum(x.1)), sqrt(sum(x.2))), 2) FROM (SELECT (3, 4) AS x UNION ALL SELECT (1, 1) AS x);
SELECT LpNormalize((a, b), p) FROM (SELECT (3, 4) AS vec, 5 AS p) AS subquery WHERE (a, b) != (0, 0);