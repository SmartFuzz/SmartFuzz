CREATE TABLE test_reverse (id UInt32, arr Array(Int32));
INSERT INTO test_reverse VALUES (1, [1, 2, 3, 4]), (2, [5, 6, 7]), (3, [8]);
SELECT id, reverse(arr) AS reversed_array FROM test_reverse;
SELECT id, reverse(arr) AS reversed_array FROM test_reverse WHERE id < 3;
SELECT id, reverse(arr) AS reversed_array FROM (SELECT id, arr FROM test_reverse WHERE id = 1) AS subquery;
CREATE TABLE test_join (id UInt32, test_id UInt32, value Int32);
INSERT INTO test_join VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30);
SELECT tr.id, reverse(arrayMap(x -> x + 1, tr.arr)) AS modified_reversed_array FROM test_reverse AS tr JOIN test_join AS tj ON tr.id = tj.test_id;
SELECT id, reverse(arr) AS reversed_array FROM test_reverse WHERE arrayExists(x -> x > 5, arr);
SELECT id, reverse(arr) AS reversed_array FROM (SELECT id, arr FROM test_reverse WHERE length(arr) > 2) AS filtered;
SELECT tj.value, reverse(tr.arr) AS reversed_array FROM test_reverse AS tr INNER JOIN test_join AS tj ON tr.id = tj.test_id GROUP BY tj.value, tr.arr;