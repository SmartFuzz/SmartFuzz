CREATE TABLE ip_addresses (id UInt32, ip_string String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO ip_addresses VALUES (1, '2001:438:ffff::407d:1bc1'), (2, '127.0.0.1'), (3, 'invalid_ip'), (4, '::1'), (5, '255.255.255.255');
SELECT * FROM ip_addresses WHERE toIPv6(ip_string) != ANY (SELECT toIPv6(ip_string) FROM ip_addresses WHERE id > 2);
SELECT id, toIPv6(ip_string) AS converted_ip FROM ip_addresses GROUP BY converted_ip HAVING converted_ip IS NOT NULL;
SELECT a.id, a.ip_string FROM ip_addresses a JOIN ip_addresses b ON a.id != b.id WHERE toIPv6(a.ip_string) != ANY (SELECT toIPv6(b.ip_string) FROM ip_addresses b WHERE b.ip_string IS NOT NULL);
SELECT COUNT(*) FROM ip_addresses WHERE toIPv6(ip_string) != ANY (SELECT toIPv6('127.0.0.1') AS test_ip);
CREATE TABLE temp_ips AS SELECT id, toIPv6(ip_string) AS ipv6 FROM ip_addresses WHERE toIPv6(ip_string) IS NOT NULL;
SELECT DISTINCT ipv6 FROM temp_ips WHERE ipv6 != ANY (SELECT ipv6 FROM temp_ips WHERE ipv6 LIKE '2001:%');
SELECT AVG(length(toIPv6(ip_string))) FROM ip_addresses WHERE toIPv6(ip_string) != ANY (SELECT toIPv6('invalid_ip') AS test);
CREATE TABLE mixed_ip_addresses (id UInt32, ip_string String, valid_ipv6 IPv6) ENGINE = MergeTree() ORDER BY id;
INSERT INTO mixed_ip_addresses SELECT id, ip_string, toIPv6(ip_string) FROM ip_addresses;
UPDATE mixed_ip_addresses SET valid_ipv6 = toIPv6(ip_string) WHERE valid_ipv6 IS NULL AND ip_string != 'invalid_ip';