CREATE TABLE test_series (id UInt32, series Array(Float64) DEFAULT [1.0, 2.0, 3.5, 4.2, NULL, 5.8, 100.0, 2.0, 1.0]);
INSERT INTO test_series VALUES (1, [1, 2, 100, 3]), (2, [NULL, 5, 6, 7]), (3, [2.5, 8, 9, 1.5]);
SELECT id, seriesOutliersDetectTukey(series, 0.1, 0.9, 2) FROM test_series WHERE series IS NOT NULL;
SELECT id, multiIf(length(series) < 4, 'Not enough data', seriesOutliersDetectTukey(series), 0) AS outlier_scores FROM test_series;
SELECT id, arrayJoin(series) AS individual_values, seriesOutliersDetectTukey(arrayJoin(series), 0.2, 0.8, 1.5) AS anomaly_scores FROM test_series;
CREATE TABLE complex_table (num Float32, value String, date DateTime) ENGINE = MergeTree() ORDER BY num;
INSERT INTO complex_table VALUES (1.5, 'test', now()), (1.0, 'sample', now()), (NULL, 'example', now());
SELECT num, value, seriesOutliersDetectTukey([sum(num) OVER (PARTITION BY value ORDER BY num), count(value) OVER (ORDER BY date)], 0.25, 0.75) AS outlier_indicators FROM complex_table;
WITH (SELECT arrayMap(x -> x * 2, [1, 2, 3]) AS doubled_series) AS inner_series SELECT seriesOutliersDetectTukey(inner_series.doubled_series) AS outlier_scores;
SELECT id, multiIf(seriesOutliersDetectTukey(series) = 0, 'No outlier', 'Outlier detected') AS anomaly_report FROM test_series WHERE series IS NOT NULL;