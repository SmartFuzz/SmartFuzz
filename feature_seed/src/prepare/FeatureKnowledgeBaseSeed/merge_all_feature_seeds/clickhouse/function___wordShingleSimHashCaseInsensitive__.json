CREATE TABLE test_data (id UInt32, text String) ENGINE = Memory;
INSERT INTO test_data VALUES (1, 'ClickHouse® is a column-oriented database management system (DBMS) for online analytical processing of queries (OLAP).');
INSERT INTO test_data VALUES (2, 'ClickHouse is a database management system');
SELECT wordShingleSimHashCaseInsensitive(text, 3) AS Hash FROM test_data WHERE id = 1;
SELECT id, wordShingleSimHashCaseInsensitive(text, 4) AS Hash FROM test_data WHERE text LIKE '%database%';
SELECT t1.id, wordShingleSimHashCaseInsensitive(t1.text, 5) AS Hash1, wordShingleSimHashCaseInsensitive(t2.text, 3) AS Hash2 FROM test_data t1 JOIN test_data t2 ON t1.id != t2.id;
SELECT wordShingleSimHashCaseInsensitive(text, 1) AS Hash FROM test_data HAVING Hash IS NOT NULL;
SELECT DISTINCT wordShingleSimHashCaseInsensitive(text) AS Hash FROM test_data ORDER BY Hash;
SELECT wordShingleSimHashCaseInsensitive(text, 2) AS Hash FROM (SELECT text FROM test_data WHERE id < 3) AS sub;
SELECT MAX(wordShingleSimHashCaseInsensitive(text, 3)) AS MaxHash FROM test_data WHERE LENGTH(text) < 100;
SELECT SUM(wordShingleSimHashCaseInsensitive(text, 3)) AS SumHash FROM test_data GROUP BY id;
SELECT wordShingleSimHashCaseInsensitive('The quick brown fox jumps over the lazy dog', 3) AS HashCaseFromString;
SELECT wordShingleSimHashCaseInsensitive('the quick brown fox jumps over the lazy dog', 3) AS HashCaseFromStringUpper;
SELECT wordShingleSimHashCaseInsensitive('') AS HashEmptyString;
SELECT wordShingleSimHashCaseInsensitive('singleword', 1) AS HashSingleWord;
SELECT wordShingleSimHashCaseInsensitive('word word word word word word', 8) AS HashLargeShingleSize;