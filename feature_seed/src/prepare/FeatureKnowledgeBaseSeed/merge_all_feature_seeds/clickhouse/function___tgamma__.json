CREATE TABLE gamma_test (value FLOAT);
INSERT INTO gamma_test VALUES (0), (1), (2), (3), (4), (5), (10), (100);
SELECT value, gamma(value) AS gamma_value FROM gamma_test;
CREATE TABLE complex_gamma_test AS SELECT value, gamma(value) AS gamma_value FROM (SELECT * FROM gamma_test WHERE value < 5);
SELECT COUNT(*) FROM (SELECT gamma(value) FROM gamma_test WHERE value IS NOT NULL) AS non_null_gamma;
WITH (SELECT MAX(value) AS max_val FROM gamma_test) AS max FROM gamma_test WHERE gamma(value) > gamma(max_val);
SELECT g.value, g.gamma_value FROM (SELECT value, gamma(value) AS gamma_value FROM gamma_test) AS g JOIN (SELECT value FROM gamma_test WHERE value > 10) AS h ON g.value = h.value;
SELECT g.value, g.gamma_value FROM (SELECT value, gamma(value) AS gamma_value FROM gamma_test WHERE value BETWEEN 0 AND 5) AS g WHERE g.gamma_value < 10;
CREATE TABLE extended_gamma_test (value DECIMAL(10,5));
INSERT INTO extended_gamma_test VALUES (0.1), (1.5), (3.75), (2.25), (4.0), (6.5);
SELECT value, gamma(value) AS gamma_value FROM extended_gamma_test;
CREATE TABLE combined_gamma_test AS SELECT g.value, g.gamma_value, t.name FROM extended_gamma_test g JOIN (SELECT 1 AS id, 'Test Name' AS name) AS t ON g.value < 2;
SELECT g.value, g.gamma_value, t.name FROM (SELECT value, gamma(value) AS gamma_value FROM extended_gamma_test) AS g JOIN (SELECT 2 AS id, 'Another Test' AS name) AS t ON g.gamma_value > 1;