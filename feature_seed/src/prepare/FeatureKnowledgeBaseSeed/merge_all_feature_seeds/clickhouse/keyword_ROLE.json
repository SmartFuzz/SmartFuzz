CREATE ROLE test_role;
ALTER ROLE test_role GRANT SELECT ON database_name.table_name TO user_name;
ALTER ROLE test_role REVOKE INSERT ON database_name.table_name FROM user_name;
CREATE TABLE IF NOT EXISTS database_name.table_name (id UInt32, name String) ENGINE = MergeTree() ORDER BY id;
GRANT ALL PRIVILEGES ON database_name.table_name TO test_role;
CREATE ROLE secondary_role;
ALTER ROLE secondary_role GRANT SELECT ON database_name.table_name TO user_name;
GRANT test_role, secondary_role TO user_name;
ALTER ROLE test_role DROP;
SELECT * FROM database_name.table_name WHERE id IN (SELECT id FROM another_table WHERE name LIKE 'test%');
SELECT COUNT(*) FROM (SELECT id FROM database_name.table_name WHERE id > 100) AS subquery;
ALTER ROLE test_role GRANT ALL ON database_name.* TO user_name;
REVOKE SELECT ON database_name.table_name FROM user_name;
DROP ROLE IF EXISTS remove_role;
ALTER ROLE test_role GRANT EXECUTE ON FUNCTION my_function();
CREATE TABLE IF NOT EXISTS another_table (id UInt32, description String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_table (id, description) VALUES (1, 'Sample description');
SELECT id, name FROM database_name.table_name WHERE id IN (SELECT id FROM another_table WHERE description = 'Sample description');
CREATE TEMPORARY TABLE temp_table AS SELECT * FROM database_name.table_name;
ALTER ROLE test_role GRANT INSERT ON temp_table TO user_name;