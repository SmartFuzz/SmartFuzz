CREATE TABLE numbers AS SELECT number AS n FROM system.numbers_mt LIMIT 10;
SELECT rowNumberInBlock() FROM (SELECT n FROM numbers) SETTINGS max_block_size = 2;
SELECT rowNumberInBlock() FROM (SELECT n FROM numbers ORDER BY n DESC) SETTINGS max_block_size = 3;
SELECT rowNumberInBlock() FROM (SELECT n FROM (SELECT number AS n FROM system.numbers_mt LIMIT 50) AS subquery) SETTINGS max_block_size = 5;
CREATE TABLE test_table (id UInt64, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'first'), (2, 'second'), (3, 'third'), (4, 'fourth');
SELECT rowNumberInBlock() FROM (SELECT * FROM test_table WHERE id < 3) SETTINGS max_block_size = 1;
SELECT rowNumberInBlock() FROM (SELECT id, (SELECT count() FROM test_table WHERE id < t.id) AS rank FROM test_table AS t) SETTINGS max_block_size = 10;
SELECT id, rowNumberInBlock() FROM test_table GROUP BY id SETTINGS max_block_size = 2;
SELECT rowNumberInBlock() FROM (SELECT n, rowNumberInBlock() AS rn FROM (SELECT number AS n FROM system.numbers_mt LIMIT 100) AS subquery) WHERE rn % 10 = 0 SETTINGS max_block_size = 20;