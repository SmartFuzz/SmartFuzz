CREATE TABLE test_table (id UInt32, val Nullable(String), created_at DateTime DEFAULT now());
INSERT INTO test_table VALUES (1, 'example', toDateTime('2022-01-01 12:00:00')),(2, NULL, toDateTime('2022-01-02 12:00:00')),(3, 'test', toDateTime('2022-01-03 12:00:00')),(4, '', toDateTime('2022-01-04 12:00:00'));
SELECT halfMD5(IF(val IS NOT NULL, val, 'default')) AS hash_value FROM test_table WHERE val IS NOT NULL;
SELECT halfMD5(array(val, toString(id))) AS combined_hash FROM test_table WHERE val IS NOT NULL GROUP BY combined_hash HAVING combined_hash != '00000000';
SELECT id, halfMD5(val) AS hash_value, val IS NOT NULL AS is_not_null FROM test_table WHERE created_at IS NOT NULL ORDER BY is_not_null DESC;
SELECT halfMD5(val || CAST(id AS String)) AS hash_value FROM test_table WHERE val IS NOT NULL AND created_at IS NOT NULL;
WITH (SELECT halfMD5(toString(id)) FROM test_table WHERE val IS NOT NULL) AS sub_hash SELECT halfMD5(sub_hash) AS final_hash FROM test_table;
CREATE TABLE nested_test (a Nullable(Int32), b Nullable(String));
INSERT INTO nested_test VALUES (1, 'data1'), (NULL, 'data2'), (2, NULL), (3, '');
SELECT halfMD5(cast(a AS String)) AS hash_value, b IS NOT NULL AS is_b_not_null FROM nested_test WHERE a IS NOT NULL;
SELECT a, halfMD5(array(b, toString(a))) AS hash_value FROM nested_test WHERE a IS NULL OR b IS NOT NULL;
CREATE TABLE temp_table AS SELECT id, halfMD5(val) AS hash_value FROM test_table WHERE val IS NOT NULL;
SELECT COUNT(*) FROM temp_table WHERE hash_value IS NOT NULL;
DROP TABLE IF EXISTS temp_table;