CREATE TABLE test_strings (id UInt32, str Nullable(String), from_encoding String, to_encoding String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'Hello World', 'UTF-8', 'ASCII'), (2, NULL, 'UTF-8', 'ISO-8859-1'), (3, 'Fuzzy Testing', 'ASCII', 'UTF-16');
SELECT id, convertCharset(str, from_encoding, to_encoding) AS converted_str FROM test_strings WHERE str IS NOT NULL;
SELECT id, convertCharset(COALESCE(str, 'Empty'), from_encoding, to_encoding) AS converted_str FROM test_strings HAVING converted_str IS NOT NULL;
WITH (SELECT str FROM test_strings WHERE from_encoding = 'UTF-8') AS utf8_strings SELECT id, convertCharset(str, 'UTF-8', 'ASCII') FROM utf8_strings WHERE str IS NOT NULL;
CREATE TABLE test_numbers (num UInt32, nullable_num Nullable(UInt32)) ENGINE = MergeTree() ORDER BY num;
INSERT INTO test_numbers VALUES (1, 10), (2, NULL), (3, 20);
SELECT num, CASE WHEN nullable_num IS NOT NULL THEN convertCharset(toString(nullable_num), 'ASCII', 'UTF-8') ELSE 'NULL' END AS converted_num FROM test_numbers;
CREATE TABLE test_composite (id UInt32 PRIMARY KEY, val Nullable(String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_composite VALUES (1, 'Sample Text'), (2, NULL), (3, 'Edge Case');
SELECT id, convertCharset(product(val, '1'), 'UTF-8', 'ASCII') FROM test_composite WHERE val IS NOT NULL;
SELECT id, convertCharset(COALESCE(val, ''), 'UTF-8', 'ISO-8859-1') AS charset_val FROM test_composite HAVING charset_val IS NOT NULL AND id IS NOT NULL;
CREATE TABLE test_join (id UInt32, value Chart(100)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_join VALUES (1, 'Some Value'), (2, NULL), (3, 'Another Value');
SELECT j.id, convertCharset(COALESCE(t.val, 'Default'), 'UTF-8', 'ASCII') AS converted_val FROM test_join AS j JOIN test_composite AS t ON j.id = t.id WHERE j.value IS NOT NULL;
WITH (SELECT DISTINCT value FROM test_join WHERE value IS NOT NULL) AS distinct_values SELECT id, convertCharset(val, 'ASCII', 'UTF-16') FROM distinct_values HAVING convertCharset(val, 'ASCII', 'UTF-16') IS NOT NULL;
CREATE TABLE test_null_handling (num Nullable(Int32), str Nullable(String), enc_from String, enc_to String) ENGINE = MergeTree() ORDER BY num;
INSERT INTO test_null_handling VALUES (1, 'Test', 'UTF-8', 'ASCII'), (NULL, 'Null Case', 'UTF-8', 'ISO-8859-1'), (2, NULL, 'ASCII', 'UTF-16');
SELECT num, convertCharset(NULLIF(str, 'Null Case'), enc_from, enc_to) AS converted_str FROM test_null_handling WHERE str IS NOT NULL;
SELECT id, convertCharset(concat(str, ' - ', val), from_encoding, to_encoding) AS combined_conversion FROM test_strings CROSS JOIN test_numbers WHERE str IS NOT NULL AND nullable_num IS NOT NULL;