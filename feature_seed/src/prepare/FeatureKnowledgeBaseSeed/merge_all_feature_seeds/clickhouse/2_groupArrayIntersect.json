CREATE TABLE test_intersect (id UInt32, nums Array(Int32));
INSERT INTO test_intersect VALUES (1, [1, 2, 3]), (2, [2, 3, 4]), (3, [3, 4, 5]);
SELECT groupArrayIntersect(-nums) AS intersection FROM test_intersect;
SELECT groupArrayIntersect(-nums) AS intersection FROM (SELECT nums FROM test_intersect WHERE id > 1);
SELECT groupArrayIntersect(-arrayJoin(nums)) AS intersection FROM test_intersect GROUP BY id HAVING id < 3;
SELECT groupArrayIntersect(arrayMap(x -> -x, nums)) AS intersection FROM test_intersect;
CREATE TABLE edge_cases (letter String, values Array(String), float_val Float64);
INSERT INTO edge_cases VALUES ('a', ['1', '2', '3'], 1.5), ('b', ['2', '3', '4'], 2.5), ('c', ['3', '4', '5'], 3.5);
SELECT groupArrayIntersect(arrayMap(x -> toInt32(x), values)) AS intersection FROM edge_cases WHERE float_val < -(-2.5);
SELECT groupArrayIntersect(NULL) AS intersection FROM edge_cases;
CREATE TABLE complex_data (user_id UInt32, data Array(Int32), other_data Nullable(String));
INSERT INTO complex_data VALUES (1, [1, 2, 3], 'example'), (2, [2, 3], NULL), (3, [1, 3]);
SELECT groupArrayIntersect(-data) AS intersection FROM complex_data WHERE other_data IS NULL OR other_data = 'example';
SELECT groupArrayIntersect(arrayJoin(data)) AS intersection FROM complex_data GROUP BY user_id HAVING COUNT(*) > 1;
SELECT groupArrayIntersect(arr) AS intersection FROM (SELECT arrayMap(i -> i, arrayJoin(data)) as arr FROM complex_data);
CREATE TABLE temp_users (user_id UInt32, scores Array(Float64));
INSERT INTO temp_users VALUES (1, [1.1, 2.2, 3.3]), (2, [2.2, 3.3, 4.4]), (3, [3.3, 4.4, 5.5]);
SELECT groupArrayIntersect(arrayMap(x -> -x, scores)) AS intersection FROM temp_users WHERE user_id IN (SELECT user_id FROM temp_users WHERE scores IS NOT NULL);
SELECT id, groupArrayIntersect(-nums) AS intersection FROM test_intersect GROUP BY id ORDER BY id;
SELECT groupArrayIntersect(arrayMap(x -> -toInt32(x), ['1', '2', '3'])) AS intersection FROM test_intersect;