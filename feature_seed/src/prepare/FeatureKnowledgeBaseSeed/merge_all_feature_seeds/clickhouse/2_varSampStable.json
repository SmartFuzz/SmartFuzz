DROP TABLE IF EXISTS test_data;
CREATE TABLE test_data (x Float64, y Float64) ENGINE = Memory;
INSERT INTO test_data VALUES (10.5, NULL), (12.3, 15.4), (9.8, 5.6), (11.2, 13.1), (10.7, -4.5), (NULL, 0.0);
SELECT round(varSampStable(-x), 3) AS neg_var_stable FROM test_data WHERE y IS NOT NULL;
DROP TABLE IF EXISTS edge_cases;
CREATE TABLE edge_cases (str_col String, float_col Float64) ENGINE = Memory;
INSERT INTO edge_cases VALUES ('10.5', '15.8'), ('10.0', '20.0'), ('11.2', NULL), ('12.8', '-9999.9'), ('15', '30.5');
SELECT round(varSampStable(-cast(str_col AS Float64)), 3) AS var_on_cast FROM edge_cases WHERE float_col IS NOT NULL GROUP BY str_col HAVING var_on_cast > 0;
DROP TABLE IF EXISTS join_test;
CREATE TABLE join_test(a Float64, b Float64) ENGINE = Memory;
INSERT INTO join_test VALUES (1.5, 2.5), (NULL, 3.5), (5.5, NULL), (3.5, 1.5), (10.0, 12.5);
CREATE TABLE ref_table(c Float64) ENGINE = Memory;
INSERT INTO ref_table VALUES (2.0), (3.0), (4.0);
SELECT round(varSampStable(-j.a + j.b), 4) AS combined_var FROM (SELECT a, b FROM join_test WHERE b IS NOT NULL) j JOIN ref_table r ON j.b < r.c GROUP BY j.a ORDER BY combined_var ASC;
DROP TABLE IF EXISTS null_test;
CREATE TABLE null_test (a Float64 DEFAULT NULL) ENGINE = Memory;
INSERT INTO null_test VALUES (NULL), (5.4), (2.2), (NULL), (10.1);
SELECT round(varSampStable(-COALESCE(a, 0.0)), 4) AS adjusted_var FROM null_test;
DROP TABLE IF EXISTS complex_case;
CREATE TABLE complex_case(a Float64, b Float64) ENGINE = Memory;
INSERT INTO complex_case VALUES (0.0, 1.0), (1.0, 2.0), (2.0, 3.0);
SELECT round(varSampStable((a + b) / 2), 5) AS avg_var FROM complex_case WHERE a <> 0.0 HAVING avg_var > 0.0;