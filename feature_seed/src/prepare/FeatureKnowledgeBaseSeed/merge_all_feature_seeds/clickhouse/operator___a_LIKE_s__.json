CREATE TABLE test_table (id UInt32, name String, description String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'Alice', 'This is a test entry'), (2, 'Bob', 'Another test entry'), (3, 'Charlie', 'Entry with test keyword');
SELECT * FROM test_table WHERE name LIKE '%A%';
SELECT * FROM test_table WHERE description LIKE 'Another%';
SELECT * FROM test_table WHERE description LIKE 'Entry with test%';
SELECT name FROM test_table WHERE name LIKE 'A% OR name LIKE 'B%';
CREATE TABLE test_table2 (id UInt32, test_id UInt32, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table2 VALUES (1, 1, 'First value'), (2, 1, 'Another value'), (3, 2, 'Test value');
SELECT t1.name, t2.value FROM test_table t1 JOIN test_table2 t2 ON t1.id = t2.test_id WHERE t1.name LIKE 'A%' AND t2.value LIKE '%value';
SELECT DISTINCT name FROM test_table WHERE id IN (SELECT test_id FROM test_table2 WHERE value LIKE 'Another%');
SELECT * FROM test_table WHERE id IN (SELECT DISTINCT test_id FROM test_table2 WHERE value LIKE 'First%') AND description LIKE '%test%';
SELECT name FROM test_table WHERE id NOT IN (SELECT test_id FROM test_table2 WHERE value LIKE 'Test%') AND name LIKE 'C%';
CREATE TABLE test_table3 AS (SELECT * FROM test_table WHERE description LIKE '%test%') ENGINE = MergeTree() ORDER BY id;
SELECT * FROM test_table3 WHERE name LIKE 'C%' OR name LIKE 'A%';
INSERT INTO test_table3 SELECT * FROM test_table WHERE description LIKE '%keyword%';