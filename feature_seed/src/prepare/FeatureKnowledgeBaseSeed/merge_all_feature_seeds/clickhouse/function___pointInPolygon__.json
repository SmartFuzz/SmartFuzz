CREATE TABLE points (point Tuple(Float64, Float64));
INSERT INTO points VALUES ((3.0, 3.0));
CREATE TABLE polygons (polygon Array(Tuple(Float64, Float64)));
INSERT INTO polygons VALUES ([(6, 0), (8, 4), (5, 8), (0, 2)]), ([(2, 2), (4, 4), (2, 6)]);
SELECT pointInPolygon((3.0, 3.0), (SELECT polygon FROM polygons WHERE index = 1)) AS is_in_polygon;
SELECT pointInPolygon((3.0, 3.0), [(6, 0), (8, 4), (5, 8), (0, 2)]) AS result;
SELECT p.point, pointInPolygon(p.point, poly.polygon) AS inside FROM points AS p JOIN polygons AS poly ON true;
WITH (SELECT [(0, 0), (10, 0), (10, 10), (0, 10)]) AS square_polygon SELECT pointInPolygon((5, 5), square_polygon) AS is_inside;
SELECT pointInPolygon((4, 4), [(1, 1), (5, 1), (5, 5), (1, 5)], [(2, 2), (2, 3), (3, 3), (3, 2)]) AS res;
SELECT pointInPolygon((3, 2), [(1, 1), (4, 1), (4, 4), (1, 4)], [(2, 2), (2, 3), (3, 3), (3, 2)]) AS with_holes;
SELECT pointInPolygon((1, 1), [(0, 0), (2, 0), (2, 2), (0, 2)]) AS on_boundary;
SELECT pointInPolygon((0, 10), [(0, 0), (10, 0), (10, 10), (0, 10)]) AS on_edge_case;
SELECT pointInPolygon((2.5, 2.5), [(1, 1), (4, 1), (4, 4), (1, 4)]) AS inside_complex_polygon;