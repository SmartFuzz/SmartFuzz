SELECT getServerPort('tcp_port');
CREATE TABLE ports_info (port_name String, port_number UInt16);
INSERT INTO ports_info VALUES ('tcp_port', getServerPort('tcp_port'));
INSERT INTO ports_info VALUES ('http_port', getServerPort('http_port'));
INSERT INTO ports_info VALUES ('https_port', getServerPort('https_port'));
SELECT port_name, port_number FROM ports_info WHERE port_number IS NOT NULL;
SELECT getServerPort('tcp_port_secure') + getServerPort('http_port') AS total_secure_ports;
SELECT (SELECT getServerPort('grpc_port')) AS grpc_port FROM ports_info;
SELECT port_name FROM ports_info WHERE port_number = (SELECT getServerPort('mysql_port'));
SELECT COUNT(*) FROM ports_info WHERE port_number > getServerPort('interserver_http_port');
SELECT getServerPort('tcp_port') AS tcp_port_value, getServerPort('postgresql_port') AS postgresql_port_value;
SELECT port_name FROM ports_info WHERE port_name IN ('tcp_port', 'https_port') HAVING count(port_name) = 2;