CREATE TABLE test_dates (id Int32, created_at Nullable(DateTime));
INSERT INTO test_dates VALUES (1, toDateTime('2021-08-15 18:57:56', 'Asia/Shanghai')), (2, NULL), (3, toDateTime('2023-01-01 00:00:01'));
CREATE TABLE test_results AS SELECT id, dateTimeToSnowflake(created_at) AS snowflake_id FROM test_dates WHERE created_at IS NOT NULL;
SELECT * FROM test_results WHERE snowflake_id IS NOT NULL;
SELECT created_at, dateTimeToSnowflake(created_at) AS snowflake_id FROM test_dates WHERE created_at IS NOT NULL HAVING snowflake_id IS NOT NULL;
CREATE TABLE join_test (test_id Int32, test_created_at Nullable(DateTime), FOREIGN KEY (test_id) REFERENCES test_dates (id));
INSERT INTO join_test VALUES (1, toDateTime('2021-08-15 18:57:56', 'Asia/Shanghai')), (2, NULL);
SELECT dt.id, dt.created_at, jt.test_created_at, dateTimeToSnowflake(dt.created_at) AS snowflake_id FROM test_dates dt JOIN join_test jt ON dt.id = jt.test_id WHERE jt.test_created_at IS NOT NULL;
SELECT dateTimeToSnowflake(toDateTime('2022-06-15 12:30:00')) AS snowflake_id, COUNT(*) FROM test_dates WHERE created_at IS NOT NULL GROUP BY snowflake_id HAVING snowflake_id IS NOT NULL;
WITH (SELECT MAX(created_at) FROM test_dates WHERE created_at IS NOT NULL) AS max_dt SELECT dateTimeToSnowflake(max_dt) AS max_snowflake_id;
SELECT DISTINCT dateTimeToSnowflake(COALESCE(created_at, '1970-01-01 00:00:00')) AS snowflake_id FROM test_dates WHERE created_at IS NOT NULL;