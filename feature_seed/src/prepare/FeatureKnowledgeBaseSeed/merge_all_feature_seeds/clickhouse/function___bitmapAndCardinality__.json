CREATE TABLE bitmaps_test (id UInt32, bitmap_data Array(UInt32));
INSERT INTO bitmaps_test VALUES (1, bitmapBuild([1, 2, 3])), (2, bitmapBuild([3, 4, 5])), (3, bitmapBuild([6, 7, 8]));
SELECT bitmapAndCardinality(bitmapBuild([1]), bitmapBuild([1])) AS res;
SELECT bitmapAndCardinality(bitmapBuild([1, 2, 3]), bitmapBuild([1, 2, 3, 4, 5])) AS res;
SELECT bitmapAndCardinality(bitmapBuild([]), bitmapBuild([1, 2])) AS res;
SELECT bitmapAndCardinality(bitmapBuild([1, 2, 3]), bitmapBuild([])) AS res;
SELECT bitmapAndCardinality(bitmapBuild([0]), bitmapBuild([0])) AS res;
SELECT bitmapAndCardinality(bitmapBuild([1, 1, 2, 2]), bitmapBuild([2, 2, 3, 4])) AS res;
SELECT (SELECT bitmapAndCardinality(bitmap_data[1], bitmap_data[2]) FROM bitmaps_test) AS nested_res;
SELECT bt1.id, bitmapAndCardinality(bt1.bitmap_data, bt2.bitmap_data) AS res FROM bitmaps_test AS bt1 JOIN bitmaps_test AS bt2 ON bt1.id != bt2.id;
SELECT bitmapAndCardinality(bitmapBuild([1, 2]), bitmapBuild([2, 3, 4])) AS res;
SELECT bitmapAndCardinality(bitmapBuild([100]), bitmapBuild([100, 200, 300])) AS res;
SELECT COUNT(*) FROM (SELECT bitmapAndCardinality(bitmapBuild([1]), bitmapBuild([1])) AS res FROM bitmaps_test) AS temp WHERE res > 0;