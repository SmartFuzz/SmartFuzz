CREATE TABLE test_crc64 (id UInt32, data String) ENGINE = Memory;
INSERT INTO test_crc64 VALUES (1, 'test_string'), (2, 'another_string'), (3, 'averyverylongteststringthatextendsbeyondusuallimits'), (4, 'short'), (5, ' '), (6, '');
SELECT id, CRC64(data) AS checksum FROM test_crc64;
SELECT id, CRC64(data) AS checksum FROM (SELECT * FROM test_crc64 WHERE id > 2);
SELECT t1.id, CRC64(t1.data) AS checksum, t2.id AS another_id FROM test_crc64 t1 JOIN test_crc64 t2 ON t1.id > t2.id;
SELECT id, CRC64(data || CAST(id AS String)) AS complex_checksum FROM test_crc64;
SELECT id, CRC64(data) AS checksum FROM test_crc64 WHERE id IN (SELECT id FROM test_crc64 WHERE id % 2 = 0);
WITH (SELECT '', 'string_example') AS strings_list SELECT CRC64(str) AS string_checksum FROM strings_list;
SELECT id, CRC64(data) AS checksum FROM (SELECT data FROM test_crc64 WHERE length(data) <= 20) AS subquery;
SELECT id, count() AS occurrences, CRC64(data) AS checksum FROM test_crc64 GROUP BY data HAVING occurrences > 1;