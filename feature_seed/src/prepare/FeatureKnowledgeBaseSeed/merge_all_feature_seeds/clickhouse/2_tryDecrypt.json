CREATE TABLE decrypt_test (dt DateTime, user_id UInt32, encrypted String, iv String) ENGINE = Memory;
INSERT INTO decrypt_test VALUES ('2022-08-02 00:00:00', 1, encrypt('aes-256-gcm', 'value1', 'keykeykeykeykeykeykeykeykeykey01', 'iv1'), 'iv1'), ('2022-09-02 00:00:00', 2, encrypt('aes-256-gcm', 'value2', 'keykeykeykeykeykeykeykeykeykey02', 'iv2'), 'iv2'), ('2022-09-02 00:00:01', 3, encrypt('aes-256-gcm', 'value3', 'keykeykeykeykeykeykeykeykeykey03', 'iv3'), 'iv3');
SELECT user_id, tryDecrypt('aes-256-gcm', encrypted, 'wrongkeywrongkeywrongkeywrongkey01', iv) AS value FROM decrypt_test WHERE value IS NOT NULL ORDER BY user_id ASC;
SELECT dt, user_id, tryDecrypt('aes-256-gcm', encrypted, 'keykeykeykeykeykeykeykeykeykey01', iv) AS decrypted_value FROM decrypt_test WHERE decrypted_value <> 'value1' AND dt < '2022-09-01 00:00:00';
SELECT user_id, COUNT(*) FROM (SELECT user_id, tryDecrypt('aes-256-gcm', encrypted, 'keykeykeykeykeykeykeykeykeykey02', iv) AS decrypted_value FROM decrypt_test) sub WHERE decrypted_value IS NOT NULL GROUP BY user_id HAVING COUNT(*) <> 0;
SELECT user_id FROM decrypt_test WHERE dt = (SELECT max(dt) FROM decrypt_test) AND tryDecrypt('aes-256-gcm', encrypted, 'keykeykeykeykeykeykeykeykeykey03', iv) IS NULL;
CREATE TABLE temp_decrypt_test AS SELECT *, tryDecrypt('aes-256-gcm', encrypted, 'keykeykeykeykeykeykeykeykeykey01', iv) AS decrypted FROM decrypt_test;
INSERT INTO temp_decrypt_test SELECT dt, user_id, encrypted, iv FROM decrypt_test WHERE tryDecrypt('aes-256-gcm', encrypted, 'wrongkeywrongkeywrongkeywrongkey02', iv) IS NULL;
SELECT user_id, COUNT(*) FROM decrypt_test GROUP BY user_id HAVING tryDecrypt('aes-256-gcm', encrypted, 'keykeykeykeykeykeykeykeykeykey02', iv) <> 'value2';
CREATE TABLE decrypt_edge_cases (dt DateTime, user_id UInt32, encrypted String, iv String) ENGINE = Memory;
INSERT INTO decrypt_edge_cases VALUES ('2022-01-01 00:00:00', 0, '', ''), ('2022-01-01 00:00:01', 0, encrypt('aes-256-gcm', 'value_edge', '', ''), '');
SELECT user_id, tryDecrypt('aes-256-gcm', encrypted, 'keykeykeykeykeykeykeykeykeykey01', iv) AS value FROM decrypt_edge_cases WHERE user_id <> 0;