CREATE TABLE response_data (response_time FLOAT, weight INT) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO response_data VALUES (200, 1), (600, 2), (1200, 1), (30000, 1), (15000, 1), (32000, 1);
SELECT quantileTimingWeighted(0.5)(response_time, weight) FROM response_data;
SELECT quantileTimingWeighted(0.75)(response_time, weight) FROM response_data;
SELECT quantileTimingWeighted(0.99)(response_time, weight) FROM response_data WHERE response_time < 30000;
SELECT quantileTimingWeighted(0.01)(response_time, weight) FROM response_data WHERE weight > 1;
SELECT quantileTimingWeighted(0.5)(AVG(response_time), SUM(weight)) FROM (SELECT response_time, weight FROM response_data WHERE response_time < 30000);
SELECT quantileTimingWeighted(0.5)(response_time, weight) FROM (SELECT response_time, weight FROM response_data WHERE weight > 0) AS filtered_data;
CREATE TABLE response_data_2 (response_time FLOAT, weight INT) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO response_data_2 VALUES (100, 3), (300, 2), (1700, 1);
SELECT q1.quantile, q2.quantile FROM (SELECT quantileTimingWeighted(0.75)(response_time, weight) AS quantile FROM response_data) AS q1, (SELECT quantileTimingWeighted(0.5)(response_time, weight) AS quantile FROM response_data_2) AS q2;
SELECT quantileTimingWeighted(0.95)(response_time, weight) FROM (SELECT response_time, weight FROM response_data UNION ALL SELECT response_time, weight FROM response_data_2);
SELECT quantileTimingWeighted(0.5)(response_time, weight) FROM response_data WHERE response_time < 1000;
SELECT quantileTimingWeighted(0.5)(response_time, weight) FROM response_data WHERE weight < 5 GROUP BY weight;
SELECT quantileTimingWeighted(0.5)(response_time, weight) FROM response_data GROUP BY weight ORDER BY weight;
SELECT quantileTimingWeighted(0.5)(response_time, weight) + 100 FROM response_data WHERE response_time >= 0;