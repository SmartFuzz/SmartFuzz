CREATE TABLE test_strings (haystack String, needle String);
INSERT INTO test_strings VALUES ('ClickHouse', 'ClickHouse!');
INSERT INTO test_strings VALUES ('ClickHouse', 'House');
INSERT INTO test_strings VALUES ('Hello World', 'Hello');
INSERT INTO test_strings VALUES ('Sample Text', 'Sample Texts');
INSERT INTO test_strings VALUES (REPEAT('a', 32000), REPEAT('a', 32000));
INSERT INTO test_strings VALUES ('Short', 'Longer String');
SELECT ngramDistance(haystack, needle) FROM test_strings;
SELECT *, ngramDistance(haystack, needle) AS distance FROM test_strings WHERE distance < 0.5;
SELECT haystack, needle, ngramDistance(haystack, needle) AS distance FROM test_strings WHERE distance BETWEEN 0 AND 1;
SELECT ngramDistance('ClickHouse is fast', 'ClickHouse is awesome!') AS distance;
SELECT ngramDistanceCaseInsensitive(haystack, needle) FROM test_strings;
SELECT ngramDistanceUTF8(haystack, needle) FROM test_strings;
SELECT ngramDistanceCaseInsensitiveUTF8(haystack, needle) FROM test_strings;
SELECT CASE WHEN ngramDistance(haystack, needle) < 0.1 THEN 'Very Similar' ELSE 'Different' END AS similarity FROM test_strings;
SELECT haystack, needle FROM test_strings WHERE ngramDistance(haystack, needle) = 1;
SELECT AVG(ngramDistance(haystack, needle)) FROM test_strings;
WITH (SELECT haystack FROM test_strings WHERE LENGTH(haystack) > 10) AS haystack_long FROM test_strings WHERE ngramDistance(haystack_long, needle) < 0.2;
CREATE TABLE test_results AS SELECT haystack, needle, ngramDistance(haystack, needle) AS distance FROM test_strings;
SELECT AVG(distance) FROM (SELECT ngramDistance(haystack, needle) AS distance FROM test_strings GROUP BY haystack, needle);