CREATE TABLE test_table (input_value String, default_value UInt32);
INSERT INTO test_table VALUES ('32', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('abc', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('-10', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('4294967295', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('4294967296', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('3.14', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('NaN', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('Inf', CAST('0', 'UInt32'));
INSERT INTO test_table VALUES ('0xc0fe', CAST('0', 'UInt32'));
SELECT input_value, toUInt32OrDefault(input_value, default_value) FROM test_table;
SELECT toUInt32OrDefault(input_value, CAST('0', 'UInt32')) AS converted_value FROM (SELECT input_value FROM test_table) WHERE default_value < 100;
SELECT toUInt32OrDefault(input_value, CAST('1', 'UInt32')) AS converted_value FROM (SELECT input_value FROM test_table WHERE input_value NOT LIKE 'abc%') ORDER BY converted_value;
SELECT toUInt32OrDefault(input_value, CAST('MaxValue', 'UInt32')) FROM (SELECT input_value FROM test_table) GROUP BY input_value;
CREATE TABLE alt_test_table AS SELECT input_value, toUInt32OrDefault(input_value) AS converted_value FROM test_table WHERE default_value = 0;