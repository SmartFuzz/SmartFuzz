CREATE TABLE test_data (id Int32, value Int32);
INSERT INTO test_data VALUES (1, 10), (2, 20), (3, 30), (4, 40);
CREATE TABLE subquery_data (threshold Int32);
INSERT INTO subquery_data VALUES (15), (25);
SELECT * FROM test_data WHERE value != ANY (SELECT threshold FROM subquery_data);
SELECT id FROM test_data WHERE id != ANY (SELECT DISTINCT value FROM test_data WHERE value > 20);
CREATE TABLE user_data (user_id Int32, role_id Int32);
INSERT INTO user_data VALUES (1, 100), (2, 200), (3, 300);
SELECT user_id FROM user_data WHERE role_id != ANY (SELECT role_id FROM user_data WHERE user_id = 2);
SELECT id FROM test_data WHERE id != ANY (SELECT value FROM subquery_data WHERE threshold < 20);
SELECT id, value FROM test_data WHERE value != ANY (SELECT value FROM (SELECT DISTINCT value FROM test_data WHERE value < 25));
SELECT * FROM test_data WHERE value NOT IN (SELECT DISTINCT NOT id FROM test_data WHERE id > 2);