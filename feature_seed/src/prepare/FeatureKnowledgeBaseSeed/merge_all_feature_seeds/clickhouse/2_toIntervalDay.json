CREATE TABLE test_table (id UInt32, start_date Date, duration String, value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, '2024-06-15', '5', 100.25), (2, '2024-06-20', '10', NULL), (3, '2024-06-25', '15.5', 200.75);
SELECT id, start_date + toIntervalDay(CAST(duration AS Int32)) AS new_date FROM test_table WHERE value = ANY (SELECT value FROM test_table WHERE value IS NOT NULL);
WITH start_date AS (SELECT start_date FROM test_table WHERE id = 1) SELECT start_date + toIntervalDay(0) AS same_date FROM start_date;
SELECT SUM(value) AS total_value, start_date + toIntervalDay(MAX(CAST(duration AS Float32))) AS max_duration_date FROM test_table GROUP BY start_date HAVING total_value > 50.0;
SELECT id, COUNT(*) AS count FROM (SELECT id, start_date + toIntervalDay(CAST(duration AS Int32)) AS new_date FROM test_table) AS subquery GROUP BY id HAVING count > ANY (SELECT COUNT(*) FROM test_table);