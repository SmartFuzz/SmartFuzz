CREATE TABLE test_table (value String);
INSERT INTO test_table VALUES ('100');
INSERT INTO test_table VALUES ('-8');
INSERT INTO test_table VALUES ('256');
INSERT INTO test_table VALUES ('abc');
INSERT INTO test_table VALUES ('3.14');
INSERT INTO test_table VALUES ('1e10');
INSERT INTO test_table VALUES ('-3.5');
INSERT INTO test_table VALUES ('0xc0fe');
INSERT INTO test_table VALUES ('NaN');
INSERT INTO test_table VALUES ('Inf');
SELECT toUInt8OrZero(value) FROM test_table;
SELECT toUInt8OrZero('200') AS num, COUNT(*) FROM test_table GROUP BY num;
SELECT id, toUInt8OrZero(value) AS converted_value FROM (SELECT 1 AS id, '-15' AS value) UNION SELECT 2, '0' ORDER BY id;
SELECT (SELECT toUInt8OrZero(value) FROM test_table WHERE value = '100') + (SELECT toUInt8OrZero(value) FROM test_table WHERE value = 'abc') AS result;
CREATE TABLE test_join (x String);
INSERT INTO test_join VALUES ('50'), ('-1'), ('Inf');
SELECT t.value, j.x, toUInt8OrZero(t.value) + toUInt8OrZero(j.x) AS total FROM test_table t JOIN test_join j ON t.value = '50' OR j.x = '-1';
SELECT CASE WHEN toUInt8OrZero(value) > 200 THEN 'High' ELSE 'Low' END AS category FROM test_table;