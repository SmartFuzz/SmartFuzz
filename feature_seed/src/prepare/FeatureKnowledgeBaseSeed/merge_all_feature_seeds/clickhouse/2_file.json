CREATE TABLE test_files (id Int32, content String, difference Float64);
INSERT INTO test_files SELECT number, file(concat('file', number, '.txt')), number - 1.5 FROM system.numbers LIMIT 10;
CREATE TABLE test_numbers (num1 Float64, num2 Float64, result Float64);
INSERT INTO test_numbers SELECT number, number * 2, number + 5.5 - number FROM system.numbers LIMIT 10;
SELECT id, content, difference, IF(difference IS NULL, 'missing', 'present') AS status FROM test_files WHERE difference < 0;
SELECT num1, num2, result FROM test_numbers HAVING result IS NOT NULL AND result > 5.5;
CREATE TABLE test_boundary (key Int32, value Nullable(Float64));
INSERT INTO test_boundary SELECT number, NULLIF(number - 10, 0) FROM system.numbers WHERE number < 15;
SELECT key, file(concat('path/to/file_', key, '.txt')) AS file_content, value FROM test_boundary WHERE value IS NOT NULL AND key - 2 < 5;
SELECT key, COUNT(*) AS count FROM test_boundary GROUP BY key HAVING count > 1;
CREATE TABLE complex_test (x Nullable(Int32), y Nullable(Int32));
INSERT INTO complex_test SELECT number % 5, number FROM system.numbers LIMIT 20;
SELECT *, file('does_not_exist.txt') AS file_error FROM complex_test WHERE x IS NOT NULL AND (y - x) > 0;