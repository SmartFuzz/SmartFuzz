CREATE TABLE test_table (id Int32, array_col Array(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, [10, 20, 30]), (2, [40, 50]), (3, [60]);
SELECT id, arrayJoin(array_col) AS array_element FROM test_table;
CREATE TABLE another_table (session_id Int32, goals Array(Int32)) ENGINE = MergeTree() ORDER BY session_id;
INSERT INTO another_table VALUES (1, [101, 102]), (2, [103]), (3, [104, 105, 106]);
SELECT session_id, arrayJoin(goals) AS goal_id FROM another_table;
SELECT t.id, t.array_col, a.goal_id FROM test_table t LEFT ARRAY JOIN another_table a ON t.id = a.session_id;
SELECT t.id, arrayJoin(t.array_col) AS array_elem, COUNT(DISTINCT a.goal_id) FROM test_table t LEFT ARRAY JOIN another_table a ON t.id = a.session_id GROUP BY t.id, array_elem;
CREATE TABLE complex_table (user_id Int32, actions Array(String), timestamps Array(DateTime)) ENGINE = MergeTree() ORDER BY user_id;
INSERT INTO complex_table VALUES (1, ['click', 'scroll', 'view'], [NOW(), NOW() - INTERVAL 1 HOUR, NOW() - INTERVAL 2 HOURS]);
SELECT user_id, arrayJoin(actions) AS action_type, arrayJoin(timestamps) AS action_time FROM complex_table;
SELECT user_id, actions[1] AS first_action FROM complex_table WHERE arrayJoin(actions) = 'click';
SELECT t.id, t.array_col, COUNT(*) FROM test_table t ARRAY JOIN (SELECT a.goal_id FROM another_table a) AS a GROUP BY t.id, t.array_col;
SELECT e.id, arrayJoin(e.nested_col) AS nested_element FROM (SELECT id, arrayJoin(array_col) AS nested_col FROM test_table) e;
CREATE TABLE nested_table (id Int32, nested Array(Array(Int32))) ENGINE = MergeTree() ORDER BY id;
INSERT INTO nested_table VALUES (1, [[1, 2], [3, 4]]), (2, [[5]]);
SELECT id, arrayJoin(nested) AS inner_array FROM nested_table ARRAY JOIN arrayJoin(inner_array) AS value;
CREATE TABLE mixed_table (event_id Int32, event_type Array(String), counts Array(Int32)) ENGINE = MergeTree() ORDER BY event_id;
INSERT INTO mixed_table VALUES (1, ['click', 'view'], [3, 5]), (2, ['scroll'], [1]);
SELECT event_id, event_type, counts FROM mixed_table ARRAY JOIN event_type, counts;
SELECT id, arrayJoin(arrayJoin(goals)) AS goal_id FROM another_table;
SELECT id, arrayJoin(arrayJoin(array_col)) FROM test_table;
CREATE TABLE complex_arrays (user_id Int32, mixed_array Array(Array(String))) ENGINE = MergeTree() ORDER BY user_id;
INSERT INTO complex_arrays VALUES (1, [['open', 'close'], ['play', 'pause']]), (2, [['reset']]);
SELECT user_id, arrayJoin(mixed_array) AS array_item FROM complex_arrays;
SELECT id, total_count FROM (SELECT id, COUNT(arrayJoin(array_col)) AS total_count FROM test_table GROUP BY id) WHERE total_count > 1;