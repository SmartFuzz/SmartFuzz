CREATE TABLE test_table (id UInt32, value1 Int32, value2 Int32, value3 String, created_at DateTime);
INSERT INTO test_table (id, value1, value2, value3, created_at) VALUES (1, 10, 20, '2023-10-01 12:00:00', '2023-10-01 12:00:00');
INSERT INTO test_table (id, value1, value2, value3, created_at) VALUES (2, 5, 25, '', '2023-10-01 00:00:00');
INSERT INTO test_table (id, value1, value2, value3, created_at) VALUES (3, NULL, 30, '2023-10-01 11:00:00', '2023-10-01 11:00:00');
SELECT *, greater(value1, value2) AS comparison_result FROM test_table WHERE created_at IS NOT NULL;
SELECT id, value1 % (greater(value2, 10) + 1) AS mod_result FROM test_table HAVING mod_result > 0;
SELECT id, (greater(value1, value2) AND (value2 % 3 = 0)) AS logical_result FROM test_table WHERE value3 != '';
SELECT id, value1, (SELECT avg(value1) FROM test_table WHERE value2 > 15) AS subquery_avg FROM test_table WHERE greater(value1, (SELECT max(value1) FROM test_table));
SELECT id, value3, (greatest(value1, value2) % 5) AS edge_case_mod FROM test_table GROUP BY value3 HAVING edge_case_mod < 3;
SELECT id, value1, value2, (greatest(0, value1) % (ifNull(value2, 1) + 1)) AS safe_mod FROM test_table WHERE greater(value1, 0) OR value2 IS NULL;