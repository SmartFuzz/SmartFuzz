CREATE TABLE LEFT_RIGHT (left Integer, right Integer) ENGINE = MergeTree() ORDER BY left;
INSERT INTO LEFT_RIGHT (left, right) VALUES (1, 2), (NULL, 2), (3, NULL), (4, 1), (5, 5);
SELECT left, right, left < right AS is_small, -left AS negated_left FROM LEFT_RIGHT WHERE (left IS NOT NULL OR right IS NOT NULL);
SELECT left, right, -(-left) AS double_negated, (SELECT COUNT() FROM LEFT_RIGHT) AS total_count FROM LEFT_RIGHT HAVING total_count > 1;
SELECT AVG(CASE WHEN left IS NULL THEN 0 ELSE left END) AS avg_left, MAX(right) AS max_right FROM LEFT_RIGHT GROUP BY right HAVING avg_left < 3;
SELECT left, right, left < right AS is_small, (SELECT SUM(-a) FROM (SELECT -right AS a) AS subquery) AS negated_sum FROM LEFT_RIGHT;
CREATE TABLE TEST_TYPE_CAST (a String, b Float32) ENGINE = MergeTree() ORDER BY a;
INSERT INTO TEST_TYPE_CAST (a, b) VALUES ('10', 10.0), (NULL, NULL), ('-5', -5.5), ('3.14', 3.14);
SELECT a, b, a < CAST(b AS String) AS is_a_smaller FROM TEST_TYPE_CAST WHERE a IS NOT NULL;
SELECT COUNT(*) AS neg_count FROM LEFT_RIGHT WHERE -left < right GROUP BY right HAVING neg_count > 1;