CREATE TABLE test_array_operators (id Int32, values Array(Int32), status Int8 DEFAULT 0);
INSERT INTO test_array_operators (id, values) VALUES (1, [1, 2, NULL, 4]), (2, [NULL, NULL]), (3, [3, 3, 3]), (4, []);
SELECT id, arrayExists(x -> x > 2 ? 1 : 0, values) AS exists_greater_than_2 FROM test_array_operators;
SELECT id, countIf(arrayExists(x -> x IS NULL ? 1 : 0, values)) AS count_nulls FROM test_array_operators GROUP BY id HAVING count_nulls > 0;
SELECT id, arrayExists(x -> x == 0 ? status : 1, values) AS flag_zero_if_status_zero FROM test_array_operators WHERE status = (CASE WHEN id < 3 THEN 0 ELSE 1 END);
CREATE TABLE temp_data (group_id Int32, data Array(String));
INSERT INTO temp_data (group_id, data) VALUES (1, ['test', 'example']), (2, ['NULL', '']);
SELECT group_id, arrayExists(x -> x IS NOT NULL ? 1 : 0, data) AS has_non_null FROM temp_data GROUP BY group_id ORDER BY has_non_null DESC;
SELECT id, arrayExists(x -> x > (SELECT MAX(id) FROM test_array_operators ? 1 : 0), values) AS check_max_value FROM test_array_operators;
SELECT id, arrayExists(x -> x == 5 ? (SELECT AVG(values[1]) FROM test_array_operators) : 0, values) AS avg_if_five FROM test_array_operators;