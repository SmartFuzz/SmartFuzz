CREATE TABLE test_table (id UInt32, value String, amount Float64, created_at DateTime);
INSERT INTO test_table VALUES (1, '100.12345', 150.6789, now()), (2, 'invalid_value', 200.0, now()), (3, '50.1', NULL, now());
SELECT id, toDecimal32(value, 5) AS decimal_value FROM test_table WHERE amount GLOBAL NOT IN (SELECT amount FROM test_table WHERE created_at < now() - INTERVAL 1 DAY);
SELECT id, value, toDecimal32(amount, 3) AS decimal_amount FROM test_table WHERE decimal_amount GLOBAL NOT IN (SELECT toDecimal32(value, 2) FROM test_table WHERE value IS NOT NULL) AND created_at = (SELECT max(created_at) FROM test_table);
CREATE TABLE test_table_2 (id UInt32, related_id UInt32, foreign_value Float64);
INSERT INTO test_table_2 VALUES (1, 1, 123456.789), (2, 1, 1.23456789), (3, 2, 987654.321);
SELECT t1.id, t1.value, t1.amount, toDecimal32(t1.amount, 4) AS decimal_amount FROM test_table t1 JOIN test_table_2 t2 ON t1.id = t2.related_id WHERE t1.value GLOBAL NOT IN (SELECT related_value FROM (SELECT toDecimal32(amount, 2) AS related_value FROM test_table_2));
SELECT t1.id, toDecimal32(MAX(amount), 1) AS max_decimal FROM test_table t1 GROUP BY t1.id HAVING max_decimal GLOBAL NOT IN (SELECT toDecimal32(related_value, 0) FROM test_table_2) ORDER BY max_decimal DESC;
SELECT id, toDecimal32(value, 6) AS decimal_value FROM test_table WHERE COALESCE(decimal_value, 0) != 0 GLOBAL NOT IN (SELECT toDecimal32('50.0001', 4));
SELECT id FROM (SELECT id, toDecimal32('12345.6789', 4) AS converted FROM test_table) AS inner_query WHERE converted GLOBAL NOT IN (SELECT toDecimal32(value, 3) FROM test_table WHERE value IS NOT NULL);