CREATE TABLE bitmaps_table (id UInt32, bitmap_col Bitmap(32));
INSERT INTO bitmaps_table VALUES (1, bitmapBuild([1, 2, 3])), (2, bitmapBuild([3, 4, 5])), (3, bitmapBuild([6, 7, 8]));
SELECT bitmapHasAny(bitmap_col, bitmapBuild([3, 4, 5])) AS res FROM bitmaps_table WHERE id = 1;
SELECT id, bitmapHasAny(bitmap_col, bitmapBuild([2])) AS res FROM bitmaps_table;
SELECT id, bitmapHasAny(bitmap_col, bitmapBuild([])) AS res FROM bitmaps_table;
SELECT id, bitmapHasAny(bitmapBuild([1, 2, 3]), bitmapBuild([2, 3, 4])) AS res FROM bitmaps_table WHERE id = 1;
SELECT id, bitmapHasAny(bitmap_col, aggregationBitmap(bitmap_col)) AS res FROM bitmaps_table GROUP BY id;
SELECT bitmapHasAny(bitmapBuild([1, 2, 3]), (SELECT bitmapBuild([3, 4, 5]) FROM bitmaps_table WHERE id = 2)) AS res;
SELECT count() AS intersection_count FROM bitmaps_table WHERE bitmapHasAny(bitmap_col, bitmapBuild([3])) = 1;
SELECT bitmapHasAny(NULL, bitmapBuild([1])) AS res;
SELECT bitmapHasAny(bitmapBuild([1, 2, 3]), bitmapBuild([1, 2, 3])) AS res FROM bitmaps_table WHERE id IN (SELECT id FROM bitmaps_table WHERE id < 3);