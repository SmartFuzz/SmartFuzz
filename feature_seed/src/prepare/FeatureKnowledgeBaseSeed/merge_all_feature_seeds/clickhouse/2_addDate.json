CREATE TABLE test_dates (id UInt32, created_at DateTime, event_date Date, description String);
INSERT INTO test_dates VALUES (1, toDateTime('2022-01-01 10:15:30'), toDate('2022-01-01'), 'New Year Event');
INSERT INTO test_dates VALUES (2, toDateTime('2022-02-28 09:05:00'), toDate('2022-02-28'), 'February Event');
INSERT INTO test_dates VALUES (3, toDateTime('2022-03-15 14:45:20'), toDate('2022-03-15'), 'Spring Event');
SELECT id, addDate(EXTRACT(YEAR FROM created_at), INTERVAL 2 YEAR) AS future_year FROM test_dates WHERE description LIKE 'Event%';
SELECT id, ADDDATE(created_at, INTERVAL EXTRACT(MONTH FROM event_date) MONTH) AS adjusted_date FROM test_dates WHERE event_date IS NOT NULL;
SELECT id, EXTRACT(DAY FROM addDate(event_date, INTERVAL 1 MONTH)) AS next_month_day FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE description LIKE 'February%');
SELECT id, EXTRACT(MONTH FROM addDate(toDate('2020-12-31'), INTERVAL -1 DAY)) AS last_month FROM test_dates HAVING last_month = 12;
WITH (SELECT toDate('2020-01-01') AS ref_date) AS dates_ref SELECT id, addDate(ref_date, INTERVAL EXTRACT(YEAR FROM created_at) YEAR) AS anniversary FROM test_dates;
SELECT t1.id, EXTRACT(YEAR FROM t1.created_at) AS year, addDate(t1.created_at, INTERVAL EXTRACT(DAY FROM t2.event_date) DAY) AS date_adjust FROM test_dates t1 JOIN test_dates t2 ON t1.id != t2.id WHERE EXTRACT(MONTH FROM t1.created_at) = 1;
CREATE TABLE test_dates_nulls (id UInt32, event_date Nullable(Date), event_time Nullable(DateTime));
INSERT INTO test_dates_nulls VALUES (1, NULL, NULL);
INSERT INTO test_dates_nulls VALUES (2, toDate('2021-11-15'), toDateTime('2021-11-15 10:30:00'));
SELECT id, addDate(event_date, INTERVAL 1 YEAR) AS next_year FROM test_dates_nulls WHERE event_date IS NOT NULL;
SELECT id, addDate(NULLIF(event_date, toDate('2021-11-15')), INTERVAL EXTRACT(MONTH FROM event_time) MONTH) AS adjusted_year FROM test_dates_nulls;
DROP TABLE IF EXISTS test_dates;
DROP TABLE IF EXISTS test_dates_nulls;