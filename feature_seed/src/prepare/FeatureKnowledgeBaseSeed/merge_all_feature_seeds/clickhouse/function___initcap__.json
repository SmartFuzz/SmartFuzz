CREATE TABLE test_strings (input STRING, expected STRING);
INSERT INTO test_strings VALUES ('hello world', 'Hello World');
INSERT INTO test_strings VALUES ('john DOE', 'John Doe');
INSERT INTO test_strings VALUES ('mother''s daughter', 'Mother''S Daughter');
INSERT INTO test_strings VALUES ('   leading spaces', '   Leading Spaces');
INSERT INTO test_strings VALUES ('trailing spaces   ', 'Trailing Spaces   ');
INSERT INTO test_strings VALUES ('  mixed  CASE  ', '  Mixed  Case  ');
INSERT INTO test_strings VALUES ('!@#$%^&*()', '!@#$%^&*()');
INSERT INTO test_strings VALUES ('123 apples', '123 Apples');
INSERT INTO test_strings VALUES ('a''b c''d e''f', 'A''B C''D E''F');
INSERT INTO test_strings VALUES ('singleword', 'Singleword');
INSERT INTO test_strings VALUES ('', '');
SELECT input, initcap(input) AS result, expected FROM test_strings;
SELECT initcap(CONCAT(a.field1, ' ', b.field2)) FROM table1 a JOIN table2 b ON a.id = b.id;
SELECT initcap(STRING_AGG(input, ' ')) FROM test_strings GROUP BY input;
WITH (SELECT input FROM test_strings) AS subquery SELECT initcap(input) FROM subquery;
SELECT input, initcap(input) AS result FROM test_strings WHERE expected != initcap(input);
SELECT initcap('get ready: be prepared!') AS formatted_string;
SELECT initcap('here.we-go!') AS formatted_string_with_periods;