CREATE TABLE subquery_table (value Int32);
INSERT INTO subquery_table VALUES (1), (2), (3), (4);
CREATE TABLE main_table (a Int32);
INSERT INTO main_table VALUES (1), (2), (3);
SELECT a FROM main_table WHERE a = ALL (SELECT value FROM subquery_table);
CREATE TABLE complex_subquery (id Int32, grp Int32);
INSERT INTO complex_subquery VALUES (1, 1), (2, 1), (3, 2), (4, 2);
SELECT id FROM complex_subquery WHERE grp = ALL (SELECT grp FROM complex_subquery WHERE id IN (1, 2));
SELECT a FROM main_table WHERE a = ALL (SELECT value + 10 FROM subquery_table);
SELECT a FROM main_table WHERE a = ALL (SELECT DISTINCT value FROM subquery_table WHERE value < 5);
CREATE TABLE another_table (y Int32, z Int32);
INSERT INTO another_table VALUES (3, 3), (4, 4), (1, 1);
SELECT y FROM another_table WHERE y = ALL (SELECT z FROM another_table WHERE y < 5);
SELECT a FROM main_table WHERE a = ALL (SELECT MAX(value) FROM subquery_table GROUP BY value);
CREATE TABLE final_table (b Int32);
INSERT INTO final_table VALUES (1), (2), (3), (4);
SELECT b FROM final_table WHERE b = ALL (SELECT COUNT(*) FROM final_table GROUP BY b HAVING b < 5);