CREATE TABLE test_vectors (id Int32, vector Tuple(Float64, Float64), label String);
INSERT INTO test_vectors VALUES (1, (1.0, 2.0), 'A'), (2, (2.0, 3.0), 'B'), (3, (0.0, 1.0), 'C'), (4, (1.0, 1.0), 'D');
SELECT id, cosineDistance(vector, (1, 1)) AS distance FROM test_vectors WHERE distance = ANY (SELECT distance FROM (SELECT cosineDistance(vector, (1, 1)) AS distance FROM test_vectors WHERE label = 'A'));
SELECT COUNT(*) FROM test_vectors WHERE cosineDistance(vector, (0.0, 0.0)) >= 0.5 GROUP BY label HAVING COUNT(*) > 0;
SELECT a.id, cosineDistance(a.vector, b.vector) AS distance FROM test_vectors AS a JOIN test_vectors AS b ON a.id != b.id WHERE distance <= 1.0 AND a.vector = ANY (SELECT vector FROM test_vectors WHERE label = 'B');
SELECT label, cosineDistance((1.0, NULL), (NULL, 1.0)) AS null_distance FROM test_vectors GROUP BY label HAVING null_distance IS NOT NULL;
CREATE TABLE temp_vectors AS SELECT vector FROM test_vectors WHERE label = '';
INSERT INTO temp_vectors VALUES ((2.5, 3.5));
SELECT cosineDistance(vector, (2.0, 2.0)) FROM temp_vectors ORDER BY cosineDistance(vector, (0.0, 0.0)) DESC LIMIT 1;