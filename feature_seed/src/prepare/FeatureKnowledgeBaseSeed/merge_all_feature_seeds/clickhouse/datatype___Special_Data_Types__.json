CREATE TABLE special_types_test (id UInt32, val Float32, special_val Tuple(String, Int32));
INSERT INTO special_types_test VALUES (1, 3.14, ('Test', 1));
INSERT INTO special_types_test VALUES (2, 2.71, ('Example', 2));
SELECT id, val, special_val FROM special_types_test;
SELECT id, val, special_val.1 FROM special_types_test WHERE special_val.2 > 0;
SELECT id, val + 1.0 AS incremented_val, special_val FROM special_types_test WHERE special_val.1 LIKE 'Te%';
CREATE TABLE other_table (id UInt32, extra_val String);
INSERT INTO other_table VALUES (1, 'Extra1'), (2, 'Extra2');
SELECT s.id, s.val, o.extra_val FROM special_types_test AS s JOIN other_table AS o ON s.id = o.id WHERE s.special_val.2 = o.id;
SELECT id, val, special_val FROM special_types_test WHERE special_val.1 IN (SELECT extra_val FROM other_table);
SELECT id, special_val FROM special_types_test WHERE (SELECT COUNT() FROM other_table) > 1 AND special_val.2 > 0;