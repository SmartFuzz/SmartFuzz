CREATE TABLE test_float32 (val String);
INSERT INTO test_float32 VALUES ('42.7'), ('NaN'), ('Inf'), ('-Inf'), ('0'), ('-0'), ('1e10'), ('3.14'), ('-3.14');
SELECT toFloat32(val) FROM test_float32;
SELECT toFloat32(val) AS float_value FROM test_float32 WHERE float_value > 0;
CREATE TABLE test_nested (id Int32, str_val String);
INSERT INTO test_nested VALUES (1, '2.5'), (2, 'NaN'), (3, 'Inf'), (4, '0'), (5, '3e3');
SELECT id, toFloat32(str_val) FROM test_nested WHERE id IN (SELECT id FROM test_nested WHERE str_val != 'NaN');
SELECT toFloat32(s.val) FROM (SELECT str_val AS val FROM test_nested) AS s WHERE s.val = '3.14';
CREATE TABLE test_join (id Int32, float_value Float32);
INSERT INTO test_join VALUES (1, toFloat32('2.5')), (2, toFloat32('3.5')), (3, toFloat32('NaN'));
SELECT j.id, j.float_value FROM test_join AS j INNER JOIN test_float32 AS tf ON j.float_value > toFloat32(tf.val);
SELECT toFloat32((SELECT str_val FROM test_nested WHERE id = 1)) AS result;
SELECT toFloat32(42.7 + toFloat32('3.5')) AS combined_value;