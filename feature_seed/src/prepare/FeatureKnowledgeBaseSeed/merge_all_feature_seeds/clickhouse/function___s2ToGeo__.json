CREATE TABLE GeoPoints (s2index UInt64, description String);
INSERT INTO GeoPoints VALUES (4704772434919038107, 'Example Point 1');
INSERT INTO GeoPoints VALUES (0, 'Example Point 2');
INSERT INTO GeoPoints VALUES (18446744073709551615, 'Boundary Point');
SELECT s2ToGeo(s2index) FROM GeoPoints;
SELECT s2ToGeo(s2index) AS coordinates FROM GeoPoints WHERE s2index > 0;
SELECT s2ToGeo(s2index) AS coordinates FROM GeoPoints WHERE description LIKE 'Example%';
SELECT g1.s2index, g1.description, s2ToGeo(g1.s2index) AS geo_coordinates FROM GeoPoints AS g1 JOIN GeoPoints AS g2 ON g1.s2index = g2.s2index WHERE g1.description = 'Example Point 1';
WITH (SELECT s2index FROM GeoPoints WHERE description = 'Boundary Point') AS boundary_index SELECT s2ToGeo(boundary_index) AS boundary_coordinates;
SELECT s2ToGeo(s2index + 1) FROM GeoPoints WHERE s2index IN (SELECT s2index FROM GeoPoints WHERE description = 'Example Point 1');