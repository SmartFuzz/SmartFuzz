CREATE TABLE h3_indices (index UInt64);
INSERT INTO h3_indices VALUES (590080540275638271), (590103561300344831), (590080540275638272), (590080540275638273);
CREATE TABLE h3_test AS SELECT h3Line(start, end) AS indexes FROM (SELECT index AS start FROM h3_indices WHERE index = 590080540275638271) AS start_index, (SELECT index AS end FROM h3_indices WHERE index = 590103561300344831) AS end_index;
SELECT h3Line(590080540275638271, 590103561300344831) AS indexes;
SELECT h3Line(590080540275638271, 590080540275638281) AS indexes WHERE index = 590080540275638271;
SELECT h3Line((SELECT index FROM h3_indices LIMIT 1), (SELECT index FROM h3_indices LIMIT 1 OFFSET 1)) AS indexes;
WITH (SELECT count() FROM h3_indices) AS total FROM h3_indices GROUP BY total HAVING total > 0 ORDER BY total ASC;
SELECT arrayJoin(h3Line(590080540275638271, 590103561300344831)) AS index_line;
CREATE TABLE h3_results AS SELECT start, end, h3Line(start, end) AS line_indexes FROM (SELECT index AS start FROM h3_indices) AS starts, (SELECT index AS end FROM h3_indices) AS ends WHERE start < end;
SELECT start, end, h3Line(start, end) AS index_line FROM (SELECT index AS start FROM h3_indices) AS start_indexes JOIN (SELECT index AS end FROM h3_indices) AS end_indexes ON start_indexes.start < end_indexes.end;