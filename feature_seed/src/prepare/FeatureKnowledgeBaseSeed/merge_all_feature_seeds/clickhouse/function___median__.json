CREATE TABLE test_table (val Float64);
INSERT INTO test_table VALUES (1), (2), (3), (4), (5);
SELECT median(val) FROM test_table;
INSERT INTO test_table VALUES (NULL), (6), (7), (8), (9);
SELECT median(val) FROM test_table WHERE val IS NOT NULL;
CREATE TABLE another_table (id UInt32, val Float64);
INSERT INTO another_table VALUES (1, 1.5), (2, 2.5), (3, NULL), (4, 4.5);
SELECT median(val) FROM another_table WHERE id < 4;
SELECT median(val) FROM (SELECT val FROM test_table UNION ALL SELECT val FROM another_table);
CREATE TABLE multi_table (id UInt32, group_id UInt32, val Float64);
INSERT INTO multi_table VALUES (1, 1, 1), (2, 1, 2), (3, 1, 3), (4, 2, 4), (5, 2, 5);
SELECT group_id, median(val) FROM multi_table GROUP BY group_id;
SELECT id, median(val) OVER (PARTITION BY group_id) AS median_val FROM multi_table;
CREATE TABLE weighted_table (id UInt32, val Float64, weight Float64);
INSERT INTO weighted_table VALUES (1, 1, 1), (2, 2, 2), (3, 3, 3);
SELECT median(val) AS median_val FROM weighted_table;
SELECT median(val) AS weighted_median FROM weighted_table USING weight;
SELECT median(val) FROM (SELECT val FROM test_table WHERE val > 2) AS filtered;
SELECT a.id, median(b.val) FROM test_table AS a JOIN another_table AS b ON a.val = b.val GROUP BY a.id;