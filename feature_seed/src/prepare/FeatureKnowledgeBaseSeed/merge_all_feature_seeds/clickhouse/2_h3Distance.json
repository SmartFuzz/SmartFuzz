CREATE TABLE geospatial_indices (id UInt64, h3_index UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO geospatial_indices VALUES (1, 590080540275638271), (2, 590103561300344831), (3, NULL), (4, 0);
SELECT id, h3_index, h3Distance(h3_index, 590080540275638271) AS distance FROM geospatial_indices WHERE h3_index BETWEEN 590080540275638271 AND 590103561300344831;
SELECT id, h3_index, h3Distance(h3_index, 590103561300344831) AS distance FROM geospatial_indices WHERE h3Distance(h3_index, (SELECT MAX(h3_index) FROM geospatial_indices WHERE h3_index IS NOT NULL)) BETWEEN -1 AND 10;
SELECT id, h3_index, h3Distance(NULL, h3_index) AS distance, h3Distance(h3_index, NULL) AS distance_nulls FROM geospatial_indices WHERE h3_index BETWEEN (SELECT MIN(h3_index) FROM geospatial_indices WHERE h3_index IS NOT NULL) AND 590103561300344831;
SELECT id, h3_index, h3Distance(h3_index, h3_index + 1) AS distance FROM geospatial_indices WHERE distance BETWEEN 0 AND 5;
SELECT id, h3_index, h3Distance(h3_index, (SELECT MIN(h3_index) FROM geospatial_indices)) AS distance FROM geospatial_indices GROUP BY id, h3_index HAVING distance <> NULL;
WITH (SELECT h3Distance(590080540275638271, 590103561300344831)) AS calculated_distance SELECT id, h3_index FROM geospatial_indices WHERE h3_index BETWEEN calculated_distance AND (SELECT MAX(h3_index) FROM geospatial_indices);