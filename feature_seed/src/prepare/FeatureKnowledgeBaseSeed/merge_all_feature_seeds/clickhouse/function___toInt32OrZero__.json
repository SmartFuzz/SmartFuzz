CREATE TABLE test_table (input_string String, expected_output Int32);
INSERT INTO test_table VALUES ('-32', -32);
INSERT INTO test_table VALUES ('0', 0);
INSERT INTO test_table VALUES ('12345', 12345);
INSERT INTO test_table VALUES ('9999999999', 0);
INSERT INTO test_table VALUES ('abc', 0);
INSERT INTO test_table VALUES ('-abc', 0);
INSERT INTO test_table VALUES ('3.14', 0);
INSERT INTO test_table VALUES ('-3.14', 0);
INSERT INTO test_table VALUES ('Inf', 0);
INSERT INTO test_table VALUES ('NaN', 0);
INSERT INTO test_table VALUES ('0xc0fe', 0);
INSERT INTO test_table VALUES ('256', 256);
INSERT INTO test_table VALUES ('-2147483648', -2147483648);
INSERT INTO test_table VALUES ('2147483647', 2147483647);
SELECT input_string, toInt32OrZero(input_string) AS result FROM test_table;
CREATE TABLE validation_table (input_string String, result Int32);
INSERT INTO validation_table SELECT input_string, toInt32OrZero(input_string) FROM test_table;
SELECT expected_output, result FROM validation_table WHERE expected_output != result;
SELECT input_string, toInt32OrZero(toString(result)) AS result FROM (SELECT number AS result FROM system.numbers LIMIT 10);
SELECT countIf(toInt32OrZero(input_string) != expected_output) AS failure_count FROM test_table;