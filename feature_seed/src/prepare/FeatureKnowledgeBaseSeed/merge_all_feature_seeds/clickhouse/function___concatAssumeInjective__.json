CREATE TABLE test_concat (a String, b String, c UInt32) ENGINE = MergeTree() ORDER BY a;
INSERT INTO test_concat VALUES ('Alpha', 'Beta', 10), ('Gamma', 'Delta', 20), ('Alpha', 'Beta', 30), ('Epsilon', 'Zeta', 40);
SELECT concatAssumeInjective(a, b), sum(c) FROM test_concat GROUP BY concatAssumeInjective(a, b);
SELECT concatAssumeInjective(a, b) AS combined, count(*) FROM (SELECT DISTINCT a, b FROM test_concat) WHERE a IS NOT NULL GROUP BY combined;
CREATE TABLE key_val(`key1` String, `key2` String, `value` UInt32) ENGINE = MergeTree() ORDER BY key1;
INSERT INTO key_val VALUES ('Hello, ', 'World', 1), ('Hello, ', 'World', 2), ('Hello, ', 'World!', 3), ('Hello', ', World!', 2);
SELECT CONCAT('Sample', ' ', 'Concatenation') AS FullString;
SELECT concatAssumeInjective(key1, key2) AS ConcatKey, AVG(value) FROM key_val GROUP BY concatAssumeInjective(key1, key2);
SELECT concatAssumeInjective(name, surname) AS full_name, COUNT(*) FROM users WHERE active = 1 GROUP BY full_name HAVING COUNT(*) > 1;
CREATE TABLE orders (product String, user_id UInt32, order_value UInt32) ENGINE = MergeTree() ORDER BY user_id;
INSERT INTO orders VALUES ('ProductA', 1, 100), ('ProductB', 1, 150), ('ProductC', 2, 200);
SELECT user_id, concatAssumeInjective(product, CAST(order_value AS String)) FROM orders GROUP BY user_id, concatAssumeInjective(product, CAST(order_value AS String));
SELECT Users.user_id, concatAssumeInjective(u.first_name, u.last_name) AS full_name FROM Users INNER JOIN UserProfile u ON Users.id = u.user_id GROUP BY full_name;
CREATE TABLE accounts (id UInt32, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO accounts VALUES (1, 'User1'), (2, 'User2');
SELECT concatAssumeInjective(a.name, b.product) AS unique_key FROM accounts a JOIN orders b ON a.id = b.user_id GROUP BY unique_key;