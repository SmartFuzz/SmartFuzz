CREATE TABLE ip_addresses (ipv6 FixedString(16), ipv4 FixedString(4));
INSERT INTO ip_addresses VALUES (IPv6StringToNum('2001:0DB8:AC10:FE01:FEED:BABE:CAFE:F00D'), IPv4StringToNum('192.168.0.1'));
WITH IPv6StringToNum('2001:0DB8:AC10:FE01:FEED:BABE:CAFE:F00D') AS ipv6, IPv4ToIPv6(IPv4StringToNum('192.168.0.1')) AS ipv4 SELECT cutIPv6(ipv6, 2, 0) AS trimmed_ipv6, cutIPv6(ipv4, 0, 2) AS trimmed_ipv4 FROM ip_addresses;
WITH IPv6StringToNum('::1') AS ipv6, IPv4ToIPv6(IPv4StringToNum('0.0.0.0')) AS ipv4 SELECT cutIPv6(ipv6, 0, 2) AS trimmed_ipv6_zero, cutIPv6(ipv4, 2, 0) AS trimmed_ipv4_zero FROM ip_addresses;
WITH IPv6StringToNum('1234:5678:9abc:def0:1234:5678:9abc:def0') AS ipv6, IPv4ToIPv6(IPv4StringToNum('255.255.255.255')) AS ipv4 SELECT cutIPv6(ipv6, 4, 4) AS trimmed_ipv6_full, cutIPv6(ipv4, 2, 2) AS trimmed_ipv4_full FROM ip_addresses;
CREATE TABLE more_addresses (ipv6 FixedString(16), ipv4 FixedString(4));
INSERT INTO more_addresses VALUES (IPv6StringToNum('::'), IPv4StringToNum('127.0.0.1'));
WITH IPv6StringToNum('abcd:ef01:2345:6789:abcd:ef01:2345:6789') AS ipv6, IPv4StringToIPv6(IPv4StringToNum('192.168.1.1')) AS ipv4 SELECT cutIPv6(ipv6, 6, 0) AS trimmed_ipv6_large, cutIPv6(ipv4, 0, 4) AS trimmed_ipv4_large FROM more_addresses;
WITH (SELECT cutIPv6(ipv4, 2, 0) FROM ip_addresses) AS trimmed_ipv4_subquery, IPv6StringToNum('1111:2222:3333:4444:5555:6666:7777:8888') AS ipv6 SELECT cutIPv6(ipv6, 4, 0) AS trimmed_new_ipv6, trimmed_ipv4_subquery AS trimmed_ipv4_result;
WITH [IPv6StringToNum('dead:beef:dead:beef:dead:beef:dead:beef')] AS ipv6_list SELECT cutIPv6(ipv6_list[1], 8, 0) AS ipv6_byte_cut FROM ip_addresses;