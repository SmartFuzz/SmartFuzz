CREATE TABLE test_tuples (id Int32, tuple_data Tuple(Int32, Int32));
INSERT INTO test_tuples VALUES (1, (1, 2)), (2, (3, 4)), (3, (0, 0));
SELECT id, tuplePlus(tuple_data, (1, 1)) AS summed_tuple FROM test_tuples WHERE (id = 1 OR id = 2);
CREATE TABLE test_nulls (id Int32, nullable_data Nullable(Int32));
INSERT INTO test_nulls VALUES (1, 10), (2, NULL), (3, 5);
SELECT id, tuplePlus((1, if(nullable_data IS NULL, 0, nullable_data)), (2, 3)) AS adjusted_sum FROM test_nulls WHERE (id = 1 OR id = 2);
CREATE TABLE test_join (a_id Int32, b_id Int32, value Tuple(Int32, Int32));
INSERT INTO test_join VALUES (1, 1, (1, 1)), (1, 2, (2, 2)), (2, 1, (3, 3));
SELECT a.a_id, tuplePlus(a.value, (SELECT tuplePlus(b.value, (0, 0)) FROM test_join b WHERE b.b_id = a.b_id)) AS combined_value FROM test_join a WHERE a.a_id = 1 OR a.a_id = 2;
SELECT DISTINCT id, tuplePlus((SELECT tuplePlus((1, 1), (2, 2))), (SELECT tuplePlus((3, 3), (4, 4))) AS nested_sum FROM test_tuples);
SELECT a_id, SUM(tuplePlus(value, (5, 5))) AS total_sum FROM test_join GROUP BY a_id HAVING total_sum > 0 AND (a_id = 1 OR a_id = 2);
CREATE TABLE complex_data (x Float64, y Float64);
INSERT INTO complex_data VALUES (1.0, 2.0), (3.5, NULL), (NULL, 5.0);
SELECT tuplePlus((x, if(y IS NULL, 0, y)), (10, 20)) AS final_tuple FROM complex_data WHERE (x > 1 OR y > 3);