CREATE TABLE time_series_data (value Float64, time DateTime) ENGINE = MergeTree() ORDER BY time;
INSERT INTO time_series_data VALUES (1.5, '2023-01-01 00:00:00'), (2.5, '2023-01-02 00:00:00'), (NULL, '2023-01-03 00:00:00'), (4.5, '2023-01-04 00:00:00'), (5.0, '2023-01-05 00:00:00');
SELECT time, exponentialTimeDecayedSum(10)((value IS NULL) ? 0 : value)(time) OVER (ORDER BY time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS exp_smooth FROM time_series_data;
CREATE TABLE alternative_data (value Nullable(Float64), time Nullable(DateTime)) ENGINE = MergeTree() ORDER BY time;
INSERT INTO alternative_data VALUES (NULL, NULL), (3.5, '2023-01-06 00:00:00'), (NULL, '2023-01-07 00:00:00'), (4.5, '2023-01-08 00:00:00');
SELECT time, exponentialTimeDecayedSum(5)((value IS NULL) ? 0 : value)(toUnixTimestamp(time)) OVER (ORDER BY time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS exp_smooth FROM alternative_data WHERE time IS NOT NULL;
SELECT bar(exp_smooth, 0, 15, 50) AS bar_output FROM (SELECT time, exponentialTimeDecayedSum(20)((value) OR (value < 5))(time) OVER (ORDER BY time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS exp_smooth FROM time_series_data);
SELECT time, exponentialTimeDecayedSum(30)((if(value > 2.5, value, 0))(time)) OVER (ORDER BY time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS exp_smooth FROM (SELECT value, time FROM alternative_data WHERE value IS NOT NULL);
CREATE TEMPORARY TABLE temp_time_series AS SELECT time, value FROM time_series_data WHERE value >= 2;
SELECT DISTINCT time, exponentialTimeDecayedSum(10)((value + 2 * (number % 2))(time)) OVER (ORDER BY time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS exp_smooth FROM temp_time_series JOIN numbers(5) ON number < 5;
SELECT value, exponentialTimeDecayedSum(15)((x -> x * 1.5)(value))(time) OVER (ORDER BY time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS exp_smooth FROM time_series_data WHERE time >= '2023-01-01 00:00:00' AND time <= '2023-01-05 00:00:00' GROUP BY time, value HAVING value IS NOT NULL;