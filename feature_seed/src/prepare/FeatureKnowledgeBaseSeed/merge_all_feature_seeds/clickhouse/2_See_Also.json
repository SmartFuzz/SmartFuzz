CREATE TABLE test_data (id UUID DEFAULT generateUUIDv4(), ulid_value ULID, value_string String, value_int Int32, created_at DateTime DEFAULT now());
INSERT INTO test_data (ulid_value, value_string, value_int) VALUES (generateULID(), 'test', 1), (generateULID(), NULL, 2), (generateULID(), '', 3);
SELECT id, ulid_value, NOT value_int = 2 AS is_not_two FROM test_data WHERE NOT (value_string IS NULL) AND NOT (value_string = '') ORDER BY ulid_value;
SELECT ulid_value, COUNT(*) FROM test_data GROUP BY ulid_value HAVING NOT (COUNT(value_int) = 0);
SELECT id, ulid_value, (SELECT COUNT(*) FROM test_data AS sub WHERE sub.value_int > 1) AS sub_count FROM test_data WHERE NOT (ulid_value IS NULL) ORDER BY sub_count DESC;
SELECT value_string, NOT (value_int < 5) AS negate_condition FROM test_data WHERE value_string IS NOT NULL AND NOT (value_int = 0) GROUP BY value_string, negate_condition HAVING NOT (negate_condition);