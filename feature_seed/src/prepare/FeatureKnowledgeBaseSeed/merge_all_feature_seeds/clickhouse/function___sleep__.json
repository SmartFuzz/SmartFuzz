CREATE TABLE test_sleep (id UInt32, value Float32);
INSERT INTO test_sleep VALUES (1, 0.5), (2, 1.5), (3, 2.5);
SELECT id FROM test_sleep WHERE value > 1.0;
SELECT sleep(1.5);
SELECT id, value FROM (SELECT id, value FROM test_sleep WHERE id < 3) AS subquery;
SELECT sleep(2);
SELECT COUNT(*) FROM (SELECT id FROM test_sleep) AS count_query;
SELECT sleep(3);
CREATE TABLE test_data (a UInt32, b Float32) ENGINE = MergeTree() ORDER BY a;
INSERT INTO test_data VALUES (1, 0.1), (2, 0.2), (3, 0.3);
SELECT a FROM test_data WHERE b IN (SELECT value FROM test_sleep WHERE id = 2);
SELECT sleep(2.5);
CREATE TABLE join_test (j_id UInt32, j_value Float32) ENGINE = MergeTree() ORDER BY j_id;
INSERT INTO join_test VALUES (1, 1.0), (2, 2.0);
SELECT t.id, jt.j_value FROM test_sleep AS t JOIN join_test AS jt ON t.id = jt.j_id;
SELECT sleep(0.5);
SELECT id FROM test_sleep WHERE id IN (SELECT j_id FROM join_test WHERE j_value < 2.0);
SELECT sleep(1.0);