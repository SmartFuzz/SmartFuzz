CREATE TABLE test_dates (id Int32, event_time String, event_description String);
INSERT INTO test_dates VALUES (1, '2022-01-01 10:00:00', 'First Event'), (2, '', 'Empty Time'), (3, 'Invalid Time', 'Error Event');
SELECT id, toDateTimeOrDefault(event_time, 'UTC', toDateTimeOrDefault('2021-01-01 00:00:00', 'UTC')) - toDateTimeOrDefault('2021-01-01 00:00:01', 'UTC') AS time_difference FROM test_dates;
SELECT id, event_description, toDateTimeOrDefault(event_time) AS valid_time FROM test_dates WHERE valid_time IS NOT NULL;
SELECT id, COUNT(*) AS num_events FROM (SELECT id, toDateTimeOrDefault(event_time, 'UTC', '2023-01-01 00:00:00') AS event_time_converted FROM test_dates GROUP BY id HAVING event_time_converted > '2023-01-01 00:00:00') GROUP BY id;
CREATE TABLE test_numbers (id Int32, numeric_value String);
INSERT INTO test_numbers VALUES (1, '10'), (2, '20.5'), (3, 'INVALID');
SELECT id, toDateTimeOrDefault(numeric_value, 'UTC') - toDateTimeOrDefault('', 'UTC', toDateTimeOrDefault('2000-01-01 00:00:00', 'UTC')) AS adjusted_time FROM test_numbers;
CREATE TABLE test_joins (event_id Int32, date_value String);
INSERT INTO test_joins VALUES (1, '2023-10-01 08:00:00'), (2, '2023-10-02 09:00:00'), (3, 'INVALID DATE');
SELECT j.event_id, COUNT(d.id) AS join_count FROM test_joins j LEFT JOIN test_dates d ON toDateTimeOrDefault(j.date_value, 'UTC') - toDateTimeOrDefault(d.event_time, 'UTC', toDateTimeOrDefault('1900-01-01', 'UTC')) > 0 GROUP BY j.event_id HAVING join_count > 0;
SELECT toDateTimeOrDefault((SELECT event_time FROM test_dates WHERE id = 1), 'UTC', '2020-01-01 00:00:00') - event_time AS time_diff FROM test_dates WHERE id = 1;