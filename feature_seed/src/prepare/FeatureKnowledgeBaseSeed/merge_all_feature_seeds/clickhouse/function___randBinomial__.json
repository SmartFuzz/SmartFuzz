CREATE TABLE experiments_data (id UInt64, experiments UInt64, success_probability Float64);
INSERT INTO experiments_data VALUES (1, 100, 0.75), (2, 50, 0.5), (3, 1000, 0.05);
SELECT randBinomial(experiments, success_probability) FROM experiments_data;
SELECT id, randBinomial(experiments, success_probability) AS random_success FROM experiments_data WHERE success_probability BETWEEN 0.0 AND 1.0;
WITH (SELECT sum(experiments) FROM experiments_data) AS total_experiments SELECT randBinomial(total_experiments, 0.6) AS overall_success_count;
SELECT id, randBinomial(experiments, success_probability) FROM experiments_data WHERE experiments > 0;
SELECT id, randBinomial(experiments, 0.99) AS high_prob_success, randBinomial(experiments, 0.01) AS low_prob_success FROM experiments_data;
CREATE TABLE results AS SELECT id, randBinomial(experiments, success_probability) AS outcome FROM experiments_data;
SELECT id, outcome, COUNT(*) FROM results GROUP BY id, outcome;
SELECT id FROM experiments_data WHERE randBinomial(experiments, success_probability) > 20;