CREATE TABLE test_table (id UInt32, value Float64);
INSERT INTO test_table VALUES (1, 257.0), (2, 0.0), (3, -1.0), (4, 9223372036854775807.0), (5, -9223372036854775808.0);
SELECT value, reinterpretAsUInt64(value) AS uint64_value FROM test_table;
SELECT id, reinterpretAsUInt64(value) AS uint64_value FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value > 0);
CREATE TABLE another_table (uuid UUID, ts DateTime);
INSERT INTO another_table VALUES (generateUUIDv4(), now()), (generateUUIDv4(), now() - INTERVAL 1 DAY);
SELECT at.ts, reinterpretAsUInt64(at.uuid) AS uint64_uuid FROM another_table AS at;
SELECT id, reinterpretAsUInt64(value + 1.5) AS reinterpret_result FROM test_table;
SELECT id, reinterpretAsUInt64(toString(value)) AS reinterpret_as_string FROM test_table;
CREATE TABLE mixed_table (str_value String, int_value Int64);
INSERT INTO mixed_table VALUES ('100', 456), ('-500', 789);
SELECT str_value, reinterpretAsUInt64(int_value) AS uint64_conversion FROM mixed_table;
SELECT mt.int_value, reinterpretAsUInt64(mt.str_value) AS uint64_from_string FROM mixed_table AS mt JOIN test_table AS tt ON (tt.id = mt.int_value) WHERE mt.int_value < 5;
CREATE TABLE float_table (f_val Float32);
INSERT INTO float_table VALUES (1.5), (-1.5), (0.0), (4294967295.0);
SELECT f_val, reinterpretAsUInt64(f_val) AS uint64_f_val FROM float_table;
SELECT (SELECT avg(reinterpretAsUInt64(value)) FROM test_table WHERE value > 0) AS avg_uint64_value;