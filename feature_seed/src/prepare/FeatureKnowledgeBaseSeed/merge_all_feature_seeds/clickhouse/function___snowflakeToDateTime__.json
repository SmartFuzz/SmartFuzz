CREATE TABLE snowflake_test (id Int64);
INSERT INTO snowflake_test VALUES (CAST('1426860702823350272', 'Int64'));
INSERT INTO snowflake_test VALUES (CAST('1426860702825000000', 'Int64'));
INSERT INTO snowflake_test VALUES (CAST('1426860702826000000', 'Int64'));
SELECT snowflakeToDateTime(id, 'UTC') FROM snowflake_test;
SELECT snowflakeToDateTime(id, 'America/New_York') FROM snowflake_test;
SELECT snowflakeToDateTime(id) AS timestamp_utc, count(*) FROM snowflake_test GROUP BY timestamp_utc;
SELECT id, snowflakeToDateTime(id) AS timestamp_utc FROM snowflake_test WHERE id > CAST('1426860702820000000', 'Int64');
CREATE TABLE user_activity (user_id Int64, snowflake_id Int64);
INSERT INTO user_activity VALUES (1, CAST('1426860702823350272', 'Int64'));
INSERT INTO user_activity VALUES (2, CAST('1426860702825000000', 'Int64'));
SELECT u.user_id, snowflakeToDateTime(a.snowflake_id, 'UTC') AS activity_time FROM user_activity a JOIN snowflake_test u ON a.user_id = u.id;
WITH (SELECT snowflakeToDateTime(id, 'UTC') FROM snowflake_test) AS timestamps SELECT arrayJoin(timestamps) AS timestamp;
SELECT avg(toUnixTimestamp(snowflakeToDateTime(id, 'UTC'))) FROM snowflake_test;
SELECT count(*) FROM (SELECT snowflakeToDateTime(id, 'UTC') FROM snowflake_test WHERE id < CAST('1426860702826000000', 'Int64')) AS subquery;
SELECT snowflakeToDateTime(MAX(id), 'UTC') AS latest_time FROM snowflake_test WHERE id BETWEEN CAST('1426860702823000000', 'Int64') AND CAST('1426860702828000000', 'Int64');
CREATE TABLE activity_logs (log_id Int64, user_snowflake_id Int64);
INSERT INTO activity_logs VALUES (1, CAST('1426860702823350272', 'Int64'));
INSERT INTO activity_logs VALUES (2, CAST('1426860702825000000', 'Int64'));
SELECT a.user_snowflake_id, snowflakeToDateTime(a.user_snowflake_id, 'Europe/London') AS activity_time FROM activity_logs a WHERE log_id IN (SELECT log_id FROM activity_logs WHERE log_id >= 1);