CREATE TABLE points (id UInt32, vector Tuple(Float64, Float64));
INSERT INTO points VALUES (1, (1, 2)), (2, (2, 3)), (3, (4, 5));
SELECT LinfDistance(vector, (0, 0)) FROM points WHERE id = 1;
SELECT LinfDistance((1, 3), (3, 1));
SELECT LinfDistance((1, 2), (3, 4)) + LinfDistance((3, 4), (5, 6));
SELECT LinfDistance(vector, (3, 4)) FROM (SELECT vector FROM points WHERE id = 2);
SELECT LinfDistance((x, y), (a, b)) FROM (SELECT vector.1 AS x, vector.2 AS y FROM points) AS first_table, (SELECT vector.1 AS a, vector.2 AS b FROM points) AS second_table;
SELECT id, LinfDistance(vector, (0, 5)) AS distance FROM points HAVING distance < 1;
SELECT COUNT(*) FROM (SELECT LinfDistance(vector, (1, 1)) AS dist FROM points) WHERE dist < 5;
CREATE TABLE distances AS SELECT id, LinfDistance(vector, (1, 1)) AS distance FROM points;
SELECT id, distance FROM distances WHERE distance >= 2;
SELECT LinfDistance((1, 1), (2, 2)) + LinfDistance((2, 2), (3, 3)) + LinfDistance((3, 3), (4, 4)) AS total_distance;