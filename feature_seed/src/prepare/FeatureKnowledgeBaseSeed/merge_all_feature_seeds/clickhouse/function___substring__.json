CREATE TABLE strings_table (str_column String);
INSERT INTO strings_table VALUES ('hello world'), ('ClickHouse'), ('substring test'), ('another example');
SELECT str_column, substring(str_column, 1) AS from_start FROM strings_table;
SELECT str_column, substring(str_column, 0) AS empty_string FROM strings_table;
SELECT str_column, substring(str_column, -1) AS last_char FROM strings_table;
SELECT str_column, substring(str_column, -5) AS last_five_chars FROM strings_table;
SELECT str_column, substring(str_column, 1, 5) AS first_five_chars FROM strings_table;
SELECT str_column, substring(str_column, 2, 4) AS mid_substring FROM strings_table;
SELECT str_column, substring(str_column, 1, 20) AS oversized_length FROM strings_table;
SELECT str_column, substring(str_column, 1, 1) AS single_char FROM strings_table;
SELECT str_column, substring(str_column, -10, 3) AS three_chars_from_last_ten FROM strings_table;
SELECT str_column, substring(str_column, -20, 10) AS oversized_neg_offset FROM strings_table;
SELECT str_column, substring(str_column, 4) AS substring_from_table WHERE str_column LIKE 'sub%';
SELECT str_column, substring(substring(str_column, 1, 5), 3) AS nested_substring FROM strings_table;
SELECT str_column, substring(CONCAT(str_column, ' suffix'), 1, 15) AS concat_substring FROM strings_table;
SELECT str_column, substring((SELECT str_column FROM strings_table WHERE str_column LIKE 'C%'), 1, 5) AS subquery_select FROM strings_table;