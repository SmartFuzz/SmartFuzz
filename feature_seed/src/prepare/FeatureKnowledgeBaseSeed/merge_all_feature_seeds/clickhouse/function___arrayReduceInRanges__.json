CREATE TABLE test_array (arr Array(Int32)) ENGINE = Memory;
INSERT INTO test_array VALUES ([1000000, 200000, 30000, 4000, 500, 60, 7]);
SELECT arrayReduceInRanges('sum', [(1, 5), (2, 3), (3, 4), (4, 4)], arr) AS res FROM test_array;
CREATE TABLE test_data (id Int32, values Array(Int32)) ENGINE = Memory;
INSERT INTO test_data VALUES (1, [1, 2, 3, 4, 5]), (2, [10, 20, 30, 40, 50]);
SELECT id, arrayReduceInRanges('avg', [(1, 2), (3, 2)], values) AS res FROM test_data;
CREATE TABLE complex_data (x Int32, y Array(Int32), z Array(Int32)) ENGINE = Memory;
INSERT INTO complex_data VALUES (1, [1, 2, 3, 4, 5], [10, 20, 30, 40, 50]);
SELECT x, arrayReduceInRanges('sum', [(1, 3), (2, 2)], y) AS y_sum, arrayReduceInRanges('avg', [(1, 4), (2, 3)], z) AS z_avg FROM complex_data;
CREATE TABLE temp_table AS (SELECT arr FROM test_array);
SELECT arrayReduceInRanges('count', [(1, 3), (4, 2)], arr) FROM temp_table;
CREATE TABLE joined_data AS (SELECT t1.arr AS arr1, t2.arr AS arr2 FROM test_array AS t1 JOIN test_array AS t2 ON t1.id = t2.id);
SELECT arrayReduceInRanges('max', [(1, 5), (2, 4)], arr1) FROM joined_data;
CREATE TABLE multi_store (store_id Int32, transactions Array(Int32)) ENGINE = Memory;
INSERT INTO multi_store VALUES (1, [100, 200, 300]), (2, [400, 500, 600]);
SELECT store_id, arrayReduceInRanges('sum', [(1, 2), (2, 2)], transactions) FROM multi_store;
SELECT arrayReduceInRanges('median', [(1, 3)], [1, 2, 3, 4, 5, 6, 7, 8]) AS median_res;
SELECT arrayReduceInRanges('min', [(1, 3), (4, 2)], [3, 2, 1, 6, 5]) AS min_res;