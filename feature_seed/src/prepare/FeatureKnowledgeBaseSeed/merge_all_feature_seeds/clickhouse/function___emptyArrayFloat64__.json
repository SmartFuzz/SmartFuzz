CREATE TABLE test_table (id UInt32, values Array(Float64));
INSERT INTO test_table VALUES (1, emptyArrayFloat64()), (2, [1.0, 2.0, 3.0]), (3, emptyArrayFloat64());
SELECT id, values FROM test_table WHERE values = emptyArrayFloat64();
SELECT id, arrayJoin(values) AS value FROM test_table WHERE value IN (SELECT arrayJoin(emptyArrayFloat64()) AS empty_value);
CREATE TABLE subquery_table AS SELECT id, emptyArrayFloat64() AS empty_values FROM test_table WHERE id < 3;
SELECT id, IF(values = emptyArrayFloat64(), 'No values', 'Has values') AS value_status FROM test_table;
WITH (SELECT emptyArrayFloat64()) AS empty_array SELECT id FROM test_table WHERE values = empty_array;
SELECT COUNT(*) FROM test_table WHERE values = emptyArrayFloat64();
SELECT id, arrayMap(x -> x + 1, emptyArrayFloat64()) AS incremented_values FROM test_table WHERE id = 1;
CREATE TABLE another_table AS SELECT id, emptyArrayFloat64() AS empty_col FROM test_table;
INSERT INTO another_table SELECT id, emptyArrayFloat64() FROM test_table WHERE id % 2 = 0;
SELECT id, sumIf(arrayJoin(values), length(emptyArrayFloat64()) > 0) AS conditional_sum FROM test_table GROUP BY id;