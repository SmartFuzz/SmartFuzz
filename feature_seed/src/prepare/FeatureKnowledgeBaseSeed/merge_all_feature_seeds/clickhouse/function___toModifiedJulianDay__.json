CREATE TABLE test_dates (date_string String);
INSERT INTO test_dates VALUES ('0000-01-01'), ('9999-12-31'), ('2022-05-16'), ('2023-10-10');
SELECT toModifiedJulianDay(date_string) FROM test_dates;
SELECT date_string, toModifiedJulianDay(date_string) FROM test_dates WHERE date_string LIKE '202%';
SELECT date_string, toModifiedJulianDay(date_string) AS mjd FROM test_dates WHERE mjd IS NOT NULL;
SELECT toModifiedJulianDay('1995-12-31') UNION SELECT toModifiedJulianDay('2000-07-04') UNION SELECT toModifiedJulianDay('2010-01-01') ORDER BY 1;
CREATE TABLE date_validation (valid_date String, invalid_date String);
INSERT INTO date_validation VALUES ('2021-01-01', '2021-02-31'), ('2000-02-29', '2021-04-31');
SELECT toModifiedJulianDay(valid_date) AS valid_mjd, toModifiedJulianDay(invalid_date) AS invalid_mjd FROM date_validation;
SELECT COUNT(*) FROM (SELECT toModifiedJulianDay(date_string) FROM test_dates) AS mjd_values;
CREATE TABLE combined_dates (id UInt32, date String);
INSERT INTO combined_dates VALUES (1, '2020-01-01'), (2, '2022-12-31');
SELECT a.id, toModifiedJulianDay(a.date) AS mjd_a, toModifiedJulianDay(b.date) AS mjd_b FROM combined_dates AS a JOIN combined_dates AS b ON a.id < b.id;
WITH (SELECT toModifiedJulianDay('1990-02-28')) AS mjd_base SELECT date_string, toModifiedJulianDay(date_string) - mjd_base AS day_difference FROM test_dates;
SELECT DISTINCT toModifiedJulianDay(date_string) FROM (SELECT date_string FROM test_dates WHERE date_string LIKE '999%') AS subquery;