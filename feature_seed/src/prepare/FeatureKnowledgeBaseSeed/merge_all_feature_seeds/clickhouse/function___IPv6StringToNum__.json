CREATE TEMPORARY TABLE test_ipv6 (addr String);
INSERT INTO test_ipv6 VALUES ('::1'), ('2001:0db8:85a3:0000:0000:8a2e:0370:7334'), ('1200:0000:AB00:1234:0000:2552:7777:1313'), ('notaddress'), ('127.0.0.1'), ('1111::ffff');
SELECT addr, IPv6StringToNum(addr) FROM test_ipv6 WHERE addr NOT LIKE 'notaddress';
SELECT addr, cutIPv6(IPv6StringToNum(addr), 0, 0) FROM test_ipv6 ARRAY JOIN addr WHERE IPv6StringToNum(addr) IS NOT NULL;
SELECT addr, IPv6StringToNum(addr) AS ipv6_num FROM test_ipv6 WHERE length(addr) <= 39;
SELECT addr1, addr2, IPv6StringToNum(addr1) AS ipv6_num1, IPv6StringToNum(addr2) AS ipv6_num2 FROM (SELECT addr AS addr1 FROM test_ipv6 WHERE addr LIKE '2001:%') AS t1 JOIN (SELECT addr AS addr2 FROM test_ipv6 WHERE addr LIKE '::1' OR addr LIKE '127.0.0.1') AS t2;
SELECT cutIPv6(IPv6StringToNum(addr), 0, 0) FROM (SELECT DISTINCT addr FROM test_ipv6) AS unique_addrs WHERE addr IS NOT NULL;
SELECT addr, NULLIF(IPv6StringToNum(addr), 0) AS ipv6_num FROM test_ipv6 WHERE addr != '';
SELECT addr, IPv6StringToNum(addr) AS ipv6_num FROM (SELECT addr FROM test_ipv6 WHERE addr RLIKE '(([0-9a-fA-F]{1,4}:){7,7}[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,7}:|([0-9a-fA-F]{1,4}:){1,6}:[0-9a-fA-F]{1,4}|([0-9a-fA-F]{1,4}:){1,5}(:[0-9a-fA-F]{1,4}){1,2}|([0-9a-fA-F]{1,4}:){1,4}(:[0-9a-fA-F]{1,4}){1,3}|([0-9a-fA-F]{1,4}:){1,3}(:[0-9a-fA-F]{1,4}){1,4}|([0-9a-fA-F]{1,4}:){1,2}(:[0-9a-fA-F]{1,4}){1,5}|[0-9a-fA-F]{1,4}:((:[0-9a-fA-F]{1,4}){1,6})|:((:[0-9a-fA-F]{1,4}){1,7}|:)|fe80:(:[0-9a-fA-F]{0,4}){0,4}%[0-9a-zA-Z]{1,})') AS valid_ipv6;
DROP TABLE test_ipv6;