CREATE TABLE test_table (a Int32, b Int32, c Int32);
INSERT INTO test_table VALUES (1, 0, 2), (2, 0, 2), (3, 1, 1), (0, 0, 0);
SELECT * FROM test_table WHERE a BETWEEN b AND c;
SELECT * FROM test_table WHERE a BETWEEN 0 AND 2 AND c > b;
SELECT * FROM test_table t1 JOIN test_table t2 ON t1.a BETWEEN t2.b AND t2.c;
SELECT a, b FROM test_table WHERE a BETWEEN (SELECT MIN(b) FROM test_table) AND (SELECT MAX(c) FROM test_table);
SELECT COUNT(*) FROM test_table WHERE a BETWEEN 1 AND 2;
CREATE TABLE test_table_nested AS (SELECT a FROM (SELECT a, b, c FROM test_table) AS nested_table WHERE b <= c);
INSERT INTO test_table_nested SELECT a FROM test_table WHERE a BETWEEN (SELECT MIN(b) FROM test_table) AND (SELECT MAX(c) FROM test_table);
SELECT * FROM test_table WHERE a BETWEEN (SELECT AVG(b) FROM test_table) AND (SELECT AVG(c) FROM test_table) AND a <> 0;