CREATE TABLE test_dates (id UInt32, date_col String, nullable_date_col Nullable(Date32));
INSERT INTO test_dates VALUES (1, '1899-01-01', NULL), (2, '2023-07-25', '2023-07-30'), (3, '1955-01-01', '1990-01-01'), (4, '', NULL), (5, '1970-01-01', '9999-12-31');
SELECT id, toDate32(date_col) AS converted_date, toTypeName(toDate32(date_col)) FROM test_dates WHERE toDate32(date_col) BETWEEN toDate32('1900-01-01') AND toDate32('2000-12-31') AND nullable_date_col IS NOT NULL;
SELECT id, toDate32(date_col) AS converted_date FROM test_dates WHERE converted_date BETWEEN toDate32(toDate('1899-01-01')) AND toDate32('2050-12-31') AND nullable_date_col IS NULL;
SELECT COUNT(*) AS cnt, MAX(toDate32(date_col)) AS max_date FROM test_dates GROUP BY converted_date HAVING MAX(toDate32(nullable_date_col)) BETWEEN toDate32('1990-01-01') AND toDate32('2023-01-01');
SELECT id FROM (SELECT id, toDate32(date_col) AS converted_date FROM test_dates) AS subquery WHERE converted_date BETWEEN toDate32('2000-01-01') AND toDate32('2023-12-31');
SELECT id FROM test_dates WHERE (SELECT COUNT(*) FROM test_dates WHERE toDate32(date_col) IS NULL) BETWEEN 0 AND 5;
SELECT DISTINCT id, toDate32(date_col) AS converted_date FROM test_dates WHERE converted_date BETWEEN toDate32('1950-01-01') AND toDate32('1980-12-31') OR converted_date IS NULL;
CREATE TABLE temp_dates AS SELECT id, toDate32(date_col) AS converted_date FROM test_dates WHERE toDate32(date_col) BETWEEN toDate32('1900-01-01') AND toDate32('2000-12-31') ORDER BY converted_date;
SELECT id, COUNT(*) FROM temp_dates GROUP BY id HAVING COUNT(*) BETWEEN 1 AND 5;