CREATE TABLE test_ripemd160 (input_string String) ENGINE = Memory;
INSERT INTO test_ripemd160 VALUES ('The quick brown fox jumps over the lazy dog');
SELECT HEX(RIPEMD160(input_string)) FROM test_ripemd160;
INSERT INTO test_ripemd160 VALUES (''), ('a'), ('Hello, World!');
SELECT HEX(RIPEMD160(input_string)) FROM test_ripemd160 WHERE input_string != '';
SELECT COUNT(*) AS count, HEX(RIPEMD160(input_string)) AS hash_value FROM test_ripemd160 GROUP BY hash_value;
WITH (SELECT HEX(RIPEMD160(input_string)) FROM test_ripemd160) AS hashes SELECT arrayJoin(hashes) AS all_hashes;
CREATE TABLE test_ripemd160_2 (id UInt32, description String) ENGINE = Memory;
INSERT INTO test_ripemd160_2 VALUES (1, 'hash of the quick brown fox'), (2, 'another string');
SELECT t2.id, HEX(RIPEMD160(t1.input_string)) AS hash_value FROM test_ripemd160 t1 INNER JOIN test_ripemd160_2 t2 ON t1.input_string = t2.description;
SELECT HEX(RIPEMD160(CONCAT(input_string, ' extra text'))) FROM test_ripemd160;
DELETE FROM test_ripemd160 WHERE input_string = 'a';
SELECT COUNT(*) FROM test_ripemd160;
SELECT HEX(RIPEMD160(input_string)) FROM (SELECT input_string FROM test_ripemd160 WHERE LENGTH(input_string) > 10) AS filtered_inputs;