CREATE TABLE test_table (id UInt8, value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, 40.0), (5, 50.0);
SELECT groupArrayMovingSum(value) AS moving_sum FROM test_table;
SELECT groupArrayMovingSum(3)(value) AS moving_sum FROM test_table;
SELECT id, groupArrayMovingSum(value)(2) AS moving_sum FROM test_table GROUP BY id ORDER BY id;
SELECT id, groupArrayMovingSum(value)(3) AS moving_sum FROM (SELECT * FROM test_table) AS subquery GROUP BY id ORDER BY id;
CREATE TABLE another_table (group_id UInt8, score Float32) ENGINE = MergeTree() ORDER BY group_id;
INSERT INTO another_table VALUES (1, 15.0), (1, 25.0), (2, 35.0), (2, 45.0);
SELECT group_id, groupArrayMovingSum(score)(2) AS rolling_sum FROM another_table GROUP BY group_id ORDER BY group_id;
SELECT group_id, groupArrayMovingSum(score)(1) AS rolling_sum FROM another_table WHERE group_id = 1 GROUP BY group_id;
SELECT a.id, groupArrayMovingSum(a.value)(2) AS moving_sum, b.score FROM test_table AS a JOIN another_table AS b ON a.id = b.group_id GROUP BY a.id, b.score;