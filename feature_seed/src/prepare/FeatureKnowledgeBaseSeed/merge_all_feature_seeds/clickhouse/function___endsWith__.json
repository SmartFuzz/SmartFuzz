CREATE TABLE strings_test (id Int32, str String, suffix String);
INSERT INTO strings_test VALUES (1, 'HelloWorld', 'World');
INSERT INTO strings_test VALUES (2, 'ClickhouseDatabase', 'Database');
INSERT INTO strings_test VALUES (3, 'TestString', 'String');
INSERT INTO strings_test VALUES (4, 'BoundaryCase', 'case');
INSERT INTO strings_test VALUES (5, 'Short', 'Long');
SELECT id, endsWith(str, suffix) AS ends_with_check FROM strings_test;
SELECT id FROM strings_test WHERE endsWith(str, suffix);
SELECT id, str FROM strings_test WHERE endsWith(str, '');
SELECT id FROM strings_test WHERE endsWith(str, 'World') AND id = 1;
SELECT id, str FROM strings_test WHERE id IN (SELECT id FROM strings_test WHERE endsWith(str, 'Database'));
CREATE TABLE strings_test_2 (id Int32, another_column String);
INSERT INTO strings_test_2 VALUES (1, 'HelloWorldTest');
SELECT s.id FROM strings_test s JOIN strings_test_2 t ON endsWith(s.str, 'Test') WHERE t.id = 1;
SELECT str FROM strings_test WHERE endsWith(str, (SELECT suffix FROM strings_test LIMIT 1));
SELECT COUNT(*) FROM strings_test WHERE endsWith(str, 'Long');