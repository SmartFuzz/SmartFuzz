CREATE TABLE hex_test (id UInt32, resolution UInt8, area Float64, description String);
INSERT INTO hex_test VALUES (1, 13, h3HexAreaM2(13), 'Normal resolution');
INSERT INTO hex_test VALUES (2, 14, h3HexAreaM2(14), 'Higher resolution');
INSERT INTO hex_test VALUES (3, 15, h3HexAreaM2(15), 'Max resolution');
INSERT INTO hex_test VALUES (4, 0, h3HexAreaM2(0), 'Min resolution');
INSERT INTO hex_test VALUES (5, NULL, h3HexAreaM2(if(resolution IS NULL, 0, resolution)), 'NULL resolution handled');
SELECT * FROM hex_test WHERE area NOT LIKE '%.0';
SELECT id, area, NOT (area NOT LIKE '%.0001') AS is_rounded FROM hex_test HAVING is_rounded = 1;
SELECT id, h3HexAreaM2(resolution) AS hex_area FROM hex_test WHERE area NOT LIKE CAST('NaN' AS String);
SELECT id, area FROM hex_test WHERE resolution NOT LIKE '1a' AND resolution IS NOT NULL;
SELECT id FROM (SELECT id, resolution, area FROM hex_test WHERE resolution NOT LIKE '2' GROUP BY resolution HAVING COUNT(*) > 2) AS subquery WHERE area NOT LIKE '%1.0';