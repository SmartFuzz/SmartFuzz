CREATE TABLE test_strings (id UInt32, text String, array_data Array(Int32));
INSERT INTO test_strings VALUES (1, 'Hello, World!', [1, 2, 3]), (2, '', [4, 5, 6]), (3, 'ClickHouse is great!', NULL);
SELECT id, locate(array_element(array_data, 2), text) AS position FROM test_strings WHERE locate('lo', text) IS NOT NULL;
SELECT id, locate('is', text, 1) AS position, array_element(array_data, locate('is', text, 1) % length(text) + 1) AS array_val FROM test_strings WHERE text IS NOT NULL;
CREATE TABLE temp_strings AS SELECT id, text, array_data FROM test_strings WHERE text != '';
SELECT id, locate(array_element(array_data, 1), text) AS position, text FROM temp_strings WHERE text IS NOT NULL ORDER BY position;
SELECT id, array_join(array_data) AS single_value, locate(single_value, text) AS position FROM temp_strings GROUP BY id, single_value HAVING position > 0;
SELECT id, locate('to', text) AS position FROM temp_strings WHERE position IS NOT NULL AND position <= length(text) - 1;
SELECT id, count(*) AS occurrences, locate('ClickHouse', text) AS position FROM test_strings GROUP BY id HAVING occurrences > 0;
SELECT id, array_element(array_data, 3) AS third_value, locate(third_value, text) AS position FROM test_strings WHERE third_value IS NOT NULL;