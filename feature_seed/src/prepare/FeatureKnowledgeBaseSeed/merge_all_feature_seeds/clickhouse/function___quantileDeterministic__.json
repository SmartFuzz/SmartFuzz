CREATE TABLE test_data (id UInt32, val Float64);
INSERT INTO test_data VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, 40.0), (5, 50.0);
SELECT quantileDeterministic(0.5)(val, id) FROM test_data;
SELECT quantileDeterministic(0.01)(val, id) FROM test_data;
SELECT quantileDeterministic(0.99)(val, id) FROM test_data;
SELECT quantileDeterministic(0.25)(val, id) FROM test_data WHERE id IN (SELECT id FROM test_data WHERE val > 20);
SELECT quantileDeterministic(0.75)(val, id) FROM test_data GROUP BY id % 2;
CREATE TABLE test_data2 (user_id UInt32, score Float64);
INSERT INTO test_data2 VALUES (1, 5.0), (2, 15.0), (1, 10.0), (2, 20.0);
SELECT quantileDeterministic(0.5)(score, user_id) FROM test_data2 GROUP BY user_id;
SELECT user_id, quantileDeterministic(0.5)(score, user_id) FROM test_data2 GROUP BY user_id ORDER BY user_id;
SELECT quantileDeterministic(0.5)(val, id) FROM (SELECT val, id FROM test_data WHERE id <= 3) AS sub;
SELECT quantileDeterministic(0.5)(val, id) FROM (SELECT * FROM test_data WHERE val > 15) AS sub_data LEFT JOIN test_data2 ON sub_data.id = test_data2.user_id;