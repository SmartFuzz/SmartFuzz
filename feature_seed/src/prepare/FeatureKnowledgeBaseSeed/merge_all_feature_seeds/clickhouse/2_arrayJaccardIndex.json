CREATE TABLE test_arrays (id UInt32, arr1 Array(Int32), arr2 Array(Int32), value Nullable(Int32));
INSERT INTO test_arrays VALUES (1, [1, 2], [2, 3], NULL), (2, [], [1, 2, 3], 1), (3, [4, 5, 6], [5, 6, 7], 2);
SELECT id, arrayJaccardIndex(arr1, arr2) AS jaccard_index FROM test_arrays WHERE jaccard_index IS NOT NULL;
SELECT id, arrayJaccardIndex(arr1, arr2) AS jaccard_index FROM test_arrays WHERE jaccard_index > 0 AND value IS NULL;
SELECT id, arrayJaccardIndex(arr1, arr2) AS jaccard_index FROM (SELECT id, arr1, arr2 FROM test_arrays WHERE value IS NULL) AS subquery WHERE arrayJaccardIndex(arr1, arr2) < 1;
SELECT id, arrayJaccardIndex(arr1, arr2) AS jaccard_index FROM (SELECT id, arr1, arr2, value FROM test_arrays HAVING value < 2) AS filtered WHERE jaccard_index IS NOT NULL AND id > 1;
SELECT id, arrayJaccardIndex(arr1, arr2) AS jaccard_index FROM test_arrays WHERE arrayJaccardIndex(arr1, NULL) IS NULL AND arrayJaccardIndex(NULL, arr2) IS NULL;
SELECT arrayJaccardIndex(arr1, arr2) AS jaccard_index, (SELECT COUNT(*) FROM test_arrays WHERE value IS NOT NULL) AS non_null_count FROM test_arrays HAVING jaccard_index < 1;
CREATE TABLE temp_arrays AS SELECT id, arr1, arr2, arrayJaccardIndex(arr1, arr2) AS jaccard_index FROM test_arrays;
SELECT t1.id, t2.arr1, arrayJaccardIndex(t1.arr2, t2.arr1) AS new_jaccard FROM test_arrays AS t1 INNER JOIN temp_arrays AS t2 ON t1.id = t2.id AND arrayJaccardIndex(t1.arr1, t2.arr2) > 0;