CREATE TABLE test_table (degree_of_freedom Float64);
INSERT INTO test_table VALUES (1.0);
INSERT INTO test_table VALUES (10.0);
INSERT INTO test_table VALUES (100.0);
INSERT INTO test_table VALUES (1000.0);
SELECT randChiSquared(degree_of_freedom) FROM test_table;
SELECT randChiSquared(degree_of_freedom) FROM test_table WHERE degree_of_freedom > 0;
SELECT randChiSquared(degree_of_freedom) FROM test_table WHERE degree_of_freedom < 100;
SELECT degree_of_freedom, randChiSquared(degree_of_freedom) FROM test_table;
SELECT SUM(randChiSquared(degree_of_freedom)) FROM (SELECT degree_of_freedom FROM test_table) AS sub;
CREATE TABLE another_table (k Int32);
INSERT INTO another_table VALUES (1), (2), (3), (4), (5);
SELECT k, randChiSquared(10 * k) FROM another_table;
SELECT AVG(randChiSquared(degree_of_freedom)) AS average FROM test_table;
SELECT MAX(randChiSquared(degree_of_freedom)) FROM test_table WHERE degree_of_freedom BETWEEN 1 AND 100;
SELECT COUNT(randChiSquared(degree_of_freedom)) FROM test_table HAVING degree_of_freedom IS NOT NULL;
WITH (SELECT AVG(degree_of_freedom) FROM test_table) AS avg_dof SELECT randChiSquared(avg_dof) FROM test_table;
SELECT randChiSquared(degree_of_freedom) FROM test_table JOIN another_table ON another_table.k <= 5;