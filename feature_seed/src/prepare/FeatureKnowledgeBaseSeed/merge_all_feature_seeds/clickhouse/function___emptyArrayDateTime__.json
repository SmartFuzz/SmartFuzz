CREATE TABLE test_table (id UInt32, timestamp DateTime);
INSERT INTO test_table VALUES (1, now()), (2, now() + INTERVAL 1 HOUR);
SELECT emptyArrayDateTime() AS empty_array, id FROM test_table WHERE id = 1;
SELECT id, emptyArrayDateTime() AS empty_array FROM test_table WHERE timestamp > now() - INTERVAL 1 DAY;
SELECT id, ARRAY_AGG(emptyArrayDateTime()) AS empty_array_group FROM test_table GROUP BY id;
SELECT id, (SELECT emptyArrayDateTime() FROM test_table WHERE id = t.id) AS empty_array_subquery FROM test_table t;
CREATE TABLE empty_test_table AS SELECT emptyArrayDateTime() AS empty_array;
SELECT empty_array FROM empty_test_table;
SELECT id, arrayJoin(emptyArrayDateTime()) AS joined_array FROM test_table;
WITH (SELECT emptyArrayDateTime()) AS empty_array_alias SELECT id, empty_array_alias FROM test_table ORDER BY id;