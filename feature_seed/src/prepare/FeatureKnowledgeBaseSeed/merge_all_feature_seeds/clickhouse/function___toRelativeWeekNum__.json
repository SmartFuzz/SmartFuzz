CREATE TABLE dates_table (event_date Date);
INSERT INTO dates_table VALUES (toDate('2000-01-01'));
INSERT INTO dates_table VALUES (toDate('2001-01-01'));
INSERT INTO dates_table VALUES (toDate('2000-02-29'));
INSERT INTO dates_table VALUES (toDate('2001-01-12'));
INSERT INTO dates_table VALUES (toDate('2020-02-29'));
INSERT INTO dates_table VALUES (toDate('2023-06-15'));
SELECT toRelativeWeekNum(event_date) AS week_num FROM dates_table;
SELECT event_date, toRelativeWeekNum(event_date) AS week_num FROM dates_table WHERE event_date >= toDate('2000-01-01') AND event_date <= toDate('2023-12-31');
SELECT AVG(toRelativeWeekNum(event_date)) AS average_week_num FROM dates_table;
SELECT MAX(week_num) FROM (SELECT toRelativeWeekNum(event_date) AS week_num FROM dates_table) AS inner_query;
SELECT event_date, toRelativeWeekNum(event_date) AS week_num FROM dates_table ORDER BY week_num DESC;
CREATE TABLE other_table (id UInt32, event_date Date);
INSERT INTO other_table VALUES (1, toDate('2000-01-01'));
INSERT INTO other_table VALUES (2, toDate('2001-01-12'));
SELECT a.event_date, toRelativeWeekNum(a.event_date) AS week_num, b.id FROM dates_table a JOIN other_table b ON a.event_date = b.event_date;
SELECT COUNT(*) FROM dates_table WHERE toRelativeWeekNum(event_date) IS NOT NULL;
SELECT event_date, toRelativeWeekNum(event_date) AS week_num FROM dates_table WHERE toRelativeWeekNum(event_date) > 20 ORDER BY week_num ASC;