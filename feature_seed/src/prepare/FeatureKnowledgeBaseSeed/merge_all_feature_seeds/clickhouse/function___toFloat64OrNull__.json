CREATE TABLE test_float_conversion (value String);
INSERT INTO test_float_conversion VALUES ('42.7'), ('-1.5'), ('3.14'), ('0'), ('abc'), ('-abc'), (''), ('NaN'), ('Infinity'), ('-Infinity'), ('256'), ('-128'), ('4294967296'), ('32768'), ('-32768');
SELECT toFloat64OrNull(value) FROM test_float_conversion;
SELECT value, toFloat64OrNull(value) FROM test_float_conversion WHERE toFloat64OrNull(value) IS NOT NULL;
SELECT COUNT(*) AS valid_count FROM test_float_conversion WHERE toFloat64OrNull(value) IS NOT NULL;
SELECT SUM(toFloat64OrNull(value)) AS sum_valid FROM test_float_conversion WHERE toFloat64OrNull(value) IS NOT NULL;
SELECT value, CASE WHEN toFloat64OrNull(value) IS NOT NULL THEN 'Valid' ELSE 'Invalid' END AS status FROM test_float_conversion;
WITH (SELECT value FROM test_float_conversion WHERE toFloat64OrNull(value) IS NULL) AS invalid_values SELECT toFloat64OrNull(value), invalid_values.value FROM invalid_values;
CREATE TABLE test_float_conversion_2 (id UInt32, val String);
INSERT INTO test_float_conversion_2 VALUES (1, '45.5'), (2, 'abc'), (3, '100');
SELECT a.id, toFloat64OrNull(a.val) AS num_val FROM test_float_conversion_2 AS a JOIN test_float_conversion AS b ON a.val = b.value;
SELECT DISTINCT toFloat64OrNull(a.val) FROM test_float_conversion_2 AS a WHERE a.val LIKE '%.%' ORDER BY toFloat64OrNull(a.val);
SELECT a.id, a.val, toFloat64OrNull(a.val) + 10 AS adjusted_val FROM test_float_conversion_2 AS a;
SELECT COALESCE(toFloat64OrNull(value), -1) AS safe_val FROM test_float_conversion;
SELECT (SELECT COUNT(*) FROM test_float_conversion WHERE toFloat64OrNull(value) IS NOT NULL) AS valid_count, (SELECT COUNT(*) FROM test_float_conversion WHERE toFloat64OrNull(value) IS NULL) AS invalid_count;