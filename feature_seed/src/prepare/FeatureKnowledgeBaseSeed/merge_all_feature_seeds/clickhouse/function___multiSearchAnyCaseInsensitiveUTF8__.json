CREATE TABLE test_table (id Int32, text_field String);
INSERT INTO test_table VALUES (1, '\x43\x6c\x69\x63\x6b\x48\x6f\x75\x73\x65'), (2, '\x43\x6c\x69\x63\x6b\x68\x6f\x75\x73\x65'), (3, '\x43\x6c\x49\x63\x6b\x48\x6f\x75\x73\x65');
SELECT multiSearchAnyCaseInsensitiveUTF8(text_field, ['\x68']) FROM test_table;
SELECT multiSearchAnyCaseInsensitiveUTF8(text_field, ['\x43', '\x6c']) FROM test_table;
SELECT multiSearchAnyCaseInsensitiveUTF8(text_field, ['\x63', '\x68', '\x69']) FROM test_table WHERE id = 1;
SELECT id, multiSearchAnyCaseInsensitiveUTF8(text_field, ['\x43\x6c\x69']) AS match_found FROM test_table HAVING match_found = 1;
WITH (SELECT text_field FROM test_table WHERE id = 1) AS subquery SELECT multiSearchAnyCaseInsensitiveUTF8(subquery, ['\x68', '\x43']) AS result FROM subquery;
SELECT SUM(multiSearchAnyCaseInsensitiveUTF8(text_field, ['\x65'])) FROM test_table GROUP BY id HAVING SUM(result) > 0;
SELECT DISTINCT id FROM test_table WHERE multiSearchAnyCaseInsensitiveUTF8(text_field, ['\x45']) = 1;
CREATE TABLE another_table (field1 Int32, field2 String);
INSERT INTO another_table VALUES (1, '\x48\x6f\x75\x73\x65\x63\x6c\x69\x63'), (2, '\x68\x6f\x75\x73\x65\x43\x6c\x69\x63\x6b');
SELECT a.field1, multiSearchAnyCaseInsensitiveUTF8(a.field2, ['\x68', '\x43']) FROM another_table AS a JOIN test_table AS b ON a.field1 = b.id WHERE multiSearchAnyCaseInsensitiveUTF8(b.text_field, ['\x68']) = 1;