CREATE TABLE test_strings (id UInt32, data String);
INSERT INTO test_strings VALUES (1, 'Hello, World!');
INSERT INTO test_strings VALUES (2, '');
INSERT INTO test_strings VALUES (3, 'A string with special characters: !@#$%^&*()');
INSERT INTO test_strings VALUES (4, '\0');
INSERT INTO test_strings VALUES (5, repeat('a', 10000));
SELECT data FROM test_strings WHERE id = 1;
SELECT data FROM test_strings WHERE LENGTH(data) > 10;
SELECT data FROM test_strings WHERE LENGTHUTF8(data) = 13;
CREATE TABLE other_strings (id UInt32, description String);
INSERT INTO other_strings VALUES (1, 'This is a test string.');
INSERT INTO other_strings VALUES (2, 'Another string.');
SELECT ts.data FROM test_strings ts JOIN other_strings os ON ts.id = os.id;
SELECT ts.data, os.description FROM test_strings ts LEFT JOIN other_strings os ON ts.id = os.id WHERE ts.data LIKE '%test%';
INSERT INTO test_strings SELECT 6, concat('String number ', toString(id)) FROM other_strings;
SELECT DISTINCT data FROM test_strings WHERE data != '' ORDER BY data;
SELECT COUNT(*) FROM test_strings WHERE data NOT LIKE '%\0%';
SELECT LENGTH(data) AS byte_length, LENGTHUTF8(data) AS utf8_length FROM test_strings;
SELECT data, LENGTH(data) AS byte_length, LENGTHUTF8(data) AS utf8_length FROM test_strings WHERE LENGTH(data) <= 255;