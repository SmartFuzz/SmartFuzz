CREATE TABLE bitmap_test (id UInt32);
INSERT INTO bitmap_test VALUES (1), (2), (3), (4), (5);
SELECT bitmapBuild(arrayJoin([1, 2, 3, 4, 5])) AS res, toTypeName(res);
SELECT bitmapBuild([0, 1000, 3000, 5000]) AS res, toTypeName(res);
SELECT bitmapBuild(range(1, 10)) AS res, toTypeName(res);
SELECT bitmapBuild(arrayMap(x -> x + 10, [1, 2, 3])) AS res, toTypeName(res);
WITH (SELECT arrayJoin([10, 20, 30, 40]) AS x) SELECT bitmapBuild(arrayMap(y -> y * 2, [x])) FROM (SELECT x LIMIT 10);
WITH (SELECT arrayJoin([100, 200, 300, 400, 500]) AS x) SELECT bitmapBuild(x) AS res FROM (SELECT x WHERE x > 200);
SELECT bitmapBuild(array) AS bitmap_res FROM (SELECT arrayReduce('groupUniqArray', arrayJoin([1, 2, 2, 3, 4])) AS array) AS new_table;
WITH (SELECT bitmapBuild(arrayJoin([0, 1, 2])) AS res) SELECT res, toTypeName(res) AS type FROM new_table;