CREATE TABLE test_dates (id Int32, dateString String, eventType String);
INSERT INTO test_dates VALUES (1, '2023-10-01 12:30:00', 'meeting'), (2, '2023-10-02 15:50:00', 'conference'), (3, '2023-10-03 18:00:00', NULL);
SELECT id, parseDateTimeBestEffort(dateString) AS parsed_date FROM test_dates WHERE NOT eventType IS NULL;
CREATE TABLE test_events (eventId Int32, eventName String, eventDate String);
INSERT INTO test_events VALUES (1, 'Event A', '2023-10-05 10:00:00'), (2, 'Event B', 'Not a date'), (3, 'Event C', NULL);
SELECT e.eventId, e.eventName, parseDateTimeBestEffort(e.eventDate) AS event_date FROM test_events e WHERE NOT (e.eventName = 'Event B' OR e.eventId = 2);
SELECT t.id, t.dateString, parseDateTimeBestEffort(t.dateString) AS parsed_date FROM test_dates t JOIN test_events e ON NOT (parseDateTimeBestEffort(e.eventDate) IS NULL AND t.eventType IS NULL) GROUP BY t.id, t.dateString ORDER BY parsed_date;
CREATE TABLE test_composite (id Int32, compDate DateTime, duration Int32);
INSERT INTO test_composite VALUES (1, '2023-10-01 00:00:00', 10), (2, '2023-10-01 00:00:00', -1), (3, NULL, 30);
SELECT id, compDate, duration, parseDateTimeBestEffort(toString(compDate + INTERVAL duration DAY)) FROM test_composite WHERE NOT (duration < 0 AND compDate IS NULL) HAVING NOT (duration > 10);