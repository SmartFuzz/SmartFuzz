CREATE TABLE test_conversion (value String);
INSERT INTO test_conversion VALUES ('-128'), ('abc'), ('128'), ('3.14'), ('0xc0fe'), ('256'), ('NaN'), ('Inf'), ('-99999999999999999999999999999999999999999999999');
SELECT toInt128OrNull(value) FROM test_conversion;
SELECT toInt128OrNull(value) FROM test_conversion WHERE value LIKE '-%';
SELECT toInt128OrNull(value) FROM (SELECT value FROM test_conversion WHERE value IS NOT NULL);
SELECT t.value, toInt128OrNull(t.value) as converted FROM (SELECT value FROM test_conversion WHERE value NOT LIKE '%abc%') as t;
SELECT t1.value, toInt128OrNull(t1.value) FROM (SELECT value FROM test_conversion UNION SELECT '-123456') as t1;
SELECT t.value, t.converted FROM (SELECT value, toInt128OrNull(value) AS converted FROM test_conversion) as t WHERE converted IS NULL;
SELECT COUNT(*) FROM (SELECT toInt128OrNull(value) FROM test_conversion) AS t;
SELECT AVG(toInt128OrNull(value)) FROM (SELECT value FROM test_conversion WHERE value NOT LIKE '%Nan%') AS t;
SELECT CASE WHEN toInt128OrNull(value) IS NULL THEN 'Invalid' ELSE 'Valid' END AS validation FROM test_conversion;