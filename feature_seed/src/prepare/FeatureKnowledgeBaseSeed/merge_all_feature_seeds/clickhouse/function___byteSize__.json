CREATE TABLE test_empty (key Int32);
SELECT byteSize(NULL) AS byteSizeNull FROM test_empty;
CREATE TABLE test_mixed (key Int32, val String);
INSERT INTO test_mixed VALUES (1, 'example'), (2, NULL), (3, '');
SELECT key, byteSize(val) AS byteSizeVal FROM test_mixed ORDER BY key;
SELECT byteSize(1, 'test', 0.5, NULL) AS byteSizeMixed;
CREATE TABLE test_large (id Int32, data String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_large VALUES (1, repeat('a', 1000)), (2, repeat('b', 2000));
SELECT id, byteSize(data) AS byteSizeData FROM test_large;
CREATE TABLE test_numeric (num1 Int8, num2 UInt8, num3 Float32) ENGINE = MergeTree() ORDER BY num1;
INSERT INTO test_numeric VALUES (10, 20, 30.5), (15, 25, NULL);
SELECT num1, byteSize(num1), byteSize(num2), byteSize(num3) FROM test_numeric;
CREATE TABLE test_nested (id Int32, values Array(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_nested VALUES (1, [1, 2, 3]), (2, [4, 5, 6, 7, 8]);
SELECT id, byteSize(values) AS byteSizeArray FROM test_nested;
CREATE TABLE test_composite (id Int32, name String, score Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_composite VALUES (1, 'Alice', 95.0), (2, 'Bob', 85.5);
SELECT id, byteSize(name) AS byteSizeName, byteSize(score) AS byteSizeScore FROM test_composite;
SELECT byteSize(1, 2, 3, 4, 5, 'test') AS byteSizeVariety;