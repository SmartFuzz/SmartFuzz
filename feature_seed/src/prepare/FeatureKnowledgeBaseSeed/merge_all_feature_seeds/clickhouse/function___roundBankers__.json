CREATE TABLE test_roundBankers (value FLOAT, decimal_position INT);
INSERT INTO test_roundBankers VALUES (3.5, 0), (2.5, 0), (3.55, 1), (24.55, -1), (45, -1), (1.499, 2), (1.500, 3), (1.505, 2), (1.505, 1);
SELECT value, roundBankers(value, decimal_position) AS rounded_value FROM test_roundBankers;
SELECT roundBankers(CAST(number AS FLOAT) / 2, 0) AS banker_rounded FROM system.numbers LIMIT 10;
SELECT roundBankers(x, 0) FROM (SELECT x FROM (SELECT CAST(1.5 + i AS FLOAT) AS x FROM system.numbers LIMIT 10) AS temp) AS sub_query;
SELECT roundBankers(x, 1) FROM (SELECT x * 3.14159 AS x FROM (SELECT number / 10 AS number FROM system.numbers LIMIT 10) AS temp_sub) AS final_sub;
SELECT a.value, b.rounded_value FROM (SELECT value, roundBankers(value, 0) AS rounded_value FROM test_roundBankers WHERE decimal_position = 0) AS a JOIN (SELECT value, roundBankers(value, 1) AS rounded_value FROM test_roundBankers WHERE decimal_position = 1) AS b ON a.value = b.value;
SELECT DISTINCT roundBankers(value, decimal_position) FROM test_roundBankers WHERE value > 0.5 AND decimal_position = 0;
WITH roundBankers(3.5, 0) AS rounded1, roundBankers(2.5, 0) AS rounded2 SELECT rounded1 + rounded2 AS total;
SELECT x, roundBankers(x, 1) FROM (SELECT number / 3 AS x FROM system.numbers LIMIT 10) AS divided;