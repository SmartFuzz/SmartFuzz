CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('Hello World!'), ('This is a sample string.'), ('Fuzzy searching can be useful!');
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['hello', 'this', 'IS']);
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['sample', 'fuzzy', 'useful']);
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['world', 'searching', 'IN']);
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['nonexistent', 'strings']);
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['HELLO', 'WORLD', 'FOO']);
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['sample', 'STRING', 'searching']);
WITH (SELECT haystack FROM test_strings) AS subquery SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['hello', 'sample']) FROM subquery;
WITH (SELECT haystack FROM test_strings) AS subquery SELECT COUNT(*) FROM (SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['some', 'string']) FROM subquery) as matched WHERE matched != 0;
SELECT multiSearchFirstPositionCaseInsensitive(haystack, ['wOr', 'wORLD']) FROM (SELECT haystack FROM test_strings WHERE haystack LIKE '%string%');
SELECT COUNT(*) FROM test_strings WHERE multiSearchFirstPositionCaseInsensitive(haystack, ['this', 'is']) > 0;