CREATE TABLE test_times (event_time DateTime);
INSERT INTO test_times VALUES (toDateTime('2023-01-01 00:00:00'));
INSERT INTO test_times VALUES (toDateTime('2023-01-01 23:59:59'));
INSERT INTO test_times VALUES (toDateTime('2023-06-30 12:30:45'));
INSERT INTO test_times VALUES (toDateTime('2023-12-31 15:45:20'));
CREATE TABLE test_results AS SELECT toMinute(event_time) AS minute_component FROM test_times;
SELECT minute_component FROM test_results WHERE minute_component = 0;
SELECT minute_component FROM test_results WHERE minute_component = 59;
SELECT toMinute(toDateTime(CONCAT('2023-04-20 ', hour, ':', minute, ':00'))) AS minute FROM (SELECT number AS hour FROM numbers(24), numbers(60) AS minute);
SELECT DISTINCT toMinute(event_time) FROM test_times ORDER BY minute_component ASC;
CREATE TABLE combined_test AS SELECT t1.event_time, toMinute(t2.event_time) AS minute_component FROM test_times AS t1 JOIN test_times AS t2 ON t1.event_time < t2.event_time;
SELECT toMinute(toDateTime('2023-10-10 09:00:00')) + toMinute(toDateTime('2023-10-10 10:15:00')) AS total_minutes;
SELECT toMinute(t.event_time) AS minute_value, COUNT(*) AS occurrences FROM test_times AS t GROUP BY minute_value HAVING minute_value > 0 ORDER BY occurrences DESC;