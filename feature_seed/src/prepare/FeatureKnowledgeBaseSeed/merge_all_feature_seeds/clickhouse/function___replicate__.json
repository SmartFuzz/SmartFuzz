CREATE TABLE test_table (value String, arr Array(String));
INSERT INTO test_table VALUES ('test', ['a', 'b', 'c']);
SELECT replicate(value, arr) FROM test_table;
SELECT replicate('x', ['a', 'b', 'c', 'd', 'e']);
SELECT replicate(NULL, ['a', 'b']);
CREATE TABLE num_table (num UInt8);
INSERT INTO num_table VALUES (1), (2), (3);
SELECT replicate(5, arrayJoin([1, 2, 3]));
SELECT replicate(100, arraySlice(['a', 'b', 'c', 'd', 'e'], 1, 3));
SELECT replicate(value, ['one', 'two', 'three']) AS replicated_value FROM test_table;
SELECT replicate('test', ['array'] * 10) FROM (SELECT arrayJoin([1, 2, 3]) AS arr);
SELECT replicate(value, [arr]) FROM test_table WHERE value = 'test';
SELECT replicate(value, arrayConcat(['a'], ['b', 'c', 'd'])) AS new_array FROM test_table;
SELECT replicate(0, []) AS empty_array;
SELECT replicate(value, [arr, arr]) FROM test_table;
SELECT replicate(value, arrayReduce('groupArray', [1, 2, 3]));
SELECT replicate('test', arrayJoin(arr)) AS expanded_test FROM (SELECT ['x', 'y', 'z'] AS arr);
SELECT replicate(num, ['alpha', 'beta']) FROM num_table WHERE num > 0;