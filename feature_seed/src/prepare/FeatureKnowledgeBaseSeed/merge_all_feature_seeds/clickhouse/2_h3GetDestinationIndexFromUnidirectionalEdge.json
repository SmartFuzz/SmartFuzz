CREATE TABLE hexagons (id UInt64, hexIndex UInt64, edge UInt64, value Nullable(Int32));
INSERT INTO hexagons VALUES (1, 1248204388774707197, 1248204388774707197, 10), (2, 1248204388774707198, 1248204388774707198, NULL), (3, 1248204388774707199, NULL, 20);
SELECT id, h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination_index FROM hexagons WHERE edge IS NOT NULL AND h3GetDestinationIndexFromUnidirectionalEdge(edge) > 1248204388774707195;
SELECT id, SUM(CASE WHEN h3GetDestinationIndexFromUnidirectionalEdge(edge) > 1248204388774707190 THEN value ELSE 0 END) AS total_value FROM hexagons GROUP BY id HAVING total_value > 0;
SELECT id, h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination_index, (h3GetDestinationIndexFromUnidirectionalEdge(edge) > 1248204388774707197) AS comparison FROM hexagons ORDER BY comparison DESC;
SELECT g1.id, g2.id, h3GetDestinationIndexFromUnidirectionalEdge(g1.edge) AS edge_destination FROM hexagons g1 JOIN hexagons g2 ON h3GetDestinationIndexFromUnidirectionalEdge(g1.edge) > g2.edge WHERE g1.value IS NOT NULL;
CREATE TABLE temp_hexagons AS SELECT * FROM hexagons WHERE value IS NOT NULL;
INSERT INTO temp_hexagons SELECT id, hexIndex, edge, value FROM hexagons WHERE edge IS NULL;
SELECT COUNT(*) FROM temp_hexagons WHERE h3GetDestinationIndexFromUnidirectionalEdge(edge) IS NOT NULL;
SELECT id, h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination FROM hexagons WHERE edge IS NOT NULL AND value IS NULL HAVING destination > 0;