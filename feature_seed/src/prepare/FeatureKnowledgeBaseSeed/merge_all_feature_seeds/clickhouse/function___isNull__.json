CREATE TABLE t_null (x Int32, y Nullable(Int32));
INSERT INTO t_null VALUES (1, 2), (2, NULL), (3, 3), (4, NULL);
SELECT x FROM t_null WHERE isNull(y);
SELECT x FROM t_null WHERE isNull(y) AND x > 2;
SELECT x FROM t_null WHERE isNull(y) OR x < 3;
SELECT x FROM (SELECT x, y FROM t_null) sub WHERE isNull(sub.y);
CREATE TABLE t1 (z Nullable(Int32));
INSERT INTO t1 VALUES (NULL), (1), (2);
SELECT z FROM t1 WHERE isNull(z) AND z IS NULL;
SELECT t1.z, t_null.x FROM t1 JOIN t_null ON isNull(t1.z) WHERE t_null.x < 4;
SELECT COUNT(*) FROM t_null WHERE isNull(y) AND x IN (SELECT x FROM t_null WHERE isNull(y));
SELECT DISTINCT x FROM t_null WHERE isNull(y) ORDER BY x;
CREATE TABLE t2 (id Int32, value Nullable(Int32));
INSERT INTO t2 VALUES (1, NULL), (2, 40), (3, NULL), (4, 50);
SELECT t_null.x, t2.value FROM t_null JOIN t2 ON isNull(t_null.y) WHERE t2.id = t_null.x;
SELECT x, isNull(y) AS is_y_null FROM t_null WHERE is_y_null;
SELECT count(*) FROM t_null WHERE isNull(y) GROUP BY x;
SELECT x, isNull(y) AS is_y_null FROM t_null HAVING is_y_null = 1;