CREATE TABLE test_datetime (dt DateTime);
INSERT INTO test_datetime VALUES ('2023-04-21 10:20:30'), ('2023-12-31 23:59:59'), ('2023-01-01 00:00:00');
SELECT toSecond(dt) FROM test_datetime;
SELECT toSecond(toDateTime('2023-04-21 10:20:30')) AS second FROM test_datetime LIMIT 1;
SELECT toSecond(toDateTime(CONCAT('2023-04-21 ', '10:20:30'))) AS second FROM test_datetime;
WITH (SELECT toDateTime('2023-04-21 10:20:30')) AS dt_val SELECT toSecond(dt_val) AS second;
CREATE TABLE test_events (event_time DateTime, event_id UInt32);
INSERT INTO test_events VALUES ('2023-04-21 10:20:15', 1), ('2023-04-21 10:20:45', 2);
SELECT toSecond(event_time) FROM test_events WHERE event_id = 1;
WITH (SELECT toSecond(dt) FROM test_datetime) AS seconds SELECT SUM(seconds) FROM (SELECT toSecond(dt) as dt FROM test_datetime) AS dt_second;
SELECT toSecond(toDateTime(t.dt)) as second FROM (SELECT dt FROM test_datetime) AS t;
SELECT DISTINCT toSecond(dt) FROM (SELECT dt FROM test_datetime UNION SELECT dt FROM test_events);
CREATE TABLE nested_test (id UInt32, nested_dt DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO nested_test VALUES (1, '2023-02-28 23:59:58'), (2, '2023-02-28 00:00:00');
SELECT toSecond(nested_dt) FROM nested_test WHERE id = 1;
SELECT avg(toSecond(dt)) FROM (SELECT dt FROM test_datetime) WHERE toSecond(dt) >= 30;
SELECT t1.dt, toSecond(t1.dt) AS second1, toSecond(t2.event_time) AS second2 FROM test_datetime AS t1 JOIN test_events AS t2 ON t1.dt < t2.event_time;