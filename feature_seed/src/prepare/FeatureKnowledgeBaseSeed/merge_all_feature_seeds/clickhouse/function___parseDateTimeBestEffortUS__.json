CREATE TABLE date_tests (date_string String);
INSERT INTO date_tests VALUES ('2023-10-12 14:30:00'), ('2023-10-12 14:30:00 ±05:00'), ('20231012143000'), ('2023-10'), ('12 14:00'), ('2023-15-12 14:30:00'), ('15-10-2023'), ('10/12/2023'), ('10-15-2023'), ('2023-99-12 14:30');
SELECT parseDateTimeBestEffortUS(date_string) AS parsed_date FROM date_tests;
CREATE TABLE multi_date_tests (id UInt32, date_string String);
INSERT INTO multi_date_tests VALUES (1, '2023-10-12 14:30:00'), (2, '12/10/2023'), (3, '20231012'), (4, '10-12-23');
SELECT id, parseDateTimeBestEffortUS(date_string) AS parsed_date FROM multi_date_tests WHERE id IN (SELECT id FROM multi_date_tests WHERE id < 3);
CREATE TABLE join_date_tests (id UInt32, date_string String);
INSERT INTO join_date_tests VALUES (1, '2023-10-12'), (2, '12-10-2023'), (3, '2023-10-12 14:30:00'), (4, '10/12/2023');
SELECT jdt.id, parseDateTimeBestEffortUS(jdt.date_string) AS parsed_date FROM join_date_tests jdt JOIN multi_date_tests mdt ON jdt.id = mdt.id;
SELECT COUNT(*) AS valid_dates FROM date_tests WHERE parseDateTimeBestEffortUS(date_string) IS NOT NULL;
SELECT parsed_date FROM (SELECT parseDateTimeBestEffortUS(date_string) AS parsed_date FROM date_tests) WHERE parsed_date >= '2023-10-01' AND parsed_date <= '2023-10-31';