CREATE TABLE vectors (coords Tuple(Float32, Float32, Float32));
INSERT INTO vectors VALUES ((3, 4, 0));
INSERT INTO vectors VALUES ((0, 0, 0));
INSERT INTO vectors VALUES ((1, 1, 1));
INSERT INTO vectors VALUES ((-3, -4, 0));
INSERT INTO vectors VALUES ((1, 2, -3));
SELECT LinfNormalize(coords) FROM vectors;
SELECT LinfNormalize((5, 0, 0));
SELECT LinfNormalize((0, 0, 0));
SELECT LinfNormalize((-10, 10, 0));
SELECT LinfNormalize((100, 200, 300));
SELECT LinfNormalize((0, -5, 5)) AS normalized_vector;
SELECT LinfNormalize((0.5, 0.5, 0.5));
SELECT LinfNormalize((NULL, 3.5, 4.5));
SELECT LinfNormalize((MAX(x), MIN(y), AVG(z))) FROM (SELECT 1 AS x, 2 AS y, 3 AS z UNION ALL SELECT 4, 5, 6) AS t;
SELECT LinfNormalize(subvector) FROM (SELECT LinfNormalize((x, y, z)) AS subvector FROM vectors) AS normalized_vectors;
SELECT LinfNormalize((MAX(x), MIN(y))) FROM (SELECT 1 AS x, -1 AS y UNION ALL SELECT 3, 3) AS t;
CREATE TABLE results AS SELECT LinfNormalize(coords) AS normalized_vector FROM vectors;
SELECT * FROM results WHERE normalized_vector IS NOT NULL;