CREATE TABLE test_map (id UInt32, data Map(String, Int32));
INSERT INTO test_map VALUES (1, map('k1', 4, 'k2', 1, 'k3', 3)), (2, map('k4', 5, 'k5', 2, 'k6', 1));
SELECT id, mapPartialSort(2, data) FROM test_map;
SELECT id, mapPartialSort((k, v) -> v + 1, 3, data) FROM test_map;
SELECT id, mapPartialSort(1, map('k1', 5)) FROM test_map WHERE id = 1;
SELECT id, mapPartialSort(2, map()) FROM test_map WHERE id = 2;
SELECT id, mapPartialSort((k, v) -> k, 2, data) FROM (SELECT data FROM test_map WHERE id = 1);
SELECT id, mapPartialSort((k, v) -> tuple(v, k), 1, data) FROM test_map WHERE id = 1 UNION ALL SELECT id, mapPartialSort((k, v) -> tuple(v, k), 2, data) FROM test_map WHERE id = 2;
CREATE TABLE test_nested AS (SELECT mapPartialSort((k, v) -> v, 2, data) AS sorted_data FROM test_map);
INSERT INTO test_nested SELECT mapPartialSort(3, data) FROM test_map WHERE id = 1;