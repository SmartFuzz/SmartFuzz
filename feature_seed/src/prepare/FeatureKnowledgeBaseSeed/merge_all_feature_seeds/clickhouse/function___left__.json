CREATE TABLE test_strings (s String);
INSERT INTO test_strings VALUES ('Hello'), ('World'), ('ClickHouse'), ('DB'), ('');
SELECT left(s, 3) FROM test_strings;
SELECT left(s, -3) FROM test_strings;
SELECT left(left(s, 3), 2) FROM test_strings;
SELECT left(s, CASE WHEN length(s) < 5 THEN 1 ELSE 3 END) FROM test_strings;
SELECT left(s, 0) FROM test_strings;
SELECT left(s, LENGTH(s)) FROM test_strings;
SELECT left(s, -1) FROM test_strings;
SELECT left(s, 10) FROM test_strings;
WITH (SELECT 'ExampleString' AS example_str) SELECT left(example_str, 5);
CREATE TABLE test_substrings AS SELECT left(s, 2) AS substr FROM test_strings;
SELECT substr FROM test_substrings WHERE substr = 'Cl' OR substr = 'DB';
SELECT t1.s, left(t2.s, 2) FROM test_strings AS t1 JOIN test_strings AS t2 ON length(t1.s) > 0;
SELECT COUNT(*) FROM test_strings WHERE left(s, 1) = 'H';