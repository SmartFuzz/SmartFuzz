CREATE TABLE test_strings (id UInt32, haystack String);
INSERT INTO test_strings VALUES (1, 'number: 1, number: 2, number: 3');
INSERT INTO test_strings VALUES (2, 'abc 123 def 456 ghi');
INSERT INTO test_strings VALUES (3, 'no numbers here');
INSERT INTO test_strings VALUES (4, '');
INSERT INTO test_strings VALUES (5, 'single number 7');
SELECT extractAll(haystack, '\\d+') AS result FROM test_strings WHERE id = 1;
SELECT extractAll(haystack, '\\d+') AS result FROM test_strings WHERE id = 2;
SELECT extractAll(haystack, '\\d+') AS result FROM test_strings WHERE id = 3;
SELECT extractAll(haystack, '\\d+') AS result FROM test_strings WHERE id = 4;
SELECT extractAll(haystack, '\\d+') AS result FROM test_strings WHERE id = 5;
SELECT id, extractAll(haystack, '\\d+') AS result FROM test_strings ORDER BY id;
CREATE TABLE other_data (ref_id UInt32, description String);
INSERT INTO other_data VALUES (1, 'related info 111'), (1, 'related info 222'), (2, 'info 333');
SELECT ts.id, extractAll(ts.haystack, '\\d+') AS result, extractAll(od.description, '\\d+') AS related_results FROM test_strings ts JOIN other_data od ON ts.id = od.ref_id;
SELECT id, arrayJoin(extractAll(haystack, '\\d+')) AS extracted_numbers FROM test_strings ORDER BY id;
SELECT id, count(arrayJoin(extractAll(haystack, '\\d+'))) AS match_count FROM test_strings GROUP BY id;