CREATE TABLE ulid_test (id String, created_at DateTime64(3));
INSERT INTO ulid_test VALUES ('01GNB2S2FGN2P93QPXDNB4EN2R', ULIDStringToDateTime('01GNB2S2FGN2P93QPXDNB4EN2R'));
SELECT ULIDStringToDateTime(id) AS timestamp FROM ulid_test;
SELECT ULIDStringToDateTime('01GNB2S2FGN2P93QPXDNB4EN2R', 'UTC') AS utc_timestamp, ULIDStringToDateTime('01GNB2S2FGN2P93QPXDNB4EN2R', 'America/New_York') AS ny_timestamp FROM ulid_test;
SELECT AVG(ULIDStringToDateTime(id)) AS average_timestamps FROM (SELECT id FROM ulid_test) AS subquery;
CREATE TABLE ulid_test_2 (ulid String, datetime DateTime64(3));
INSERT INTO ulid_test_2 VALUES ('01GNB2S2FGN2P93QPXDNB4EN2R', ULIDStringToDateTime('01GNB2S2FGN2P93QPXDNB4EN2R'));
SELECT ulid_test.id, ulid_test_2.datetime FROM ulid_test JOIN ulid_test_2 ON ulid_test.id = ulid_test_2.ulid;
SELECT ULIDStringToDateTime('01GNB2S2FGN2P93QPXDNB4EN2R') AS ulid_time WHERE ULIDStringToDateTime('01GNB2S2FGN2P93QPXDNB4EN2R') < now();
SELECT ULIDStringToDateTime(id) AS timestamp, COUNT(*) FROM ulid_test GROUP BY timestamp ORDER BY timestamp DESC;
SELECT ULIDStringToDateTime((SELECT id FROM ulid_test ORDER BY created_at DESC LIMIT 1)) AS latest_timestamp;