CREATE TABLE test_table (id Int32, value Nullable(String));
INSERT INTO test_table VALUES (1, 'test'), (2, NULL), (3, 'foo');
SELECT id, toLowCardinality(value) FROM test_table WHERE value IS NOT NULL;
SELECT id, COUNT(*) FROM test_table WHERE toLowCardinality(value) IS NOT NULL GROUP BY id HAVING COUNT(*) > 0;
CREATE TABLE test_table2 (id Int32, amount Nullable(Float64));
INSERT INTO test_table2 VALUES (1, 100.50), (2, NULL), (3, 200.75);
SELECT t1.id, toLowCardinality(t1.value) FROM test_table t1 JOIN test_table2 t2 ON t1.id = t2.id WHERE t1.value IS NOT NULL AND t2.amount IS NOT NULL;
SELECT id, AVG(CASE WHEN value IS NOT NULL THEN 1 ELSE 0 END) AS not_null_ratio FROM test_table GROUP BY id HAVING not_null_ratio > 0.5;
SELECT toLowCardinality(value) AS low_value FROM (SELECT value FROM test_table WHERE value IS NOT NULL) AS filtered_values;
SELECT DISTINCT id FROM test_table WHERE toLowCardinality(value) IS NOT NULL AND id IS NOT NULL;
SELECT t1.id, MAX(t2.amount) FROM test_table t1 LEFT JOIN test_table2 t2 ON t1.id = t2.id WHERE toLowCardinality(t1.value) IS NOT NULL GROUP BY t1.id HAVING MAX(t2.amount) IS NOT NULL;
CREATE TABLE test_table3 (start_date Date, end_date Date);
INSERT INTO test_table3 VALUES (CAST('2023-01-01' AS Date), CAST('2023-12-31' AS Date));
SELECT t1.start_date, COUNT(*) FROM test_table3 t1 WHERE t1.end_date IS NOT NULL GROUP BY t1.start_date;
SELECT toLowCardinality(t1.value) AS low_value FROM (SELECT value FROM test_table WHERE value IS NOT NULL AND value <> '') t1;
SELECT COUNT(*) FROM (SELECT id, toLowCardinality(value) AS low_value FROM test_table WHERE value IS NOT NULL) AS subquery GROUP BY low_value HAVING COUNT(*) > 0;