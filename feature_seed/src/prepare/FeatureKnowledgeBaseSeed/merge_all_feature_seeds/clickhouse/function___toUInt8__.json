CREATE TABLE test_values (value String);
INSERT INTO test_values VALUES ('5'), ('10.8'), ('0'), ('255'), ('256'), ('-1'), ('abc'), ('NaN'), ('Inf');
SELECT toUInt8(value) FROM test_values;
CREATE TABLE mixed_values (val Nullable(UInt16));
INSERT INTO mixed_values VALUES (NULL), (5), (16), (255), (256), (30000);
SELECT toUInt8(val) FROM mixed_values;
CREATE TABLE float_values (fvalue Float32);
INSERT INTO float_values VALUES (1.99), (-1.0), (3.14), (255.9), (256.5), (0.0);
SELECT toUInt8(fvalue) FROM float_values;
CREATE TABLE hex_values (hex_value String);
INSERT INTO hex_values VALUES ('0'), ('0x1A'), ('0xc0fe'), ('0xff'), ('0x100');
SELECT toUInt8(hex_value) FROM hex_values WHERE NOT isNull(toUInt8(hex_value));
SELECT toUInt8((SELECT AVG(val) FROM mixed_values)) AS avg_value;
CREATE TABLE subquery_test (value Int32);
INSERT INTO subquery_test VALUES (8), (8), (8);
SELECT toUInt8((SELECT AVG(value) FROM subquery_test));
CREATE TABLE temp_data (num Int64);
INSERT INTO temp_data VALUES (42), (1000), (2048), (4096), (8192);
SELECT COUNT(*) FROM temp_data WHERE toUInt8(num) > 0;
CREATE TABLE positive_negative (num Int8);
INSERT INTO positive_negative VALUES (5), (-1), (10), (-10);
SELECT toUInt8(num) AS converted_num, num FROM positive_negative;