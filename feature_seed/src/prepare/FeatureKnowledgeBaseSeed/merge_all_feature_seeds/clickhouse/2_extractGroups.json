CREATE TABLE test_data (id Int32, text String, num Float64, value Nullable(Int32));
INSERT INTO test_data VALUES (1, 'example abc=100 test', 123.45, NULL), (2, 'another abc=200 case', 678.90, 10), (3, '', 0.0, 20);
SELECT extractGroups(text, '(\w+)\s+abc=(\d+)') AS matches FROM test_data WHERE num % 2 = 0;
SELECT id, extractGroups(text, '(\w+)=\s*(\d+)') AS extracted_groups FROM test_data WHERE value IS NOT NULL AND id % 2 = 1;
SELECT num, (SELECT count(*) FROM test_data t2 WHERE t2.num > t1.num) AS greater_count FROM test_data t1 HAVING greater_count > 1;
WITH (SELECT extractGroups(text, '(\w+)\s*abc=(\d+)') FROM test_data WHERE text != '') AS results SELECT str, (id % 3) AS mod_val FROM (SELECT text AS str, text != '' AS not_empty FROM test_data) WHERE not_empty;
SELECT num, extractGroups(text, '(\w+)\s*abc=(\d+)') AS extracted_groups FROM test_data WHERE extractGroups(text, '(\w+)\s*abc=(\d+)') IS NOT NULL AND num % 1 = 0;
CREATE TABLE temp_data AS SELECT * FROM test_data WHERE text != '' LIMIT 10;
INSERT INTO temp_data SELECT id, text, num, value FROM test_data WHERE text LIKE '%abc=%' AND value IS NOT NULL;
SELECT id, value, extractGroups(text, '(\w+)\s+abc=(\d+)') FROM temp_data WHERE (value + 1) % 2 = 0 AND value IS NULL;