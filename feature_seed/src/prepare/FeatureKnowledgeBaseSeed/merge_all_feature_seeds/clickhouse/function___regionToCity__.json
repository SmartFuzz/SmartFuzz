CREATE TABLE geobase (region_id UInt32, region_name String);
INSERT INTO geobase VALUES (1, 'City A'), (2, 'City B'), (3, 'City C'), (4, 'Region D'), (5, 'Region E');
SELECT regionToCity(1) AS city_id;
SELECT regionToCity(2) AS city_id;
SELECT regionToCity(3) AS city_id;
SELECT regionToCity(4) AS city_id;
SELECT regionToCity(5) AS city_id;
SELECT regionToCity(0) AS city_id;
SELECT regionToCity(999) AS city_id;
SELECT regionToCity(number::UInt32) AS city_id FROM numbers(10) WHERE number < 7;
SELECT regionToCity(region_id) FROM geobase WHERE region_id IN (1, 2, 3) ORDER BY region_id;
SELECT regionToCity(r.region_id) AS city_id, r.region_name FROM geobase AS r JOIN (SELECT 1 AS temp_id UNION SELECT 2 UNION SELECT 3) AS temp ON r.region_id = temp.temp_id;
SELECT COUNT(*) FROM (SELECT regionToCity(region_id) FROM geobase WHERE region_id > 0) AS cities WHERE cities.city_id > 0;
WITH (SELECT max(region_id) FROM geobase) AS max_id SELECT regionToCity(max_id) AS city_of_max_region;