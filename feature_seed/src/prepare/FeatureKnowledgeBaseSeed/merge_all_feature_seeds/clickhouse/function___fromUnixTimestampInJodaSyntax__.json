CREATE TABLE timestamps (unix_time UInt32);
INSERT INTO timestamps VALUES (1234334543), (1672531199), (0);
SELECT fromUnixTimestampInJodaSyntax(unix_time, 'yyyy-MM-dd HH:mm:ss', 'UTC') AS DateTime FROM timestamps;
CREATE TABLE events (id UInt32, event_time UInt32);
INSERT INTO events VALUES (1, 1234334543), (2, 1672531199);
SELECT e.id, fromUnixTimestampInJodaSyntax(e.event_time, 'MMM d, yyyy hh:mm a', 'UTC') AS formatted_time FROM events e;
SELECT fromUnixTimestampInJodaSyntax(unix_time, 'yyyy-MM-dd HH:mm:ss', 'UTC') AS DateTime FROM (SELECT unix_time FROM timestamps WHERE unix_time > 1000000000);
CREATE TABLE user_activities (user_id UInt32, activity_time UInt32);
INSERT INTO user_activities VALUES (101, 1234334543), (102, 1609477200);
SELECT ua.user_id, fromUnixTimestampInJodaSyntax(ua.activity_time, 'EEEE, MMMM d, yyyy', 'UTC') AS activity_date FROM user_activities ua WHERE ua.activity_time < 1700000000;
SELECT COUNT(*) FROM (SELECT fromUnixTimestampInJodaSyntax(ua.activity_time, 'yyyy.MM.dd HH:mm', 'UTC') AS activity_date FROM user_activities ua) AS formatted_dates WHERE activity_date IS NOT NULL;
SELECT ua.user_id, f.activity_date FROM user_activities ua JOIN (SELECT ua.user_id, fromUnixTimestampInJodaSyntax(ua.activity_time, 'dd-MM-yyyy', 'UTC') AS activity_date FROM user_activities ua) AS f ON ua.user_id = f.user_id WHERE f.activity_date LIKE '2023%-01';