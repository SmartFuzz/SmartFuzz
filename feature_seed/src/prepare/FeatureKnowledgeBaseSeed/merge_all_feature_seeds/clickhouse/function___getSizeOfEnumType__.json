CREATE TABLE enums_test (enum_value Enum8('a' = 1, 'b' = 2, 'c' = 3));
INSERT INTO enums_test VALUES (CAST('a' AS Enum8('a' = 1, 'b' = 2, 'c' = 3)));
SELECT getSizeOfEnumType(CAST('a' AS Enum8('a' = 1, 'b' = 2, 'c' = 3))) AS size;
SELECT getSizeOfEnumType(CAST('b' AS Enum8('a' = 1, 'b' = 2, 'c' = 3))) AS size;
SELECT getSizeOfEnumType(CAST('c' AS Enum8('a' = 1, 'b' = 2, 'c' = 3))) AS size;
SELECT getSizeOfEnumType(CAST('d' AS Enum8('a' = 1, 'b' = 2, 'c' = 3))) AS size;
CREATE TABLE enums_test_ext (enum_value Enum8('x' = 1, 'y' = 2, 'z' = 3));
INSERT INTO enums_test_ext VALUES (CAST('x' AS Enum8('x' = 1, 'y' = 2, 'z' = 3)));
SELECT getSizeOfEnumType(CAST('x' AS Enum8('x' = 1, 'y' = 2, 'z' = 3))) AS size_ext;
SELECT (SELECT getSizeOfEnumType(CAST('a' AS Enum8('a' = 1, 'b' = 2))) FROM enums_test) AS enum_size;
SELECT (SELECT getSizeOfEnumType(CAST('b' AS Enum8('a' = 1, 'b' = 2, 'c' = 3))) FROM enums_test) + (SELECT getSizeOfEnumType(CAST('y' AS Enum8('x' = 1, 'y' = 2))) FROM enums_test_ext) AS total_enum_size;
CREATE TABLE enums_join (id UInt32, enum_value Enum8('a' = 1, 'b' = 2));
INSERT INTO enums_join VALUES (1, CAST('a' AS Enum8('a' = 1, 'b' = 2))), (2, CAST('b' AS Enum8('a' = 1, 'b' = 2)));
SELECT id, getSizeOfEnumType(enum_value) FROM enums_join;
SELECT id FROM enums_join WHERE getSizeOfEnumType(enum_value) = 2;
CREATE TABLE enums_combined (id UInt32, enum_value Enum8('p' = 1, 'q' = 2));
INSERT INTO enums_combined VALUES (1, CAST('p' AS Enum8('p' = 1, 'q' = 2))), (2, CAST('q' AS Enum8('p' = 1, 'q' = 2)));
SELECT ej.id, getSizeOfEnumType(ej.enum_value) AS enum_size FROM enums_join ej JOIN enums_combined ec ON ej.id = ec.id;
SELECT getSizeOfEnumType(CAST('a' AS Enum8('a' = 1, 'b' = 2))) + getSizeOfEnumType(CAST('x' AS Enum8('x' = 1, 'y' = 2))) AS combined_size;