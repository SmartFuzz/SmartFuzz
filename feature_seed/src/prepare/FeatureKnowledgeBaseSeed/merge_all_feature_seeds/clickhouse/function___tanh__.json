CREATE TABLE test_tanh (value Float64);
INSERT INTO test_tanh VALUES (-1.0), (0.0), (1.0), (3.0), (-3.0), (1.5), (-1.5);
SELECT tanh(value) FROM test_tanh;
SELECT tanh(0.1) AS tanh_positive_least_increment, tanh(-0.1) AS tanh_negative_least_increment;
SELECT tanh(x) FROM (SELECT value AS x FROM test_tanh WHERE value <> 0);
SELECT x, tanh(x) FROM (SELECT value AS x FROM test_tanh) AS temp;
SELECT x, tanh(x) AS hyperbolic_tangent FROM (SELECT value AS x FROM test_tanh WHERE value BETWEEN -10 AND 10);
CREATE TABLE test_ranges (angle Float64);
INSERT INTO test_ranges VALUES (-100.0), (0.0), (100.0);
SELECT angle, tanh(angle) FROM test_ranges;
SELECT AVG(tanh(value)) FROM test_tanh WHERE value <= 1;
WITH (SELECT tanh(5) AS result) AS temp_result SELECT result, result > 0.9 AS is_approx_one FROM temp_result;
SELECT t1.value, t2.angle, tanh(t1.value + t2.angle) AS combined_tanh FROM test_tanh t1 CROSS JOIN test_ranges t2;
SELECT x, tanh(x) FROM (SELECT value AS x FROM test_tanh UNION SELECT angle AS x FROM test_ranges) AS combined_table;
CREATE TEMPORARY TABLE temp_table AS SELECT tanh(value) AS tanh_value FROM test_tanh;
SELECT * FROM temp_table WHERE tanh_value > 0.5;