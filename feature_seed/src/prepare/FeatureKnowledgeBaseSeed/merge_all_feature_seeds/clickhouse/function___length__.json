CREATE TABLE test_strings (str String);
INSERT INTO test_strings VALUES ('Hello, world!');
INSERT INTO test_strings VALUES ('');
INSERT INTO test_strings VALUES ('Lorem ipsum dolor sit amet, consectetur adipiscing elit.');
INSERT INTO test_strings VALUES ('1234567890');
INSERT INTO test_strings VALUES (repeat('A', 1000));
INSERT INTO test_strings VALUES (repeat('B', 1024));
SELECT length(str) FROM test_strings;
SELECT length('😊');
SELECT length(array('a', 'b', 'c', 'd'));
SELECT length(str) AS str_length FROM test_strings WHERE length(str) < 100;
SELECT str, length(str) FROM test_strings WHERE length(str) > 0 ORDER BY str_length DESC;
SELECT length(arrayJoin(['this', 'is', 'a', 'test']));
SELECT length(s) FROM (SELECT str FROM test_strings WHERE str != '') AS s;
SELECT length(str) + length(arrayJoin(['apple', 'banana'])) FROM test_strings;
SELECT str, length(str) FROM test_strings WHERE length(str) = 0 UNION ALL SELECT 'Empty String', length('');
CREATE TABLE test_nested (id UInt64, data Array(String));
INSERT INTO test_nested VALUES (1, ['Hello', 'World']), (2, ['ClickHouse', 'Database']);
SELECT id, length(arrayJoin(data)) FROM test_nested;
SELECT id, sum(length(arrayJoin(data))) AS total_length FROM test_nested GROUP BY id;