CREATE TABLE test_strings (str String, num UInt32);
INSERT INTO test_strings VALUES ('abc', 10), ('def', 5), ('ghi', 0), ('jkl', -2);
SELECT repeat(str, num) FROM test_strings;
SELECT repeat('test', 1) AS repeated_string;
SELECT repeat('hello', 2) AS repeated_string, repeat('world', 3);
SELECT repeat('a', 20), repeat('b', 0), repeat('c', -1);
SELECT repeat(repeat('x', 2), 3) AS nested_repeat;
SELECT repeat((SELECT str FROM test_strings LIMIT 1), (SELECT num FROM test_strings LIMIT 1));
SELECT str, repeat(str, num) FROM test_strings WHERE num > 0;
SELECT str, repeat(str, num + 1) FROM test_strings WHERE str LIKE 'a%';
CREATE TABLE repeat_test (id UInt32, repeated String);
INSERT INTO repeat_test SELECT id, repeat(str, num) FROM test_strings;
SELECT id, repeated FROM repeat_test WHERE repeated LIKE '%abc%';