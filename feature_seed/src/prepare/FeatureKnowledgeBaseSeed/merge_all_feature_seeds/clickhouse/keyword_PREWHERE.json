CREATE TABLE test_table (id UInt32, name String, created_at DateTime, value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table (id, name, created_at, value) VALUES (1, 'Test1', '2023-01-01 00:00:00', 10.5), (2, 'Test2', '2023-01-02 00:00:00', 20.0), (3, 'Test3', '2023-01-03 00:00:00', 30.3);
SELECT * FROM test_table PREWHERE created_at > '2023-01-01 00:00:00' AND value < 25.0;
SELECT * FROM test_table PREWHERE created_at < '2023-01-03 00:00:00' AND value > 10.0 WHERE id = 2;
SELECT id, name FROM test_table PREWHERE value >= 20.0 WHERE created_at BETWEEN '2023-01-01' AND '2023-01-10';
SELECT COUNT(*) FROM (SELECT * FROM test_table PREWHERE value < 25.0) AS subquery;
SELECT t1.id, t2.name FROM test_table AS t1 PREWHERE t1.value > 15.0 JOIN test_table AS t2 ON t1.id = t2.id WHERE t2.value < 25.0;
SELECT AVG(value) FROM test_table PREWHERE id IN (SELECT id FROM test_table WHERE value > 15.0) WHERE created_at >= '2023-01-01';
SELECT * FROM (SELECT * FROM test_table PREWHERE created_at < '2023-01-02') AS temp WHERE name LIKE 'Test%';
SELECT * FROM test_table PREWHERE created_at >= '2023-01-01' AND created_at < '2023-01-04' WHERE value IS NOT NULL;