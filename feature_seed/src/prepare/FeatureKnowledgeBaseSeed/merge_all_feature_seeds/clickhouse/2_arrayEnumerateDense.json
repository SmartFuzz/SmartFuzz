CREATE TABLE test_array (id Int32, values Array(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_array VALUES (1, [10, 20, 10, 30]), (2, [30, 20, 40, 10]), (3, [NULL, NULL, 10]), (4, [5, 10, 5, 2, 5]);
SELECT id, arrayEnumerateDense(values) AS enumerated FROM test_array WHERE arrayEnumerateDense(values) + 1 = 3;
SELECT id, arrayEnumerateDense(values) AS enumerated FROM test_array WHERE enumerated + 5 > 5 ORDER BY id;
WITH (SELECT arrayEnumerateDense(values) AS enumerated FROM test_array WHERE id = 1) AS subquery SELECT id FROM test_array WHERE EXISTS (SELECT 1 FROM subquery WHERE enumerated > 1);
SELECT id, arrayEnumerateDense(arrayReverse(values)) AS reverse_enumerated FROM test_array WHERE reverse_enumerated + 10 = 11 ORDER BY reverse_enumerated DESC;
CREATE TABLE temp_table (num Int32, str String) ENGINE = MergeTree() ORDER BY num;
INSERT INTO temp_table VALUES (1, '5'), (2, '10'), (3, '20'), (NULL, '30');
SELECT t.num, arrayEnumerateDense(ARRAY(SELECT CAST(str AS Int32) + num FROM temp_table t WHERE str IS NOT NULL AND num IS NOT NULL)) AS dense_result FROM temp_table t GROUP BY num;
SELECT id, arrayEnumerateDense(NULLIF(values, [])) AS enumerated_result FROM test_array WHERE NULLIF(enumerated_result, 0) IS NOT NULL;
SELECT id, arrayEnumerateDense([1, 2, 2] + [3, NULL]) AS combined_enumerated FROM test_array HAVING combined_enumerated[1] > 1;
ALTER TABLE test_array ADD COLUMN desc String;
UPDATE test_array SET desc = 'Test description' WHERE id = 1;
SELECT id, arrayEnumerateDense(values) + 1 AS test_value FROM test_array WHERE test_value IS NOT NULL ORDER BY test_value DESC;