CREATE TABLE hamming_test (id UInt32, tuple1 Tuple(UInt8, UInt8, UInt8), tuple2 Tuple(UInt8, UInt8, UInt8)) ENGINE = Memory;
INSERT INTO hamming_test VALUES (1, (1, 2, 3), (3, 2, 1)), (2, (1, 1, 1), (1, 1, 1)), (3, (0, 0, 0), (0, 0, 1)), (4, (255, 127, 63), (255, 127, 62));
SELECT id, tupleHammingDistance(tuple1, tuple2) AS distance FROM hamming_test WHERE distance NOT LIKE 0;
SELECT id, tupleHammingDistance((a, b, c), (b, c, a)) AS hamming FROM (SELECT 1 AS a, 2 AS b, 3 AS c);
WITH (SELECT tuple1, tuple2 FROM hamming_test) AS tuples SELECT tupleHammingDistance(t.tuple1, t.tuple2) AS distance FROM tuples t WHERE distance NOT LIKE 0;
CREATE TABLE more_complex_hamming_test (id UInt32, str1 String, str2 String) ENGINE = Memory;
INSERT INTO more_complex_hamming_test VALUES (1, 'abc', 'cba'), (2, 'xyz', 'zyx'), (3, '', ''), (4, NULL, NULL);
SELECT id, tupleHammingDistance(tuple(0, 1, 2), tuple(1, 1, 1)) AS hamming_distance, str1 NOT LIKE str2 AS mismatch FROM more_complex_hamming_test;
SELECT id, tupleHammingDistance(tuple(reverse(str1), reverse(str2)), tuple(str2, str1)) AS rev_distance FROM more_complex_hamming_test WHERE str1 NOT LIKE str2;
WITH (SELECT id, tupleHammingDistance(tuple1, tuple2) AS distance FROM hamming_test) AS results SELECT AVG(distance) AS avg_distance FROM results GROUP BY dimension HAVING avg_distance > 1;