CREATE TABLE numbers (num UInt32);
INSERT INTO numbers VALUES (1), (2), (3), (4), (5);
SELECT groupBitXor(num) FROM numbers;
CREATE TABLE more_numbers (num Int32);
INSERT INTO more_numbers VALUES (-1), (0), (1), (2), (3);
SELECT groupBitXor(num) FROM more_numbers;
CREATE TABLE combined_numbers AS numbers;
INSERT INTO combined_numbers SELECT num FROM more_numbers;
SELECT groupBitXor(num) FROM combined_numbers;
CREATE TABLE data1 (id UInt32, value UInt32);
CREATE TABLE data2 (id UInt32, value UInt32);
INSERT INTO data1 VALUES (1, 10), (2, 20);
INSERT INTO data2 VALUES (1, 30), (2, 40);
SELECT groupBitXor(a.value) FROM data1 a JOIN data2 b ON a.id = b.id;
SELECT groupBitXor(CASE WHEN value > 0 THEN value ELSE 0 END) FROM more_numbers;
SELECT groupBitXor(num) FROM (SELECT num FROM numbers WHERE num > 2);
SELECT a.id, groupBitXor(a.value) FROM data1 a JOIN data2 b ON a.id = b.id GROUP BY a.id;
CREATE TABLE empty_table (num Int32);
SELECT groupBitXor(num) FROM empty_table;
SELECT groupBitXor(num) FROM (SELECT DISTINCT num FROM more_numbers);
SELECT groupBitXor(num) FROM numbers WHERE num % 2 = 0;
SELECT groupBitXor(num) FROM (SELECT num FROM more_numbers WHERE num < 3) AS subquery;