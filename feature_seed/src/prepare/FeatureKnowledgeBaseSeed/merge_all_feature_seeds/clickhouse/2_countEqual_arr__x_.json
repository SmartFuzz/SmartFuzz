CREATE TABLE test_table (id UInt32, values Array(Int32), date Date, description String, score Float32);
INSERT INTO test_table VALUES (1, [1, 2, NULL, 4], '2023-01-01', 'First entry', 1.5), (2, [NULL, NULL, 3, 4], '2023-01-02', 'Second entry', 2.0), (3, [2, 2, 3, NULL], '2023-01-03', 'Third entry', NULL);
SELECT id, countEqual(values, NULL) AS null_count FROM test_table WHERE id NOT BETWEEN 1 AND 2 GROUP BY id HAVING null_count > 1;
SELECT id, score FROM test_table WHERE score NOT BETWEEN 0 AND 2 AND countEqual(values, 2) > 0 ORDER BY id DESC;
SELECT id, countEqual(values, description) AS count_mismatch FROM test_table WHERE countEqual(values, NULL) NOT BETWEEN 0 AND 2 GROUP BY id HAVING count_mismatch < 1;
SELECT id, countEqual(values, CAST(score AS Int32)) AS score_as_int FROM test_table WHERE score NOT BETWEEN 1.0 AND 3.0 GROUP BY id HAVING score_as_int > 0;
SELECT id, date, countEqual(values, MAX(score)) OVER (PARTITION BY id) AS max_score_count FROM test_table WHERE values NOT BETWEEN [1, 2] AND [4] ORDER BY date;