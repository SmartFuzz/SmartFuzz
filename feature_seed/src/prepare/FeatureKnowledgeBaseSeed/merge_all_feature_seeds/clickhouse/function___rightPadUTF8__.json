CREATE TABLE test_strings (s String);
INSERT INTO test_strings VALUES ('Hello'), ('World'), ('Test'), ('абвг'), ('Unicode 💻');
SELECT rightPadUTF8(s, 10, '*') FROM test_strings;
SELECT rightPadUTF8(s, 10) FROM test_strings WHERE length(s) < 10;
SELECT rightPadUTF8(s, 10, 'x') FROM test_strings WHERE s LIKE 'T%';
SELECT rightPadUTF8('абвг', 3) AS shortened FROM test_strings;
SELECT rightPadUTF8('example', 14, ' ') AS padded_space FROM test_strings;
SELECT rightPadUTF8(s, 5, 'pad') AS result FROM test_strings WHERE s NOT LIKE '%Test%';
SELECT rightPadUTF8(s, 8) AS padded WHERE s IN (SELECT s FROM test_strings WHERE s LIKE 'H%');
SELECT rightPadUTF8('Combined', 15, ' - ') AS complex_example, rightPadUTF8('Subquery', 15) FROM (SELECT s FROM test_strings WHERE length(s) > 4) AS sub;
SELECT s, rightPadUTF8(s, length(s) + 5) AS fully_padded FROM test_strings;
SELECT COUNT(*) FROM (SELECT rightPadUTF8(s, 12) AS padded FROM test_strings WHERE length(s) <= 5) AS sub_query;
SELECT rightPadUTF8(s, 10, '*'), rightPadUTF8('testing', 10, '#') FROM (SELECT s FROM test_strings LIMIT 2) AS sub;