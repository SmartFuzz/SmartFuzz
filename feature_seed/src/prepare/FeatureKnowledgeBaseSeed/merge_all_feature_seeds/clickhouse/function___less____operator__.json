CREATE TABLE test_table_1 (a INT, b INT) ENGINE = MergeTree() ORDER BY a;
INSERT INTO test_table_1 VALUES (1, 2), (3, 2), (2, 3), (2, 1);
SELECT * FROM test_table_1 WHERE a < b;
SELECT a, b FROM test_table_1 WHERE a < b ORDER BY a;
CREATE TABLE test_table_2 (x FLOAT, y FLOAT) ENGINE = MergeTree() ORDER BY x;
INSERT INTO test_table_2 VALUES (1.1, 2.2), (3.3, 3.3), (2.1, 1.1);
SELECT * FROM test_table_2 WHERE less(x, y);
SELECT x, y FROM test_table_2 WHERE less(x, 2.5) AND less(y, 2.5);
CREATE TABLE test_table_3 (id INT, value INT) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_3 VALUES (1, 10), (2, 20), (3, 30);
SELECT id FROM test_table_3 WHERE value < (SELECT AVG(value) FROM test_table_3);
SELECT id, value FROM test_table_3 WHERE value < (SELECT MAX(value) FROM test_table_3 WHERE id < 3);
CREATE TABLE test_table_4 (num INT, category STRING) ENGINE = MergeTree() ORDER BY num;
INSERT INTO test_table_4 VALUES (1, 'A'), (2, 'B'), (3, 'C'), (0, 'D');
SELECT * FROM test_table_4 WHERE num < 2 AND category = 'A';
SELECT num, category FROM test_table_4 WHERE num < (SELECT MIN(num) FROM test_table_4 WHERE category = 'C');
SELECT a FROM (SELECT a, b FROM (SELECT a, b FROM test_table_1) AS inner_query) AS outer_query WHERE less(a, 2);
SELECT * FROM test_table_2 AS t2 WHERE t2.x < ANY (SELECT x FROM test_table_2 WHERE y < 3);
CREATE TABLE joined_table (id INT, value INT) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE another_table (id INT, ref_value INT) ENGINE = MergeTree() ORDER BY id;
INSERT INTO joined_table VALUES (1, 10), (2, 20), (3, 30);
INSERT INTO another_table VALUES (1, 15), (2, 5), (3, 25);
SELECT jt.id, jt.value FROM joined_table jt JOIN another_table at ON jt.id = at.id WHERE jt.value < at.ref_value;