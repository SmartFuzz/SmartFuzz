CREATE TABLE test_tuples (num_tuple Tuple(Int32, Int32, Int32), div_tuple Tuple(Int32, Int32, Int32));
INSERT INTO test_tuples VALUES ((15, 10, 5), (5, 5, 5));
SELECT tupleIntDiv(num_tuple, div_tuple) FROM test_tuples;
INSERT INTO test_tuples VALUES ((15, 10, 5), (0, 5, 5));
SELECT tupleIntDiv(num_tuple, div_tuple) FROM test_tuples;
INSERT INTO test_tuples VALUES ((15, 10.5, 5), (5, 5.5, 5));
SELECT tupleIntDiv(num_tuple, div_tuple) FROM test_tuples;
INSERT INTO test_tuples VALUES ((15, 10, 5), (5, 5.2, 5));
SELECT tupleIntDiv(num_tuple, div_tuple) FROM test_tuples;
WITH (SELECT (15, 10, 5) AS nums, (5, 5, 5) AS divs) AS tuples SELECT tupleIntDiv(nums, divs);
WITH (SELECT (15, 10, 5) AS nums, (10, 0, 5) AS divs) AS tuples SELECT tupleIntDiv(nums, divs);
CREATE TABLE another_table (id UInt32, num_tuple Tuple(Int32, Int32), div_tuple Tuple(Int32, Int32));
INSERT INTO another_table VALUES (1, (20, 30), (4, 0));
SELECT id, tupleIntDiv(num_tuple, div_tuple) FROM another_table;
INSERT INTO another_table VALUES (2, (22, 35), (5.2, 5));
SELECT id, tupleIntDiv(num_tuple, div_tuple) FROM another_table;
SELECT tupleIntDiv((10, 20, 30), (2, 4, 0));
SELECT tupleIntDiv((10, 20, 30), (3, 2, 1));
SELECT tupleIntDiv((15.7, 10.9, 7.3), (5, 2, 0));
INSERT INTO test_tuples VALUES ((9, 18, 27), (3, 1, 0));
SELECT tupleIntDiv(num_tuple, div_tuple) FROM test_tuples WHERE div_tuple = (3, 1, 0);
SELECT tupleIntDiv((48, 72), (6, 8));
SELECT tupleIntDiv((12, 20), (5, 0));