CREATE TABLE SearchLog (UserID UInt32, SearchPhrase String, Timestamp DateTime);
INSERT INTO SearchLog VALUES (1, 'apple', '2023-01-01 12:00:00'), (1, 'banana', '2023-01-01 12:01:00'), (2, 'apple', '2023-01-01 12:02:00'), (3, 'apple', '2023-01-01 12:03:00'), (4, 'apple', '2023-01-01 12:04:00'), (5, 'banana', '2023-01-01 12:05:00'), (6, 'banana', '2023-01-01 12:06:00');
SELECT SearchPhrase FROM SearchLog GROUP BY SearchPhrase HAVING uniqUpTo(3)(UserID) >= 4;
SELECT SearchPhrase, COUNT(*) as Frequency FROM SearchLog GROUP BY SearchPhrase HAVING uniqUpTo(2)(UserID) > 2;
CREATE TABLE UserActivity (UserID UInt32, Activity String, ActivityTime DateTime);
INSERT INTO UserActivity VALUES (1, 'login', '2023-01-01 12:00:00'), (1, 'search', '2023-01-01 12:01:00'), (2, 'search', '2023-01-01 12:02:00'), (3, 'search', '2023-01-01 12:03:00'), (4, 'search', '2023-01-01 12:04:00');
SELECT S.SearchPhrase FROM SearchLog S JOIN UserActivity A ON S.UserID = A.UserID WHERE A.Activity = 'search' GROUP BY S.SearchPhrase HAVING uniqUpTo(3)(S.UserID) >= 3;
SELECT SearchPhrase, AVG(Timestamp) as AvgTime FROM SearchLog GROUP BY SearchPhrase HAVING uniqUpTo(2)(UserID) = 3;
WITH (SELECT COUNT(*) FROM (SELECT DISTINCT SearchPhrase FROM SearchLog)) AS TotalPhrases SELECT SearchPhrase FROM SearchLog GROUP BY SearchPhrase HAVING uniqUpTo(1)(UserID) >= TotalPhrases;
SELECT SearchPhrase FROM (SELECT SearchPhrase, uniqUpTo(5)(UserID) as uniqueUsers FROM SearchLog GROUP BY SearchPhrase) AS userCounts WHERE uniqueUsers > 2;
CREATE TABLE KeywordStats (Keyword String, UserCount UInt32);
INSERT INTO KeywordStats VALUES ('apple', 3), ('banana', 2);
SELECT K.Keyword FROM KeywordStats K JOIN SearchLog S ON K.Keyword = S.SearchPhrase GROUP BY K.Keyword HAVING uniqUpTo(4)(S.UserID) = 5;