CREATE TABLE test_table (id Int32, timestamp_value DateTime, description String);
INSERT INTO test_table VALUES (1, YYYYMMDDhhmmssToDateTime(20230911131415), 'Sample data 1'), (2, YYYYMMDDhhmmssToDateTime(20230911131416), 'Sample data 2');
SELECT id FROM test_table WHERE timestamp_value NOT LIKE YYYYMMDDhhmmssToDateTime(20230911131415) AND description NOT LIKE 'Sample data%';
SELECT id, count(*) as count FROM (SELECT id, YYYYMMDDhhmmssToDateTime(20230911131415) as converted_time FROM test_table WHERE timestamp_value NOT LIKE YYYYMMDDhhmmssToDateTime(20230911131415) GROUP BY id) WHERE count > 0 HAVING count NOT LIKE 1;
SELECT DISTINCT id, description FROM (SELECT id, NOT LIKE(converted_time, '20230911%') AS time_check, YYYYMMDDhhmmssToDateTime(toUInt32(20230911131415)) AS converted_time FROM (SELECT id, timestamp_value, description FROM test_table) AS inner_table) WHERE time_check = 1;
SELECT AVG(toUnixTimestamp(timestamp_value)) AS avg_timestamp FROM (SELECT timestamp_value, timestamp_value NOT LIKE YYYYMMDDhhmmssToDateTime(20230911131415) FROM test_table) WHERE timestamp_value IS NOT NULL;
SELECT id FROM (SELECT id, description FROM test_table WHERE timestamp_value NOT LIKE YYYYMMDDhhmmssToDateTime(toInt32(NULL))) GROUP BY id HAVING count(*) NOT LIKE 0;
CREATE TABLE temp_table AS SELECT * FROM test_table WHERE timestamp_value NOT NULL;
INSERT INTO temp_table SELECT id, YYYYMMDDhhmmssToDateTime(20230911131417) AS timestamp_value, description FROM test_table WHERE description NOT LIKE 'Sample data 1';