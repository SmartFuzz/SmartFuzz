CREATE TABLE test_h3 (id UInt32, h3_str String, value Float64);
INSERT INTO test_h3 VALUES (1, '89184926cc3ffff', 10.5), (2, '89184926ccdffff', NULL), (3, 'invalid_h3', 5.0), (4, '', 20.0);
SELECT id, stringToH3(h3_str) AS h3_index FROM test_h3 WHERE h3_index BETWEEN 0 AND 10;
SELECT id, h3_str FROM test_h3 WHERE stringToH3(h3_str) = 0 AND value IS NOT NULL;
SELECT id, stringToH3(h3_str) AS h3_index FROM (SELECT id, h3_str FROM test_h3 WHERE value > 5) WHERE h3_index BETWEEN 0 AND 15;
SELECT COUNT(*) FROM (SELECT id, stringToH3(h3_str) AS h3_index FROM test_h3 GROUP BY id HAVING h3_index < 10) WHERE h3_index IS NOT NULL;
SELECT id, h3_str, value FROM test_h3 WHERE stringToH3(h3_str) BETWEEN stringToH3('89184926cc3ffff') AND stringToH3('89184926ccdffff');
SELECT id FROM (SELECT id, stringToH3(h3_str) AS h3_index FROM test_h3) WHERE h3_index BETWEEN (SELECT MIN(stringToH3(h3_str)) FROM test_h3) AND (SELECT MAX(stringToH3(h3_str)) FROM test_h3);
SELECT id, COUNT(*) FROM test_h3 GROUP BY id HAVING stringToH3(h3_str) BETWEEN 0 AND 10 AND value IS NOT NULL;
CREATE TABLE temp_h3 AS SELECT stringToH3(h3_str) AS h3_index FROM test_h3 WHERE h3_str <> '';