CREATE TABLE ip_test (num UInt32);
INSERT INTO ip_test VALUES (0), (2130706433), (2149583361), (4294967295);
SELECT IPv4NumToString(num) AS ip_address FROM ip_test;
SELECT IPv4NumToString(num) AS ip_address FROM (SELECT num FROM ip_test WHERE num > 0);
SELECT (SELECT IPv4NumToString(num) FROM ip_test WHERE num = 0) AS ip_zero, (SELECT IPv4NumToString(num) FROM ip_test WHERE num = 2130706433) AS ip_local;
CREATE TABLE ip_example AS SELECT num FROM ip_test WHERE num BETWEEN 0 AND 4294967295;
SELECT IPv4NumToString(num) AS ip_address FROM ip_example WHERE num IN (SELECT num FROM ip_test WHERE num MOD 2 = 0);
SELECT t1.num, t2.ip_address FROM (SELECT num FROM ip_test) AS t1 LEFT JOIN (SELECT IPv4NumToString(num) AS ip_address FROM ip_test) AS t2 ON t1.num = t2.num;
WITH (SELECT num FROM ip_test LIMIT 1) AS temp_num SELECT IPv4NumToString(temp_num) AS ip_address;
CREATE TEMPORARY TABLE temp_ip AS SELECT num FROM ip_test WHERE num < 2147483648;
SELECT IPv4NumToString(num) AS ip_address FROM temp_ip UNION ALL SELECT IPv4NumToString(4294967295);