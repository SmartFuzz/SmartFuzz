CREATE TABLE test_strings (haystack String, needle String);
INSERT INTO test_strings VALUES ('garbage', 'ARG');
INSERT INTO test_strings VALUES ('HelloWorld', 'hElLo');
INSERT INTO test_strings VALUES ('abcdefg', 'BC');
INSERT INTO test_strings VALUES ('CaseSensitivity', 'sensitive');
INSERT INTO test_strings VALUES ('This is a test', 'is a');
INSERT INTO test_strings VALUES ('AnotherExample', 'example');
INSERT INTO test_strings VALUES ('SampleText', 'text');
INSERT INTO test_strings VALUES ('Empty', '');
INSERT INTO test_strings VALUES ('', 'non-empty');
INSERT INTO test_strings VALUES ('MixedCASE', 'mixedcase');
INSERT INTO test_strings VALUES ('DifferentCASE', 'DIFFERENT');
SELECT hasSubsequenceCaseInsensitive(haystack, needle) FROM test_strings;
SELECT haystack, needle, hasSubsequenceCaseInsensitive(haystack, needle) AS result FROM test_strings WHERE result = 1;
SELECT haystack, needle FROM test_strings WHERE hasSubsequenceCaseInsensitive(haystack, needle) = 0;
SELECT haystack FROM test_strings WHERE hasSubsequenceCaseInsensitive(haystack, (SELECT needle FROM test_strings WHERE haystack = 'HelloWorld')) = 1;
SELECT DISTINCT haystack FROM test_strings JOIN (SELECT DISTINCT needle FROM test_strings) AS subsequences ON hasSubsequenceCaseInsensitive(test_strings.haystack, subsequences.needle) = 1;
SELECT haystack, needle FROM test_strings WHERE haystack LIKE '%s%' AND hasSubsequenceCaseInsensitive(haystack, needle) = 1;