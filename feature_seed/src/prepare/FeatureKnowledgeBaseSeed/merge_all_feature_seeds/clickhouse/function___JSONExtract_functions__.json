CREATE TABLE json_test (data JSON);
INSERT INTO json_test VALUES ('{"a": "hello", "b": [-100, 200.0, 300]}');
INSERT INTO json_test VALUES ('{"x": null, "y": true, "z": [1, 2, 3]}');
SELECT isValidJSON(data) FROM json_test;
SELECT JSONHas(data, 'b') FROM json_test;
SELECT JSONExtractKey(data, 1) FROM json_test;
SELECT JSONLength(data, 'b') FROM json_test;
SELECT JSONType(data) FROM json_test;
SELECT JSONType(data, 'a') FROM json_test;
SELECT JSONExtractBool(data, 'y') FROM json_test;
SELECT JSONExtractInt(data, 'b', -1) as x, toTypeName(x) FROM json_test;
SELECT JSONExtractUInt(data, 'z', 1) as y, toTypeName(y) FROM json_test;
SELECT JSONExtractFloat(data, 'b', 2) as z, toTypeName(z) FROM json_test;
SELECT JSONExtractString(data, 'a') FROM json_test;
SELECT JSONExtract(data, 'Tuple(String, Array(Float64))', 'a', 'b') FROM json_test;
SELECT JSONExtractKeysAndValues(data, 'x', 'Int8') FROM json_test;
SELECT JSON_QUERY(data, '$.b[0]') FROM json_test;
SELECT JSONAllPaths(data) FROM json_test;
SELECT JSONDynamicPaths(data) FROM json_test;
CREATE TABLE np_test (json_data JSON);
INSERT INTO np_test VALUES ('{"a": {"b": {"c": 1}}}, {"x": {"y": {"z": 2}}}');
SELECT JSONExists(json_data, '$.a.b.c') FROM np_test;
SELECT JSON_VALUE(json_data, '$.x.y.z') FROM np_test;
SELECT JSON_TYPE(json_data, '$.a') FROM np_test;
WITH (SELECT JSONExtractKeysAndValues(json_data, 'a', 'Int8') FROM np_test) as keys_values SELECT * FROM keys_values;
SELECT jsonMergePatch('{"key1": 1}', '{"key2": 2}') AS merged;
CREATE TABLE multi_json (json_field JSON);
INSERT INTO multi_json VALUES ('{"data": [{"id": 1, "value": "a"}, {"id": 2, "value": "b"}]}');
SELECT JSONExtract(json_field, 'Array(Tuple(Int32, String))', 'data') FROM multi_json;
SELECT toJSONString(JSONExtract(json_field, 'data')) FROM multi_json;
SELECT JSONExists(json_field, '$.data[*].value') FROM multi_json;
SELECT JSONExtractKeysAndValues(json_field, 'data', 'String') FROM multi_json;