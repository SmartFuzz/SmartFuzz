CREATE TABLE test_tuples (num_tuple Tuple(Int32, Int32, Int32), mod_tuple Tuple(Int32, Int32, Int32));
INSERT INTO test_tuples VALUES ((15, 10, 5), (5, 3, 2));
SELECT tupleModulo(num_tuple, mod_tuple) FROM test_tuples;
INSERT INTO test_tuples VALUES ((20, 25, 30), (4, 0, 3));
SELECT tupleModulo(num_tuple, mod_tuple) FROM test_tuples;
SELECT tupleModulo((12, 18, 24), (4, 6, 0));
WITH (SELECT num_tuple, mod_tuple FROM test_tuples) AS tuples SELECT tupleModulo(num_tuple, mod_tuple) FROM tuples;
CREATE TABLE another_table (id UInt32, values Tuple(Int32, Int32));
INSERT INTO another_table VALUES (1, (100, 200)), (2, (50, 75));
SELECT id, tupleModulo((values.1, values.2), (10, 25)) FROM another_table;
SELECT tupleModulo((1, 2, 3), (1, 1, 1));
SELECT tupleModulo((9, 18, 27), (3, 6, 9)) AS remainders, (SELECT AVG(remainders) FROM (SELECT tupleModulo((9, 18, 27), (3, 6, 9)) AS remainders));