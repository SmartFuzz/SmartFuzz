CREATE TABLE test_strings (input_string String) ENGINE = MergeTree() ORDER BY input_string;
INSERT INTO test_strings VALUES ('ClickHouse'), ('clickhouse'), ('ClicKhouSe'), ('CLICKHOUSE');
SELECT ngramMinHashArgCaseInsensitive(input_string, 3, 6) FROM test_strings;
SELECT ngramMinHashArgCaseInsensitive(input_string) FROM test_strings WHERE input_string LIKE 'Cl%';
SELECT a.input_string, ngramMinHashArgCaseInsensitive(a.input_string, 4, 8) FROM test_strings AS a JOIN test_strings AS b ON a.input_string <> b.input_string;
SELECT ngramMinHashArgCaseInsensitive('Hello World!', 5, 5) AS hashes;
SELECT ngramMinHashArgCaseInsensitive('Fuzzy Testing', 3) AS hashes, ngramMinHashArgCaseInsensitive('Fuzzy Testing', 5) AS hashes_different_size;
ALTER TABLE test_strings ADD COLUMN ngram_results Tuple(Tuple(String), Tuple(String));
UPDATE test_strings SET ngram_results = ngramMinHashArgCaseInsensitive(input_string, 4) WHERE input_string = 'ClickHouse';
SELECT ngramMinHashArgCaseInsensitive(input_string, 10) FROM test_strings HAVING length(input_string) > 5;