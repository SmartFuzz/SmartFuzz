CREATE TABLE test_table (id Int32, value Nullable(String));
INSERT INTO test_table VALUES (1, '42'), (2, NULL), (3, 'abc'), (4, '0xc0fe'), (5, '-1.5'), (6, 'Inf');
SELECT id, toInt32OrDefault(value, -1) AS converted_value FROM test_table WHERE value IS NOT NULL;
SELECT id, toInt32OrDefault(value, -1) AS converted_value FROM test_table WHERE toInt32OrDefault(value, -1) IS NOT NULL;
SELECT id, toInt32OrDefault(CAST(NULL AS String), -1) AS null_conversion, value IS NOT NULL AS is_value_present FROM test_table;
SELECT id, toInt32OrDefault(value, -1) AS converted_value FROM test_table WHERE toInt32OrDefault(value, -1) IS NOT NULL GROUP BY id HAVING converted_value >= 0;
CREATE TABLE example_table (a Int32, b Nullable(Float64));
INSERT INTO example_table VALUES (1, 3.14), (2, NULL), (3, 2.718), (4, -Inf);
SELECT a, toInt32OrDefault(b, -1) AS converted_b FROM example_table WHERE toInt32OrDefault(b, -1) IS NOT NULL ORDER BY converted_b ASC;
SELECT id FROM (SELECT id, toInt32OrDefault(value, -1) AS converted_value FROM test_table) AS subquery WHERE converted_value > 0;
CREATE TABLE complex_table (name String, score Nullable(Int32), extra Float64);
INSERT INTO complex_table VALUES ('Alice', 100, 1.5), ('Bob', NULL, 3.0), ('Charlie', -1, 4.5);
SELECT name, score, toInt32OrDefault(toString(score), -2) AS score_status FROM complex_table WHERE score IS NOT NULL;
SELECT name, COUNT(*) AS cnt, toInt32OrDefault(MAX(score), -1) AS max_score FROM complex_table GROUP BY name HAVING max_score > 0;
SELECT (SELECT toInt32OrDefault(b, -1) FROM example_table WHERE a = 1 AND b IS NOT NULL) AS sub_query_value, name FROM complex_table WHERE score IS NOT NULL;
SELECT name, CASE WHEN score IS NOT NULL THEN toInt32OrDefault(toString(score), -1) ELSE -1 END AS score_check FROM complex_table;
SELECT a, toInt32OrDefault(CAST(NULL AS String), -1) AS conversion_check FROM example_table WHERE a IS NOT NULL;