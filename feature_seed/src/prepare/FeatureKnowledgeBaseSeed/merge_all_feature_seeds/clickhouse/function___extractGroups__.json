CREATE TABLE test_strings (input_string String);
INSERT INTO test_strings VALUES ('hello abc=111 world'), ('foo bar=222 baz'), ('test key="value with spaces"');
SELECT extractGroups(input_string, '([a-zA-Z]+)\s*=\s*([a-zA-Z0-9]+)') AS result FROM test_strings;
SELECT extractGroups(input_string, '([a-zA-Z]+)\s*=(\"[^\"]+\"|\\w+)') AS result FROM test_strings WHERE input_string LIKE '%abc%';
SELECT extractGroups(input_string, '.*?(\w+)\s*(=)\s*(\"[^\"]*\"|\w+)') AS result FROM test_strings WHERE input_string != 'not present';
CREATE TABLE patterns (regex String);
INSERT INTO patterns VALUES ('([a-zA-Z]+)\s*=\s*([a-zA-Z0-9]+)');
SELECT extractGroups(input_string, regex) AS result FROM test_strings JOIN patterns ON input_string LIKE '%abc%';
WITH (SELECT patterns.regex FROM patterns LIMIT 1) AS reg EXCEPT SELECT extractGroups(input_string, reg) AS result FROM test_strings;
SELECT extractGroups(input_string, '([a-z]+)\s*=\s*"([^\"]+)"') AS result FROM (SELECT input_string FROM test_strings WHERE input_string LIKE '%key%');
SELECT input_string, extractGroups(input_string, '([a-z]+)\s*=\s*(\w+)') FROM test_strings WHERE input_string IN (SELECT input_string FROM test_strings WHERE input_string LIKE '%bar%') ORDER BY input_string DESC;