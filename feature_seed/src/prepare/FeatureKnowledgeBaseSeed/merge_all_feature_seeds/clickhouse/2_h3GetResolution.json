CREATE TABLE h3_test (index UInt64, description String, created_at DateTime);
INSERT INTO h3_test VALUES (639821929606596015, 'Valid H3 index', now()), (999999999999999999, 'Invalid H3 index', now()), (0, 'Edge H3 index', now()), (123456789012345678, 'Another valid index', now());
SELECT h3GetResolution(index) AS resolution, h3GetResolution(index) - 3 AS adjusted_resolution FROM h3_test WHERE h3GetResolution(index) IS NOT NULL;
SELECT index, h3GetResolution(index) AS res, CASE WHEN h3GetResolution(index) < 5 THEN 'Low' ELSE 'High' END AS resolution_category FROM h3_test WHERE index > 0 ORDER BY res;
SELECT h3GetResolution(index) AS res, AVG(h3GetResolution(index) - 2) AS avg_adjusted FROM h3_test GROUP BY index HAVING res >= 0;
SELECT t1.index, t1.description, h3GetResolution(t1.index) - h3GetResolution(t2.index) AS resolution_diff FROM h3_test t1 JOIN h3_test t2 ON t1.index <> t2.index WHERE t1.index IS NOT NULL;
SELECT index, h3GetResolution(index) AS res FROM h3_test WHERE h3GetResolution(index) IN (SELECT h3GetResolution(index) FROM h3_test WHERE index < 500000000000000000) HAVING res > 2;
SELECT h3GetResolution(CAST('abc' AS UInt64)) AS resolution_try_cast, h3GetResolution(NULL) AS resolution_try_null FROM h3_test;
CREATE TABLE h3_test_extended AS SELECT index, h3GetResolution(index) FROM h3_test WHERE index < 1000000000;
INSERT INTO h3_test_extended VALUES (200000000000000000, h3GetResolution(200000000000000000)), (300000000000000000, h3GetResolution(300000000000000000));
SELECT h3GetResolution(index) + 1 AS new_resolution, COUNT(*) FROM h3_test_extended GROUP BY new_resolution HAVING new_resolution < 16;