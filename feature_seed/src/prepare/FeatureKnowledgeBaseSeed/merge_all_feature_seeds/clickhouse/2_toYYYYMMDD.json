CREATE TABLE test_dates (event_date DateTime, event_name String, event_code UInt32) ENGINE = MergeTree() ORDER BY event_date;
INSERT INTO test_dates (event_date, event_name, event_code) VALUES (now(), 'Event A', 1), (toDate('2023-01-01'), 'Event B', 2), (toDate('2023-12-31'), 'Event C', 3);
SELECT event_name, toYYYYMMDD(event_date, 'UTC') AS formatted_date FROM test_dates WHERE toYYYYMMDD(event_date, 'UTC') BETWEEN toYYYYMMDD(toDate('2023-01-01'), 'UTC') AND toYYYYMMDD(toDate('2023-12-31'), 'UTC') ORDER BY formatted_date;
SELECT event_name, COUNT(*) AS num_events FROM test_dates GROUP BY event_name HAVING num_events BETWEEN 1 AND 10;
INSERT INTO test_dates (event_date, event_name, event_code) VALUES (NULL, 'Event D', 4);
SELECT event_name, toYYYYMMDD(event_date) AS formatted_date FROM test_dates WHERE formatted_date BETWEEN 20230101 AND 20231231 AND event_code BETWEEN 1 AND (SELECT max(event_code) FROM test_dates);
SELECT event_name, toYYYYMMDD(event_date, 'US/Eastern') AS formatted_date FROM (SELECT event_name, event_date FROM test_dates WHERE event_code = 1) AS subquery WHERE formatted_date IS NOT NULL;
CREATE TABLE temp_table AS SELECT event_name, toYYYYMMDD(event_date) AS formatted_date FROM test_dates;
SELECT event_name FROM temp_table WHERE formatted_date BETWEEN (toYYYYMMDD(toStartOfMonth(now()), 'US/Eastern') - 100) AND (toYYYYMMDD(now(), 'US/Eastern') + 100) ORDER BY event_name DESC;
DROP TABLE IF EXISTS temp_table;