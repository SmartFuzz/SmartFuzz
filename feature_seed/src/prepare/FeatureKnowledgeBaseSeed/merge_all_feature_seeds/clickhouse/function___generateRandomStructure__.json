SELECT generateRandomStructure();
SELECT generateRandomStructure(0);
SELECT generateRandomStructure(1);
SELECT generateRandomStructure(128);
SELECT generateRandomStructure(64, 42);
SELECT generateRandomStructure(10, 0);
CREATE TABLE my_table AS SELECT generateRandomStructure(5);
CREATE TABLE random_structure (structure String) ENGINE = Memory;
INSERT INTO random_structure VALUES (generateRandomStructure(8));
WITH generateRandomStructure(3) AS random_columns SELECT * FROM random_structure;
SELECT * FROM random_structure WHERE structure LIKE CONCAT('%', generateRandomStructure(2), '%');
SELECT generateRandomStructure(5) AS cols, generateRandomStructure(3) AS cols2 FROM my_table JOIN random_structure ON cols = cols2;
SELECT generateRandomStructure(seed) FROM (SELECT 1 AS seed UNION ALL SELECT 2);
SELECT generateRandomStructure(15) AS col_def FROM my_table WHERE col_def IS NOT NULL;
SELECT generateRandomStructure(NULL) AS random_structure WHERE random_structure NOT LIKE '%;
