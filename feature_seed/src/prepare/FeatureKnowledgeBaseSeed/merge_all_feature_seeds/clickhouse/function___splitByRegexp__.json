CREATE TABLE test_strings (id Int32, input_string String);
INSERT INTO test_strings VALUES (1, 'abc123def456ghi');
INSERT INTO test_strings VALUES (2, '789xyz');
INSERT INTO test_strings VALUES (3, '');
INSERT INTO test_strings VALUES (4, 'noNumbersHere');
INSERT INTO test_strings VALUES (5, '1a2b3c');
SELECT splitByRegexp('\d+', input_string) FROM test_strings;
SELECT id, splitByRegexp('\d+', input_string) AS substrings FROM test_strings WHERE id = 1;
SELECT id, splitByRegexp('\D+', input_string) AS substrings FROM test_strings;
SELECT id, splitByRegexp('', input_string) AS substrings FROM test_strings;
SELECT id, splitByRegexp('\s+', input_string) AS substrings FROM (SELECT 'abc def ghi' AS input_string);
SELECT id, substrings FROM (SELECT id, splitByRegexp('\d+', input_string, 2) AS substrings FROM test_strings) WHERE arrayLength(substrings) > 1;
SELECT id, splitByRegexp('([a-z]+)', input_string) AS substrings FROM test_strings;
SELECT id, splitByRegexp('\d+', '') AS substrings FROM test_strings;
SELECT splitByRegexp('\+|\-|\*|\/', 'a+b-c*d/e');
SELECT splitByRegexp('foo|bar', 'foobarbarfoo') AS split_result;
SELECT id, splitByRegexp('\D+', input_string, 3) AS substrings FROM test_strings;