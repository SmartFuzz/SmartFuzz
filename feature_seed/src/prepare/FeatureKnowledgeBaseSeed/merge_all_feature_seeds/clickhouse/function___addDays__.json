CREATE TABLE test_dates (event_date Date, event_date_time DateTime, event_date_time_string String);
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
SELECT addDays(event_date, 5) AS add_days_with_date FROM test_dates;
SELECT addDays(event_date_time, 10) AS add_days_with_date_time FROM test_dates;
SELECT addDays(event_date_time_string, 15) AS add_days_with_date_time_string FROM test_dates;
WITH event_date AS toDate('2023-12-31'), event_date_time AS toDateTime('2023-12-31 23:59:59') SELECT addDays(event_date, -1) AS add_days_negative, addDays(event_date_time, 1) AS add_days_timestamp_increment;
WITH (SELECT MIN(event_date) FROM test_dates) AS min_date, (SELECT MAX(event_date_time) FROM test_dates) AS max_date SELECT addDays(min_date, 5) AS min_date_plus_5_days, addDays(max_date, -10) AS max_date_minus_10_days;
SELECT addDays(toDate('2024-02-29'), 1) AS leap_year_handling;
WITH toDate('2024-01-01') AS start_date SELECT addDays(start_date, 30), addDays(start_date, 60), addDays(start_date, 90);
CREATE TABLE temp_dates AS SELECT addDays(toDate('2024-01-01'), number) AS computed_date FROM numbers(30);
SELECT computed_date FROM temp_dates WHERE computed_date BETWEEN toDate('2024-01-01') AND toDate('2024-01-31');