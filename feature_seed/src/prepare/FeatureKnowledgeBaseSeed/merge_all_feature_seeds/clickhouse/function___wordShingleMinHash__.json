CREATE TABLE test_strings (id UInt32, string String);
INSERT INTO test_strings VALUES (1, 'ClickHouse® is a column-oriented database management system (DBMS) for online analytical processing of queries (OLAP).');
INSERT INTO test_strings VALUES (2, 'ClickHouse is great for analytics and big data.');
INSERT INTO test_strings VALUES (3, 'This is a test string for ClickHouse word shingles.');
SELECT wordShingleMinHash(string) AS hash_result FROM test_strings WHERE id = 1;
SELECT wordShingleMinHash(string, 2) AS hash_result FROM test_strings WHERE id = 2;
SELECT wordShingleMinHash(string, 25, 10) AS hash_result FROM test_strings WHERE id = 3;
SELECT wordShingleMinHash(string, 1, 1) AS hash_result FROM test_strings;
SELECT id, wordShingleMinHash(string, 4, 5) AS hash_result FROM test_strings;
SELECT id, hash_result FROM (SELECT id, wordShingleMinHash(string, 5) AS hash_result FROM test_strings) WHERE id <= 2;
SELECT wordShingleMinHash(string, 6, 6) AS hash_result FROM test_strings WHERE string LIKE '%analytics%';
SELECT wordShingleMinHash(CONCAT(string, ' is awesome!'), 3, 8) AS hash_result FROM test_strings;
SELECT A.id, A.string, B.hash_result FROM test_strings AS A JOIN (SELECT id, wordShingleMinHash(string) AS hash_result FROM test_strings WHERE id != 1) AS B ON A.id = 1;
DROP TABLE test_strings;