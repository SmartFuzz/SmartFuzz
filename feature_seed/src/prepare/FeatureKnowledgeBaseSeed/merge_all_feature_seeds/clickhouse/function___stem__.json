CREATE TABLE words (id Int32, word String) ENGINE = Memory;
INSERT INTO words VALUES (1, 'running'), (2, 'jumps'), (3, 'easily'), (4, 'fairly'), (5, 'blessings');
SELECT arrayMap(x -> stem('en', x), groupArray(word)) as res FROM words;
CREATE TABLE languages (lang_code String, lang_name String) ENGINE = Memory;
INSERT INTO languages VALUES ('en', 'English'), ('es', 'Spanish');
SELECT lang_name, arrayMap(x -> stem(lang_code, x), groupArray(word)) as stemmed_words FROM languages JOIN words ON lang_code = 'en' GROUP BY lang_name;
SELECT arrayJoin(arrayMap(x -> stem('en', x), ['programm', 'programmer', 'programming'])) as stemmed FROM tuples;
CREATE TABLE duplicates (id Int32, word String) ENGINE = Memory;
INSERT INTO duplicates VALUES (1, 'testing'), (2, 'test'), (3, 'tested'), (4, 'tester'), (5, 'test');
SELECT word, arrayMap(x -> stem('en', x), groupArray(word)) as distinct_stems FROM duplicates GROUP BY word;
SELECT distinct stem('en', word) FROM words;
SELECT stem('en', word) as stemmed_word FROM words WHERE word LIKE 'b%';
SELECT word, stem('en', word) as stemmed_word FROM words WHERE id = 1 UNION SELECT word, stem('en', word) as stemmed_word FROM words WHERE id = 2;
CREATE TABLE sentence_words (sentence_id Int32, word String) ENGINE = Memory;
INSERT INTO sentence_words VALUES (1, 'The'), (1, 'quick'), (1, 'brown'), (1, 'fox'), (2, 'jumps'), (2, 'over'), (2, 'the'), (2, 'lazy'), (2, 'dog');
SELECT sentence_id, arrayMap(x -> stem('en', x), groupArray(word)) as stems FROM sentence_words GROUP BY sentence_id;