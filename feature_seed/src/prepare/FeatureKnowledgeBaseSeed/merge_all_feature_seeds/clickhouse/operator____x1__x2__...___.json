CREATE TABLE test_tuples (id UInt32, data Tuple(String, Int32));
INSERT INTO test_tuples VALUES (1, ('test', 123)), (2, ('example', 456));
SELECT id, data FROM test_tuples WHERE data.1 = 'test';
CREATE TABLE another_tuples (id UInt32, info Tuple(Tuple(String, Int32), UInt32));
INSERT INTO another_tuples VALUES (1, (('inner', 1), 100)), (2, (('outer', 2), 200));
SELECT id, info.1.1, info.2 FROM another_tuples WHERE info.1.2 < 150;
SELECT id, data, (data.1, data.2) FROM test_tuples WHERE id IN (SELECT id FROM test_tuples WHERE data.2 > 100);
CREATE TABLE complex_tuples (id UInt32, nested Tuple(Tuple(String, String), Tuple(Int32, Int32)));
INSERT INTO complex_tuples VALUES (1, (('pair1', 'pair2'), (1, 2))), (2, (('pair3', 'pair4'), (3, 4)));
SELECT id, nested FROM complex_tuples WHERE nested.1.1 = 'pair1' AND nested.2.1 + nested.2.2 = 3;
SELECT (data.1, data.2) AS tuple_data FROM test_tuples WHERE id = 1 UNION ALL SELECT (info.1.1, info.1.2) FROM another_tuples WHERE id = 1;
CREATE TABLE join_tuples (key UInt32, value Tuple(String, Nullable(Int32)));
INSERT INTO join_tuples VALUES (1, ('value1', 5)), (2, ('value2', NULL));
SELECT t1.key, t1.value.1, t2.value.1 FROM join_tuples t1 JOIN join_tuples t2 ON t1.key = t2.key WHERE t1.value.2 IS NOT NULL;