CREATE TABLE test_intervals (id Int32, start_time DateTime);
INSERT INTO test_intervals VALUES (1, toDateTime('2024-06-15 00:00:00'));
SELECT start_time + toIntervalSecond(30) AS new_time FROM test_intervals WHERE id = 1;
SELECT start_time + toIntervalSecond(60.5) AS new_time FROM test_intervals WHERE id = 1;
WITH toIntervalSecond(-15) AS negative_interval SELECT start_time + negative_interval AS new_time FROM test_intervals WHERE id = 1;
WITH (SELECT toIntervalSecond(25) AS interval) AS subquery SELECT start_time + interval FROM test_intervals WHERE id = 1;
SELECT start_time, (SELECT toIntervalSecond(90) FROM test_intervals WHERE id = 1) AS interval FROM test_intervals;
CREATE TABLE test_dates (name String, date_value Date) ENGINE = MergeTree() ORDER BY name;
INSERT INTO test_dates VALUES ('test1', toDate('2024-06-15')), ('test2', toDate('2024-06-16'));
SELECT date_value, date_value + toIntervalSecond(300) AS new_date_value FROM test_dates;
WITH (SELECT MAX(date_value) FROM test_dates) AS max_date SELECT max_date + toIntervalSecond(600) AS extended_date FROM test_dates;
SELECT t1.date_value, t2.name FROM test_dates AS t1 JOIN (SELECT date_value + toIntervalSecond(1200) AS name FROM test_dates) AS t2 ON t1.date_value < t2.name;
WITH toIntervalSecond(1000) AS interval_1, toIntervalSecond(2000) AS interval_2 SELECT start_time + interval_1 AS first_addition, start_time + interval_2 AS second_addition FROM test_intervals WHERE id = 1;