CREATE TABLE test_table (id UInt8, value String, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, '10'), (2, '256'), (3, 'invalid'), (4, '3.14159'), (5, '255');
SELECT id, toUInt8(value) || ' - converted' AS converted_value FROM test_table WHERE toUInt8(value) IS NOT NULL;
SELECT id, toUInt8(value) || toUInt8('1') AS combined FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value LIKE '%3%') HAVING combined > 1;
SELECT id, COUNT(*) AS value_count FROM test_table GROUP BY toUInt8(value) HAVING value_count > 1;
SELECT id, toUInt8(value) || CAST(toUInt8(created_at) AS String) AS combined_time FROM test_table WHERE created_at > now() - INTERVAL 1 DAY;
CREATE TEMPORARY TABLE temp_table (temp_value String) ENGINE = Memory;
INSERT INTO temp_table SELECT value FROM test_table WHERE value != 'invalid' AND value != '';
SELECT toUInt8('0') || ' is zero' AS zero_value FROM temp_table UNION SELECT toUInt8('255') || ' is max' AS max_value;
SELECT id, toUInt8(value) FROM test_table WHERE value IS NULL OR value = '';