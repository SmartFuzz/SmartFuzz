CREATE TABLE numbers_table (number UInt64);
INSERT INTO numbers_table SELECT number FROM numbers(1e6);
SELECT uniqCombined(number) FROM numbers_table;
CREATE TABLE array_table (arr Array(UInt64));
INSERT INTO array_table VALUES ([1, 2, 3, 4]), ([2, 3, 4, 5]), ([4, 5, 6, 7]);
SELECT uniqCombined(arr) FROM array_table;
CREATE TABLE nested_table (id UInt64, value UInt64);
INSERT INTO nested_table VALUES (1, 10), (2, 20), (3, 20), (4, 30);
SELECT id, uniqCombined(value) FROM nested_table GROUP BY id;
CREATE TABLE join_table1 (id UInt64, value UInt64);
CREATE TABLE join_table2 (id UInt64, description String);
INSERT INTO join_table1 VALUES (1, 100), (2, 200), (3, 100);
INSERT INTO join_table2 VALUES (1, 'First'), (2, 'Second'), (3, 'Third');
SELECT j.id, uniqCombined(j.value) FROM join_table1 AS j JOIN join_table2 AS d ON j.id = d.id GROUP BY j.id;
CREATE TABLE hll_table (id UInt64, number UInt32);
INSERT INTO hll_table SELECT number FROM numbers(1e7);
SELECT uniqCombined(17)(number) FROM hll_table;
SELECT uniqCombined(number, number % 5) FROM numbers_table;
SELECT uniqCombined(17)(arr) FROM array_table WHERE arr[1] < 5;
CREATE TABLE tuple_table (data Tuple(UInt64, String));
INSERT INTO tuple_table VALUES ((1, 'One')), ((2, 'Two')), ((2, 'Two')), ((3, 'Three'));
SELECT uniqCombined(data) FROM tuple_table;