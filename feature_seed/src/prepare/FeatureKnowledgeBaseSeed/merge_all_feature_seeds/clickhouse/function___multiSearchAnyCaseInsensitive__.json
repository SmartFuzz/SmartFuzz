CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('ClickHouse'), ('Data Science'), ('SQL Functions'), ('Fuzzy Search'), ('Case Insensitive'), ('CLICKHOUSE'), ('some random text');
SELECT multiSearchAnyCaseInsensitive(haystack, ['c', 'H']) FROM test_strings;
SELECT multiSearchAnyCaseInsensitive(haystack, ['f', 's']) FROM test_strings WHERE haystack LIKE '%random%';
SELECT haystack, multiSearchAnyCaseInsensitive(haystack, ['data', 'sql']) AS search_result FROM test_strings WHERE search_result = 1;
SELECT COUNT(*) FROM test_strings WHERE multiSearchAnyCaseInsensitive(haystack, ['a', 'e', 'i', 'o', 'u']) = 1;
SELECT DISTINCT haystack FROM test_strings WHERE multiSearchAnyCaseInsensitive(haystack, ['c']) = 1 UNION SELECT DISTINCT haystack FROM test_strings WHERE multiSearchAnyCaseInsensitive(haystack, ['d']) = 1;
WITH (SELECT haystack FROM test_strings WHERE haystack LIKE '%search%') AS subquery SELECT multiSearchAnyCaseInsensitive(haystack, ['H', 'e']) FROM subquery;
SELECT haystack FROM (SELECT haystack FROM test_strings WHERE multiSearchAnyCaseInsensitive(haystack, ['f', 'F']) = 0) AS filtered WHERE haystack != '';
CREATE TABLE another_table (knows String);
INSERT INTO another_table VALUES ('Hello World'), ('ClickHouse is Great'), ('Data Analysis'), ('No matches here');
SELECT multiSearchAnyCaseInsensitive(a.haystack, [b.knows]) FROM test_strings a JOIN another_table b ON multiSearchAnyCaseInsensitive(a.haystack, ['ClickHouse']) = 1;