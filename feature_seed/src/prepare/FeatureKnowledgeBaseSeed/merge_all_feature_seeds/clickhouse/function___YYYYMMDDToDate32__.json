CREATE TABLE test_dates (id UInt32, date_str String) ENGINE = Memory;
INSERT INTO test_dates VALUES (1, '20230101'), (2, '20221231'), (3, '20230229'), (4, '20000229'), (5, '19000101');
SELECT id, YYYYMMDDToDate32(date_str) AS converted_date FROM test_dates;
SELECT id, YYYYMMDDToDate32(date_str) AS converted_date FROM test_dates WHERE YYYYMMDDToDate32(date_str) > '1970-01-01';
SELECT id, converted_date FROM (SELECT id, YYYYMMDDToDate32(date_str) AS converted_date FROM test_dates) WHERE converted_date IS NOT NULL;
CREATE TABLE test_dates2 (id UInt32, date_value Date32) ENGINE = Memory;
INSERT INTO test_dates2 SELECT id, YYYYMMDDToDate32(date_str) FROM test_dates;
SELECT t1.id, t1.date_str, t2.date_value FROM test_dates t1 JOIN test_dates2 t2 ON (t1.id = t2.id) WHERE t2.date_value < '2023-01-01';
SELECT id, YYYYMMDDToDate32(date_str) AS converted_date FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE date_str LIKE '2023%');
WITH (SELECT min(id) FROM test_dates) AS min_id SELECT id, YYYYMMDDToDate32(date_str) AS converted_date FROM test_dates WHERE id > min_id;