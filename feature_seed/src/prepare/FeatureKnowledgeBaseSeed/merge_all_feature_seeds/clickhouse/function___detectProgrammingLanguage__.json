CREATE TABLE source_codes (code String);
INSERT INTO source_codes VALUES ('#include <stdio.h>');
INSERT INTO source_codes VALUES ('def hello_world(): print("Hello, world!")');
INSERT INTO source_codes VALUES ('public static void main(String[] args) { System.out.println("Hello, World!");
}');
INSERT INTO source_codes VALUES ('print("Hello, World!")');
SELECT detectProgrammingLanguage(code) FROM source_codes;
CREATE TABLE complex_codes (code String);
INSERT INTO complex_codes VALUES ('function main() { var msg = "Hello World";
console.log(msg);
}');
INSERT INTO complex_codes VALUES ('echo "Hello World";
');
INSERT INTO complex_codes VALUES ('class HelloWorld { public static void main(String[] args) { System.out.println("Hello World");
}}');
SELECT detectProgrammingLanguage(code) FROM complex_codes;
SELECT detectProgrammingLanguage(code) FROM (SELECT code FROM source_codes UNION SELECT code FROM complex_codes);
SELECT detectProgrammingLanguage(code) FROM (SELECT code FROM source_codes WHERE code LIKE '%Hello%') AS filtered;
CREATE TABLE languages (language String);
INSERT INTO languages VALUES ('C');
INSERT INTO languages VALUES ('Python');
INSERT INTO languages VALUES ('Java');
INSERT INTO languages VALUES ('JavaScript');
INSERT INTO languages SELECT detectProgrammingLanguage(code) FROM source_codes;