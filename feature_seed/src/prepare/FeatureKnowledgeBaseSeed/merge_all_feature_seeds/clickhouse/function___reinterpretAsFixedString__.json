CREATE TABLE test_table (value UInt32, timestamp DateTime);
INSERT INTO test_table VALUES (0, toDateTime('1970-01-01 00:00:00'));
INSERT INTO test_table VALUES (255, toDateTime('1970-01-01 01:01:05'));
INSERT INTO test_table VALUES (16777215, toDateTime('1970-01-01 23:59:59'));
INSERT INTO test_table VALUES (4294967295, toDateTime('2038-01-19 03:14:07'));
CREATE TABLE another_table (date_value Date, fixed_string_value FixedString(4));
INSERT INTO another_table VALUES (toDate('1970-03-07'), reinterpretAsFixedString(255));
SELECT reinterpretAsFixedString(value) FROM test_table WHERE value < 256;
SELECT reinterpretAsFixedString(toDateTime('1970-01-01 01:01:05')), reinterpretAsFixedString(toDate('1970-03-07')) FROM test_table;
SELECT a.value, reinterpretAsFixedString(a.value) AS fixed_str FROM test_table AS a JOIN another_table AS b ON reinterpretAsFixedString(a.value) = b.fixed_string_value;
SELECT reinterpretAsFixedString(s.value), reinterpretAsFixedString(toUInt32(4)) FROM (SELECT 4 AS value) AS s;
SELECT reinterpretAsFixedString(1.0), reinterpretAsFixedString(1.515) FROM (SELECT 1.0 AS num1, 1.515 AS num2) AS params;
SELECT reinterpretAsFixedString(timestamp) FROM test_table ORDER BY timestamp;
SELECT reinterpretAsFixedString(toDate('1970-01-01')) AS date_string, reinterpretAsFixedString(toDateTime('1970-01-01 01:01:05')) AS datetime_string FROM test_table LIMIT 1;