CREATE TABLE html_test (id UInt32, content String);
INSERT INTO html_test VALUES (1, '<p>Valid text <i>with</i> tags.</p>');
INSERT INTO html_test VALUES (2, '<div>Many <b>levels</b> <span>of</span> <i>tags</i> <script>alert("alert");
</script></div>');
INSERT INTO html_test VALUES (3, '<![CDATA[<!DOCTYPE html><html><head><title>Title</title></head><body>Content</body></html>]]> <p>Text</p>');
INSERT INTO html_test VALUES (4, '<script><![CDATA[Content <b>inside</b> CDATA]]></script><p>Text after script</p>');
INSERT INTO html_test VALUES (5, '<style>body {background-color: #f0f0f0;
}</style><p>Hello World!</p>');
INSERT INTO html_test VALUES (6, '<!-- Comment here --><p>Visible text after comment</p>');
INSERT INTO html_test VALUES (7, '<a test="}"><b>Invalid tag</b></a>');
INSERT INTO html_test VALUES (8, '<p>Hello<!--nested-->world!</p>');
INSERT INTO html_test VALUES (9, '<p>Mix of<!-- comments <script>this should be ignored</script> --> text.</p>');
SELECT extractTextFromHTML(content) FROM html_test WHERE id IN (1, 2, 3);
SELECT extractTextFromHTML(content) AS extracted_text FROM html_test WHERE content LIKE '%<script>%';
SELECT extractTextFromHTML(content) AS clean_text FROM html_test ORDER BY id DESC;
CREATE TABLE another_test (id UInt32, extra_content String);
INSERT INTO another_test VALUES (1, '<b>Join this</b> <p>with another table</p>');
SELECT a.id, extractTextFromHTML(a.content) AS cleaned, b.extra_content FROM html_test AS a JOIN another_test AS b ON a.id = b.id;
SELECT id, extractTextFromHTML(content) AS result FROM html_test WHERE content LIKE '%<b>%';
SELECT COUNT(*) FROM html_test WHERE extractTextFromHTML(content) = 'Hello World!';