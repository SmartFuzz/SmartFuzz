CREATE TABLE test_strings (id UInt32, str Nullable(String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'HelloWorld'), (2, NULL), (3, 'TestString'), (4, 'SampleString'), (5, 'AnotherSample');
SELECT id, str, endsWith(str, 'Sample') AS ends_with_sample FROM test_strings WHERE endsWith(CAST(str AS String), 'String') IS NOT NULL;
SELECT id, str FROM test_strings WHERE (endsWith(str, 'World') IS NOT NULL) AND (str IS NOT NULL) ORDER BY id;
CREATE TABLE test_numbers (id UInt32, num Nullable(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_numbers VALUES (1, NULL), (2, -1), (3, 0), (4, 1), (5, 100000);
SELECT id, num, endsWith(CAST(num AS String), '0') AS ends_with_zero FROM test_numbers WHERE num IS NOT NULL;
SELECT t.id, t.str FROM test_strings t JOIN test_numbers n ON t.id = n.id WHERE endsWith(t.str, 'String') IS NOT NULL AND n.num IS NOT NULL;
CREATE TABLE test_aggregates (id UInt32, group_id UInt32, value UInt32) ENGINE = MergeTree() ORDER BY (group_id, id);
INSERT INTO test_aggregates VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30), (4, 2, NULL);
SELECT group_id, COUNT(*) AS count, endsWith(ANY(value), '0') AS ends_with_zero FROM test_aggregates GROUP BY group_id HAVING ends_with_zero IS NOT NULL;
SELECT id, endsWith(str, 'World') AS result FROM test_strings WHERE str IS NOT NULL UNION ALL SELECT id, endsWith(CAST(num AS String), '1') FROM test_numbers WHERE num IS NOT NULL;
SELECT id, count(*) OVER (PARTITION BY group_id) AS row_count FROM test_aggregates WHERE endsWith(CAST(value AS String), '0') IS NOT NULL;
DROP TABLE IF EXISTS test_strings;
DROP TABLE IF EXISTS test_numbers;
DROP TABLE IF EXISTS test_aggregates;