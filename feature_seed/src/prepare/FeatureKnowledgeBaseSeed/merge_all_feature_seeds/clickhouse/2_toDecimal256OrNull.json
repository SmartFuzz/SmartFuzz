CREATE TABLE test_table (id UInt64, date_col DateTime, num_col String, decimal_col Nullable(Decimal(76, 10)));
INSERT INTO test_table VALUES (1, '2023-01-01 10:00:00', '256', toDecimal256OrNull('123.456', 10));
INSERT INTO test_table VALUES (2, '2023-02-01 11:00:00', 'NaN', toDecimal256OrNull('0.999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999', 76));
INSERT INTO test_table VALUES (3, '2023-03-01 12:00:00', '', toDecimal256OrNull('', 2));
INSERT INTO test_table VALUES (4, '2023-03-02 13:00:00', 'Inf', toDecimal256OrNull('Inf', 5));
SELECT id, EXTRACT(YEAR FROM date_col) AS year, toDecimal256OrNull(num_col, 2) AS decimal_value FROM test_table WHERE decimal_value IS NOT NULL;
SELECT id, EXTRACT(MONTH FROM date_col) AS month, toDecimal256OrNull(num_col, 0) AS decimal_value FROM test_table WHERE date_col >= '2023-01-01 00:00:00' AND decimal_value < 100;
SELECT AVG(toDecimal256OrNull(num_col, 4)) AS avg_decimal_value FROM test_table GROUP BY EXTRACT(DAY FROM date_col) HAVING avg_decimal_value IS NOT NULL;
SELECT id, date_col, num_col FROM test_table JOIN (SELECT id, EXTRACT(MONTH FROM date_col) AS month FROM test_table WHERE date_col < now()) subquery ON test_table.id = subquery.id;
SELECT EXTRACT(DAY FROM date_col) AS day, toDecimal256OrNull(num_col, 1) AS decimal_value FROM test_table WHERE decimal_value IS NOT NULL ORDER BY day DESC;