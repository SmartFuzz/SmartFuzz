CREATE TABLE geo_points (lon Float64, lat Float64);
INSERT INTO geo_points VALUES (37.79506683, 55.71290588), (0, 0), (-180, -90), (180, 90), (100.0, 45.0);
SELECT geoToS2(lon, lat) AS s2Index FROM geo_points;
SELECT geoToS2(lon, lat) AS s2Index FROM geo_points WHERE lon > 0 AND lat > 0;
SELECT COUNT(*) FROM (SELECT geoToS2(lon, lat) AS s2Index FROM geo_points WHERE lon BETWEEN -180 AND 180 AND lat BETWEEN -90 AND 90);
SELECT SUM(geoToS2(lon, lat)) AS total_s2 FROM geo_points;
CREATE TABLE geo_analysis AS SELECT geoToS2(lon, lat) AS s2Index FROM geo_points;
WITH (SELECT MIN(lon) AS min_lon, MAX(lat) AS max_lat FROM geo_points) AS bounds SELECT geoToS2(bounds.min_lon, bounds.max_lat) AS boundary_s2Index;
SELECT g1.lon, g1.lat, geoToS2(g2.lon, g2.lat) AS s2Index FROM geo_points AS g1 JOIN geo_points AS g2 ON g1.lon <> g2.lon AND g1.lat <> g2.lat;
CREATE TABLE processed_geo AS SELECT geoToS2(lon, lat) AS s2Index FROM geo_points WHERE lon != 0 OR lat != 0;