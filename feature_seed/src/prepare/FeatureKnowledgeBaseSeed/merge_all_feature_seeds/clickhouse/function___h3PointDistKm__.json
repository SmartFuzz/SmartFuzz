CREATE TABLE geo_points (lat1 FLOAT64, lon1 FLOAT64, lat2 FLOAT64, lon2 FLOAT64);
INSERT INTO geo_points VALUES (-10.0, 0.0, 10.0, 0.0);
INSERT INTO geo_points VALUES (0.0, 0.0, 0.0, 0.0);
INSERT INTO geo_points VALUES (90.0, 0.0, -90.0, 0.0);
INSERT INTO geo_points VALUES (45.0, 90.0, -45.0, -90.0);
INSERT INTO geo_points VALUES (12.3456, 98.7654, 12.3456, 98.7654);
SELECT h3PointDistKm(lat1, lon1, lat2, lon2) AS distance FROM geo_points;
SELECT lat1, lon1, lat2, lon2, h3PointDistKm(lat1, lon1, lat2, lon2) AS distance FROM geo_points WHERE lat1 < 0;
WITH (SELECT MAX(lat1) AS max_lat1 FROM geo_points) AS max_lat, (SELECT MIN(lon1) AS min_lon1 FROM geo_points) AS min_lon SELECT h3PointDistKm(max_lat.max_lat1, min_lon.min_lon1, 0, 0) AS distance;
SELECT g1.lat1, g1.lon1, g2.lat2, g2.lon2, h3PointDistKm(g1.lat1, g1.lon1, g2.lat2, g2.lon2) AS distance FROM geo_points AS g1 JOIN geo_points AS g2 ON g1.lat1 != g2.lat2;
SELECT (SELECT h3PointDistKm(lat1, lon1, lat2, lon2) FROM geo_points) AS overall_distance;