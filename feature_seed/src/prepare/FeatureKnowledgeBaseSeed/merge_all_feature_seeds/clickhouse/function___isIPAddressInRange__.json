CREATE TABLE ip_test (address String, prefix String);
INSERT INTO ip_test VALUES ('192.168.1.1', '192.168.0.0/16');
INSERT INTO ip_test VALUES ('10.0.0.5', '10.0.0.0/8');
INSERT INTO ip_test VALUES ('172.16.5.4', '172.16.0.0/12');
INSERT INTO ip_test VALUES ('192.168.1.10', '192.168.1.0/24');
INSERT INTO ip_test VALUES ('::1', '::/128');
INSERT INTO ip_test VALUES ('2001:db8::1', '2001:db8::/32');
INSERT INTO ip_test VALUES ('::ffff:192.168.1.1', '::ffff:192.168.1.0/120');
SELECT isIPAddressInRange(address, prefix) FROM ip_test;
SELECT address, prefix, isIPAddressInRange(address, prefix) AS in_range FROM ip_test WHERE in_range = 1;
SELECT address FROM ip_test WHERE isIPAddressInRange(address, '192.168.0.0/16') = 1;
SELECT address FROM ip_test WHERE isIPAddressInRange(address, '172.16.0.0/12') AND address LIKE '172.%';
SELECT COUNT(*) AS valid_ips FROM ip_test WHERE isIPAddressInRange(address, prefix) = 1;
SELECT a.address, b.prefix FROM ip_test AS a JOIN ip_test AS b ON isIPAddressInRange(a.address, b.prefix) = 1;
SELECT address, prefix FROM ip_test WHERE address IN (SELECT address FROM ip_test WHERE isIPAddressInRange(address, '10.0.0.0/8') = 1);
SELECT a.address, b.prefix FROM ip_test AS a CROSS JOIN ip_test AS b WHERE isIPAddressInRange(a.address, b.prefix) = 0;
SELECT isIPAddressInRange('10.10.10.10', '10.0.0.0/8') AS within_range;
SELECT isIPAddressInRange('256.256.256.256', '192.168.1.0/24') AS invalid_ip;
SELECT isIPAddressInRange('127.0.0.1', '127.0.0.0/8') AS localhost_check;
SELECT address, prefix, isIPAddressInRange(address, prefix) AS result FROM ip_test ORDER BY result DESC;
SELECT address FROM (SELECT address, isIPAddressInRange(address, '::1/128') AS loopback FROM ip_test) AS subquery WHERE loopback = 1;