CREATE TABLE accounts (id UInt32, name String, salary Float32) Engine = MergeTree() ORDER BY id;
CREATE TABLE staff (id UInt32, position String, wage Float32) Engine = MergeTree() ORDER BY id;
GRANT SELECT * ON accounts TO john;
GRANT SELECT (id, position) ON staff TO mira;
REVOKE SELECT (id) ON staff FROM mira;
REVOKE SELECT * ON accounts FROM john;
REVOKE SELECT salary ON accounts FROM john;
REVOKE ALL PRIVILEGES ON accounts FROM john;
GRANT SELECT * ON accounts TO john;
REVOKE SELECT * FROM staff;
GRANT SELECT * ON staff TO mira;
REVOKE SELECT (id, position) ON staff FROM mira;
REVOKE SELECT (wage) ON staff FROM mira;
REVOKE SELECT (salary, id) ON accounts FROM john;
REVOKE SELECT (salary) ON accounts FROM john;
REVOKE SELECT * ON staff FROM ALL;
REVOKE ALL PRIVILEGES ON staff FROM ALL;