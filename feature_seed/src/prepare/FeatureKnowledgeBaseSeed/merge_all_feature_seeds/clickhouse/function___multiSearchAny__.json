CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('ClickHouse is a fast open-source OLAP database management system.');
INSERT INTO test_strings VALUES ('Fuzzy testing can reveal hidden bugs!');
INSERT INTO test_strings VALUES ('MultiSearchAny feature allows string searching.');
SELECT multiSearchAny(haystack, ['ClickHouse', 'OpenSource']) FROM test_strings;
SELECT multiSearchAny(haystack, ['hidden', 'nonexistent']) FROM test_strings;
SELECT multiSearchAny(haystack, ['fast', 'OLAP', 'database']) FROM test_strings;
SELECT multiSearchAny(haystack, ['Feature', 'allows']) FROM test_strings;
SELECT multiSearchAny(haystack, ['ClickHouse', 'nonexistent']) FROM test_strings;
SELECT multiSearchAny(haystack, ['OLAP', 'atabase']) FROM test_strings;
SELECT multiSearchAny(haystack, ['fuzzy']) FROM (SELECT haystack FROM test_strings WHERE haystack LIKE '%feature%') AS subquery;
SELECT multiSearchAny(haystack, ['a', 'e', 'i', 'o', 'u']) FROM test_strings;
SELECT haystack, multiSearchAny(haystack, ['fast', 'slow']) AS match_status FROM test_strings;
SELECT multiSearchAny(haystack, ['ClickHouse']) AS found FROM (SELECT haystack FROM test_strings WHERE haystack LIKE '%ClickHouse%') AS filtered;
SELECT multiSearchAny(haystack, arrayJoin(['Feature', 'bug', 'search'])) FROM test_strings;
SELECT multiSearchAny(haystack, ['multiSearchAny']) AS matched FROM test_strings;