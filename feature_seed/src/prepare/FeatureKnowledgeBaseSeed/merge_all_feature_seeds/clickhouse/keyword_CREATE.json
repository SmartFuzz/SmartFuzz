CREATE DATABASE test_db;
CREATE TABLE test_db.users (id UInt32, name String, email String) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE test_db.orders (order_id UInt32, user_id UInt32, amount Float64) ENGINE = MergeTree() ORDER BY order_id;
CREATE VIEW test_db.user_order_summary AS SELECT u.id AS user_id, u.name, COUNT(o.order_id) AS total_orders, SUM(o.amount) AS total_amount FROM test_db.users u LEFT JOIN test_db.orders o ON u.id = o.user_id GROUP BY u.id, u.name;
CREATE TABLE test_db.analytics (event_id UInt32, user_id UInt32, event_name String, timestamp DateTime) ENGINE = MergeTree() ORDER BY (user_id, timestamp);
CREATE TABLE test_db.large_table AS SELECT number AS id, toString(number) AS name FROM system.numbers LIMIT 100000;
CREATE TABLE test_db.nested_subquery AS SELECT id, (SELECT COUNT(*) FROM test_db.orders WHERE user_id = u.id) AS order_count FROM test_db.users u;
CREATE TABLE test_db.join_table AS SELECT u.id, u.name, o.amount FROM test_db.users u JOIN test_db.orders o ON u.id = o.user_id;
CREATE TABLE test_db.partitioned_table (date Date, event String) ENGINE = MergeTree() PARTITION BY toYYYYMM(date) ORDER BY date;
CREATE TABLE test_db.temp_data AS SELECT * FROM (SELECT number % 10 AS category, count() AS cnt FROM system.numbers GROUP BY category) WHERE cnt > 100;