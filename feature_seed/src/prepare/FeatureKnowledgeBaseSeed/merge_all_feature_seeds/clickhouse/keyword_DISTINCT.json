CREATE TABLE test_table (id UInt32, name String, age UInt8, city String);
INSERT INTO test_table (id, name, age, city) VALUES (1, 'Alice', 30, 'New York');
INSERT INTO test_table (id, name, age, city) VALUES (2, 'Bob', 25, 'Los Angeles');
INSERT INTO test_table (id, name, age, city) VALUES (3, 'Alice', 30, 'New York');
INSERT INTO test_table (id, name, age, city) VALUES (4, 'Charlie', 35, 'Chicago');
INSERT INTO test_table (id, name, age, city) VALUES (5, NULL, 20, 'Miami');
INSERT INTO test_table (id, name, age, city) VALUES (6, 'Alice', NULL, 'New York');
INSERT INTO test_table (id, name, age, city) VALUES (7, NULL, NULL, NULL);
SELECT DISTINCT * FROM test_table;
SELECT DISTINCT name FROM test_table;
SELECT DISTINCT city, age FROM test_table;
SELECT DISTINCT ON (name, city) * FROM test_table;
SELECT DISTINCT city, COUNT(*) FROM test_table GROUP BY city;
SELECT DISTINCT id FROM test_table WHERE age > 25;
SELECT DISTINCT name, age FROM test_table WHERE city = 'New York';
SELECT DISTINCT city, name FROM (SELECT city, name FROM test_table WHERE age < 40) AS subquery;
SELECT DISTINCT name FROM test_table ORDER BY city ASC;
SELECT DISTINCT name FROM test_table ORDER BY age DESC;
SELECT DISTINCT age FROM test_table WHERE city IS NOT NULL;
SELECT DISTINCT city FROM test_table WHERE name IS NULL;
SELECT DISTINCT city FROM (SELECT DISTINCT city FROM test_table WHERE age IS NOT NULL) AS inner_query;
SELECT DISTINCT t1.name FROM test_table t1 JOIN test_table t2 ON t1.city = t2.city WHERE t1.id != t2.id;
SELECT DISTINCT t1.name FROM test_table t1 LEFT JOIN test_table t2 ON t1.city = t2.city WHERE t2.id IS NULL;
SELECT DISTINCT age FROM test_table WHERE id IN (SELECT id FROM test_table WHERE city = 'Miami');
SELECT COUNT(DISTINCT name) FROM test_table;
SELECT DISTINCT name FROM test_table ORDER BY name, city;
SELECT DISTINCT age, city FROM test_table ORDER BY age DESC, city ASC;
SELECT DISTINCT t1.name FROM (SELECT DISTINCT name, city FROM test_table) AS t1 JOIN test_table t2 ON t1.city = t2.city;