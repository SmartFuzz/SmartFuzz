CREATE TABLE test_table (id UInt32, value String);
INSERT INTO test_table VALUES (1, '123.456'), (2, 'abc'), (3, 'NaN'), (4, 'Inf'), (5, '0xc0fe');
SELECT id, toFloat64OrDefault(value) AS float_value FROM test_table;
SELECT id, toFloat64OrDefault(value, CAST('1.5', 'Float64')) AS float_value FROM test_table WHERE id < 4;
SELECT id, toFloat64OrDefault(value, CAST('0', 'Float64')) AS float_value FROM test_table WHERE value LIKE 'abc' OR value LIKE 'Inf';
SELECT id, toFloat64OrDefault(value, CAST('10', 'Float64')) AS float_value FROM test_table WHERE value IN ('NaN', 'abc', '0xc0fe');
WITH (SELECT value FROM test_table WHERE id = 1) AS temp_value SELECT toFloat64OrDefault(temp_value, CAST('5', 'Float64')) AS float_value;
WITH (SELECT AVG(value) FROM (SELECT toFloat64OrDefault(value, CAST('0', 'Float64')) FROM test_table)) AS avg_value SELECT toFloat64OrDefault('abc', avg_value);
SELECT id, toFloat64OrDefault(value) + 1 AS incremented_value FROM test_table WHERE value NOT IN ('abc', '0xc0fe');
SELECT toFloat64OrDefault(value, CAST('0', 'Float64')) AS float_value, id FROM test_table ORDER BY float_value DESC;