SELECT h3GetRes0Indexes() AS indexes;
WITH (SELECT arrayJoin(h3GetRes0Indexes()) AS indexes) AS temp SELECT COUNT(*) FROM temp;
CREATE TABLE temp_indexes (index UInt64) ENGINE = MergeTree() ORDER BY index;
INSERT INTO temp_indexes SELECT arrayJoin(h3GetRes0Indexes());
SELECT * FROM temp_indexes WHERE index % 2 = 0;
SELECT index, count() FROM temp_indexes GROUP BY index HAVING count() > 1;
WITH (SELECT h3GetRes0Indexes() AS indexes) SELECT indexes[1], indexes[10] FROM temp;
SELECT arrayMap(x -> x * 2, h3GetRes0Indexes()) AS doubled_indexes;
SELECT DISTINCT index FROM temp_indexes WHERE index IN (SELECT index FROM temp_indexes WHERE index < 100);
SELECT h3GetRes0Indexes() AS indexes, arrayLength(indexes) AS length FROM temp_indexes LIMIT 1;