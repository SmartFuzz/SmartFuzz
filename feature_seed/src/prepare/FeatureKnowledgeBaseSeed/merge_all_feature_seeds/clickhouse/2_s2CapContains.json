CREATE TABLE geo_test (id UInt32, center UInt64, radius Float64, point UInt64);
INSERT INTO geo_test VALUES (1, 1157339245694594829, 1.0, 1157347770437378819), (2, 0, 999.9, 1157347770437378819), (3, 1157347770437378819, -1.0, 1157339245694594829);
SELECT id, s2CapContains(center, radius, point) AS capContains FROM geo_test WHERE (s2CapContains(center, radius, point) = 1) AND (radius > 0);
SELECT id, s2CapContains(center, radius, point) AS capContains FROM geo_test WHERE (capContains < 1) OR (point < 1157350000000000000);
SELECT id, COUNT(*) FROM geo_test WHERE s2CapContains(center, radius, point) = 1 GROUP BY id HAVING COUNT(*) < 10;
SELECT id, (s2CapContains(center, radius, point) = 1) AS containsCheck FROM geo_test WHERE point < 1157350000000000000 CONCAT (' - ', CAST(radius AS String));
SELECT a.id, a.center, a.radius, s2CapContains(a.center, a.radius, b.point) AS capContains FROM geo_test a JOIN geo_test b ON a.id < b.id WHERE s2CapContains(a.center, a.radius, b.point) IS NOT NULL;
SELECT id, s2CapContains(center, 0.0, point) AS capContains FROM geo_test WHERE center < 1157350000000000000 UNION ALL SELECT id, 0 FROM geo_test WHERE radius IS NULL;
CREATE TEMPORARY TABLE temp_geo_test AS SELECT * FROM geo_test WHERE radius > 0;
SELECT AVG(radius) FROM temp_geo_test WHERE s2CapContains(center, radius, point) = 1;