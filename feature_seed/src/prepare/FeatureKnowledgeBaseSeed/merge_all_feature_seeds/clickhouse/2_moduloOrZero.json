CREATE TABLE test_table (id UInt32, value Float64, divisor Float64, check_value UInt8);
INSERT INTO test_table VALUES (1, 12.5, 3.0, 1), (2, 15.0, 0.0, 0), (3, NULL, 2.0, 1), (4, 20.0, NULL, 0);
CREATE TABLE another_table (value2 Float64, id2 UInt32);
INSERT INTO another_table VALUES (2.5, 1), (3.5, 2), (4.5, 3);
SELECT id, moduloOrZero(value, divisor) AS mod_result FROM test_table WHERE NOT (check_value = 1) GROUP BY id, mod_result HAVING mod_result IS NOT NULL;
SELECT id2, NOT (SELECT COUNT(*) FROM test_table WHERE MODULOORZERO(value, divisor) = 0 AND id = id2) AS no_zero_mod FROM another_table;
SELECT value, moduloOrZero(value, (SELECT MAX(value) FROM test_table WHERE value IS NOT NULL)) AS max_mod_result FROM test_table GROUP BY value;
WITH (SELECT AVG(divisor) FROM test_table WHERE divisor IS NOT NULL) AS avg_divisor SELECT id, moduloOrZero(value, avg_divisor) FROM test_table;
SELECT id, moduloOrZero(COALESCE(value, 0), divisor) AS safe_mod_result FROM test_table WHERE NOT (divisor = 0 OR divisor IS NULL);
CREATE TABLE temp_table AS SELECT id, moduloOrZero(value, divisor) AS mod_result FROM test_table;
ALTER TABLE temp_table ADD COLUMN extra_value Float64;
INSERT INTO temp_table (id, mod_result, extra_value) VALUES (5, 1.5, NULL), (6, 2.0, 1.5);
SELECT id, NOT (SELECT mod_result FROM temp_table WHERE id = 5 AND extra_value = 1.5) AS negated_mod FROM temp_table;
DROP TABLE temp_table;