CREATE TABLE test_dates (id UInt32, event_time DateTime64(3), description String);
INSERT INTO test_dates VALUES (1, toDateTime64('2024-01-01 00:00:00.123', 3), 'First Event'), (2, toDateTime64('2024-01-01 00:00:00.456', 3), 'Second Event'), (3, toDateTime64('2024-01-01 00:00:01.789', 3), 'Third Event');
SELECT id, subtractMilliseconds(event_time, 1000) AS updated_time FROM test_dates WHERE event_time = subtractMilliseconds(toDateTime('2024-01-01 00:00:02'), 1000);
SELECT id, event_time, subtractMilliseconds(event_time, CAST(null AS Int32)) AS time_with_null FROM test_dates HAVING time_with_null IS NULL;
SELECT COUNT(*) FROM test_dates WHERE event_time = subtractMilliseconds(COALESCE(max(event_time), toDateTime('2024-01-01 00:00:00')), 500);
CREATE TABLE test_dates_2 (id UInt32, event_time DateTime64(3), description String, expired DateTime64(3) DEFAULT subtractMilliseconds(event_time, 500));
INSERT INTO test_dates_2 SELECT id, event_time, description FROM test_dates WHERE event_time > subtractMilliseconds(toDateTime64('2024-01-01 00:00:00.999', 3), 1000);
SELECT d1.id, d1.description, d1.event_time FROM test_dates d1 JOIN test_dates_2 d2 ON d1.event_time = d2.expired WHERE d1.id = subtractMilliseconds(d2.id, 1);
WITH (SELECT AVG(subtractMilliseconds(event_time, 500)) FROM test_dates) AS avg_time SELECT * FROM test_dates WHERE event_time = avg_time;
SELECT event_time FROM test_dates WHERE event_time = subtractMilliseconds(CAST('', 'DateTime64(3)') AS DateTime64(3)) UNION SELECT toDateTime64('2024-01-01 00:00:02.999', 3);