CREATE TABLE salaries(    `team` String,    `player` String,    `salary` UInt32,    `position` String) Engine = Memory;
INSERT INTO salaries FORMAT Values    ('Port Elizabeth Barbarians', 'Gary Chen', 195000, 'F'),    ('New Coreystad Archdukes', 'Charles Juarez', 190000, 'F'),    ('Port Elizabeth Barbarians', 'Michael Stanley', 150000, 'D'),    ('New Coreystad Archdukes', 'Scott Harrison', 150000, 'D'),    ('Port Elizabeth Barbarians', 'Robert George', 195000, 'M'),    ('South Hampton Seagulls', 'Douglas Benson', 150000, 'M'),    ('South Hampton Seagulls', 'James Henderson', 140000, 'M');
SELECT player, salary, percent_rank() OVER (ORDER BY salary DESC) AS percent_rank FROM salaries;
CREATE TABLE team_stats(    `team` String,    `wins` UInt32,    `losses` UInt32,    `draws` UInt32) Engine = Memory;
INSERT INTO team_stats FORMAT Values    ('Port Elizabeth Barbarians', 10, 2, 1),    ('New Coreystad Archdukes', 8, 5, 0),    ('South Hampton Seagulls', 6, 8, 0);
SELECT team, wins, percent_rank() OVER (ORDER BY wins DESC) AS win_percent_rank FROM team_stats;
SELECT player, salary, team, percent_rank() OVER (PARTITION BY team ORDER BY salary DESC) AS team_salary_rank FROM salaries;
SELECT player, salary, percent_rank() OVER (PARTITION BY position ORDER BY salary DESC) AS position_salary_rank FROM salaries;
SELECT player, salary, percent_rank() OVER (ORDER BY salary DESC) AS overall_rank FROM (SELECT player, salary FROM salaries WHERE salary > 100000) AS high_earners;
SELECT t1.player, t1.salary, t2.wins, percent_rank() OVER (PARTITION BY t1.team ORDER BY t1.salary DESC) AS team_salary_rank FROM salaries AS t1 JOIN team_stats AS t2 ON t1.team = t2.team;
SELECT team, SUM(salary) AS total_salary, percent_rank() OVER (ORDER BY SUM(salary) DESC) AS total_salary_rank FROM salaries GROUP BY team;