CREATE TABLE test_table (id Int32, values Array(Int64));
INSERT INTO test_table VALUES (1, emptyArrayInt64()), (2, [1, 2, 3]), (3, emptyArrayInt64());
SELECT id, values FROM test_table WHERE values = emptyArrayInt64();
SELECT id, values FROM test_table WHERE length(values) = 0;
CREATE TABLE another_table (id Int32, counter Array(Int64));
INSERT INTO another_table VALUES (1, emptyArrayInt64()), (2, [4, 5]), (3, emptyArrayInt64());
SELECT a.id FROM test_table as a JOIN another_table as b ON a.id = b.id WHERE b.counter = emptyArrayInt64();
SELECT id FROM another_table WHERE counter = emptyArrayInt64() UNION SELECT id FROM test_table WHERE values = emptyArrayInt64();
SELECT id FROM (SELECT id, emptyArrayInt64() AS empty_values FROM test_table) t WHERE empty_values = emptyArrayInt64();
SELECT count(*) FROM test_table WHERE values = emptyArrayInt64() INTERSECT SELECT count(*) FROM another_table WHERE counter = emptyArrayInt64();
SELECT id FROM test_table WHERE values = emptyArrayInt64() OR id IN (SELECT id FROM another_table WHERE counter = emptyArrayInt64());