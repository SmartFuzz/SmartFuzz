CREATE TABLE test_strings (id UInt32, name String, value String, created_at DateTime DEFAULT now());
INSERT INTO test_strings VALUES (1, 'test', 'clickhouse'), (2, NULL, 'test_value'), (3, 'example', 'null_value');
SELECT upper(name) AS upper_case_name FROM test_strings WHERE value NOT BETWEEN upper('A') AND upper('z');
SELECT id, upper(name), value FROM test_strings WHERE upper(name) NOT BETWEEN 'A' AND 'Z';
SELECT id, upper(value) AS upper_value FROM test_strings WHERE value IS NULL OR upper(value) NOT BETWEEN 'A' AND 'Z';
SELECT COUNT(*) AS count_upper_from_non_null FROM (SELECT upper(value) AS upper_value FROM test_strings WHERE value IS NOT NULL) AS sub WHERE upper_value NOT BETWEEN 'A' AND upper('Z');
SELECT name, upper(value) AS upper_value FROM test_strings WHERE id NOT BETWEEN 1 AND (SELECT max(id) FROM test_strings);
SELECT name, COUNT(distinct upper(name)) FROM test_strings GROUP BY upper(name) HAVING upper(name) NOT BETWEEN 'A' AND 'M';
SELECT id, upper(name) FROM test_strings HAVING upper(name) NOT BETWEEN (SELECT upper('a') FROM test_strings LIMIT 1) AND (SELECT upper(NULLIF(value, 'test_value')) FROM test_strings WHERE value IS NOT NULL LIMIT 1);
CREATE TABLE test_numbers (id UInt32, num UInt32, value String);
INSERT INTO test_numbers VALUES (1, 10, 'Value1'), (2, 20, 'Value2'), (3, 30, 'Value3');
SELECT upper(value) AS upper_value FROM test_numbers WHERE num NOT BETWEEN (SELECT min(num) FROM test_numbers WHERE num IS NOT NULL) AND (SELECT max(num) FROM test_numbers WHERE num IS NOT NULL);
SELECT id, upper(value) FROM test_numbers WHERE id NOT BETWEEN 0 AND (SELECT COUNT(*) FROM test_numbers WHERE id IS NOT NULL);
CREATE TEMPORARY TABLE temp_test AS SELECT id, upper(value) AS upper_value FROM test_numbers WHERE value IS NOT NULL;
SELECT upper_value FROM temp_test WHERE upper_value NOT BETWEEN upper('VA') AND upper('VE');