CREATE TABLE test_table (id Int32, value Float64, category String, created_at DateTime);
INSERT INTO test_table (id, value, category, created_at) VALUES (1, 10.5, 'A', '2023-01-01 00:00:00'), (2, 20.5, 'B', '2023-01-02 00:00:00'), (3, NULL, 'C', '2023-01-03 00:00:00'), (4, 40.0, 'D', '2023-01-04 00:00:00');
SELECT tupleIntDivByNumber((value, 15.3, CAST(NULL AS Float64)), 5) AS result FROM test_table WHERE id IN (SELECT id FROM test_table WHERE category = 'A' OR created_at >= '2023-01-02 00:00:00');
SELECT id, tupleIntDivByNumber((value, ROUND(value * 1.1), 0), value) AS division_result FROM test_table WHERE value IN (SELECT value FROM test_table WHERE created_at < '2023-01-03 00:00:00') GROUP BY id HAVING division_result != (0, 0, 0);
SELECT id, category, tupleIntDivByNumber((value, 100.3, 0), value) AS div0_check FROM test_table WHERE category IN (SELECT DISTINCT category FROM test_table WHERE value IS NOT NULL) ORDER BY div0_check;
SELECT value, tupleIntDivByNumber((value, 10.5, 7.25), CAST(5 AS Int32)) AS div_tuple FROM test_table WHERE NULL IN (SELECT AVG(value) FROM test_table WHERE category = 'C') GROUP BY value HAVING div_tuple IS NOT NULL ORDER BY value DESC;