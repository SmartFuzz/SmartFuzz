CREATE TABLE test_bin_negation (id UInt32, value Int32, float_value Float32, uuid_value UUID) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_bin_negation VALUES (1, 14, 3.14, toUUID('61f0c404-5cb3-11e7-907b-a6006ad3dba0'));
INSERT INTO test_bin_negation VALUES (2, -10, 6.28, toUUID('71f0c404-5cb3-11e7-907b-a6006ad3dba1'));
INSERT INTO test_bin_negation VALUES (3, 0, 0.0, toUUID('81f0c404-5cb3-11e7-907b-a6006ad3dba2'));
SELECT bin(-value) AS neg_bin FROM test_bin_negation;
SELECT id, bin(toFloat32(value)), bin(uuid_value) FROM test_bin_negation WHERE value > -15;
SELECT id, bin(-float_value) AS neg_bin_float, bin(14 + 1) AS bin_plus FROM test_bin_negation WHERE float_value IS NOT NULL;
SELECT id, bin(toUUID('b1a864d6-0c6f-4b95-9b56-3b8809ec9901')) AS bin_uuid_negated FROM test_bin_negation WHERE id IN (SELECT id FROM test_bin_negation WHERE value < 5);
SELECT id, value, bin(-value) AS neg_bin_value, bin(-float_value) AS neg_bin_float FROM test_bin_negation WHERE value IS NOT NULL GROUP BY id, value HAVING value >= -10;
SELECT bin(toFloat64(SUM(value) - AVG(value))) AS bin_difference FROM test_bin_negation GROUP BY id;
SELECT id, bin((SELECT SUM(value) FROM test_bin_negation WHERE value < 10) / COUNT(*)) AS bin_average FROM test_bin_negation;
SELECT DISTINCT toUInt8(bin(toUInt64(-1))) AS neg_bin_uint FROM test_bin_negation WHERE float_value IS NOT NULL ORDER BY neg_bin_uint DESC;
SELECT id, bin(value + (SELECT MAX(value) FROM test_bin_negation WHERE value < 0)) AS combined_bin FROM test_bin_negation;
SELECT bin(toString(value)) AS string_bin, bin(-value - 8) AS neg_bin_expression FROM test_bin_negation;
SELECT id, bin(NULLIF(value, 0)) AS bin_null_if, bin(-value) AS neg_bin_value FROM test_bin_negation WHERE uuid_value IS NOT NULL;
SELECT id, bin(CAST(value AS String)) AS bin_casted FROM test_bin_negation WHERE value BETWEEN -10 AND 10;
SELECT bin(toIPv4('192.168.1.1')) AS bin_ip FROM test_bin_negation;
SELECT COUNT(*) AS total, bin(-MAX(value)) AS neg_max_bin FROM test_bin_negation GROUP BY bin(toSTRING(value));