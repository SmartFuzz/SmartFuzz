CREATE TABLE test_any_1 (id UInt32, value Nullable(String)) ENGINE=Log;
INSERT INTO test_any_1 (id, value) VALUES (1, NULL), (2, 'A'), (3, 'B'), (4, NULL), (5, 'C');
SELECT any(value) FROM test_any_1;
CREATE TABLE test_any_2 (category String, price Nullable(Float64)) ENGINE=Log;
INSERT INTO test_any_2 (category, price) VALUES ('Electronics', NULL), ('Clothing', 20.5), ('Sports', NULL), ('Clothing', 15.0);
SELECT category, any(price) FROM test_any_2 GROUP BY category;
CREATE TABLE test_any_3 (id UInt32, score Nullable(Int32)) ENGINE=Log;
INSERT INTO test_any_3 (id, score) VALUES (1, 10), (2, NULL), (3, 25), (4, NULL), (5, 30);
SELECT any(score) AS first_score FROM test_any_3 WHERE id >= 3;
CREATE TABLE test_any_4 (name Nullable(String), region Nullable(String)) ENGINE=Log;
INSERT INTO test_any_4 (name, region) VALUES (NULL, 'Europe'), ('Alice', NULL), ('Bob', 'Asia'), ('Charlie', 'Europe');
SELECT any(name) AS first_name, region FROM test_any_4 GROUP BY region;
CREATE TABLE orders (order_id UInt32, customer_id UInt32, product_id UInt32, NULLABLE_DISCOUNT Nullable(Float32)) ENGINE=Log;
INSERT INTO orders (order_id, customer_id, product_id, NULLABLE_DISCOUNT) VALUES (1, 100, 10, NULL), (2, 101, 11, 5.0), (3, 100, 12, 10.0);
SELECT customer_id, any(NULLABLE_DISCOUNT) AS discount FROM orders GROUP BY customer_id;
CREATE TABLE products (product_id UInt32, category String, price Float64) ENGINE=Log;
INSERT INTO products (product_id, category, price) VALUES (1, 'Electronics', 299.99), (2, 'Clothing', 49.99), (3, 'Electronics', 199.99);
SELECT category, any(price) AS example_price FROM products GROUP BY category;
CREATE TABLE employee_data (employee_id UInt32, department String, salary Nullable(UInt32)) ENGINE=Log;
INSERT INTO employee_data (employee_id, department, salary) VALUES (1, 'HR', 50000), (2, 'IT', NULL), (3, 'IT', 70000), (4, 'HR', NULL);
SELECT department, any(salary) AS max_salary FROM employee_data GROUP BY department;
CREATE TABLE nested_example (group_id UInt32, nested_id UInt32, value Nullable(String)) ENGINE=Log;
INSERT INTO nested_example (group_id, nested_id, value) VALUES (1, 1, NULL), (1, 2, 'Value A'), (2, 1, 'Value B'), (2, 2, NULL);
SELECT group_id, any(value) AS first_value FROM nested_example GROUP BY group_id;
CREATE TABLE complex_example (id UInt32, name Nullable(String), ref_id UInt32) ENGINE=Log;
INSERT INTO complex_example (id, name, ref_id) VALUES (1, 'Product 1', 100), (2, NULL, 101), (3, 'Product 3', 100);
SELECT ref_id, any(name) AS first_name FROM complex_example GROUP BY ref_id;
CREATE TABLE main_data (main_id UInt32, foreign_key UInt32) ENGINE=Log;
INSERT INTO main_data (main_id, foreign_key) VALUES (1, 1), (2, 3), (3, 2), (4, NULL);
SELECT main_id, any(foreign_key) AS first_ref FROM main_data GROUP BY main_id;