CREATE TABLE test_array (id UInt32, arr Array(Int32), str_id String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_array VALUES (1, [1, 2, 3], '1'), (2, [4, 5], '2'), (3, [6], NULL);
SELECT id, arrayResize(arr, 5, NULL) AS resized_arr FROM test_array WHERE resized_arr NOT LIKE [1, NULL, NULL, NULL, NULL];
SELECT id, arr, (SELECT arrayResize(arr, 4) FROM test_array t2 WHERE t2.id = test_array.id) AS truncated_array FROM test_array WHERE arr NOT LIKE [] AND arr NOT LIKE [4, 5, 0];
SELECT id, arrayResize(arr, 2) AS truncated_arr, str_id FROM test_array WHERE arrayResize(arr, 2) NOT LIKE (SELECT arr FROM test_array WHERE id = 3);
SELECT id, arrayResize(arr, 6, str_id) AS extended_array FROM test_array HAVING extended_array NOT LIKE [6, '1', '2', '2', '2', '2'];
SELECT id, arrayResize(arr, 0) AS empty_array FROM test_array WHERE empty_array NOT LIKE [1];