CREATE TABLE test_table (id Int32, value Float64, text_value String, nullable_value Nullable(Int32));
INSERT INTO test_table (id, value, text_value, nullable_value) VALUES (1, -3.5, 'text', NULL), (2, 0, '', 1), (3, 5.0, 'another text', 2);
CREATE TABLE test_table2 (a Int32, b Float64);
INSERT INTO test_table2 (a, b) VALUES (1, 10.0), (2, -20.0);
SELECT id, abs(value) FROM test_table WHERE value < 0;
SELECT (SELECT abs(value) FROM test_table WHERE id = 1) as abs_value FROM dual;
SELECT NOT abs(value) FROM test_table WHERE text_value = '' AND NOT nullable_value IS NULL;
SELECT t1.id, (SELECT abs(SUM(value)) FROM test_table2 t2 WHERE t2.a = t1.id) AS total_abs_value FROM test_table t1 GROUP BY t1.id HAVING total_abs_value > 0;
SELECT id, value, NOT abs(value) as neg_abs_value FROM test_table WHERE (value > -10 OR nullable_value IS NULL) ORDER BY neg_abs_value;
SELECT id, abs(value) AS abs_value FROM test_table WHERE value IS NOT NULL AND abs(value) <= (SELECT MAX(abs(b)) FROM test_table2);
SELECT NOT (abs(value) = 3.5) AS is_not_equal FROM test_table WHERE id = 1;