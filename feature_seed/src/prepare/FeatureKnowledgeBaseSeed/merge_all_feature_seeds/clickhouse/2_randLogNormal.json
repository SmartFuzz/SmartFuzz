CREATE TABLE test_table (id Int32, description String, value Float64 DEFAULT randLogNormal(0, 1));
INSERT INTO test_table VALUES (1, 'Value with log-normal: ' || toString(randLogNormal(50, 10)), randLogNormal(50, 10));
INSERT INTO test_table VALUES (2, 'Boundary test: ' || 'MinValue' || ' with LogNormal: ' || toString(randLogNormal(0, 0)), randLogNormal(0, 0));
INSERT INTO test_table VALUES (3, 'Value at: ' || toString(randLogNormal(100, 0.0000001)) || ' for extreme precision', randLogNormal(100, 0.0000001));
INSERT INTO test_table VALUES (4, 'NULL propagation test: ' || 'Empty' || ' with LogNormal: ' || toString(coalesce(randLogNormal(NULL, 5), 0)), coalesce(randLogNormal(NULL, 5), 0));
SELECT id, description || ' - Result: ' || toString(randLogNormal(value, 1)) AS result FROM test_table WHERE value > 0.5;
SELECT count(*) AS total, description FROM test_table GROUP BY description HAVING total > 1;
SELECT id, description, value FROM (SELECT id, description, value FROM test_table WHERE description || ' Extra' = 'Some Condition') AS derived_table WHERE value < 10;
SELECT DISTINCT description || ' - Random Value: ' || toString(randLogNormal(value, 0.5)) FROM test_table ORDER BY value DESC;
SELECT id, value, description FROM test_table WHERE value IN (SELECT randLogNormal(0, 0.1) FROM numbers(10)) ORDER BY value;