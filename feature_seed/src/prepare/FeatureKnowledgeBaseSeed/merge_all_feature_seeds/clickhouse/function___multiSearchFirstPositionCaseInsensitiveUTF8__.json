CREATE TABLE test_strings (haystack String, needle Array(String));
INSERT INTO test_strings VALUES ('Hello World', ['wor', 'ld', 'ello']);
INSERT INTO test_strings VALUES ('こんにちは世界', ['世界', 'こん']);
INSERT INTO test_strings VALUES ('Case Sensitivity Test', ['case', 'SENSITIVITY', 'Test']);
INSERT INTO test_strings VALUES ('abcdefgHIJKLMN', ['xyz', 'abc', 'hij']);
INSERT INTO test_strings VALUES ('OpenAI ChatGPT', ['openai', 'chatgpt', 'gpt']);
SELECT multiSearchFirstPositionCaseInsensitiveUTF8(haystack, needle) FROM test_strings;
SELECT multiSearchFirstPositionCaseInsensitiveUTF8(haystack, ['world', 'universe']) AS position FROM test_strings WHERE position > 0;
SELECT haystack, multiSearchFirstPositionCaseInsensitiveUTF8(haystack, needle) AS position FROM test_strings WHERE position = 0;
CREATE TABLE results AS SELECT haystack, multiSearchFirstPositionCaseInsensitiveUTF8(haystack, needle) AS position FROM test_strings WHERE position > 0;
SELECT * FROM results WHERE position < 10 ORDER BY position;
SELECT multiSearchFirstPositionCaseInsensitiveUTF8('testing case insensitivity', ['TEST', 'INSENSITIVITY']) AS position UNION ALL SELECT multiSearchFirstPositionCaseInsensitiveUTF8('Another Case', ['another', 'CASE']);