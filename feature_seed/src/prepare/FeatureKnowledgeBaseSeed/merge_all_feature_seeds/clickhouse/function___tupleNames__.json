CREATE TABLE tupletest (col Tuple(user_ID UInt64, session_ID UInt64)) ENGINE = Memory;
INSERT INTO tupletest VALUES (tuple(1, 2));
SELECT tupleNames(col) FROM tupletest;
CREATE TABLE user_sessions (session Tuple(user_ID UInt64, session_ID UInt64)) ENGINE = Memory;
INSERT INTO user_sessions VALUES (tuple(3, 4));
INSERT INTO user_sessions VALUES (tuple(5, 6));
SELECT tupleNames(session) FROM user_sessions;
CREATE TABLE complex (details Tuple(name String, age Int32, active UInt8)) ENGINE = Memory;
INSERT INTO complex VALUES (tuple('Alice', 30, 1));
INSERT INTO complex VALUES (tuple('Bob', 25, 0));
SELECT tupleNames(details) FROM complex WHERE active = 1;
CREATE TABLE advanced (info Tuple(a Float64, b Tuple(x Int32, y Int32))) ENGINE = Memory;
INSERT INTO advanced VALUES (tuple(3.14, tuple(1, 2)));
SELECT tupleNames(info) FROM advanced;
CREATE TABLE multi (user Tuple(id UInt64, data Tuple(name String, score Int32))) ENGINE = Memory;
INSERT INTO multi VALUES (tuple(1, tuple('John', 95)));
INSERT INTO multi VALUES (tuple(2, tuple('Doe', 88)));
SELECT tupleNames(data) FROM multi;
CREATE TABLE nested (info Tuple(a Tuple(b String, c Int32), d UInt8)) ENGINE = Memory;
INSERT INTO nested VALUES (tuple(tuple('Nested', 42), 1));
SELECT tupleNames(info) FROM nested;
CREATE TABLE joined (user Tuple(id UInt64, user_data Tuple(username String, age Int32)), session Tuple(session_id UInt64, user_id UInt64)) ENGINE = Memory;
INSERT INTO joined VALUES (tuple(1, tuple('Alice', 30)), tuple(101, 1));
INSERT INTO joined VALUES (tuple(2, tuple('Bob', 25)), tuple(102, 2));
SELECT tupleNames(user_data) FROM joined WHERE session.user_id = user.id;
CREATE TABLE complex_joined AS (SELECT user_id, tupleNames(user_data) AS column_names FROM joined);