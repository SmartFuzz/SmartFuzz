CREATE TABLE test_html (id UInt32, content String, created_at DateTime DEFAULT now());
INSERT INTO test_html VALUES (1, '<p> A text <i>with</i><b>tags</b>. <!-- comments --> </p>'), (2, '<![CDATA[The content within <b>CDATA</b>]]> <script>alert("Script");
</script>');
SELECT id, extractTextFromHTML(content) AS text FROM test_html WHERE extractTextFromHTML(content) <= 'A text withtags.';
SELECT id, extractTextFromHTML(content) AS text FROM test_html WHERE extractTextFromHTML(content) <= (SELECT MAX(extractTextFromHTML(content)) FROM test_html);
WITH (SELECT COUNT(*) FROM test_html) AS row_count SELECT id, extractTextFromHTML(content) AS text FROM test_html WHERE row_count <= 2;
SELECT id, extractTextFromHTML(content) AS text, (SELECT COUNT(*) FROM test_html WHERE extractTextFromHTML(content) <= 'B') AS count FROM test_html GROUP BY text HAVING count > 0;
CREATE TABLE temp_table AS SELECT id, extractTextFromHTML(content) AS text FROM test_html WHERE extractTextFromHTML(content) <= (SELECT extractTextFromHTML(content) FROM test_html WHERE id = 1);
SELECT A.id, A.text FROM (SELECT id, extractTextFromHTML(content) AS text FROM test_html) AS A JOIN (SELECT MIN(id) AS min_id FROM test_html) AS B ON A.id <= B.min_id;
CREATE TABLE edge_cases (val String, n Nullable(Int32));
INSERT INTO edge_cases VALUES ('1', NULL), (NULL, 2), ('0', 3);
SELECT val, IF(extractTextFromHTML(val) <= '0', 'Negative', 'Positive') AS classification FROM edge_cases WHERE n IS NOT NULL;
SELECT extractTextFromHTML(content), COUNT(*) FROM test_html GROUP BY extractTextFromHTML(content) HAVING COUNT(*) <= (SELECT COUNT(*) FROM test_html);
SELECT A.id, extractTextFromHTML(A.content) FROM (SELECT id, content FROM test_html WHERE content IS NOT NULL) AS A WHERE LENGTH(extractTextFromHTML(A.content)) <= 50;
WITH (SELECT 1 AS min_val) AS min_value SELECT extractTextFromHTML(content) FROM test_html WHERE min_value <= LENGTH(extractTextFromHTML(content));
CREATE TABLE fuzz_test_cases (case_id Int32, case_string String, case_number Float64);
INSERT INTO fuzz_test_cases VALUES (1, '<div><span>Test</span><i></i><!-- comment --></div>', NULL), (2, '<p>Valid <b>text</b></p>', 0.0);
SELECT case_id, extractTextFromHTML(case_string) AS extracted_text FROM fuzz_test_cases WHERE case_number <= 1.0;
SELECT DISTINCT extractTextFromHTML(case_string) AS unique_text FROM fuzz_test_cases WHERE case_number <= (SELECT AVG(case_number) FROM fuzz_test_cases);