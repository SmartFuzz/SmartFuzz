SET allow_introspection_functions=1;
CREATE TABLE trace_example (id UInt64, address UInt64, symbol String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO trace_example VALUES (1, 94138803686098, addressToSymbol(94138803686098));
SELECT addressToSymbol(0) AS symbol_for_zero;
SELECT addressToSymbol(12345678901234) AS symbol_for_large_address;
SELECT addressToSymbol(94138803686098) AS valid_symbol;
SELECT addressToSymbol(99999999999999) AS invalid_symbol;
SELECT arrayStringConcat(arrayMap(address -> addressToSymbol(address), [94138803686098, 0, 99999999999999]), '\n') AS trace_symbols;
SELECT addressToSymbol(address) FROM trace_example WHERE id = 1;
WITH (SELECT arrayJoin([94138803686098, 12345678901234, 99999999999999]) AS addresses) SELECT arrayMap(addr -> addressToSymbol(addr), addresses) AS symbols;
SELECT id, address, addressToSymbol(address) FROM trace_example WHERE symbol IS NOT NULL;
CREATE TABLE result AS SELECT addressToSymbol(address) AS symbol FROM trace_example WHERE address > 0;
SELECT * FROM result LIMIT 10;
SELECT addressToSymbol(a.address) FROM (SELECT address FROM trace_example WHERE id IN (SELECT id FROM trace_example WHERE address < 94138803686098)) AS a;
SELECT addressToSymbol((SELECT MAX(address) FROM trace_example)) AS max_address_symbol;