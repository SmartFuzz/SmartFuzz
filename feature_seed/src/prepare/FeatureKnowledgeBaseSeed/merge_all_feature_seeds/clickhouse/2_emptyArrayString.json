CREATE TABLE test_table (id Int32, name String, array_data Array(String));
INSERT INTO test_table VALUES (1, 'Alice', ['foo', 'bar']), (2, 'Bob', emptyArrayString()), (3, NULL, ['baz']);
SELECT id, name, array_data FROM test_table WHERE length(array_data) < (SELECT count(*) FROM test_table WHERE name IS NOT NULL);
SELECT id, name, array_data, emptyArrayString() < array_data AS is_empty_array FROM test_table WHERE is_empty_array = 1;
CREATE TABLE another_table (id Int32, value Float32);
INSERT INTO another_table VALUES (1, 1.5), (2, NULL), (3, 3.5);
SELECT a.id, a.value, emptyArrayString() < array(a.value) AS is_empty_array FROM another_table AS a WHERE a.value IS NOT NULL GROUP BY a.id, a.value HAVING is_empty_array;
SELECT (SELECT count(*) FROM test_table) AS total_count, emptyArrayString() < array((SELECT name FROM test_table WHERE id = 3)) AS is_empty_array FROM test_table WHERE id < 2;
SELECT a.id, a.name, emptyArrayString() < array_to_string(array_data, ', ') AS array_check FROM test_table AS a JOIN another_table AS b ON a.id < b.id WHERE b.value IS NULL ORDER BY a.id;
SELECT count(*) FROM (SELECT id, length(array_data) AS data_length FROM test_table WHERE array_data IS NOT NULL GROUP BY id HAVING emptyArrayString() < array_data) AS subquery;
DROP TABLE IF EXISTS test_table;
DROP TABLE IF EXISTS another_table;