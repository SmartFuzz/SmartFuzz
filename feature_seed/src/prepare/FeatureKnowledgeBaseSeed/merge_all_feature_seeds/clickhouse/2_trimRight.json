CREATE TABLE test_strings (id Int32, value String, nullable_value Nullable(String));
INSERT INTO test_strings VALUES (1, '     ClickHouse Fuzz Testing     '), (2, NULL), (3, '     Edge Cases     ');
SELECT id, trimRight(value) || ' - ' || trimRight(nullable_value) AS concatenated_value FROM test_strings WHERE trimRight(value) IS NOT NULL;
SELECT id, trimRight(value) AS trimmed_value, COUNT(*) OVER (PARTITION BY trimRight(value)) AS count FROM test_strings GROUP BY trimmed_value HAVING count > 1;
SELECT id, trimRight(value) || CAST(id AS String) AS combined_value FROM test_strings WHERE trimRight(value) IS NOT NULL AND id > 1;
CREATE TABLE test_fuzz (id Int32, string_col String);
INSERT INTO test_fuzz VALUES (1, '123'), (2, '456'), (3, ''), (4, '   '), (5, 'Test String     ');
SELECT id, trimRight(string_col || ' Extra') FROM test_fuzz WHERE string_col IS NOT NULL;
SELECT id, trimRight(value) AS trimmed_value FROM (SELECT value FROM test_strings WHERE value IS NOT NULL) AS subquery;
SELECT id, trimRight(value) || ' NULL: ' || trimRight(nullable_value) AS combined все from test_strings WHERE nullable_value IS NULL;