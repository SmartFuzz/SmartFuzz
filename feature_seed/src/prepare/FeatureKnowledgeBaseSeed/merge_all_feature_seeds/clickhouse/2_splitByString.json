CREATE TABLE test_split_operator (id Int32, data String);
INSERT INTO test_split_operator VALUES (1, '1, 2, 3, 4,5, abcde'), (2, '  ,   ,'), (3, ''), (4, 'split here, here split');
SELECT id, splitByString(', ', data) AS substrings FROM test_split_operator WHERE id BETWEEN 1 AND 4;
SELECT id, splitByString('', data) AS substrings FROM test_split_operator WHERE data IS NOT NULL AND id BETWEEN 1 AND 2;
SELECT id, sum(length(splitByString(', ', data))) AS total_length FROM test_split_operator GROUP BY id HAVING total_length BETWEEN 0 AND 50;
CREATE TABLE test_null_cases (id Int32, value Nullable(String));
INSERT INTO test_null_cases VALUES (1, NULL), (2, 'abc'), (3, '  '), (4, 'def, ghi, jkl');
SELECT id, splitByString(', ', value) AS substrings FROM test_null_cases WHERE value IS NULL OR value BETWEEN 'a' AND 'z';
SELECT id, splitByString(', ', value) AS substrings FROM test_null_cases WHERE IFNULL(length(value), 0) BETWEEN 1 AND 5;
SELECT id, splitByString(', ', value) AS substrings FROM test_null_cases WHERE id BETWEEN 1 AND 4 ORDER BY substrings[1] ASC;
CREATE TABLE test_complex_join (id Int32, data String, foreign_key Int32);
INSERT INTO test_complex_join VALUES (1, 'apple, banana', 1), (2, 'pear, grape', 2);
SELECT a.id, splitByString(', ', a.data) AS fruits FROM test_complex_join AS a JOIN test_split_operator AS b ON a.foreign_key BETWEEN b.id - 1 AND b.id + 1 WHERE b.data LIKE '%apple%';
CREATE TABLE test_boundary_values (id Int32, min_val Float64, max_val Float64, num_test String);
INSERT INTO test_boundary_values VALUES (1, -1.7976931348623157E+308, 1.7976931348623157E+308, '1, 2, 3'), (2, 0, 0, '0, 0');
SELECT id, min_val, max_val, splitByString(', ', num_test) AS num_array FROM test_boundary_values WHERE max_val BETWEEN min_val AND max_val;