CREATE TABLE test_table (id Int32, name String, value Float64);
INSERT INTO test_table VALUES (1, 'Alice', 10.5), (2, 'Bob', 20.3), (3, 'Charlie', 30.7);
SELECT formatQuerySingleLine('SELECT id, name FROM test_table WHERE value >= 10 AND name != ''Bob'';
');
SELECT formatQuerySingleLine('SELECT a.id, b.name FROM test_table AS a JOIN test_table AS b ON a.id = b.id WHERE a.value > 15;
');
WITH (SELECT AVG(value) FROM test_table) AS avg_value SELECT formatQuerySingleLine('SELECT * FROM test_table WHERE value > avg_value;
');
SELECT formatQuerySingleLine('SELECT a.name, COUNT(*) FROM test_table AS a LEFT JOIN test_table AS b ON a.id = b.id GROUP BY a.name HAVING COUNT(*) > 1;
');
CREATE TABLE another_table (id Int32, value Float32);
INSERT INTO another_table VALUES (1, 5.5), (2, 15.5), (3, 25.5);
SELECT formatQuerySingleLine('SELECT a.name, b.value FROM test_table a JOIN another_table b ON a.id = b.id WHERE b.value < 20;
');
SELECT formatQuerySingleLine('SELECT DISTINCT name FROM (SELECT name FROM test_table WHERE value > 10) AS subquery;
');
SELECT formatQuerySingleLineOrNull('SELECT * FORM test_table;
');
SELECT formatQuerySingleLine('SELECT id, SUM(value) AS total_value FROM test_table GROUP BY id ORDER BY total_value DESC;
');
SELECT formatQuerySingleLine('SELECT name FROM (SELECT name, COUNT(*) AS cnt FROM test_table GROUP BY name ORDER BY cnt DESC) AS t1 WHERE cnt > 1;
');