CREATE TABLE test_strings (id UInt32, content String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'ClickHouse® is a column-oriented database management system'), (2, 'data processing at scale!'), (3, 'CLICKHOUSE® IS AN OLAP system.');
SELECT id, wordShingleMinHashArgCaseInsensitiveUTF8(content, 3, 4) AS hashes FROM test_strings WHERE content ILIKE '%database%';
SELECT id, content FROM test_strings WHERE EXISTS (SELECT 1 FROM test_strings AS ts2 WHERE ts2.content ILIKE ts1.content) AS ts1;
SELECT COUNT(*) FROM test_strings WHERE wordShingleMinHashArgCaseInsensitiveUTF8(content, 1, 6).1 ILIKE 'clickhouse';
SELECT content, (wordShingleMinHashArgCaseInsensitiveUTF8(content, 2, 2).1, wordShingleMinHashArgCaseInsensitiveUTF8(content, 2, 2).2) AS shingles_hashes FROM test_strings HAVING shingles_hashes.1 ILIKE '%OLAP%';
SELECT ts1.id, ts1.content FROM test_strings AS ts1 INNER JOIN (SELECT id, wordShingleMinHashArgCaseInsensitiveUTF8(content, 1, 5) AS hashes FROM test_strings) AS ts2 ON ts1.id = ts2.id WHERE ts2.hashes.1 ILIKE '%processing%';
SELECT content FROM test_strings WHERE content ILIKE NULL OR wordShingleMinHashArgCaseInsensitiveUTF8(content, 1, 6).2 ILIKE '%IS AN%';
SELECT wordShingleMinHashArgCaseInsensitiveUTF8(content, 1, 6) AS shingle_hashes FROM test_strings WHERE LENGTH(content) > 0 GROUP BY shingle_hashes;
CREATE TABLE temp_table AS SELECT content FROM test_strings WHERE LENGTH(content) < 30;
INSERT INTO temp_table VALUES ('Test string with NULL value', NULL);
SELECT * FROM temp_table WHERE content ILIKE '%NULL%' OR content ILIKE '';