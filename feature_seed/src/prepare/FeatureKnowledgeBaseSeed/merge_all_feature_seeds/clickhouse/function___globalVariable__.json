CREATE TABLE global_vars (name String, value String);
INSERT INTO global_vars VALUES ('max_allowed_packet', '1048576'), ('connect_timeout', '10');
SELECT globalVariable('max_allowed_packet');
SELECT globalVariable('connect_timeout') AS timeout FROM global_vars WHERE name = 'connect_timeout';
WITH (SELECT value FROM global_vars WHERE name = 'max_allowed_packet') AS packet_size SELECT packet_size + 512 AS adjusted_packet_size;
SELECT g.name, g.value FROM global_vars g JOIN (SELECT globalVariable('max_allowed_packet') AS max_packet) AS m ON g.name = 'max_allowed_packet';
SELECT globalVariable('invalid_variable') AS invalid_var UNION SELECT globalVariable('max_allowed_packet');
DELETE FROM global_vars WHERE name = 'max_allowed_packet';
SELECT globalVariable('max_allowed_packet') AS max_packet_after_delete;
CREATE TABLE temp_table AS SELECT globalVariable('max_allowed_packet') AS max_packet;
SELECT (SELECT globalVariable('max_allowed_packet') > 1024) AS is_greater_than_1mb;