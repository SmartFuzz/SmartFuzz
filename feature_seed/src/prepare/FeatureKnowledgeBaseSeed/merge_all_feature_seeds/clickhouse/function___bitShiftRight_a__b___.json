CREATE TABLE test_bit_shift (value UInt64, str_value String) ENGINE = MergeTree() ORDER BY value;
INSERT INTO test_bit_shift VALUES (101, 'abc'), (255, 'xyz'), (4095, '12345');
SELECT value AS a, bin(a) AS binary_representation, bitShiftRight(a, 1) AS a_shifted, bin(a_shifted) FROM test_bit_shift;
SELECT str_value AS a, hex(a) AS hex_representation, bitShiftRight(a, 5) AS a_shifted, hex(a_shifted) FROM test_bit_shift;
SELECT toFixedString(str_value, 3) AS a, hex(a) AS hex_representation, bitShiftRight(a, 9) AS a_shifted, hex(a_shifted) FROM test_bit_shift;
SELECT value AS a, bitShiftRight(a, 1) AS a_shifted FROM (SELECT value FROM test_bit_shift WHERE value < 256);
SELECT value AS a, bitShiftRight(a, 2) AS a_shifted FROM test_bit_shift WHERE value > 100 AND value < 500;
WITH (SELECT value FROM test_bit_shift WHERE value = 255) AS subquery SELECT bitShiftRight(value, 4) AS shifted_value FROM subquery;
SELECT a.value AS a, b.value AS b, bitShiftRight(a.value, 3) AS a_shifted, bitShiftRight(b.value, 2) AS b_shifted FROM test_bit_shift a JOIN test_bit_shift b ON a.value != b.value LIMIT 5;
SELECT str_value AS a, bitShiftRight(toUInt64(length(a)), 1) AS length_shifted FROM test_bit_shift;