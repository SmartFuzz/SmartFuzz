CREATE TABLE test_table (id Int32, value Nullable(String), number Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, '10.5', 100.75), (2, NULL, 200.5), (3, 'NaN', 300.25), (4, 'Inf', 400.0);
SELECT id, toInt8(number) AS int_value FROM test_table WHERE value IS NOT NULL;
SELECT id, value, toInt8(toString(number)) AS int_number FROM test_table WHERE toInt8(number) IS NOT NULL;
SELECT id, SUM(toInt8(number)) AS total FROM test_table WHERE value IS NOT NULL GROUP BY id HAVING total IS NOT NULL;
SELECT id, CASE WHEN toInt8(value) IS NOT NULL THEN toInt8(value) ELSE -1 END AS converted_value FROM test_table;
SELECT id, COUNT(*) FROM test_table WHERE toInt8(number) IS NOT NULL GROUP BY id ORDER BY COUNT(*) DESC;
SELECT id FROM test_table WHERE value IS NOT NULL AND value NOT IN (SELECT value FROM test_table WHERE toInt8(number) IS NOT NULL);
SELECT id, toInt8(number) AS int_val FROM test_table WHERE number NOT IN (SELECT number FROM test_table WHERE value IS NOT NULL) AND int_val IS NOT NULL;
WITH (SELECT AVG(toInt8(number)) FROM test_table WHERE value IS NOT NULL) AS avg_value SELECT id, toInt8(value) AS converted_value FROM test_table HAVING converted_value > avg_value;