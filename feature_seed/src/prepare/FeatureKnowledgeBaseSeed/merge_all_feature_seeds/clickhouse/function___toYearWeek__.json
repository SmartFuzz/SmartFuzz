CREATE TABLE test_dates (event_date Date);
INSERT INTO test_dates VALUES ('2015-12-28'), ('2016-01-02'), ('2016-12-31'), ('2017-01-01');
SELECT event_date, toYearWeek(event_date) AS yearWeek0 FROM test_dates;
SELECT event_date, toYearWeek(event_date, 1) AS yearWeek1 FROM test_dates;
SELECT event_date, toYearWeek(event_date, 9) AS yearWeek9 FROM test_dates;
SELECT event_date, toYearWeek(event_date) AS yearWeek0, toYearWeek(event_date, 1) AS yearWeek1 FROM test_dates WHERE event_date > '2015-12-01';
SELECT event_date, toYearWeek(event_date), toYearWeek(event_date, 1) FROM test_dates WHERE toYearWeek(event_date) > 201601;
WITH (SELECT event_date FROM test_dates WHERE event_date < '2016-01-01') AS old_dates SELECT event_date, toYearWeek(event_date) FROM old_dates;
SELECT t.event_date, toYearWeek(t.event_date) AS yearWeek0, COUNT(*) OVER (PARTITION BY toYearWeek(t.event_date)) AS week_count FROM test_dates AS t;
SELECT t1.event_date, t2.yearWeek0 FROM test_dates AS t1 JOIN (SELECT event_date, toYearWeek(event_date) AS yearWeek0 FROM test_dates) AS t2 ON t1.event_date = t2.event_date;
SELECT toYearWeek(toDate('2018-12-31'), 3) AS yearWeekWithMode FROM test_dates;
SELECT toYearWeek(toDate('2019-01-01')) AS prev_yearWeek, toYearWeek(toDate('2019-12-31')) AS last_yearWeek FROM test_dates;
SELECT toYearWeek(toDate('2020-03-01'), 0) AS firstMarchWeek, toYearWeek(toDate('2020-12-31')) AS lastWeek2020;
SELECT toYearWeek(toDate('2022-12-31')), toISOYear(toDate('2022-12-31')) AS isoYear WHERE toYearWeek(toDate('2022-12-31')) = 202253;