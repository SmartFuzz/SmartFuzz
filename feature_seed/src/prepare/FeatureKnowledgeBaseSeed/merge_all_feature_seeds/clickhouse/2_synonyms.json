CREATE TABLE test_words (id UInt32, word String, description String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_words VALUES (1, 'important', 'Significant or worthy of attention.');
INSERT INTO test_words VALUES (2, 'critical', 'Of great importance;
crucial.');
INSERT INTO test_words VALUES (3, '', 'Empty string case.');
SELECT synonyms('plain', (SELECT word FROM test_words WHERE id = 1));
SELECT word, synonyms('wordnet', word) AS synonyms_list FROM test_words WHERE LENGTH(word) > 0;
SELECT id, word, (SELECT synonyms('plain', word) FROM test_words WHERE id = 2) AS related_terms FROM test_words;
WITH (SELECT MIN(id) AS min_id, MAX(id) AS max_id FROM test_words) AS bounds SELECT synonyms('plain', word) FROM test_words WHERE id BETWEEN bounds.min_id AND bounds.max_id;
SELECT CASE WHEN (SELECT COUNT(*) FROM test_words) IS NULL THEN 'No data' ELSE synonyms('plain', (SELECT word FROM test_words LIMIT 1)) END AS synonyms_check;
CREATE TABLE processed_words AS SELECT id, word, synonyms('plain', word) AS synonyms FROM test_words GROUP BY word HAVING synonyms IS NOT NULL;
SELECT a / NULL AS div_null, synonyms('plain', word) FROM test_words;
SELECT synonyms('plain', CONCAT(word, ' example')) FROM test_words WHERE LENGTH(word) < 5;
SELECT synonyms('plain', word) FROM (SELECT UPPER(word) AS word FROM test_words) WHERE LENGTH(word) < 10;
SELECT word, (word = '') / (LENGTH(word) + 1) AS division_test FROM test_words;
SELECT synonyms('plain', (SELECT word FROM test_words WHERE id = (SELECT MAX(id) FROM test_words) LIMIT 1));