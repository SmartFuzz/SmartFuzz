CREATE TABLE test_vectors (id UInt32, vec Array(Float32), nullable_float Nullable(Float32));
INSERT INTO test_vectors VALUES (1, [1, 2, NULL]), (2, [3, 4, 5]), (3, []), (4, [NULL]), (5, [0.1, 0.2, NULL, 0.4]);
SELECT id, L2Norm(vec) AS norm_value FROM test_vectors WHERE L2Norm(vec) IS NOT NULL;
SELECT id, L2Norm(vec) AS norm_value FROM test_vectors WHERE (SELECT COUNT(*) FROM test_vectors WHERE vec IS NOT NULL) > 0;
SELECT id, AVG(L2Norm(vec)) AS avg_norm FROM test_vectors GROUP BY id HAVING L2Norm(vec) IS NULL OR L2Norm(vec) > 4;
SELECT id, L2Norm(vec) AS norm_value FROM test_vectors WHERE vec IS NOT NULL AND norm_value IS NOT NULL ORDER BY norm_value DESC;
CREATE TABLE temp_results AS SELECT id, L2Norm(vec) AS norm_value FROM test_vectors;
SELECT * FROM temp_results WHERE norm_value IS NULL;
SELECT id, L2Norm(vec) AS norm_value FROM test_vectors WHERE (SELECT norm_value IS NULL FROM temp_results WHERE temp_results.id = test_vectors.id);
SELECT id, L2Norm(vec), vec IS NULL AS is_nullable FROM test_vectors WHERE vec IS NOT NULL AND (SELECT COUNT(*) FROM temp_results WHERE norm_value > 2) = 0;