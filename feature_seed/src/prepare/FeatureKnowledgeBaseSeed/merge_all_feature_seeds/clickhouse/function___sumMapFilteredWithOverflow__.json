CREATE TABLE sum_map(    `date` Date,    `timeslot` DateTime,    `statusMap` Nested(status UInt8, requests UInt8)) ENGINE = Log;
INSERT INTO sum_map VALUES ('2000-01-01', '2000-01-01 00:00:00', [1, 2, 3], [10, 10, 10]), ('2000-01-01', '2000-01-01 00:00:00', [3, 4, 5], [10, 10, 10]), ('2000-01-01', '2000-01-01 00:01:00', [4, 5, 6], [10, 10, 10]), ('2000-01-01', '2000-01-01 00:01:00', [6, 7, 8], [10, 10, 10]);
SELECT sumMapFilteredWithOverflow([1, 4, 8])(statusMap.status, statusMap.requests) AS summap_overflow, toTypeName(summap_overflow) FROM sum_map;
SELECT sumMapFilteredWithOverflow([2, 3, 6])(statusMap.status, statusMap.requests) AS summap_overflow, date FROM sum_map GROUP BY date;
CREATE TABLE sum_map_additional(    `date` Date,    `timeslot` DateTime,    `statusMap` Nested(status UInt8, requests UInt8)) ENGINE = Log;
INSERT INTO sum_map_additional VALUES ('2000-01-01', '2000-01-01 00:05:00', [1, 2, 1], [5, 5, 5]), ('2000-01-01', '2000-01-01 00:05:00', [3, 4, 6], [5, 5, 5]);
SELECT date, SUM(summap_overflow) AS total_requests FROM (SELECT sumMapFilteredWithOverflow([1, 2, 4])(statusMap.status, statusMap.requests) AS summap_overflow FROM sum_map UNION ALL SELECT sumMapFilteredWithOverflow([3, 4, 5])(statusMap.status, statusMap.requests) AS summap_overflow FROM sum_map_additional) GROUP BY date;
SELECT date, SUM(summap_overflow) AS total_requests FROM (SELECT sumMapFilteredWithOverflow([1, 4, 8])(statusMap.status, statusMap.requests) AS summap_overflow FROM sum_map WHERE date = '2000-01-01') GROUP BY date;
SELECT sumMapFilteredWithOverflow([1, 2, 4, 5])(statusMap.status, statusMap.requests) AS summap_overflow, date, toTypeName(summap_overflow) FROM sum_map WHERE date BETWEEN '2000-01-01' AND '2000-01-01' GROUP BY date;
WITH (SELECT DISTINCT statusMap.status FROM sum_map) AS unique_status SELECT sumMapFilteredWithOverflow(unique_status, statusMap.requests) AS totals FROM sum_map;
SELECT status, sumMapFilteredWithOverflow([1, 3, 5])(statusMap.status, statusMap.requests) AS request_count FROM sum_map GROUP BY status;