CREATE TABLE test_map (m Map(String, String), n String) ENGINE = Memory;
INSERT INTO test_map VALUES ({'a':'1'}, 'value1'), ({'b':'2'}, 'value2'), ({'c':'NULL'}, 'value3');
SELECT mapValues(m) AS values FROM test_map WHERE n LIKE 'value%';
SELECT mapValues(m) AS values FROM test_map WHERE mapValues(m) LIKE mapValues(m) AND n LIKE '%1%';
CREATE TABLE test_join (id UInt32, data Map(String, String)) ENGINE = Memory;
INSERT INTO test_join VALUES (1, {'name':'one', 'age':'1'}), (2, {'name':'two', 'age':'2'});
SELECT t.id, mapValues(t.data) FROM test_join t JOIN (SELECT id, mapValues(m) AS vals FROM test_map) AS tm ON t.id = tm.id;
CREATE TABLE test_null (m Map(String, Nullable(String))) ENGINE = Memory;
INSERT INTO test_null VALUES ({'key1':NULL}), ({'key2':'value2'});
SELECT mapValues(m) AS values FROM test_null WHERE values LIKE 'value%' OR values LIKE '%1';
SELECT m, mapValues(m) FROM test_null WHERE m['key1'] IS NULL OR m['key2'] LIKE 'value%';
CREATE TABLE test_boundary (m Map(String, String), num Int32) ENGINE = Memory;
INSERT INTO test_boundary VALUES ({'min': '0', 'max': '100'}, 50), ({'min': '10', 'max': '90'}, 70);
SELECT mapValues(m) AS values FROM test_boundary WHERE num LIKE CAST(num AS String) AND max(num) >= 0;
SELECT mapValues(m) FROM test_boundary GROUP BY mapValues(m) HAVING count() > 1;