CREATE ROLE role1;
CREATE ROLE role2;
CREATE USER user1 IDENTIFIED BY 'password';
GRANT role1 TO user1;
GRANT role2 TO user1;
CREATE TABLE test_table (id UInt32, name String, value Float32);
INSERT INTO test_table VALUES (1, 'Alice', 10.0), (2, 'Bob', 20.0);
SET DEFAULT ROLE role1 TO user1;
SELECT defaultRoles();
CREATE TABLE test_table_2 (id UInt32, user_name String);
INSERT INTO test_table_2 VALUES (1, 'Alice'), (2, 'Bob');
SELECT defaultRoles() AS user_roles FROM test_table_2 WHERE user_name IN (SELECT name FROM test_table WHERE value > 15);
SET DEFAULT ROLE role2 TO user1;
SELECT defaultRoles();
CREATE TABLE permissions (user_id UInt32, role_name String);
INSERT INTO permissions VALUES (1, 'role1'), (1, 'role2');
SELECT defaultRoles() FROM permissions WHERE user_id = (SELECT id FROM test_table_2 WHERE user_name = 'Alice');
SELECT user_id, defaultRoles() AS roles FROM permissions LEFT JOIN (SELECT id FROM test_table_2) AS users ON permissions.user_id = users.id;