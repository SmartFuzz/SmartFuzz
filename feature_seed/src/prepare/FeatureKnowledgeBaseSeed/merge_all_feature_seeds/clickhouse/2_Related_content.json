CREATE TABLE test_dates (id Int32, event_date DateTime, value Nullable(Int32));
INSERT INTO test_dates (id, event_date, value) VALUES (1, '2023-10-01 00:00:00', 10), (2, '2023-10-02 00:00:00', NULL), (3, '2023-10-01 12:00:00', 20);
SELECT id, value IS NULL AS is_value_null FROM test_dates WHERE value IS NULL;
SELECT id, toUnixTimestamp(event_date) IS NULL AS is_timestamp_null FROM test_dates WHERE event_date > '2023-10-15 00:00:00';
SELECT AVG(value) IS NULL AS avg_value_is_null FROM (SELECT value FROM test_dates WHERE event_date < '2023-10-03 00:00:00') AS subquery;
SELECT id, event_date, COUNT(*) IS NULL AS count_null FROM (SELECT id, event_date FROM test_dates WHERE value IS NULL GROUP BY id, event_date) AS temp_table GROUP BY id, event_date HAVING COUNT(*) IS NULL;
SELECT DISTINCT id, (value + 10) IS NULL AS add_null FROM test_dates WHERE event_date < '2023-10-02 00:00:00' AND value IS NOT NULL;
CREATE TABLE test_joins (id Int32, related_id Int32, event_time DateTime);
INSERT INTO test_joins (id, related_id, event_time) VALUES (1, 1, '2023-10-01 01:00:00'), (2, NULL, '2023-10-01 01:00:00'), (3, 2, NULL);
SELECT t1.id, (CASE WHEN t2.related_id IS NULL THEN 0 ELSE 1 END) IS NULL AS is_related_null FROM test_dates t1 LEFT JOIN test_joins t2 ON t1.id = t2.id WHERE t1.value IS NOT NULL;
SELECT id, event_date, (SELECT COUNT(*) FROM test_joins t2 WHERE t2.related_id = test_dates.id) IS NULL AS count_related_null FROM test_dates;