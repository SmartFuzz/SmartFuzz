CREATE TABLE test_table (id Int8, value String, timestamp DateTime);
INSERT INTO test_table VALUES (1, '100'), (2, '200'), (3, '257'), (4, NULL);
SELECT id, reinterpretAsInt8(value) AS reinterpret_value, toTypeName(reinterpretAsInt8(value)) AS type_name FROM test_table WHERE reinterpret_value NOT BETWEEN 0 AND 100;
SELECT id, reinterpretAsInt8(COALESCE(value, '0')) AS reinterpret_value FROM test_table WHERE reinterpret_value NOT BETWEEN 200 AND 300;
CREATE TABLE second_table (id Int8, ref_id Int8) ENGINE = MergeTree() ORDER BY id;
INSERT INTO second_table VALUES (1, 1), (2, 2), (3, 3);
SELECT t1.id, t1.value, reinterpretAsInt8(t1.value) AS reinterpret_value FROM test_table t1 JOIN second_table t2 ON t1.id = t2.ref_id WHERE t1.id NOT BETWEEN 1 AND 2;
SELECT id, reinterpretAsInt8(value) AS reinterpret_value FROM test_table GROUP BY reinterpret_value HAVING reinterpret_value NOT BETWEEN reinterpretAsInt8('5') AND reinterpretAsInt8('15');
CREATE TEMPORARY TABLE temp_table AS SELECT id, value FROM test_table WHERE value != '';
SELECT id, reinterpretAsInt8(value) AS reinterpret_value FROM temp_table WHERE reinterpret_value NOT BETWEEN -128 AND 127 ORDER BY id DESC;