CREATE TABLE test_max2 (a Float64, b Float64);
INSERT INTO test_max2 VALUES (-1, 2), (3, -4), (0, 0), (5, 5);
SELECT max2(a, b) FROM test_max2;
SELECT max2(max2(-1, 3), min2(5, 2)) AS result FROM test_max2;
SELECT max2(a, (SELECT max(b) FROM test_max2 WHERE a < b)) AS max_value FROM test_max2;
WITH (SELECT avg(a) FROM test_max2) AS avg_a, (SELECT avg(b) FROM test_max2) AS avg_b SELECT max2(avg_a, avg_b) AS avg_max FROM test_max2;
CREATE TABLE t1 (x Float64);
INSERT INTO t1 VALUES (1.5), (2.5);
SELECT max2((SELECT max(x) FROM t1), (SELECT min(x) FROM t1)) AS max_value;
CREATE TABLE t2 (y Float64);
INSERT INTO t2 VALUES (-3.5), (4.5);
SELECT max2((SELECT SUM(x) FROM t1), (SELECT SUM(y) FROM t2)) AS combined_max;
SELECT max2(a, (SELECT max2(2, 3))) FROM test_max2 WHERE a > 0;