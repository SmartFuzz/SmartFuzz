CREATE TABLE test_dt64 (dt DateTime64(3, 'UTC'));
INSERT INTO test_dt64 VALUES (toDateTime64('2009-02-13 23:31:31.011', 3, 'UTC'));
SELECT toUnixTimestamp64Milli(dt) FROM test_dt64 AS dt;
CREATE TABLE test_boundary (dt DateTime64(6, 'UTC'));
INSERT INTO test_boundary VALUES (toDateTime64('2038-01-19 03:14:07.999999', 6, 'UTC'));
SELECT toUnixTimestamp64Milli(dt) FROM test_boundary AS dt;
CREATE TABLE nested_query (dt DateTime64(2, 'UTC'));
INSERT INTO nested_query VALUES (toDateTime64('1970-01-01 00:00:00.500', 2, 'UTC'));
WITH (SELECT toUnixTimestamp64Milli(dt) FROM nested_query) AS utc_timestamp SELECT utc_timestamp * 2 AS double_timestamp;
CREATE TABLE join_table_1 (id Int32, dt DateTime64(3, 'UTC'));
CREATE TABLE join_table_2 (id Int32, related_dt DateTime64(3, 'UTC'));
INSERT INTO join_table_1 VALUES (1, toDateTime64('2023-01-01 12:00:00.123', 3, 'UTC'));
INSERT INTO join_table_2 VALUES (1, toDateTime64('2023-01-01 12:00:05.456', 3, 'UTC'));
SELECT j1.id, toUnixTimestamp64Milli(j1.dt) AS j1_timestamp, toUnixTimestamp64Milli(j2.related_dt) AS j2_timestamp FROM join_table_1 j1 JOIN join_table_2 j2 ON j1.id = j2.id;
CREATE TABLE table_with_null (dt DateTime64(3, 'UTC'));
INSERT INTO table_with_null VALUES (NULL), (toDateTime64('2020-05-20 10:10:10.999', 3, 'UTC'));
SELECT toUnixTimestamp64Milli(dt) FROM table_with_null;
CREATE TABLE precision_test (dt DateTime64(7, 'UTC'));
INSERT INTO precision_test VALUES (toDateTime64('2023-10-10 12:12:12.1234567', 7, 'UTC'));
SELECT toUnixTimestamp64Milli(dt) FROM precision_test WHERE dt IS NOT NULL;