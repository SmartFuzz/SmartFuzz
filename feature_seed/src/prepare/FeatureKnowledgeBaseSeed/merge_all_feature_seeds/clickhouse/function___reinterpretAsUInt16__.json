CREATE TABLE test_table (id UInt32, value UInt16);
INSERT INTO test_table VALUES (1, 256), (2, 65535), (3, 0);
SELECT id, reinterpretAsUInt16(value) AS reinterpret_value FROM test_table;
CREATE TABLE source_table (number Float64);
INSERT INTO source_table VALUES (257.0), (65536.0), (0.1);
SELECT number, reinterpretAsUInt16(number) AS reinterpret_number FROM source_table;
SELECT toTypeName(reinterpretAsUInt16(257)) AS type_name1, toTypeName(reinterpretAsUInt16(65536)) AS type_name2, toTypeName(reinterpretAsUInt16(-1)) AS type_name3;
WITH (SELECT toUInt8(256) AS x) AS tmp SELECT x, reinterpretAsUInt16(x) AS res FROM tmp;
CREATE TABLE temp_table (str_value String);
INSERT INTO temp_table VALUES ('string_value1'), ('string_value2');
SELECT str_value, reinterpretAsUInt16(str_value) AS reinterpret_str FROM temp_table;
CREATE TABLE join_table1 (id UInt32, value UInt16);
INSERT INTO join_table1 VALUES (1, 100), (2, 200);
CREATE TABLE join_table2 (join_id UInt32, join_value UInt16);
INSERT INTO join_table2 VALUES (1, 300), (2, 400);
SELECT jt1.id, reinterpretAsUInt16(jt1.value) + reinterpretAsUInt16(jt2.join_value) AS combined_value FROM join_table1 jt1 JOIN join_table2 jt2 ON jt1.id = jt2.join_id;
SELECT reinterpretAsUInt16(toUInt8(258)), reinterpretAsUInt16(toUInt16(65535)), reinterpretAsUInt16(toFloat32(3.14)), reinterpretAsUInt16(toDate('2023-10-01'));