CREATE TABLE test_dates (id UInt32, date_value String);
INSERT INTO test_dates VALUES (1, '2023-10-01T12:00:00.000Z'), (2, 'invalid-date'), (3, '2023-10-02T15:30:45.123456789Z'), (4, '2023-10-03T25:00:00.000Z');
SELECT id, parseDateTime64InJodaSyntaxOrNull(date_value, 6) AS parsed_date FROM test_dates;
CREATE TABLE valid_dates AS SELECT parseDateTime64InJodaSyntaxOrNull(date_value, 6) AS parsed_date FROM test_dates WHERE date_value LIKE '%T%';
CREATE TABLE invalid_dates AS SELECT parseDateTime64InJodaSyntaxOrNull(date_value, 6) AS parsed_date FROM test_dates WHERE date_value NOT LIKE '%T%';
SELECT id, parseDateTime64InJodaSyntaxOrNull(date_value, 3) AS parsed_date FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE date_value IS NOT NULL);
SELECT t1.id, parseDateTime64InJodaSyntaxOrNull(t2.date_value, 6) AS parsed_date FROM test_dates AS t1 JOIN test_dates AS t2 ON t1.id = t2.id WHERE t2.date_value IS NOT NULL;
SELECT id, parseDateTime64InJodaSyntaxOrNull(date_value, 9) AS parsed_date FROM test_dates WHERE parseDateTime64InJodaSyntaxOrNull(date_value, 6) IS NULL;
SELECT (SELECT MAX(parseDateTime64InJodaSyntaxOrNull(date_value, 6)) FROM test_dates) AS max_date, (SELECT MIN(parseDateTime64InJodaSyntaxOrNull(date_value, 6)) FROM test_dates) AS min_date;
SELECT AVG(toUnixTimestamp(parseDateTime64InJodaSyntaxOrNull(date_value, 6))) AS avg_timestamp FROM test_dates WHERE parseDateTime64InJodaSyntaxOrNull(date_value, 6) IS NOT NULL;