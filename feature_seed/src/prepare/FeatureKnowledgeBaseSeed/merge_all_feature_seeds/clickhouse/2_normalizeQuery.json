CREATE TABLE test_data (id UInt32, value String, created_at DateTime, score Float32, notes UUID);
INSERT INTO test_data VALUES (1, '[1, 2, 3, 4]', '2023-10-01 10:00:00', 98.7, 'a8babc56-7f00-428b-a16f-dd4f36d8a7a6');
INSERT INTO test_data VALUES (2, '[5, 6, 7, 8]', '2023-10-02 10:00:00', NULL, NULL);
INSERT INTO test_data VALUES (3, 'EMPTY STRING', '2023-10-03 10:00:00', 100.5, '123e4567-e89b-12d3-a456-426614174000');
SELECT normalizeQuery(value) AS normalized_query, COUNT(*) FROM test_data GROUP BY normalized_query HAVING normalized_query BETWEEN '[1, 2, 3, 4]' AND '[1, 2, 3, 8]';
SELECT id, value, created_at, score FROM test_data WHERE score IS NULL AND created_at BETWEEN addDays(NOW(), -10) AND NOW();
SELECT id, normalizeQuery(value) AS norm_value, score FROM test_data WHERE norm_value BETWEEN normalizeQuery('[1, 2]') AND normalizeQuery('[1, 9]') ORDER BY norm_value;
SELECT id, AVG(score) AS avg_score FROM test_data WHERE value = normalizeQuery('[5, 6, 7, 8]') GROUP BY id HAVING avg_score BETWEEN 95 AND 105;
WITH (SELECT id, normalizeQuery(value) AS norm_val FROM test_data) AS subquery SELECT COUNT(*) FROM subquery WHERE norm_val BETWEEN '[1, 2]' AND '[3, 4]';
CREATE TABLE temp_data AS SELECT * FROM test_data WHERE score BETWEEN 50 AND 100;
INSERT INTO temp_data SELECT id, normalizeQuery(value), created_at, score FROM test_data WHERE id BETWEEN 1 AND 3;
SELECT AVG(score) FROM temp_data WHERE created_at BETWEEN '2023-10-01' AND '2023-10-03' AND score IS NOT NULL;