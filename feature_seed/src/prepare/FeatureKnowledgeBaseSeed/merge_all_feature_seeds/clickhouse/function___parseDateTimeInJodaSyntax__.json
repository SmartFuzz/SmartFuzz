CREATE TABLE test_dates (dateString String);
INSERT INTO test_dates VALUES ('2023-02-24 14:53:31'), ('2023-02-25 15:00:00'), ('invalid-date'), ('2023-03-01 12:30:45');
SELECT parseDateTimeInJodaSyntax(dateString, 'yyyy-MM-dd HH:mm:ss', 'UTC') AS parsedDate FROM test_dates;
SELECT dateString, parseDateTimeInJodaSyntax(dateString, 'yyyy-MM-dd HH:mm:ss', 'Europe/London') FROM test_dates WHERE dateString IS NOT NULL;
CREATE TABLE timezones (id Int32, name String, timezone String);
INSERT INTO timezones VALUES (1, 'Timezone 1', 'Europe/London'), (2, 'Timezone 2', 'America/New_York');
SELECT t.name AS timezoneName, parseDateTimeInJodaSyntax('2023-02-24 14:53:31', 'yyyy-MM-dd HH:mm:ss', t.timezone) FROM timezones t;
SELECT t.id, parseDateTimeInJodaSyntax(d.dateString, 'yyyy-MM-dd HH:mm:ss', t.timezone) FROM timezones t JOIN test_dates d ON parseDateTimeInJodaSyntax(d.dateString, 'yyyy-MM-dd HH:mm:ss', t.timezone) IS NOT NULL;
SELECT parseDateTimeInJodaSyntax('2023-12-31 23:59:59', 'yyyy-MM-dd HH:mm:ss') AS endOfYear, parseDateTimeInJodaSyntax('2023-01-01 00:00:00', 'yyyy-MM-dd HH:mm:ss') AS startOfYear;
SELECT parseDateTimeInJodaSyntax('2023-05-15 12:30:00', 'yyyy-MM-dd HH:mm:ss') + INTERVAL 1 DAY AS nextDay;
SELECT DISTINCT parseDateTimeInJodaSyntax(dateString, 'yyyy-MM-dd HH:mm:ss') FROM test_dates;
SELECT count(*) AS validDateCount FROM test_dates WHERE parseDateTimeInJodaSyntax(dateString, 'yyyy-MM-dd HH:mm:ss') IS NOT NULL;