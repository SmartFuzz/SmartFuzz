CREATE TABLE test_dates (event_time DateTime);
INSERT INTO test_dates VALUES (toDateTime('1990-01-01 00:00:00')), (toDateTime('1995-06-15 12:30:00')), (toDateTime('2000-01-01 00:00:00'));
SELECT toRelativeHourNum(event_time) FROM test_dates;
SELECT toRelativeHourNum(toDateTime('2023-10-01 07:15:00')) AS hours_elapsed;
SELECT toRelativeHourNum(toDateTime('2023-12-31 23:59:59')) AS hours_end_of_year;
SELECT toRelativeHourNum(DATEADD(hour, -1, event_time)) FROM test_dates;
SELECT toRelativeHourNum(event_time), COUNT(*) AS event_count FROM test_dates GROUP BY toRelativeHourNum(event_time);
SELECT d.id, toRelativeHourNum(e.event_time) FROM (SELECT number AS id FROM system.numbers LIMIT 10) AS d JOIN test_dates AS e ON d.id = toRelativeHourNum(e.event_time) WHERE e.event_time < toDateTime('2000-01-01 00:00:00');
SELECT MAX(toRelativeHourNum(event_time)) AS max_hours FROM test_dates;
SELECT toRelativeHourNum(MAX(event_time)) FROM test_dates;
SELECT AVG(toRelativeHourNum(event_time)) AS average_hours FROM test_dates WHERE event_time > toDateTime('1990-01-01 00:00:00');
SELECT (SELECT toRelativeHourNum(event_time) FROM test_dates WHERE event_time = toDateTime('1995-06-15 12:30:00')) AS specific_hour;
SELECT toRelativeHourNum(toDateTime('2050-01-01 00:00:00')) AS future_hour;
CREATE TABLE test_results AS (SELECT toRelativeHourNum(event_time) AS hours_elapsed FROM test_dates);
INSERT INTO test_results SELECT toRelativeHourNum(toDateTime('1995-06-15 12:30:00'));
SELECT toRelativeHourNum(toDateTime('1960-01-01 12:00:00')) AS hours_since_fixed_point;