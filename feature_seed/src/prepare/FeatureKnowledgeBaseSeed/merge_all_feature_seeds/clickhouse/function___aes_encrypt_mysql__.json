CREATE TABLE test_encryption (id UInt32, plaintext String, key String, iv String, mode String);
INSERT INTO test_encryption VALUES (1, 'Secret', '12345678910121314151617181920212', 'iviviviviviviviv', 'aes-256-ofb');
INSERT INTO test_encryption VALUES (2, 'AnotherSecret', '123456789101213141516171819202122', 'iviviviviviviviv123456', 'aes-256-cbc');
INSERT INTO test_encryption VALUES (3, 'SecretAgain', '12345678910121314151617181920212', 'iviviviviviviviv123', 'aes-128-ecb');
SELECT encrypt(mode, plaintext, key, iv) AS expected_ciphertext FROM test_encryption WHERE id = 1;
SELECT aes_encrypt_mysql(mode, plaintext, key, iv) AS actual_ciphertext FROM test_encryption WHERE id = 1;
SELECT CASE WHEN encrypt(mode, plaintext, key, iv) = aes_encrypt_mysql(mode, plaintext, key, iv) THEN 'MATCH' ELSE 'NO MATCH' END AS comparison FROM test_encryption WHERE id = 1;
SELECT hex(aes_encrypt_mysql(mode, plaintext, key, iv)) AS ciphertext_hex FROM test_encryption WHERE id = 2;
WITH (SELECT 'Secret' AS text, '123456789101213141516171819202122' AS key, 'iviviviviviviviv123' AS iv) AS params SELECT aes_encrypt_mysql('aes-256-CBC', text, key, iv) AS encrypted_text;
WITH (SELECT * FROM test_encryption WHERE mode = 'aes-256-ofb') AS encrypted_data SELECT hex(aes_encrypt_mysql(mode, plaintext, key, iv)) AS ciphertext_hex FROM encrypted_data;
SELECT aes_encrypt_mysql('aes-128-cbc', plaintext, 'shortkey', 'iviviviviviviviv') AS encrypted_output FROM test_encryption WHERE LENGTH(key) < 16;
SELECT aes_encrypt_mysql('aes-256-ecb', 'BoundaryCase', '1234567', 'ivtoo_long_iv_for_this');
SELECT aes_encrypt_mysql('aes-192-ofb', plaintext, key) AS encrypted FROM test_encryption WHERE iv IS NULL;
SELECT COUNT(*) AS match_count FROM (SELECT hex(aes_encrypt_mysql(mode, plaintext, key, iv)) AS ciphertext_hex FROM test_encryption) AS subquery WHERE ciphertext_hex IS NOT NULL;