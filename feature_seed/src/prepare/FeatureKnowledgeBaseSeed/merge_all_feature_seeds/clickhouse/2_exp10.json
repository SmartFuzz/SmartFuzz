CREATE TABLE test_table (id UInt32, value Float64, text_column String);
INSERT INTO test_table (id, value, text_column) VALUES (1, 0.999999999999, 'input1'), (2, -1.0, 'input2'), (3, NULL, 'input3'), (4, 1000000.0, 'input4');
CREATE TABLE nested_table (data Float64, idx UInt32);
INSERT INTO nested_table (data, idx) VALUES (1.5, 1), (2.0, 2), (3.5, 3);
SELECT id, exp10(value % (SELECT AVG(data) FROM nested_table WHERE idx < 3)) AS result FROM test_table WHERE result IS NOT NULL;
SELECT id, exp10(value % (SELECT COUNT() FROM nested_table)) AS mod_result FROM test_table HAVING mod_result > exp10(0) ORDER BY mod_result ASC;
WITH (SELECT SUM(value) FROM test_table) AS total FROM test_table WHERE exp10(total % 10) IS NOT NULL;
SELECT A.id, A.value, exp10(B.data) % 10 AS mod_result FROM test_table AS A JOIN nested_table AS B ON A.id = (B.idx + 1) GROUP BY A.id, mod_result HAVING mod_result < exp10(3.0);
ALTER TABLE test_table ADD COLUMN new_value Decimal(10, 5);
UPDATE test_table SET new_value = exp10(value % 5) WHERE new_value IS NULL;