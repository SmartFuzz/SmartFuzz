CREATE TABLE fuzz_test (id UInt32, str1 String, str2 String, val INT);
INSERT INTO fuzz_test VALUES (1, '', ''), (2, 'abc', 'a'), (3, 'clickhouse', NULL), (4, 'damerau', 'damear'), (5, ' ', ' '), (6, 'abc', 'def'), (7, 'test', 'tset');
SELECT str1, str2, damerauLevenshteinDistance(str1, str2) AS distance FROM fuzz_test WHERE id BETWEEN 2 AND 7;
SELECT id, str1, str2, damerauLevenshteinDistance(str1, str2) AS distance FROM fuzz_test WHERE distance BETWEEN 0 AND 3;
SELECT id, str1, str2, CASE WHEN damerauLevenshteinDistance(str1, str2) IS NOT NULL THEN 'Valid' ELSE 'Invalid' END AS status FROM fuzz_test;
CREATE TABLE temp_test AS SELECT id, str1, str2 FROM fuzz_test WHERE damerauLevenshteinDistance(str1, str2) BETWEEN 1 AND 2;
SELECT id, COUNT(*) AS count FROM (SELECT str1, str2 FROM temp_test) GROUP BY str1 HAVING count BETWEEN 1 AND 5;
SELECT DISTINCT str1, str2 FROM fuzz_test WHERE damerauLevenshteinDistance(str1, str2) BETWEEN 0 AND 2 ORDER BY str1, str2;
SELECT id, MAX(damerauLevenshteinDistance(str1, str2)) OVER (PARTITION BY val) AS max_distance FROM fuzz_test;
SELECT str1, damerauLevenshteinDistance(str1, toString(val)) AS distance FROM fuzz_test JOIN (SELECT DISTINCT val FROM fuzz_test WHERE val IS NOT NULL) AS vals ON val BETWEEN 1 AND 5;