CREATE TABLE test_strings (id Int32, text String, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'Hello World'), (2, 'Lorem Ipsum Dolor Sit Amet'), (3, 'Ein Beispieltext mit Umlaute: Ä, Ö, Ü'), (4, 'Über den Wolken'), (5, 'Daten mit NULL: NULL');
CREATE TABLE test_numbers (id Int32, num Float64, str_id Int32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_numbers VALUES (1, 1.1, 1), (2, 2.2, 2), (3, NULL, 3), (4, 4.4, 4), (5, 5.5, 5);
SELECT overlayUTF8(text, overlayUTF8(text, 'Test', 1), 1) AS modified_text FROM test_strings WHERE id != ALL (SELECT str_id FROM test_numbers WHERE num IS NOT NULL);
SELECT t1.id, overlayUTF8(t1.text, 'foobar', 1) AS overlayed_text FROM test_strings t1 JOIN test_numbers t2 ON t1.id != ALL (SELECT str_id FROM test_numbers WHERE num < 3.0) WHERE created_at IS NOT NULL GROUP BY t1.id, t1.text HAVING overlayed_text != 'foobar';
SELECT t1.id, overlayUTF8(t1.text, 'replacement', -5) AS new_text FROM test_strings t1 WHERE id != ALL (SELECT id FROM test_numbers WHERE num IS NULL);
SELECT COUNT(*) FROM test_numbers WHERE num > ALL(SELECT num FROM test_numbers WHERE str_id = 2);
SELECT overlayUTF8(t1.text, 'foo', 1, 3) FROM test_strings t1 WHERE (SELECT COUNT(*) FROM test_numbers WHERE num < 2.0) != ALL (SELECT id FROM test_numbers);
SELECT t1.id, overlayUTF8(t1.text, 'old', LENGTH(t1.text) - 3) AS modified FROM test_strings t1 JOIN (SELECT str_id FROM test_numbers WHERE num IS NULL) t2 ON t1.id != ALL (SELECT id FROM test_numbers WHERE num = 5.5);