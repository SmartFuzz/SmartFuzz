CREATE TABLE test_bitShift (value Int32) ENGINE = Memory;
INSERT INTO test_bitShift VALUES (99), (128), (255), (512);
SELECT value AS a, bin(a), bitShiftLeft(a, 2) AS a_shifted, bin(a_shifted) FROM test_bitShift;
CREATE TABLE test_strings (str String) ENGINE = Memory;
INSERT INTO test_strings VALUES ('abc'), ('xyz'), ('OpenAI'), ('ChatGPT');
SELECT str AS a, hex(a), bitShiftLeft(a, 4) AS a_shifted, hex(a_shifted) FROM test_strings;
CREATE TABLE test_fixed_strings (fixed_str FixedString(3)) ENGINE = Memory;
INSERT INTO test_fixed_strings VALUES (toFixedString('abc', 3)), (toFixedString('xyz', 3));
SELECT fixed_str AS a, hex(a), bitShiftLeft(a, 4) AS a_shifted, hex(a_shifted) FROM test_fixed_strings;
WITH (SELECT value FROM test_bitShift WHERE value < 200) AS subquery1, (SELECT str FROM test_strings WHERE str LIKE 'a%') AS subquery2 SELECT subquery1.value AS a, bitShiftLeft(subquery1.value, 2) AS a_shifted, subquery2.str AS b, bitShiftLeft(b, 2) AS b_shifted;
SELECT value AS a, bitShiftLeft(a, 1) AS a_shifted FROM (SELECT value FROM test_bitShift WHERE value IN (99, 128));
SELECT a.value AS a, b.value AS b, bitShiftLeft(a.value, 2) AS a_shifted, bitShiftLeft(b.value, 3) AS b_shifted FROM (SELECT value FROM test_bitShift) AS a JOIN (SELECT value FROM test_bitShift WHERE value > 128) AS b ON a.value < b.value;