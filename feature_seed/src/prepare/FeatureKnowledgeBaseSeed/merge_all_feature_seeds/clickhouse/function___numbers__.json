SELECT * FROM numbers(10);
SELECT * FROM numbers(0, 10);
SELECT * FROM numbers(10, 5);
SELECT * FROM numbers(5, 15);
SELECT * FROM numbers(0, 20, 2);
SELECT number + 5 AS incremented_number FROM numbers(5);
SELECT number * 3 AS tripled_number FROM numbers(10);
SELECT number, number * number AS squared_number FROM numbers(10);
SELECT number FROM numbers(0, 100) WHERE number % 10 = 0;
SELECT sum(number) AS total FROM numbers(1, 100);
SELECT d FROM (SELECT toDate('2020-01-01') + number AS d FROM numbers(365)) WHERE d < toDate('2020-07-01');
CREATE TABLE test_numbers (num UInt64);
INSERT INTO test_numbers SELECT number FROM numbers(10);
SELECT a.num, b.num FROM test_numbers AS a JOIN test_numbers AS b ON a.num < b.num;
SELECT number - 10 AS difference FROM numbers(15);
SELECT DISTINCT number FROM numbers(1, 50) WHERE number IN (10, 20, 30, 40);
WITH numbers(10) AS t SELECT * FROM t WHERE number < 5;
SELECT number FROM (SELECT number FROM numbers(20) WHERE number % 3 = 0) AS temp WHERE number > 5;
SELECT count(*) FROM numbers(200) WHERE number % 4 = 0;
SELECT arrayJoin(numbers(5)) AS num_array;
CREATE TABLE numbers_test AS SELECT number FROM numbers(5);