CREATE TABLE test_array (id INT, values ARRAY(INT));
INSERT INTO test_array VALUES (1, [1, null, 3, 11, null, 12]), (2, [null, null, 5, 6, 14, null]), (3, [null, null, null, null]);
SELECT id, arrayFill(x -> not isNull(x), values) AS filled_values FROM test_array;
SELECT id, arrayFill(x -> x < 10, values) AS filled_values FROM test_array;
SELECT id, arrayFill(x -> x == 3, values) AS filled_values FROM test_array WHERE id = 1;
SELECT id, arrayFill(x -> not isNull(x) AND x > 5, values) AS filled_values FROM test_array WHERE id = 2;
SELECT t.id, arrayFill(x -> not isNull(x), t.values) AS filled_values FROM test_array t WHERE id IN (SELECT id FROM test_array WHERE arrayLength(values) > 5);
SELECT id, arrayFill(x -> x % 2 != 0, values) AS filled_values FROM test_array WHERE arrayLength(values) > 3;
CREATE TABLE test_array_nested AS SELECT id, arrayFill(x -> not isNull(x), values) AS filled_values FROM test_array;
SELECT id, filled_values FROM test_array_nested WHERE arrayLength(filled_values) > 3;