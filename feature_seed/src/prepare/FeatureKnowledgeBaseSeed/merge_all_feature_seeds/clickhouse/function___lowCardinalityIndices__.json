DROP TABLE IF EXISTS test_part1;
CREATE TABLE test_part1 (s LowCardinality(String)) ENGINE = Memory;
INSERT INTO test_part1 VALUES ('ab'), ('cd'), ('ab'), ('ab'), ('df');
DROP TABLE IF EXISTS test_part2;
CREATE TABLE test_part2 (s LowCardinality(String)) ENGINE = Memory;
INSERT INTO test_part2 VALUES ('ef'), ('cd'), ('ab'), ('cd'), ('ef');
CREATE TABLE combined_test AS SELECT s FROM test_part1 UNION ALL SELECT s FROM test_part2;
SELECT s, lowCardinalityIndices(s) FROM combined_test;
CREATE TABLE test_multi (id UInt32, s LowCardinality(String)) ENGINE = Memory;
INSERT INTO test_multi VALUES (1, 'xx'), (2, 'yy'), (2, 'xx'), (3, 'zz');
SELECT id, s, lowCardinalityIndices(s) FROM test_multi ORDER BY id;
CREATE TABLE sample_data (key UInt32, value LowCardinality(String)) ENGINE = Memory;
INSERT INTO sample_data VALUES (1, 'alpha'), (1, 'beta'), (2, 'alpha'), (3, 'gamma');
SELECT key, value, lowCardinalityIndices(value) FROM sample_data WHERE key IN (SELECT DISTINCT key FROM sample_data WHERE value LIKE 'a%');
DROP TABLE IF EXISTS test_nested;
CREATE TABLE test_nested (s LowCardinality(String), score UInt32) ENGINE = Memory;
INSERT INTO test_nested VALUES ('quick', 10), ('brown', 20), ('fox', 30);
SELECT s, lowCardinalityIndices(s), (SELECT AVG(score) FROM test_nested) as avg_score FROM test_nested WHERE score > (SELECT 15);
CREATE TABLE join_test (user_id UInt32, status LowCardinality(String)) ENGINE = Memory;
INSERT INTO join_test VALUES (1, 'active'), (2, 'inactive'), (3, 'active');
SELECT j.user_id, j.status, lowCardinalityIndices(j.status) FROM join_test AS j JOIN (SELECT DISTINCT user_id FROM join_test WHERE status = 'active') AS active_users ON j.user_id = active_users.user_id;