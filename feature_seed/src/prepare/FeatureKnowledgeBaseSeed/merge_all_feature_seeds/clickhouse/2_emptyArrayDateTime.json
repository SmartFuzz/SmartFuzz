CREATE TABLE test_table (id UInt32, name String, timestamps Array(DateTime), value Float64, description Nullable(String));
INSERT INTO test_table (id, name, timestamps, value, description) VALUES (1, 'test1', [], 0.0, NULL), (2, 'test2', ['2023-01-01 00:00:00'], 1.0, 'sample description');
SELECT id, name, timestamps FROM test_table WHERE emptyArrayDateTime() LIKE name;
SELECT id, name, value, (SELECT COUNT() FROM test_table AS t WHERE t.value > test_table.value) AS higher_count FROM test_table WHERE emptyArrayDateTime() LIKE (SELECT description FROM test_table WHERE id = 1 LIMIT 1);
SELECT id, value, COUNT(*) OVER () AS total_count FROM test_table WHERE value < 1.0 AND emptyArrayDateTime() LIKE (SELECT name FROM test_table WHERE id = 2);
SELECT id, name FROM test_table WHERE name LIKE 'test%' AND timestamps IS NOT NULL AND value > (SELECT AVG(value) FROM test_table WHERE description IS NULL);
SELECT id, name FROM test_table WHERE emptyArrayDateTime() LIKE name GROUP BY id HAVING COUNT(timestamps) > 0;
SELECT id, name, value, (SELECT COUNT() FROM test_table WHERE value IS NOT NULL AND emptyArrayDateTime() LIKE name) AS non_null_count FROM test_table ORDER BY non_null_count DESC;
SELECT id, name, (SELECT MAX(value) FROM test_table) AS max_value FROM test_table WHERE emptyArrayDateTime() LIKE description OR id = 1;
ALTER TABLE test_table ADD COLUMN new_column DateTime;
INSERT INTO test_table (id, name, timestamps, value, description, new_column) VALUES (3, 'test3', emptyArrayDateTime(), 2.5, 'new entry', '2023-01-02 00:00:00');