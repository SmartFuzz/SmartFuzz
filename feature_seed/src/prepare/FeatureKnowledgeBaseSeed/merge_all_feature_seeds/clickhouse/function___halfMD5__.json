CREATE TABLE test_halfMD5 (id UInt64, input Array(String), created_at DateTime);
INSERT INTO test_halfMD5 VALUES (1, array('hello', 'world'), toDateTime('2023-01-01 00:00:00'));
INSERT INTO test_halfMD5 VALUES (2, array('clickhouse', 'database'), toDateTime('2023-01-01 00:00:00'));
INSERT INTO test_halfMD5 VALUES (3, array('halfMD5', 'function', 'test'), toDateTime('2023-01-01 00:00:00'));
SELECT id, halfMD5(input) AS hash_value FROM test_halfMD5 WHERE created_at > toDateTime('2022-12-31 00:00:00');
SELECT id, halfMD5(input, 'additional_param') AS hash_value FROM test_halfMD5;
WITH (SELECT arrayJoin(input) AS item FROM test_halfMD5 WHERE id = 1) AS flattened_input SELECT halfMD5(item) AS hash_value FROM flattened_input;
SELECT id, halfMD5(arrayJoin(input), 'concat', created_at) AS hash_value FROM test_halfMD5;
CREATE TABLE test_nested (src Array(String), dest Array(String));
INSERT INTO test_nested VALUES (array('source1', 'source2'), array('dest1', 'dest2'));
SELECT halfMD5(arrayJoin(src), arrayJoin(dest)) AS combined_hash FROM test_nested;
SELECT halfMD5('same_value', 12345, toDate('2023-01-01')) AS hash1, halfMD5('same_value', 123.45, toDate('2023-01-01')) AS hash2;
SELECT COUNT(*) FROM test_halfMD5 WHERE halfMD5(input) = halfMD5(array('hello', 'world'));