CREATE TABLE h3_edges (edge UInt64);
INSERT INTO h3_edges VALUES (1248204388774707197), (1248204388774707198), (1248204388774707199);
SELECT h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination FROM h3_edges;
SELECT h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination FROM (SELECT edge FROM h3_edges WHERE edge IN (1248204388774707197, 1248204388774707198));
WITH 1248204388774707197 AS edge_value SELECT h3GetDestinationIndexFromUnidirectionalEdge(edge_value) AS destination;
SELECT a.edge, h3GetDestinationIndexFromUnidirectionalEdge(a.edge) AS destination FROM (SELECT edge FROM h3_edges) AS a;
CREATE TABLE h3_results (destination UInt64);
INSERT INTO h3_results SELECT h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination FROM h3_edges;
SELECT COUNT(*) FROM (SELECT h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination FROM h3_edges) AS result WHERE destination IS NOT NULL;
SELECT DISTINCT h3GetDestinationIndexFromUnidirectionalEdge(edge) AS destination FROM h3_edges WHERE edge > 0;