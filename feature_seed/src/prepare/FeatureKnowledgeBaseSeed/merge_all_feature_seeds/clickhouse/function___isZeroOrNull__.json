CREATE TABLE t_null (y Nullable(Int32));
INSERT INTO t_null VALUES (NULL), (0), (1), (2);
SELECT isZeroOrNull(y) FROM t_null;
SELECT COUNT(*) FROM t_null WHERE isZeroOrNull(y);
SELECT * FROM (SELECT y, isZeroOrNull(y) as is_zero_null FROM t_null) AS subquery WHERE is_zero_null = 1;
CREATE TABLE t1 (id Int32, value Nullable(Int32));
INSERT INTO t1 VALUES (1, NULL), (2, 0), (3, 5);
SELECT t1.id FROM t1 JOIN t_null ON isZeroOrNull(t_null.y) WHERE t_null.y = t1.value;
SELECT * FROM (SELECT t1.id, isZeroOrNull(t1.value) as value_check FROM t1) AS check_query WHERE value_check = 1;
SELECT t1.id FROM t1 WHERE isZeroOrNull(value) OR value = 1;
SELECT COUNT(*) AS total_zero_null FROM (SELECT value, isZeroOrNull(value) FROM t1 WHERE isZeroOrNull(value) = 1) AS inner_query;
CREATE TABLE t2 (x Nullable(Int32), y Nullable(Int32));
INSERT INTO t2 VALUES (NULL, NULL), (0, 1), (3, 0), (4, 5);
SELECT t2.x, t2.y, isZeroOrNull(t2.x) AS x_check, isZeroOrNull(t2.y) AS y_check FROM t2 WHERE x_check = 1 AND y_check = 1;
SELECT SUM(isZeroOrNull(y)) FROM t_null;
SELECT t2.x FROM t2 LEFT JOIN t1 ON isZeroOrNull(t1.value) WHERE t1.value IS NULL;