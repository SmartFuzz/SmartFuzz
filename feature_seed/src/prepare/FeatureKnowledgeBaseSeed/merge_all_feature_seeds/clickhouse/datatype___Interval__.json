CREATE TABLE interval_test (id INT, start_date DATETIME, end_date DATETIME);
INSERT INTO interval_test VALUES (1, '2023-01-01 00:00:00', '2023-01-03 12:00:00');
INSERT INTO interval_test VALUES (2, '2023-02-01 00:00:00', '2023-02-15 12:00:00');
SELECT id, start_date, end_date, end_date - start_date AS duration_days FROM interval_test WHERE duration_days > INTERVAL 10 DAY;
SELECT id, start_date, start_date + INTERVAL 2 DAY AS second_day, end_date + INTERVAL 5 HOUR AS adjusted_end_date FROM interval_test;
SELECT id, start_date, end_date, start_date + (INTERVAL 1 WEEK + INTERVAL 2 HOUR) AS extended_date FROM interval_test WHERE id = 1;
SELECT id, start_date + INTERVAL 1 MONTH AS start_plus_month, end_date + INTERVAL 1 MONTH AS end_plus_month FROM interval_test WHERE start_date < end_date;
SELECT id, (end_date - start_date) > INTERVAL 10 DAY AS is_long_duration FROM interval_test;
SELECT id, end_date, toIntervalDay(DATEDIFF(DAY, start_date, end_date)) AS duration_interval FROM interval_test;
SELECT * FROM interval_test WHERE start_date + INTERVAL 3 DAYS < end_date;
SELECT id, start_date + INTERVAL 30 MINUTE AS adjusted_time FROM interval_test WHERE id IN (SELECT id FROM interval_test WHERE end_date > now());
SELECT t1.id, t1.start_date, t1.end_date, t2.additional_days FROM interval_test AS t1 JOIN (SELECT id, 5 AS additional_days FROM interval_test WHERE id = 1) AS t2 ON t1.id = t2.id;
SELECT id, CASE WHEN end_date < now() THEN INTERVAL 1 DAY ELSE INTERVAL 2 DAY END AS interval_case FROM interval_test;
SELECT now() AS current_time, current_time + INTERVAL 15 MINUTE AS time_plus_15_mins;
SELECT toTypeName(INTERVAL 5 HOUR) AS interval_type;
SELECT toIntervalWeek(3) = toIntervalDay(21) AS week_equals_days;
SELECT id, (start_date + INTERVAL 1 MONTH) AS future_date FROM interval_test WHERE id = (SELECT max(id) FROM interval_test);