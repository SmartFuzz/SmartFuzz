CREATE TABLE test_urls (url String);
INSERT INTO test_urls VALUES ('http://example.com'), ('https://clickhouse.com'), ('ftp://files.example.com/file.txt'), ('data:text/plain;
base64,Hello%20World!');
SELECT base64URLEncode(url) FROM test_urls;
SELECT base64URLEncode('https://example.com/path/to/resource?query=string&another=value#fragment') AS encoded_url;
SELECT base64URLEncode(concat('https://', url)) FROM test_urls;
SELECT base64URLEncode(url) FROM (SELECT url FROM test_urls WHERE url LIKE 'https://%') AS filtered_urls;
WITH (SELECT url FROM test_urls LIMIT 1) AS subquery SELECT base64URLEncode(url) FROM subquery;
SELECT base64URLEncode(url1) AS encoded_url1, base64URLEncode(url2) AS encoded_url2 FROM (SELECT url AS url1, url FROM test_urls) AS urls_combined;
SELECT base64URLEncode(concat('Encoded: ', url)) FROM test_urls;
CREATE TABLE urls_external (url String) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO urls_external VALUES ('http://api.example.com/data/1'), ('http://api.example.com/data/2');
SELECT base64URLEncode(url) FROM urls_external WHERE url LIKE 'http://%';
CREATE TABLE complex_test (url String, timestamp DateTime) ENGINE = MergeTree() ORDER BY timestamp;
INSERT INTO complex_test VALUES ('https://test.com', '2023-01-01 12:00:00'), ('http://test.com/file', '2023-01-02 12:00:00');
SELECT base64URLEncode(url) AS encoded_url, timestamp FROM complex_test ORDER BY timestamp DESC;