CREATE TABLE user_roles (user_id UInt32, role String, active UInt8);
INSERT INTO user_roles VALUES (1, 'admin', 1), (2, 'editor', 1), (3, 'viewer', 0);
SELECT user_id, defaultRoles() AS roles FROM user_roles WHERE active = 1;
SELECT user_id, (defaultRoles() - array('admin')) AS restricted_roles FROM user_roles WHERE active = 1;
SELECT user_id, (SELECT defaultRoles() FROM user_roles WHERE user_id = 1) - array('viewer') AS filtered_roles FROM user_roles;
SELECT user_id, count() as role_count FROM user_roles GROUP BY user_id HAVING role_count > 0;
SELECT user_id, (defaultRoles() - array(toString(role))) AS modified_roles FROM user_roles WHERE toUint32(user_id) - 1 = 1;
CREATE TABLE temp_roles AS SELECT (defaultRoles() - array('editor')) AS limited_roles FROM user_roles;
INSERT INTO temp_roles SELECT defaultRoles() FROM user_roles WHERE role = 'admin';
SELECT user_id, (defaultRoles() - array(toNullable(role))) AS null_handled_roles FROM user_roles WHERE role IS NOT NULL;
CREATE TABLE complex_data (id UInt32, value String);
INSERT INTO complex_data VALUES (1, 'High'), (2, 'Medium'), (3, 'Low');
SELECT d.id, (SELECT count() FROM user_roles WHERE role = d.value) AS role_matches FROM complex_data d WHERE d.value IN (defaultRoles());
SELECT user_id, (defaultRoles() - array('admin')) AS user_reduced_roles FROM user_roles JOIN (SELECT distinct value FROM complex_data) AS d ON user_roles.role = d.value;
SELECT user_id, (defaultRoles() - array(toString(max(user_id)))) AS role_with_boundary FROM user_roles GROUP BY user_id HAVING role_with_boundary IS NOT NULL;
ALTER TABLE user_roles ADD COLUMN extra_role String;
INSERT INTO user_roles SELECT user_id, defaultRoles() - array('viewer'), active FROM user_roles WHERE active = 1;