CREATE DATABASE db_test;
CREATE TABLE db_test.id_val(`id` UInt32, `val` UInt32) ENGINE = Join(ANY, LEFT, id);
INSERT INTO db_test.id_val VALUES (1, 11), (2, 12), (4, 13);
SELECT number, joinGetOrNull(db_test.id_val, 'val', toUInt32(number)) FROM numbers(6);
SELECT toUInt32(number) AS key, joinGetOrNull(db_test.id_val, 'val', toUInt32(number)) AS value FROM numbers(10);
CREATE TABLE db_test.secondary_values(`key` UInt32, `description` String) ENGINE=Memory;
INSERT INTO db_test.secondary_values VALUES (1, 'first'), (2, 'second'), (3, 'third');
SELECT sv.key, sv.description, joinGetOrNull(db_test.id_val, 'val', sv.key) FROM db_test.secondary_values AS sv;
WITH (SELECT number FROM numbers(4)) AS keys SELECT keys.number, joinGetOrNull(db_test.id_val, 'val', toUInt32(keys.number)) FROM keys;
SELECT number, joinGetOrNull(db_test.id_val, 'val', toUInt32(number)) AS joined_val FROM numbers(4) WHERE number < 3;
CREATE TABLE db_test.final_results(`num` UInt32, `join_val` UInt32) ENGINE=Memory;
INSERT INTO db_test.final_results SELECT number, joinGetOrNull(db_test.id_val, 'val', number) FROM numbers(5);
SELECT fr.num, fr.join_val, IF(fr.join_val IS NULL, 'No Value', 'Value Exists') AS status FROM db_test.final_results AS fr;
SELECT number, joinGetOrNull(db_test.id_val, 'val', toUInt32(number + 1)) AS incremented_val FROM numbers(8);
CREATE TABLE db_test.all_keys(`num` UInt32) ENGINE=Memory;
INSERT INTO db_test.all_keys SELECT number FROM numbers(10);
SELECT ak.num, joinGetOrNull(db_test.id_val, 'val', ak.num) AS results FROM db_test.all_keys AS ak LEFT JOIN db_test.id_val AS j ON ak.num = j.id;