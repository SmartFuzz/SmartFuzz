CREATE TABLE h3_indices (index UInt64);
INSERT INTO h3_indices VALUES (644721767722457330), (644721767722457331), (644721767722457332);
SELECT index, h3IsPentagon(index) AS is_pentagon FROM h3_indices;
WITH (SELECT index FROM h3_indices WHERE index < 644721767722457340) AS valid_indices SELECT index, h3IsPentagon(index) AS is_pentagon FROM valid_indices;
SELECT h3IsPentagon(index) FROM (SELECT index FROM h3_indices WHERE index > 644721767722457329) AS subquery;
CREATE TABLE additional_indices (index UInt64);
INSERT INTO additional_indices VALUES (644721767722457340), (644721767722457341);
SELECT a.index, h3IsPentagon(a.index) AS is_pentagon FROM h3_indices AS a JOIN additional_indices AS b ON a.index < b.index;
SELECT toString(h3IsPentagon(index)) AS result FROM (SELECT index FROM h3_indices) HAVING result = '1';
WITH (SELECT index FROM h3_indices WHERE h3IsPentagon(index) = 1) AS pentagons SELECT COUNT(*) FROM pentagons;