CREATE TABLE filesystem_test (id UInt32, available_space UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO filesystem_test VALUES (1, filesystemAvailable()), (2, filesystemAvailable());
SELECT id, formatReadableSize(available_space) AS 'Available Space' FROM filesystem_test;
SELECT id, available_space FROM filesystem_test WHERE available_space < (SELECT AVG(available_space) FROM filesystem_test);
SELECT id, formatReadableSize(filesystemAvailable() + available_space) AS 'Total Available' FROM filesystem_test;
SELECT MAX(available_space) AS 'Max Available Space' FROM filesystem_test WHERE available_space > 0;
SELECT id FROM filesystem_test WHERE available_space IN (SELECT available_space FROM filesystem_test WHERE available_space IS NOT NULL);
WITH (SELECT filesystemAvailable()) AS disk_space, (SELECT COUNT(*) FROM filesystem_test) AS total_count SELECT disk_space, total_count;
CREATE TABLE sub_filesystem_test AS SELECT id, filesystemAvailable() AS available_space FROM filesystem_test WHERE available_space > 0;
SELECT DISTINCT A.id FROM filesystem_test AS A JOIN sub_filesystem_test AS B ON A.available_space = B.available_space WHERE A.id < B.id;