CREATE TABLE test_tuples (a Tuple(int, int), b Tuple(int, int));
INSERT INTO test_tuples VALUES ((1, 2), (2, 3));
SELECT tupleDivide(a, b) FROM test_tuples;
INSERT INTO test_tuples VALUES ((5, 10), (0, 5));
SELECT tupleDivide(a, b) FROM test_tuples WHERE a.1 > 0;
INSERT INTO test_tuples VALUES ((10, 20), (5, 0));
SELECT tupleDivide(a, b) FROM test_tuples WHERE b.2 = 0;
CREATE TABLE t2 (x Tuple(int, int), y Tuple(int, int));
INSERT INTO t2 VALUES ((2, 4), (2, 1));
SELECT tupleDivide(t1.a, t2.y) FROM test_tuples t1 JOIN t2 ON t1.a.1 = t2.x.1;
SELECT tupleDivide((10, 20), (5, 5));
SELECT tupleDivide((1, 0), (0, 0));
SELECT tupleDivide((NULL, 2), (2, 1));
SELECT tupleDivide((7, 14), (7, 0));
SELECT tupleDivide((1, 2), (2, NULL));