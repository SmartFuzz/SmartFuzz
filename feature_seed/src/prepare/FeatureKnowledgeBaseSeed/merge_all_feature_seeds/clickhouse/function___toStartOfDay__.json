CREATE TABLE test_dates (event_time DateTime) ENGINE = Memory;
INSERT INTO test_dates VALUES ('2023-04-21 10:20:30'), ('2023-04-21 23:59:59'), ('2023-04-22 00:00:00'), ('2023-04-22 15:45:00');
SELECT toStartOfDay(event_time) FROM test_dates;
SELECT toStartOfDay(toDateTime('2023-05-01 08:00:00')) AS start_of_day;
SELECT toStartOfDay(toDateTime('2020-12-31 23:59:59')) AS start_of_2020_new_year_eve;
SELECT toStartOfDay(toDateTime('1970-01-01 01:01:01')) AS start_of_epoch;
SELECT toStartOfDay(toDateTime('9999-12-31 23:59:59')) AS end_of_known_time;
SELECT t1.event_time, toStartOfDay(t1.event_time) AS start_of_day FROM test_dates t1 WHERE toStartOfDay(t1.event_time) = '2023-04-21 00:00:00';
CREATE TABLE events (event_id UInt32, event_time DateTime) ENGINE = MergeTree() ORDER BY event_id;
INSERT INTO events VALUES (1, '2023-01-01 12:00:00'), (2, '2023-01-02 18:30:45'), (3, '2023-01-03 00:00:01');
SELECT event_id, toStartOfDay(event_time) AS event_start FROM events WHERE event_start >= '2023-01-01 00:00:00' AND event_start < '2023-01-04 00:00:00';
SELECT AVG(toStartOfDay(event_time)) FROM events GROUP BY toStartOfDay(event_time);
SELECT '2023-06-15' AS date_str, toStartOfDay(toDateTime(date_str)) AS start_of_day;
SELECT t1.event_time, t2.additional_time, toStartOfDay(t1.event_time) AS start_of_day FROM test_dates t1 JOIN test_dates t2 ON toStartOfDay(t1.event_time) = toStartOfDay(t2.event_time) WHERE t1.event_time > '2023-04-20 00:00:00';