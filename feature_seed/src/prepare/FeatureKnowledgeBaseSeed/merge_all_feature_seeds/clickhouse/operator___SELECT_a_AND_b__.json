CREATE TABLE test_table (a UInt8, b UInt8);
INSERT INTO test_table VALUES (1, 1), (1, 0), (0, 1), (0, 0);
SELECT a AND b FROM test_table;
SELECT a, b, a AND b AS logical_conjunction FROM test_table;
CREATE TABLE secondary_table (x UInt8, y UInt8);
INSERT INTO secondary_table VALUES (1, 1), (0, 0);
SELECT t.a, t.b, s.x, s.y, t.a AND t.b AS conjunction FROM test_table t JOIN secondary_table s ON t.a = s.x;
SELECT (SELECT a FROM test_table WHERE b = 1) AND (SELECT b FROM test_table WHERE a = 1);
WITH (SELECT COUNT() FROM test_table) AS cnt SELECT a AND b, cnt FROM test_table;
SELECT IF(a = 1, b, 0) AND IF(b = 1, a, 0) AS combined FROM test_table;
SELECT a, b, (SELECT COUNT() FROM test_table WHERE a = 1 AND b = 1) AS count FROM test_table;