CREATE TABLE test_unbin (binary_string String);
INSERT INTO test_unbin VALUES ('00110000'), ('00110001'), ('01000001'), ('11010101');
SELECT UNBIN(binary_string) FROM test_unbin;
SELECT UNBIN('11111111') AS result;
SELECT UNBIN('00011111') AS result;
SELECT UNBIN('00101010') AS result FROM test_unbin WHERE binary_string = '00110000';
SELECT reinterpretAsUInt8(UNBIN(binary_string)) AS num FROM test_unbin;
SELECT UNBIN('001101000110010101110010') AS result;
SELECT UNBIN('1100101010110000') AS bin_result, UNBIN('1101001110110001') AS bin_result2;
SELECT UNBIN('0100100001100101011011000110110001101111') AS hello_bin;
SELECT reinterpretAsUInt64(reverse(UNBIN('11111111'))) AS num;
SELECT (SELECT UNBIN('10101010')) + (SELECT UNBIN('01010101')) AS combined_result;
WITH (SELECT UNBIN('010110010110010101110011')) AS alias_result SELECT alias_result AS final_result;
CREATE TABLE binary_tests (id UInt32, bin_value String);
INSERT INTO binary_tests VALUES (1, '00000001'), (2, '00000010'), (3, '00000011');
SELECT id, UNBIN(bin_value) FROM binary_tests WHERE id IN (1, 2);
SELECT UNBIN('1010101010000000') AS result FROM (SELECT '1010101010000000' AS val) AS tmp;
SELECT UNBIN('') AS empty_result;
SELECT UNBIN('012') AS invalid_result;
SELECT UNBIN('1111000011110000'), UNBIN('0000111100001111') AS multiple_results;