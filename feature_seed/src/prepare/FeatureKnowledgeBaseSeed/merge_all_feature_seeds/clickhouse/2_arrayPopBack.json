CREATE TABLE test_arrays (id UInt32, values Array(Int32), str_value String);
INSERT INTO test_arrays VALUES (1, [1, 2, 3, NULL], 'test1'), (2, [4, 5, 6], 'test2'), (3, [], 'test3');
SELECT arrayPopBack(values) AS last_value, id FROM test_arrays WHERE arrayPopBack(values) = 5;
SELECT id, arrayPopBack(values) = (SELECT max(number) FROM (SELECT number FROM numbers(10) WHERE number < 7)) AS valid_last_value FROM test_arrays;
SELECT id, values, arrayPopBack(values) AS modified_values FROM test_arrays WHERE modified_values IS NULL;
SELECT id, arrayPopBack(values) AS popped_values FROM test_arrays GROUP BY id HAVING popped_values = 2 OR popped_values IS NULL;
SELECT id, arrayPopBack(NULLIF(values, [])) AS popped_values FROM test_arrays;
SELECT id, arrayPopBack(arrayRepeat('1000', 5)) AS repeated_values FROM test_arrays WHERE repeated_values = 1000;
SELECT y.id, y.values, arrayPopBack(y.values) AS modified_values FROM test_arrays AS y JOIN (SELECT id FROM test_arrays WHERE id = 1) AS x ON y.id = x.id;
SELECT id, arrayPopBack(values) AS last_elem FROM test_arrays WHERE last_elem IS NOT NULL AND id = (SELECT max(id) FROM test_arrays);