CREATE TABLE test_values (input String);
INSERT INTO test_values VALUES ('-64'), ('abc'), ('100'), ('3.14'), ('0xc0fe'), ('9223372036854775807'), ('-9223372036854775808'), ('inf'), ('nan');
SELECT toInt64OrZero(input) FROM test_values;
SELECT input, toInt64OrZero(input) AS converted FROM test_values WHERE converted = 0;
SELECT toInt64OrZero('12345678901234567890'), toInt64OrZero('-12345678901234567890');
SELECT toInt64OrZero('10000000000000000000') + 1 AS overflow_test;
WITH (SELECT toInt64OrZero(input) FROM test_values) AS converted_values SELECT AVG(converted_values) FROM converted_values;
CREATE TABLE t1 (value String);
INSERT INTO t1 VALUES ('1'), ('1.5'), ('-1.5'), ('1000');
SELECT value, toInt64OrZero(value) FROM t1 WHERE toInt64OrZero(value) > 0;
SELECT toInt64OrZero('256'), toInt64OrZero('0xffffffff'), toInt64OrZero('3e2'), toInt64OrZero('NaN') FROM t1;
SELECT toInt64OrZero('128'), MAX(toInt64OrZero(value)) FROM t1;
SELECT CASE WHEN toInt64OrZero('abc') = 0 THEN 'Conversion failed' ELSE 'Conversion succeeded' END AS conversion_status;
SELECT input, toInt64OrZero(input) AS converted FROM test_values GROUP BY input HAVING converted > 0 ORDER BY converted DESC;