CREATE TABLE datetime_tests (id UInt32, datetime_string String) ENGINE = Log;
INSERT INTO datetime_tests VALUES (1, '2023-10-01 12:00:00.123456789'), (2, 'invalid date'), (3, '2023-10-01 25:00:00'), (4, '2023-02-29 00:00:00'), (5, '2021-01-01T12:00:00'), (6, '');
SELECT id, parseDateTime64BestEffortOrZero(datetime_string, 9) AS datetime_parsed FROM datetime_tests;
WITH (SELECT datetime_string FROM datetime_tests WHERE id = 2) AS invalid_date_string SELECT parseDateTime64BestEffortOrZero(invalid_date_string, 9) AS datetime_parsed;
SELECT id, parseDateTime64BestEffortOrZero(datetime_string, 6) as datetime_parsed FROM datetime_tests WHERE id IN (1, 3);
CREATE TABLE valid_dates AS SELECT datetime_string FROM datetime_tests WHERE parseDateTime64BestEffortOrZero(datetime_string, 9) != 0;
SELECT AVG(datetime_parsed) FROM (SELECT parseDateTime64BestEffortOrZero(datetime_string, 9) AS datetime_parsed FROM datetime_tests) WHERE datetime_parsed != 0;
INSERT INTO datetime_tests VALUES (7, '2020-02-29 12:00:00');
CREATE TABLE failed_parses AS SELECT id, datetime_string FROM datetime_tests WHERE parseDateTime64BestEffortOrZero(datetime_string, 9) = 0;
SELECT A.id, parseDateTime64BestEffortOrZero(A.datetime_string, 9) AS parsed FROM datetime_tests AS A JOIN failed_parses AS B ON A.id = B.id;