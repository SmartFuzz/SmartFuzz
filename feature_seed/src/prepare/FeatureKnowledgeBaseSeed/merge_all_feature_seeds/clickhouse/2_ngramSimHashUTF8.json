CREATE TABLE test_strings (id UInt32, string_value String);
INSERT INTO test_strings VALUES (1, 'ClickHouse is great!'), (2, NULL), (3, 'The quick brown fox jumps over the lazy dog.');
SELECT ngramSimHashUTF8(string_value) AS simhash FROM test_strings WHERE string_value IS NOT NULL;
SELECT a.id, ngramSimHashUTF8(a.string_value, 2) * 100 AS hash_multiplied FROM test_strings AS a JOIN test_strings AS b ON ngramSimHashUTF8(a.string_value) = ngramSimHashUTF8(b.string_value) WHERE a.id != b.id;
SELECT id, ngramSimHashUTF8(string_value, 1) AS ngram_hash FROM test_strings GROUP BY id, ngram_hash HAVING ngram_hash > 0;
SELECT id, ngramSimHashUTF8(string_value) AS hash_value FROM test_strings WHERE ngramSimHashUTF8(string_value) IS NOT NULL;
SELECT id, ngramSimHashUTF8(string_value, 3) * (SELECT COUNT(*) FROM test_strings) AS final_hash FROM test_strings;
CREATE TABLE test_edges (id UInt32, numeric_value Float64, string_value Nullable(String));
INSERT INTO test_edges VALUES (1, 3.14, 'Edge case!'), (2, NULL, 'Test'), (3, 0.0, 'Zero value!');
SELECT id, ngramSimHashUTF8(string_value) * numeric_value AS result FROM test_edges WHERE string_value IS NOT NULL OR numeric_value > 1.0;
SELECT id, ngramSimHashUTF8(string_value) AS sim_hash, (SELECT COUNT(*) FROM test_edges) * 2 FROM test_edges GROUP BY id, sim_hash HAVING sim_hash IS NOT NULL;
WITH (SELECT ngramSimHashUTF8(string_value) FROM test_strings) AS subquery_hashes SELECT * FROM subquery_hashes WHERE simhash IS NOT NULL;
WITH (SELECT ngramSimHashUTF8('') AS empty_hash) SELECT empty_hash * 0;
CREATE TEMPORARY TABLE temp_join (id UInt32, ref UInt32);
INSERT INTO temp_join VALUES (1, 1), (2, 2);
SELECT t.id, ngramSimHashUTF8(ts.string_value, 5) * t.ref FROM temp_join AS t LEFT JOIN test_strings AS ts ON t.ref = ts.id;
SELECT ngramSimHashUTF8(COALESCE(string_value, 'default')) AS coalesced_hash FROM test_strings;