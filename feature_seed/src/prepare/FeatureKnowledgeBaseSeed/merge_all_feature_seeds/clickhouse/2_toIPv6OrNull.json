CREATE TABLE test_ips (ip_string String, ip_invalid_reason String);
INSERT INTO test_ips VALUES ('127.0.0.1.6', 'Invalid IPv4 format'), ('2001:0db8:85a3:0000:0000:8a2e:0370:7334', 'Valid IPv6'), ('invalid_ip_address', 'Invalid format');
SELECT ip_string, toIPv6OrNull(ip_string) AS ipv6_converted FROM test_ips WHERE toIPv6OrNull(ip_string) NOT LIKE '2001:0db8:%';
SELECT ip_string, (CASE WHEN toIPv6OrNull(ip_string) IS NULL THEN 'NULL' ELSE toIPv6OrNull(ip_string) END) AS ipv6_status FROM test_ips;
WITH (SELECT COUNT() AS total_count FROM test_ips WHERE toIPv6OrNull(ip_string) IS NULL) AS null_count SELECT ip_string, toIPv6OrNull(ip_string) FROM test_ips WHERE (total_count NOT LIKE '0' AND ip_string NOT LIKE 'invalid%') ORDER BY ip_string;
CREATE TABLE test_edges (num_column Int32, text_column String, const_column UInt32 DEFAULT 100, name_column String);
INSERT INTO test_edges VALUES (1, 'Valid entry', 100, 'Alice'), (2, 'Invalid entry', 100, 'Bob'), (3, '', 101, 'Charlie'), (4, 'edge case', NULL, NULL);
SELECT name_column, toIPv6OrNull(text_column) AS ipv6_from_text FROM test_edges WHERE num_column NOT LIKE 2 AND (text_column NOT LIKE 'Valid%') GROUP BY name_column HAVING COUNT() > 1;
(SELECT COUNT() AS valid_count FROM test_ips WHERE toIPv6OrNull(ip_string) IS NOT NULL) UNION ALL (SELECT COUNT() AS invalid_count FROM test_ips WHERE toIPv6OrNull(ip_string) IS NULL);
SELECT text_column, toIPv6OrNull(text_column) NOT LIKE '2001:%' AS is_not_valid FROM test_edges WHERE text_column IS NOT NULL AND num_column NOT LIKE 1 ORDER BY num_column DESC;
DROP TABLE test_ips;
DROP TABLE test_edges;