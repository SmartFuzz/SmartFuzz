CREATE TABLE test_data (id UInt32, value String, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_data VALUES (1, '100'), (2, '200'), (3, NULL), (4, '300'), (5, 'string'), (6, '0'), (7, '');
SELECT formatRowNoNewline('CSV', id, value, (SELECT COUNT(*) FROM test_data WHERE value NOT IN (SELECT value FROM test_data WHERE value IS NOT NULL))) FROM test_data GROUP BY id HAVING id NOT IN (SELECT id FROM test_data WHERE value IS NOT NULL) ORDER BY id;
SELECT formatRowNoNewline('TSV', id, value) FROM test_data WHERE value NOT IN (SELECT value FROM test_data WHERE created_at IS NULL) LIMIT 5;
SELECT formatRowNoNewline('CSV', id, value) FROM (SELECT id, value FROM test_data WHERE value NOT IN (SELECT value FROM test_data WHERE id > 3)) AS subquery WHERE id <= (SELECT MAX(id) FROM test_data WHERE value NOT IN ('string')) ORDER BY value;