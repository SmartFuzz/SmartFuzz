CREATE TABLE test_table (id Int32, value String, sample_key Int32) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE sampled_table (id Int32, value String, sample_key Int32) ENGINE = MergeTree() ORDER BY id SAMPLE BY sample_key;
ALTER TABLE test_table MODIFY SAMPLE BY value;
ALTER TABLE sampled_table REMOVE SAMPLE BY;
SELECT * FROM test_table SAMPLE BY sample_key;
SELECT id, value FROM test_table SAMPLE BY sample_key ORDER BY id;
INSERT INTO test_table (id, value, sample_key) VALUES (1, 'test', 1);
INSERT INTO test_table (id, value, sample_key) VALUES (2, 'fuzz', 2);
ALTER TABLE test_table MODIFY SAMPLE BY (sample_key, id);
SELECT * FROM test_table SAMPLE BY (sample_key, id);
ALTER TABLE test_table REMOVE SAMPLE BY;
SELECT * FROM (SELECT id, value FROM test_table WHERE sample_key = 1) AS subquery SAMPLE BY sample_key;
CREATE TABLE another_table (id Int32, value String, sample_key Int32) ENGINE = MergeTree() ORDER BY id SAMPLE BY (sample_key);
SELECT a.id, b.value FROM test_table AS a JOIN another_table AS b ON a.sample_key = b.sample_key SAMPLE BY a.sample_key;
ALTER TABLE another_table MODIFY SAMPLE BY (value, sample_key);
INSERT INTO another_table (id, value, sample_key) VALUES (3, 'sample', 1);
SELECT id FROM sampled_table WHERE id IN (SELECT id FROM another_table SAMPLE BY sample_key) SAMPLE BY sample_key;