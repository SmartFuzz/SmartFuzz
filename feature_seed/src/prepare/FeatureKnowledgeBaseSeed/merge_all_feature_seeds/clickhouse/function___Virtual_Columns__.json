CREATE TABLE files (id UInt32, _path LowCardinality(String), _file LowCardinality(String), _size Nullable(UInt64), _time Nullable(DateTime));
INSERT INTO files VALUES (1, '/home/user/file1.txt', 'file1.txt', 2048, '2023-10-01 10:00:00'), (2, '/home/user/archive.zip::file2.txt', 'file2.txt', 1048576, NULL), (3, '/home/user/.hidden/file3.log', 'file3.log', NULL, '2023-09-28 15:30:00');
SELECT _path, _file, _size, _time FROM files WHERE _size IS NOT NULL;
SELECT COUNT(*) FROM files WHERE _time >= '2023-09-01' AND _time <= '2023-10-01';
SELECT _file, SUM(_size) AS total_size FROM files GROUP BY _file HAVING total_size > 1024;
SELECT f1._path, f2._file FROM files AS f1 JOIN files AS f2 ON f1.id = f2.id WHERE f1._size IS NOT NULL AND f2._size IS NULL;
WITH (SELECT AVG(_size) FROM files) AS avg_size SELECT _path, _file FROM files WHERE _size > avg_size;
SELECT _path, _file FROM files WHERE _path LIKE '%.zip' AND _size IS NOT NULL ORDER BY _size DESC;
CREATE TABLE hidden_files (id UInt32, _path LowCardinality(String), _file LowCardinality(String), _size Nullable(UInt64), _time Nullable(DateTime));
INSERT INTO hidden_files SELECT * FROM files WHERE _path LIKE '%.log';
SELECT COUNT(DISTINCT _path) FROM hidden_files;
SELECT _file, COUNT(*) AS occurrence FROM files GROUP BY _file HAVING occurrence > 1 ORDER BY occurrence DESC;