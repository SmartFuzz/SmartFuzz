CREATE TABLE test_plus (id UInt32, value_a Int32, value_b Int32, date_value Date, datetime_value DateTime);
INSERT INTO test_plus VALUES (1, 5, 10, '2023-01-01', '2023-01-01 12:00:00');
INSERT INTO test_plus VALUES (2, -3, 4, '2023-06-15', '2023-06-15 08:30:00');
INSERT INTO test_plus VALUES (3, 0, 0, '2023-12-31', '2023-12-31 23:59:59');
SELECT plus(value_a, value_b) AS total_sum FROM test_plus WHERE id = 1;
SELECT plus(date_value, 10) AS incremented_date FROM test_plus WHERE id = 2;
SELECT plus(datetime_value, 3600) AS incremented_datetime FROM test_plus WHERE id = 3;
SELECT a.id, plus(a.value_a, b.value_b) AS combined_sum FROM test_plus AS a JOIN test_plus AS b ON a.id <> b.id;
WITH (SELECT plus(value_a, value_b) FROM test_plus WHERE id = 1) AS sum_value SELECT plus(sum_value, 100) AS final_result;
SELECT id, plus(value_a, 5) AS added_value, plus(date_value, 30) AS new_date FROM test_plus WHERE value_a >= 0;
SELECT id, plus(datetime_value, 7200) AS new_time FROM test_plus WHERE datetime_value < '2023-07-01 00:00:00';