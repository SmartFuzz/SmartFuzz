CREATE TABLE test_table (id Int32, num_value Float64, div_value Float64);
INSERT INTO test_table VALUES (1, 5.5, 2.0), (2, 10.0, 0.0), (3, 15.2, NULL), (4, 3.3, 1.1);
SELECT id, tupleIntDivOrZero((num_value, num_value * 2), (div_value, div_value + 1)) AS result FROM test_table;
SELECT id, num_value, div_value, tupleIntDivOrZero((num_value, div_value), (0, div_value)) FROM test_table WHERE div_value IS NOT NULL;
SELECT id, AVG(result) AS avg_result FROM (SELECT id, tupleIntDivOrZero((num_value + 1, num_value * 3), (div_value - 1, div_value + 2)) AS result FROM test_table) GROUP BY id HAVING avg_result > 0;
CREATE TABLE temp_table (temp_num String, temp_div String);
INSERT INTO temp_table VALUES ('10', '2'), ('15', '0'), ('NULL', '3'), ('5', NULL);
SELECT tupleIntDivOrZero((CAST(temp_num AS Float64), CAST(temp_div AS Float64)), (1, CAST(temp_div AS Float64))) FROM temp_table;
SELECT id, tupleIntDivOrZero((num_value, CAST(NULL AS Float64)), (2, div_value)) FROM test_table;
SELECT id, tupleIntDivOrZero((num_value * div_value, num_value + div_value), (div_value, 0)) AS results FROM test_table WHERE (num_value * div_value) > 1;
SELECT id, COUNT(*) AS total FROM (SELECT DISTINCT id, tupleIntDivOrZero((num_value, 10), (div_value, 0)) AS div_result FROM test_table) GROUP BY id HAVING total > 0;