CREATE TABLE test_table (value String, id UInt64) ENGINE = Memory;
INSERT INTO test_table VALUES ('100', 1), ('-255.5', 2), ('abc', 3), (NULL, 4), ('0xe', 5), (Inf, 6), (NaN, 7);
SELECT id, toUInt256OrDefault(value, CAST('0', 'UInt256')) AS converted_value FROM test_table WHERE id = ALL (SELECT id FROM test_table WHERE value IS NOT NULL);
SELECT id, COUNT(*) AS count_valid FROM (SELECT id, toUInt256OrDefault(value, CAST('0', 'UInt256')) AS converted_value FROM test_table GROUP BY id HAVING converted_value >= 0) GROUP BY id HAVING count_valid > 0;
SELECT t1.id, toUInt256OrDefault(t1.value, CAST('0', 'UInt256')) FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t2.value = ALL (SELECT value FROM test_table WHERE id > 3) AND t1.value LIKE '%' || t2.value || '%';
CREATE TABLE temp_table (val Float64, ref UInt64) ENGINE = Memory;
INSERT INTO temp_table VALUES (NULL, 1), (Inf, 2), (NaN, 3), (1.5, 4);
SELECT ref, toUInt256OrDefault(CAST(val AS String), CAST('0', 'UInt256')) FROM temp_table WHERE ref = ALL (SELECT ref FROM temp_table WHERE val IS NOT NULL);
SELECT COUNT(*) FROM (SELECT toUInt256OrDefault(CASE WHEN value = '' THEN '0' ELSE value END, CAST('0', 'UInt256')) FROM test_table) AS subquery;
SELECT id, MAX(toUInt256OrDefault(value, CAST('0', 'UInt256'))) AS max_converted FROM test_table GROUP BY id HAVING max_converted > 5;