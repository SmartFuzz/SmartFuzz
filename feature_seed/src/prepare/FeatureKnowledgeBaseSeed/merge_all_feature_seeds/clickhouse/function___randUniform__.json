CREATE TABLE test_random (id Int32, value Float64);
INSERT INTO test_random VALUES (1, randUniform(1.0, 10.0)), (2, randUniform(2.0, 8.0));
SELECT id, value FROM test_random WHERE value BETWEEN 1.0 AND 10.0;
SELECT id, randUniform(1.0, value) AS random_value FROM test_random;
CREATE TABLE numbers_table AS SELECT number FROM numbers(100);
SELECT number, randUniform(1.0, 5.0) AS random_val FROM numbers_table;
WITH (SELECT randUniform(5.0, 10.0)) AS min_max FROM numbers(1) UNION ALL SELECT 1, randUniform(5.0, 10.0);
SELECT number, (SELECT randUniform(1.0, 10.0) FROM numbers_table WHERE number < 50) AS random_val FROM numbers_table;
SELECT a.id, randUniform(a.value, b.value) AS random_range_value FROM test_random a JOIN test_random b ON a.id != b.id;
CREATE TABLE rand_test (min_val Float64, max_val Float64);
INSERT INTO rand_test VALUES (5.5, 10.0), (0.0, 2.0);
SELECT min_val, max_val, randUniform(min_val, max_val) AS random_value FROM rand_test;
SELECT id, randUniform(0.0, 0.0) AS constant_random_value FROM numbers(5);
SELECT id, randUniform(-1.0, 1.0) AS negative_random_val FROM numbers(10);
CREATE TABLE complex_rand AS SELECT number, randUniform(1.0, number) AS random_val FROM numbers(10);
SELECT AVG(random_val) FROM complex_rand;
SELECT COUNT(*) FROM test_random WHERE value > randUniform(0.0, 20.0);
SELECT number, randUniform(0.0, 100.0) AS high_random FROM numbers(10) ORDER BY high_random DESC;
SELECT randUniform(value, 10.0) AS variable_random_value FROM (SELECT value FROM test_random WHERE id = 1);