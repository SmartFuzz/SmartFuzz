CREATE TABLE bit_test (a UInt32, b UInt8);
INSERT INTO bit_test VALUES (1, 1), (2, 2), (3, 3), (4, 4), (15, 4), (32, 3), (4294967295, 1);
SELECT bitRotateRight(a, b) FROM bit_test;
SELECT a, bitRotateRight(a, b) AS rotated FROM bit_test WHERE b <= 8;
SELECT bitRotateRight(a, (SELECT MAX(b) FROM bit_test)) AS rotated_value FROM bit_test;
WITH (SELECT COUNT(*) FROM bit_test) AS total_entries SELECT bitRotateRight(a, b) FROM bit_test WHERE total_entries > 0;
CREATE TABLE another_table AS SELECT bitRotateRight(a, b) AS rotated_value FROM bit_test WHERE a > 1;
SELECT b, COUNT(*) FROM (SELECT bitRotateRight(a, b) AS rotated FROM bit_test GROUP BY rotated) AS subquery GROUP BY b;
CREATE TABLE joined_test (id UInt32, value UInt32);
INSERT INTO joined_test VALUES (1, 10), (2, 20), (3, 30);
SELECT jt.id, bitRotateRight(bt.a, bt.b) AS rotated_value FROM bit_test AS bt JOIN joined_test AS jt ON bt.a = jt.value;
SELECT SUM(bitRotateRight(a, b)) AS total FROM bit_test GROUP BY b HAVING total > 0;