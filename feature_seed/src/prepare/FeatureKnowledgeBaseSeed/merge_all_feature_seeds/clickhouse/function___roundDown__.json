CREATE TABLE test_roundDown (num Float64);
INSERT INTO test_roundDown VALUES (0), (1), (2), (3), (4), (5), (6.5), (7.3), (-1), (-2);
SELECT num, roundDown(num, [3, 4, 5]) AS rounded FROM test_roundDown;
SELECT num, roundDown(num, [1, 5, 10]) AS rounded FROM test_roundDown;
SELECT num, roundDown(num, [0, 3, 6]) AS rounded FROM test_roundDown WHERE num >= -1;
SELECT num, roundDown(num, [10, 20, 30]) AS rounded FROM test_roundDown WHERE num < 10;
SELECT num, roundDown(num, [1.5, 2.5, 3.5]) AS rounded FROM test_roundDown WHERE num > 0;
SELECT *, roundDown(num, (SELECT arrayJoin([2, 4, 6, 8]) FROM system.numbers LIMIT 1)) AS rounded FROM test_roundDown;
SELECT A.num, roundDown(A.num, B.arr) AS rounded FROM test_roundDown AS A JOIN (SELECT arrayJoin([1, 3, 5]) AS arr) AS B ON A.num > 0;
SELECT num, roundDown(num, arrayJoin([0, 1, 2])) AS rounded FROM test_roundDown WHERE num <= 3;
CREATE TABLE additional_test ROUND_DOWN_TEST (value Float64);
INSERT INTO additional_test VALUES (8.2), (9.1), (2.5), (0.3), (4.7);
SELECT value, roundDown(value, [1, 5, 10]) AS rounded FROM additional_test WHERE value > 0;
SELECT value, roundDown(value, (SELECT arrayJoin([2.5, 5.0]) FROM system.numbers LIMIT 1)) AS rounded FROM additional_test;