CREATE TABLE test_or (val1 UInt8, val2 UInt8, val3 Nullable(UInt8));
INSERT INTO test_or VALUES (1, 0, NULL), (0, 0, NULL), (0, 1, 1), (0, 0, 0), (1, 1, NULL);
SELECT or(val1, val2) FROM test_or;
SELECT or(val1, val2, val3) FROM test_or;
SELECT or(1, or(0, 2));
SELECT or(1, 0, 0) AS result;
SELECT or(NULL, NULL) AS result;
SELECT or(1, 0, NULL) FROM test_or;
SELECT or(0, 1, 1) FROM test_or WHERE val1 = 0;
SELECT or(number > 0, intDiv(1, number) != 0) FROM numbers(5);
SELECT or((SELECT count() FROM test_or WHERE val1 = 1) > 0, (SELECT count() FROM test_or WHERE val2 = 1) > 0);
SELECT or(val1 = 1, (SELECT max(val2) FROM test_or)) FROM test_or WHERE val3 IS NOT NULL;
SELECT or(val1 = 1, val2 = 1) FROM (SELECT 1 AS val1, 0 AS val2 UNION ALL SELECT 0 AS val1, 1 AS val2) AS sub;
SELECT or((SELECT count() FROM test_or WHERE val1 = 0), (SELECT count() FROM test_or WHERE val2 = 1)) AS overall_result;
SELECT or(0, or(0, or(1, NULL))) AS final_result;