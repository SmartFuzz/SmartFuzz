CREATE TABLE test_table (id UInt32, arr_arr Array(UInt32), name String, created_at DateTime DEFAULT now());
INSERT INTO test_table VALUES (1, [1, 2, 3], 'test1', '2023-01-01 10:00:00');
INSERT INTO test_table VALUES (2, [], 'test2', '2023-01-02 10:00:00');
INSERT INTO test_table VALUES (3, [4, 5], 'test3', '2023-01-03 10:00:00');
SELECT id, empty(arr_arr || []) AS is_empty FROM test_table WHERE created_at > '2023-01-01 00:00:00' GROUP BY id HAVING is_empty = 1;
SELECT id, empty(arr_arr || ['a']) AS is_empty, name FROM test_table WHERE id IN (SELECT id FROM test_table WHERE empty(arr_arr) = 0) ORDER BY is_empty DESC;
SELECT a.id, empty(a.arr_arr || b.arr_arr) AS combined_empty FROM test_table AS a JOIN (SELECT id, arr_arr FROM test_table WHERE id > 1) AS b ON a.id = b.id;
SELECT id, arr_arr, empty(arr_arr) AS arr_empty FROM test_table ORDER BY arr_empty DESC LIMIT 10;
SELECT id, empty(arr_arr) AS is_empty, name || toString(created_at) AS name_with_date FROM test_table WHERE is_empty = 1 ORDER BY name_with_date;
SELECT DISTINCT id, empty(arr_arr || arrayJoin([NULL])) AS combined_empty FROM test_table WHERE NOT is_empty;