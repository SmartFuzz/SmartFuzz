CREATE TABLE test_strings (id UInt32, text String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'example'), (2, 'test'), (3, ''), (4, NULL), (5, 'fuzzy testing');
SELECT id, substring(text, 1) AS full_text, substring(text, -2, 1) AS last_char FROM test_strings;
SELECT id, (substring(text, 1) = '') AS is_empty FROM test_strings WHERE text IS NOT NULL;
SELECT id, (text, substring(text, 1, 4)) AS tuple_result FROM test_strings;
SELECT id, substring((text, 'processed'), 1) AS combined_text FROM test_strings;
SELECT id, COUNT(*) AS count_per_length, substring(text, 1, 3) AS short_text FROM test_strings GROUP BY short_text HAVING count_per_length > 1;
SELECT id, COUNT(*) AS count FROM (SELECT substring(text, 1, 2) AS short FROM test_strings) AS subquery GROUP BY short;
CREATE TABLE temp_strings AS SELECT DISTINCT substring(text, 1, 3) AS short_text FROM test_strings;
SELECT short_text, count() FROM temp_strings GROUP BY short_text ORDER BY count() DESC;
SELECT id, text FROM test_strings WHERE text IS NOT NULL AND (substring(text, 1, 100) = 'fuzzy testing' OR substring(text, -12) = 'testing');
CREATE TABLE another_test (id UInt32, reference String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_test VALUES (1, 'fuzzy'), (2, 'test');
SELECT a.id, b.id, substring(a.reference, 1, 1) AS initial FROM another_test AS a JOIN test_strings AS b ON initial = substring(b.text, 1, 1);
SELECT id, substring(COALESCE(text, 'default'), 1, 1) AS first_char FROM test_strings;
SELECT MAX(LENGTH(substring(text, 1, 4))) AS max_length FROM test_strings;