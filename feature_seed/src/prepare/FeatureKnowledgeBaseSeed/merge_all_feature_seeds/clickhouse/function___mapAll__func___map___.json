CREATE TABLE test_map (key String, value Int32) ENGINE = Memory;
INSERT INTO test_map VALUES ('k1', 1), ('k2', 2), ('k3', 0), ('k4', 3);
SELECT mapAll((k, v) -> (v > 0), map('k1', 1, 'k2', 2)) AS res;
SELECT mapAll((k, v) -> (v = 1), map('k1', 1, 'k2', 1)) AS res;
SELECT mapAll((k, v) -> (v <= 3), map('k1', 1, 'k2', 2, 'k3', 3)) AS res;
SELECT mapAll((k, v) -> (v < 5), map('k1', 4, 'k2', 5)) AS res;
CREATE TABLE test_nested_map (id Int32, data Map(String, Int32)) ENGINE = Memory;
INSERT INTO test_nested_map VALUES (1, map('k1', 1, 'k2', 1)), (2, map('k1', 1, 'k2', 0));
SELECT id, mapAll((k, v) -> (v = 1), data) AS all_positive FROM test_nested_map;
SELECT id, mapAll((k, v) -> (v = 1), data) AS all_positive FROM test_nested_map WHERE all_positive = 1;
SELECT mapAll((k, v) -> (v != 0), map('a', 1, 'b', 0, 'c', 2)) AS all_non_zero;
SELECT id, mapAll((k, v) -> (v > 0), data) FROM test_nested_map GROUP BY id;
SELECT id FROM (SELECT id, mapAll((k, v) -> (v > 0), data) AS all_positive FROM test_nested_map) WHERE all_positive = 1;