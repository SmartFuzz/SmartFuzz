CREATE TABLE uuid_table_1 (uuid UUID) ENGINE = Memory;
INSERT INTO uuid_table_1 SELECT generateUUIDv4();
SELECT * FROM uuid_table_1;
CREATE TABLE uuid_table_2 (id UInt32, uuid UUID) ENGINE = Memory;
INSERT INTO uuid_table_2 SELECT number, generateUUIDv4() FROM system.numbers LIMIT 5;
SELECT id, uuid FROM uuid_table_2;
CREATE TABLE nested_uuid (id UInt32, uuid UUID) ENGINE = Memory;
INSERT INTO nested_uuid SELECT number, generateUUIDv4() FROM system.numbers LIMIT 3;
SELECT (SELECT uuid FROM nested_uuid WHERE id = 1) as uuid_1, (SELECT uuid FROM nested_uuid WHERE id = 2) as uuid_2;
CREATE TABLE join_uuid_table_1 (group_id UInt32, uuid UUID) ENGINE = Memory;
INSERT INTO join_uuid_table_1 SELECT number % 2, generateUUIDv4() FROM system.numbers LIMIT 4;
CREATE TABLE join_uuid_table_2 (id UInt32, group_id UInt32) ENGINE = Memory;
INSERT INTO join_uuid_table_2 SELECT number, number % 2 FROM system.numbers LIMIT 4;
SELECT j.group_id, j.uuid FROM join_uuid_table_1 j JOIN join_uuid_table_2 g ON j.group_id = g.group_id;
CREATE TABLE complex_query_test (uuid UUID, custom_data String) ENGINE = Memory;
INSERT INTO complex_query_test SELECT generateUUIDv4(), 'data_' || toString(number) FROM system.numbers LIMIT 5;
SELECT uuid, custom_data FROM complex_query_test WHERE custom_data LIKE 'data_1';
SELECT generateUUIDv4() as new_uuid, count(*) FROM uuid_table_2 GROUP BY new_uuid;