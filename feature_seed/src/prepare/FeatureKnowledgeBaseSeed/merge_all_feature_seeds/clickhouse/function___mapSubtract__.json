CREATE TABLE test_mapSubtract_1 (k Array(Int64), v Array(Int64));
INSERT INTO test_mapSubtract_1 VALUES ([1, 2], [5, 10]), ([1, 3], [12, 15]);
SELECT mapSubtract((k, v), (k, v)) AS res FROM test_mapSubtract_1;
SELECT mapSubtract(([1, 2], [5, 10]), ([1, 3], [12, 5])) AS res;
SELECT mapSubtract(([1, 1, 2], [2, 3, 10]), ([1, 1, 2], [1, 3, 1])) AS res;
SELECT mapSubtract((k, v), (k, v)) AS res FROM (SELECT [1, 2, 3] AS k, [5, 5, 5] AS v) AS t;
SELECT mapSubtract((arrayJoin([1, 2]), [5, 10]), (arrayJoin([1, 3]), [12, 15])) AS res;
WITH ([1, 2, 3], [5, 10, 15]) AS first_map, ([1, 2, 4], [3, 5, 10]) AS second_map SELECT mapSubtract(first_map, second_map) AS res;
SELECT mapSubtract(([toUInt8(1), 2], [toInt32(4), 4]), ([toUInt8(1), 3], [toInt32(2), 5])) AS res, toTypeName(res) AS type;
CREATE TABLE test_mapSubtract_2 (k Array(String), v Array(Float64));
INSERT INTO test_mapSubtract_2 VALUES (['a', 'b'], [1.0, 2.0]), (['a', 'c'], [3.0, 4.0]);
SELECT mapSubtract((k, v), (k, v)) AS res FROM test_mapSubtract_2;
SELECT mapSubtract((['x', 'y'], [1.0, 2.0]), (['x', 'z'], [3.0, 4.0])) AS res;
SELECT mapSubtract((arrayJoin(['apple', 'banana']), [3.5, 2.5]), (arrayJoin(['apple', 'orange']), [1.0, 4.0])) AS res;
WITH ([1, 2, 3], [2.5, 3.5, 4.5]) AS a_map, ([1, 2, 4], [3.5, 2.5, 1.5]) AS b_map SELECT mapSubtract(a_map, b_map) AS res;
SELECT mapSubtract(([1, 2], [5, 10]), ([2, 2], [5, 10])) AS res;
WITH ([1, 2, 3], [4.0, 5.0, 6.0]) AS map1, ([1, 2, 4], [1.0, 2.0, 3.0]) AS map2 SELECT mapSubtract(map1, map2) AS result;