CREATE TABLE test_intDiv (a Int64, b Int64);
INSERT INTO test_intDiv VALUES (10, 2), (15, 3), (20, 0), (0, 1), (-10, -2), (-1, -1);
SELECT intDiv(a, b) AS quotient FROM test_intDiv WHERE b != 0;
SELECT a, b, intDiv(a, b) AS quotient FROM test_intDiv;
SELECT intDiv(7, 2) AS res, toTypeName(res) AS type_name;
SELECT intDiv(-9, 3) AS res;
SELECT intDiv(-1, -1) AS res;
SELECT intDiv(1, -1) AS res;
SELECT intDiv(200, 3) AS res, toTypeName(res) AS type_name;
SELECT a, b, intDiv(a * 1.0, b * 1.0) AS res FROM test_intDiv;
SELECT a, b, (SELECT intDiv(a, b) FROM test_intDiv WHERE a > 0 LIMIT 1) AS nested_result FROM test_intDiv;
SELECT a, b, (SELECT sum(intDiv(a, b)) FROM test_intDiv WHERE b > 0) AS total_quotient FROM test_intDiv;
CREATE TABLE test_subquery (x Int64);
INSERT INTO test_subquery VALUES (1), (2), (3);
SELECT intDiv(t1.a, (SELECT max(x) FROM test_subquery)) AS result FROM test_intDiv t1 WHERE t1.b > 0;
SELECT a, b, intDiv(a, b) OVER (PARTITION BY b) FROM test_intDiv;
SELECT intDiv(CAST(a AS Float64), CAST(b AS Float64)) AS res FROM test_intDiv WHERE b != 0;
SELECT intDiv(a, b) AS res FROM test_intDiv WHERE b <= 5 ORDER BY res DESC;