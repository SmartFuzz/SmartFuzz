CREATE TABLE test_data (successes_x UInt64, successes_y UInt64, trials_x UInt64, trials_y UInt64, conf_level Float64, pool_type String);
INSERT INTO test_data VALUES (10, 11, 100, 101, 0.95, 'unpooled');
INSERT INTO test_data VALUES (0, 0, 1, 1, 0.95, 'pooled');
INSERT INTO test_data VALUES (100, 200, 1000, 2000, 0.99, 'unpooled');
INSERT INTO test_data VALUES (50, 100, 200, 300, 0.90, 'pooled');
INSERT INTO test_data VALUES (1, 1, 10, 10, 0.95, 'unpooled');
SELECT proportionsZTest(successes_x, successes_y, trials_x, trials_y, conf_level, pool_type) FROM test_data WHERE trials_x > 0 AND trials_y > 0;
SELECT * FROM (SELECT proportionsZTest(successes_x, successes_y, trials_x, trials_y, conf_level, pool_type) AS stats FROM test_data) AS derived_table WHERE stats.p_val < 0.05;
SELECT COUNT(*) FROM (SELECT DISTINCT pool_type FROM test_data WHERE pool_type IN ('unpooled', 'pooled'));
SELECT proportionsZTest(MAX(successes_x), MAX(successes_y), SUM(trials_x), SUM(trials_y), 0.95, 'pooled') FROM test_data GROUP BY pool_type;
WITH (SELECT COUNT(*) FROM test_data WHERE trials_x = 0) AS zero_trials SELECT proportionsZTest(10, 5, 0, 10, 0.95, 'unpooled') WHERE zero_trials > 0;