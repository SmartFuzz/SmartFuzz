CREATE TABLE test_parse_datetime (date_string String);
INSERT INTO test_parse_datetime VALUES ('2023-10-01'), ('invalid-date'), ('2023-10-15 12:30:00');
SELECT date_string, parseDateTimeOrNull(date_string) AS parsed_date FROM test_parse_datetime;
SELECT date_string, parseDateTimeOrNull(date_string) AS parsed_date FROM (SELECT date_string FROM test_parse_datetime) AS subquery;
CREATE TABLE test_dates (id Int32, date_string String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_dates VALUES (1, '2023-10-01'), (2, '2023-10-32'), (3, '2023-10-15 14:00:00'), (4, 'not-a-date');
SELECT id, parseDateTimeOrNull(date_string) AS parsed_date FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE id > 1);
SELECT id, parseDateTimeOrNull(date_string) AS parsed_date FROM (SELECT id, date_string FROM test_dates WHERE id < 3) AS filtered_dates;
SELECT COUNT(*) AS valid_dates_count FROM test_dates WHERE parseDateTimeOrNull(date_string) IS NOT NULL;
SELECT id, parseDateTimeOrNull(date_string) AS parsed_date FROM test_dates GROUP BY id, date_string HAVING parsed_date IS NULL;