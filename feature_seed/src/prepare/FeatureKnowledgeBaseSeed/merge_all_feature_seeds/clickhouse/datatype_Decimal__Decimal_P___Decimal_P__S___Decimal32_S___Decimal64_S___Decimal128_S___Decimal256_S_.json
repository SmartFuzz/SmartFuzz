CREATE TABLE test_decimals (id UInt32, value Decimal32(4)) ENGINE = Memory;
INSERT INTO test_decimals VALUES (1, toDecimal32(99999.9999, 4)), (2, toDecimal32(-99999.9999, 4));
SELECT id, value, value + toDecimal32(1.0001, 4) AS incremented_value FROM test_decimals;
SELECT id, value, value - toDecimal32(0.0001, 4) AS decremented_value FROM test_decimals;
SELECT id, value, value * toDecimal32(2, 0) AS doubled_value FROM test_decimals;
SELECT id, value, value / toDecimal32(3, 0) AS divided_value FROM test_decimals;
CREATE TABLE test_decimals_scale (id UInt32, value Decimal64(10, 5)) ENGINE = Memory;
INSERT INTO test_decimals_scale VALUES (1, toDecimal64(12345.67889, 5)), (2, toDecimal64(-12345.67889, 5));
SELECT id, value, value + toDecimal64(1.23456, 5) AS scaled_increment FROM test_decimals_scale;
SELECT id, value, value - toDecimal64(0.00001, 5) AS scaled_decrement FROM test_decimals_scale;
SET decimal_check_overflow = 0;
SELECT id, value, value * toDecimal64(6, 0) AS unsafe_multiplied_value FROM test_decimals_scale;
CREATE TABLE test_decimals_large (id UInt32, value Decimal128(38, 10)) ENGINE = Memory;
INSERT INTO test_decimals_large VALUES (1, toDecimal128(1e-10, 10)), (2, toDecimal128(1e+10, 10));
SELECT id, value, value + toDecimal128(0.0000000001, 10) AS very_small_increment FROM test_decimals_large;
SELECT id, value, value - toDecimal128(1e+9, 10) AS large_decrement FROM test_decimals_large;
CREATE TABLE test_multijoin (id UInt32, value Decimal32(4), category_id UInt32) ENGINE = Memory;
INSERT INTO test_multijoin VALUES (1, toDecimal32(100.1234, 4), 1), (2, toDecimal32(200.5678, 4), 2);
CREATE TABLE categories (category_id UInt32, name String) ENGINE = Memory;
INSERT INTO categories VALUES (1, 'Category1'), (2, 'Category2');
SELECT m.id, m.value, c.name, m.value * 2 AS doubled_value FROM test_multijoin m JOIN categories c ON m.category_id = c.category_id;
SELECT id, value, (value * 1.1) AS increase_value FROM test_multijoin WHERE value < toDecimal32(150, 4);
SET decimal_check_overflow = 0;
SELECT id, value, CAST(value AS Float64) * 2 as unsafe_casted_value FROM test_decimals;
CREATE TABLE overflow_test (id UInt32, value Decimal32(2)) ENGINE = Memory;
INSERT INTO overflow_test VALUES (1, toDecimal32(99.99, 2)), (2, toDecimal32(0.01, 2));
SELECT id, value, value + toDecimal32(0.02, 2) AS result FROM overflow_test;
SELECT id, value, value * toDecimal32(10, 0) AS overflow_attempt FROM overflow_test;