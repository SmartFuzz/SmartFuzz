CREATE TABLE test_ceiling (value FLOAT);
INSERT INTO test_ceiling VALUES (1.4), (1.5), (2.3), (3.9), (4.0), (-1.1), (-1.5), (0.0);
SELECT ceiling(value) FROM test_ceiling;
SELECT ceiling(value * 2.5) FROM test_ceiling;
SELECT ceiling(average) FROM (SELECT AVG(value) AS average FROM test_ceiling);
SELECT ceiling((SELECT AVG(value) FROM test_ceiling) + 1.1);
CREATE TABLE test_join (id INT, value FLOAT);
INSERT INTO test_join VALUES (1, 2.2), (2, 3.7), (3, 4.4);
SELECT j.id, ceiling(t.value + j.value) AS rounded_sum FROM test_ceiling t JOIN test_join j ON t.value <= j.value;
SELECT ceiling(MAX(value)) FROM (SELECT value FROM test_ceiling UNION ALL SELECT value FROM test_join);
SELECT ceiling(value) AS ceiling_value FROM test_ceiling WHERE value < 0.5;
SELECT id, ceiling(value) AS ceiling_value FROM test_join WHERE ceiling(value) >= 5;
SELECT ceiling(1 - (SELECT COUNT(*) FROM test_ceiling));
SELECT ceiling(SUM(value) / COUNT(*)) AS average_ceiling FROM (SELECT value FROM test_ceiling) GROUP BY value;
SELECT DISTINCT ceiling(x.value) FROM (SELECT value FROM test_ceiling) AS x;