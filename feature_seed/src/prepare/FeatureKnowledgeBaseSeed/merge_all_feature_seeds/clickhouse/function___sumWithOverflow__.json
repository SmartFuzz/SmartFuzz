CREATE TABLE salaries (id UInt32, employee_id UInt32, monthly_salary UInt16) ENGINE = MergeTree() ORDER BY id;
INSERT INTO salaries VALUES (1, 101, 65535), (2, 102, 1), (3, 103, 32767);
SELECT sum(monthly_salary) AS no_overflow, sumWithOverflow(monthly_salary) AS overflow FROM salaries;
CREATE TABLE bonuses (employee_id UInt32, bonus_amount UInt16) ENGINE = MergeTree() ORDER BY employee_id;
INSERT INTO bonuses VALUES (101, 30000), (102, 40000), (103, 60000);
SELECT s.id, SUM(s.monthly_salary) AS total_salary, SUM(b.bonus_amount) AS total_bonuses, sumWithOverflow(b.bonus_amount) AS overflow_bonus FROM salaries s JOIN bonuses b ON s.employee_id = b.employee_id GROUP BY s.id;
CREATE TABLE temp_salaries AS SELECT employee_id, monthly_salary FROM salaries WHERE monthly_salary > 100;
SELECT employee_id, sumWithOverflow(monthly_salary) AS overflow_salary FROM temp_salaries GROUP BY employee_id;
SELECT employee_id, (SELECT sumWithOverflow(monthly_salary) FROM salaries WHERE employee_id < 103) AS overflow_salary FROM bonuses;
CREATE TABLE metrics (metric_id UInt32, value Int32) ENGINE = MergeTree() ORDER BY metric_id;
INSERT INTO metrics VALUES (1, 2147483646), (2, 5);
SELECT SUM(value) AS total_value, sumWithOverflow(value) AS overflowed_value FROM metrics;
SELECT employee_id, sumWithOverflow(monthly_salary + (SELECT COALESCE(SUM(b.bonus_amount), 0) FROM bonuses b WHERE b.employee_id = s.employee_id)) AS total_with_bonuses FROM salaries s GROUP BY employee_id;
SELECT s.employee_id, SUM(b.bonus_amount) AS total_bonus, sumWithOverflow(SUM(b.bonus_amount)) AS overflowed_bonus FROM bonuses b RIGHT JOIN salaries s ON s.employee_id = b.employee_id GROUP BY s.employee_id;