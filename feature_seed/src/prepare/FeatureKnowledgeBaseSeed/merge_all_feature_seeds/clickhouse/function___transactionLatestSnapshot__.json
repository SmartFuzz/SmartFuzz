CREATE TABLE transactions (id UInt64, data String) ENGINE = MergeTree() ORDER BY id;
BEGIN TRANSACTION;
INSERT INTO transactions VALUES (1, 'data1'), (2, 'data2');
SELECT transactionLatestSnapshot();
ROLLBACK;
BEGIN TRANSACTION;
INSERT INTO transactions VALUES (3, 'data3');
SELECT transactionLatestSnapshot();
COMMIT;
BEGIN TRANSACTION;
INSERT INTO transactions VALUES (4, 'data4');
TRUNCATE TABLE transactions;
SELECT transactionLatestSnapshot();
ROLLBACK;
CREATE TABLE snapshots (snapshot_id UInt64, commit_sequence_number UInt64) ENGINE = MergeTree() ORDER BY snapshot_id;
BEGIN TRANSACTION;
INSERT INTO snapshots VALUES (1, 100), (2, 200);
SELECT transactionLatestSnapshot();
COMMIT;
BEGIN TRANSACTION;
INSERT INTO transactions VALUES (5, 'data5');
SELECT transactionLatestSnapshot();
ROLLBACK;
SELECT transactionLatestSnapshot() FROM (SELECT * FROM transactions WHERE id IN (1, 2));
BEGIN TRANSACTION;
SELECT MAX(commit_sequence_number) AS max_csn FROM snapshots;
SELECT transactionLatestSnapshot();
ROLLBACK;
BEGIN TRANSACTION;
INSERT INTO transactions VALUES (6, 'data6');
INSERT INTO snapshots VALUES (3, 300);
SELECT transactionLatestSnapshot();
ROLLBACK;
CREATE TABLE details (id UInt64, info String) ENGINE = MergeTree() ORDER BY id;
BEGIN TRANSACTION;
INSERT INTO details SELECT id, data FROM transactions;
SELECT transactionLatestSnapshot();
ROLLBACK;
CREATE TABLE complex_data (id UInt64, category String, value Float64) ENGINE = MergeTree() ORDER BY id;
BEGIN TRANSACTION;
INSERT INTO complex_data VALUES (1, 'A', 10.5), (2, 'B', 20.5);
SELECT transactionLatestSnapshot();
INSERT INTO complex_data VALUES (3, 'C', 30.5);
ROLLBACK;
BEGIN TRANSACTION;
SELECT COUNT(*) FROM details WHERE info LIKE '%data%';
SELECT transactionLatestSnapshot();
ROLLBACK;
CREATE TABLE join_test (id UInt64, foreign_id UInt64) ENGINE = MergeTree() ORDER BY id;
BEGIN TRANSACTION;
INSERT INTO join_test VALUES (1, 1), (2, 2);
SELECT transactionLatestSnapshot();
ROLLBACK;
BEGIN TRANSACTION;
SELECT t.id, COUNT(d.info) FROM transactions t LEFT JOIN details d ON t.id = d.id GROUP BY t.id;
SELECT transactionLatestSnapshot();
ROLLBACK;
INSERT INTO complex_data VALUES (4, 'D', 40.5);
SELECT transactionLatestSnapshot();