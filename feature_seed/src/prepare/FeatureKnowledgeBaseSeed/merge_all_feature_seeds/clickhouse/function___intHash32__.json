CREATE TABLE test_integers (id Int32, value Int32);
INSERT INTO test_integers VALUES (1, 0), (2, 2147483647), (3, -2147483648), (4, -1), (5, 42);
SELECT id, intHash32(value) AS hash_code FROM test_integers;
SELECT intHash32(value) FROM (SELECT value FROM test_integers WHERE id = 1);
SELECT t.id, intHash32(t.value) AS hash_code FROM test_integers t WHERE t.value > 0;
SELECT t1.id, intHash32(t2.value) AS hash_code FROM test_integers t1 JOIN test_integers t2 ON t1.id <> t2.id;
WITH (SELECT value FROM test_integers WHERE id = 2) AS val SELECT intHash32(val) AS hash_code_nested;
SELECT id, intHash32(value + 100) AS hash_code FROM test_integers WHERE values IN (SELECT value FROM test_integers WHERE value < 100);
SELECT id, intHash32(if(value > 0, value, 0)) AS hash_code FROM test_integers;
CREATE TABLE test_hash_results (hash_code UInt32);
INSERT INTO test_hash_results SELECT intHash32(value) FROM test_integers;
SELECT DISTINCT(hash_code) FROM test_hash_results;
SELECT id, intHash32(value) AS hash_value FROM (SELECT * FROM test_integers WHERE id IN (SELECT id FROM test_integers WHERE value < 0)) AS filtered;