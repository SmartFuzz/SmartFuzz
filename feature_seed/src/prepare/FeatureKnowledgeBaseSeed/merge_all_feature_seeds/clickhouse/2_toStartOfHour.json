CREATE TABLE test_table (id Int32, event_time DateTime, event_data String);
INSERT INTO test_table VALUES (1, toDateTime('2023-04-21 10:20:30'), 'Event A');
INSERT INTO test_table VALUES (2, toDateTime('2023-04-21 10:45:15'), NULL);
INSERT INTO test_table VALUES (3, toDateTime('2023-04-21 11:10:45'), 'Event B');
SELECT id, event_time, toStartOfHour(event_time) AS hour_start FROM test_table WHERE toStartOfHour(event_time) > toStartOfHour(toDateTime('2023-04-21 10:00:00'));
SELECT AVG(id) AS avg_id FROM (SELECT id, toStartOfHour(event_time) AS hour_start FROM test_table GROUP BY hour_start HAVING hour_start > toStartOfHour(toDateTime('2023-04-21 10:20:00')));
SELECT id, event_data FROM test_table WHERE event_data IS NOT NULL AND toStartOfHour(event_time) > toStartOfHour(toDateTime64('2023-04-21 10:00:00', 3)) AND NOT (event_time > toDateTime('2023-04-21 11:00:00'));
SELECT id, event_time, toStartOfHour(event_time) AS hour_start, (CASE WHEN event_data IS NULL THEN 0 ELSE 1 END) AS data_present FROM test_table WHERE hour_start > toStartOfHour(toDateTime('2023-04-21 10:30:00')) ORDER BY hour_start ASC;
SELECT t1.id, t1.event_time, toStartOfHour(t1.event_time) AS hour_start FROM test_table t1 JOIN (SELECT id, event_time FROM test_table WHERE event_data = 'Event A') t2 ON t1.id > t2.id AND t1.event_time < toStartOfHour(t2.event_time) + INTERVAL 1 HOUR;
SELECT toStartOfHour(hour_start) FROM (SELECT toStartOfHour(event_time) AS hour_start FROM test_table GROUP BY hour_start HAVING COUNT(id) > 0) WHERE hour_start > toStartOfHour(toDateTime('2023-04-21 10:00:00'));