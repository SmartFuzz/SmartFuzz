CREATE TABLE regions (id UInt32, name String) ENGINE = Memory;
INSERT INTO regions VALUES (1, 'Region A'), (2, 'Region B'), (3, 'Region C');
CREATE TABLE cities (id UInt32, name String) ENGINE = Memory;
INSERT INTO cities VALUES (101, 'City A1'), (102, 'City B1'), (103, 'City C1');
CREATE TABLE region_to_district (region_id UInt32, district_id UInt32) ENGINE = Memory;
INSERT INTO region_to_district VALUES (1, 11), (2, 12), (3, 13);
SELECT DISTINCT regionToDistrict(id) FROM regions;
SELECT r.id, regionToDistrict(r.id) AS district_id FROM regions AS r JOIN region_to_district AS rd ON r.id = rd.region_id;
SELECT regionToDistrict(r.id) FROM (SELECT DISTINCT id FROM regions) AS r;
SELECT regionToDistrict(r.id, 'default') FROM regions AS r WHERE r.id IN (1, 2, 3);
SELECT DISTINCT regionToName(regionToDistrict(r.id)) FROM regions AS r JOIN region_to_district AS rd ON r.id = rd.region_id WHERE r.name LIKE 'Region%';
SELECT COUNT(*) FROM (SELECT DISTINCT regionToDistrict(r.id, 'ua') AS district_id FROM regions r) AS subquery WHERE district_id > 0;
SELECT regionToDistrict(id) FROM (SELECT id FROM regions WHERE id < 5) AS temp;
WITH (SELECT COUNT(*) FROM region_to_district) AS count_ AS temp_count SELECT regionToDistrict(1) AS district_output FROM regions WHERE count_ > 0;
SELECT regionToDistrict(id) AS district FROM region_to_district WHERE region_id = 2 UNION SELECT regionToDistrict(3);
SELECT regionToDistrict(id, 'geobase') FROM system.numbers LIMIT 10;