CREATE TABLE test_dates (id UInt32, eventDate Date, eventTime DateTime, timestampValue UInt64);
INSERT INTO test_dates VALUES (1, toDate('2022-12-30'), toDateTime('2022-12-30 13:00:00'), 1672400000);
INSERT INTO test_dates VALUES (2, toDate(12345), toDateTime('2022-01-01 00:00:00'), 12345);
SELECT id, eventDate, toDate(eventDate) AS truncated_date, toDate(toUnixTimestamp(eventTime)) AS unix_to_date FROM test_dates WHERE toDate(eventDate) == '2022-12-30';
SELECT id, eventDate, eventTime, toDate(timestampValue) AS date_from_timestamp, toDate(toUnixTimestamp(eventTime)) AS unix_to_date FROM test_dates WHERE eventDate == toDate(12345);
SELECT id, eventDate, eventTime, COUNT(*) OVER (PARTITION BY toDate(eventTime)) AS date_count FROM test_dates HAVING toDate(eventTime) == eventDate;
SELECT id, eventDate, toDate(toUnixTimestamp(CAST(id AS UInt64) * 10000)) AS calculated_date FROM test_dates WHERE toDate(eventDate) == toDate(10000000000.) OR toDate(eventTime) == toDate(0);
SELECT COUNT(*), AVG(eventTime) AS avg_time, toDate(CAST(AVG(toUnixTimestamp(eventTime)) AS UInt64)) AS avg_date FROM test_dates GROUP BY eventDate HAVING avg_time == toUnixTimestamp(eventTime);
SELECT CASE WHEN toDate(eventDate) == '2022-12-30' THEN toDate(toUnixTimestamp(eventTime)) ELSE NULL END AS case_date FROM test_dates;
CREATE TEMPORARY TABLE temp_dates AS SELECT *, toDate(timestampValue) AS converted_date FROM test_dates WHERE toDate(timestampValue) == toDate(12345);
SELECT id, eventDate, eventTime, converted_date FROM temp_dates WHERE toDate(eventTime) == converted_date;