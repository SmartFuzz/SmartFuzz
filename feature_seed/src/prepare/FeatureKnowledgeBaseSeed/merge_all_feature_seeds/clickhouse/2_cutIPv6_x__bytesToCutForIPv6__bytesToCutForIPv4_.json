CREATE TABLE ip_addresses (id Int32, ipv6 FixedString(16), ipv4 FixedString(4), data String);
INSERT INTO ip_addresses VALUES (1, IPv6StringToNum('2001:0DB8:AC10:FE01:FEED:BABE:CAFE:F00D'), IPv4StringToNum('192.168.0.1'), 'Test data');
SELECT cutIPv6(ipv6, 2, 0) AS modified_ipv6, cutIPv6(ipv4, 0, 2) AS modified_ipv4 FROM ip_addresses;
SELECT id, cutIPv6(ipv6, bytesToCut, 0) FROM (SELECT id, ipv6, 2 AS bytesToCut FROM ip_addresses) WHERE modified_ipv6 IS NOT NULL;
WITH (SELECT cutIPv6(ipv6, 2, 0) FROM ip_addresses) AS modified_ipv6, (SELECT cutIPv6(ipv4, 0, 2) FROM ip_addresses) AS modified_ipv4 SELECT modified_ipv6, modified_ipv4;
CREATE TABLE temp_ips AS SELECT id, cutIPv6(ipv6, 1, 0) AS partial_ipv6 FROM ip_addresses;
INSERT INTO temp_ips SELECT id, cutIPv6(ipv6, 0, 1) FROM ip_addresses;
SELECT id, COUNT(*) FROM temp_ips GROUP BY id HAVING MOD(id, 2) = 0;
SELECT arrayJoin([cutIPv6(ipv6, 2, 0), cutIPv6(ipv4, 0, 2)]) AS combined_ips FROM ip_addresses;
SELECT id, CUT_IPV6(ipv6, -1, 0) AS negative_cut FROM ip_addresses WHERE cut_ipv6 IS NOT NULL;