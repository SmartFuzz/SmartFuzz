CREATE TABLE test_dates (id UInt32, event_date DateTime, description String, value Float64);
INSERT INTO test_dates VALUES (1, makeDateTime(2023, 2, 28, 17, 12, 33), 'Event A', 100.0), (2, makeDateTime(2023, 2, 28, 12, 30, 0), 'Event B', NULL);
SELECT id, event_date, description FROM test_dates WHERE event_date != makeDateTime(2023, 2, 28, 17, 12, 33);
SELECT id, COUNT(*) FROM test_dates GROUP BY id HAVING makeDateTime(2023, 2, 28, 17, 12, 33) != event_date;
SELECT id, event_date, description FROM test_dates WHERE event_date != makeDateTime(2023, 2, 28, 17, 12, NULL);
SELECT id, event_date, description FROM test_dates WHERE value != 100 AND event_date = makeDateTime(2023, 2, 28, 17, 12, 33);
CREATE TABLE temp_dates AS SELECT id, makeDateTime(2023, month, 1, 0, 0, 0) AS start_of_month FROM test_dates WHERE description != 'Event B';
SELECT t1.id, t1.event_date FROM test_dates t1 JOIN temp_dates t2 ON t1.event_date != t2.start_of_month WHERE t1.value IS NOT NULL;
SELECT id, makeDateTime(CONVERT('2023', 'Int32'), 2, 28, 17, 12, 33) AS event_datetime FROM test_dates WHERE id != 1 GROUP BY event_datetime;
INSERT INTO test_dates VALUES (3, makeDateTime(2023, 1, 1, 23, NULL, 15), 'Boundary Event', 0.1234567890123456789);
SELECT id, event_date FROM test_dates WHERE value IS NOT NULL AND event_date != makeDateTime(2023, NULL, NULL, 0, 0, 0);
WITH (makeDateTime(2023, 10, 1, 12, 0, 0) AS threshold) SELECT id FROM test_dates WHERE event_date != threshold;
CREATE TABLE edge_cases (event DateTime, note String);
INSERT INTO edge_cases VALUES (makeDateTime(2023, 12, 31, 23, 59, 59), 'End of Year'), (makeDateTime(2024, 1, 1, 0, 0, 0), 'Start of Year');
SELECT event, note FROM edge_cases WHERE event != makeDateTime(2023, 12, 31, 23, 59, 59) AND note != 'End of Year';