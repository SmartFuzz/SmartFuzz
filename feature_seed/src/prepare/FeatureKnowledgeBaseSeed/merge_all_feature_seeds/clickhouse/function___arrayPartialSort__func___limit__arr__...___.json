CREATE TABLE test_partial_sort (id UInt32, arr Array(Int32));
INSERT INTO test_partial_sort VALUES (1, [3, 1, 4, 1, 5, 9, 2, 6, 5, 3]), (2, [7, 8, 2, 0, 1, 5]), (3, [10, 9, 8]);
SELECT id, arrayPartialSort(5, arr) AS sorted_arr FROM test_partial_sort;
SELECT id, arrayPartialSort(3, arr) AS sorted_arr FROM test_partial_sort WHERE id = 1;
SELECT id, arrayPartialSort(10, arr) AS sorted_arr, arraySort(arr) AS full_sorted_arr FROM test_partial_sort;
SELECT id, arrayPartialSort(2, arr) AS sorted_arr FROM test_partial_sort WHERE arr[1] > 3;
CREATE TABLE test_nested (id UInt32, arr Array(Int32), c UInt32);
INSERT INTO test_nested VALUES (1, [3, 1, 4, 1], 1), (2, [7, 8, 5, 0], 2);
SELECT tn.id, arrayPartialSort(tn.c, tn.arr) AS sorted_arr FROM test_nested tn JOIN test_partial_sort tp ON tn.id = tp.id;
SELECT id, arrayPartialSort(5, arr) AS sorted_arr, (SELECT count() FROM test_partial_sort WHERE id = 1) AS count FROM test_partial_sort;
SELECT id, arrayPartialSort(1, arr) AS sorted_arr FROM test_partial_sort WHERE arr[1] IN (SELECT arr[1] FROM test_partial_sort WHERE id = 2);