CREATE TABLE test_ignore (value Int32, text String, nullable_value Nullable(Int32));
INSERT INTO test_ignore VALUES (1, 'Hello'), (2, 'World'), (3, NULL);
SELECT ignore(SELECT COUNT(*) FROM test_ignore WHERE value > 1);
SELECT ignore(text, value, NULL) FROM test_ignore;
SELECT ignore(1 + 2, 'Test', ignore(NULL));
WITH (SELECT COUNT(*) FROM test_ignore) AS cnt SELECT ignore(cnt);
SELECT ignore(t1.value, t2.text) FROM (SELECT value FROM test_ignore) AS t1 JOIN (SELECT text FROM test_ignore) AS t2 ON t1.value = 1;
CREATE TABLE another_test (id Int32, desc String);
INSERT INTO another_test VALUES (1, 'Desc1'), (2, 'Desc2');
SELECT ignore(1, (SELECT desc FROM another_test WHERE id = 1), (SELECT value FROM test_ignore WHERE value < 3));
SELECT ignore(arrayJoin([1, 2, 3]), 'Multiple Arguments', ignore(NULL));