CREATE TABLE test_table (id UInt32, val1 Nullable(Int32), val2 Nullable(Int32), val3 Int32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 10, NULL, 25), (2, NULL, 20, 35), (3, 30, 15, NULL), (4, 40, 45, 20);
SELECT tupleMinus((val1, val2), (NULL, 10)) AS result FROM test_table WHERE val3 IS NULL;
SELECT id, tupleMinus((val1, val2), (5, 10)) AS differences FROM test_table WHERE val1 IS NOT NULL AND val2 IS NOT NULL GROUP BY id;
SELECT id, IF(val1 IS NULL, tupleMinus((0, 0), (val1, val2)), tupleMinus((val1, val2), (5, 10))) AS calculations FROM test_table HAVING calculations.1 > 0;
WITH (SELECT AVG(val3) FROM test_table WHERE val1 IS NOT NULL) AS avg_val3 SELECT tupleMinus((val1, CAST(avg_val3 AS Nullable(Int32))), (10, 10)) FROM test_table WHERE val2 IS NOT NULL;
CREATE TABLE test_table_2 (id UInt32, value Nullable(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_2 VALUES (1, 5), (2, NULL), (3, 15);
SELECT t1.id, tupleMinus((t1.value, t2.value), (5, 5)) FROM test_table_2 AS t1 JOIN test_table AS t2 ON t1.id = t2.id WHERE t1.value IS NOT NULL;
SELECT v.id, tupleMinus((v.val1, v.val2), (v.val3, 0)) AS differences FROM test_table AS v WHERE v.val1 IS NULL OR v.val2 IS NULL;