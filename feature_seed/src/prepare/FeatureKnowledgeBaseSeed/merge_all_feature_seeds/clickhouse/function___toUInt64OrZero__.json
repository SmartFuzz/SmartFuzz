CREATE TABLE test_table (input_string String);
INSERT INTO test_table VALUES ('64'), ('abc'), ('-50'), ('18446744073709551615'), ('18446744073709551616'), ('3.14'), ('NaN'), ('Infinity'), ('0x1A'), ('-0x1'), ('-1.1'), ('0.999'), ('100.01'), ('-100.01');
SELECT input_string, toUInt64OrZero(input_string) AS converted_value FROM test_table;
SELECT toUInt64OrZero('3000000000') AS valid_conversion, toUInt64OrZero('abc') AS invalid_conversion FROM test_table LIMIT 1;
SELECT toUInt64OrZero(DISTINCT input_string) FROM test_table;
CREATE TABLE test_table_2 (id UInt64, value String);
INSERT INTO test_table_2 VALUES (1, '32'), (2, 'abc'), (3, '0xFF'), (4, '256'), (5, '67.89');
SELECT t.id, toUInt64OrZero(t.value) FROM test_table_2 AS t WHERE t.id < 3;
SELECT t1.id, toUInt64OrZero(t2.value) FROM test_table AS t1 JOIN test_table_2 AS t2 ON t1.input_string = t2.value;
SELECT toUInt64OrZero( CAST('1500.99' AS String) ) AS rounded_value, toUInt64OrZero(CAST('1500.99abc' AS String)) AS error_value;
CREATE TABLE another_table (num_value String);
INSERT INTO another_table VALUES ('10'), ('-20'), ('99999999999999999999'), ('-99999999999999999999'), ('Inf'), ('0.1'), ('NaN');
SELECT num_value, toUInt64OrZero(num_value) AS conversion FROM another_table;
SELECT toUInt64OrZero('0') AS zero_value, toUInt64OrZero('1') AS one_value;
WITH (SELECT toUInt64OrZero('150.5')) AS subquery_value SELECT subquery_value * 2 AS doubled_value;