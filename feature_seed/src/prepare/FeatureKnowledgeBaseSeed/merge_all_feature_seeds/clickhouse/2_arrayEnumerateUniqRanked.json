CREATE TABLE test_rank (id UInt32, arr Array(Int32), level UInt32);
INSERT INTO test_rank VALUES (1, [1, 2, 1], 1), (2, [3, 2, 3], 1), (3, [4, 4, 4], 2);
SELECT arrayEnumerateUniqRanked(1, arr, level) AS ranks FROM test_rank WHERE id > 0;
SELECT t1.id, arrayEnumerateUniqRanked(2, t2.arr, t2.level) AS ranks FROM (SELECT DISTINCT id FROM test_rank) as t1 JOIN test_rank AS t2 ON t1.id = t2.id;
WITH (arrayEnumerateUniqRanked(1, [NULL, 2, NULL, 2, 3, 3], 1)) AS ranks SELECT id, ranks[1] AS first_rank FROM test_rank WHERE arr[1] IS NULL;
SELECT t1.id, tupleElement(arrayEnumerateUniqRanked(1, t2.arr, t2.level), 1) AS first_rank FROM test_rank AS t1 JOIN (SELECT id, arr FROM test_rank WHERE level = 1) AS t2 ON t1.id = t2.id;
SELECT id, arrayEnumerateUniqRanked(1, arr, level) AS ranks FROM test_rank GROUP BY id HAVING ranks[1] > 0;
SELECT rank_values.1 FROM (SELECT arrayEnumerateUniqRanked(1, arr, level) AS rank_values FROM test_rank) AS subquery WHERE rank_values[1] IS NOT NULL;
CREATE TABLE temp_test AS SELECT * FROM test_rank WHERE level = 2;
INSERT INTO temp_test SELECT id, arr, level FROM test_rank WHERE level = 1;
SELECT arrayEnumerateUniqRanked(1, t.arr, t.level) AS enumerated_ranks FROM temp_test AS t WHERE arr[1] = 3;