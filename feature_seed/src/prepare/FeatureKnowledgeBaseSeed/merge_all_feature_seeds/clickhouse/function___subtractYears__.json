CREATE TABLE test_dates (id Int32, date_col Date, datetime_col DateTime);
INSERT INTO test_dates VALUES (1, toDate('2024-01-01'), toDateTime('2024-01-01 12:00:00'));
INSERT INTO test_dates VALUES (2, toDate('2000-01-01'), toDateTime('2000-01-01 00:00:00'));
INSERT INTO test_dates VALUES (3, toDate('1900-01-01'), toDateTime('1900-01-01 23:59:59'));
SELECT id, subtractYears(date_col, 1) AS date_subtracted, subtractYears(datetime_col, 1) AS datetime_subtracted FROM test_dates;
WITH toDate('2024-01-01') AS date, toDateTime('2024-01-01 00:00:00') AS date_time SELECT subtractYears(date, 1) AS date_sub, subtractYears(date_time, 1) AS datetime_sub;
SELECT id, subtractYears(date_col, 5) AS date_subtracted FROM test_dates WHERE date_col > toDate('2010-01-01');
SELECT id, subtractYears(datetime_col, 10) AS datetime_subtracted FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE date_col <= toDate('2000-01-01'));
WITH (SELECT toDate('2024-01-01')) AS future_date SELECT subtractYears(future_date, 2) AS past_date;
WITH (SELECT toDateTime('2024-05-15 10:00:00')) AS future_datetime SELECT subtractYears(future_datetime, 1) AS past_datetime;
SELECT id, subtractYears(subtractYears(datetime_col, 1), 2) AS double_subtracted FROM test_dates;
SELECT id, subtractYears(date_col, CAST(3 AS Int8)) AS date_subtracted FROM test_dates WHERE id = 2;
SELECT id, subtractYears(datetime_col, CAST(10.5 AS Float64)) AS datetime_subtracted FROM test_dates WHERE date_col = toDate('2000-01-01');