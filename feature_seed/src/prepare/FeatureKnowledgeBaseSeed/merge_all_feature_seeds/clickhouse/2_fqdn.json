CREATE TABLE test_domains (id UInt32, domain String, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_domains VALUES (1, 'example.com', now() - INTERVAL 1 DAY), (2, NULL, now() - INTERVAL 2 DAY), (3, 'test.org', now());
SELECT fqdn() AS server_name, domain, created_at + INTERVAL 2 HOUR AS adjusted_time FROM test_domains WHERE domain IS NOT NULL;
SELECT fqdn() AS server_name, COUNT(*) AS total_domains FROM test_domains GROUP BY server_name HAVING total_domains > 0;
SELECT fqdn() AS server_name, domain, created_at FROM test_domains WHERE created_at > (SELECT MIN(created_at) FROM test_domains WHERE domain IS NOT NULL) + INTERVAL 1 DAY;
SELECT fqdn(), (SELECT COUNT() FROM test_domains WHERE domain IS NOT NULL) AS non_null_count FROM (SELECT created_at + INTERVAL '1 day' AS new_date FROM test_domains) sub;
CREATE TABLE temp_domains AS SELECT * FROM test_domains WHERE domain LIKE '%com%' WITH NO DATA;
INSERT INTO temp_domains SELECT id, domain, created_at + INTERVAL 1 MONTH FROM test_domains WHERE created_at < now();
SELECT fqdn() AS server_name, domain, created_at - INTERVAL (SELECT COUNT() FROM temp_domains) DAY AS adjusted_created_at FROM test_domains;
SELECT fqdn(), domain, created_at + INTERVAL 5 DAY - INTERVAL 3 HOUR AS final_time FROM test_domains WHERE priority IS NULL OR priority > 1;