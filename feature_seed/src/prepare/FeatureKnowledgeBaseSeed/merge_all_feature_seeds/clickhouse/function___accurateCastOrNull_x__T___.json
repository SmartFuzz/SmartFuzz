CREATE TABLE test_table (id Int32, value String);
INSERT INTO test_table VALUES (1, '10'), (2, '-5'), (3, '255'), (4, 'Test'), (5, '300');
SELECT id, accurateCastOrNull(value, 'UInt8') AS uint8_value FROM test_table;
SELECT id, accurateCastOrNull(value, 'Int8') AS int8_value FROM test_table WHERE id IN (SELECT id FROM test_table WHERE id < 4);
SELECT id, accurateCastOrNull(value, 'Int16') AS int16_value, accurateCastOrNull(accurateCastOrNull(value, 'Int16'), 'UInt8') AS nested_cast FROM test_table;
CREATE TABLE another_table (num UInt8);
INSERT INTO another_table VALUES (0), (1), (255);
SELECT a.id, accurateCastOrNull(a.value, 'UInt8') AS uint8_value, b.num FROM test_table AS a JOIN another_table AS b ON accurateCastOrNull(a.value, 'UInt8') = b.num;
SELECT id, accurateCastOrNull(value, 'FixedString(3)') AS fixed_string FROM test_table WHERE accurateCastOrNull(value, 'String') IS NOT NULL;
CREATE TABLE mixed_table (value String);
INSERT INTO mixed_table VALUES ('123'), ('456'), ('abc'), ('789');
SELECT accurateCastOrNull(value, 'Float32') AS float_value FROM mixed_table;
SELECT accurateCastOrNull(-1, 'UInt8') AS uint8_cast, accurateCastOrNull(128, 'Int8') AS int8_cast;
SELECT id, accurateCastOrNull(value, 'Nullable(Int32)') AS nullable_int FROM test_table WHERE id = 1;