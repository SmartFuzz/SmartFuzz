CREATE TABLE test_table (value Int32);
INSERT INTO test_table VALUES (0), (1), (2), (3), (4), (5), (10), (15);
SELECT intExp10(value) FROM test_table;
SELECT value, intExp10(value) AS result FROM test_table WHERE value >= 0;
WITH (SELECT COUNT(*) FROM test_table) AS total_rows SELECT intExp10(value) AS exp_result FROM test_table LIMIT total_rows;
SELECT a.value, b.value, intExp10(a.value + b.value) AS combined_exp FROM test_table AS a JOIN test_table AS b ON a.value < b.value;
CREATE TABLE another_table (x Int64, y UInt64) ENGINE = MergeTree() ORDER BY x;
INSERT INTO another_table VALUES (0, 0), (1, 1), (2, 2), (3, 3), (10, 100);
SELECT x, intExp10(y) FROM another_table WHERE y > 0;
SELECT a.value, intExp10(a.value) AS exp_result, (SELECT COUNT(*) FROM test_table) AS total FROM test_table AS a;