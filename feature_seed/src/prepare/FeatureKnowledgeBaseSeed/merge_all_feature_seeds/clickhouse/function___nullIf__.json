CREATE TABLE test_nullif (a Nullable(Int32), b Nullable(Int32));
INSERT INTO test_nullif VALUES (1, 1), (2, 2), (NULL, 1), (1, NULL), (NULL, NULL);
SELECT nullIf(a, b) AS result FROM test_nullif;
SELECT nullIf(a, b) AS result FROM test_nullif WHERE a IS NOT NULL;
SELECT nullIf(a, 1) AS result FROM test_nullif;
SELECT nullIf(1, b) AS result FROM test_nullif;
SELECT nullIf(x.value, y.value) AS result FROM (SELECT a AS value FROM test_nullif) x JOIN (SELECT b AS value FROM test_nullif) y ON x.value <> 2;
SELECT NULLIF(a, b) FROM (SELECT 1 AS a, 1 AS b UNION ALL SELECT 2, 2 UNION ALL SELECT 3, 4) temp;
CREATE TABLE t2 (id UInt32, value Nullable(Int32));
INSERT INTO t2 VALUES (1, NULL), (2, 100), (3, 100), (4, NULL);
SELECT nullIf(t1.a, t2.value) AS result FROM test_nullif t1 JOIN t2 ON t1.b = t2.id WHERE t2.value IS NOT NULL;
SELECT nullIf(nullIf(a, b), 1) AS result FROM test_nullif;
SELECT nullIf(0, 0) AS result, nullIf(0, 1) AS result2;
SELECT nullIf(a, b) AS first, nullIf(b, a) AS second FROM test_nullif;
SELECT nullIf(nullIf(a, b), nullIf(b, a)) AS symmetric_result FROM test_nullif;