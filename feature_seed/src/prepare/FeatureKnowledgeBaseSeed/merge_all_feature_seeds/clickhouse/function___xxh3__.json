CREATE TABLE test_table (id UInt32, name String, value Float64);
INSERT INTO test_table VALUES (1, 'A', 10.5), (2, 'B', 20.5), (3, 'C', 30.5);
SELECT xxh3(name) FROM test_table;
SELECT id, xxh3(name) AS hash_value FROM test_table WHERE value > 15;
SELECT xxh3(name) AS hash_value FROM (SELECT name, value FROM test_table WHERE value > 10) AS subquery;
CREATE TABLE another_table (id UInt32, reference_id UInt32);
INSERT INTO another_table VALUES (1, 1), (2, 2), (3, 1);
SELECT xxh3(t.name || a.id) AS combined_hash FROM test_table AS t JOIN another_table AS a ON t.id = a.reference_id;
SELECT xxh3(CONCAT(name, '_', value)) FROM test_table;
SELECT xxh3((SELECT name FROM test_table WHERE id = 2)) AS hash_subquery;
SELECT xxh3(arrayJoin(['first', 'second', 'third'])) AS multi_input_hash;
SELECT xxh3(UNION ALL SELECT name FROM test_table WHERE id <= 2) AS union_hash;
SELECT xxh3(CAST(value AS String)) FROM test_table;
SELECT xxh3(name || '_' || toString(value)) FROM test_table ORDER BY id;
SELECT xxh3('Example', 'hash', 'function') AS complex_hash;
SELECT xxh3(NULLIF(name, 'A')) FROM test_table;