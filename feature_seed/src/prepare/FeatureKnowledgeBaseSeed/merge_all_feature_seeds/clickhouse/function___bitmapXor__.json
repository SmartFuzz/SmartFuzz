CREATE TABLE test_table1 (id UInt32, bitmap_col1 AggregateFunction(bitmap, UInt32), bitmap_col2 AggregateFunction(bitmap, UInt32));
INSERT INTO test_table1 VALUES (1, bitmapBuild([1, 2, 3])), (2, bitmapBuild([3, 4, 5])), (3, bitmapBuild([6, 7, 8]));
SELECT bitmapToArray(bitmapXor(bitmap_col1, bitmap_col2)) AS result FROM test_table1;
CREATE TABLE test_table2 (id UInt32, bitmap_col AggregateFunction(bitmap, UInt32));
INSERT INTO test_table2 VALUES (1, bitmapBuild([1, 2])), (2, bitmapBuild([2, 3])), (3, bitmapBuild([3, 4]));
SELECT bitmapToArray(bitmapXor(b1.bitmap, b2.bitmap)) AS res FROM (SELECT bitmap_col AS bitmap FROM test_table1) AS b1 JOIN (SELECT bitmap_col AS bitmap FROM test_table2) AS b2 ON b1.id = b2.id;
SELECT bitmapToArray(bitmapXor(bitmapBuild([1, 2, 3]), bitmapBuild([]))) AS empty_result;
SELECT bitmapToArray(bitmapXor(bitmapBuild([]), bitmapBuild([]))) AS empty_xor;
SELECT bitmapToArray(bitmapXor(bitmapBuild([1]), bitmapBuild([1]))) AS single_result;
SELECT bitmapToArray(bitmapXor(bitmapBuild([1, 2]), bitmapBuild([1, 2, 3, 4]))) AS complex_result;
CREATE TABLE test_table3 (group_id UInt32, user_bitmap AggregateFunction(bitmap, UInt32));
INSERT INTO test_table3 VALUES (1, bitmapBuild([1, 2, 3])), (1, bitmapBuild([2, 3, 4])), (2, bitmapBuild([5, 6, 7]));
SELECT group_id, bitmapToArray(bitmapXor(user_bitmap)) AS aggregated_result FROM test_table3 GROUP BY group_id;
SELECT bitmapToArray(bitmapXor(bitmapBuild([1, 2, 3]), bitmapXor(bitmapBuild([3, 4]), bitmapBuild([5])))) AS nested_xor;