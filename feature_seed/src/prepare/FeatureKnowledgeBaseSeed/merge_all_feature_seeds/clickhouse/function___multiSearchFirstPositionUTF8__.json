CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('hello world');
SELECT multiSearchFirstPositionUTF8(haystack, ['wor', 'ld', 'ello']) FROM test_strings;
CREATE TABLE test_needles (needle Array(String));
INSERT INTO test_needles VALUES (['wor', 'ld', 'ello']);
SELECT multiSearchFirstPositionUTF8(haystack, needle) FROM test_strings, test_needles;
CREATE TABLE multi_search_test (haystack String, needle Array(String));
INSERT INTO multi_search_test VALUES ('hello world', ['wor', 'ld', 'ello']);
SELECT multiSearchFirstPositionUTF8(haystack, needle) FROM multi_search_test;
WITH (SELECT multiSearchFirstPositionUTF8(haystack, ['wor', 'ld', 'ello']) FROM test_strings) AS pos SELECT * FROM test_strings, multi_search_test WHERE pos > 0;
SELECT multiSearchFirstPositionUTF8(haystack, ['notfound']) FROM test_strings;
SELECT multiSearchFirstPositionUTF8('abcdef', ['a', 'b', 'c', 'd', 'e', 'f']) FROM test_strings;
SELECT multiSearchFirstPositionUTF8('abcdabcd', ['bc', 'cd', 'da']) AS position;
CREATE TABLE haystack_test (haystack String) ENGINE = MergeTree() ORDER BY (haystack);
INSERT INTO haystack_test VALUES ('sample string for testing purposes');
SELECT multiSearchFirstPositionUTF8(haystack, ['test', 'sample', 'notfound']) FROM haystack_test;
SELECT multiSearchFirstPositionUTF8('complex string with multiple possibilities', ['possibilities', 'other', 'complex']);
WITH (SELECT haystack FROM haystack_test) AS h SELECT multiSearchFirstPositionUTF8(h, ['testing']) FROM h;