CREATE TABLE test_strings (str1 String, str2 String);
INSERT INTO test_strings VALUES ('clickhouse', 'click');
INSERT INTO test_strings VALUES ('test', 'test');
INSERT INTO test_strings VALUES ('similarity', 'similari');
INSERT INTO test_strings VALUES ('', 'non-empty');
INSERT INTO test_strings VALUES ('non-empty', '');
INSERT INTO test_strings VALUES ('', '');
SELECT jaroSimilarity(str1, str2) FROM test_strings;
SELECT str1, str2, jaroSimilarity(str1, str2) as similarity FROM test_strings WHERE str1 != '';
SELECT str1, str2, jaroSimilarity(str1, str2) as similarity FROM test_strings WHERE LENGTH(str1) > 0 AND LENGTH(str2) > 0;
CREATE TABLE other_strings (str3 String, str4 String);
INSERT INTO other_strings VALUES ('nearly', 'nearl');
INSERT INTO other_strings VALUES ('same', 'sane');
SELECT a.str1, b.str3, jaroSimilarity(a.str1, b.str3) as similarity FROM test_strings a JOIN other_strings b ON LENGTH(a.str1) >= 3 AND LENGTH(b.str3) >= 3;
WITH (SELECT COUNT(*) FROM test_strings) AS total FROM test_strings, (SELECT jaroSimilarity('hello', 'hallo') AS sim_value) AS sim WHERE sim_value > 0.8;
SELECT jaroSimilarity(CONCAT('data', 'base'), CONCAT('data', 'bse')) AS similarity;
SELECT jaroSimilarity('abc', 'xyz') AS similarity;
SELECT jaroSimilarity('A string with mixed case', 'a STRING WITH Mixed Case') AS similarity;