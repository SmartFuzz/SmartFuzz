CREATE TABLE test_table (numbers Tuple(Int32, Int32, Int32));
INSERT INTO test_table VALUES ((15, 10, 5));
SELECT tupleModuloByNumber(numbers, 2) FROM test_table;
SELECT tupleModuloByNumber((1, 0, 3), 1);
SELECT tupleModuloByNumber((7, 14, 21, 28), 5) AS mod_results;
CREATE TABLE div_table (divisor Float64);
INSERT INTO div_table VALUES (0), (2), (3);
SELECT t.numbers, tupleModuloByNumber(t.numbers, d.divisor) FROM test_table AS t, div_table AS d WHERE d.divisor > 0;
WITH (SELECT tupleModuloByNumber((100, 200, 300), 7)) AS mod_results SELECT * FROM system.one;
SELECT tupleModuloByNumber((15, 10, 5), div_table.divisor) FROM div_table WHERE div_table.divisor != 0;
SELECT tupleModuloByNumber((3, 5, 8, 12), 0);