CREATE TABLE geo_point (p Point) ENGINE = Memory();
INSERT INTO geo_point VALUES((0, 0));
INSERT INTO geo_point VALUES((1, 1));
INSERT INTO geo_point VALUES((-1, -1));
INSERT INTO geo_point VALUES((1000000, 1000000));
INSERT INTO geo_point VALUES((1.5, 2.5));
INSERT INTO geo_point VALUES((10.1, 20.2));
INSERT INTO geo_point VALUES((NULL, NULL));
SELECT p, toTypeName(p) FROM geo_point;
CREATE TABLE geo_point_2 (p Point) ENGINE = Memory();
INSERT INTO geo_point_2 VALUES((5, 5));
INSERT INTO geo_point_2 SELECT (p.1 + 1, p.2 + 1) FROM geo_point;
SELECT a.p, b.p FROM geo_point a JOIN geo_point_2 b ON a.p = (b.p.1, b.p.2);
WITH (SELECT (10, 10) AS p) AS subquery SELECT toTypeName(p) FROM subquery;
CREATE TABLE geo_point_summary AS SELECT toTypeName(p) AS point_type, count(*) AS count FROM geo_point GROUP BY point_type;
SELECT point_type, count FROM geo_point_summary WHERE count > 0;
CREATE TABLE geo_point_nested AS SELECT (p.1, p.2) AS coords FROM geo_point;
SELECT coords, toTypeName(coords) FROM geo_point_nested;