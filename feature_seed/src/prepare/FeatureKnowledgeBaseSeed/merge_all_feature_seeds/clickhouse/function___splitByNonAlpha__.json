CREATE TABLE test_strings (input_string String);
INSERT INTO test_strings VALUES ('  !1a 2b, c. 3d?  '), ('Separate: each;
part?;
example.'), ('Just letters'), ('__underscore____test__'), ('  ');
SELECT splitByNonAlpha(input_string) FROM test_strings;
SELECT splitByNonAlpha(input_string, 3) FROM test_strings;
SELECT arrayJoin(splitByNonAlpha(input_string)) AS substrings FROM test_strings;
WITH splitByNonAlpha(input_string) AS substrings SELECT substrings FROM test_strings WHERE arrayLength(substrings) > 2;
SELECT t1.input_string, splitByNonAlpha(t1.input_string, 2) AS substrings FROM test_strings AS t1 JOIN (SELECT 'join test data' AS join_string) AS t2 ON t1.input_string LIKE '%test%';
SELECT splitByNonAlpha(input_string, 0) AS substrings, arrayJoin(substrings) AS single_substring FROM test_strings;
SELECT splitByNonAlpha('NonAlpha123:       hello, world!@#$%^&*()') AS split_result;
CREATE TABLE processed_strings AS SELECT splitByNonAlpha(input_string) AS substrings FROM test_strings;
SELECT input_string, splitByNonAlpha(input_string, 4) AS limited_result FROM test_strings;