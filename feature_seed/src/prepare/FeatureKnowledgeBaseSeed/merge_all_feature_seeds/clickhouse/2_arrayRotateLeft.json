CREATE TABLE test_arrays (id UInt32, arr Array(Int32), val Int32);
INSERT INTO test_arrays VALUES (1, [1, 2, 3, 4, 5, 6], 2), (2, [7, 8, 9, 10], -1), (3, [], 0), (4, [NULL], -2);
SELECT id, arrayRotateLeft(arr, val) as rotated_array FROM test_arrays WHERE arrayRotateLeft(arr, val) < arr;
SELECT id, arrayRotateLeft(arr, val) as rotated_array FROM test_arrays WHERE arrayRotateLeft(arr, 3) < arrayRotateLeft(arr, -1);
WITH (SELECT AVG(val) FROM test_arrays WHERE val IS NOT NULL) as avg_val SELECT id, arrayRotateLeft(arr, val) AS rotated FROM test_arrays GROUP BY id HAVING COUNT(*) < avg_val;
SELECT id, arrayRotateLeft(arr, (SELECT COUNT() FROM test_arrays WHERE id < 3)) as rotated_array FROM test_arrays ORDER BY rotated_array < arr;
CREATE TEMPORARY TABLE temp AS SELECT id, arrayRotateLeft(arr, if(val < 0, -val, val)) as rotated FROM test_arrays;
SELECT * FROM temp WHERE rotated < arr;
UPDATE test_arrays SET val = val + 1 WHERE arrayRotateLeft(arr, val) IS NOT NULL;
DROP TABLE IF EXISTS test_arrays;