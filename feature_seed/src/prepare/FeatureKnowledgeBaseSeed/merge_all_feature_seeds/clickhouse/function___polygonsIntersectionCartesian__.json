CREATE TABLE polygons1 (id UInt32, geom Array(Array(Array(Float64))));
INSERT INTO polygons1 VALUES (1, [[[(0., 0.), (0., 3.), (1., 2.9), (2., 2.6), (2.6, 2.), (2.9, 1.), (3., 0.), (0., 0.)]]]);
CREATE TABLE polygons2 (id UInt32, geom Array(Array(Array(Float64))));
INSERT INTO polygons2 VALUES (1, [[[(1., 1.), (1., 4.), (4., 4.), (4., 1.), (1., 1.)]]]);
SELECT wkt(polygonsIntersectionCartesian((SELECT geom FROM polygons1 WHERE id = 1), (SELECT geom FROM polygons2 WHERE id = 1))) AS intersection;
CREATE TABLE complex_polygons1 (id UInt32, geom Array(Array(Array(Float64))), name String);
INSERT INTO complex_polygons1 VALUES (1, [[[(0., 0.), (5., 0.), (5., 5.), (0., 5.), (0., 0.)]]], 'Square1');
INSERT INTO complex_polygons1 VALUES (2, [[[(3., 3.), (6., 3.), (6., 6.), (3., 6.), (3., 3.)]]], 'Square2');
SELECT name, wkt(polygonsIntersectionCartesian(geom, (SELECT geom FROM complex_polygons1 WHERE id = 2))) AS intersection FROM complex_polygons1 WHERE id = 1;
SELECT COUNT(*) FROM complex_polygons1 WHERE wkt(polygonsIntersectionCartesian(geom, (SELECT geom FROM complex_polygons1 WHERE id = 1))) IS NOT NULL;
CREATE TABLE additional_polygons (id UInt32, geom Array(Array(Array(Float64)));
INSERT INTO additional_polygons VALUES (1, [[[(2., 2.), (4., 2.), (4., 4.), (2., 4.), (2., 2.)]]]);
SELECT wkt(polygonsIntersectionCartesian((SELECT geom FROM polygons1 WHERE id = 1), (SELECT geom FROM additional_polygons WHERE id = 1))) AS intersection;
SELECT wkt(polygonsIntersectionCartesian(geom, (SELECT geom FROM additional_polygons WHERE id = 1))) AS intersection FROM complex_polygons1;