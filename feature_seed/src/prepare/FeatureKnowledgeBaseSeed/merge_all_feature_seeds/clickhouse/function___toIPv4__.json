CREATE TABLE ipv4_test (ip_address String);
INSERT INTO ipv4_test VALUES ('0.0.0.0'), ('255.255.255.255'), ('192.168.1.1'), ('10.0.0.1');
SELECT toIPv4(ip_address) FROM ipv4_test;
SELECT toIPv4(CONCAT('192.', '168.', '0.', '1')) AS ipv4_address FROM ipv4_test;
SELECT * FROM ipv4_test WHERE ip_address = '171.225.130.45';
WITH ('171.225.130.45') AS IPv4_string SELECT toIPv4(IPv4_string) AS ipv4_address;
SELECT ip_address, hex(toIPv4(ip_address)) FROM ipv4_test WHERE ip_address LIKE '%.1.1';
CREATE TABLE ipv4_conversion (original String, converted IPv4);
INSERT INTO ipv4_conversion SELECT ip_address, toIPv4(ip_address) FROM ipv4_test;
SELECT original, converted FROM ipv4_conversion WHERE converted IS NOT NULL;
WITH (SELECT ip_address FROM ipv4_test WHERE ip_address LIKE '192.168.%') AS subquery SELECT toIPv4(ip_address) FROM subquery;
SELECT DISTINCT toIPv4(ip_address) FROM ipv4_test WHERE toIPv4(ip_address) IN (SELECT toIPv4('255.255.255.0'));
SELECT AVG(toIPv4(ip_address)) FROM ipv4_test WHERE toIPv4(ip_address) IS NOT NULL;
SELECT 'The address is: ' || toIPv4('172.16.254.1') AS message;
SELECT a.ip_address, b.ip_address FROM ipv4_test AS a JOIN ipv4_test AS b ON toIPv4(a.ip_address) < toIPv4(b.ip_address);