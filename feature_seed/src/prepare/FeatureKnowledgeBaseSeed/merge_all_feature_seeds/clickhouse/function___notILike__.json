CREATE TABLE test_strings (id UInt32, content String);
INSERT INTO test_strings VALUES (1, 'Hello World'), (2, 'Goodbye World'), (3, 'hello universe'), (4, 'Greetings Earth'), (5, 'Welcome to the Programming World');
SELECT * FROM test_strings WHERE content NOT ILIKE '%hello%';
SELECT * FROM test_strings WHERE content NOT ILIKE 'Good%';
SELECT * FROM test_strings WHERE content NOT ILIKE 'Earth' AND content NOT ILIKE 'Goodbye World';
CREATE TABLE test_strings2 (id UInt32, description String);
INSERT INTO test_strings2 VALUES (1, 'Hello there'), (2, 'No match here'), (3, 'nothing special'), (4, 'Greetings to all');
SELECT ts.id, ts.content FROM test_strings ts JOIN test_strings2 ts2 ON ts.id = ts2.id WHERE ts.content NOT ILIKE ts2.description;
SELECT * FROM test_strings WHERE content NOT ILIKE CONCAT('%', (SELECT description FROM test_strings2 WHERE id = 1), '%');
SELECT * FROM test_strings ts WHERE NOT EXISTS (SELECT 1 FROM test_strings2 ts2 WHERE ts.content ILIKE ts2.description);
SELECT * FROM (SELECT content FROM test_strings WHERE content NOT ILIKE '%Programming%') AS unmatched WHERE unmatched.content NOT ILIKE '%World%';
CREATE TABLE keywords (keyword String);
INSERT INTO keywords VALUES ('hello'), ('world'), ('goodbye');
SELECT ts.content FROM test_strings ts WHERE NOT EXISTS (SELECT 1 FROM keywords kw WHERE ts.content ILIKE CONCAT('%', kw.keyword, '%'));