CREATE TABLE fuzz_test (id UInt32, value Float64, text String, nullable_value Nullable(Int32));
INSERT INTO fuzz_test VALUES (1, randExponential(-1), 'example1', NULL), (2, -randExponential(0.5), 'example2', 3), (3, randExponential(3.5), '', NULL);
SELECT id, value, text, (SELECT -avg(nullable_value) FROM fuzz_test WHERE nullable_value IS NOT NULL) AS avg_null_value FROM fuzz_test WHERE value > -randExponential(2);
SELECT id, value, text FROM fuzz_test f1 JOIN (SELECT id, -randExponential(0.1) AS neg_value FROM fuzz_test WHERE text != '') f2 ON f1.id = f2.id WHERE f1.value < -1.0 AND f2.neg_value < 0;
SELECT id, COUNT(*) AS count FROM fuzz_test GROUP BY id HAVING -randExponential(0.25) > 0 AND count > 1;
SELECT id, text, randExponential(1/CASE WHEN nullable_value IS NULL THEN 1 ELSE nullable_value END) AS random_dist FROM fuzz_test WHERE randExponential(0.1) < value;