CREATE DATABASE test_db;
CREATE TABLE test_db.test_table (id UInt32, name String) ENGINE = MergeTree() ORDER BY id;
SELECT EXISTS (SELECT * FROM test_db.test_table) AS exists_check;
SELECT EXISTS (SELECT * FROM test_db.non_existent_table) AS exists_check;
SELECT EXISTS (SELECT * FROM system.tables WHERE name = 'test_table' AND database = 'test_db') AS exists_check;
SELECT EXISTS (SELECT count() FROM test_db.test_table) AS exists_check;
SELECT EXISTS (SELECT * FROM test_db.test_table WHERE id = 1) AS exists_check;
SELECT EXISTS (SELECT * FROM system.databases WHERE name = 'test_db') AS exists_check;
SELECT EXISTS (SELECT name FROM system.tables WHERE database = 'test_db') AS exists_check;
SELECT EXISTS (SELECT * FROM system.tables WHERE name LIKE 'test%') AS exists_check;
SELECT EXISTS (SELECT * FROM system.tables WHERE name = 'non_existent_table' AND database = 'test_db') AS exists_check;
CREATE TABLE test_db.another_table (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
SELECT EXISTS (SELECT * FROM (SELECT * FROM test_db.test_table UNION ALL SELECT * FROM test_db.another_table)) AS exists_check;
SELECT EXISTS (SELECT * FROM (SELECT * FROM system.tables WHERE database = 'test_db') AS inner_query WHERE inner_query.name = 'test_table') AS exists_check;
SELECT EXISTS (SELECT 1 WHERE EXISTS (SELECT * FROM system.tables WHERE name = 'test_table' AND database = 'test_db')) AS exists_check;