CREATE TABLE h3_test2 AS SELECT index, h3ToParent(index, 3) AS parent_index FROM h3_test;
SELECT COUNT(*) FROM h3_test WHERE h3ToParent(index, resolution) IS NOT NULL;
SELECT index, resolution FROM h3_test ORDER BY h3ToParent(index, resolution) DESC;
CREATE TABLE complex_test (index UInt64, resolution UInt8);
INSERT INTO complex_test SELECT index, resolution FROM h3_test WHERE resolution >= 0;
SELECT ct.index, ct.resolution FROM complex_test ct JOIN h3_test ht ON ct.index = ht.index WHERE ht.resolution IN (0, 1, 2) AND h3ToParent(ct.index, ct.resolution) IS NOT NULL;
SELECT DISTINCT h3ToParent(index, resolution) FROM h3_test WHERE index IN (SELECT index FROM h3_test WHERE resolution = 2);
