CREATE TABLE h3_test (index UInt64, resolution UInt8, parent_index UInt64);
INSERT INTO h3_test VALUES (599405990164561919, 3, h3ToParent(599405990164561919, 3));
INSERT INTO h3_test VALUES (599405990164561920, 2, h3ToParent(599405990164561920, 2));
SELECT index, h3ToParent(index, resolution) AS parent FROM h3_test WHERE h3ToParent(index, resolution) IN (SELECT parent_index FROM h3_test);
SELECT index, h3ToParent(index, resolution) AS parent FROM h3_test HAVING parent IN (SELECT h3ToParent(599405990164561919, 2));
