CREATE TABLE test_dates (event_date Date, event_time DateTime);
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 10:00:00'));
INSERT INTO test_dates VALUES (toDate('2024-01-31'), toDateTime('2024-01-31 12:30:00'));
INSERT INTO test_dates VALUES (toDate('2024-02-29'), toDateTime('2024-02-29 15:45:00'));
WITH toDate('2024-01-01') AS date, toDateTime('2024-01-01 00:00:00') AS date_time, '2024-01-01 00:00:00' AS date_time_string SELECT subtractDays(date, 0) AS no_days_subtracted, subtractDays(date_time, 60) AS subtract_days_60, subtractDays(date_time_string, 1) AS subtract_days_1;
SELECT subtractDays(event_date, 15) AS mid_january_event_date FROM test_dates WHERE event_date = toDate('2024-01-01');
SELECT subtractDays(event_time, 1) AS event_time_subtracted FROM test_dates WHERE event_time > toDateTime('2024-01-01 00:00:00');
WITH (SELECT toDate('2024-01-01') AS sub_date) AS temp SELECT subtractDays(sub_date, (SELECT COUNT(*) FROM test_dates)) AS subtracted_date;
WITH (SELECT COUNT(*) AS days FROM test_dates) AS temp SELECT subtractDays(toDate('2024-03-01'), (SELECT days FROM temp)) AS deducted_days;
SELECT event_date, subtractDays(event_date, 30) AS thirty_days_prior FROM test_dates UNION SELECT toDate('2024-02-01'), subtractDays(toDate('2024-02-01'), 10);
SELECT subtractDays(t.event_date, 7) AS week_prior, t.event_time FROM test_dates t INNER JOIN (SELECT toDate('2024-01-31') AS ref_date) AS ref ON t.event_date = ref.ref_date;
CREATE TABLE reference_dates (due_date Date) ENGINE = MergeTree() ORDER BY due_date;
INSERT INTO reference_dates VALUES (toDate('2024-03-01'));
SELECT due_date, subtractDays(due_date, 45) AS updated_due_date FROM reference_dates;