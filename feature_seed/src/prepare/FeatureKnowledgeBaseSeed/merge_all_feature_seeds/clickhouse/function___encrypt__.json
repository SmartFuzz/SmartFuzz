CREATE TABLE encryption_test( `comment` String, `secret` String) ENGINE = Memory;
INSERT INTO encryption_test VALUES ('aes-128-ecb no IV', encrypt('aes-128-ecb', 'Secret', '1234567891012131')), ('aes-192-ecb no IV', encrypt('aes-192-ecb', 'Secret', '123456789101213141516'));
INSERT INTO encryption_test VALUES ('aes-256-cbc with IV', encrypt('aes-256-cbc', 'Secret', '12345678910121314151617181920212', 'initialvector123')), ('aes-128-ctr with IV', encrypt('aes-128-ctr', 'Secret', '1234567891012131', 'initialvector123'));
INSERT INTO encryption_test VALUES ('aes-192-gcm with AAD', encrypt('aes-192-gcm', 'Secret', '123456789101213141516', 'iviviviviviviviv', 'extraaad'));
SELECT comment, hex(secret) FROM encryption_test WHERE comment LIKE '%no IV%';
SELECT comment, hex(secret) FROM encryption_test WHERE comment LIKE '%gcm%' AND comment NOT LIKE '%no IV%';
CREATE TABLE additional_test( `id` UInt32, `data` String) ENGINE = Memory;
INSERT INTO additional_test VALUES (1, 'SampleData1'), (2, 'SampleData2');
SELECT a.comment, hex(a.secret), b.data FROM encryption_test AS a JOIN additional_test AS b ON a.comment LIKE '%gcm%' WHERE b.id = 1;
INSERT INTO encryption_test SELECT concat(comment, ' + new entry'), encrypt('aes-256-ctr', 'NewSecret', '12345678910121314151617181920212') FROM encryption_test WHERE comment LIKE '%no IV%';
CREATE TABLE further_test( `lookup` String, `encrypted_data` String) ENGINE = Memory;
INSERT INTO further_test SELECT 'Test A', encrypt('aes-128-ofb', 'Hello World', '1234567891012131'), ('Test B', encrypt('aes-192-ofb', 'Hello Again', '123456789101213141516'));
SELECT f.lookup, hex(f.encrypted_data) FROM further_test AS f WHERE f.lookup LIKE 'Test%';