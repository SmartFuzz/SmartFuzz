CREATE TABLE geo_linestring_1 (l LineString) ENGINE = Memory();
INSERT INTO geo_linestring_1 VALUES([(1, 1), (2, 2), (3, 3)]);
CREATE TABLE geo_linestring_2 (l LineString) ENGINE = Memory();
INSERT INTO geo_linestring_2 VALUES([(5, 5), (6, 6), (7, 7), (8, 8)]);
SELECT l, toTypeName(l) FROM geo_linestring_1;
SELECT l, toTypeName(l) FROM geo_linestring_2;
CREATE TABLE combined_linestring AS SELECT l FROM geo_linestring_1 UNION ALL SELECT l FROM geo_linestring_2;
SELECT count(*) FROM combined_linestring;
SELECT l, length(l) AS line_length FROM geo_linestring_1;
SELECT l, arrayJoin(l) AS points FROM geo_linestring_2;
CREATE TABLE geo_linestring_geo (id UInt32, l LineString) ENGINE = Memory();
INSERT INTO geo_linestring_geo VALUES (1, [(0, 0), (3, 4)]), (2, [(2, 3), (5, 1)]);
SELECT id, l FROM geo_linestring_geo WHERE length(l) > 5;
SELECT g1.l, g2.l FROM geo_linestring_1 AS g1 JOIN geo_linestring_2 AS g2 ON length(g1.l) = length(g2.l);
INSERT INTO geo_linestring_geo SELECT id, l FROM geo_linestring_2;
SELECT id, toTypeName(l) FROM geo_linestring_geo WHERE id = 1;
SELECT l, arrayMap(x -> (x.1 + 1, x.2 + 1), l) AS shifted_line FROM geo_linestring_1;