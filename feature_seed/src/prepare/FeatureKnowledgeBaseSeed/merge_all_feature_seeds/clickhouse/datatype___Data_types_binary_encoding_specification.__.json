CREATE TABLE test_binary_encoding (id UInt8, name String, created_date DateTime, value Float64) ENGINE = Memory;
INSERT INTO test_binary_encoding VALUES (1, 'example', '2023-10-10 10:00:00', 123.45);
INSERT INTO test_binary_encoding VALUES (2, 'test', '2023-10-10 12:00:00', 678.90);
SELECT * FROM test_binary_encoding WHERE id < 3;
CREATE TABLE test_nested (id UInt8, values Array(UInt8)) ENGINE = Memory;
INSERT INTO test_nested VALUES (1, [1, 2, 3]), (2, [4, 5, 6]);
SELECT id, arraySum(values) AS total_sum FROM test_nested WHERE total_sum > 7;
CREATE TABLE nested_table (id UInt8, val Tuple(name String, age UInt8), valid Bool) ENGINE = Memory;
INSERT INTO nested_table VALUES (1, ('John', 30), true), (2, ('Alice', 25), false);
SELECT id, val.1 AS name FROM nested_table WHERE valid = true;
CREATE TABLE complex_table (id UInt8, arr Array(Int32), rec Nested (name String, age UInt8)) ENGINE = Memory;
INSERT INTO complex_table VALUES (1, [10, 20, 30], [('John', 30), ('Doe', 40)]);
SELECT id, arr, rec.name FROM complex_table WHERE arrayCount(arr) > 2;
CREATE TABLE joined_table1 (id UInt8, value Float32) ENGINE = Memory;
CREATE TABLE joined_table2 (id UInt8, description String) ENGINE = Memory;
INSERT INTO joined_table1 VALUES (1, 100.5), (2, 200.5);
INSERT INTO joined_table2 VALUES (1, 'first'), (2, 'second');
SELECT a.id, b.description FROM joined_table1 a JOIN joined_table2 b ON a.id = b.id WHERE a.value > 150;
CREATE TABLE json_data (data JSON) ENGINE = Memory;
INSERT INTO json_data VALUES ('{"key":"value"}');
SELECT data->>'key' AS value FROM json_data;
CREATE TABLE function_table (date_time DateTime, aggregate_data AggregateFunction(sum, Float64)) ENGINE = Memory;
INSERT INTO function_table VALUES ('2023-10-10 10:00:00', sum(100.5)), ('2023-10-10 11:00:00', sum(200.5));
SELECT date_time, sumMerge(aggregate_data) AS total FROM function_table GROUP BY date_time;