CREATE TABLE test_table (id Int32, value Nullable(Int32), name String, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table (id, value, name, created_at) VALUES (1, NULL, 'alpha', '2023-10-01 00:00:00'), (2, 10, 'beta', '2023-10-02 00:00:00'), (3, 20, 'gamma', '2023-10-03 00:00:00'), (4, 30, 'delta', '2023-10-04 00:00:00');
SELECT id, multiIf(value IS NULL, 'Value is Null', value != 10, 'Not Ten', value = 20, 'Twenty', 'Others') AS result FROM test_table WHERE created_at > '2023-09-30 00:00:00';
SELECT id, multiIf(value IS NULL, 'Value is Null', notEquals(value, 10), 'Not Ten', notEquals(value, 20), 'Not Twenty', 'Others') AS result FROM test_table WHERE name != 'alpha';
SELECT id, value, COUNT(*) AS count FROM (SELECT id, multiIf(name = 'beta', value + 5, value) AS value FROM test_table) GROUP BY id, value HAVING count < 2;
CREATE TABLE nested_test (id Int32, parent_id Nullable(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO nested_test (id, parent_id) VALUES (1, NULL), (2, 1), (3, 1), (4, 2);
SELECT nt.id, multiIf(nt.parent_id IS NULL, 'No Parent', nt.parent_id != 1, 'Other Parent', 'Directly Child') AS hierarchical FROM nested_test nt JOIN test_table tt ON multiIf(tt.value IS NULL, nt.parent_id IS NULL, nt.parent_id != tt.id) WHERE tt.created_at >= '2023-10-01 00:00:00';
SELECT id, value, multiIf(value IS NOT NULL, intDiv(value, 2), NULL) AS halved_value FROM test_table WHERE multiIf(value = 20, TRUE, FALSE) != FALSE;
SELECT id, multiIf(multiIf(value IS NULL, 0, value) != 10, value + 1, value) AS adjusted_value FROM test_table HAVING adjusted_value != 21;