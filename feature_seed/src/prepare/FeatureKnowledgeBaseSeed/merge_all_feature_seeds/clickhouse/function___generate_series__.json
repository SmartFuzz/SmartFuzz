CREATE TABLE test_series (value UInt64);
INSERT INTO test_series SELECT generate_series(1, 10);
SELECT value FROM test_series WHERE value IN (SELECT generate_series(1, 5));
SELECT SUM(value) FROM test_series WHERE value BETWEEN 3 AND 7;
SELECT * FROM generate_series(0, 100, 10);
SELECT COUNT(*) FROM (SELECT * FROM generate_series(1, 20, 2) WHERE number > 5) AS subquery;
SELECT a.value, b.value FROM (SELECT * FROM generate_series(1, 5)) AS a JOIN (SELECT * FROM generate_series(10, 15)) AS b ON a.value + 10 = b.value;
SELECT AVG(value) FROM (SELECT generate_series(0, 50, 5)) AS series;
SELECT * FROM generate_series(5, 1) LIMIT 10;
SELECT * FROM generate_series(1, 1000) AS gs WHERE gs % 100 = 0;
SELECT x.value FROM (SELECT generate_series(1, 5) AS value) AS x WHERE value < 4;
CREATE TABLE series_test AS SELECT generate_series(1, 50);
SELECT MAX(value) FROM series_test;
SELECT MIN(value) FROM (SELECT generate_series(10, 100, 10)) AS t;
SELECT COUNT(*) FROM generate_series(1, 100) WHERE number % 2 = 0;
SELECT gs1.value, gs2.value FROM generate_series(1, 5) AS gs1, generate_series(1, 5) AS gs2 WHERE gs1.value + gs2.value = 6;
SELECT value FROM generate_series(1, 10) UNION SELECT value FROM generate_series(5, 15);
SELECT * FROM (SELECT generate_series(1, 20) AS series)a WHERE series > 10 ORDER BY series DESC;