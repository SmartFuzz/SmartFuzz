CREATE TABLE h3_indexes (index UInt64);
INSERT INTO h3_indexes VALUES (0), (612916788725809151), (9223372036854775807), (18446744073709551615);
SELECT h3GetBaseCell(index) AS basecell FROM h3_indexes WHERE index BETWEEN 0 AND 612916788725809151;
SELECT h3GetBaseCell(index) AS basecell FROM h3_indexes WHERE index = 0;
SELECT h3GetBaseCell(index) AS basecell FROM h3_indexes WHERE index = 612916788725809151;
SELECT h3GetBaseCell(index) AS basecell FROM h3_indexes WHERE index = 9223372036854775807;
SELECT h3GetBaseCell(index) AS basecell FROM h3_indexes WHERE index = 18446744073709551615;
SELECT h3GetBaseCell(index) AS basecell FROM h3_indexes HAVING basecell IS NOT NULL;
SELECT (SELECT h3GetBaseCell(index) FROM h3_indexes LIMIT 1) AS basecell_subquery;
SELECT t1.index, h3GetBaseCell(t1.index) AS basecell FROM h3_indexes AS t1 JOIN h3_indexes AS t2 ON t1.index > t2.index;
SELECT DISTINCT h3GetBaseCell(t1.index) FROM h3_indexes AS t1 INNER JOIN h3_indexes AS t2 ON t1.index < t2.index;
WITH (SELECT index FROM h3_indexes WHERE index > 0) AS positive_indexes SELECT h3GetBaseCell(index) FROM positive_indexes;
CREATE TABLE h3_test AS SELECT index, h3GetBaseCell(index) AS basecell FROM h3_indexes;
SELECT COUNT(*), h3GetBaseCell(index) AS basecell FROM h3_indexes GROUP BY basecell HAVING COUNT(*) > 1;