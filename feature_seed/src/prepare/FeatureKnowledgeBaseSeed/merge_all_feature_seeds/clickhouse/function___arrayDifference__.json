CREATE TABLE test_array_diff (numbers Array(Int32));
INSERT INTO test_array_diff VALUES ([1, 2, 3, 4]);
SELECT arrayDifference(numbers) FROM test_array_diff;
INSERT INTO test_array_diff VALUES ([0, 10000000000000000000]);
SELECT arrayDifference(numbers) FROM test_array_diff;
CREATE TABLE test_complex (id UInt32, array_data Array(Int32));
INSERT INTO test_complex VALUES (1, [10, 20, 30]), (2, [5, 15, 25]), (3, [0, 0, 0]);
SELECT id, arrayDifference(array_data) FROM test_complex;
SELECT id, arrayDifference(array_data) AS differences FROM test_complex WHERE id = 2;
CREATE TABLE nested AS SELECT arrayDifference([1, 2, 3]) AS diff;
CREATE TABLE temp AS SELECT arrayDifference([10, 20, 30]) AS differences UNION ALL SELECT arrayDifference([5, 15, 25]);
SELECT * FROM temp;
CREATE TABLE ref_table (a Array(Int32));
INSERT INTO ref_table VALUES ([10, 20, 30]), ([1, 2, 3, 4]);
SELECT a, arrayDifference(a) FROM ref_table;
INSERT INTO test_complex SELECT id, arrayDifference(array_data) FROM ref_table;
SELECT id, arrayDifference(array_data) FROM test_complex WHERE arrayLength(array_data) > 2;
SELECT id, arrayDifference(array_data) FROM test_complex WHERE id IN (SELECT id FROM test_complex WHERE arrayLength(array_data) >= 2);