CREATE TABLE test_divide_notlike (id UInt32, value1 Float64, value2 Float64, text_value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_divide_notlike VALUES (1, 10.5, 2.0, 'Test String'), (2, 0, 0, 'Sample Text'), (3, NULL, 5.0, 'NULL Test'), (4, 5.0, 0, 'Edge Case');
SELECT id, divide(value1, value2) AS quotient FROM test_divide_notlike WHERE text_value NOT LIKE 'Sample%' AND text_value NOT LIKE '';
SELECT id, value1, value2, divide(value1, value2) AS quotient FROM test_divide_notlike WHERE value1 != 0 OR (value1 = 0 AND text_value NOT LIKE 'Edge%') GROUP BY id, value1, value2 HAVING quotient NOT LIKE 'inf' AND quotient NOT LIKE '-inf';
WITH (SELECT id, divide(value1, value2) AS div_res FROM test_divide_notlike) AS derived_table SELECT id, div_res FROM derived_table WHERE div_res NOT LIKE 'nan' AND div_res NOT LIKE '%0%';
SELECT id, text_value, (select count() FROM test_divide_notlike t2 WHERE t2.text_value NOT LIKE test_divide_notlike.text_value) AS text_count FROM test_divide_notlike WHERE divide(value1, NULLIF(value2, 0)) NOT LIKE 'nan';