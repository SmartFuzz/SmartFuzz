CREATE TABLE tab1 (a Map(String, String)) ENGINE = Memory;
INSERT INTO tab1 VALUES ({'abc':'abc','def':'def'}), ({'xyz':'xyz','abc123':'abc123'}, {'emp':'employee','fan':'fan'});
SELECT mapExtractKeyLike(a, 'a%') FROM tab1;
CREATE TABLE tab2 (b Map(String, String)) ENGINE = Memory;
INSERT INTO tab2 VALUES ({'apple':'fruit','banana':'fruit'}), ({'cherry':'fruit','grape':'fruit'});
SELECT mapExtractKeyLike(b, '%e%') FROM tab2;
CREATE TABLE tab3 (c Map(String, String)) ENGINE = Memory;
INSERT INTO tab3 VALUES ({'name1':'value1','name2':'value2'}), ({'name3':'value3','name4':'value4'}, {'key1':'value5','key2':'value6'});
SELECT mapExtractKeyLike(c, 'name%') FROM tab3 WHERE mapExtractKeyLike(c, 'name%') != map();
CREATE TABLE combined (d Map(String, String), e String) ENGINE = Memory;
INSERT INTO combined VALUES ({'s1':'x','s2':'y'}, 'first'), ({'s3':'z','s4':'w'}, 'second');
SELECT e, mapExtractKeyLike(d, 's%') FROM combined WHERE e = 'first';
SELECT mapExtractKeyLike(a, 'x%') AS result FROM tab1 UNION ALL SELECT mapExtractKeyLike(b, '%a%') AS result FROM tab2;
SELECT mapExtractKeyLike(d, 's%') FROM combined WHERE e IN (SELECT e FROM combined WHERE e LIKE 'first%');
SELECT mapExtractKeyLike(a, 'def') FROM tab1 WHERE mapExtractKeyLike(a, 'd%') = map();