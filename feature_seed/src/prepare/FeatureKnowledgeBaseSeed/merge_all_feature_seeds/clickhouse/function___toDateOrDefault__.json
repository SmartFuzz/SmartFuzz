CREATE TABLE dates_table (date_string String, default_date Date);
INSERT INTO dates_table VALUES ('2022-03-15', '2020-01-01'), ('', '2023-01-01'), ('invalid_date', '2021-07-01');
SELECT toDateOrDefault(date_string, '2023-01-01') FROM dates_table;
SELECT toDateOrDefault(date_string) FROM dates_table WHERE date_string != '';
SELECT toDateOrDefault(date_string, toDate('2022-01-01')) AS converted_date FROM dates_table WHERE date_string IS NOT NULL;
CREATE TABLE another_table (id UInt32, value String);
INSERT INTO another_table VALUES (1, '2022-04-10'), (2, 'invalid_value');
SELECT id, toDateOrDefault(value, '2020-01-01') AS converted_date FROM another_table;
SELECT t1.id, toDateOrDefault(t1.value, toDate('2023-01-01')) AS convertedDate FROM another_table t1 JOIN dates_table t2 ON t1.id = 1;
SELECT COUNT(*) FROM dates_table WHERE toDateOrDefault(date_string, '1900-01-01') > toDate('2000-01-01');
SELECT MAX(toDateOrDefault(date_string, today())) AS max_date FROM dates_table;