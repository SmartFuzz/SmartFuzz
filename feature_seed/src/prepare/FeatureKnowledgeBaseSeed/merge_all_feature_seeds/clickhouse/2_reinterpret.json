CREATE TABLE test_table (id UInt32, value String, score Float32, status UInt8);
INSERT INTO test_table VALUES (1, 'test1', 1.5, 1), (2, 'test2', -2.6, 0), (3, NULL, 3.1, 1);
SELECT reinterpret(value, 'UInt8') as interpreted_value, reinterpret(score, 'String') as reinterpret_float_string FROM test_table WHERE reinterpret(value, 'UInt8') ILIKE '1' OR status ILIKE '0';
SELECT t1.id, t1.value, t2.score FROM test_table t1 JOIN (SELECT id, reinterpret(score, 'String') as score_string FROM test_table WHERE score < 0) t2 ON t1.id = t2.id;
SELECT COUNT(*) FROM (SELECT reinterpret(NULLIF(value, ''), 'UInt8') as safe_value FROM test_table) WHERE safe_value ILIKE '0' GROUP BY safe_value HAVING COUNT(*) > 0;
SELECT id, score, value ILIKE reinterpret(score, 'String') as score_str_comparison FROM test_table ORDER BY reinterpret(score, 'String');
SELECT reinterpret(score, 'UInt8') AS score_uint8, search_value FROM (SELECT score, reinterpret(value, 'String') as search_value FROM test_table) WHERE score_uint8 ILIKE '2' OR search_value ILIKE '%test%';
CREATE TABLE temp_table AS SELECT reinterpret(value, 'UInt8') AS temp_value FROM test_table;
INSERT INTO temp_table SELECT reinterpret(NULL, 'UInt8') AS temp_value;
SELECT * FROM temp_table WHERE temp_value IS NOT NULL;