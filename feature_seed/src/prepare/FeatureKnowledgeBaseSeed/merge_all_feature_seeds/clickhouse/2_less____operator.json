CREATE TABLE test_dates (id UInt32, start_date DateTime, end_date DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_dates VALUES (1, now(), now() + INTERVAL 1 DAY), (2, now() - INTERVAL 2 HOUR, now() + INTERVAL 5 DAY);
SELECT id, less(end_date, start_date + INTERVAL 1 HOUR) AS is_before FROM test_dates WHERE is_before IS NOT NULL;
SELECT id, start_date, end_date FROM test_dates WHERE less(end_date, start_date + INTERVAL '1 hour') AND start_date IS NOT NULL;
SELECT id, (start_date + INTERVAL 2 DAY) AS new_start_date, less(new_start_date, end_date) AS comparison FROM test_dates HAVING comparison = 1;
WITH (SELECT count(*) FROM test_dates) AS total FROM test_dates WHERE total < 10;
SELECT id FROM test_dates t1 JOIN test_dates t2 ON less(t1.start_date, t2.start_date + INTERVAL 1 DAY) WHERE t1.id != t2.id;
CREATE TABLE temp_test_dates AS SELECT * FROM test_dates WHERE less(end_date, start_date + INTERVAL 10 MINUTE);
INSERT INTO temp_test_dates SELECT *, now() AS reference_time FROM test_dates WHERE reference_time IS NOT NULL AND less(start_date, reference_time);
SELECT start_date, end_date, less(end_date, start_date) AS is_invalid FROM test_dates HAVING is_invalid = 1;