CREATE TABLE test_table (id UInt32, name String, description String, value Float64);
INSERT INTO test_table VALUES (1, 'Test', 'Description without end char', 9.99);
INSERT INTO test_table VALUES (2, 'Another', 'Another desc', NULL);
INSERT INTO test_table VALUES (3, '', 'Empty string', 1.23);
SELECT id, appendTrailingCharIfAbsent(name, 'X') AS modified_name FROM test_table WHERE name != '' AND value > 5.00;
SELECT id, appendTrailingCharIfAbsent((SELECT name FROM test_table WHERE id = 1 LIMIT 1), 'X') AS modified_name FROM test_table WHERE id < 5;
SELECT id, value FROM test_table WHERE description LIKE '%end char' AND appendTrailingCharIfAbsent(name, 'X') != name;
SELECT id, appendTrailingCharIfAbsent(name, ' ') AS modified_name FROM (SELECT id, name FROM test_table WHERE value IS NOT NULL) AS subquery WHERE modified_name != name;
SELECT id FROM test_table WHERE appendTrailingCharIfAbsent(name, 'X') AND value IS NOT NULL AND (SELECT COUNT(*) FROM test_table WHERE value > 0) > 1;
SELECT id, appendTrailingCharIfAbsent(description, '.') AS modified_desc FROM (SELECT * FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NULL)) AS inner_query WHERE id < 5;
SELECT id, appendTrailingCharIfAbsent(name, 'X') AS modified_name FROM (SELECT id, name FROM test_table WHERE value < 10) AS subquery WHERE (id < 10 AND (SELECT COUNT(*) FROM test_table) = 3) OR (value IS NULL AND name != '') ORDER BY modified_name;