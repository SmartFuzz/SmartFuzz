CREATE TABLE test_base64 (encodedUrl String);
INSERT INTO test_base64 VALUES ('aHR0cDovL2NsaWNraG91c2UuY29t'), ('U29tZSBlbmNvZGVkIHV0aWxpemU='), ('aHR0cHM6Ly93d3cueW91eWl0Y29t');
SELECT base64URLDecode(encodedUrl) FROM test_base64;
SELECT base64URLDecode('aHR0cDovL2NsaWNraG91c2UuY29t'), base64URLDecode('U29tZSBlbmNvZGVkIHV0aWxpemU=') AS decodedUrl;
WITH (SELECT arrayJoin(['YWJjZA', 'YWJjZFRV', 'V0hUIGh0dHA6Ly9leGFtcGxlLmNvbS8=']) AS encodedUrls) AS urls SELECT base64URLDecode(encodedUrls) FROM urls;
CREATE TABLE temp_results AS SELECT base64URLDecode(encodedUrl) AS decodedUrl FROM test_base64;
SELECT decodedUrl FROM temp_results WHERE decodedUrl LIKE 'http%' ORDER BY decodedUrl;
SELECT COUNT(*) FROM (SELECT base64URLDecode(encodedUrl) FROM test_base64) AS decodedUrls WHERE decodedUrls IS NOT NULL;
SELECT d.decodedUrl FROM (SELECT base64URLDecode(encodedUrl) AS decodedUrl FROM test_base64) AS d WHERE d.decodedUrl IS NOT NULL AND d.decodedUrl LIKE 'http%';
SELECT d.decodedUrl, t2.column2 FROM (SELECT base64URLDecode(encodedUrl) AS decodedUrl FROM test_base64) AS d JOIN another_table AS t2 ON d.decodedUrl = t2.column1;