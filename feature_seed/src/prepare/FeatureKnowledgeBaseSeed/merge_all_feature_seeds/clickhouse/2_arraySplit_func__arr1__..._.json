CREATE TABLE test_table (id UInt32, values Array(UInt32), flags Array(UInt32));
INSERT INTO test_table VALUES (1, [1, 2, 3, 4, 5], [1, 0, 0, 1, 0]), (2, [10, 20, 30], [0, 1, 0]);
SELECT id, arraySplit((x, y) -> x AND y, values, flags) AS split_values FROM test_table WHERE split_values[1] IS NOT NULL;
CREATE TABLE temp_table (score Float32, status Nullable(String));
INSERT INTO temp_table VALUES (1.5, 'active'), (2.0, NULL), (NULL, 'inactive');
SELECT a.id, arraySplit((val, flag) -> if(val > 2, val, 0) AND if(flag = 1, 1, 0), t.values, t.flags) AS split_values FROM test_table AS t INNER JOIN temp_table AS tt ON tt.score > 1.0 AND tt.status IS NOT NULL;
SELECT COUNT(*) FROM (SELECT id, arraySplit((x, y) -> y, values, flags) AS split_values FROM test_table GROUP BY id) HAVING split_values[1] IS NOT NULL;
SELECT arraySplit((a, b) -> a > b, [1, 2, 3], [3, 2, 1]) AS comparison_results;
SELECT id, arraySplit((x, y) -> x AND (y IS NOT NULL), [NULL, 1, 0], [1, NULL, 0]) AS null_sensitive_results FROM (SELECT * FROM test_table ORDER BY id) AS sub_query;
CREATE TABLE edge_cases (num Nullable(Int32), str String);
INSERT INTO edge_cases VALUES (NULL, 'test'), (2147483647, 'max'), (-2147483648, 'min');
SELECT num, arraySplit((val, str) -> val AND length(str) > 2, [1, 0, 1], str) AS edge_results FROM edge_cases;