CREATE TABLE datetime_test (id UInt32, timestamp String);
INSERT INTO datetime_test VALUES (1, '2022-12-30 13:44:17'), (2, '1685457500'), (3, '1999'), (4, 'invalid_string');
SELECT toDateTime(timestamp) FROM datetime_test WHERE id = 1;
SELECT toDateTime(timestamp, 'UTC') FROM datetime_test WHERE id = 2;
SELECT toDateTime(1685457500) + INTERVAL 1 HOUR AS new_time FROM datetime_test WHERE id = 2;
SELECT id, toDateTime(timestamp) FROM datetime_test WHERE toDateTime(timestamp) IS NOT NULL;
SELECT id, toDateTime(UNIFORM(0, 10000000000)) FROM datetime_test;
SELECT id, toDateTime(CAST(timestamp AS Int32)) FROM datetime_test WHERE id = 1;
SELECT id, toDateTime('2022-12-30 13:44:17', 'Europe/London') FROM datetime_test;
SELECT id, toDateTime(EXTRACT(epoch FROM toDateTime('2022-12-30 13:44:17'))) FROM datetime_test WHERE id = 1;
CREATE TABLE other_table (id UInt32, event_time String);
INSERT INTO other_table VALUES (1, '2022-12-30 13:44:17'), (2, '2023-01-01 00:00:00');
SELECT a.id, toDateTime(a.timestamp) AS event_dt, b.event_time FROM datetime_test a JOIN other_table b ON a.id = b.id;
SELECT COUNT(*) FROM datetime_test WHERE toDateTime(timestamp, 'UTC') > NOW();
SELECT toDateTime(0) AS epoch_start, toDateTime(1609459200) AS new_year_2021;
SELECT id, toDateTime(timestamp) AS converted_time FROM datetime_test HAVING converted_time IS NOT NULL;
SELECT DISTINCT toDateTime(timestamp) FROM datetime_test WHERE timestamp NOT LIKE 'invalid_string';