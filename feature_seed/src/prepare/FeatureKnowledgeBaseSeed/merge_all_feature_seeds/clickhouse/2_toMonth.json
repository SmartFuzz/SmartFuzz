CREATE TABLE test_dates (id UInt32, event_date DateTime, description String);
INSERT INTO test_dates VALUES (1, '2023-01-15 12:00:00', 'New Year Event'), (2, '2023-02-20 08:30:00', 'February Event'), (3, NULL, 'Null Date Event');
SELECT id, toMonth(event_date) AS month FROM test_dates WHERE description NOT LIKE 'Event' OR month = toMonth(toDateTime('2023-02-01 00:00:00'));
SELECT id, toMonth(event_date), count(*) FROM test_dates GROUP BY toMonth(event_date) HAVING count(*) NOT LIKE '' AND toMonth(event_date) < 3;
CREATE TABLE temp_dates AS SELECT id, event_date FROM test_dates WHERE event_date IS NOT NULL;
SELECT t1.id, t2.month FROM (SELECT id, toMonth(event_date) AS month FROM test_dates WHERE event_date IS NOT NULL) AS t1 JOIN (SELECT id, toMonth(event_date) AS month FROM temp_dates WHERE event_date >= '2023-01-01') AS t2 ON t1.month NOT LIKE t2.month ORDER BY t1.id;
SELECT id FROM test_dates WHERE toMonth(event_date) NOT LIKE toMonth(NULLIF(event_date, '2023-01-15 12:00:00'));
SELECT description, COUNT(*) AS total FROM test_dates GROUP BY description HAVING total NOT LIKE '' AND total > 1;