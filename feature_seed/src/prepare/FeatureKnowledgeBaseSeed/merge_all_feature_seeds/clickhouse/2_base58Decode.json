CREATE TABLE base58_test (id UInt32, encoded_string String, decoded_value String);
INSERT INTO base58_test VALUES (1, '3dc8KtHrwM', base58Decode('3dc8KtHrwM'));
INSERT INTO base58_test VALUES (2, 'INVALID_BASE58', NULL);
INSERT INTO base58_test VALUES (3, '', base58Decode(''));
INSERT INTO base58_test VALUES (4, '123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz', base58Decode('123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz'));
SELECT id, base58Decode(encoded_string) AS decoded FROM base58_test WHERE encoded_string IN (SELECT encoded_string FROM base58_test WHERE id = 1);
SELECT id FROM base58_test WHERE base58Decode(encoded_string) IN ('SomeDecodedValue') OR (base58Decode(encoded_string) IS NULL);
SELECT id, COUNT(*) FROM base58_test GROUP BY base58Decode(encoded_string) HAVING COUNT(*) > 1;
SELECT base58Decode(encoded_string) AS decoded FROM base58_test ORDER BY base58Decode(encoded_string) DESC;
SELECT a.id FROM base58_test a JOIN (SELECT id FROM base58_test WHERE encoded_string IN ('3dc8KtHrwM', '') ) b ON a.id = b.id WHERE a.decoded_value IS NOT NULL;
SELECT id, base58Decode(encoded_string) AS decoded FROM base58_test WHERE base58Decode(encoded_string) IN (SELECT base58Decode(encoded_string) FROM base58_test WHERE encoded_string LIKE '3d%');
CREATE TABLE join_test (id UInt32, ref_id UInt32, ref_value String);
INSERT INTO join_test VALUES (1, 1, 'RefValue1'), (2, 2, 'RefValue2');
SELECT a.id, base58Decode(a.encoded_string) AS decoded, b.ref_value FROM base58_test a JOIN join_test b ON a.id = b.ref_id WHERE base58Decode(a.encoded_string) IS NOT NULL;
CREATE TABLE boundary_test (id UInt32, base58_string String);
INSERT INTO boundary_test VALUES (1, '1'), (2, '2'), (3, '123456789ABCDEFGHIJKLMNO');
SELECT id FROM boundary_test WHERE base58_string IN (SELECT base58_string FROM boundary_test WHERE id = 1);