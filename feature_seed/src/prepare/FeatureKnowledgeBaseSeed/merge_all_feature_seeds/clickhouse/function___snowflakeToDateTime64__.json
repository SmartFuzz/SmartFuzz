CREATE TABLE snowflake_test (id Int64);
INSERT INTO snowflake_test VALUES (1426860802823350272);
SELECT snowflakeToDateTime64(id, 'UTC') FROM snowflake_test;
SELECT snowflakeToDateTime64(id) FROM (SELECT id FROM snowflake_test);
CREATE TABLE time_zones (zone String);
INSERT INTO time_zones VALUES ('UTC'), ('America/New_York'), ('Europe/London');
SELECT snowflakeToDateTime64(s.id, z.zone) FROM snowflake_test AS s, time_zones AS z WHERE s.id IS NOT NULL;
SELECT count(*) FROM snowflake_test WHERE snowflakeToDateTime64(id) > '2021-01-01 00:00:00';
WITH tz AS (SELECT zone FROM time_zones) SELECT snowflakeToDateTime64(id, (SELECT zone FROM tz WHERE zone = 'America/New_York')) FROM snowflake_test;
CREATE TABLE snowflake_details (id Int64, description String);
INSERT INTO snowflake_details VALUES (1426860802823350272, 'Sample Snowflake ID');
SELECT d.description, snowflakeToDateTime64(d.id) FROM snowflake_details AS d JOIN snowflake_test AS s ON d.id = s.id;
SELECT snowflakeToDateTime64(s.id) AS timestamp FROM (SELECT id FROM snowflake_test) AS s HAVING timestamp IS NOT NULL;