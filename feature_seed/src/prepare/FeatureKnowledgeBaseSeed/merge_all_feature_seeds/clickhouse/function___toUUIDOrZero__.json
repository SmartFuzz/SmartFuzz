SELECT id, toUUIDOrZero((SELECT uuid_string FROM test_subquery WHERE id = 2)) AS uuid;
SELECT (SELECT toUUIDOrZero('61f0c404-5cb3-11e7-907b-a6006ad3dba0T')), (SELECT toUUIDOrZero('invalid-uuid'));
SELECT id, CASE WHEN toUUIDOrZero(uuid_string) = '00000000-0000-0000-0000-000000000000' THEN 'Invalid UUID' ELSE 'Valid UUID' END AS uuid_status FROM test_uuids;