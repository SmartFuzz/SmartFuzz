CREATE TABLE test_table (id UInt32, value String, num_value Float64);
INSERT INTO test_table VALUES (1, '128'), (2, 'abc'), (3, '0xc0fe'), (4, 'NaN'), (5, 'Inf'), (6, '0');
SELECT id, toUInt128OrDefault(value, CAST('0', 'UInt128')) AS converted_value FROM test_table WHERE value NOT BETWEEN '32' AND '256';
SELECT id, num_value, toUInt128OrDefault(toString(num_value), CAST('0', 'UInt128')) AS converted_num FROM test_table WHERE toUInt128OrDefault(num_value, CAST('0', 'UInt128')) NOT BETWEEN 0 AND 10;
CREATE TABLE test_table_2 (id UInt32, test_value UInt128);
INSERT INTO test_table_2 SELECT id, toUInt128OrDefault(value, CAST('0', 'UInt128')) FROM test_table WHERE value NOT BETWEEN '5' AND '10';
SELECT a.id, toUInt128OrDefault(b.value, CAST(NULL, 'UInt128')) AS test_value FROM test_table_2 a JOIN test_table b ON a.test_value NOT BETWEEN 0 AND 100 GROUP BY a.id HAVING a.id NOT BETWEEN 1 AND 3;
SELECT id, toUInt128OrDefault(value, CAST('0', 'UInt128')) FROM test_table WHERE value NOT BETWEEN '0' AND '' ORDER BY toUInt128OrDefault(value, CAST('0', 'UInt128')) DESC;