CREATE TABLE test_dates (date_string String);
INSERT INTO test_dates VALUES ('2023-10-01'), ('invalid-date'), ('2023-10-05 14:00:00'), (NULL);
SELECT date_string, parseDateTimeOrZero(date_string) AS parsed_date FROM test_dates;
CREATE TABLE test_dates2 (date_string String, id Int32);
INSERT INTO test_dates2 VALUES ('2023-10-01', 1), ('invalid-date', 2), ('2023-10-05 14:00:00', 3), (NULL, 4);
SELECT id, parseDateTimeOrZero(date_string) AS parsed_date FROM test_dates2 WHERE id > 1;
SELECT id, date_string, parseDateTimeOrZero(date_string) + INTERVAL 1 DAY AS next_day FROM test_dates2;
CREATE TABLE test_dates3 AS SELECT id, parseDateTimeOrZero(date_string) AS parsed_date FROM test_dates2 WHERE date_string IS NOT NULL;
SELECT parsed_date FROM test_dates3 WHERE parsed_date = 0;
CREATE TABLE log_events (event_time String, user_id Int32);
INSERT INTO log_events VALUES ('2023-10-01 08:30:00', 1), ('foobar', 2), ('2023-10-02 13:45:00', 3);
SELECT user_id, parseDateTimeOrZero(event_time) AS event_parsed FROM log_events WHERE user_id > 1;
SELECT COUNT(*) AS zero_date_count FROM log_events WHERE parseDateTimeOrZero(event_time) = 0;
SELECT AVG(parseDateTimeOrZero(event_time)) FROM log_events WHERE user_id = 1;
SELECT t1.user_id, t2.parsed_date FROM log_events t1 JOIN (SELECT user_id, parseDateTimeOrZero(event_time) AS parsed_date FROM log_events) t2 ON t1.user_id = t2.user_id WHERE t2.parsed_date = 0;