CREATE TABLE ip_addresses (id UInt32, ip_address String);
INSERT INTO ip_addresses VALUES (1, '192.168.1.1'), (2, '10.0.0.255'), (3, '255.255.255.255'), (4, '0.0.0.0');
SELECT ip_address, IPv4StringToNum(ip_address) AS ip_num FROM ip_addresses;
SELECT x.id, IPv4StringToNum(x.ip_address) AS ip_num FROM (SELECT * FROM ip_addresses) AS x WHERE x.ip_address LIKE '192.%';
CREATE TABLE valid_ips AS SELECT ip_address, IPv4StringToNum(ip_address) AS ip_num FROM ip_addresses WHERE IPv4StringToNum(ip_address) IS NOT NULL;
SELECT the.id, the.ip_num FROM (SELECT id, IPv4StringToNum(ip_address) AS ip_num FROM ip_addresses) AS the WHERE ip_num > 167772160 AND ip_num < 184549376;
CREATE TABLE invalid_ips AS SELECT ip_address FROM ip_addresses WHERE try(IPv4StringToNum(ip_address)) IS NULL;
SELECT ip_address FROM invalid_ips WHERE ip_address NOT LIKE '%.%.%.%';
WITH (SELECT COUNT(*) FROM ip_addresses) AS total_ips SELECT total_ips, (SELECT COUNT(*) FROM valid_ips) AS valid_ips_count, (SELECT COUNT(*) FROM invalid_ips) AS invalid_ips_count;
SELECT IPv4StringToNum('300.0.0.1') AS invalid;
