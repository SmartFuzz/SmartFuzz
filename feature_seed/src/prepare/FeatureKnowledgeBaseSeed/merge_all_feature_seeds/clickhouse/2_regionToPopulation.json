CREATE TABLE regions (id UInt32, name String, population UInt32);
INSERT INTO regions VALUES (1, 'RegionA', 1000), (2, 'RegionB', NULL), (3, 'RegionC', 2000);
SELECT regionToPopulation(number::UInt32) AS population, regionToPopulation(1) <> regionToPopulation(2) AS population_difference FROM numbers(3);
SELECT r.name, regionToPopulation(r.id) AS region_population FROM regions r WHERE regionToPopulation(r.id) <> 0;
SELECT r1.name, r2.name, regionToPopulation(r1.id) <> regionToPopulation(r2.id) AS different_populations FROM regions r1 JOIN regions r2 ON r1.id <> r2.id;
SELECT COUNT(*) FROM regions WHERE regionToPopulation(id) IS NOT NULL HAVING COUNT(*) > 0;
SELECT AVG(population) AS avg_population FROM regions WHERE regionToPopulation(id) <> 0 GROUP BY name;
SELECT e.id, regionToPopulation(e.id) + 1 AS incremented_population FROM (SELECT id FROM regions) AS e WHERE regionToPopulation(e.id) IS NOT NULL;
WITH (SELECT COUNT(*) FROM regions) AS total FROM regions WHERE regionToPopulation(id) <> (SELECT AVG(population) FROM regions);
CREATE TABLE temp_population AS SELECT id, regionToPopulation(id) AS population FROM regions WHERE regionToPopulation(id) <> 0;
INSERT INTO temp_population SELECT 4, regionToPopulation(4) FROM numbers(1) WHERE regionToPopulation(4) IS NULL;