CREATE TABLE test_strings (id UInt32, text String);
INSERT INTO test_strings VALUES (1, '   Hello,   World!  '), (2, '   This is a test.    '), (3, 'ClickHouse     is   amazing!'), (4, '   '), (5, 'OneWord');
SELECT splitByWhitespace(text) FROM test_strings;
SELECT id, splitByWhitespace(text, 2) FROM test_strings;
SELECT id, splitByWhitespace(text, 0) FROM test_strings;
SELECT id, splitByWhitespace(text, 1) FROM test_strings WHERE id = 5;
SELECT id, splitByWhitespace(text, 3) AS substrings FROM test_strings WHERE text != '';
CREATE TABLE joined_test (id UInt32, t1_id UInt32, value String);
INSERT INTO joined_test VALUES (1, 1, 'First'), (2, 1, 'Second'), (3, 2, 'Third'), (4, 3, 'Fourth'), (5, 4, 'Fifth');
SELECT j.id, splitByWhitespace(t.text, 2) AS substrings FROM test_strings t JOIN joined_test j ON t.id = j.t1_id;
SELECT j.id, splitByWhitespace(t.text) AS substrings FROM test_strings t, joined_test j WHERE j.value LIKE 'F%';
SELECT id, splitByWhitespace(text) FROM test_strings WHERE id IN (SELECT DISTINCT t1_id FROM joined_test WHERE value = 'First');