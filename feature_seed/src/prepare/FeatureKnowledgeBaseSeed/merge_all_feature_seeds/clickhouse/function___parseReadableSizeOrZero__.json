CREATE TABLE sizes_test (readable_size String);
INSERT INTO sizes_test VALUES ('1 B'), ('1 KiB'), ('3 MB'), ('5.314 KiB'), ('invalid');
SELECT readable_size, parseReadableSizeOrZero(readable_size) AS bytes_size FROM sizes_test;
CREATE TABLE sizes_extended (id UInt64, readable_size String);
INSERT INTO sizes_extended VALUES (1, '0 B'), (2, '1024 B'), (3, '1 MiB'), (4, '2.5 MB'), (5, 'invalid size');
SELECT id, readable_size, parseReadableSizeOrZero(readable_size) AS bytes_size FROM sizes_extended;
WITH arrayJoin(['1 B', '1 KiB', '3 MB', '5.314 KiB', 'invalid']) AS readable_sizes SELECT parseReadableSizeOrZero(readable_sizes) AS sizes;
SELECT t1.readable_size, parseReadableSizeOrZero(t1.readable_size) AS byte_value FROM sizes_test t1 JOIN sizes_extended t2 ON parseReadableSizeOrZero(t1.readable_size) = t2.id;
SELECT id, parseReadableSizeOrZero(readable_size) AS parsed_size FROM sizes_extended WHERE parsed_size > 0;
CREATE TABLE large_table (size String) ENGINE = MergeTree() ORDER BY size;
INSERT INTO large_table VALUES ('100 MB'), ('2 GiB'), ('256 KiB'), ('invalid size');
SELECT size, parseReadableSizeOrZero(size) AS bytes FROM large_table WHERE parseReadableSizeOrZero(size) IS NOT NULL;
WITH arrayJoin(['0 B', '1 KB', '1.5 MB', '2.5 GiB', 'invalid size']) AS sizes SELECT sizes, parseReadableSizeOrZero(sizes) AS byte_value;
CREATE TABLE multiple_units (unit String);
INSERT INTO multiple_units VALUES ('1 GB'), ('500 MB'), ('250 KiB'), ('125 B'), ('invalid unit');
SELECT unit, parseReadableSizeOrZero(unit) AS size_bytes FROM multiple_units;