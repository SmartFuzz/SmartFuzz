CREATE TABLE test_table1 (id Int32, value Nullable(Int32));
INSERT INTO test_table1 VALUES (1, NULL), (2, 2), (3, NULL);
CREATE TABLE test_table2 (key Int32, data Nullable(Int32));
INSERT INTO test_table2 VALUES (1, NULL), (2, 3), (3, NULL);
SELECT t1.id, t2.key FROM test_table1 AS t1 JOIN test_table2 AS t2 ON isNotDistinctFrom(t1.value, t2.data);
SELECT count(*) FROM (SELECT t1.id FROM test_table1 AS t1 JOIN test_table2 AS t2 ON isNotDistinctFrom(t1.value, t2.data) WHERE t1.id > 1);
CREATE TABLE test_table3 (ref_key Int32, foreign_value Nullable(Int32));
INSERT INTO test_table3 VALUES (1, 10), (2, NULL), (3, 30);
SELECT t1.id, t2.ref_key FROM test_table1 AS t1 JOIN test_table3 AS t2 ON isNotDistinctFrom(t1.value, t2.foreign_value) WHERE t1.id < 3;
SELECT t1.id, t1.value, t2.key, t2.data FROM test_table1 AS t1 LEFT JOIN test_table2 AS t2 ON isNotDistinctFrom(t1.value, t2.data) WHERE t1.id IS NOT NULL;
SELECT avg(t2.data) FROM test_table2 AS t2 WHERE isNotDistinctFrom(t2.data, NULL);