CREATE TABLE test_table (value String);
INSERT INTO test_table VALUES ('123'), ('-64'), ('abc'), ('256.78'), ('-512.34'), ('0xc0fe'), ('NaN'), ('Inf'), ('-9223372036854775809'), ('9223372036854775808');
SELECT value, toInt64OrNull(value) AS converted_value FROM test_table;
SELECT value, toInt64OrNull(trim(value)) AS trimmed_value FROM test_table WHERE value IS NOT NULL;
SELECT value, toInt64OrNull(concat(value, '')) AS concatenated_converted FROM test_table;
SELECT t1.value, toInt64OrNull(t1.value) AS conversion_result FROM test_table t1 JOIN test_table t2 ON toInt64OrNull(t1.value) = toInt64OrNull(t2.value) WHERE t2.value IS NOT NULL;
SELECT value, toInt64OrNull(if(value = 'abc', '0', value)) AS conditional_conversion FROM test_table;
SELECT value, toInt64OrNull((SELECT AVG(toInt64OrNull(value)) FROM test_table)) AS average_conversion FROM test_table;
WITH (SELECT MAX(toInt64OrNull(value)) FROM test_table) AS max_conversion SELECT value, toInt64OrNull(value) AS conversion FROM test_table WHERE toInt64OrNull(value) < max_conversion;
SELECT value, toInt64OrNull(substring(value, 1, 3)) AS substring_conversion FROM test_table;
CREATE TABLE another_test_table (id UInt32, value String);
INSERT INTO another_test_table VALUES (1, '123'), (2, 'abc'), (3, '512.99');
SELECT a.id, toInt64OrNull(a.value) AS converted_value FROM another_test_table a LEFT JOIN test_table b ON a.value = b.value;
SELECT COUNT(*) AS total_valid_conversions FROM test_table WHERE toInt64OrNull(value) IS NOT NULL;