CREATE TABLE test_table (column1 UInt32, column2 UInt32, column3 UInt32);
INSERT INTO test_table SELECT * FROM file('test.csv', 'CSV', 'column1 UInt32, column2 UInt32, column3 UInt32');
SELECT * FROM test_table LIMIT 2;
SELECT column1, column2 FROM test_table WHERE column1 > 2;
SELECT COUNT(*) FROM test_table WHERE column3 < 5;
CREATE TABLE test_table2 AS SELECT * FROM table(test_table) WHERE column1 = 1;
SELECT a.column1, b.column2 FROM test_table AS a JOIN test_table2 AS b ON a.column1 = b.column1;
SELECT * FROM (SELECT column1, SUM(column2) AS total FROM test_table GROUP BY column1) AS subquery WHERE total > 2;
SELECT * FROM file('test.csv', 'CSV', 'column1 UInt32, column2 UInt32, column3 UInt32') WHERE column1 IN (SELECT column1 FROM test_table WHERE column2 < column3);
SELECT column1, AVG(column3) OVER (PARTITION BY column2 ORDER BY column1) FROM test_table;
SELECT * FROM file('user_files/archives/archive1.zip :: table.csv') UNION ALL SELECT * FROM file('user_files/archives/archive2.zip :: table.csv');
INSERT INTO test_table SELECT column1, column2, column3 FROM file('test.csv', 'CSV', 'column1 UInt32, column2 UInt32, column3 UInt32') WHERE column1 < 100;
CREATE TABLE test_aggregate AS SELECT column1, COUNT(*) AS counts FROM test_table GROUP BY column1 HAVING counts > 1;
SELECT DISTINCT column1 FROM test_table WHERE column2 = (SELECT MAX(column2) FROM test_table);
SELECT * FROM file('test.csv', 'CSV', 'column1 UInt32, column2 UInt32, column3 UInt32') LIMIT 10 OFFSET 5;