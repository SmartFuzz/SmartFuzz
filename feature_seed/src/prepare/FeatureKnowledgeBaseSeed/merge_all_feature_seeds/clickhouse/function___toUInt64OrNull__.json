CREATE TABLE test_table (id UInt64, str_value String);
INSERT INTO test_table VALUES (1, '64'), (2, 'abc'), (3, '18446744073709551615'), (4, '18446744073709551616');
SELECT toUInt64OrNull(str_value) AS converted FROM test_table WHERE id = 1;
SELECT toUInt64OrNull(str_value) AS converted FROM test_table WHERE id IN (2, 3);
SELECT id, toUInt64OrNull(str_value) AS converted FROM test_table ORDER BY id;
SELECT t1.id, toUInt64OrNull(t2.str_value) FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t2.id = 1;
SELECT toUInt64OrNull('0xc0fe') AS converted;
SELECT toUInt64OrNull('3.14159'), toUInt64OrNull('Inf'), toUInt64OrNull('NaN');
SELECT id, CASE WHEN toUInt64OrNull(str_value) IS NULL THEN 'Conversion Failed' ELSE 'Conversion Successful' END AS conversion_status FROM test_table;
SELECT str_value, toUInt64OrNull(str_value) AS converted FROM test_table WHERE id <= 3;
SELECT count(*) FROM test_table WHERE toUInt64OrNull(str_value) IS NOT NULL;
WITH (SELECT '256') AS input_value SELECT toUInt64OrNull(input_value) AS converted;
SELECT t1.id, t2.id, toUInt64OrNull(t2.str_value) FROM test_table t1, test_table t2 WHERE t1.id < t2.id;