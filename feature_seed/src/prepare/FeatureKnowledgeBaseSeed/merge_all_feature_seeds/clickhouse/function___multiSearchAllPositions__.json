CREATE TABLE test_strings (haystack String, needles Array(String));
INSERT INTO test_strings VALUES ('Hello, World!', ['hello', '!', 'world']);
SELECT multiSearchAllPositions(haystack, needles) FROM test_strings;
CREATE TABLE test_table AS (SELECT multiSearchAllPositions('foo bar baz foo', ['bar', 'foo', 'baz']) AS positions);
SELECT positions FROM test_table;
WITH multiSearchAllPositions('abcdefg', ['a', 'b', 'c', 'h']) AS pos SELECT arrayJoin(pos) AS position;
CREATE TABLE words (word String);
INSERT INTO words VALUES ('Hello, World!'), ('Welcome to ClickHouse'), ('Fuzz testing in databases');
SELECT word, multiSearchAllPositions(word, ['Hello', 'World', 'ClickHouse', 'fuzz']) AS positions FROM words;
SELECT multiSearchAllPositions('ClickHouse is a fast open-source OLAP database management system.', ['fast', 'open-source', 'database', 'system']) AS results;
INSERT INTO test_strings VALUES ('Test string with duplicates: test, test, test.', ['test', 'string', 'duplicates']);
SELECT multiSearchAllPositions(haystack, needles) FROM test_strings WHERE haystack LIKE '%test%';
SELECT multiSearchAllPositions('Quick brown fox jumps over the lazy dog', ['quick', 'jumps', 'dog', 'cat']);
CREATE TABLE test_positions AS SELECT multiSearchAllPositions('The rain in Spain stays mainly in the plain', ['rain', 'Spain', 'plain', 'notfound']) AS positions;
SELECT arrayJoin(multiSearchAllPositions('random text with no needles', ['needle1', 'needle2', 'needle3'])) AS found_positions;
SELECT multiSearchAllPositions('Edge cases with empty strings', ['']) AS empty_positions;
INSERT INTO test_strings VALUES ('aaaaaaa', ['a', 'aa', 'aaa', 'aaaa', 'aaaaa']);
SELECT multiSearchAllPositions(haystack, needles) FROM test_strings WHERE needles[1] IS NOT NULL;