CREATE TABLE mean_ztest (sample_data FLOAT, sample_index INT);
INSERT INTO mean_ztest VALUES (1.5, 0), (2.5, 0), (3.0, 1), (4.0, 1);
SELECT meanZTest(0.7, 0.45, 0.95)(sample_data, sample_index) FROM mean_ztest;
INSERT INTO mean_ztest VALUES (5.0, 0), (3.0, 1), (6.1, 0), (5.5, 1);
SELECT meanZTest(0.3, 0.6, 0.90)(sample_data, sample_index) FROM mean_ztest;
CREATE TABLE test1 (id INT, value FLOAT);
INSERT INTO test1 VALUES (1, 1.5), (2, 2.5);
SELECT meanZTest(0.8, 0.5, 0.99)(SELECT value FROM test1, mean_ztest WHERE test1.id = 1 AND mean_ztest.sample_index = 0, (SELECT sample_index FROM mean_ztest WHERE sample_index = 1));
CREATE TABLE test_population (id INT, sample_data FLOAT, sample_index INT);
INSERT INTO test_population VALUES (1, 2.2, 0), (2, 3.8, 1), (3, 1.1, 0), (4, 4.9, 1);
SELECT meanZTest(0.5, 0.25, 0.95)(sample_data, sample_index) FROM (SELECT sample_data, sample_index FROM test_population WHERE sample_index IN (0, 1));
INSERT INTO mean_ztest VALUES (NULL, 0), (NULL, 1);
SELECT meanZTest(0.9, 0.4, 0.97)(sample_data, sample_index) FROM mean_ztest WHERE sample_data IS NOT NULL;
SELECT meanZTest(0.0, 0.0, 0.99)(sample_data, sample_index) FROM mean_ztest WHERE sample_index IN (0, 1) HAVING COUNT(*) > 0;