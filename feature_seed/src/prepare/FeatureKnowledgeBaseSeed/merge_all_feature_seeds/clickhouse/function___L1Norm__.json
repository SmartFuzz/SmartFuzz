CREATE TABLE test_vectors (id UInt32, vec Array(Float64));
INSERT INTO test_vectors VALUES (1, [1, -2, 3]), (2, [0.5, 0.5, -0.5]), (3, [1.1, 2.2, -3.3, 4.4]);
SELECT L1Norm(vec) FROM test_vectors;
SELECT id, L1Norm(vec) AS l1_norm FROM test_vectors WHERE L1Norm(vec) > 2;
SELECT id, L1Norm(arrayJoin([1, -2, 3, -4, 5])) AS l1_norm FROM test_vectors;
SELECT id, L1Norm((SELECT arrayJoin(vec) FROM test_vectors WHERE id = 1)) AS l1_norm FROM test_vectors;
WITH (SELECT L1Norm(vec) FROM test_vectors WHERE id = 2) AS norm_value SELECT norm_value * 2 AS double_norm FROM test_vectors WHERE id = 2;
CREATE TABLE test_results AS SELECT id, L1Norm(vec) AS l1_norm FROM test_vectors;
WITH (SELECT vec FROM test_vectors WHERE id = 3) AS vector SELECT L1Norm(vector) AS result;
SELECT id FROM test_vectors WHERE L1Norm(vec) < 5 ORDER BY id DESC;