CREATE TABLE test_timestamps (id UInt32, dt64 DateTime64(9), value String);
INSERT INTO test_timestamps (id, dt64, value) VALUES (1, toDateTime64('1970-01-01 00:20:34.567891011', 9, 'UTC'), 'test1'), (2, toDateTime64('2000-01-01 00:00:00.123456789', 9, 'UTC'), 'test2'), (3, toDateTime64('1999-12-31 23:59:59.999999999', 9, 'UTC'), 'test3');
SELECT toUnixTimestamp64Nano(dt64) AS unix_time, value FROM test_timestamps WHERE dt64 LIKE toDateTime64('1970-01-01 00:20:34.567891011', 9, 'UTC') AND value LIKE '%test%';
SELECT id, toUnixTimestamp64Nano(dt64) AS unix_time FROM test_timestamps WHERE unix_time IS NOT NULL AND id IN (SELECT id FROM test_timestamps WHERE value LIKE 'test2');
SELECT COUNT(*) FROM test_timestamps HAVING COUNT(*) > 1 AND value LIKE '%test%' AND dt64 = (SELECT dt64 FROM test_timestamps WHERE value LIKE 'test3' LIMIT 1);
CREATE TABLE temp_timestamps AS SELECT id, dt64, toUnixTimestamp64Nano(dt64) AS unix_time FROM test_timestamps;
SELECT * FROM temp_timestamps WHERE unix_time LIKE '0%';
SELECT toUnixTimestamp64Nano(dt64), value FROM (SELECT dt64, value FROM test_timestamps WHERE id LIKE 1) AS subquery WHERE NOT value IS NULL GROUP BY dt64, value ORDER BY unix_time DESC;