CREATE TABLE trades (coin String, price Float64, volume Float64) ENGINE = MergeTree() ORDER BY coin;
INSERT INTO trades VALUES ('Bitcoin', 120.5, 1000.0), ('Ethereum', 150.0, 500.0), ('DOGE', 80.0, 1500.0), ('Bitcoin', 110.0, 800.0), ('Ethereum', 130.0, 700.0);
CREATE TABLE holdings (coin String, amount Float64) ENGINE = MergeTree() ORDER BY coin;
INSERT INTO holdings VALUES ('Bitcoin', 2.0), ('Ethereum', 1.5), ('DOGE', 3.0);
SELECT coin FROM trades WHERE price > 100 INTERSECT SELECT coin FROM holdings;
SELECT DISTINCT coin FROM trades WHERE price > 100 INTERSECT SELECT DISTINCT coin FROM holdings;
SELECT coin FROM (SELECT coin FROM trades WHERE volume > 1000) INTERSECT SELECT coin FROM (SELECT coin FROM holdings WHERE amount > 1);
CREATE TABLE trades2 (coin String, price Float64, volume Float64) ENGINE = MergeTree() ORDER BY coin;
INSERT INTO trades2 VALUES ('Bitcoin', 200.0, 900.0), ('Ethereum', 170.0, 600.0), ('Litecoin', 95.0, 300.0);
SELECT coin FROM trades INTERSECT SELECT coin FROM trades2;
SELECT coin FROM (SELECT DISTINCT coin FROM trades WHERE price > 100) INTERSECT SELECT DISTINCT coin FROM (SELECT DISTINCT coin FROM holdings);
SELECT coin FROM trades WHERE price > 100 INTERSECT SELECT coin FROM holdings WHERE amount < 5;