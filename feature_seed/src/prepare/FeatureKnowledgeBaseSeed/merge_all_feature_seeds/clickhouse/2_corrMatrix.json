CREATE TABLE test1(a UInt32, b Float64, c Float64, d Float64) ENGINE = Memory;
INSERT INTO test1(a, b, c, d) VALUES (1, 5.6, -4.4, 2.6), (2, -9.6, 3, 3.3), (3, -1.3, -4, 1.2), (4, 5.3, 9.7, 2.3);
CREATE TABLE test2(x String, y Float64) ENGINE = Memory;
INSERT INTO test2(x, y) VALUES ('test1', 1.1), ('test2', -2.2), ('test3', NULL);
SELECT arrayMap(x -> round(x, 3), arrayJoin(corrMatrix(a, b, c, d))) AS corrMatrix FROM test1 WHERE a NOT LIKE '2' AND b NOT LIKE '%.5';
SELECT a, b FROM test1 WHERE a IN (SELECT DISTINCT a FROM test1 WHERE b NOT LIKE '%5%') GROUP BY a, b HAVING count(*) > 1;
SELECT count(*) FROM (SELECT a, b, c FROM test1 WHERE c IS NOT NULL AND a NOT LIKE '1' GROUP BY a, b) AS sub1 JOIN (SELECT y FROM test2 WHERE x NOT LIKE 'test1') AS sub2 ON sub1.b = sub2.y;
SELECT arrayJoin(corrMatrix(a, b, c, d)) FROM (SELECT a, ROUND(b, 1) AS rounded_b FROM test1 WHERE d NOT LIKE '%.2');
CREATE TABLE test3(e Nullable(UInt32), f Nullable(Float64)) ENGINE = Memory;
INSERT INTO test3(e, f) VALUES (NULL, 0.0), (5, NULL), (10, -10.5);
SELECT e, corrMatrix(f, e) FROM test3 WHERE e NOT LIKE %'5' GROUP BY e;