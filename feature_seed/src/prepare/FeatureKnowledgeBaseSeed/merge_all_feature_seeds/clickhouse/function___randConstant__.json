CREATE TABLE test_table (id UInt32, value UInt32);
INSERT INTO test_table VALUES (1, 1), (2, 2), (3, 3);
SELECT randConstant() AS random_value FROM test_table;
SELECT id, randConstant(5) AS random_value FROM test_table ORDER BY id;
SELECT id, randConstant(id) AS random_value FROM test_table WHERE value > 1;
SELECT id, randConstant() + value AS combined_value FROM test_table;
SELECT id, (SELECT randConstant() FROM test_table) AS random_value FROM test_table;
CREATE TABLE another_table (id UInt32, group_id UInt32);
INSERT INTO another_table VALUES (1, 1), (2, 1), (3, 2);
SELECT a.id, randConstant(a.group_id) AS random_value FROM test_table AS a JOIN another_table AS b ON a.id = b.id;
SELECT value * randConstant(100) AS scaling_value FROM test_table GROUP BY value;