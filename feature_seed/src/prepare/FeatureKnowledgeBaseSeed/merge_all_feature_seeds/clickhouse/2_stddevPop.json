CREATE TABLE test_data1 (population UInt8, status String) ENGINE = MergeTree() ORDER BY population;
INSERT INTO test_data1 VALUES (3, 'valid'), (3, 'valid'), (5, 'valid'), (5, 'missing'), (6, 'valid'), (NULL, 'invalid'), (8, 'valid'), (10, 'valid');
SELECT stddevPop(population) AS stddev, multiIf(status = 'valid', stddevPop(population), 0) AS valid_stddev FROM test_data1 GROUP BY status;
WITH (SELECT COUNT(*) FROM test_data1 WHERE population IS NOT NULL) AS not_null_count, stddevPop(population) AS overall_stddev SELECT not_null_count, overall_stddev FROM test_data1;
CREATE TABLE test_data2 (age Int32, category LowCardinalEnum('child', 'adult', 'senior')) ENGINE = Log;
INSERT INTO test_data2 VALUES (10, 'child'), (15, 'child'), (20, 'adult'), (65, 'senior'), (40, 'adult'), (90, 'senior');
SELECT avg(age) AS avg_age, multiIf(category = 'adult', stddevPop(age), NULL) AS adult_stddev FROM test_data2 GROUP BY category;
CREATE TABLE test_data3 (id UInt8, values Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_data3 VALUES (1, 1.5), (2, NULL), (3, 3.3), (4, 2.2), (5, 2.6), (6, NULL);
SELECT stddevPop(COALESCE(values, 0)) AS stddev_with_null FROM test_data3;
WITH (SELECT COUNT(*) FROM test_data3 WHERE values IS NOT NULL) AS total_not_null, stddevPop(values) AS population_stddev SELECT total_not_null, population_stddev FROM test_data3 WHERE values > 0;
CREATE TABLE test_data4 (data String) ENGINE = Log;
INSERT INTO test_data4 VALUES ('1.5'), ('3.2'), ('4.6'), (NULL), ('six'), ('8.9');
SELECT stddevPop(CAST(data AS Float64)) AS stddev_from_string, multiIf(data = 'six', NULL, stddevPop(CAST(data AS Float64))) AS conditional_stddev FROM test_data4;
WITH (SELECT MIN(data) FROM test_data4 WHERE data IS NOT NULL) AS min_data, (SELECT MAX(data) FROM test_data4 WHERE data IS NOT NULL) AS max_data SELECT min_data, max_data, stddevPop(COALESCE(CAST(data AS Float64), 0)) AS adjusted_stddev FROM test_data4;
CREATE TABLE test_data5 (a UInt32, b UInt32) ENGINE = MergeTree() ORDER BY a;
INSERT INTO test_data5 VALUES (1, 2), (2, 4), (3, 8), (4, 16), (NULL, 32);
SELECT stddevPop(multiIf(b > 5, a, NULL)) AS high_stddev FROM test_data5 GROUP BY a HAVING a IS NOT NULL;
CREATE TEMPORARY TABLE test_temp AS SELECT * FROM test_data2;
SELECT COUNT(*), stddevPop(age) FROM test_temp WHERE category = 'adult' HAVING COUNT(*) > 1;