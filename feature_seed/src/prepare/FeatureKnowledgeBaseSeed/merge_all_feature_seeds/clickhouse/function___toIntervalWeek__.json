CREATE TABLE test_dates (date Date);
INSERT INTO test_dates VALUES (toDate('2024-06-15'));
SELECT date + toIntervalWeek(1) AS result FROM test_dates;
SELECT date + toIntervalWeek(-1) AS result FROM test_dates;
SELECT date + toIntervalWeek(0) AS result FROM test_dates;
WITH toDate('2024-06-15') AS date SELECT date + toIntervalWeek(2) AS result;
SELECT date + toIntervalWeek(3.5) AS result FROM test_dates;
SELECT date + toIntervalWeek(CAST('2' AS Int32)) AS result FROM test_dates;
CREATE TABLE test_intervals (id Int32, interval_value IntervalWeek);
INSERT INTO test_intervals VALUES (1, toIntervalWeek(1)), (2, toIntervalWeek(2));
SELECT t1.id, t1.interval_value + toIntervalWeek(1) AS new_interval FROM test_intervals AS t1 WHERE t1.id = 1;
WITH (SELECT MAX(interval_value) FROM test_intervals) AS max_interval SELECT toIntervalWeek(max_interval + 1) AS result;
SELECT date + (toIntervalWeek(3) + toIntervalWeek(2)) AS result FROM test_dates;
WITH (SELECT toIntervalWeek(1)) AS interval_one SELECT toDate('2024-06-15') + interval_one AS result;
CREATE TABLE dates_extended (id Int32, date Date);
INSERT INTO dates_extended VALUES (1, toDate('2023-05-01')), (2, toDate('2023-06-01')), (3, toDate('2024-03-01'));
SELECT d.date + toIntervalWeek(1) AS new_date FROM dates_extended AS d WHERE d.id IN (SELECT DISTINCT id FROM dates_extended WHERE date < toDate('2024-01-01'));
SELECT * FROM (SELECT toDate('2024-06-15') AS date UNION ALL SELECT toDate('2022-06-15')) AS tbl JOIN test_dates td ON tbl.date = td.date;