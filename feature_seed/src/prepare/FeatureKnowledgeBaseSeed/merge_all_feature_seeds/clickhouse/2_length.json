CREATE TABLE test_strings (id UInt64, text String NOT NULL, arr Array(UInt8)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'Hello, world!', [1, 2, 3]), (2, '', [4, 5]), (3, NULL, [6, 7, 8, 9]);
SELECT id, length(text) AS text_length FROM test_strings WHERE length(text) = length('Hello, world!') ORDER BY text_length;
SELECT id, length(arr) AS arr_length FROM test_strings WHERE arr_length > 3;
SELECT id, text, length(text) + length(arr) AS total_length FROM test_strings WHERE length(text) IS NULL OR length(arr) = 3;
SELECT id FROM (SELECT id, length(text) AS str_len FROM test_strings WHERE str_len IS NOT NULL) AS subquery WHERE str_len > 0;
CREATE TABLE test_numbers (id UInt64, num Array(UInt64), str String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_numbers VALUES (1, [1, 2, 3], 'Test'), (2, [4, 5], 'Another Test'), (3, [], '');
SELECT id, length(str) AS str_length FROM test_numbers WHERE (str_length = 0) OR (str_length = length('Another Test'));
SELECT id FROM (SELECT id, length(num) AS num_len FROM test_numbers GROUP BY id HAVING num_len < 3) AS subquery WHERE length(str) = 0;
SELECT a.id FROM test_strings AS a JOIN test_numbers AS b ON length(a.text) = (SELECT length(str) FROM test_numbers WHERE id = b.id);
SELECT id FROM test_numbers WHERE length(num) = (SELECT MAX(length(str)) FROM test_numbers) AND length(str) > 0;
SELECT id, length(text) AS text_length FROM test_strings HAVING text_length < (SELECT AVG(length(text)) FROM test_strings WHERE text IS NOT NULL);
SELECT id, length(text) AS text_length FROM test_strings WHERE text_length = (SELECT length(text) FROM test_strings WHERE id = 2);
SELECT id FROM test_numbers WHERE length(str) = length('Test') AND (length(num) <> length(arr) OR length(arr) IS NULL);