CREATE TABLE test_dates (id Int32, dt64 DateTime64(6) DEFAULT toDateTime64('1970-01-01 00:00:00', 6, 'UTC'));
INSERT INTO test_dates (id, dt64) VALUES (1, toDateTime64('1970-01-15 06:56:07.891011', 6, 'UTC')), (2, toDateTime64('1970-01-15 06:56:07.000000', 6, 'UTC')), (3, toDateTime64('1970-01-15 06:56:07.123456', 6, 'UTC'));
SELECT id, toUnixTimestamp64Micro(dt64) AS unix_ts FROM test_dates WHERE toUnixTimestamp64Micro(dt64) ILIKE CAST('15' AS String);
SELECT id, (SELECT toUnixTimestamp64Micro(MAX(dt64)) FROM test_dates WHERE dt64 IS NOT NULL) AS max_ts FROM test_dates GROUP BY id HAVING toUnixTimestamp64Micro(dt64) < max_ts;
SELECT A.id, A.dt64 FROM test_dates A JOIN (SELECT id, toUnixTimestamp64Micro(dt64) AS ts FROM test_dates WHERE dt64 ILIKE '%6-7%') B ON A.id = B.id ORDER BY A.dt64 DESC;
CREATE TEMPORARY TABLE temp_dates AS SELECT id, dt64 FROM test_dates WHERE dt64 IS NULL;
INSERT INTO temp_dates (id, dt64) VALUES (4, NULL), (5, toDateTime64('', 6, 'UTC'));
SELECT COUNT(*) FROM temp_dates WHERE dt64 ILIKE '1970-01-15%';
WITH temp AS (SELECT id, toUnixTimestamp64Micro(dt64) AS ts FROM test_dates WHERE dt64 IS NOT NULL) SELECT AVG(ts) AS avg_ts FROM temp GROUP BY id HAVING avg_ts > 0;
SELECT id, toUnixTimestamp64Micro(COALESCE(dt64, toDateTime64('1970-01-01 00:00:00', 6, 'UTC'))) AS ts FROM test_dates WHERE dt64 ILIKE CAST('1970-01-15%' AS String);