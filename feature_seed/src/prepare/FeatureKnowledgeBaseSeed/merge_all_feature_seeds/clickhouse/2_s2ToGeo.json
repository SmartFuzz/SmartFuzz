CREATE TABLE geo_data (id UInt64, s2index UInt64, description String, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO geo_data (id, s2index, description, value) VALUES (1, 4704772434919038107, 'Test Point', 123.456);
INSERT INTO geo_data (id, s2index, description, value) VALUES (2, 0, 'Boundary Test', NULL);
SELECT id, s2ToGeo(s2index) AS coordinates FROM geo_data WHERE description NOT LIKE 'Test%';
SELECT id, s2ToGeo(s2index) AS coordinates FROM geo_data WHERE s2index NOT LIKE (SELECT MAX(s2index) FROM geo_data WHERE value > 100.0);
SELECT id, s2ToGeo(s2index) AS coordinates FROM geo_data WHERE NOT (s2ToGeo(s2index) NOT LIKE ('1.0,1.0'));
SELECT COUNT(*) FROM (SELECT id, s2ToGeo(s2index) AS geo_coords FROM geo_data WHERE s2index NOT LIKE (SELECT MIN(s2index) FROM geo_data));
SELECT AVG(value) AS average_value FROM geo_data WHERE s2ToGeo(s2index) NOT LIKE (SELECT s2ToGeo(4704772434919038107) FROM geo_data);
SELECT id, s2ToGeo(s2index), value FROM geo_data WHERE s2index NOT LIKE (SELECT id FROM (SELECT DISTINCT id FROM geo_data WHERE value IS NULL));
SELECT id, s2ToGeo(s2index) AS coordinates FROM geo_data GROUP BY id, s2ToGeo(s2index) HAVING coordinates NOT LIKE ('%0.0%');