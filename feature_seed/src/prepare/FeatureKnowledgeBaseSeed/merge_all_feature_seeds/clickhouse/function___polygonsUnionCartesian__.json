CREATE TABLE polygons_test (polygon1 ARRAY(ARRAY(Tuple(Float64, Float64))), polygon2 ARRAY(ARRAY(Tuple(Float64, Float64)));
INSERT INTO polygons_test VALUES ([[[(0., 0.), (1., 1.), (1., 0.), (0., 0.)]]], [[[(0.5, 0.5), (1.5, 1.5), (1.5, 0.5), (0.5, 0.5)]]]);
SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM polygons_test;
CREATE TABLE polygons_empty (polygon1 ARRAY(ARRAY(Tuple(Float64, Float64))), polygon2 ARRAY(ARRAY(Tuple(Float64, Float64)));
INSERT INTO polygons_empty VALUES ([[[]]], [[[(1., 1.), (2., 2.), (2., 3.), (1., 1.)]]]);
SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM polygons_empty;
CREATE TABLE polygons_overlap (polygon1 ARRAY(ARRAY(Tuple(Float64, Float64))), polygon2 ARRAY(ARRAY(Tuple(Float64, Float64)));
INSERT INTO polygons_overlap VALUES ([[[(0., 0.), (0., 4.), (5., 4.), (5., 0.), (0., 0.)]]], [[[(3., 1.), (3., 3.), (5., 3.), (5., 1.), (3., 1.)]]]);
SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM polygons_overlap;
CREATE TABLE polygons_complement (polygon1 ARRAY(ARRAY(Tuple(Float64, Float64))), polygon2 ARRAY(ARRAY(Tuple(Float64, Float64)));
INSERT INTO polygons_complement VALUES ([[[(1., 1.), (1., 4.), (4., 4.), (4., 1.), (1., 1.)]]], [[[(0., 0.), (0., 2.), (2., 2.), (2., 0.), (0., 0.)]]]);
SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM polygons_complement;
SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM (SELECT polygon1, polygon2 FROM polygons_test UNION SELECT polygon1, polygon2 FROM polygons_overlap);
SELECT COUNT(*) FROM (SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM polygons_test UNION ALL SELECT wkt(polygonsUnionCartesian(polygon1, polygon2)) FROM polygons_empty) AS combined_results;