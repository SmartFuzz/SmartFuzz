CREATE TABLE test_table (test_string String);
INSERT INTO test_table VALUES ('hello (world)');
INSERT INTO test_table VALUES ('regex * with + special chars?');
INSERT INTO test_table VALUES ('$^ .()[]{}|');
SELECT regexpQuoteMeta(test_string) AS quoted_string FROM test_table;
SELECT regexpQuoteMeta('Test with zero byte \0 in string') AS quoted_zero_byte;
SELECT regexpQuoteMeta(LOWER(test_string)) AS quoted_lower_case FROM test_table;
SELECT regexpQuoteMeta(CONCAT(test_string, ' extra string')) AS quoted_concatenated FROM test_table;
SELECT regexpQuoteMeta(SUBSTRING(test_string, 1, 5)) AS quoted_substring FROM test_table;
SELECT test_string, regexpQuoteMeta(test_string) AS quoted_string FROM test_table WHERE test_string LIKE '%special%';
CREATE TABLE another_table (id Int32, description String);
INSERT INTO another_table VALUES (1, 'Sample description (test)');
INSERT INTO another_table VALUES (2, 'Another description [sample]');
SELECT a.id, regexpQuoteMeta(a.description) AS quoted_description FROM another_table a JOIN test_table t ON a.id = 1;
SELECT regexpQuoteMeta(test_string) FROM test_table WHERE test_string NOT LIKE '%' || regexpQuoteMeta('()') || '%';
CREATE TABLE complex_table (id Int32, pattern String);
INSERT INTO complex_table VALUES (1, 'Complex pattern: * and ?');
INSERT INTO complex_table VALUES (2, 'Use of $ and ^ in regex');
SELECT id, regexpQuoteMeta(pattern) AS quoted_pattern FROM complex_table WHERE id > 0;