CREATE TABLE test_dates (id Int32, date_field Date, date_time_field DateTime, date_string_field String);
INSERT INTO test_dates VALUES (1, '2024-01-01', '2024-01-01 00:00:00', '2024-01-01 00:00:00');
INSERT INTO test_dates VALUES (2, '2023-02-29', '2023-02-28 00:00:00', '2023-02-28 00:00:00');
INSERT INTO test_dates VALUES (3, '2025-12-31', '2025-12-31 23:59:59', '2025-12-31 23:59:59');
SELECT addYears(date_field, 1) AS new_date FROM test_dates WHERE id = 1;
SELECT addYears(date_time_field, 5) AS new_date_time FROM test_dates WHERE id = 2;
SELECT addYears(date_string_field, -2) AS new_date_string FROM test_dates WHERE id = 3;
SELECT addYears(toDate('2024-03-01'), -1) AS adjusted_date;
WITH (SELECT date_field FROM test_dates WHERE id = 1) AS subquery_date SELECT addYears(subquery_date, 2) AS subquery_date_added;
WITH (SELECT date_time_field FROM test_dates WHERE id = 2) AS subquery_date_time SELECT addYears(subquery_date_time, 3) AS subquery_date_time_added;
WITH (SELECT date_string_field FROM test_dates WHERE id = 3) AS subquery_date_time_string SELECT addYears(subquery_date_time_string, 10) AS subquery_date_time_string_added;
SELECT id, addYears(date_field, num) AS modified_date FROM test_dates CROSS JOIN (SELECT 1 AS num) AS numbers;
SELECT id, addYears(date_time_field, num) AS modified_date_time FROM test_dates CROSS JOIN (SELECT -1 AS num) AS negative_numbers;
SELECT id, addYears(date_string_field, num) AS modified_date_string FROM test_dates CROSS JOIN (SELECT 0 AS num) AS zero_numbers;
CREATE TABLE date_operations (operation_result DateTime);
INSERT INTO date_operations SELECT addYears(addYears(date_field, 1), 1) FROM test_dates;
INSERT INTO date_operations SELECT addYears(addYears(date_time_field, -1), 2) FROM test_dates;
CREATE TABLE date_combination AS SELECT id, addYears(date_field, num) AS final_result FROM test_dates CROSS JOIN (SELECT 3 AS num) AS three_years;
SELECT * FROM date_combination WHERE final_result > '2025-12-31';