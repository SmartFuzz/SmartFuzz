CREATE TABLE test_values (x FLOAT);
INSERT INTO test_values VALUES (-0.9999), (-0.5), (0), (0.5), (0.9999);
SELECT atanh(x) FROM test_values;
SELECT atanh((SELECT x FROM test_values WHERE x = 0.5)) AS atanh_half;
SELECT atanh(x) FROM (SELECT x FROM test_values WHERE x > 0) AS positive_values;
SELECT atanh(x) FROM (SELECT x FROM test_values WHERE x < 0) AS negative_values;
CREATE TABLE results (result FLOAT);
INSERT INTO results (result) SELECT atanh(x) FROM test_values;
SELECT AVG(result) FROM results;
SELECT result FROM results WHERE result IN (SELECT atanh(x) FROM test_values);
WITH (SELECT atanh(x) FROM test_values) AS atanh_values SELECT * FROM atanh_values;