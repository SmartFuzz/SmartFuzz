CREATE TABLE test_table (id UInt32, value Float64);
INSERT INTO test_table VALUES (1, 10.5), (2, 20.0), (3, 30.0);
SELECT * FROM test_table WHERE greaterOrEquals(value, 15.0);
SELECT * FROM test_table WHERE greaterOrEquals(value, 10.5) AND id = 1;
SELECT * FROM test_table WHERE greaterOrEquals(value, (SELECT AVG(value) FROM test_table));
CREATE TABLE another_table (id UInt32, min_value Float64);
INSERT INTO another_table VALUES (1, 15.0), (2, 25.0);
SELECT t1.id FROM test_table t1 JOIN another_table t2 ON greaterOrEquals(t1.value, t2.min_value);
SELECT t1.id, t2.id FROM test_table t1, another_table t2 WHERE greaterOrEquals(t1.value + 5, t2.min_value);
SELECT COUNT(*) FROM test_table WHERE greaterOrEquals(value, 10) GROUP BY id HAVING greaterOrEquals(COUNT(*), 1);
CREATE TABLE nested_table AS SELECT id, value FROM test_table WHERE greaterOrEquals(value, 15.0);
SELECT * FROM nested_table WHERE greaterOrEquals(value, (SELECT MIN(value) FROM test_table));