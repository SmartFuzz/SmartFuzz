CREATE TABLE decimals_table (value Decimal32(9, 0));
INSERT INTO decimals_table VALUES (1000000000), (-1000000000), (999999999), (-999999999), (1234567891), (0);
SELECT isDecimalOverflow(value, 9) FROM decimals_table;
SELECT isDecimalOverflow(value) FROM (SELECT value FROM decimals_table WHERE value > 1000000000);
CREATE TABLE test_table (value Decimal32(9, 2), precision UInt8);
INSERT INTO test_table VALUES (123.45, 2), (100000.01, 2), (99999.99, 2), (-99999.99, 2), (999.99, 2);
SELECT isDecimalOverflow(value, precision) FROM test_table;
WITH (SELECT value FROM decimals_table LIMIT 1) AS sub_query SELECT isDecimalOverflow(sub_query, 10);
SELECT isDecimalOverflow(toDecimal32(10000.123, 3), 2) AS result1, isDecimalOverflow(toDecimal32(10000.123, 3)) AS result2;
SELECT (SELECT isDecimalOverflow(value, 5) FROM (SELECT value FROM decimals_table WHERE value < 0) AS inner_query) AS negative_check;
SELECT value, isDecimalOverflow(value, 8) FROM decimals_table WHERE value > 0;