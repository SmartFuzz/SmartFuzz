CREATE DATABASE IF NOT EXISTS test_db;
USE test_db;
CREATE TABLE IF NOT EXISTS test_table (id UInt64, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'Alice'), (2, 'Bob');
SELECT currentDatabase();
SELECT * FROM test_table WHERE currentDatabase() = 'test_db';
SELECT id, name FROM test_table WHERE currentDatabase() = currentDatabase();
CREATE TABLE IF NOT EXISTS another_table (id UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_table VALUES (1), (2), (3);
SELECT t.name, currentDatabase() FROM test_table t JOIN another_table a ON t.id = a.id;
WITH currentDatabase() AS current_db SELECT * FROM test_table WHERE currentDatabase() = current_db;
SELECT currentDatabase() AS db_name, COUNT(*) AS total FROM test_table GROUP BY db_name;
CREATE TABLE IF NOT EXISTS joined_table AS SELECT id, name FROM test_table WHERE currentDatabase() = 'test_db';
SELECT currentDatabase() AS current_db, (SELECT COUNT(*) FROM test_table) AS total_rows FROM joined_table WHERE currentDatabase() = current_db;