CREATE TABLE test_strings (id UInt64, str Nullable(String), count Int32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'www.straßen-in-europa.de', 2), (2, NULL, 1), (3, '', 0), (4, 'hello.world.example', -1);
SELECT id, substringIndexUTF8(str, '.', count) AS result FROM test_strings WHERE str IS NOT NULL AND count < 0;
SELECT id, substringIndexUTF8(str, '.', (count + 1) * -1) AS adjusted_result FROM test_strings WHERE adjusted_result IS NOT NULL AND adjusted_result != '';
CREATE TABLE test_numbers (num1 Int32, num2 Int32) ENGINE = MergeTree() ORDER BY num1;
INSERT INTO test_numbers VALUES (10, 20), (NULL, 30), (40, 50);
SELECT num1, num2, (substringIndexUTF8(CAST(num1 AS String), '0', 1) IS NOT NULL) AND (num2 > 15) AS logical_check FROM test_numbers WHERE num1 IS NOT NULL;
SELECT id, str, COUNT(*) OVER (PARTITION BY substringIndexUTF8(str, '.', 1)) AS count_per_group FROM test_strings GROUP BY str HAVING COUNT(*) > 1;
SELECT str, substringIndexUTF8(CAST(num1 AS String) || '|' || str, '|', 2) AS extracted_substring FROM test_strings JOIN test_numbers ON num1 = count;
SELECT substringIndexUTF8(str, '.', count) AS prefix FROM test_strings WHERE count IN (SELECT DISTINCT count FROM test_strings WHERE str IS NOT NULL) AND str != '';