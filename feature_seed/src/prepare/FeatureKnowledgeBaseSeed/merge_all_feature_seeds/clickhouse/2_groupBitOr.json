CREATE TABLE test_table (num UInt32, str String, val Int32, timestamp DateTime, nullable_num Nullable(Int32));
INSERT INTO test_table VALUES (1, 'test1', 5, '2023-01-01 12:00:00', NULL), (2, 'test2', 10, '2023-01-02 13:00:00', 20), (3, 'test3', 15, '2023-01-03 14:00:00', NULL);
SELECT groupBitOr(num) FROM test_table WHERE num <> 2 AND (val <> 10 OR str = 'test1');
SELECT groupBitOr(IFNULL(nullable_num, 0)) FROM test_table GROUP BY val HAVING groupBitOr(num) <> 5;
SELECT DISTINCT groupBitOr(CAST(val AS UInt32)) FROM test_table WHERE str <> 'test2' AND timestamp > '2023-01-01 00:00:00' GROUP BY val ORDER BY groupBitOr(val) DESC;
SELECT groupBitOr(num) AS bit_or FROM (SELECT num, str FROM test_table WHERE str <> 'test3') GROUP BY str HAVING COUNT(*) > 1;
CREATE TABLE temp_table AS SELECT DISTINCT num, str, timestamp FROM test_table WHERE nullable_num IS NULL;
SELECT groupBitOr(num) FROM temp_table WHERE (num <> 1 AND num <> 3) OR str <> '';
WITH (SELECT COUNT(*) FROM test_table WHERE val <> 15) AS cnt SELECT groupBitOr(num) FROM test_table GROUP BY cnt HAVING cnt > 0;
SELECT groupBitOr(num) FROM (SELECT num FROM test_table WHERE timestamp < now() - INTERVAL 1 DAY) AS temp WHERE num <> 0;