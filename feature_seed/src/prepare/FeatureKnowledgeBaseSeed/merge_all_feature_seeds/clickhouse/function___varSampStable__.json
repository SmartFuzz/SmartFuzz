DROP TABLE IF EXISTS test_data;
CREATE TABLE test_data (x Float64) ENGINE = Memory;
INSERT INTO test_data VALUES (10.5), (12.3), (9.8), (11.2), (10.7);
SELECT round(varSampStable(x), 3) AS var_samp_stable FROM test_data;
DROP TABLE IF EXISTS test_data_large;
CREATE TABLE test_data_large (x Float64) ENGINE = Memory;
INSERT INTO test_data_large SELECT number + 1.0 FROM numbers(1000000);
SELECT round(varSampStable(x), 3) AS var_samp_stable FROM test_data_large;
DROP TABLE IF EXISTS test_data_empty;
CREATE TABLE test_data_empty (x Float64) ENGINE = Memory;
SELECT round(varSampStable(x), 3) AS var_samp_stable FROM test_data_empty;
DROP TABLE IF EXISTS test_data_neg;
CREATE TABLE test_data_neg (x Float64) ENGINE = Memory;
INSERT INTO test_data_neg VALUES (-10.0), (-20.0), (-30.0);
SELECT round(varSampStable(x), 3) AS var_samp_stable FROM test_data_neg;
DROP TABLE IF EXISTS test_data_complex;
CREATE TABLE test_data_complex (x Float64, y Float64) ENGINE = Memory;
INSERT INTO test_data_complex VALUES (10.5, 1.0), (12.3, 1.5), (9.8, 2.0), (11.2, 2.5), (10.7, 3.0);
SELECT y, round(varSampStable(x), 3) AS var_samp_stable FROM test_data_complex GROUP BY y;
DROP TABLE IF EXISTS test_data_subquery;
CREATE TABLE test_data_subquery (x Float64) ENGINE = Memory;
INSERT INTO test_data_subquery VALUES (10.0), (15.0), (20.0);
SELECT round(varSampStable((SELECT x FROM test_data_subquery)), 3) AS var_samp_stable;
DROP TABLE IF EXISTS test_data_join;
CREATE TABLE test_data_join_1 (x Float64) ENGINE = Memory;
CREATE TABLE test_data_join_2 (y Float64) ENGINE = Memory;
INSERT INTO test_data_join_1 VALUES (5.0), (10.0), (15.0);
INSERT INTO test_data_join_2 VALUES (20.0), (25.0);
SELECT round(varSampStable(j.x), 3) AS var_samp_stable FROM (SELECT x FROM test_data_join_1 JOIN test_data_join_2 ON test_data_join_1.x < test_data_join_2.y) AS j;
DROP TABLE IF EXISTS test_data_null;
CREATE TABLE test_data_null (x Float64) ENGINE = Memory;
INSERT INTO test_data_null VALUES (NULL), (NULL), (12.0), (15.0);
SELECT round(varSampStable(x), 3) AS var_samp_stable FROM test_data_null;