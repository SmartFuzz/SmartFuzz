CREATE TABLE sum_map_test (date Date, timeslot DateTime, statusMap Nested(status UInt16, requests UInt64)) ENGINE = Log;
INSERT INTO sum_map_test VALUES ('2000-01-01', '2000-01-01 00:00:00', [1, 2, 3], [10, 10, 10]), ('2000-01-01', '2000-01-01 00:00:00', [3, 4, 5], [10, 10, 10]), ('2000-01-01', '2000-01-01 00:01:00', [4, 5, 6], [10, 10, 10]), ('2000-01-01', '2000-01-01 00:01:00', [6, 7, 8], [10, 10, 10]);
SELECT sumMapFiltered([1, 4, 8])(statusMap.status, statusMap.requests) FROM sum_map_test;
SELECT sumMapFiltered([2, 5])(statusMap.status, statusMap.requests) FROM sum_map_test WHERE date = '2000-01-01';
CREATE TABLE sum_map_join (id UInt32, data Nested(key UInt16, value UInt64)) ENGINE = Log;
INSERT INTO sum_map_join VALUES (1, [1, 2, 3], [10, 20, 30]), (2, [3, 4, 5], [40, 50, 60]);
SELECT sumMapFiltered([2, 4])(data.key, data.value) FROM sum_map_join JOIN sum_map_test ON sum_map_test.date = '2000-01-01';
WITH (SELECT arrayJoin(statusMap.status) AS statuses, arrayJoin(statusMap.requests) AS requests FROM sum_map_test) AS derived_table SELECT sumMapFiltered([1, 3])(statuses, requests) FROM sum_map_test;
CREATE TABLE sum_map_edge_cases (date Date, statusMap Nested(status UInt16, requests UInt64)) ENGINE = Log;
INSERT INTO sum_map_edge_cases VALUES ('2000-01-01', [1, 2], [10, 20]), ('2000-01-02', [1], [10]);
SELECT sumMapFiltered([1, 2, 3])(statusMap.status, statusMap.requests) FROM sum_map_edge_cases;
SELECT sumMapFiltered([10])(statusMap.status, statusMap.requests) FROM sum_map_test WHERE date = '2000-01-01' GROUP BY date;