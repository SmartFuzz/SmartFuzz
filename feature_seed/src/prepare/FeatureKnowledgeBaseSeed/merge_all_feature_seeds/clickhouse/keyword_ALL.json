CREATE TABLE test_table (id Int32, value String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'A'), (2, 'B'), (2, 'B'), (3, 'C');
SELECT ALL value FROM test_table;
SELECT ALL value FROM test_table WHERE id > 1;
SELECT ALL id, value FROM test_table WHERE value = 'B' ORDER BY id;
CREATE TABLE another_table (id Int32, category String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_table VALUES (1, 'X'), (2, 'Y'), (3, 'X');
SELECT ALL t1.id, t1.value, t2.category FROM test_table AS t1 JOIN another_table AS t2 ON t1.id = t2.id;
SELECT ALL id, COUNT(value) FROM test_table GROUP BY id;
SELECT ALL id, sum(value) FROM (SELECT id, value FROM test_table) GROUP BY id;
SELECT ALL AVG(value) FROM (SELECT id, value FROM test_table) WHERE id IN (SELECT id FROM another_table);
SELECT ALL id FROM test_table WHERE id IN (SELECT id FROM another_table WHERE category = 'X');
SELECT ALL t1.id FROM test_table AS t1 JOIN (SELECT id FROM another_table) AS t2 ON t1.id = t2.id;
SELECT ALL id FROM test_table WHERE EXISTS (SELECT 1 FROM another_table WHERE another_table.id = test_table.id);
SELECT ALL value FROM test_table WHERE value IN (SELECT category FROM another_table);
SELECT ALL t1.id, t1.value FROM test_table AS t1 LEFT JOIN another_table AS t2 ON t1.id = t2.id WHERE t2.category = 'Y' OR t2.category IS NULL;