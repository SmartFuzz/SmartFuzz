CREATE TABLE test_strings (id Int32, original String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, 'abc'), (2, 'def'), (3, 'ghi');
SELECT id, replaceRegexpAll(original, '([a-z])', '\\0\\0') - 1 AS res FROM test_strings;
SELECT id, (replaceRegexpAll(original, '([a-z])', '\\0\\0') - 1) AS modified FROM test_strings WHERE modified > 0;
CREATE TABLE test_numbers (num1 Int32, num2 Int32) ENGINE = MergeTree() ORDER BY num1;
INSERT INTO test_numbers VALUES (1, 2), (3, 4), (5, 6);
SELECT num1, replaceRegexpAll(CAST(num1 AS String), '1', 'X') - num2 AS result FROM test_numbers;
CREATE TABLE temp_results AS SELECT id, replaceRegexpAll(original, 'o', 'O') AS modified FROM test_strings;
SELECT modified, (modified - '4') AS diff FROM temp_results;
SELECT id, (replaceRegexpAll(original, 'd', '') - CAST(num1 AS String)) AS final_result FROM test_numbers, test_strings WHERE id = num1;