CREATE TABLE test_uuids (uuid String);
INSERT INTO test_uuids VALUES ('612f3c40-5d3b-217e-707b-6a546a3d7b29'), ('123e4567-e89b-12d3-a456-426614174000'), ('d92aeb3a-9e30-4bc0-b656-d23a7d3a6bba');
SELECT uuid, UUIDStringToNum(uuid) AS bytes FROM test_uuids;
SELECT uuid, UUIDStringToNum(uuid, 2) AS bytes FROM test_uuids;
SELECT uuid, UUIDStringToNum(uuid) AS bytes FROM test_uuids WHERE uuid LIKE '612f3c40-%';
SELECT (SELECT UUIDStringToNum(uuid) FROM test_uuids WHERE uuid = '123e4567-e89b-12d3-a456-426614174000') AS bytes;
SELECT a.uuid, b.bytes FROM test_uuids a JOIN (SELECT uuid, UUIDStringToNum(uuid) AS bytes FROM test_uuids) b ON a.uuid = '612f3c40-5d3b-217e-707b-6a546a3d7b29';
CREATE TABLE test_result (uuid String, bytes FixedString(16));
INSERT INTO test_result SELECT uuid, UUIDStringToNum(uuid) FROM test_uuids;
SELECT uuid, bytes FROM test_result WHERE bytes IS NOT NULL;
SELECT count(*) FROM (SELECT UUIDStringToNum(uuid) AS bytes FROM test_uuids GROUP BY bytes) AS unique_bytes;
SELECT a.uuid, UUIDStringToNum(a.uuid, 2) AS ms_bytes, UUIDStringToNum(b.uuid) AS be_bytes FROM test_uuids a, test_uuids b WHERE a.uuid != b.uuid;