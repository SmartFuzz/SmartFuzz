CREATE TABLE array_test_1 (arr1 Array(Int32), arr2 Array(Int32));
INSERT INTO array_test_1 VALUES ([1, 2, 3], [3, 4, 5]);
SELECT hasAny(arr1, arr2) AS intersection_exists FROM array_test_1;
CREATE TABLE array_test_2 (arr1 Array(String), arr2 Array(String));
INSERT INTO array_test_2 VALUES (['apple', 'banana'], ['banana', 'cherry']);
SELECT hasAny(arr1, arr2) AS items_in_common FROM array_test_2;
CREATE TABLE array_test_3 (arr1 Array(Float64), arr2 Array(Int32));
INSERT INTO array_test_3 VALUES ([1.1, 2.2, 3.3], [3, 4, 5]);
SELECT hasAny(arr1, arr2) AS floating_points_in_common FROM array_test_3;
CREATE TABLE array_test_4 (arr1 Array(Int32), arr2 Array(String));
INSERT INTO array_test_4 VALUES ([NULL, 1, 2], ['1', '2', '3']);
SELECT hasAny(arr1, arr2) AS has_nulls FROM array_test_4;
CREATE TABLE array_test_5 (arr1 Array(Int32), arr2 Array(Int32));
INSERT INTO array_test_5 VALUES ([], [5, 6, 7]);
SELECT hasAny(arr1, arr2) AS empty_array_case FROM array_test_5;
CREATE TABLE array_test_6 AS SELECT [1, 2, 3] AS arr1, [2, 3, 4] AS arr2;
SELECT hasAny(arr1, arr2) AS common_intersection FROM array_test_6;
CREATE TABLE array_test_7 AS SELECT [1, 2, 3] AS arr1, [] AS arr2;
SELECT hasAny(arr1, arr2) AS no_elements_in_array_two FROM array_test_7;
CREATE TABLE complex_test AS SELECT arr1, arr2 FROM (SELECT [1, 2] AS arr1, [2, 3] AS arr2 UNION ALL SELECT [4] AS arr1, [5] AS arr2);
SELECT hasAny(arr1, arr2) AS complex_intersection_check FROM complex_test;
CREATE TABLE nested_subquery_test AS SELECT [1, NULL] AS arr1, [NULL, 2] AS arr2;
SELECT (SELECT hasAny(arr1, arr2) FROM nested_subquery_test) AS nested_intersection;
CREATE TABLE join_test AS SELECT t1.arr1, t2.arr2 FROM (SELECT [1, 2] AS arr1) AS t1 JOIN (SELECT [2, 3] AS arr2) AS t2 ON hasAny(t1.arr1, t2.arr2);
SELECT hasAny(t1.arr1, t2.arr2) AS join_array_intersection FROM join_test;