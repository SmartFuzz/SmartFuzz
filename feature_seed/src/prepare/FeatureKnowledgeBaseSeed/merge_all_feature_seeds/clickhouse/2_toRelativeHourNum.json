CREATE TABLE test_dates (id UInt32, event_time DateTime, value Float64 DEFAULT 0);
INSERT INTO test_dates VALUES (1, toDateTime('2000-01-01 00:00:00'), 1.5), (2, toDateTime('2000-01-02 12:34:56'), 2.5), (3, toDateTime('2000-01-03 23:59:59'), 3.5), (4, toDateTime('2000-01-01 01:01:01'), NULL);
SELECT event_time, toRelativeHourNum(event_time) AS relative_hour FROM test_dates WHERE toRelativeHourNum(event_time) = 1 OR (event_time IS NULL);
SELECT id, COUNT(*) AS cnt FROM (SELECT toRelativeHourNum(event_time) AS h FROM test_dates GROUP BY h) AS sub WHERE h = 24 GROUP BY id HAVING cnt > 1;
SELECT id, value FROM test_dates WHERE value = toRelativeHourNum(toDateTime('2000-01-01 00:00:00')) / 2.0;
SELECT t1.id, t1.event_time FROM test_dates t1 JOIN test_dates t2 ON toRelativeHourNum(t1.event_time) = toRelativeHourNum(t2.event_time) WHERE t1.id != t2.id;
CREATE TABLE temp_dates AS SELECT *, toRelativeHourNum(event_time) AS relative_hour FROM test_dates WHERE value IS NOT NULL;
SELECT AVG(value) AS avg_value FROM temp_dates WHERE relative_hour = toRelativeHourNum(toDateTime('2000-01-02 12:34:56')) AND (value IS NOT NULL OR 1 = 1);
SELECT event_time FROM temp_dates WHERE toRelativeHourNum(event_time) = (SELECT MAX(toRelativeHourNum(event_time)) FROM temp_dates) AND event_time IS NOT NULL;
DROP TABLE temp_dates;