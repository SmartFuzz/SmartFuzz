CREATE TABLE test_arrays (id Int32, values Array(Int16));
INSERT INTO test_arrays VALUES (1, emptyArrayInt16()), (2, [1, 2, 3]), (3, emptyArrayInt16());
SELECT id, values FROM test_arrays WHERE values = emptyArrayInt16();
CREATE TABLE temp_numbers (num Int32);
INSERT INTO temp_numbers VALUES (1), (2), (3);
SELECT num, emptyArrayInt16() AS empty_arr FROM temp_numbers WHERE num > 0;
SELECT (SELECT emptyArrayInt16() UNION ALL SELECT [4, 5]) AS union_array;
SELECT id, array_length(emptyArrayInt16()) AS empty_length FROM test_arrays;
SELECT id, arrayJoin(values) AS individual_values FROM test_arrays;
SELECT id, (SELECT emptyArrayInt16() FROM test_arrays) AS nested_empty_arr FROM test_arrays;
SELECT t1.id, t1.values, (SELECT count(*) FROM temp_numbers) AS num_count FROM test_arrays t1 LEFT JOIN temp_numbers t2 ON t1.id = t2.num;
SELECT emptyArrayInt16() AS empty_array, COUNT(*) FROM test_arrays GROUP BY empty_array;