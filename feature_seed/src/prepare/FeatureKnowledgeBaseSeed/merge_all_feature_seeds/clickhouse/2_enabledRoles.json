CREATE TABLE test_roles (id UInt32, role_name String, value Float64);
INSERT INTO test_roles VALUES (1, 'admin', 10.0), (2, 'user', 20.5), (3, 'guest', NULL), (4, 'editor', 0.0);
SELECT id, enabledRoles() AS current_roles, role_name, value % (SELECT COUNT(*) FROM test_roles WHERE value IS NOT NULL) AS mod_value FROM test_roles HAVING mod_value > 0;
SELECT role_name, value, (SELECT COUNT(*) FROM test_roles WHERE enabledRoles()[1] = role_name) AS role_count, (enabledRoles()[1] % value) AS role_mod FROM test_roles WHERE role_mod IS NOT NULL ORDER BY role_mod DESC;
SELECT id, (value + 1) % (SELECT AVG(value) FROM test_roles) AS adjusted_value FROM test_roles GROUP BY id, adjusted_value HAVING adjusted_value > 0 AND adjusted_value < value;
SELECT AVG(value) AS average_value FROM test_roles WHERE enabledRoles() != [] GROUP BY enabledRoles()[1];
CREATE TABLE temp_roles AS SELECT *, enabledRoles() AS roles FROM test_roles WHERE value IS NOT NULL;
SELECT role_name, value % (SELECT MAX(value) FROM temp_roles) AS mod_value FROM temp_roles GROUP BY role_name HAVING mod_value IS NOT NULL OR role_name IS NULL;