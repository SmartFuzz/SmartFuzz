CREATE TABLE test_data (id Int32, data String, timestamp DateTime, hash_result FixedString(16));
INSERT INTO test_data VALUES (1, '', now()), (2, 'Hello World', now()), (3, NULL, now());
SELECT id, MD5(data) AS hash FROM test_data WHERE data IS NOT NULL OR id = 2;
SELECT id, data, MD5(data) AS hash FROM (SELECT id, data FROM test_data WHERE data IS NOT NULL UNION SELECT id, CAST(NULL AS String) AS data FROM test_data WHERE id = 3) AS subquery WHERE hash = MD5('Hello World');
SELECT id, COUNT(*) AS count FROM test_data GROUP BY id HAVING count > 0 OR (data IS NOT NULL AND data != '') ORDER BY hash_result DESC;
SELECT t1.id, t1.data, t2.data AS other_data FROM test_data AS t1 JOIN test_data AS t2 ON MD5(t1.data) = MD5(t2.data) OR t1.timestamp > t2.timestamp;
SELECT id, data FROM test_data WHERE LENGTH(data) > 0 OR MD5(data) IS NOT NULL;
SELECT COUNT(*) FROM (SELECT id, MD5(data) AS hash FROM test_data GROUP BY id HAVING hash IS NOT NULL) AS inner_query;
SELECT id, MD5(NULLIF(data, '')) AS hash_value FROM test_data WHERE timestamp < now() OR data IS NULL;