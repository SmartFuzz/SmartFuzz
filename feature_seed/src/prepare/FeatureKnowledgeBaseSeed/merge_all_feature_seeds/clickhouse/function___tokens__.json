CREATE TABLE tokens_test (input_string String);
INSERT INTO tokens_test VALUES ('test1,;
\\ test2,;
\\ test3,;
\\   test4');
INSERT INTO tokens_test VALUES ('single_token');
INSERT INTO tokens_test VALUES ('multiple,,tokens;
here');
INSERT INTO tokens_test VALUES ('');
INSERT INTO tokens_test VALUES ('only_special_!@#$$%&*()_+');
INSERT INTO tokens_test VALUES ('test1:test2:test3');
INSERT INTO tokens_test VALUES ('long_string_with_special_chars_&&^%$#@!');
SELECT tokens(input_string) AS tokens_output FROM tokens_test;
SELECT COUNT(*) FROM (SELECT tokens(input_string) AS tokens_output FROM tokens_test) AS subquery WHERE arrayLength(tokens_output) > 1;
SELECT arrayJoin(tokens(input_string)) AS individual_tokens FROM tokens_test;
SELECT input_string, tokens(input_string) AS tokens_output FROM tokens_test WHERE input_string != '';
SELECT tokens(input_string) AS tokens_output, COUNT(*) FROM tokens_test GROUP BY tokens_output;
SELECT tokens(input_string) AS tokens_output FROM tokens_test WHERE input_string LIKE '%test%';
SELECT t.input_string, arrayJoin(tokens(t.input_string)) AS individual_tokens FROM tokens_test AS t JOIN tokens_test AS t2 ON t.input_string != t2.input_string;