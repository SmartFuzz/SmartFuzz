CREATE TABLE ip_data (id UInt32, ip_num UInt32, ip_string String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO ip_data (id, ip_num, ip_string) VALUES (1, 3232235776, '192.168.1.0'), (2, 4294967295, '255.255.255.255'), (3, 0, '0.0.0.0');
SELECT id, IPv4NumToString(ip_num) AS ip_converted FROM ip_data WHERE IPv4NumToString(ip_num) LIKE '192.%';
SELECT id, IPv4NumToString(ip_num), COUNT(*) FROM ip_data GROUP BY IPv4NumToString(ip_num) HAVING COUNT(*) > 1;
SELECT id, IPv4NumToString(ip_num) AS ip_converted FROM (SELECT DISTINCT ip_num FROM ip_data) AS distinct_ips WHERE ip_converted LIKE '255.%';
SELECT DISTINCT ip_string, COUNT(*) FROM ip_data WHERE ip_string LIKE CONCAT('%', IPv4NumToString(ip_num), '%') GROUP BY ip_string;
SELECT ip_num, ip_string FROM ip_data WHERE ip_num IS NOT NULL AND IPv4NumToString(ip_num) LIKE '%0.0.0.0%';
CREATE TABLE temp_ip_data (id UInt32, ip_num Nullable(UInt32)) ENGINE = Memory;
INSERT INTO temp_ip_data (id, ip_num) VALUES (1, NULL), (2, 167772160), (3, 0);
SELECT id, IPv4NumToString(IFNULL(ip_num, 0)) AS ip_safe FROM temp_ip_data WHERE ip_safe LIKE '%0.0.0.0%';
SELECT (SELECT COUNT(*) FROM ip_data WHERE ip_num = NULL) AS null_count, (SELECT COUNT(*) FROM ip_data) AS total_count;
SELECT id, IPv4NumToString(ip_num * 1) AS ip_eval FROM ip_data WHERE ip_eval LIKE '192.%' OR ip_eval LIKE '0.0.0.0';
SELECT id, COUNT(*) FROM (SELECT DISTINCT IPv4NumToString(ip_num) AS ip_all FROM ip_data) AS unique_ips GROUP BY ip_all HAVING COUNT(*) < 3;