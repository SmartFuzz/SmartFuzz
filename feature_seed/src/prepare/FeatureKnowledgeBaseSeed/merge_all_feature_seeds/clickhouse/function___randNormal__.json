CREATE TABLE test_randNormal (id UInt8, result Float64);
INSERT INTO test_randNormal VALUES (1, randNormal(0, 1)), (2, randNormal(0, 0.001)), (3, randNormal(-10, 5));
SELECT result FROM test_randNormal WHERE result > 0;
SELECT count(*) FROM (SELECT randNormal(5, 3) FROM numbers(100));
WITH (SELECT avg(result) FROM test_randNormal) AS avg_result SELECT randNormal(avg_result, 4) FROM numbers(10);
SELECT randNormal(50, 4) AS random_value, count(*) FROM test_randNormal GROUP BY random_value;
SELECT id, randNormal(id, 1) FROM (SELECT id FROM numbers(10)) AS numbers_table;
CREATE TABLE random_numbers AS SELECT randNormal(10, 2) AS random_value FROM numbers(50);
SELECT avg(random_value) FROM random_numbers WHERE random_value < 12;
WITH (SELECT randNormal(10, 2) AS r1, randNormal(20, 5) AS r2) AS randoms SELECT r1 + r2 AS combined_random FROM randoms;