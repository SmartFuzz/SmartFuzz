CREATE TABLE test_strings (value String);
INSERT INTO test_strings VALUES ('foo\nbar\nbaz');
INSERT INTO test_strings VALUES ('single line string');
INSERT INTO test_strings VALUES ('first line\nsecond line\nthird line');
SELECT firstLine(value) FROM test_strings;
SELECT firstLine(value) AS first_line FROM test_strings WHERE value LIKE '%\n%';
SELECT firstLine(value) FROM (SELECT value FROM test_strings WHERE value LIKE '%\n%') AS subquery;
CREATE TABLE test_multi_lines (id Int32, value String);
INSERT INTO test_multi_lines VALUES (1, 'line one\nline two\nline three'), (2, 'only one line');
SELECT id, firstLine(value) FROM test_multi_lines;
SELECT id, firstLine(value) FROM (SELECT id, value FROM test_multi_lines) AS subquery;
CREATE TABLE test_complex (id Int32, description String);
INSERT INTO test_complex VALUES (1, 'value1\nvalue2\nvalue3'), (2, 'valueA');
SELECT firstLine(description) FROM test_complex WHERE id = 1;
SELECT firstLine(description) FROM (SELECT description FROM test_complex WHERE id = 2) AS subquery;
SELECT firstLine(CONCAT(value1, '\n', value2)) FROM (SELECT value AS value1, 'extra line\n' AS value2 FROM test_strings) AS combined;