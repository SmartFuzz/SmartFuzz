SELECT toTypeName(123);
SELECT toTypeName('hello');
CREATE TABLE test_table (id UInt32, name String, value Nullable(Float64));
INSERT INTO test_table VALUES (1, 'test1', NULL), (2, 'test2', 10.5), (3, 'test3', NULL);
SELECT toTypeName(value) FROM test_table;
SELECT toTypeName(NULL);
SELECT toTypeName((SELECT value FROM test_table WHERE id = 2));
SELECT toTypeName(CAST('2021-01-01' AS Date));
SELECT toTypeName((SELECT max(value) FROM test_table));
SELECT toTypeName(CONCAT('hello', ' world'));
CREATE TABLE nested_table (id Int32);
INSERT INTO nested_table VALUES (1), (2), (3);
SELECT toTypeName((SELECT id FROM nested_table WHERE id > 1));
SELECT toTypeName((SELECT count(*) FROM test_table WHERE value IS NOT NULL));
SELECT toTypeName((SELECT * FROM test_table WHERE name = 'test2' LIMIT 1).value);
SELECT toTypeName(name) AS name_type, toTypeName(value) AS value_type FROM test_table;