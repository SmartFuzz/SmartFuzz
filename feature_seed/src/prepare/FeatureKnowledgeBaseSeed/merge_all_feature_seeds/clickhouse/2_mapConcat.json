CREATE TABLE test_map (key String, value Int32, additional_value Nullable(Int32));
INSERT INTO test_map VALUES ('key1', 1, NULL), ('key2', 2, 3), ('key1', 4, 5);
SELECT mapConcat(map(key, value), map('key2', 6)) AS merged_map FROM test_map WHERE key = 'key1' AND NOT (value > 0);
SELECT mapConcat(map('key1', value), map('key2', 2)) AS merged_map, additional_value FROM test_map WHERE (map['key1'] > 2) OR (additional_value IS NOT NULL);
SELECT COUNT(*) FROM (SELECT mapConcat(map(key, value), map('key1', value + 1)) AS result_map FROM test_map GROUP BY key HAVING result_map['key1'] > 2);
WITH (SELECT mapConcat(map('key2', 1), map('key3', NULL)) AS inner_map FROM test_map) AS combined_map SELECT combined_map AS outer_map WHERE outer_map['key2'] > 0;
SELECT mapConcat(map(key, value), (SELECT map('key4', 4) FROM test_map WHERE key = 'key3')) AS final_map FROM test_map WHERE value > (SELECT MAX(value) FROM test_map WHERE additional_value IS NOT NULL);