CREATE TABLE test_table (id UInt32, value String, created_at DateTime, status Nullable(String));
INSERT INTO test_table VALUES (1, 'test', '2023-01-01 00:00:00', 'active'), (2, NULL, '2023-01-02 00:00:00', 'pending'), (3, '', now(), NULL);
SELECT id, value, status FROM test_table WHERE created_at > '2023-01-01 00:00:00' AND status IS NOT NULL;
SELECT id, value FROM test_table WHERE (status = 'active' AND value != '') OR (value IS NULL AND status IS NOT NULL);
SELECT id, (value AND status) AS logical_check FROM test_table WHERE created_at < now();
SELECT id, value FROM (SELECT id, value, (created_at > '2022-12-31') AS is_new FROM test_table) AS subquery WHERE is_new AND value <> '';
SELECT COUNT(*) FROM test_table WHERE (created_at > now() AND status IS NULL) OR (created_at < now() AND value = '');
SELECT AVG(id) FROM test_table GROUP BY (value AND status) HAVING COUNT(*) > 0;
SELECT id, value FROM test_table WHERE (SELECT COUNT(*) FROM test_table WHERE status = 'pending') > 0 AND value != '' AND status IS NOT NULL;
SELECT id FROM test_table WHERE (value AND (SELECT status FROM test_table WHERE created_at < '2023-01-01' LIMIT 1)) IS NOT NULL;