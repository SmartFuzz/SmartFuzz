CREATE TABLE test_shingle (id UInt32, text String);
INSERT INTO test_shingle VALUES (1, 'ClickHouse is a powerful analytical database.'), (2, 'ClickHouse is a fast database designed for analytics.');
SELECT wordShingleMinHash(text, 3, 6) AS hashes FROM test_shingle WHERE wordShingleMinHash(text, 3, 6).1 > 0;
SELECT id, text FROM test_shingle WHERE wordShingleMinHash(text, 5, 10).2 > wordShingleMinHash('', 3, 6).1;
SELECT text, (SELECT wordShingleMinHash(text, 3, 10) FROM test_shingle WHERE id = 1) AS minhash FROM test_shingle WHERE text IS NOT NULL;
SELECT a.text, b.text FROM test_shingle a JOIN test_shingle b ON wordShingleMinHash(a.text, 4, 5).1 > wordShingleMinHash(b.text, 4, 5).2;
SELECT COUNT(*) FROM test_shingle HAVING wordShingleMinHash(text, 3, 5) IS NOT NULL AND COUNT(*) > 0;
CREATE TABLE test_numbers (num UInt64, desc String) ENGINE = MergeTree() ORDER BY num;
INSERT INTO test_numbers VALUES (1, 'one'), (2, 'two'), (3, 'three'), (4, 'four');
SELECT a.num, a.desc FROM test_numbers a WHERE a.num > (SELECT max(num - 1) FROM test_numbers) AND wordShingleMinHash(a.desc, 2, 6).1 > 0;
SELECT MIN(num) AS min_num FROM test_numbers GROUP BY desc HAVING min_num > (SELECT max(num) FROM test_numbers WHERE desc IS NOT NULL);
SELECT a.num, b.text FROM test_numbers a JOIN test_shingle b ON wordShingleMinHash(b.text, 5, 6).2 > a.num WHERE a.num IS NOT NULL;