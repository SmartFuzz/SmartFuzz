CREATE TABLE salary (user String, salary Int64) ENGINE = Memory;
INSERT INTO salary VALUES ('Alice', 70000), ('Bob', 80000), ('Charlie', 80000), ('David', 60000);
SELECT argMax(user, salary) FROM salary;
CREATE TABLE test (a Nullable(String), b Nullable(Int64)) ENGINE = Memory AS SELECT * FROM VALUES(('a', 1), ('b', 2), ('c', 2), (NULL, 3), (NULL, NULL), ('d', NULL));
SELECT argMax(a, b), max(b) FROM test;
SELECT argMax(tuple(a), b) FROM test;
SELECT (argMax((a, b), b) as t).1 argMaxA, t.2 argMaxB FROM test;
SELECT argMax(a, b) FROM test WHERE a IS NOT NULL;
SELECT argMax(a, b) FROM test WHERE b IS NULL;
SELECT argMax(a, (b, a)) FROM test;
SELECT argMax(a, tuple(b, a)) FROM test;
CREATE TABLE employee (name String, salary Int64, department String) ENGINE = Memory;
INSERT INTO employee VALUES ('Alice', 70000, 'HR'), ('Bob', 80000, 'IT'), ('Charlie', 80000, 'IT'), ('David', 60000, 'Finance');
SELECT argMax(name, salary) FROM employee WHERE department = 'IT';
SELECT argMax(name, salary) FROM (SELECT name, salary FROM employee WHERE salary > 50000) AS subquery;
SELECT argMax(name, salary) FROM employee GROUP BY department;
CREATE TABLE department (dept_name String, budget Int64) ENGINE = Memory;
INSERT INTO department VALUES ('HR', 100000), ('IT', 200000), ('Finance', 150000);
SELECT argMax(dept_name, budget) FROM department;
SELECT (argMax((name, salary), salary) AS res).1 AS max_name, res.2 AS max_salary FROM employee;