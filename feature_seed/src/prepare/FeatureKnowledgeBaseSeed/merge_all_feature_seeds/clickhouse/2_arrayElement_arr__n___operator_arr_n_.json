CREATE TABLE test_table(arr Array(Int32), nullable_val Nullable(Int32));
INSERT INTO test_table SELECT [1, 2, 3, 4, 5], NULL UNION ALL SELECT [10, 20], 20 UNION ALL SELECT [], 30;
SELECT arrayElement(arr, 1) AS first_value, nullable_val IS NULL AS is_null_check FROM test_table WHERE arrayElement(arr, 2) IS NOT NULL;
SELECT arrayElement(arr, -1) AS last_value WHERE nullable_val IS NULL OR arrayElement(arr, -2) IS NULL;
SELECT arrayElement(arr, arrayElement([1, 2, 3], 2)) AS dynamic_index FROM test_table WHERE arr[1] IS NOT NULL;
SELECT nullable_val, arrayElement(arr, 0) IS NULL AS null_index_check FROM test_table HAVING arrayElement(arr, -3) = 0;
SELECT count() FROM test_table WHERE arrayElement(arr, 5) IS NULL OR (nullable_val IS NOT NULL AND arrayElement(arr, -1) > 0) GROUP BY nullable_val HAVING count() > 1;