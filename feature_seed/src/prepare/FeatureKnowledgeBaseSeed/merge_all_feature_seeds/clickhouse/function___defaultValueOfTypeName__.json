CREATE TABLE test_types (id Int32, value String, nullable_value Nullable(Int32));
INSERT INTO test_types VALUES (1, 'test', NULL), (2, 'example', 10), (3, 'sample', NULL);
SELECT defaultValueOfTypeName('Int32');
SELECT defaultValueOfTypeName('String');
SELECT defaultValueOfTypeName('Nullable(Int32)');
SELECT defaultValueOfTypeName('Nullable(String)');
SELECT (SELECT defaultValueOfTypeName('Int8')) AS default_int8, (SELECT defaultValueOfTypeName('Nullable(String)')) AS default_nullable_string;
SELECT id, value, defaultValueOfTypeName('Int32') AS default_int32 FROM test_types WHERE value = 'test';
SELECT COUNT(*) FROM test_types WHERE nullable_value IS NULL AND defaultValueOfTypeName('Nullable(Int32)') = 'NULL';
WITH (SELECT defaultValueOfTypeName('Int64')) AS default_int64, (SELECT defaultValueOfTypeName('String')) AS default_string SELECT default_int64, default_string;
SELECT id, value FROM test_types WHERE id IN (SELECT id FROM test_types WHERE nullable_value IS NOT NULL) AND defaultValueOfTypeName('Int32') = 0;