CREATE TABLE test_map (a Map(String, String)) ENGINE = Memory;
INSERT INTO test_map VALUES ({'apple':'red','banana':'yellow','anise':'herb'}), ({'kiwi':'green','apricot':'orange'});
SELECT mapContainsKeyLike(a, 'a%') FROM test_map;
SELECT mapContainsKeyLike(a, 'b%') FROM test_map;
SELECT mapContainsKeyLike(a, '%e') FROM test_map;
SELECT mapContainsKeyLike(a, 'ap%') FROM test_map;
SELECT mapContainsKeyLike(a, 'z%') FROM test_map;
CREATE TABLE another_map (b Map(String, String)) ENGINE = Memory;
INSERT INTO another_map VALUES ({'avocado':'green','blueberry':'blue'});
SELECT mapContainsKeyLike(b, 'b%') FROM another_map;
SELECT mapContainsKeyLike(a, '%%') FROM test_map;
CREATE TABLE complex_map AS SELECT a FROM test_map UNION ALL SELECT b FROM another_map;
SELECT mapContainsKeyLike(a, 'a%') FROM complex_map WHERE mapContainsKeyLike(a, 'b%');
SELECT COUNT(*) FROM test_map WHERE mapContainsKeyLike(a, 'a%') AND mapContainsKeyLike(a, '%h');
CREATE TABLE final_table AS SELECT mapContainsKeyLike(a, 'a%') AS like_a FROM test_map;
SELECT * FROM final_table WHERE like_a = 1;
INSERT INTO final_table SELECT mapContainsKeyLike(b, 'g%') FROM another_map;
SELECT mapContainsKeyLike((SELECT a FROM test_map LIMIT 1), 'a%') AS subquery_test;