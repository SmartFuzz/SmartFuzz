CREATE TABLE test_decimal (value Float64);
INSERT INTO test_decimal VALUES (123.45678), (987.65432), (0.12345), (-0.98765);
SELECT toDecimalString(value, 2) FROM test_decimal;
SELECT toDecimalString(value, 5) FROM test_decimal;
SELECT toDecimalString(value, 0) FROM test_decimal;
SELECT (SELECT toDecimalString(value, 3) FROM test_decimal WHERE value > 0) AS positive_decimals;
SELECT (SELECT toDecimalString(value, 4) FROM test_decimal WHERE value < 0) AS negative_decimals;
CREATE TABLE test_numbers (num Float64);
INSERT INTO test_numbers VALUES (1.1), (2.2), (3.3);
SELECT toDecimalString((SELECT sum(num) FROM test_numbers), 1);
SELECT toDecimalString((SELECT avg(num) FROM test_numbers), 2);
SELECT toDecimalString(value, 5) FROM (SELECT * FROM test_decimal) AS subquery WHERE value IS NOT NULL;
SELECT toDecimalString(ROUND(value, 2), 3) FROM test_decimal WHERE value > 100;
CREATE TABLE test_boundary (int_val UInt8);
INSERT INTO test_boundary VALUES (77);
SELECT toDecimalString((SELECT max(int_val) FROM test_boundary), 0);
CREATE TABLE test_float (float_val Float32);
INSERT INTO test_float VALUES (1.123456789), (2.987654321);
SELECT toDecimalString(float_val, 60) FROM test_float;
SELECT toDecimalString(value, 77) FROM test_decimal WHERE value < 0;
CREATE TABLE test_combined (a Float64, b Float64);
INSERT INTO test_combined VALUES (1.1, 1.2), (2.2, 2.3);
SELECT toDecimalString(a + b, 2) FROM test_combined;
SELECT toDecimalString(((SELECT avg(a) FROM test_combined) + (SELECT avg(b) FROM test_combined)), 3);