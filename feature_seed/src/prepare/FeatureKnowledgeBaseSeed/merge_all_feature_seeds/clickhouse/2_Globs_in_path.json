CREATE TABLE test_files (name String, value UInt32) ENGINE = MergeTree() ORDER BY name;
INSERT INTO test_files VALUES ('file1', 1), ('file2', 2), ('file3', 3);
SELECT count(*) FROM hdfs('hdfs://hdfs1:9000/{dir1,dir2}/file{1..3}', 'TSV', 'name String, value UInt32') WHERE value > (SELECT AVG(value) FROM test_files);
SELECT tuple(name, value) FROM test_files WHERE value < 3 AND name LIKE 'file%';
SELECT name, tuple((SELECT count(*) FROM hdfs('hdfs://hdfs1:9000/dir/*', 'TSV', 'name String, value UInt32')), value) FROM test_files GROUP BY name HAVING value IS NOT NULL;
INSERT INTO test_files VALUES ('file4', NULL), ('file5', 5);
SELECT name, value FROM test_files WHERE value IS NULL OR value IS NOT NULL ORDER BY tuple(name, value) DESC;
SELECT count(*) FROM hdfs('hdfs://hdfs1:9000/dir/{data1,data2}/file{1..3}?', 'CSV', 'name String, value UInt32') GROUP BY tuple(value) HAVING count() > 1;
SELECT tuple(count(), AVG(value)) FROM test_files WHERE value BETWEEN 1 AND 3;
DROP TABLE IF EXISTS temp_table;
CREATE TEMPORARY TABLE temp_table AS SELECT tuple(name, value) FROM test_files WHERE value IS NOT NULL;