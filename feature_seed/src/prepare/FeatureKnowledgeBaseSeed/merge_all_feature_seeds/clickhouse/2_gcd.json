CREATE TABLE gcd_test (num1 Int32, num2 Int32, result Int32);
INSERT INTO gcd_test VALUES (0, 5), (-1, 1), (10, NULL), (7, 0), (15, 5), (9, 6);
SELECT gcd(num1, num2) as gcd_val FROM gcd_test WHERE gcd(num1, num2) IS NOT NULL;
SELECT result FROM gcd_test WHERE result = gcd(num1, num2) OR num1 = num2;
SELECT num1, num2, gcd(num1, num2) as gcd_val FROM gcd_test WHERE (gcd(num1, num2) > 1 OR gcd(num2, num1) > 1);
SELECT num1, num2, CASE WHEN gcd(num1, num2) IS NULL THEN 'Undefined' ELSE 'Defined' END AS gcd_status FROM gcd_test;
SELECT a, b, gcd(a, b) AS gcd_res FROM (SELECT num1 AS a, num2 AS b FROM gcd_test WHERE num1 > 0) AS subquery WHERE a OR b;
CREATE TABLE temp_gcd_test AS SELECT num1, num2, gcd(num1, num2) AS result FROM gcd_test;
SELECT DISTINCT gcd(num1, num2) FROM temp_gcd_test GROUP BY gcd(num1, num2) HAVING gcd(num1, num2) > 0;
SELECT num1, num2, gcd(num1, 5) + gcd(num2, 10) AS combined_gcd FROM gcd_test WHERE num2 IS NOT NULL;