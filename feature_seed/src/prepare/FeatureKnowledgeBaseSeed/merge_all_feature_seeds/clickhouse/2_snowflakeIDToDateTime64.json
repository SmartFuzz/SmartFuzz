CREATE TABLE test_table (id UInt64, snowflake_id UInt64, timestamp DateTime64(3), array_column Array(UInt64));
INSERT INTO test_table (id, snowflake_id, timestamp, array_column) VALUES (1, 7204436857747984384, NOW(), [100, 200, 300]);
SELECT id, snowflakeIDToDateTime64(arrayElement(array_column, 2)) AS snowflake_time FROM test_table WHERE snowflake_time IS NOT NULL;
SELECT id, snowflakeIDToDateTime64(snowflake_id) AS snowflake_time FROM test_table WHERE arrayElement(array_column, 1) > 150;
SELECT id, snowflakeIDToDateTime64(snowflake_id, 1288834974657) AS snowflake_time FROM test_table WHERE snowflake_time IS NOT NULL HAVING snowflake_time >= '2022-01-01 00:00:00.000';
INSERT INTO test_table (id, snowflake_id, timestamp, array_column) VALUES (2, 7204436857747984385, NULL, [1, 2, NULL]);
SELECT id, ifNull(snowflakeIDToDateTime64(snowflake_id), '1970-01-01 00:00:00.000') AS snowflake_time FROM test_table;
SELECT id, snowflakeIDToDateTime64(snowflake_id) AS snowflake_time, arrayElement(array_column, 1) * 2 AS doubled_value FROM test_table WHERE doubled_value < 500;
SELECT id, snowflakeIDToDateTime64(snowflake_id) AS snowflake_time FROM test_table WHERE arrayElement(array_column, 1) = cast('2' AS UInt64);
SELECT id, snowflakeIDToDateTime64(arrayElement(array_column, 1)) AS snowflake_time FROM test_table WHERE snowflake_time IS NOT NULL ORDER BY snowflake_time DESC;