DROP TABLE IF EXISTS test;
CREATE TABLE test (n UInt8) ENGINE = Memory;
INSERT INTO test SELECT * FROM system.numbers LIMIT 10;
SELECT blockSize() FROM test;
DROP TABLE IF EXISTS test2;
CREATE TABLE test2 (m UInt8) ENGINE = Memory;
INSERT INTO test2 SELECT * FROM system.numbers LIMIT 8;
SELECT blockSize() FROM (SELECT * FROM test UNION ALL SELECT * FROM test2) AS combined;
DROP TABLE IF EXISTS test3;
CREATE TABLE test3 (x UInt8, y UInt8) ENGINE = Memory;
INSERT INTO test3 SELECT number, number + 1 FROM system.numbers LIMIT 15;
SELECT blockSize() FROM (SELECT x, blockSize() AS blockSize FROM test3 GROUP BY x) AS subquery;
SELECT SUM(blockSize()) FROM (SELECT blockSize() FROM test UNION ALL SELECT blockSize() FROM test2) AS totalSize;
DROP TABLE IF EXISTS test4;
CREATE TABLE test4 (id UInt8, value UInt8) ENGINE = Memory;
INSERT INTO test4 SELECT number, number MOD 2 FROM system.numbers LIMIT 20;
SELECT id, blockSize() FROM (SELECT id, blockSize() FROM test4 WHERE value = 0) AS filtered WHERE id < 10;
DROP TABLE IF EXISTS test5;
CREATE TABLE test5 (n UInt8, processed UInt8) ENGINE = Memory;
INSERT INTO test5 SELECT number, number % 3 FROM system.numbers LIMIT 30;
SELECT AVG(blockSize()) FROM (SELECT blockSize() FROM test5 GROUP BY processed) AS avgBlockSize;