CREATE TABLE test_strings (id UInt32, text String);
INSERT INTO test_strings VALUES (1, 'ClickHouse'), (2, 'Clickhouse'), (3, 'Click Ho use'), (4, 'Cl ckHous'), (5, 'Query Performance');
SELECT ngramSimHashUTF8(text, 3) AS Hash FROM test_strings;
SELECT ngramSimHashUTF8(text, 1) AS Hash FROM test_strings WHERE id = 1;
SELECT ngramSimHashUTF8(text, 25) AS Hash FROM test_strings WHERE id = 2;
SELECT ngramSimHashUTF8(text) AS Hash FROM (SELECT text FROM test_strings WHERE id IN (1, 2, 3));
SELECT t1.id, ngramSimHashUTF8(t1.text) AS Hash1, ngramSimHashUTF8(t2.text) AS Hash2 FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.id != t2.id;
SELECT id, ngramSimHashUTF8(CONCAT(text, ' Extra'), 4) AS HashExtra FROM test_strings;
SELECT DISTINCT ngramSimHashUTF8(text) AS UniqueHash FROM (SELECT text FROM test_strings);
SELECT ngramSimHashUTF8(text) AS Hash FROM test_strings WHERE text LIKE 'Click%';
SELECT AVG(ngramSimHashUTF8(text, 2)) AS AvgHash FROM test_strings;
CREATE TABLE test_results (hash UInt64, source_id UInt32);
INSERT INTO test_results SELECT ngramSimHashUTF8(text, 3), id FROM test_strings;
SELECT r.source_id, r.hash, ngramSimHashUTF8(s.text) AS SimilarHash FROM test_results AS r JOIN test_strings AS s ON r.hash = ngramSimHashUTF8(s.text) WHERE r.hash != 0;