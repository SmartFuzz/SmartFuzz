CREATE TABLE test_strings (id Int32, sample_string String);
INSERT INTO test_strings VALUES (1, '1! 2@ 3# hello'), (2, 'world! 4$ 5% 6^'), (3, ''), (4, 'abc! 123# '), (5, NULL);
SELECT id, splitByNonAlpha(sample_string, 3) AS substrings FROM test_strings WHERE sample_string IS NOT NULL;
SELECT id, splitByNonAlpha(sample_string, 2) AS substrings, arrayJoin(substrings) AS substring FROM (SELECT id, splitByNonAlpha(sample_string, 2) FROM test_strings) GROUP BY id, substring HAVING LENGTH(substring) > 0;
SELECT id, arrayMap(x -> x * 2, splitByNonAlpha(sample_string)) AS multiplied_substrings FROM test_strings WHERE id BETWEEN 1 AND 3;
SELECT id, splitByNonAlpha(sample_string) AS substrings, COUNT(*) AS substring_count FROM test_strings GROUP BY id HAVING substring_count > 1;
SELECT SUM(length) FROM (SELECT LENGTH(arrayJoin(splitByNonAlpha(sample_string))) AS length FROM test_strings WHERE sample_string IS NOT NULL) GROUP BY id HAVING SUM(length) > 0;
SELECT id, multiply(NULL, 5) as product_nullable, splitByNonAlpha(CAST(product_nullable AS String)) AS substrings FROM (SELECT id, id * 5 AS product_nullable FROM test_strings) WHERE id IS NOT NULL;
WITH splitByNonAlpha('a1-b2-c3', 2) AS substrings SELECT id, arrayJoin(substrings) * id AS transformed_substrings FROM test_strings;
SELECT id, splitByNonAlpha(sample_string) AS substrings FROM (SELECT id, sample_string FROM test_strings WHERE sample_string IS NOT NULL AND sample_string != '') WHERE id IN (SELECT MAX(id) FROM test_strings WHERE id NOT IN (SELECT MIN(id) FROM test_strings WHERE sample_string IS NOT NULL));