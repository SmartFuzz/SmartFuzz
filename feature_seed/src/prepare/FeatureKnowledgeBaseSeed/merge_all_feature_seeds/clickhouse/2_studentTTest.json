CREATE TABLE student_ttest (id UInt32, sample_data Float64, sample_index Int32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO student_ttest VALUES (1, 1.5, 0), (2, 2.3, 0), (3, 3.7, 1), (4, NULL, 1), (5, 5.1, 0);
SELECT studentTTest(sample_data, sample_index) FROM student_ttest GROUP BY sample_index HAVING NOT (sample_index = 0);
SELECT sample_index, studentTTest(sample_data, sample_index) OVER (PARTITION BY sample_index) AS test_result FROM (SELECT sample_data, sample_index FROM student_ttest WHERE NOT (sample_data IS NULL));
SELECT (SELECT studentTTest(sample_data, sample_index) FROM student_ttest WHERE sample_index = 1) AS statistic, NOT (sample_index = 0) AS negated FROM student_ttest;
SELECT studentTTest(sample_data, IF(sample_index = 0, 0, 1)) FROM (SELECT sample_data, sample_index FROM student_ttest WHERE sample_data > 2.0) WHERE NOT (sample_index IS NULL) GROUP BY sample_index;
CREATE TEMPORARY TABLE temp_ttest (id UInt32, sample_data Decimal(10, 2), sample_index Int32) ENGINE = Memory;
INSERT INTO temp_ttest VALUES (1, 10.00, 0), (2, 20.00, 1), (3, 30.00, 0), (4, NULL, 1);
SELECT studentTTest(COALESCE(sample_data, 0), NOT sample_index) FROM temp_ttest HAVING sample_index IN (0, 1);
SELECT studentTTest(sample_data, sample_index) FROM student_ttest ORDER BY NOT (sample_index = 0) LIMIT 10;