CREATE TABLE test_dates (id UInt32, event_time DateTime64(6), description String);
INSERT INTO test_dates VALUES (1, toDateTime64('2024-01-01 00:00:00', 6), 'New Year Event');
INSERT INTO test_dates VALUES (2, toDateTime64('2024-01-01 00:00:01', 6), 'First Second of 2024');
INSERT INTO test_dates VALUES (3, toDateTime64('2024-01-01 00:00:02', 6), NULL);
SELECT id, addMicroseconds(event_time, 1000000) AS updated_event_time, event_time - addMicroseconds(event_time, 500000) AS time_difference FROM test_dates WHERE event_time IS NOT NULL;
SELECT event_time, addMicroseconds((SELECT event_time FROM test_dates WHERE id = 1), -500000) AS adjusted_time FROM test_dates WHERE id = 2;
SELECT t1.id, addMicroseconds(t1.event_time, (SELECT COUNT(*) FROM test_dates t2 WHERE t1.description = t2.description) * 1000) AS adjusted_dt FROM test_dates t1 JOIN test_dates t2 ON t1.id = t2.id HAVING adjusted_dt IS NOT NULL;
WITH (SELECT addMicroseconds(max(event_time), 2000000) FROM test_dates) AS max_time_query SELECT addMicroseconds(event_time, (SELECT min(event_time) FROM test_dates)) AS new_time FROM test_dates WHERE addMicroseconds(event_time, 3000000) < now();
ALTER TABLE test_dates ADD COLUMN adjusted_time DateTime64(6);
UPDATE test_dates SET adjusted_time = addMicroseconds(event_time, -1000000) WHERE description IS NOT NULL;
SELECT id, addMicroseconds(COALESCE(event_time, toDateTime64('1970-01-01 00:00:00', 6)), 600000) AS coalesced_time FROM test_dates;