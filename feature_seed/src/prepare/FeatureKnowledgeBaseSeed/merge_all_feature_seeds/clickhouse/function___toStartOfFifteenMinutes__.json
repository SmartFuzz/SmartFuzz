CREATE TABLE test_time (event_time DateTime);
INSERT INTO test_time VALUES (toDateTime('2023-04-21 10:17:00')), (toDateTime('2023-04-21 10:20:00')), (toDateTime('2023-04-21 10:23:00'));
SELECT toStartOfFifteenMinutes(event_time) FROM test_time;
SELECT toStartOfFifteenMinutes(toDateTime('2023-04-21 10:01:31')) AS rounded_time;
SELECT toStartOfFifteenMinutes(toDateTime('2023-04-21 10:15:00')) AS rounded_time;
SELECT toStartOfFifteenMinutes(toDateTime('2023-04-21 10:30:00')) AS rounded_time;
SELECT toStartOfFifteenMinutes(toDateTime('2023-04-21 10:45:59')) AS rounded_time;
SELECT event_time, toStartOfFifteenMinutes(event_time) AS rounded_time FROM test_time WHERE event_time >= toDateTime('2023-04-21 10:00:00');
SELECT toStartOfFifteenMinutes(max(event_time)) FROM test_time;
SELECT toStartOfFifteenMinutes(min(event_time)) FROM test_time;
SELECT (SELECT toStartOfFifteenMinutes(event_time) FROM test_time WHERE event_time < toDateTime('2023-04-21 10:20:00')) AS rounded_before_twenty;
WITH event AS (SELECT toStartOfFifteenMinutes(event_time) AS rounded_time FROM test_time) SELECT COUNT(*) FROM event;
SELECT tt.event_time, tt.rounded_time FROM (SELECT event_time, toStartOfFifteenMinutes(event_time) AS rounded_time FROM test_time) AS tt WHERE rounded_time = toDateTime('2023-04-21 10:15:00');
SELECT multi.rounded_time FROM (SELECT toStartOfFifteenMinutes(event_time) AS rounded_time FROM test_time) AS multi JOIN (SELECT toDateTime('2023-04-21 10:15:00') AS comparison_time) AS cmp ON multi.rounded_time = cmp.comparison_time;