CREATE TABLE vectors_table (id UInt32, vec Array(Float64));
INSERT INTO vectors_table VALUES (1, [1, 2]);
INSERT INTO vectors_table VALUES (2, [3, 4]);
INSERT INTO vectors_table VALUES (3, [5, 0, 0]);
INSERT INTO vectors_table VALUES (4, [-1, -2]);
INSERT INTO vectors_table VALUES (5, [0, 0]);
SELECT id, L2SquaredNorm(vec) AS norm_squared FROM vectors_table;
SELECT id, L2SquaredNorm(vec) AS norm_squared FROM (SELECT vec FROM vectors_table WHERE id = 1);
SELECT vec, L2SquaredNorm(vec) * 2 as double_norm FROM vectors_table WHERE id IN (1, 2);
CREATE TABLE additional_vectors (id UInt32, vec Array(Float64));
INSERT INTO additional_vectors VALUES (1, [7, 8]);
SELECT a.id AS a_id, b.id AS b_id, L2SquaredNorm(a.vec) + L2SquaredNorm(b.vec) AS combined_norm FROM vectors_table a JOIN additional_vectors b ON a.id = 1;
SELECT vec, L2SquaredNorm(vec) FROM vectors_table AS v WHERE v.id NOT IN (SELECT id FROM additional_vectors);
SELECT id, L2SquaredNorm([1.5, NULL]) AS norm_squared_handle_null_values FROM vectors_table;
SELECT id, L2SquaredNorm(vec) AS norm_squared FROM vectors_table WHERE arrayExists(x -> x < 0, vec);
SELECT id, vec, normL2Squared(vec) AS norm_squared FROM vectors_table WHERE id = (SELECT min(id) FROM vectors_table);