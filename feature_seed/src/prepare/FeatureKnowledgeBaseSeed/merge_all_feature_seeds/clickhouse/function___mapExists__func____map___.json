CREATE TABLE test_map (id UInt32, map_col Map(String, Int32));
INSERT INTO test_map VALUES (1, map('k1', 1, 'k2', 2)), (2, map('k1', 0, 'k2', 0));
SELECT mapExists((k, v) -> (v > 0), map_col) AS res FROM test_map;
SELECT id, mapExists((k, v) -> (v = 1), map_col) AS map_has_k1 FROM test_map WHERE id = 1;
SELECT COUNT(*) FROM test_map WHERE mapExists((k, v) -> (k = 'k2' AND v > 1), map_col);
SELECT id FROM test_map WHERE mapExists((k, v) -> (k = 'k1' AND v = 0), map_col) AND id IN (SELECT id FROM test_map WHERE id = 2);
CREATE TABLE nested_test_map AS SELECT map('k1', rand() % 5, 'k2', rand() % 5) AS generated_map FROM numbers(10);
SELECT mapExists((k, v) -> (v > 3), generated_map) FROM nested_test_map;
SELECT id, mapExists((k, v) -> (v < 2), map_col) AS low_value_check FROM test_map GROUP BY id;
SELECT id FROM test_map WHERE mapExists((k, v) -> (k LIKE 'k%' AND v != 0), map_col) ORDER BY id DESC LIMIT 1;