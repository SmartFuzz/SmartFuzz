CREATE TABLE base58_test (encoded String);
INSERT INTO base58_test VALUES ('3dc8KtHrwM'), ('invalid'), (''), ('123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz');
SELECT tryBase58Decode(encoded) AS decoded FROM base58_test;
SELECT tryBase58Decode(encoded) AS decoded, CASE WHEN tryBase58Decode(encoded) = '' THEN 'Invalid' ELSE 'Valid' END AS status FROM base58_test;
WITH (SELECT tryBase58Decode('3dc8KtHrwM') AS decoded_value) AS subquery SELECT decoded_value FROM subquery;
SELECT t1.encoded, tryBase58Decode(t2.encoded) AS decoded FROM base58_test AS t1 JOIN base58_test AS t2 ON t1.encoded = t2.encoded WHERE t1.encoded != 'invalid';
SELECT arrayJoin([tryBase58Decode('3dc8KtHrwM'), tryBase58Decode('invalid'), tryBase58Decode(''), tryBase58Decode('123456789ABCDEFGHJKLMNPQRSTUVWXYZabcdefghijkmnopqrstuvwxyz')]) AS decoded_values;
CREATE TABLE invalid_test (encoded String) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO invalid_test VALUES ('invalid'), ('notBase58_$$$'), ('base58!@#$'), ('1234abcd*'), ('');
SELECT encoded, tryBase58Decode(encoded) AS result FROM invalid_test WHERE NOT tryBase58Decode(encoded) = '';