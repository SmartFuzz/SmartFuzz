CREATE TABLE test_table (id UInt32, description String, created_at DateTime, value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'Initial value', now(), 10.5), (2, 'Another value', now(), 20), (3, NULL, now(), 30.4);
SELECT tcpPort(), description FROM test_table WHERE description LIKE 'Initial%' AND value >= 10.0;
SELECT tcpPort() AS port, AVG(value) FROM test_table GROUP BY description HAVING AVG(value) > 15.0;
SELECT COUNT(*) FROM (SELECT id, CASE WHEN description LIKE '%value%' THEN created_at ELSE NULL END AS created_at_case FROM test_table) WHERE created_at_case IS NOT NULL;
WITH (SELECT AVG(value) FROM test_table) AS avg_value SELECT tcpPort() AS port FROM test_table WHERE value > avg_value OR description IS NULL;
CREATE TABLE second_table (id UInt32, connect_time DateTime, is_active UInt8) ENGINE = MergeTree() ORDER BY id;
INSERT INTO second_table VALUES (1, now(), 1), (2, now() - INTERVAL 1 DAY, 0);
SELECT t1.id, t1.description, t2.connect_time FROM test_table AS t1 JOIN second_table AS t2 ON t1.id LIKE toString(t2.id);
SELECT tcpPort() FROM (SELECT id, description, value FROM test_table WHERE id IN (SELECT id FROM second_table WHERE is_active = 1)) AS active_values GROUP BY description;
SELECT tcpPort() AS port, COUNT(*) FROM test_table WHERE value IS NOT NULL AND value < 10.0 GROUP BY description HAVING COUNT(*) >= 1;