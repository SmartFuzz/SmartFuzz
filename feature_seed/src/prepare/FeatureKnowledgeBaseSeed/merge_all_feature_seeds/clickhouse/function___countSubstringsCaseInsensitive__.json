CREATE TABLE test_strings (haystack String, needle String, start_pos UInt64);
INSERT INTO test_strings VALUES ('AAAA', 'aa', 1), ('abc___ABC___abc', 'abc', 1), ('Hello World', 'hello', 1), ('Test Case Test Case', 'TeSt', 1), ('Just a string, with mixed CASE sensitivity!', 'case', 1);
SELECT countSubstringsCaseInsensitive(haystack, needle) FROM test_strings;
SELECT countSubstringsCaseInsensitive(haystack, needle) FROM test_strings WHERE start_pos = 1;
SELECT countSubstringsCaseInsensitive(haystack, needle, start_pos) FROM test_strings WHERE haystack LIKE '%Case%';
SELECT haystack, countSubstringsCaseInsensitive(haystack, needle, 1) AS count FROM test_strings WHERE count > 0;
WITH (SELECT haystack FROM test_strings WHERE needle = 'abc') AS filtered_haystack SELECT countSubstringsCaseInsensitive(filtered_haystack, 'abc') AS occurrence_count;
SELECT haystack, countSubstringsCaseInsensitive(haystack, needle, 2) AS count FROM test_strings WHERE count > 0 ORDER BY count DESC;
SELECT countSubstringsCaseInsensitive(haystack, 'hello') AS hello_count FROM test_strings WHERE haystack LIKE '%Hello%';
SELECT countSubstringsCaseInsensitive(haystack, needle) FROM (SELECT haystack FROM test_strings WHERE start_pos <= 2) AS subquery;
CREATE TABLE results AS SELECT haystack, countSubstringsCaseInsensitive(haystack, needle) AS substring_count FROM test_strings;
SELECT t1.haystack, t2.needle, countSubstringsCaseInsensitive(t1.haystack, t2.needle) AS count FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.haystack != t2.haystack;
SELECT countSubstringsCaseInsensitive('Case Sensitivity Test', 'case') UNION SELECT countSubstringsCaseInsensitive('No match here', 'yes');
SELECT countSubstringsCaseInsensitive(haystack, 'notfound') AS count FROM (SELECT haystack FROM test_strings) GROUP BY haystack HAVING count > 0;