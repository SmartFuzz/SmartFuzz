CREATE TABLE test_uuids (id UUID, name String);
INSERT INTO test_uuids VALUES (generateUUIDv4(), 'Alice'), (generateUUIDv4(), 'Bob'), (generateUUIDv4(), 'Charlie');
SELECT id, name, dictGetUUID('test_uuids', 'id', toUInt64(1)) AS retrieved_uuid FROM test_uuids WHERE name = 'Alice';
SELECT id, name FROM test_uuids WHERE id = dictGetUUID('test_uuids', 'id', toUInt64(2));
CREATE TABLE test_uuids_2 AS SELECT id, name FROM test_uuids WHERE id IS NOT NULL;
SELECT t1.id, t2.name FROM test_uuids AS t1 JOIN test_uuids_2 AS t2 ON t1.id = t2.id WHERE t1.name != t2.name;
SELECT dictGetUUID('test_uuids', 'id', toUInt64(idx)) AS uuid_value FROM (SELECT number AS idx FROM numbers(10));
SELECT id FROM test_uuids WHERE id IN (SELECT dictGetUUID('test_uuids', 'id', toUInt64(number)) FROM numbers(5));
CREATE TABLE new_table AS SELECT id, dictGetUUID('test_uuids', 'id', toUInt64(number)) AS uuid_value FROM numbers(5);
SELECT id, name FROM test_uuids WHERE id IN (SELECT generateUUIDv4() FROM numbers(5)) AND name LIKE 'A%';