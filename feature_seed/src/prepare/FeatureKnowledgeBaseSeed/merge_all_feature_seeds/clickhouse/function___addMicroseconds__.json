CREATE TABLE test_dates (event_time DateTime64(3));
INSERT INTO test_dates VALUES (toDateTime64('2024-01-01 00:00:00', 3));
SELECT addMicroseconds(event_time, 1000000) AS updated_time FROM test_dates WHERE event_time = toDateTime64('2024-01-01 00:00:00', 3);
WITH toDateTime64('2024-01-01 23:59:59', 3) AS max_time SELECT addMicroseconds(max_time, 5000000) AS future_time;
SELECT addMicroseconds(date_time, -2500000) AS past_time FROM (SELECT toDateTime('2024-01-01 00:00:00') AS date_time);
SELECT addMicroseconds(toDateTime64('2024-01-01 12:00:00', 2), num) FROM (SELECT num FROM (SELECT 1000000 AS num UNION ALL SELECT 2000000 AS num) AS nums);
CREATE TABLE events (event_time DateTime64(6), event_name String);
INSERT INTO events VALUES (toDateTime64('2024-01-01 12:01:01', 6), 'Event A'), (toDateTime64('2024-01-01 12:02:02', 6), 'Event B');
SELECT event_name, addMicroseconds(event_time, 30000000) AS new_event_time FROM events WHERE event_time < toDateTime64('2024-01-01 12:03:00', 6);
WITH (SELECT addMicroseconds(toDateTime('2024-01-01 00:00:00'), 60000000)) AS add_time SELECT * FROM (SELECT add_time AS result_time) AS time_results;
SELECT addMicroseconds(date_time_string, 1000000) AS updated_string_time FROM (SELECT '2024-01-01 00:00:00' AS date_time_string);
WITH (SELECT toDateTime64('2024-01-01 00:00:00', 3)) AS start_time SELECT addMicroseconds(start_time, 1000000000) AS long_future_time;
CREATE TABLE dates_test (datetime_col DateTime64(3));
INSERT INTO dates_test VALUES (toDateTime64('2024-01-01 05:00:00', 3));
SELECT addMicroseconds(datetime_col, 1000000000) AS adjusted_time FROM dates_test;
SELECT COUNT(*) FROM (SELECT addMicroseconds(datetime_col, num) FROM (SELECT datetime_col FROM dates_test) AS subquery, (SELECT -5000000 AS num UNION ALL SELECT 15000000 AS num) AS nums);