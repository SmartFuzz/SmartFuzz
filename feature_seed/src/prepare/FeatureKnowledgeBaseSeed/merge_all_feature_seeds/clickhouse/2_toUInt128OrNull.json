CREATE TABLE test_table (id UInt8, value String);
INSERT INTO test_table VALUES (1, '128'), (2, 'abc'), (3, '340282366920938463463374607431768211456'), (4, '0'), (5, '');
CREATE TABLE other_table (id UInt8, num String);
INSERT INTO other_table VALUES (1, '256'), (2, 'inf'), (3, 'NaN'), (4, '340282366920938463463374607431768211456'), (5, '0x10');
SELECT id, toUInt128OrNull(value) AND toUInt128OrNull(num) FROM test_table JOIN other_table ON test_table.id = other_table.id;
SELECT id, toUInt128OrNull((CASE WHEN value = '' THEN '0' ELSE value END)) AND toUInt128OrNull('340282366920938463463374607431768211456') FROM test_table;
SELECT id, toUInt128OrNull(value) AND (SELECT toUInt128OrNull(num) FROM other_table WHERE id = test_table.id) AS conjunction_result FROM test_table;
SELECT id, toUInt128OrNull(value) AND NULL AS is_valid FROM test_table HAVING is_valid IS NOT NULL;
SELECT toUInt128OrNull(value) FROM (SELECT value FROM test_table WHERE value NOT LIKE '%a%') WHERE id = 1;
SELECT toUInt128OrNull(NULL) AND toUInt128OrNull('256') AS result FROM test_table;
SELECT COUNT(*) FROM (SELECT id, toUInt128OrNull('abc') AS conv_value FROM test_table GROUP BY id HAVING conv_value IS NULL);
SELECT SUM(toUInt128OrNull(value) AND toUInt128OrNull(num)) FROM test_table CROSS JOIN other_table;
CREATE TABLE temp_table AS SELECT * FROM test_table WHERE 1 = 0;
INSERT INTO temp_table SELECT * FROM test_table WHERE value = '';
SELECT COUNT(*) FROM temp_table WHERE toUInt128OrNull(value) IS NULL;