CREATE TABLE test_numbers (num INT);
INSERT INTO test_numbers VALUES (0), (1), (2), (3), (255), (256), (1023), (2047), (4095), (-1), (-2), (-3), (-128), (-255);
SELECT bitCount(num) FROM test_numbers;
SELECT bitCount(0) AS bits_in_zero, bitCount(1) AS bits_in_one, bitCount(255) AS bits_in_255;
SELECT bitCount(toUInt8(-1)) AS negative_one_bits, bitCount(toUInt8(-255)) AS negative_255_bits;
SELECT num, bitCount(num) FROM test_numbers WHERE num > 0;
SELECT SUM(bitCount(num)) FROM test_numbers;
SELECT AVG(bitCount(num)) FROM (SELECT bitCount(num) FROM test_numbers) AS subquery;
SELECT bitCount(3 + 5) AS bits_in_sum FROM (SELECT 3 AS num1, 5 AS num2);
CREATE TABLE test_floats (float_num FLOAT);
INSERT INTO test_floats VALUES (1.5), (-1.5), (0.7), (10.0), (15.1);
SELECT float_num, bitCount(toUInt64(float_num)) FROM test_floats;
SELECT BIT_COUNT, COUNT(*) FROM (SELECT bitCount(num) AS BIT_COUNT FROM test_numbers GROUP BY BIT_COUNT) AS grouped;
SELECT (SELECT bitCount(num) FROM test_numbers WHERE num = 7) AS bits_in_seven, (SELECT bitCount(num) FROM test_numbers WHERE num = 15) AS bits_in_fifteen;
SELECT n.num, bitCount(n.num) FROM (SELECT num FROM test_numbers WHERE num < 100) AS n;
CREATE TABLE test_join (id INT, value INT);
INSERT INTO test_join VALUES (1, 1), (2, 3), (3, 7);
SELECT j.id, bitCount(j.value) FROM test_join j JOIN test_numbers n ON j.id = n.num WHERE n.num < 4;