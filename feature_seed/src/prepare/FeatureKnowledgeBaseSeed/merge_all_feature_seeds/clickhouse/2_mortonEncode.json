CREATE TABLE morton_test (id UInt32, val1 UInt32, val2 UInt16, val3 UInt8) ENGINE = MergeTree() ORDER BY id;
INSERT INTO morton_test VALUES (1, 10, 5, 1), (2, 20, 10, 2), (3, 30, 15, 3);
SELECT mortonEncode(val1 / 2, val2 * 3, NULL) FROM morton_test;
SELECT mortonEncode(val1, val2, (val1 + val2) / (val3 + 1)) FROM morton_test;
SELECT id, mortonEncode(val1, val2, (SELECT AVG(val1) FROM morton_test)) AS enc1 FROM morton_test GROUP BY id;
SELECT id, enc1, enc2 FROM (SELECT id, mortonEncode(val1, NULL) AS enc1 FROM morton_test) AS tbl JOIN (SELECT id, mortonEncode(val2, val3) AS enc2 FROM morton_test) AS tbl2 ON tbl.id = tbl2.id;
CREATE TABLE nullable_morton_test (id UInt32, val1 Nullable(UInt32), val2 Nullable(UInt16), val3 Nullable(UInt8)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO nullable_morton_test VALUES (1, NULL, 5, 1), (2, 20, NULL, 2), (3, 30, 15, NULL);
SELECT id, mortonEncode(IF(val1 IS NULL, 0, val1), val2) FROM nullable_morton_test;
SELECT id, mortonEncode(val1, val2) / (val3 + 1) AS divided_encode FROM nullable_morton_test WHERE val1 IS NOT NULL;
WITH (SELECT MAX(val1) FROM morton_test) AS max_val SELECT mortonEncode(max_val, 5) AS encoded_value WHERE max_val > 0;
SELECT id, (SELECT COUNT() FROM morton_test) / (val1 + 1) FROM morton_test;
SELECT val1, mortonEncode(val1, val1 + 1, (SELECT COUNT(*) FROM morton_test) / NULLIF(val1, 0)) FROM morton_test;
SELECT id, mortonEncode((val1 + 5) / 2, (val2 + 1) * 3) AS complex_enc FROM morton_test HAVING complex_enc IS NOT NULL;