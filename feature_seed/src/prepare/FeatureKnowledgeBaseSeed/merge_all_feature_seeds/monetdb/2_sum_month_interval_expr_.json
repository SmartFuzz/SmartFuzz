CREATE TABLE test_data (id SERIAL PRIMARY KEY, month_interval_value INTERVAL MONTH, ip_address INET);
INSERT INTO test_data (month_interval_value, ip_address) VALUES (CAST('3 months' AS INTERVAL MONTH), INET '192.168.1.1');
INSERT INTO test_data (month_interval_value, ip_address) VALUES (CAST(NULL AS INTERVAL MONTH), INET '192.168.1.2');
INSERT INTO test_data (month_interval_value, ip_address) VALUES (CAST('1 month' AS INTERVAL MONTH), INET '192.168.1.3');
INSERT INTO test_data (month_interval_value, ip_address) VALUES (CAST('0 months' AS INTERVAL MONTH), INET '192.168.2.1');
INSERT INTO test_data (month_interval_value, ip_address) VALUES (CAST('-1 month' AS INTERVAL MONTH), INET '192.168.2.2');
SELECT SUM(month_interval_value) FROM test_data WHERE ip_address >>= INET '192.168.1.0/24' GROUP BY ip_address HAVING SUM(month_interval_value) IS NOT NULL;
SELECT SUM(month_interval_value) FROM test_data WHERE month_interval_value IS NOT NULL AND ip_address >>= INET '192.168.1.1' ORDER BY SUM(month_interval_value) DESC;
SELECT ip_address, SUM(month_interval_value) AS total_months FROM test_data GROUP BY ip_address HAVING total_months > (SELECT SUM(month_interval_value) FROM test_data WHERE ip_address IS NOT NULL);
SELECT COUNT(*), SUM(CASE WHEN month_interval_value IS NULL THEN 0 ELSE month_interval_value END) FROM (SELECT month_interval_value FROM test_data WHERE ip_address >>= INET '192.168.1.0/24' UNION ALL SELECT month_interval_value FROM test_data WHERE ip_address IS NULL) AS subquery;
SELECT month_interval_value, (SELECT COUNT(*) FROM test_data WHERE month_interval_value >= CAST('2 months' AS INTERVAL MONTH)) AS ip_count FROM test_data WHERE ip_address IS NOT NULL ORDER BY month_interval_value;