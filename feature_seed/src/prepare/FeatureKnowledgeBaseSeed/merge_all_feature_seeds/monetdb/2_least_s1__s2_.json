CREATE TABLE test_table (id INT PRIMARY KEY, str_col1 VARCHAR(10), str_col2 VARCHAR(10), num_col INT, nullable_col VARCHAR(10));
INSERT INTO test_table (id, str_col1, str_col2, num_col, nullable_col) VALUES (1, 'apple', 'banana', 10, NULL);
INSERT INTO test_table (id, str_col1, str_col2, num_col, nullable_col) VALUES (2, 'avocado', 'apricot', 20, 'fruit');
INSERT INTO test_table (id, str_col1, str_col2, num_col, nullable_col) VALUES (3, 'grape', 'kiwi', 30, 'vegetable');
INSERT INTO test_table (id, str_col1, str_col2, num_col, nullable_col) VALUES (4, NULL, 'lemon', 5, NULL);
INSERT INTO test_table (id, str_col1, str_col2, num_col, nullable_col) VALUES (5, 'lime', NULL, NULL, 'citrus');
SELECT id, least(str_col1, str_col2) AS least_string FROM test_table WHERE num_col > 15;
SELECT id, (SELECT COUNT(*) FROM test_table AS t2 WHERE t2.num_col > t1.num_col) AS greater_count FROM test_table AS t1;
SELECT id, least(str_col1, str_col2) AS least_string FROM test_table GROUP BY least_string HAVING least_string > 'apple';
SELECT id, least(str_col1, str_col2) AS least_string FROM test_table WHERE least(str_col1, str_col2) > 'p';
SELECT id, num_col FROM test_table WHERE nullable_col IS NULL AND num_col > (SELECT AVG(num_col) FROM test_table);
SELECT id, least((SELECT str_col1 FROM test_table WHERE id = 1), 'z') AS least_string_combined FROM test_table;
SELECT id, least(NULLIF(str_col1, ''), str_col2) AS least_string_filtered FROM test_table WHERE id < 4;
SELECT id, least(least(str_col1, str_col2), 'mango') AS least_with_literal FROM test_table ORDER BY least_with_literal;
SELECT DISTINCT id, least(num_col::VARCHAR, '50') AS least_numeric_string FROM test_table WHERE num_col IS NOT NULL;
SELECT id FROM test_table WHERE (str_col1 IS NOT NULL AND str_col2 IS NOT NULL) AND least(str_col1, str_col2) > 'a' ORDER BY id;
SELECT t1.id FROM test_table t1 JOIN test_table t2 ON least(t1.str_col1, t2.str_col2) < 'apple' WHERE t1.num_col + t2.num_col > 15;
DROP TABLE IF EXISTS test_table;