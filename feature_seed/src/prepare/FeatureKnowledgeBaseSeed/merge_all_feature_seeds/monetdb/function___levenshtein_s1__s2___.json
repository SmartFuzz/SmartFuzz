CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255));
INSERT INTO test_strings VALUES (1, 'MonetDB', 'DB3');
INSERT INTO test_strings VALUES (2, 'test', 'text');
INSERT INTO test_strings VALUES (3, 'kitten', 'sitting');
INSERT INTO test_strings VALUES (4, 'flaw', 'lawn');
INSERT INTO test_strings VALUES (5, '', '');
INSERT INTO test_strings VALUES (6, 'abc', '');
INSERT INTO test_strings VALUES (7, '', 'xyz');
SELECT id, levenshtein(str1, str2) AS distance FROM test_strings;
SELECT id, str1, str2, levenshtein(str1, str2) AS distance FROM test_strings WHERE distance < 5;
SELECT t1.id, levenshtein(t1.str1, t2.str2) AS distance FROM test_strings t1 JOIN test_strings t2 ON t1.id < t2.id;
SELECT id, str1, str2, levenshtein(str1, str2) AS distance FROM (SELECT * FROM test_strings WHERE id < 5) AS subquery;
CREATE TABLE comparison_results AS SELECT id, str1, str2, levenshtein(str1, str2) AS distance FROM test_strings;
SELECT AVG(distance) FROM comparison_results;
SELECT id, MAX(distance) FROM (SELECT id, levenshtein(str1, str2) AS distance FROM test_strings) AS subquery GROUP BY id;