CREATE TABLE numbers (a FLOAT, b FLOAT);
INSERT INTO numbers VALUES (1.2, 3.3);
INSERT INTO numbers VALUES (5.0, 2.8);
INSERT INTO numbers VALUES (-1.5, -3.6);
INSERT INTO numbers VALUES (NULL, 5.0);
INSERT INTO numbers VALUES (4.5, NULL);
SELECT sql_min(a, b) FROM numbers;
SELECT sql_min(a, sql_min(b, 1.0)) FROM numbers;
SELECT sql_min(sql_min(a, 0.0), sql_min(b, 1.0)) FROM numbers;
SELECT sql_min((SELECT MIN(a) FROM numbers), (SELECT MAX(b) FROM numbers)) AS min_value;
SELECT a, b, sql_min(a, b) AS least_value FROM numbers WHERE a > 0;
CREATE TABLE more_numbers (c FLOAT);
INSERT INTO more_numbers VALUES (2.2);
SELECT sql_min(n.a, m.c) FROM numbers n JOIN more_numbers m ON n.a < m.c WHERE n.a IS NOT NULL;
SELECT sql_min(sql_min(a, b), (SELECT MIN(c) FROM more_numbers)) FROM numbers;
SELECT sql_min(sql_min(a, b), 0) AS final_min FROM numbers WHERE a IS NOT NULL AND b IS NOT NULL;
SELECT sql_min(sql_min(10.5, 5.5), sql_min(15.0, 3.0));