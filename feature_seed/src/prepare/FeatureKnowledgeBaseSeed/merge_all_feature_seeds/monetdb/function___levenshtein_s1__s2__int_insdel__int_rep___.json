CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255), insdel INT, rep INT);
INSERT INTO test_strings VALUES (1, 'kitten', 'sitting', 1, 1);
INSERT INTO test_strings VALUES (2, 'flaw', 'lawn', 2, 1);
INSERT INTO test_strings VALUES (3, 'intention', 'execution', 2, 2);
INSERT INTO test_strings VALUES (4, 'MonetDB', 'DB3', 4, 2);
SELECT id, levenshtein(str1, str2, insdel, rep) AS distance FROM test_strings;
SELECT id, str1, str2, insdel, rep, levenshtein(str1, str2, insdel, rep) AS distance FROM test_strings WHERE insdel <= 2;
SELECT id, levenshtein(str1, str2, 5, 3) AS distance FROM test_strings WHERE str1 LIKE 'k%';
CREATE TABLE result AS SELECT id, str1, str2, indsdel, rep, levenshtein(str1, str2, insdel, rep) AS distance FROM test_strings;
SELECT AVG(distance) FROM (SELECT levenshtein(str1, str2, insdel, rep) AS distance FROM test_strings) AS sub;
SELECT t1.id, t1.str1, t1.str2, t2.insdel, t2.rep, levenshtein(t1.str1, t1.str2, t2.insdel, t2.rep) AS distance FROM test_strings t1 JOIN test_strings t2 ON t1.id != t2.id;