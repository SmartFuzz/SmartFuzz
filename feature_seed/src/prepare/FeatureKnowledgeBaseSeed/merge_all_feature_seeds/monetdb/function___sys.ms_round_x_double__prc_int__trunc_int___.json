CREATE TABLE test_round (value DOUBLE, prc INT, trunc INT);
INSERT INTO test_round VALUES (1.2359, 2, 0);
INSERT INTO test_round VALUES (1.2359, 3, 1);
INSERT INTO test_round VALUES (1.2359, 0, 0);
INSERT INTO test_round VALUES (1.2399, 2, 1);
INSERT INTO test_round VALUES (1.2345, 2, 2);
INSERT INTO test_round VALUES (1.2355, 2, 1);
INSERT INTO test_round VALUES (12345.6789, 3, 2);
INSERT INTO test_round VALUES (-1.2359, 2, 0);
SELECT sys.ms_round(value, prc, trunc) FROM test_round;
SELECT sys.ms_round(ROUND(value, 2), 1, 0) FROM test_round;
SELECT sys.ms_round(1234567.8911, 4, 2) AS rounded_value FROM (SELECT value, prc, trunc FROM test_round WHERE value > 0);
SELECT DISTINCT sys.ms_round(value, prc, trunc) FROM test_round WHERE value IS NOT NULL;
CREATE TABLE additional_test (a DOUBLE, b DOUBLE);
INSERT INTO additional_test VALUES (1.2399, 2.3489);
SELECT sys.ms_round(a + b, 2, 0) FROM additional_test;
SELECT sys.ms_round(MAX(value), 2, 1) FROM test_round;
INSERT INTO test_round VALUES (0.12345, 3, 2);
SELECT sys.ms_round(AVG(value), 2, 1) FROM test_round;
CREATE INDEX idx_prc ON test_round (prc);
SELECT sys.ms_round(MAX(value), prc, trunc) FROM test_round GROUP BY prc;
DELETE FROM test_round WHERE value < 0;