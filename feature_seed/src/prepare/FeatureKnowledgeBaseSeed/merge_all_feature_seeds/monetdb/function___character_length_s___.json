CREATE TABLE test_strings (id INT PRIMARY KEY, str VARCHAR(255));
INSERT INTO test_strings VALUES (1, R'2€'), (2, R' 😀 '), (3, R'hello'), (4, R'こんにちは'), (5, R'Hello, 世界!');
SELECT character_length(str) FROM test_strings WHERE id = 1;
SELECT character_length(str) FROM test_strings WHERE id = 2;
SELECT character_length(str) FROM test_strings WHERE id = 3;
SELECT character_length(str) FROM test_strings WHERE id = 4;
SELECT character_length(str) FROM test_strings WHERE id = 5;
SELECT id, character_length(str) AS length FROM test_strings ORDER BY length DESC;
SELECT AVG(character_length(str)) FROM test_strings;
SELECT t.id, t.str, r.length FROM test_strings t JOIN (SELECT id, character_length(str) AS length FROM test_strings) r ON t.id = r.id WHERE r.length > 5;
SELECT t1.str FROM test_strings t1 WHERE character_length(t1.str) IN (SELECT character_length(t2.str) FROM test_strings t2 WHERE t2.id < 3);
CREATE TABLE another_table (ref_id INT, data VARCHAR(100));
INSERT INTO another_table VALUES (1, R'Extra Data 1'), (2, R'Extra Data 2'), (3, R'Extra Data 3');
SELECT t.id, character_length(t.str) AS length, a.data FROM test_strings t LEFT JOIN another_table a ON t.id = a.ref_id WHERE character_length(t.str) > 3;
SELECT character_length(str) * 2 AS double_length FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE character_length(str) < 5);
SELECT character_length(R'') AS empty_length;
SELECT character_length(NULL) AS null_length;
SET @test_str := R' corazón ';
SELECT character_length(@test_str) AS variable_length;