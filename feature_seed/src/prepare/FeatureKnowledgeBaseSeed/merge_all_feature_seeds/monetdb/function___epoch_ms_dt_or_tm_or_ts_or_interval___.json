CREATE TABLE test_timestamps (id INT PRIMARY KEY, event_timestamp TIMESTAMP);
INSERT INTO test_timestamps VALUES (1, timestamp '1970-01-01 00:00:00.0');
INSERT INTO test_timestamps VALUES (2, timestamp '1970-01-01 00:00:01.0');
INSERT INTO test_timestamps VALUES (3, timestamp '2000-01-01 00:00:00.0');
INSERT INTO test_timestamps VALUES (4, timestamp '2099-12-31 23:59:59.0');
INSERT INTO test_timestamps VALUES (5, timestamp '2023-01-01 12:00:00.0');
SELECT id, epoch_ms(event_timestamp) FROM test_timestamps;
SELECT id, epoch_ms(event_timestamp) AS ms FROM test_timestamps WHERE event_timestamp < timestamp '2001-01-01 00:00:00.0';
SELECT t1.id, epoch_ms(t1.event_timestamp) FROM test_timestamps t1 JOIN (SELECT * FROM test_timestamps WHERE id % 2 = 0) t2 ON t1.id = t2.id;
SELECT id, epoch_ms(CAST(event_timestamp AS VARCHAR)) AS ms FROM test_timestamps;
CREATE TABLE test_intervals (id INT PRIMARY KEY, duration INTERVAL);
INSERT INTO test_intervals VALUES (1, INTERVAL '1 day');
INSERT INTO test_intervals VALUES (2, INTERVAL '0.5 hours');
SELECT id, epoch_ms(duration) FROM test_intervals;
SELECT event.id, epoch_ms(event.event_timestamp), interval.id, epoch_ms(interval.duration) FROM test_timestamps event JOIN test_intervals interval ON event.id = interval.id;
WITH milliseconds AS (SELECT id, epoch_ms(event_timestamp) AS ms FROM test_timestamps WHERE event_timestamp IS NOT NULL) SELECT COUNT(*) FROM milliseconds WHERE ms > 0;
SELECT id, epoch_ms(NULL) FROM test_timestamps;