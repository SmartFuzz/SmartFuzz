CREATE TABLE test_table (id INT PRIMARY KEY, text_col VARCHAR(255), num_col INT, nullable_col VARCHAR(255));
INSERT INTO test_table (id, text_col, num_col, nullable_col) VALUES (1, 'ask', 3, NULL), (2, 'repeat', 2, 'test'), (3, 'query', NULL, 'example');
SELECT repeat(text_col, num_col) AS repeated_text, num_col * 2 AS multiplied_num FROM test_table WHERE num_col IS NOT NULL;
SELECT id, repeat(text_col, (num_col * 2)) AS repeated_text FROM test_table WHERE num_col > 1;
SELECT id, repeat(text_col, 2) FROM test_table WHERE nullable_col IS NULL OR text_col = '' ORDER BY id;
SELECT id, repeat((SELECT text_col FROM test_table WHERE id = 3), num_col) AS nested_repeat FROM test_table WHERE num_col IS NOT NULL;
SELECT id, COUNT(*) AS count, repeat(CONCAT(text_col, '|'), COUNT(*)) AS repeated_group FROM test_table GROUP BY text_col HAVING COUNT(*) > 1;
SELECT text_col, repeat(text_col, 0) AS zero_repeat FROM test_table WHERE text_col IS NOT NULL;
SELECT id, repeat(text_col, num_col), id * 10 AS boundary_multiply, repeat('max', 2147483647) FROM test_table WHERE id < 3;
SELECT repeat(text_col, num_col) AS repeated_text FROM (SELECT text_col, num_col FROM test_table WHERE nullable_col IS NOT NULL) AS subquery;
SELECT id, repeat(NULLIF(text_col, ''), num_col) AS repeated_if_not_empty FROM test_table WHERE nullable_col IS NULL;
CREATE TABLE another_table (foreign_id INT, join_text VARCHAR(255));
INSERT INTO another_table (foreign_id, join_text) VALUES (1, 'A'), (2, 'B'), (3, 'C');
SELECT t.id, repeat(t.text_col, a.foreign_id) AS complex_repeat FROM test_table t JOIN another_table a ON t.id = a.foreign_id WHERE a.join_text = 'B' ORDER BY complex_repeat;
SELECT id, repeat(text_col, (SELECT MAX(num_col) FROM test_table)) AS repeat_max FROM test_table GROUP BY id HAVING repeat_max LIKE 'ask%';