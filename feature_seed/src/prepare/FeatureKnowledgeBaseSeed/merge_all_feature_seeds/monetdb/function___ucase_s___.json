CREATE TABLE users (id INT PRIMARY KEY, name STRING);
INSERT INTO users VALUES (1, 'john doe');
INSERT INTO users VALUES (2, 'jane smith');
SELECT ucase(name) FROM users WHERE id = 1;
CREATE TABLE orders (order_id INT PRIMARY KEY, user_id INT, amount DECIMAL(10, 2));
INSERT INTO orders VALUES (101, 1, 250.00);
INSERT INTO orders VALUES (102, 2, 150.50);
SELECT ucase(u.name), o.amount FROM users u JOIN orders o ON u.id = o.user_id WHERE ucase(u.name) LIKE 'J%';
CREATE TABLE products (product_id INT PRIMARY KEY, product_name STRING);
INSERT INTO products VALUES (1, 'laptop');
INSERT INTO products VALUES (2, 'desktop');
SELECT ucase(p.product_name) FROM products p WHERE product_id IN (SELECT o.user_id FROM orders o WHERE o.amount > 200);
SELECT ucase(u.name) AS upper_case_name, COUNT(o.order_id) AS total_orders FROM users u LEFT JOIN orders o ON u.id = o.user_id GROUP BY u.name;
SELECT ucase(MAX(name)) FROM (SELECT name FROM users WHERE id > 0) AS sub;
SELECT COUNT(*) FROM (SELECT DISTINCT ucaze(name) FROM users WHERE LENGTH(name) > 5) AS subquery;