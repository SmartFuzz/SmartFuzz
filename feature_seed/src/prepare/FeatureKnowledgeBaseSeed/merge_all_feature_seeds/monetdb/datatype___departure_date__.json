CREATE TABLE voyages (id INT PRIMARY KEY, departure_date DATE);
INSERT INTO voyages VALUES (1, '2023-01-01');
INSERT INTO voyages VALUES (2, '2023-01-15');
INSERT INTO voyages VALUES (3, '2023-02-01');
INSERT INTO voyages VALUES (4, '2023-12-31');
SELECT * FROM voyages WHERE departure_date = '2023-01-01';
SELECT COUNT(*) FROM voyages WHERE departure_date > '2023-01-01';
SELECT AVG(DATE_PART('day', departure_date - '2023-01-01'::DATE)) AS avg_days FROM voyages;
SELECT MAX(departure_date) FROM voyages WHERE departure_date < '2023-12-31';
CREATE TABLE ships (ship_id INT PRIMARY KEY, ship_name VARCHAR(50));
INSERT INTO ships VALUES (1, 'Titanic'), (2, 'Queen Mary');
CREATE TABLE voyages_ships (voyage_id INT, ship_id INT, FOREIGN KEY (voyage_id) REFERENCES voyages(id), FOREIGN KEY (ship_id) REFERENCES ships(ship_id));
INSERT INTO voyages_ships VALUES (1, 1), (2, 2);
SELECT s.ship_name, v.departure_date FROM ships s JOIN voyages_ships vs ON s.ship_id = vs.ship_id JOIN voyages v ON vs.voyage_id = v.id WHERE v.departure_date BETWEEN '2023-01-01' AND '2023-12-31';
SELECT s.ship_name, MIN(v.departure_date) AS first_departure FROM ships s JOIN voyages_ships vs ON s.ship_id = vs.ship_id JOIN voyages v ON vs.voyage_id = v.id GROUP BY s.ship_name;
SELECT v.id, v.departure_date FROM voyages v WHERE v.departure_date = (SELECT MAX(departure_date) FROM voyages);
SELECT * FROM voyages WHERE departure_date IN (SELECT departure_date FROM voyages WHERE id > 1);
SELECT v1.id, v1.departure_date FROM voyages v1 WHERE EXISTS (SELECT 1 FROM voyages v2 WHERE v2.departure_date < v1.departure_date);