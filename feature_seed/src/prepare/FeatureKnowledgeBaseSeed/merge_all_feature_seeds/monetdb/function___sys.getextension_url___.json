CREATE TABLE urls (id INT, url CLOB);
INSERT INTO urls VALUES (1, 'http://example.com/image.png');
INSERT INTO urls VALUES (2, 'https://www.test.com/file.pdf');
INSERT INTO urls VALUES (3, 'ftp://downloads.com/archive.tar.gz');
INSERT INTO urls VALUES (4, 'https://example.com/resource');
INSERT INTO urls VALUES (5, NULL);
SELECT sys.getextension(url) FROM urls;
SELECT id, sys.getextension(url) AS extension FROM urls WHERE url IS NOT NULL;
SELECT id, sys.getextension(url) AS extension FROM urls WHERE url LIKE '%.%' ORDER BY id;
SELECT COUNT(*) FROM (SELECT sys.getextension(url) AS ext FROM urls WHERE ext IS NOT NULL) subquery;
CREATE TABLE extensions (ext CLOB);
INSERT INTO extensions SELECT DISTINCT sys.getextension(url) FROM urls WHERE url IS NOT NULL;
SELECT u.id, e.ext FROM urls u LEFT JOIN extensions e ON u.url LIKE '%' || e.ext;