CREATE TABLE test_table (id INT, json_data CLOB);
INSERT INTO test_table VALUES (1, json '[1,2,3,4]');
INSERT INTO test_table VALUES (2, json '[5,6,7,8]');
INSERT INTO test_table VALUES (3, json '[9,10,11,12]');
SELECT json.text(json_data, ', ') FROM test_table WHERE id = 1;
SELECT json.text(json_data, '-') FROM test_table WHERE id IN (2, 3);
CREATE TABLE nested_table (id INT, value INT);
INSERT INTO nested_table VALUES (1, 100), (2, 200), (3, 300);
SELECT json.text((SELECT json_agg(value) FROM nested_table WHERE id < 3), '|') AS aggregated_values;
SELECT json.text(json '["apple", "banana", "cherry"]', ';
') AS fruit_list;
SELECT json.text((SELECT json_agg(json_data) FROM test_table WHERE id <= 2), ' | ') AS combined_json;
SELECT t1.id, json.text(t1.json_data, ': ') AS json_output FROM test_table t1 JOIN nested_table t2 ON t1.id = t2.id WHERE t2.value > 150;