CREATE TABLE interval_test (id INT, start_date TIMESTAMP, end_date TIMESTAMP);
INSERT INTO interval_test VALUES (1, '2023-01-01 00:00:00', '2023-12-31 23:59:59');
INSERT INTO interval_test VALUES (2, '2023-06-01 12:00:00', '2023-06-30 12:00:00');
SELECT id, end_date - start_date AS interval_diff FROM interval_test WHERE end_date > start_date;
CREATE TABLE multi_join_test (id INT, event_date TIMESTAMP, duration INTERVAL DAY TO SECOND);
INSERT INTO multi_join_test VALUES (1, '2023-07-01 08:00:00', INTERVAL '2' DAY);
INSERT INTO multi_join_test VALUES (2, '2023-07-02 10:00:00', INTERVAL '3' HOUR);
SELECT a.id, a.event_date, a.duration, a.event_date + a.duration AS event_end_date FROM multi_join_test a JOIN interval_test b ON a.event_date > b.start_date;
SELECT id, (end_date - start_date) + INTERVAL '5' DAY AS adjusted_interval FROM interval_test WHERE id = 1;
SELECT id, (end_date - start_date) + INTERVAL '1' MONTH AS adjusted_interval FROM interval_test WHERE id = 2;
CREATE TABLE complex_query (id INT, event_name VARCHAR(100), event_time TIMESTAMP);
INSERT INTO complex_query VALUES (1, 'Event A', '2023-08-01 10:00:00');
INSERT INTO complex_query VALUES (2, 'Event B', '2023-08-05 12:00:00');
SELECT cq.id, cq.event_name, cq.event_time, cq.event_time + INTERVAL '1' HOUR AS ended_at FROM complex_query cq WHERE cq.event_time < '2023-08-10 00:00:00';
SELECT id, (INTERVAL '5' DAY + end_date - start_date) AS extended_duration FROM interval_test WHERE id IN (SELECT id FROM multi_join_test WHERE duration > INTERVAL '1' DAY);