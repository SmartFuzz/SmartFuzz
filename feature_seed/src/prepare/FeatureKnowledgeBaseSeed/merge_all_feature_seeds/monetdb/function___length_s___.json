CREATE TABLE test_length (id INT, text_column VARCHAR(255));
INSERT INTO test_length VALUES (1, R'2€');
INSERT INTO test_length VALUES (2, R'Hello World!');
INSERT INTO test_length VALUES (3, R'😀😁😂');
INSERT INTO test_length VALUES (4, R'');
INSERT INTO test_length VALUES (5, R'αβγδε');
INSERT INTO test_length VALUES (6, R'12345');
SELECT length(text_column) FROM test_length WHERE id = 1;
SELECT length(text_column) FROM test_length WHERE id IN (2, 3);
SELECT id, length(text_column) AS str_length FROM test_length WHERE length(text_column) > 0;
SELECT t.id, t.text_column, length(t.text_column) FROM test_length t JOIN (SELECT id FROM test_length WHERE id < 5) AS filtered ON t.id = filtered.id;
SELECT MAX(length(text_column)) FROM test_length;
SELECT AVG(length(text_column)) FROM test_length WHERE text_column IS NOT NULL;
SELECT COUNT(*) FROM test_length WHERE length(text_column) = 0;
SELECT DISTINCT length(text_column) FROM test_length ORDER BY length(text_column) DESC;