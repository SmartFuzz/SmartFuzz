CREATE TABLE time_example (start_time TIMETZ, end_time TIMETZ);
INSERT INTO time_example VALUES (timetz '08:00:00+00:00', timetz '10:00:00+00:00');
INSERT INTO time_example VALUES (timetz '12:30:00+00:00', timetz '13:30:00+00:00');
INSERT INTO time_example VALUES (timetz '15:00:00+00:00', timetz '16:30:00+00:00');
SELECT sql_sub(start_time, end_time) FROM time_example;
SELECT sql_sub(timetz '23:59:59+00:00', timetz '00:00:00+00:00') AS interval_difference;
SELECT sql_sub(timetz '00:00:01-05:00', timetz '00:00:00-05:00') AS first_second_difference;
SELECT sql_sub(timetz '12:00:00+01:00', timetz '11:00:00-01:00') AS time_difference;
WITH time_data AS (SELECT start_time, end_time FROM time_example) SELECT sql_sub(start_time, end_time) FROM time_data;
CREATE TABLE timezone_test (initial_time TIMETZ);
INSERT INTO timezone_test VALUES (timetz '19:00:00+01:00');
SELECT sql_sub(initial_time, timetz '18:00:00-02:00') FROM timezone_test;
SELECT sql_sub(timetz '06:00:00+00:00', timetz '07:00:00+00:00') AS negative_interval;
SELECT sql_sub(timetz '02:00:00+05:30', timetz '01:00:00-07:00') AS cross_timezone_difference;
SELECT sql_sub(timetz '00:00:00+00:00', timetz '23:59:59+00:00') AS one_day_difference;