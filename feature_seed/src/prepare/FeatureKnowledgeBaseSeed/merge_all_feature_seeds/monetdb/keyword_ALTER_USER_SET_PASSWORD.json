CREATE USER testuser WITH PASSWORD 'old_password';
ALTER USER SET PASSWORD 'new_secure_password' USING OLD PASSWORD 'old_password';
ALTER USER SET ENCRYPTED PASSWORD 'encrypted_password' USING OLD PASSWORD 'old_password';
SELECT CURRENT_USER;
ALTER USER SET PASSWORD 'another_password' USING OLD PASSWORD 'new_secure_password';
CREATE TABLE user_sessions (username VARCHAR, session_id VARCHAR, created_at TIMESTAMP);
INSERT INTO user_sessions SELECT CURRENT_USER, 'session123', NOW();
SELECT * FROM user_sessions WHERE username = CURRENT_USER;
ALTER USER SET PASSWORD 'final_password' USING OLD PASSWORD 'another_password';
ALTER USER SET UNENCRYPTED PASSWORD 'plain_password' USING OLD PASSWORD 'final_password';
CREATE TABLE sys.users (username VARCHAR PRIMARY KEY, password VARCHAR, created_at TIMESTAMP);
INSERT INTO sys.users VALUES ('monetdb', 'monetdb_password', NOW());
SELECT username FROM sys.users WHERE password = 'monetdb_password';
ALTER USER SET PASSWORD 'monetdb_new' USING OLD PASSWORD 'monetdb_password';
CREATE TABLE user_logs (log_id INT PRIMARY KEY, username VARCHAR, action VARCHAR, log_time TIMESTAMP);
INSERT INTO user_logs SELECT NEXTVAL('log_seq'), CURRENT_USER, 'change password', NOW();
SELECT * FROM user_logs WHERE username = CURRENT_USER;
ALTER USER SET PASSWORD 'complex@123' USING OLD PASSWORD 'monetdb_new';
ALTER USER SET PASSWORD 'short' USING OLD PASSWORD 'complex@123';
CREATE USER edgecase_user WITH PASSWORD 'edgecase_pass';
ALTER USER SET PASSWORD 'password' USING OLD PASSWORD 'edgecase_pass';