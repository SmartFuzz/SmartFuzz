CREATE TABLE test_table1 (id INT PRIMARY KEY, name VARCHAR(255), value INT);
INSERT INTO test_table1 (id, name, value) VALUES (1, 'Test1', 15), (2, 'Test2', 20), (3, 'Test3', NULL);
CREATE TABLE test_table2 (id INT PRIMARY KEY, description VARCHAR(255), amount FLOAT);
INSERT INTO test_table2 (id, description, amount) VALUES (1, 'Description1', 5.75), (2, 'Description2', 10.0);
SELECT upper(name), (value << 2) AS shifted_value FROM test_table1 WHERE value IS NOT NULL;
SELECT upper(description), amount << 1 AS doubled_amount FROM test_table2 WHERE amount > (SELECT AVG(amount) FROM test_table2);
SELECT upper(t1.name), COUNT(*) AS count FROM test_table1 t1 JOIN test_table2 t2 ON (t1.value << 1) = t2.amount GROUP BY upper(t1.name) HAVING count > 1;
SELECT t1.id, upper(t1.name) AS upper_name, ((t1.value + (t2.amount >> 1)) << 1) AS combined_value FROM test_table1 t1 LEFT JOIN test_table2 t2 ON t1.id = t2.id WHERE t1.value IS NOT NULL;
SELECT upper(t1.name), (NULLIF(t1.value, 0) << (t2.amount :: INT)) AS shift_result FROM test_table1 t1 CROSS JOIN (SELECT amount FROM test_table2 WHERE amount IS NOT NULL) t2;
CREATE TEMP TABLE temp_table AS SELECT id, upper(name) AS upper_name FROM test_table1 WHERE value IS NOT NULL;
SELECT upper_name, (id << 3) AS shift_id FROM temp_table WHERE upper_name LIKE 'T%';