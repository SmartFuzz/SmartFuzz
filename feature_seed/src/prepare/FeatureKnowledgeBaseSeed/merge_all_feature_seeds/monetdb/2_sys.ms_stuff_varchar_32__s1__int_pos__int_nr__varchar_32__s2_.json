CREATE TABLE test_table (id serial PRIMARY KEY, info varchar(32), seq int, address inet);
INSERT INTO test_table (info, seq, address) VALUES ('abcdef', 1, '192.168.1.5'), ('ghijkl', 2, '10.0.0.1');
SELECT sys.ms_stuff((SELECT info FROM test_table WHERE seq = 1), 2, 1, (SELECT info FROM test_table WHERE seq = 2)) AS updated_info FROM test_table;
SELECT info, sys.ms_stuff(info, 1, 2, 'XY') AS mutated_info FROM test_table WHERE address = inet '192.168.1.5';
SELECT inet '192.168.1.5' = inet (SELECT address FROM test_table WHERE seq = 2 LIMIT 1) AS addresses_match;
SELECT info, sys.ms_stuff(info, 1, -1, '') AS edge_case FROM test_table WHERE sys.ms_stuff(info, 2, 0, 'XYZ') = '';
SELECT COUNT(*) FROM (SELECT sys.ms_stuff(info, seq, 1, 'XYZ') AS modified_info FROM test_table WHERE info IS NOT NULL) AS modified_table GROUP BY modified_info HAVING modified_info LIKE 'a%';
SELECT info FROM test_table WHERE EXISTS (SELECT 1 FROM test_table t2 WHERE t2.seq <= test_table.seq AND sys.ms_stuff(t2.info, 1, 1, 'M') = 'Mbcde');
SELECT seq, sys.ms_stuff(info, 3, 2, 'PQR') AS complex_case FROM test_table WHERE addr IS NULL OR inet '10.0.0.1' = inet (SELECT address FROM test_table WHERE seq = 1);
CREATE TEMPORARY TABLE temp_table AS SELECT * FROM test_table WHERE info LIKE 'g%';