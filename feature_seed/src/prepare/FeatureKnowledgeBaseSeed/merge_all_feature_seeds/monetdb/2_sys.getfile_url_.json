CREATE TABLE files (id INT PRIMARY KEY, url CLOB, description TEXT);
INSERT INTO files (id, url, description) VALUES (1, 'http://example.com/path/to/file.txt', 'Sample file');
INSERT INTO files (id, url, description) VALUES (2, 'https://example.com/another/path/to/image.png', 'Image file');
SELECT f1.id, sys.getfile(f1.url) AS file_name, ~1 AS neg_one FROM files f1 WHERE f1.url IS NOT NULL AND ~1 > 0;
SELECT f1.id, sys.getfile(f1.url), (SELECT COUNT(*) FROM files f2 WHERE sys.getfile(f2.url) IS NOT NULL) AS valid_file_count FROM files f1 WHERE sys.getfile(f1.url) IS NOT NULL;
CREATE TABLE downloads (id INT PRIMARY KEY, file_id INT, download_time TIMESTAMP, FOREIGN KEY(file_id) REFERENCES files(id));
INSERT INTO downloads (id, file_id, download_time) VALUES (1, 1, '2023-10-01 10:00:00'), (2, 2, NULL);
SELECT d.id, sys.getfile(f.url), COUNT(*) OVER(PARTITION BY d.file_id) AS download_count FROM downloads d JOIN files f ON d.file_id = f.id WHERE ~d.id IS NOT NULL;
SELECT f.id, sys.getfile(f.url), ~MAX(ABS(d.id)) FROM downloads d RIGHT JOIN files f ON d.file_id = f.id GROUP BY f.id, sys.getfile(f.url) HAVING sys.getfile(f.url) IS NOT NULL;
SELECT url, ~AVG(COALESCE(NULLIF(length(url), 0), 1)) FROM files GROUP BY url HAVING sys.getfile(url) IS NOT NULL;