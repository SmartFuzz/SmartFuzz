CREATE SCHEMA test_schema;
CREATE TABLE test_schema.test_table (id serial, name varchar(100) NOT NULL, value int);
INSERT INTO test_schema.test_table (name, value) VALUES ('row1', 10), ('row2', 20), ('row3', 30);
ANALYZE test_schema;
SELECT * FROM sys.statistics WHERE schema = 'test_schema';
INSERT INTO test_schema.test_table (name, value) VALUES ('row4', 40), ('row5', 50);
ANALYZE test_schema.test_table;
SELECT * FROM sys.statistics('test_schema');
ANALYZE test_schema.test_table ('name');
SELECT * FROM sys.statistics('test_schema', 'test_table');
CREATE TABLE test_schema.another_table (id serial, description varchar(200) NOT NULL);
INSERT INTO test_schema.another_table (description) VALUES ('desc1'), ('desc2');
ANALYZE test_schema.another_table;
INSERT INTO test_schema.another_table (description) VALUES ('desc3');
ANALYZE test_schema.another_table ('description');
SELECT * FROM sys.statistics('test_schema', 'another_table', 'description');
ANALYZE test_schema.test_table ('id', 'name');
CREATE TABLE test_schema.complex_table (a int, b int);
INSERT INTO test_schema.complex_table (a, b) VALUES (1, 2), (3, 4);
CREATE TABLE test_schema.join_table (x int, y int);
INSERT INTO test_schema.join_table (x, y) VALUES (5, 6), (7, 8);
ANALYZE test_schema.complex_table;
ANALYZE test_schema.join_table;
SELECT (SELECT COUNT(*) FROM test_schema.complex_table) as count_complex, (SELECT COUNT(*) FROM test_schema.join_table) as count_join;
ANALYZE test_schema;