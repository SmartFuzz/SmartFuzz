CREATE TABLE angles (id INT, degr FLOAT);
INSERT INTO angles VALUES (1, 0), (2, 45), (3, 90), (4, 180), (5, 270), (6, 360);
SELECT id, radians(degr) FROM angles;
SELECT id, radians(degr) AS radians_value FROM angles WHERE degr <= 360;
SELECT id, radians(degr) AS radians_value FROM angles WHERE degr IN (0, 90, 180, 270, 360);
SELECT id, radians(degr) + 1 AS radians_plus_one FROM angles WHERE id IN (SELECT id FROM angles WHERE degr < 90);
CREATE TABLE converted_angles AS SELECT id, radians(degr) AS radians_value FROM angles;
SELECT ca.id, ca.radians_value FROM converted_angles ca JOIN angles a ON ca.id = a.id WHERE a.degr > 180;
SELECT (SELECT radians(45) FROM angles LIMIT 1) * 2 AS double_radians;
SELECT id, radians(degr) FROM angles ORDER BY radians(degr) DESC;
SELECT MAX(radians(degr)) AS max_radians FROM angles;
SELECT AVG(radians(degr)) AS avg_radians FROM angles WHERE degr > 0;
SELECT radians(SELECT AVG(degr) FROM angles) AS avg_radians_in_radians;