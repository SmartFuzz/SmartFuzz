CREATE TABLE permissions (user_id INT, permission VARCHAR(255), FOREIGN KEY (user_id) REFERENCES users(user_id));
INSERT INTO permissions (user_id, permission) VALUES (1, 'read');
INSERT INTO permissions (user_id, permission) VALUES (2, 'write');
SELECT * FROM permissions WHERE user_id = (SELECT user_id FROM users WHERE user_login_name = CURRENT_USER);
SET CURRENT_USER = (SELECT user_login_name FROM users WHERE user_id IN (SELECT user_id FROM permissions WHERE permission = 'write'));
SELECT CURRENT_USER;