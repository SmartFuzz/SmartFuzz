CREATE TABLE test_dates (id INT, event_date DATE);
INSERT INTO test_dates (id, event_date) VALUES (1, {d '2020-01-01'});
INSERT INTO test_dates (id, event_date) VALUES (2, {d '2020-02-29'});
INSERT INTO test_dates (id, event_date) VALUES (3, {d '2020-03-22'});
INSERT INTO test_dates (id, event_date) VALUES (4, {d '2020-12-31'});
INSERT INTO test_dates (id, event_date) VALUES (5, {d '2021-01-01'});
SELECT {fn DAYNAME(event_date)} FROM test_dates WHERE id = 1;
SELECT {fn DAYNAME(event_date)} FROM test_dates WHERE event_date BETWEEN {d '2020-01-01'} AND {d '2020-12-31'};
SELECT id, {fn DAYNAME(event_date)} AS day_name FROM test_dates WHERE event_date IS NOT NULL ORDER BY id;
SELECT t1.id, {fn DAYNAME(t2.event_date)} AS day_name FROM test_dates t1 JOIN test_dates t2 ON t1.id <> t2.id;
SELECT {fn DAYNAME(event_date)} AS day_name FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE event_date > {d '2020-01-01'}) ORDER BY day_name;
SELECT COUNT(*) AS day_count, {fn DAYNAME(event_date)} AS day_name FROM test_dates GROUP BY day_name HAVING COUNT(*) > 1;
SELECT {fn DAYNAME(CURRENT_DATE)} AS current_day_name;
CREATE TABLE events (event_id INT, event_date TIMESTAMP);
INSERT INTO events (event_id, event_date) VALUES (1, {ts '2023-01-01 10:00:00'});
INSERT INTO events (event_id, event_date) VALUES (2, {ts '2023-05-03 15:30:45'});
SELECT {fn DAYNAME(event_date)} FROM events WHERE event_id = 1;
SELECT {fn DAYNAME(DATE_ADD(event_date, INTERVAL 1 DAY))} FROM events WHERE event_id = 2;
SELECT {fn DAYNAME(CAST(event_date AS DATE))} FROM events;