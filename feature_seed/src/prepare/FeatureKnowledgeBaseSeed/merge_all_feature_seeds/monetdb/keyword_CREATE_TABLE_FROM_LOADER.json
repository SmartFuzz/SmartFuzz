CREATE TABLE IF NOT EXISTS test_schema.test_table FROM LOADER test_loader_function('arg1_value', 'arg2_value', 'arg3_value');
CREATE TABLE IF NOT EXISTS test_schema.empty_table FROM LOADER test_loader_function('arg1_value') WITH NO DATA;
CREATE TABLE IF NOT EXISTS my_schema.my_table FROM LOADER my_loader_function('arg1_value', (SELECT MAX(some_column) FROM other_table) );
CREATE TABLE IF NOT EXISTS complex_schema.complex_table FROM LOADER complex_loader_function('arg1_value', (SELECT a.col1 FROM table_a a JOIN table_b b ON a.id = b.a_id WHERE b.condition = 'true')) WITH NO DATA;
CREATE TABLE IF NOT EXISTS test_schema.joined_table FROM LOADER join_loader_function('select_column', (SELECT c.col3 FROM table_c c WHERE c.col2 = (SELECT MAX(b.col2) FROM table_b b)));
CREATE TABLE IF NOT EXISTS boundary_schema.boundary_table FROM LOADER boundary_loader_function('single_value');
CREATE TABLE IF NOT EXISTS new_schema.new_table FROM LOADER new_loader_function();
CREATE TABLE IF NOT EXISTS secondary_schema.secondary_table FROM LOADER secondary_loader_function('value1', NULL, 'value3') WITH NO DATA;
CREATE TABLE IF NOT EXISTS multi_arg_schema.multi_arg_table FROM LOADER multi_arg_loader_function('arg1', 'arg2', (SELECT COUNT(*) FROM counting_table) );
CREATE TABLE IF NOT EXISTS data_schema.data_table FROM LOADER data_loader_function('arg1', (SELECT d.col FROM detailed_table d WHERE d.condition = 'active'));