CREATE SEQUENCE test_sequence START WITH 1 INCREMENT BY 1 MINVALUE 1 MAXVALUE 100;
CREATE SEQUENCE schema1.test_sequence1 AS bigint START WITH 10 INCREMENT BY 5 MINVALUE 0 MAXVALUE 50 CACHE 10;
CREATE SEQUENCE test_sequence_cycle INCREMENT BY 1 NO MINVALUE NO MAXVALUE CYCLE;
CREATE SEQUENCE seq_large INCREMENT BY 100 START WITH 1000 MINVALUE 1000 MAXVALUE 1000000 CACHE 50;
CREATE SEQUENCE seq_no_cycle START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE NO CYCLE;
CREATE SEQUENCE seq_with_comment AS bigint START WITH 5 INCREMENT BY 2 MINVALUE 1 MAXVALUE 20 CACHE 5;
CREATE SEQUENCE seq_with_schema1_sequence2 AS integer START WITH 1 INCREMENT BY 1 NO MINVALUE NO MAXVALUE CYCLE;
CREATE SEQUENCE nested_seq START WITH (SELECT COUNT(*) FROM sys.sequences) INCREMENT BY 1 MINVALUE 1 MAXVALUE 100 CACHE 1;
CREATE SEQUENCE complex_seq AS bigint START WITH (SELECT MAX(id) FROM another_table) INCREMENT BY (SELECT COUNT(*) FROM yet_another_table) MINVALUE 1 MAXVALUE 1000;
CREATE SEQUENCE seq_test_cycle_no_min_max INCREMENT BY 7 CYCLE;