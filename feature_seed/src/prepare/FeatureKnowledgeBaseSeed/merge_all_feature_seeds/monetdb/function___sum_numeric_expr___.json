CREATE TABLE test_table (id SERIAL, value INTEGER, category VARCHAR(50));
INSERT INTO test_table (value, category) VALUES (10, 'A'), (20, 'B'), (30, 'A'), (40, 'B');
SELECT SUM(value) FROM test_table WHERE category = 'A';
SELECT SUM(value) FROM test_table WHERE category IN ('A', 'B');
SELECT SUM(value) AS total FROM (SELECT value FROM test_table WHERE category = 'A') AS subquery;
CREATE TABLE additional_table (id SERIAL, test_id INTEGER, score FLOAT);
INSERT INTO additional_table (test_id, score) VALUES (1, 10.5), (1, 20.5), (2, 30.0), (2, NULL);
SELECT SUM(a.value) FROM test_table a JOIN additional_table b ON a.id = b.test_id WHERE b.score IS NOT NULL;
SELECT SUM(value) FROM (SELECT value FROM test_table WHERE id < 3) AS limited;
SELECT SUM(COALESCE(score, 0)) FROM additional_table WHERE test_id = 1;
SELECT SUM(value) FROM test_table WHERE value BETWEEN 15 AND 35;
SELECT AVG(SUM(value)) FROM (SELECT SUM(value) FROM test_table GROUP BY category) AS category_totals;
SELECT SUM((CASE WHEN value > 25 THEN value ELSE 0 END)) FROM test_table;
SELECT id, SUM(value) FROM test_table GROUP BY id HAVING SUM(value) > 15;
SELECT SUM(value) OVER (PARTITION BY category) FROM test_table;
CREATE TABLE sales_data (month INTEGER, sales_amount DECIMAL(10, 2));
INSERT INTO sales_data (month, sales_amount) VALUES (1, 150.50), (1, 200.75), (2, NULL), (2, 300.25);
SELECT SUM(sales_amount) FROM sales_data WHERE month = 1;
SELECT month, SUM(sales_amount) FROM sales_data GROUP BY month ORDER BY month;
CREATE TABLE combined_data (id SERIAL, amount1 FLOAT, amount2 FLOAT);
INSERT INTO combined_data (amount1, amount2) VALUES (10.0, 20.0), (NULL, 5.0), (15.0, NULL);
SELECT SUM(amount1) + SUM(COALESCE(amount2, 0)) FROM combined_data;
SELECT SUM(amount1) + SUM(amount2) AS total_amount FROM combined_data WHERE amount1 IS NOT NULL OR amount2 IS NOT NULL;