CREATE TABLE test_table (id SERIAL PRIMARY KEY, value DOUBLE, inet_addr INET);
INSERT INTO test_table (value, inet_addr) VALUES (2.0, inet '192.168.1.5'), (4.0, inet '192.168.1.10'), (NULL, NULL);
SELECT id, sqrt(value) AS sqrt_value FROM test_table WHERE sqrt(value) < 3.0;
SELECT id, inet_addr FROM test_table WHERE inet_addr < inet '192.168.1.6' AND value IS NOT NULL;
SELECT id, INET '10.0.0.1' AS test_inet FROM test_table WHERE sqrt(value) < sqrt(16.0) - 1.0;
CREATE TABLE join_table (join_id SERIAL PRIMARY KEY, value DOUBLE, addr INET);
INSERT INTO join_table (value, addr) VALUES (NULL, inet '192.168.1.20'), (1.0, inet '192.168.1.30');
SELECT a.id, sqrt(a.value) AS sqrt_a, b.addr FROM test_table a JOIN join_table b ON sqrt(a.value) < b.value;
SELECT id FROM test_table GROUP BY id HAVING sqrt(MAX(value)) < 3.0;
SELECT id FROM test_table WHERE value IS NOT NULL AND sqrt(value) < (SELECT AVG(value) FROM test_table WHERE value IS NOT NULL);
SELECT id, sqrt(SUM(value)) OVER (PARTITION BY inet_addr) AS sqrt_sum FROM test_table GROUP BY inet_addr;