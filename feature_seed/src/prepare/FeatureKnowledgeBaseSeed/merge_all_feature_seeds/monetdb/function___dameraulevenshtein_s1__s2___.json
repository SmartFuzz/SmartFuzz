SELECT id, s1, s2, dameraulevenshtein(s1, s2) AS distance FROM test_strings;
SELECT id, s1, s2, dameraulevenshtein(s1, s2) AS distance FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE LENGTH(s2) < 5);
SELECT t1.id, t1.s1, t2.s2, dameraulevenshtein(t1.s1, t2.s2) AS distance FROM test_strings t1 JOIN test_strings t2 ON t1.id <> t2.id;
SELECT t1.id, t1.s1, t2.s2, dameraulevenshtein(t1.s1, t2.s2) AS distance FROM test_strings t1 JOIN test_strings t2 ON LENGTH(t1.s1) = LENGTH(t2.s2) WHERE t1.id <> t2.id;
SELECT id, s1, s2, dameraulevenshtein(s1, s2) AS distance FROM test_strings WHERE dameraulevenshtein(s1, s2) < 3;