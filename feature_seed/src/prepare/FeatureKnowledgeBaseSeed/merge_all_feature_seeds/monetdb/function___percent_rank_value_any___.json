CREATE TABLE test_data (id INT, value FLOAT);
INSERT INTO test_data VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, 40.0);
SELECT id, value, percent_rank(value) OVER (ORDER BY value) AS rank FROM test_data;
CREATE TABLE partitioned_data (group_id INT, subgroup_id INT, value FLOAT);
INSERT INTO partitioned_data VALUES (1, 1, 10.0), (1, 1, 20.0), (1, 2, 30.0), (2, 1, 40.0), (2, 1, 50.0);
SELECT subgroup_id, value, percent_rank(value) OVER (PARTITION BY group_id ORDER BY value) AS rank FROM partitioned_data;
CREATE TABLE multiple_data (group_id INT, score FLOAT);
INSERT INTO multiple_data VALUES (1, 10.5), (1, 20.5), (1, 30.5), (2, 40.5), (2, 50.5);
SELECT group_id, score, percent_rank(score) OVER (PARTITION BY group_id ORDER BY score) AS rank FROM multiple_data ORDER BY group_id, rank;
CREATE TABLE complex_data (dept_id INT, employee_id INT, performance_score FLOAT);
INSERT INTO complex_data VALUES (1, 101, 70.0), (1, 102, 80.0), (1, 103, 90.0), (2, 201, 85.0), (2, 202, 95.0);
SELECT dept_id, employee_id, performance_score, percent_rank(performance_score) OVER (PARTITION BY dept_id ORDER BY performance_score) AS rank FROM complex_data;
SELECT a.id, a.value, b.rank FROM test_data a JOIN (SELECT id, percent_rank(value) OVER (ORDER BY value) AS rank FROM test_data) b ON a.id = b.id;
SELECT dept_id, AVG(performance_score) AS avg_score, percent_rank(avg_score) OVER (ORDER BY avg_score) AS rank FROM complex_data GROUP BY dept_id;