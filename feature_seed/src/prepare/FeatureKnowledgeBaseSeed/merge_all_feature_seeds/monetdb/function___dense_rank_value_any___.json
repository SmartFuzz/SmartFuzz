CREATE TABLE employees (id INT, name VARCHAR(100), salary INT);
INSERT INTO employees VALUES (1, 'Alice', 50000), (2, 'Bob', 60000), (3, 'Charlie', 70000), (4, 'David', 60000), (5, 'Eve', 50000);
SELECT dense_rank(salary) OVER (ORDER BY salary DESC) AS rank FROM employees;
CREATE TABLE departments (dept_id INT, dept_name VARCHAR(100));
INSERT INTO departments VALUES (1, 'HR'), (2, 'Engineering');
SELECT d.dept_name, e.name, dense_rank(salary) OVER (PARTITION BY d.dept_name ORDER BY salary DESC) AS rank FROM employees e JOIN departments d ON d.dept_id = CASE WHEN e.id % 2 = 0 THEN 2 ELSE 1 END;
CREATE TABLE projects (proj_id INT, dept_id INT, budget INT);
INSERT INTO projects VALUES (1, 1, 100000), (2, 2, 150000), (3, 1, 200000);
SELECT p.proj_id, e.name, dense_rank(e.salary) OVER (ORDER BY e.salary DESC) AS rank FROM employees e JOIN projects p ON e.id = CASE WHEN p.budget > 150000 THEN e.id ELSE NULL END;
WITH ranked_salaries AS (SELECT e.name, dense_rank(e.salary) OVER (ORDER BY e.salary DESC) AS rank FROM employees e) SELECT rank, COUNT(*) FROM ranked_salaries GROUP BY rank ORDER BY rank;
SELECT e1.name, e2.name, dense_rank(e1.salary) OVER (ORDER BY e1.salary) AS rank1, dense_rank(e2.salary) OVER (ORDER BY e2.salary) AS rank2 FROM employees e1, employees e2 WHERE e1.id != e2.id;
SELECT e.name, dense_rank(salary) OVER (PARTITION BY (CASE WHEN salary > 60000 THEN 'High' ELSE 'Low' END) ORDER BY salary DESC) AS rank FROM employees e;