CREATE TABLE schema1.table_a (id INT, value VARCHAR(100));
CREATE TABLE schema1.table_b (id INT, description VARCHAR(100));
CREATE MERGE TABLE schema1.merge_table AS SELECT * FROM schema1.table_a;
ALTER TABLE schema1.merge_table DROP TABLE schema1.table_a RESTRICT;
ALTER TABLE schema1.merge_table DROP TABLE schema1.table_b CASCADE;
CREATE TABLE schema2.table_x (id INT, data VARCHAR(50));
CREATE MERGE TABLE schema2.merge_table_x AS SELECT * FROM schema1.table_b;
ALTER TABLE schema2.merge_table_x DROP TABLE schema2.table_x RESTRICT;
ALTER TABLE schema1.merge_table DROP TABLE schema1.table_a CASCADE;
ALTER TABLE schema1.merge_table DROP TABLE schema1.non_existent_table RESTRICT;
CREATE TABLE schema1.table_c (id INT PRIMARY KEY, info VARCHAR(200));
ALTER TABLE schema1.merge_table DROP TABLE schema1.table_c CASCADE;
SELECT * FROM schema1.merge_table WHERE id IN (SELECT id FROM schema1.table_b);
CREATE MERGE TABLE schema1.merge_table_with_complex AS SELECT * FROM (SELECT * FROM schema1.table_a UNION SELECT * FROM schema1.table_b) AS sub;
ALTER TABLE schema1.merge_table_with_complex DROP TABLE schema1.table_b RESTRICT;