CREATE TABLE numbers (a FLOAT, b FLOAT);
INSERT INTO numbers VALUES (2, 3.4);
SELECT sql_add(a, b) AS result FROM numbers;
CREATE TABLE more_numbers (x FLOAT, y FLOAT);
INSERT INTO more_numbers VALUES (NULL, NULL), (1.1, 2.2), (5, -1);
SELECT sql_add(mn.x, mn.y) AS sum FROM more_numbers mn WHERE mn.x IS NOT NULL;
CREATE TABLE complex_data (id INT, data1 FLOAT, data2 FLOAT);
INSERT INTO complex_data VALUES (1, 3.5, 2.3), (2, 5.6, NULL), (3, NULL, 7.9);
SELECT c.id, sql_add(c.data1, c.data2) AS total FROM complex_data c;
SELECT sql_add((SELECT MAX(data1) FROM complex_data), (SELECT MIN(data2) FROM complex_data)) AS boundaries_sum;
CREATE TABLE join_table1 (id INT PRIMARY KEY, value1 FLOAT);
CREATE TABLE join_table2 (id INT PRIMARY KEY, value2 FLOAT);
INSERT INTO join_table1 VALUES (1, 1.1), (2, 2.2);
INSERT INTO join_table2 VALUES (1, 3.3), (2, 4.4);
SELECT jt1.id, sql_add(jt1.value1, jt2.value2) AS combined_value FROM join_table1 jt1 JOIN join_table2 jt2 ON jt1.id = jt2.id;
CREATE TABLE edge_cases (a FLOAT, b FLOAT);
INSERT INTO edge_cases VALUES (1.7976931348623157E+308, 1), (-1.7976931348623157E+308, -1), (0, 0);
SELECT sql_add(a, b) FROM edge_cases;
CREATE TABLE very_large_numbers (large_val FLOAT);
INSERT INTO very_large_numbers VALUES (1e+100), (1e+200);
SELECT sql_add(large_val, 1) AS incremented_val FROM very_large_numbers;