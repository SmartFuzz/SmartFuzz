CREATE TABLE angles (angle FLOAT);
INSERT INTO angles VALUES (0.0), (1.0), (1.57), (3.14), (3.14159), (-1.0), (6.28319);
SELECT angle, sin(angle) AS sine_value FROM angles;
SELECT angle, sin(angle) AS sine_value FROM angles WHERE angle > 0;
SELECT angle, sin(CAST(angle AS DOUBLE)) AS sine_value FROM angles;
SELECT sin((SELECT AVG(angle) FROM angles)) AS average_sine;
SELECT a.angle, sin(a.angle) AS sine_value FROM angles a JOIN angles b ON a.angle > b.angle;
WITH sin_values AS (SELECT angle, sin(angle) AS sine_value FROM angles) SELECT * FROM sin_values WHERE sine_value > 0.5;
SELECT (SELECT sin(angle) FROM angles WHERE angle = 1.0) + (SELECT sin(angle) FROM angles WHERE angle = 0.0) AS combined_sine;
SELECT angle, sin(angle) FROM angles ORDER BY sine_value DESC LIMIT 5;