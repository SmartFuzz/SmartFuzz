CREATE TABLE fuzz_test (id int, timestamp_col timestamp, value_col int);
INSERT INTO fuzz_test (id, timestamp_col, value_col) VALUES (1, timestamp '2020-09-28 18:40:05', 17);
INSERT INTO fuzz_test (id, timestamp_col, value_col) VALUES (2, timestamp '2020-09-29 12:30:00', 5);
INSERT INTO fuzz_test (id, timestamp_col, value_col) VALUES (3, NULL, NULL);
INSERT INTO fuzz_test (id, timestamp_col, value_col) VALUES (4, timestamp '2020-09-30 00:00:01', 0);
SELECT id, bit_xor(value_col, 5), timestamp_col FROM fuzz_test WHERE timestamp_col IS NOT NULL GROUP BY id HAVING bit_xor(value_col, 5) > 0;
SELECT id, (SELECT bit_xor(f.value_col, 5) FROM fuzz_test f WHERE f.id = ft.id) AS xor_value FROM fuzz_test ft WHERE timestamp_col IS NOT NULL;
SELECT id, bit_xor(value_col, (SELECT COUNT(*) FROM fuzz_test WHERE value_col IS NOT NULL)) AS complex_xor FROM fuzz_test GROUP BY id HAVING complex_xor < 10;
SELECT id, (bit_xor(value_col, 5) + 1) AS adjusted_value FROM fuzz_test WHERE timestamp_col < timestamp '2020-09-29 00:00:00' ORDER BY adjusted_value DESC;
SELECT ft1.id, bit_xor(ft1.value_col, ft2.value_col) AS combined_xor FROM fuzz_test ft1 JOIN fuzz_test ft2 ON ft1.id <> ft2.id GROUP BY ft1.id HAVING combined_xor IS NOT NULL;