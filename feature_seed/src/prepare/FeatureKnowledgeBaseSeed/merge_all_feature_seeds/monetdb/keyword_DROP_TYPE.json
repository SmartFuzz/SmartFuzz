CREATE TYPE example_type AS (field1 INT, field2 TEXT);
CREATE TABLE example_table (id INT PRIMARY KEY, data example_type);
INSERT INTO example_table (id, data) VALUES (1, ROW(10, 'example'));
DROP TYPE example_type RESTRICT;
CREATE TYPE another_type AS (field1 FLOAT);
CREATE TABLE another_table (id INT PRIMARY KEY, other_data another_type);
DROP TYPE another_type CASCADE;
CREATE TYPE complex_type AS (field1 INT, field2 TEXT, field3 ARRAY[INT]);
DROP TYPE complex_type RESTRICT;
CREATE TYPE nested_type AS (field1 INT, nested_field example_type);
CREATE TABLE nested_table (id INT PRIMARY KEY, nested_data nested_type);
DROP TYPE nested_type CASCADE;
CREATE TYPE temp_type AS (field1 INT);
CREATE TABLE temp_table (id INT PRIMARY KEY, temp_data temp_type);
INSERT INTO temp_table (id, temp_data) VALUES (2, ROW(20));
DROP TYPE temp_type RESTRICT;