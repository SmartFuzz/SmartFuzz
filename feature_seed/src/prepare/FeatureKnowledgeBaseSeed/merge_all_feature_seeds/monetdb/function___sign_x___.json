CREATE TABLE test_sign (value FLOAT);
INSERT INTO test_sign VALUES (-8.4), (0), (5.7), (-1.0), (3.14);
SELECT value, sign(value) FROM test_sign;
CREATE TABLE thresholds (threshold FLOAT);
INSERT INTO thresholds VALUES (-1.0), (0), (1.0);
SELECT t.threshold, sign(t.threshold) FROM thresholds t;
SELECT sign((SELECT MIN(value) FROM test_sign));
SELECT sign(AVG(value)) FROM test_sign;
SELECT t.value, sign(t.value) FROM test_sign t WHERE t.value < (SELECT AVG(value) FROM test_sign);
SELECT sign(ABS(value)) FROM test_sign;
SELECT sign(COALESCE((SELECT value FROM test_sign WHERE value < 0 LIMIT 1), 0));
SELECT COUNT(*) FROM test_sign WHERE sign(value) = 1;
SELECT SUM(CASE WHEN sign(value) = -1 THEN 1 ELSE 0 END) AS negative_count FROM test_sign;
SELECT (SELECT COUNT(*) FROM test_sign WHERE sign(value) = 0) AS zero_count, (SELECT COUNT(*) FROM test_sign WHERE sign(value) = 1) AS positive_count;
SELECT sign(CAST((SELECT SUM(value) FROM test_sign) AS FLOAT));
SELECT value, sign(value) FROM (SELECT value FROM test_sign ORDER BY value ASC) AS ordered_values;