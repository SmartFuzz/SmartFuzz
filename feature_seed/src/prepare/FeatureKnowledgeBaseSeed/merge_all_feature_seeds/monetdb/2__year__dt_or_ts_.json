CREATE TABLE test_dates (id SERIAL PRIMARY KEY, ts_col TIMESTAMP, date_col DATE);
INSERT INTO test_dates (ts_col, date_col) VALUES (timestamp '2020-09-28 18:40:05', date '2020-03-22');
SELECT id, year(ts_col) AS extract_year FROM test_dates WHERE ts_col >= timestamp '2020-01-01 00:00:00';
SELECT id, year(date_col) AS year_value FROM test_dates WHERE date_col IS NOT NULL;
SELECT id, year(timestamp '2020-12-31 23:59:59') AS year_check FROM test_dates WHERE year(ts_col) IS DISTINCT FROM year(date_col);
SELECT id, year(ts_col) + 1 AS next_year, year(date_col) * 2 AS double_year FROM test_dates HAVING next_year < 2023;
CREATE TABLE employees (id SERIAL PRIMARY KEY, hired_date DATE NOT NULL, name VARCHAR(100));
INSERT INTO employees (hired_date, name) VALUES (date '2020-03-22', 'Alice'), (date '2019-12-30', 'Bob');
SELECT e.id, year(e.hired_date) AS hire_year, d.id as dept_id FROM employees e JOIN (SELECT id, year(ts_col) as created_year FROM test_dates) d ON d.created_year = year(e.hired_date);
SELECT e.id, year(e.hired_date) AS hire_year, d.id as dept_id FROM employees e LEFT JOIN (SELECT id, year(ts_col) as created_year FROM test_dates WHERE ts_col IS NULL) d ON d.created_year = year(e.hired_date);
SELECT e.id, d.created_year FROM employees e FULL OUTER JOIN (SELECT id, year(ts_col) AS created_year FROM test_dates) d ON year(e.hired_date) = d.created_year ORDER BY d.created_year DESC NULLS LAST;
SELECT DATE_PART('year', ts_col) AS part_year FROM test_dates WHERE ts_col IS NULL;
SELECT e.id, e.name, year(COALESCE(e.hired_date, date '2000-01-01')) as hire_year FROM employees e;
CREATE TEMPORARY TABLE temp_dates AS SELECT id, ts_col FROM test_dates WHERE year(ts_col) > 2018;
SELECT id FROM temp_dates WHERE ts_col <> timestamp '2021-01-01 00:00:00';