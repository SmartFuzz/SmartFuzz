CREATE TABLE test_timestamps (id INT PRIMARY KEY, event_time TIMESTAMP(6));
INSERT INTO test_timestamps VALUES (1, timestamp(6) '2020-09-28 18:40:05.123456');
INSERT INTO test_timestamps VALUES (2, timestamp(6) '2020-01-01 00:00:00.000000');
INSERT INTO test_timestamps VALUES (3, timestamp(6) '2020-12-31 23:59:59.999999');
INSERT INTO test_timestamps VALUES (4, timestamp(6) '2019-02-29 12:00:00.000000');
INSERT INTO test_timestamps VALUES (5, timestamp(6) '2020-09-28 18:40:05.123456');
SELECT id, event_time FROM test_timestamps WHERE event_time = timestamp(6) '2020-09-28 18:40:05.123456';
SELECT id, event_time FROM test_timestamps WHERE event_time < timestamp(6) '2020-12-01 00:00:00.000000';
SELECT id, event_time FROM test_timestamps WHERE event_time > timestamp(6) '2020-01-01 00:00:00.000000';
SELECT id, event_time FROM test_timestamps WHERE event_time BETWEEN timestamp(6) '2020-01-01 00:00:00.000000' AND timestamp(6) '2020-12-31 23:59:59.999999';
SELECT id, event_time FROM (SELECT id, event_time FROM test_timestamps WHERE event_time IS NOT NULL) AS subquery WHERE id = 2;
CREATE TABLE test_events (event_id INT PRIMARY KEY, event_description TEXT, event_date TIMESTAMP(6));
INSERT INTO test_events VALUES (1, 'Event 1', timestamp(6) '2020-09-28 18:40:05.123456');
INSERT INTO test_events VALUES (2, 'Event 2', timestamp(6) '2020-09-29 19:00:00.654321');
SELECT e.event_id, e.event_description, t.event_time FROM test_events e JOIN test_timestamps t ON e.event_id = t.id WHERE e.event_date = t.event_time;
SELECT COUNT(*) FROM test_timestamps WHERE event_time IS NOT NULL;
SELECT event_time, COUNT(*) FROM test_timestamps GROUP BY event_time ORDER BY event_time;
SELECT timestamp(6) '2020-09-28 18:40:05.123456' + interval '1 hour';
SELECT timestamp(6) '2020-09-28 18:40:05.123456' - interval '12 hours';
SELECT timestamp(6) NOW();