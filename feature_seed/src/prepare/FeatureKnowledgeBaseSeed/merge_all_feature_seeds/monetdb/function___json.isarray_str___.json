CREATE TABLE json_test (id INT PRIMARY KEY, json_str STRING);
INSERT INTO json_test VALUES (1, '[1, 2, 3]');
INSERT INTO json_test VALUES (2, '["a", "b", "c"]');
INSERT INTO json_test VALUES (3, '[]');
INSERT INTO json_test VALUES (4, '{"key": "value"}');
INSERT INTO json_test VALUES (5, '[1, [2, 3], 4]');
INSERT INTO json_test VALUES (6, '[null]');
INSERT INTO json_test VALUES (7, 'non-json-string');
SELECT json.isarray(json_str) FROM json_test WHERE id = 1;
SELECT json.isarray(json_str) FROM json_test WHERE id = 2;
SELECT json.isarray(json_str) FROM json_test WHERE id = 3;
SELECT json.isarray(json_str) FROM json_test WHERE id = 4;
SELECT json.isarray(json_str) FROM json_test WHERE id = 5;
SELECT json.isarray(json_str) FROM json_test WHERE id = 6;
SELECT json.isarray(json_str) FROM json_test WHERE id = 7;
SELECT id, json.isarray(json_str) FROM json_test WHERE json_str LIKE '%[%]';
SELECT id, json.isarray(json_str) FROM json_test WHERE json_str LIKE '%[%]%' AND id < 5;
SELECT COUNT(*) FROM json_test WHERE json.isarray(json_str);
SELECT AVG(id) FROM json_test WHERE json.isarray(json_str);