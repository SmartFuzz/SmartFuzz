CREATE TABLE test_json (id INT PRIMARY KEY, js JSON);
INSERT INTO test_json VALUES (1, json '{"n":4}');
INSERT INTO test_json VALUES (2, json '{"name":"John", "age":30}');
INSERT INTO test_json VALUES (3, json '{"array":[1, 2, 3]}');
INSERT INTO test_json VALUES (4, json '{"object":{"key":"value"}}');
INSERT INTO test_json VALUES (5, json '{"null_value":null}');
INSERT INTO test_json VALUES (6, json '"just_a_string"');
INSERT INTO test_json VALUES (7, json '1234');
SELECT json.isobject(js) FROM test_json WHERE id = 1;
SELECT json.isobject(js) FROM test_json WHERE js IS NOT NULL;
SELECT id, json.isobject(js) FROM test_json WHERE js IS NOT NULL ORDER BY id;
SELECT t.id, json.isobject(t.js) AS is_object FROM test_json t WHERE EXISTS (SELECT 1 FROM test_json WHERE js IS NOT NULL);
CREATE TABLE json_test AS (SELECT id, json.isobject(js) AS is_object FROM test_json);
SELECT SUM(CASE WHEN json.isobject(js) THEN 1 ELSE 0 END) AS object_count FROM test_json;
SELECT js FROM test_json WHERE json.isobject(js) AND id IN (SELECT id FROM test_json WHERE js IS NOT NULL);
SELECT DISTINCT js FROM test_json WHERE json.isobject(js) OR js IS NULL;