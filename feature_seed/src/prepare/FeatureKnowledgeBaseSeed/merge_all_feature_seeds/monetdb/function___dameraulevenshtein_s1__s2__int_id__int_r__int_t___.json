CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255), r INT, t INT);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (1, 'MonetDB', 'DB3', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (2, 'foo', 'bar', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (3, '', 'non-empty', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (4, 'same', 'same', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (5, 'abc', 'cba', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (6, NULL, 'null', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (7, 'test', 'testcase', 1, 1);
INSERT INTO test_strings (id, str1, str2, r, t) VALUES (8, 'kitten', 'sitting', 1, 1);
SELECT id, dameraulevenshtein(str1, str2, r, t) FROM test_strings;
SELECT id, dameraulevenshtein(str1, str2, r, t) FROM test_strings WHERE r = 1;
SELECT id, dameraulevenshtein(str1, str2, r, t) AS distance FROM test_strings WHERE distance < 5;
CREATE TABLE additional_strings (id INT PRIMARY KEY, additional_str VARCHAR(255));
INSERT INTO additional_strings (id, additional_str) VALUES (1, 'abcdef'), (2, 'ghijkl');
SELECT ts.id, ts.str1, ts.str2, ds.additional_str, dameraulevenshtein(ts.str1, ds.additional_str, ts.r, ts.t) FROM test_strings ts JOIN additional_strings ds ON ts.id = ds.id;
SELECT str1, str2, dameraulevenshtein(str1, 'anotherstring', r, t) FROM test_strings WHERE str2 IS NOT NULL;