CREATE TABLE json_data (id INT, js JSON);
INSERT INTO json_data VALUES (1, json '{"a":[1]}');
INSERT INTO json_data VALUES (2, json '{"b":{"c":2}}');
INSERT INTO json_data VALUES (3, json '{"d":[{"e":3}, {"f":4}]}');
SELECT json.length(js) FROM json_data;
SELECT id, json.length(js) FROM json_data WHERE json.length(js) > 1;
SELECT id FROM json_data WHERE json.length(js) = 1 AND js IS NOT NULL;
SELECT d.id, d.js, json.length(d.js) AS length FROM json_data AS d WHERE d.id IN (SELECT id FROM json_data WHERE json.length(js) > 1);
CREATE TABLE json_info (json_value JSON);
INSERT INTO json_info VALUES (json '{"g":[5,6,7]}'), (json '{"h":8}');
SELECT json.length(json_value) AS length FROM json_info WHERE json.length(json_value) > 1;
CREATE TABLE merged_data (id INT, js JSON, other_info VARCHAR(100));
INSERT INTO merged_data VALUES (1, json '{"x":[1]}', 'info1'), (2, json '{"y":[2,3]}', 'info2');
SELECT m.id, json.length(m.js) AS component_count FROM merged_data m WHERE json.length(m.js) > (SELECT AVG(json.length(js)) FROM json_data);
SELECT sum(json.length(d.js)) FROM merged_data d JOIN json_data j ON d.id = j.id GROUP BY d.other_info HAVING sum(json.length(d.js)) > 2;