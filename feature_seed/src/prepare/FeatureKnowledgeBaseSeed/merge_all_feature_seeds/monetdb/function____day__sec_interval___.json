CREATE TABLE intervals (id SERIAL PRIMARY KEY, duration INTERVAL SECOND);
INSERT INTO intervals (duration) VALUES (INTERVAL '3.23' SECOND);
INSERT INTO intervals (duration) VALUES (INTERVAL '86400' SECOND);
INSERT INTO intervals (duration) VALUES (INTERVAL '172800' SECOND);
SELECT "day"(duration) FROM intervals;
SELECT id, "day"(duration) AS days FROM intervals WHERE duration > INTERVAL '0' SECOND;
CREATE TABLE events (event_id SERIAL PRIMARY KEY, event_start TIMESTAMP, duration INTERVAL SECOND);
INSERT INTO events (event_start, duration) VALUES (NOW(), INTERVAL '86400' SECOND), (NOW(), INTERVAL '172800' SECOND);
SELECT event_id, "day"(duration) AS duration_days FROM events WHERE event_start < NOW() ORDER BY event_start;
SELECT (SELECT "day"(duration) FROM intervals WHERE id = 1) + (SELECT "day"(duration) FROM events WHERE event_id = 1) AS total_days;
SELECT e.event_id, i.id, "day"(i.duration) AS interval_days, "day"(e.duration) AS event_days FROM events e JOIN intervals i ON "day"(i.duration) = "day"(e.duration);
CREATE TABLE day_count (count BIGINT);
INSERT INTO day_count (count) SELECT SUM("day"(duration)) FROM intervals;
SELECT * FROM day_count;
SELECT "day"(INTERVAL '0' SECOND) AS zero_days;
SELECT "day"(INTERVAL '60' SECOND) AS one_day;
SELECT "day"(INTERVAL '86401' SECOND) AS one_day_plus_one_second;