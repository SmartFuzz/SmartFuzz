CREATE TABLE test_coalesce (a STRING, b STRING, c STRING);
INSERT INTO test_coalesce VALUES (NULL, 'apple', 'banana');
INSERT INTO test_coalesce VALUES (NULL, NULL, 'cherry');
INSERT INTO test_coalesce VALUES (NULL, NULL, NULL);
INSERT INTO test_coalesce VALUES ('grape', 'orange', NULL);
INSERT INTO test_coalesce VALUES ('mango', NULL, NULL);
SELECT coalesce(a, b, c) AS first_non_null FROM test_coalesce;
SELECT coalesce(NULL, 'fixed', 'value') AS result;
SELECT coalesce(NULLIF(a, 'apple'), b, c) AS non_null_value FROM test_coalesce;
CREATE TABLE another_table (x STRING);
INSERT INTO another_table VALUES ('peach'), (NULL), (NULL);
SELECT coalesce((SELECT x FROM another_table WHERE x IS NOT NULL), 'default_value') AS retrieved_value;
SELECT coalesce((SELECT b FROM test_coalesce WHERE a IS NULL), (SELECT c FROM another_table WHERE x IS NULL), 'fallback') AS combined;
SELECT coalesce(coalesce(a, b), c) AS nested_result FROM test_coalesce;