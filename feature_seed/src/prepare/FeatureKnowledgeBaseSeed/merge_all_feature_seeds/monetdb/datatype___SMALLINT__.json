CREATE TABLE smallint_table (id SMALLINT PRIMARY KEY, name VARCHAR(50));
INSERT INTO smallint_table VALUES (32767, 'Max Value');
INSERT INTO smallint_table VALUES (-32768, 'Min Value');
INSERT INTO smallint_table VALUES (0, 'Zero Value');
SELECT * FROM smallint_table WHERE id BETWEEN -32768 AND 32767;
SELECT COUNT(*) FROM smallint_table WHERE id < 0;
SELECT name FROM smallint_table WHERE id IN (SELECT id FROM smallint_table WHERE id > 100);
CREATE TABLE another_table (name VARCHAR(50), smallint_id SMALLINT REFERENCES smallint_table(id));
INSERT INTO another_table VALUES ('Example Name', 32767);
SELECT A.name FROM another_table A JOIN smallint_table B ON A.smallint_id = B.id WHERE B.id BETWEEN 0 AND 100;
SELECT A.name, B.name FROM another_table A JOIN smallint_table B ON A.smallint_id = B.id WHERE B.id = -32768;
UPDATE smallint_table SET id = id + 1 WHERE id < 32767;
DELETE FROM smallint_table WHERE id = 0;
SELECT DISTINCT id FROM smallint_table WHERE id % 2 = 0;
SELECT id, (SELECT COUNT(*) FROM another_table WHERE smallint_id = id) AS count FROM smallint_table;
CREATE VIEW smallint_view AS SELECT * FROM smallint_table WHERE id < 100;