CREATE TABLE tanh_test (value FLOAT);
INSERT INTO tanh_test VALUES (0), (1), (-1), (2), (-2), (1.4), (3.5), (-3.5);
SELECT value, tanh(value) AS tanh_value FROM tanh_test;
SELECT tanh(value) FROM (SELECT value FROM tanh_test WHERE value > 0) AS positive_values;
SELECT a.value, b.value, tanh(a.value + b.value) AS tanh_sum FROM tanh_test a JOIN tanh_test b ON a.value < b.value;
SELECT tanh((SELECT AVG(value) FROM tanh_test));
SELECT value, tanh(value) FROM tanh_test WHERE value IN (SELECT value FROM tanh_test WHERE value >= 0.5);
SELECT tanh(CASE WHEN value > 1 THEN value ELSE -value END) AS conditional_tanh FROM tanh_test;
SELECT tanh(x) FROM (SELECT value AS x FROM tanh_test WHERE x NOT IN (SELECT value FROM tanh_test WHERE value < 0)) AS non_negative_values;
CREATE TABLE angle_test (angle FLOAT);
INSERT INTO angle_test VALUES (0.0), (3.14159/4), (3.14159/2), (-3.14159/4), (-3.14159/2);
SELECT angle, tanh(angle) FROM angle_test;
SELECT angle, tanh(angle), tanh(angle + 1) AS new_angle_tanh FROM angle_test WHERE angle < 2;
SELECT tanh(a.angle + b.angle) FROM angle_test a, angle_test b WHERE a.angle < b.angle;
SELECT tanh((SELECT MAX(angle) FROM angle_test)) AS max_angle_tanh;
SELECT angle, tanh(angle) FROM angle_test WHERE angle BETWEEN -1 AND 1;