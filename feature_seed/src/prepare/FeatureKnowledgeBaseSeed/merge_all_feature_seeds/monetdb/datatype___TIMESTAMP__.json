CREATE TABLE events (id INT PRIMARY KEY, event_time TIMESTAMP(6));
INSERT INTO events VALUES (1, '2023-10-16 14:30:00.123456');
INSERT INTO events VALUES (2, '2023-10-16 14:31:01.654321');
INSERT INTO events VALUES (3, '2023-10-16 14:32:22.111111');
SELECT * FROM events WHERE event_time BETWEEN '2023-10-16 14:30:00.000000' AND '2023-10-16 14:32:22.999999';
SELECT COUNT(*) FROM events WHERE event_time > '2023-10-16 14:31:00.000000';
SELECT AVG(EXTRACT(MILLISECOND FROM event_time)) FROM events;
CREATE TABLE event_details (event_id INT, description TEXT, FOREIGN KEY (event_id) REFERENCES events(id));
INSERT INTO event_details VALUES (1, 'Event triggered at time 1');
INSERT INTO event_details VALUES (2, 'Event triggered at time 2');
SELECT e.id, ed.description FROM events e JOIN event_details ed ON e.id = ed.event_id WHERE e.event_time < '2023-10-16 14:31:00.000000';
SELECT e.event_time, (SELECT COUNT(*) FROM event_details ed WHERE ed.event_id = e.id) AS detail_count FROM events e;
SELECT e.event_time, (SELECT MAX(event_time) FROM events WHERE event_time < e.event_time) AS previous_event_time FROM events e;
CREATE TABLE archived_events (id INT PRIMARY KEY, archived_time TIMESTAMP(6));
INSERT INTO archived_events SELECT id, event_time FROM events WHERE event_time < '2023-10-16 14:31:00.000000';
SELECT e.id, a.archived_time FROM events e LEFT JOIN archived_events a ON e.id = a.id WHERE e.event_time > '2023-10-16 14:31:00.000000' ORDER BY e.event_time DESC;