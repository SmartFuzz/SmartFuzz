CREATE TABLE test_times (id INT, time_value TIMETZ);
INSERT INTO test_times VALUES (1, timetz '00:00:00+00:00'), (2, timetz '12:30:00+00:00'), (3, timetz '23:59:59+00:00');
SELECT id, hour(time_value) FROM test_times WHERE hour(time_value) BETWEEN 0 AND 23;
SELECT hour(t1.time_value) FROM test_times t1 JOIN test_times t2 ON hour(t1.time_value) = hour(t2.time_value) WHERE t1.id != t2.id;
CREATE TABLE timestamps (id INT, timestamp_value TIMESTAMP);
INSERT INTO timestamps VALUES (1, timestamp '2023-10-01 00:00:00'), (2, timestamp '2023-10-01 15:00:00'), (3, timestamp '2023-10-01 23:30:00');
SELECT id, hour(timestamp_value) FROM timestamps WHERE timestamp_value > timestamp '2023-10-01 12:00:00';
CREATE TABLE times_with_intervals (id INT, intvl_value INTERVAL SECOND);
INSERT INTO times_with_intervals VALUES (1, interval '0 seconds'), (2, interval '3661 seconds'), (3, interval '86399 seconds');
SELECT id, hour(intvl_value) FROM times_with_intervals WHERE hour(intvl_value) BETWEEN 0 AND 23;
CREATE TABLE complex_query (id INT, ts TIMESTAMP, associated_times TIMETZ);
INSERT INTO complex_query VALUES (1, timestamp '2023-01-01 12:00:00', timetz '14:00:00+02:00'), (2, timestamp '2023-01-01 03:00:00', timetz '01:00:00+00:00');
SELECT id, hour(ts) AS hour_ts, hour(associated_times) AS hour_associated FROM complex_query WHERE hour(ts) < 6;
SELECT hour(ti1.time_value) FROM test_times ti1 WHERE EXISTS (SELECT 1 FROM test_times ti2 WHERE hour(ti1.time_value) = hour(ti2.time_value) AND ti1.id != ti2.id);
SELECT hour(ti.time_value) AS hour_value FROM (SELECT id, time_value FROM test_times UNION SELECT id, time_value FROM timestamps) AS ti WHERE hour_value IS NOT NULL;