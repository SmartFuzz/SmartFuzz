CREATE TABLE test_dates (id SERIAL PRIMARY KEY, ts1 TIMESTAMPTZ, ts2 TIMESTAMPTZ);
INSERT INTO test_dates (ts1, ts2) VALUES (timestamp '2021-12-31 18:40:40', timestamp '2024-02-20 16:30:20');
SELECT id, timestampdiff_year(ts1, ts2) AS year_diff FROM test_dates WHERE ts1 > ts2;
SELECT id, ts1, ts2 FROM test_dates WHERE timestampdiff_year(ts1, ts2) > 2;
CREATE TABLE test_ips (id SERIAL PRIMARY KEY, ip_address INET);
INSERT INTO test_ips (ip_address) VALUES (inet '192.168.1.5'), (inet '192.168.1.4');
SELECT id FROM test_ips WHERE ip_address > (SELECT ip_address FROM test_ips WHERE id = 1);
SELECT id, COUNT(*) FROM test_dates GROUP BY (CASE WHEN ts1 IS NULL THEN 0 ELSE 1 END), timestampdiff_year(ts1, ts2) HAVING COUNT(*) > 0;
SELECT id, timestampdiff_year(ts1, ts2) AS year_diff FROM test_dates WHERE year_diff < (SELECT MAX(timestampdiff_year(ts1, ts2)) FROM test_dates);
CREATE TEMPORARY TABLE temp_dates AS SELECT ts1, ts2 FROM test_dates WHERE ts1 IS NOT NULL AND ts2 IS NOT NULL;
SELECT COUNT(*) FROM temp_dates WHERE timestampdiff_year(ts1, ts2) = (SELECT MAX(timestampdiff_year(ts1, ts2)) FROM temp_dates);