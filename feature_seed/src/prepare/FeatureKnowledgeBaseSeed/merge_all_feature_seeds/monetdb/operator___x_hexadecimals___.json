CREATE TABLE test_hex_conversion (id INT PRIMARY KEY, hex_value VARCHAR(8));
INSERT INTO test_hex_conversion VALUES (1, 'abcd');
INSERT INTO test_hex_conversion VALUES (2, '1234');
INSERT INTO test_hex_conversion VALUES (3, 'deadbeef');
INSERT INTO test_hex_conversion VALUES (4, '0');
INSERT INTO test_hex_conversion VALUES (5, 'ffffffff');
SELECT hex_value, CAST(hex_value AS BLOB) AS binary_value FROM test_hex_conversion;
SELECT id, CAST(CONCAT('x''', hex_value, '''') AS BLOB) AS binary_value FROM test_hex_conversion WHERE id < 4;
SELECT MAX(CAST(hex_value AS BLOB)) FROM test_hex_conversion;
SELECT t.id, CAST(t.hex_value AS BLOB) FROM test_hex_conversion t JOIN (SELECT id FROM test_hex_conversion WHERE id > 2) sub ON t.id = sub.id;
SELECT COUNT(*) FROM test_hex_conversion WHERE CAST(hex_value AS BLOB) IS NOT NULL;
CREATE TABLE another_table (id INT, data BLOB);
INSERT INTO another_table SELECT id, CAST(hex_value AS BLOB) FROM test_hex_conversion;
SELECT a.id, a.data FROM another_table a JOIN test_hex_conversion b ON a.id = b.id WHERE b.hex_value = 'abcd';
SELECT b.hex_value, CAST(b.hex_value AS BLOB) AS binary_value FROM test_hex_conversion b WHERE LEN(b.hex_value) = 8;
SELECT DISTINCT CAST(CASE WHEN hex_value IS NULL THEN 'x''00''' ELSE CONCAT('x''', hex_value, '''') END AS BLOB) FROM test_hex_conversion;