CREATE TABLE dates_test (id INT PRIMARY KEY, event_date DATE);
INSERT INTO dates_test VALUES (1, '2023-01-01');
INSERT INTO dates_test VALUES (2, '2023-02-28');
INSERT INTO dates_test VALUES (3, '2023-12-31');
INSERT INTO dates_test VALUES (4, '2024-02-29');
SELECT * FROM dates_test WHERE event_date BETWEEN '2023-01-01' AND '2023-12-31';
SELECT COUNT(*) FROM dates_test WHERE event_date IS NOT NULL;
SELECT event_date FROM dates_test WHERE event_date = (SELECT MAX(event_date) FROM dates_test);
CREATE TABLE event_details (event_id INT, description VARCHAR(255), FOREIGN KEY (event_id) REFERENCES dates_test(id));
INSERT INTO event_details VALUES (1, 'New Year Celebration');
INSERT INTO event_details VALUES (2, 'End of February Events');
SELECT ed.description, dt.event_date FROM event_details ed JOIN dates_test dt ON ed.event_id = dt.id WHERE dt.event_date < '2024-01-01';
SELECT event_date, COUNT(*) AS event_count FROM dates_test GROUP BY event_date HAVING event_date > '2023-01-01' ORDER BY event_date;
SELECT event_date FROM dates_test WHERE event_date NOT IN (SELECT event_date FROM event_details);
SELECT MAX(event_date) FROM dates_test WHERE event_date <= '2023-12-31';
SELECT event_date FROM dates_test WHERE (event_date >= '2023-01-01' AND event_date <= '2023-01-31') OR (event_date >= '2023-12-01' AND event_date <= '2023-12-31');