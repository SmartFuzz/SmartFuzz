CREATE TABLE test_table (id INT, name VARCHAR(100));
INSERT INTO test_table VALUES (1, '    John Doe');
INSERT INTO test_table VALUES (2, '   Jane Smith   ');
INSERT INTO test_table VALUES (3, '    Bob   ');
SELECT ltrim(name) FROM test_table WHERE id = 1;
SELECT ltrim(name) AS trimmed_name FROM test_table WHERE id = 2;
SELECT ltrim(name) FROM test_table WHERE name LIKE '   %';
SELECT id, ltrim(name) FROM test_table WHERE name IS NOT NULL;
CREATE TABLE other_table (id INT, description VARCHAR(150));
INSERT INTO other_table VALUES (1, '   Sample description ');
SELECT a.id, ltrim(a.name), b.description FROM test_table a JOIN other_table b ON a.id = b.id;
SELECT ltrim(name || ' - additional data') FROM test_table;
SELECT ltrim((SELECT name FROM test_table WHERE id = 1) || ' is a user') AS user_description;
SELECT ltrim(name) FROM (SELECT name FROM test_table WHERE id IN (1, 2)) AS subquery;
SELECT count(*) FROM test_table WHERE ltrim(name) = 'John Doe';
SELECT * FROM test_table WHERE ltrim(name) LIKE 'J%' AND id > 0;