CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100), value INT);
INSERT INTO test_table (id, name, value) VALUES (1, E'John\t', 10), (2, E'Mary  \n\t', 20), (3, E'   David   ', 15);
SELECT id, rtrim(name), value % 10 AS remainder FROM test_table WHERE value > (SELECT AVG(value) FROM test_table);
SELECT id, rtrim(name), value FROM test_table WHERE (SELECT COUNT(*) FROM test_table AS t2 WHERE t2.value > test_table.value) % 2 = 0;
CREATE TABLE join_table (name VARCHAR(100), amount NUMERIC(10, 2));
INSERT INTO join_table (name, amount) VALUES (E'Item1\t', 99.99), (E'Item2\n', 50.50), (E'   Item3   ', NULL);
SELECT t1.id, rtrim(t1.name), COALESCE(t2.amount, 0) AS adjusted_amount FROM test_table AS t1 LEFT JOIN join_table AS t2 ON rtrim(t1.name) = rtrim(t2.name);
SELECT id, rtrim(name) AS trimmed_name, COUNT(value) OVER (PARTITION BY value % 2) AS value_count FROM test_table WHERE rtrim(name) IS NOT NULL;
SELECT COUNT(*) FROM test_table WHERE value % 3 = 0 HAVING rtrim(E'Some Text\t\n') IS NOT NULL;
SELECT id, (rtrim(name) || ' - ' || CAST(value AS VARCHAR)) AS result FROM test_table WHERE (value % 7) = 0;
SELECT rtrim(name) AS trimmed_name FROM test_table WHERE rtrim(name) LIKE E'John\t%' AND (SELECT MAX(value) FROM test_table) > 5;