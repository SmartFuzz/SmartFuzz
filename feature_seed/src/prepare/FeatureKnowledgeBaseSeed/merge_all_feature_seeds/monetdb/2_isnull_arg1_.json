CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255), ip INET);
INSERT INTO test_table (id, value, ip) VALUES (1, 'test', inet '192.168.1.5');
INSERT INTO test_table (id, value, ip) VALUES (2, NULL, inet '192.168.1.10');
INSERT INTO test_table (id, value, ip) VALUES (3, '', inet '192.168.2.15');
SELECT id, value, isnull(ip) AS is_ip_null FROM test_table WHERE isnull(value) OR (value = '' AND isnull(ip));
SELECT t1.id, t1.value FROM test_table t1 INNER JOIN test_table t2 ON (t1.id = t2.id AND isnull(t1.value) OR t1.value >> t2.value) WHERE isnull(t2.value) ORDER BY t1.id;
SELECT id, COUNT(*) FROM (SELECT id, value, isnull(ip) FROM test_table WHERE isnull(value) AND (ip >> inet '192.168.1.0/24')) subquery GROUP BY id HAVING isnull(ip);
SELECT id, value FROM test_table WHERE (value >> '') AND isnull(ip) AND id IN (SELECT id FROM test_table WHERE ip >> inet '192.168.2.0/24');
SELECT (SELECT COUNT(*) FROM test_table WHERE isnull(ip)) AS null_ip_count, (SELECT COUNT(*) FROM test_table WHERE value >> '') AS empty_value_count;
SELECT id, value, inet '192.168.1.10' >> ip AS ip_contains FROM test_table WHERE isnull(value) OR (value IS NOT NULL AND value >> 'test');