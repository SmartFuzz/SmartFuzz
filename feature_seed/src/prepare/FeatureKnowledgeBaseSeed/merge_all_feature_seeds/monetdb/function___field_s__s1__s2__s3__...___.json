CREATE TABLE test_fields (id INT, name VARCHAR(50));
INSERT INTO test_fields VALUES (1, 'foo'), (2, 'bar'), (3, 'baz'), (4, 'qux');
SELECT field('foo', 'bar', 'foo', 'baz') AS index_found;
SELECT field('quux', 'bar', 'foo', 'baz', 'qux') AS index_not_found;
SELECT field(name, 'foo', 'bar', 'baz', 'qux') FROM test_fields WHERE id = 1;
SELECT field(name, 'foo', 'foo', 'foo', 'foo') FROM test_fields WHERE id = 1;
SELECT field('baz', name) FROM test_fields WHERE name IN ('baz', 'bar');
SELECT id, field(name, 'foo', 'baz', 'qux') FROM test_fields WHERE id > 2;
CREATE TABLE another_table (key_id INT, description VARCHAR(100));
INSERT INTO another_table VALUES (1, 'related to foo'), (2, 'not related');
SELECT a.key_id, field(b.name, 'foo', 'bar', 'baz') FROM test_fields AS b JOIN another_table AS a ON a.key_id = b.id;
SELECT field('bar', (SELECT name FROM test_fields WHERE id = 2)) AS index_in_subquery;
SELECT field((SELECT name FROM test_fields WHERE id = 3), 'foo', 'baz') AS index_in_subquery_from_table;