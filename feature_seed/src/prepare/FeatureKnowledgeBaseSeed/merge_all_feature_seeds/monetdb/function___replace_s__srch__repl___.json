CREATE TABLE test_strings (id INTEGER PRIMARY KEY, original_string VARCHAR(255));
INSERT INTO test_strings (id, original_string) VALUES (1, 'abc'), (2, 'def'), (3, 'abcabcabc');
SELECT replace(original_string, 'b', 'X') AS modified_string FROM test_strings;
SELECT replace(replace(original_string, 'b', 'X'), 'a', 'Y') AS double_replacement FROM test_strings;
SELECT id, replace(original_string, 'abc', 'xyz') AS modified_string FROM test_strings WHERE id = 3;
CREATE TABLE additional_strings (id INTEGER PRIMARY KEY, extra_string VARCHAR(255));
INSERT INTO additional_strings (id, extra_string) VALUES (1, 'Hello World'), (2, 'Hello Everyone');
SELECT ts.id, replace(ts.original_string, 'abc', 'xyz') AS replaced_string, replace(as.extra_string, 'Hello', 'Hi') AS modified_extra FROM test_strings ts JOIN additional_strings as ON ts.id = as.id;
SELECT replace(original_string, 'X', 'Y') FROM test_strings WHERE original_string LIKE '%X%';
SELECT replace(original_string, 'missing', 'present') AS non_existent_replacement FROM test_strings;
SELECT REPLACE(REPLACE(original_string, 'a', 'A'), 'c', 'C') AS complex_replacement FROM test_strings WHERE original_string LIKE '%a%';