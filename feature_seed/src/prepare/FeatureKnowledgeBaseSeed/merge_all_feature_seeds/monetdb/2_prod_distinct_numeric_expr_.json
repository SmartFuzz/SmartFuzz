CREATE TABLE test_table (id INT PRIMARY KEY, value DOUBLE, created_at TIMESTAMP(6));
INSERT INTO test_table VALUES (1, 1.5, timestamp(6) '2020-01-01 00:00:00.000000'), (2, 2.0, timestamp(6) '2020-01-02 00:00:00.000000'), (3, NULL, timestamp(6) '2020-01-03 00:00:00.000000'), (4, 3.5, timestamp(6) '2020-01-03 00:00:00.000000');
SELECT prod(distinct value + 1) AS product FROM test_table WHERE created_at > timestamp(6) '2019-12-31 23:59:59.999999';
CREATE TABLE another_table (id INT PRIMARY KEY, ref_id INT, amount BIGINT, updated_at TIMESTAMP(6));
INSERT INTO another_table VALUES (1, 1, 100, timestamp(6) '2020-01-01 12:00:00.000000'), (2, 1, 200, NULL), (3, 2, NULL, timestamp(6) '2020-01-02 12:00:00.000000');
SELECT a.id, prod(distinct a.amount) AS total_amount FROM another_table a JOIN test_table t ON a.ref_id = t.id WHERE t.created_at IS NOT NULL GROUP BY a.id HAVING total_amount > 0;
SELECT t.id, timestamp(6) '2020-01-01 00:00:00.000000' + INTERVAL '1 day' * a.amount AS new_date FROM another_table a JOIN test_table t ON a.ref_id = t.id WHERE a.amount IS NOT NULL;
SELECT timestamp(6) '2020-01-01 00:00:00.000000' + INTERVAL '1 day' * (SELECT COUNT(*) FROM another_table WHERE amount IS NOT NULL) AS advanced_date;
SELECT prod(distinct timestamp(6) '2023-01-01 00:00:00.000000' + (SELECT COALESCE(SUM(a.amount), 0) FROM another_table a WHERE a.ref_id IS NOT NULL)) AS total_time;