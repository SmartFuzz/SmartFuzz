CREATE TABLE test_table (id INT PRIMARY KEY, json_data JSON, time_data TIME(3) WITH TIME ZONE);
INSERT INTO test_table (id, json_data, time_data) VALUES (1, json '{"n":4}', time(3) with time zone '18:40:05.123+02:00');
INSERT INTO test_table (id, json_data, time_data) VALUES (2, json '{"a":null}', time(3) with time zone '00:00:00.000+00:00');
INSERT INTO test_table (id, json_data, time_data) VALUES (3, json '{"x":"test"}', time(3) with time zone '23:59:59.999+05:30');
SELECT id, json.isobject(json_data) AS is_object_check, time_data FROM test_table WHERE time_data > time(3) with time zone '10:00:00.000+00:00' AND json.isobject(json_data) = TRUE;
SELECT id, json_data, time_data FROM test_table WHERE json.isobject(json_data) IS NULL OR json.isobject(json_data);
SELECT id, time_data FROM test_table WHERE json.isobject(json_data) AND time_data < time(3) with time zone '12:00:00.000+02:00' ORDER BY time_data ASC;
SELECT id, json.isobject(json_data) AS is_object_check FROM test_table WHERE time_data = (SELECT MAX(time_data) FROM test_table WHERE json.isobject(json_data));
SELECT id, json_data FROM test_table t1 JOIN (SELECT id, time_data FROM test_table WHERE json.isobject(json_data)) t2 ON t1.id = t2.id HAVING json.isobject(t1.json_data) = TRUE;
CREATE TEMPORARY TABLE temp_table AS SELECT id, json_data, time_data FROM test_table WHERE json.isobject(json_data) AND time_data IS NOT NULL;
SELECT DISTINCT id, json_data FROM temp_table WHERE json.isobject(json_data) AND time_data > time(3) with time zone '00:00:00.001+00:00' ORDER BY id;
DROP TABLE temp_table;