CREATE TABLE voyages (id INT PRIMARY KEY, departure_time TIMESTAMP);
INSERT INTO voyages VALUES (1, TIMESTAMP '2023-10-01 10:00:00');
INSERT INTO voyages VALUES (2, TIMESTAMP '2023-10-01 12:00:00');
INSERT INTO voyages VALUES (3, TIMESTAMP '2023-09-30 15:30:00');
INSERT INTO voyages VALUES (4, TIMESTAMP '2023-10-02 08:45:00');
SELECT * FROM voyages WHERE departure_time = TIMESTAMP '2023-10-01 12:00:00';
SELECT * FROM voyages WHERE departure_time < TIMESTAMP '2023-10-01 12:00:00';
SELECT * FROM voyages WHERE departure_time > TIMESTAMP '2023-10-01 10:00:00';
SELECT * FROM voyages WHERE departure_time BETWEEN TIMESTAMP '2023-10-01 08:00:00' AND TIMESTAMP '2023-10-01 18:00:00';
SELECT COUNT(*) FROM voyages WHERE departure_time IS NOT NULL;
CREATE TABLE voyage_details (voyage_id INT, destination VARCHAR(100), FOREIGN KEY (voyage_id) REFERENCES voyages(id));
INSERT INTO voyage_details VALUES (1, 'New York');
INSERT INTO voyage_details VALUES (2, 'Los Angeles');
INSERT INTO voyage_details VALUES (3, 'Miami');
SELECT v.id, v.departure_time, d.destination FROM voyages v JOIN voyage_details d ON v.id = d.voyage_id WHERE v.departure_time < TIMESTAMP '2023-10-01 12:00:00';
SELECT v.id, v.departure_time FROM voyages v WHERE DATE(v.departure_time) = '2023-10-01';
SELECT * FROM voyages WHERE departure_time IN (SELECT departure_time FROM voyages WHERE id IN (1, 2));
SELECT v.id, v.departure_time FROM voyages v WHERE YEAR(v.departure_time) = 2023 AND MONTH(v.departure_time) = 10;
UPDATE voyages SET departure_time = departure_time + INTERVAL '1 hour' WHERE id = 4;
DELETE FROM voyages WHERE departure_time < TIMESTAMP '2023-09-30 00:00:00';