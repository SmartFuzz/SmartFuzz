CREATE TABLE angles (value FLOAT);
INSERT INTO angles VALUES (0.0), (0.54), (1.0), (-1.0), (2.0), (3.0), (0.5);
SELECT acos(value) FROM angles;
SELECT value, acos(value) AS arc_cosine FROM angles WHERE value BETWEEN -1 AND 1;
SELECT DISTINCT a.value, acos(a.value) FROM angles a JOIN angles b ON a.value <= b.value;
SELECT a.value, acos(a.value) + acos(b.value) AS combined_acos FROM angles a, angles b WHERE a.value > 0.5 AND b.value < 0.5;
SELECT a.value, (SELECT acos(b.value) FROM angles b WHERE b.value = a.value) AS nested_acos FROM angles a;
SELECT a.value, acos(a.value) AS arc_cosine FROM angles a WHERE a.value IN (SELECT b.value FROM angles b WHERE b.value > 0.2);
SELECT AVG(acos(value)) FROM angles WHERE value IS NOT NULL;
CREATE TABLE trig_results AS SELECT value, acos(value) AS arc_cosine FROM angles;