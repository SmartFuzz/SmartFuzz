CREATE TABLE test_log (value FLOAT);
INSERT INTO test_log VALUES (0.1), (1.0), (2.0), (10.0), (100.0), (-1.0), (NULL);
SELECT log(value) FROM test_log;
SELECT log(x) FROM (SELECT value as x FROM test_log WHERE value > 0) as filtered_values;
SELECT t.value, log(t.value) FROM test_log t JOIN (SELECT * FROM test_log WHERE value > 0) as positive_values ON t.value = positive_values.value;
SELECT log(2.0 + (SELECT MAX(value) FROM test_log WHERE value > 0)) AS log_result;
SELECT CASE WHEN value IS NULL THEN NULL ELSE log(value) END as safe_log FROM test_log;
CREATE TABLE additional_log_test (num FLOAT, category VARCHAR(20));
INSERT INTO additional_log_test VALUES (0.5, 'low'), (5.0, 'medium'), (50.0, 'high');
SELECT a.category, log(a.num) FROM additional_log_test a WHERE a.num > 0;
WITH recursive log_values AS (SELECT value, log(value) FROM test_log WHERE value > 0 UNION ALL SELECT value, log(value) FROM log_values WHERE value > 1) SELECT * FROM log_values;
SELECT COUNT(*), AVG(log(value)) FROM test_log WHERE value > 0;