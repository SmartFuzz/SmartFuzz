CREATE TABLE test_bitwise (a INT, b INT);
INSERT INTO test_bitwise VALUES (32, 3);
INSERT INTO test_bitwise VALUES (0, 0);
INSERT INTO test_bitwise VALUES (INT_MAX, INT_MAX);
INSERT INTO test_bitwise VALUES (0, INT_MAX);
INSERT INTO test_bitwise VALUES (1, 1);
INSERT INTO test_bitwise VALUES (-1, -1);
SELECT bit_or(a, b) FROM test_bitwise;
SELECT a, b, bit_or(a, b) AS result FROM test_bitwise WHERE a > 0;
SELECT SUM(bit_or(a, b)) FROM test_bitwise;
SELECT bit_or(a, b) FROM (SELECT a, b FROM test_bitwise WHERE a < 10) AS subquery;
SELECT t1.a, t2.b, bit_or(t1.a, t2.b) AS or_result FROM test_bitwise t1 JOIN test_bitwise t2 ON t1.a != t2.a;
CREATE TABLE additional_data (c INT, d INT, e INT);
INSERT INTO additional_data VALUES (5, 10, 15);
SELECT bit_or(t1.a, ad.c) FROM test_bitwise t1 JOIN additional_data ad ON t1.a = ad.e WHERE ad.d < 20;
SELECT bit_or(a, 3) FROM test_bitwise WHERE a IS NOT NULL;
CREATE TABLE edge_cases (x INT, y INT);
INSERT INTO edge_cases VALUES (-1, 2);
INSERT INTO edge_cases VALUES (255, 255);
SELECT bit_or(x, y) FROM edge_cases;