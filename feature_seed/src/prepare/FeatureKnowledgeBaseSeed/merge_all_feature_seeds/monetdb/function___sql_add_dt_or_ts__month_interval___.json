CREATE TABLE test_dates (id INT, dt DATE);
INSERT INTO test_dates VALUES (1, date '2021-12-31');
INSERT INTO test_dates VALUES (2, date '2022-01-31');
INSERT INTO test_dates VALUES (3, date '2022-02-28');
SELECT sql_add(dt, interval '1' month) FROM test_dates;
SELECT sql_add(dt, interval '0' month) FROM test_dates;
SELECT sql_add(dt, interval '-1' month) FROM test_dates;
SELECT sql_add(dt, interval '12' month) FROM test_dates;
SELECT sql_add(dt, interval '1' month) AS new_date, id FROM test_dates WHERE id = 1;
SELECT id, sql_add(dt, interval '2' month) AS new_date FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE dt < date '2022-02-01');
CREATE TABLE additional_dates (id INT, dt TIMESTAMP);
INSERT INTO additional_dates VALUES (1, timestamp '2021-12-31 10:00:00');
INSERT INTO additional_dates VALUES (2, timestamp '2022-01-01 15:30:00');
SELECT sql_add(dt, interval '3' month) FROM additional_dates;
SELECT id, sql_add(dt, interval '-6' month) AS adjusted_date FROM additional_dates;
CREATE VIEW adjusted_dates AS SELECT id, sql_add(dt, interval '5' month) AS future_date FROM additional_dates;
SELECT * FROM adjusted_dates WHERE future_date > timestamp '2022-06-01 00:00:00';
CREATE TABLE complex_join (id INT, start_date DATE, end_date DATE);
INSERT INTO complex_join VALUES (1, date '2021-01-01', date '2021-12-31');
INSERT INTO complex_join VALUES (2, date '2022-01-01', date '2022-12-31');
SELECT c.id, c.start_date, c.end_date, sql_add(c.start_date, interval '3' month) AS new_start_date FROM complex_join c JOIN test_dates td ON c.start_date = td.dt;