CREATE TABLE test_trim (input_string VARCHAR(255), trim_string VARCHAR(255));
INSERT INTO test_trim VALUES ('abcdeabc', 'a'), ('aaabc', 'a'), ('aabbaaa', 'a'), ('trimtest', 't'), (' test ', ' '), ('', ' ');
SELECT input_string, trim_string, trim(input_string, trim_string) AS trimmed_result FROM test_trim;
SELECT trim(input_string, ' ') FROM test_trim WHERE input_string IS NOT NULL;
SELECT input_string, trim(trim(input_string, trim_string), ' ') AS final_trimmed FROM test_trim;
SELECT t1.input_string, trim(t2.trim_string, ' ') FROM test_trim AS t1 JOIN test_trim AS t2 ON t1.input_string <> t2.input_string;
WITH trimmed AS (SELECT input_string, trim(input_string, 'a') AS trimmed_a FROM test_trim) SELECT DISTINCT trimmed_a FROM trimmed WHERE trimmed_a <> '';
SELECT COUNT(*) FROM test_trim WHERE input_string = trim(input_string, ' ');
SELECT CASE WHEN trim(input_string, 'x') = '' THEN 'empty' ELSE trim(input_string, 'x') END AS trim_case FROM test_trim;
SELECT trim(trim(input_string, 'a'), 'b') AS double_trimmed FROM test_trim WHERE input_string LIKE '%a%' OR input_string LIKE '%b%;