CREATE TABLE sales (id INTEGER, amount DECIMAL(10, 2));
INSERT INTO sales VALUES (1, 100.50), (2, 200.75), (3, NULL), (4, 150.25);
SELECT SUM(amount) FROM sales;
CREATE TABLE transactions (trans_id INTEGER, sales_id INTEGER, value DECIMAL(10, 2));
INSERT INTO transactions VALUES (1, 1, 100.50), (2, 2, 200.75), (3, 1, NULL), (4, 2, 150.00);
SELECT SUM(t.value) FROM transactions t JOIN sales s ON t.sales_id = s.id WHERE s.amount > 50;
SELECT SUM(CAST(NULL AS DECIMAL(10, 2))) AS sum_value;
SELECT SUM(CAST(i AS DECIMAL(10, 2))) FROM generate_series(1, 100) AS i;
SELECT SUM(amount) FROM sales WHERE amount IS NOT NULL;
CREATE TABLE detailed_sales (id INTEGER, amount DECIMAL(10, 2), sale_date DATE);
INSERT INTO detailed_sales VALUES (1, 100.00, '2023-07-01'), (2, NULL, '2023-07-02'), (3, 150.50, '2023-07-03');
SELECT SUM(amount) FROM detailed_sales WHERE sale_date >= '2023-07-01' AND sale_date <= '2023-07-03';
SELECT SUM(s.amount) FROM sales s WHERE s.id IN (SELECT sales_id FROM transactions WHERE value > 100);
CREATE TABLE refunds (refund_id INTEGER, sales_id INTEGER, refund_amount DECIMAL(10, 2));
INSERT INTO refunds VALUES (1, 1, 50.25), (2, 2, NULL);
SELECT SUM(s.amount) - COALESCE(SUM(r.refund_amount), 0) FROM sales s LEFT JOIN refunds r ON s.id = r.sales_id;
SELECT SUM(ROUND(amount, 1)) FROM sales;
SELECT SUM(amount + 25) FROM sales;