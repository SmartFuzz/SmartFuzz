CREATE TABLE numbers_series (num INT);
INSERT INTO numbers_series SELECT generate_series(1, 10, 1);
SELECT * FROM numbers_series;
CREATE TABLE more_numbers (id INT, value INT);
INSERT INTO more_numbers VALUES (1, 5), (2, 15), (3, 25);
SELECT a.num, b.value FROM (SELECT generate_series(1, 5, 1) AS num) a JOIN more_numbers b ON a.num = b.id;
CREATE TABLE range_values (start_val INT, end_val INT);
INSERT INTO range_values VALUES (0, 20), (5, 30);
SELECT generate_series(start_val, end_val, 2) FROM range_values;
SELECT SUM(num) FROM (SELECT generate_series(1, 10, 1) AS num) s;
WITH series AS (SELECT generate_series(1, 100, 10) AS val) SELECT COUNT(val) FROM series WHERE val > 50;
CREATE TABLE conditions (val INT);
INSERT INTO conditions SELECT generate_series(1, 20, 2);
SELECT avg(val) FROM conditions;
SELECT * FROM more_numbers WHERE value IN (SELECT generate_series(10, 30, 5));
INSERT INTO numbers_series SELECT generate_series(100, 110, 1) WHERE NOT EXISTS (SELECT * FROM numbers_series WHERE num = generate_series(100, 110, 1));
SELECT unnest(ARRAY(SELECT generate_series(1, 5, 1) UNION SELECT generate_series(10, 15, 1))) AS combined_series;