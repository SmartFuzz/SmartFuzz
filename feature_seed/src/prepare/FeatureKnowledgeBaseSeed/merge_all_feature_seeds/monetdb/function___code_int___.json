CREATE TABLE test_char_code (id INT PRIMARY KEY, char_code CHAR(1));
INSERT INTO test_char_code VALUES (1, code(65));
INSERT INTO test_char_code VALUES (2, code(90));
INSERT INTO test_char_code VALUES (3, code(255));
INSERT INTO test_char_code VALUES (4, code(0));
INSERT INTO test_char_code VALUES (5, code(127));
SELECT * FROM test_char_code WHERE char_code = code(65);
SELECT * FROM test_char_code WHERE char_code = code(0);
SELECT char_code FROM test_char_code WHERE id IN (SELECT id FROM test_char_code WHERE id < 4);
SELECT (SELECT code(100) FROM test_char_code) AS char_for_code, (SELECT char_code FROM test_char_code LIMIT 1) AS first_char FROM test_char_code;
SELECT ct1.char_code FROM test_char_code ct1 JOIN test_char_code ct2 ON ct1.id != ct2.id WHERE ct1.char_code <> ct2.char_code;
CREATE TABLE additional_codes (value INT);
INSERT INTO additional_codes VALUES (50), (65), (66), (90), (255);
SELECT code(value) FROM additional_codes WHERE value BETWEEN 0 AND 255;
CREATE TABLE char_matches (code_point INT, char_val CHAR(1));
INSERT INTO char_matches SELECT value, code(value) FROM additional_codes;
SELECT * FROM char_matches WHERE char_val IN (SELECT char_code FROM test_char_code);
SELECT char_code FROM test_char_code WHERE id = (SELECT MIN(id) FROM test_char_code) AND char_code = code(65);