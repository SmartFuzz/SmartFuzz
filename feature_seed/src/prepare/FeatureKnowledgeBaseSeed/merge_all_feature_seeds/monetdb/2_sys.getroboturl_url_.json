CREATE TABLE test_urls (id INT PRIMARY KEY, url VARCHAR(255), value INT);
INSERT INTO test_urls (id, url, value) VALUES (1, 'http://example.com/robots.txt', 5), (2, 'http://example.org/robots.txt', 3), (3, 'http://example.net/robots.txt', NULL), (4, '', 0);
SELECT id, sys.getroboturl(url) AS robot_url FROM test_urls WHERE value >= 5;
SELECT id, sys.getroboturl(url) FROM test_urls WHERE url IS NOT NULL AND (value IS NULL OR value >= 2);
SELECT id, COUNT(*) OVER (PARTITION BY sys.getroboturl(url) ORDER BY value) AS cnt_from_partition FROM test_urls WHERE (sys.getroboturl(url) IS NOT NULL) AND (value >= 0);
SELECT id FROM test_urls WHERE EXISTS (SELECT 1 FROM test_urls t2 WHERE t2.value >= (SELECT MAX(value) FROM test_urls) AND sys.getroboturl(t2.url) = sys.getroboturl(test_urls.url));
SELECT t1.id FROM test_urls t1 JOIN test_urls t2 ON t1.value >= t2.value WHERE sys.getroboturl(t1.url) IS NOT NULL ORDER BY t1.id DESC;
SELECT AVG(value) FROM test_urls WHERE sys.getroboturl(url) >= 'http://example.com/robots.txt' HAVING AVG(value) IS NOT NULL;
CREATE TEMPORARY TABLE tmp_urls AS SELECT id, sys.getroboturl(url) AS robot_url FROM test_urls WHERE val IS NOT NULL;
UPDATE test_urls SET value = NULL WHERE id IN (SELECT id FROM test_urls WHERE sys.getroboturl(url) = 'http://example.com/robots.txt') AND value >= 3;
SELECT * FROM test_urls WHERE NULLIF(sys.getroboturl(url), '') >= 'http://example.com/robots.txt' OR value IS NULL;