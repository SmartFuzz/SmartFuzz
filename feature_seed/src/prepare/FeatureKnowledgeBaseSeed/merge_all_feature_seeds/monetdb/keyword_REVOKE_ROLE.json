CREATE TABLE users (user_id INT PRIMARY KEY, user_login_name VARCHAR(255));
CREATE TABLE roles (role_id INT PRIMARY KEY, role_name VARCHAR(255));
CREATE TABLE user_roles (user_id INT, role_id INT, FOREIGN KEY (user_id) REFERENCES users(user_id), FOREIGN KEY (role_id) REFERENCES roles(role_id));
INSERT INTO users (user_id, user_login_name) VALUES (1, 'jan'), (2, 'bob');
INSERT INTO roles (role_id, role_name) VALUES (1, 'controller'), (2, 'admin');
INSERT INTO user_roles (user_id, role_id) VALUES (1, 1), (1, 2), (2, 1);
REVOKE controller FROM jan;
REVOKE admin FROM bob;
REVOKE admin OPTION FOR controller FROM jan;
REVOKE controller, admin FROM jan;
REVOKE role_name FROM (SELECT user_login_name FROM users WHERE user_id = 1);
REVOKE (controller, admin) FROM (SELECT user_login_name FROM users WHERE user_login_name LIKE 'b%');
REVOKE admin FROM (SELECT user_login_name FROM users WHERE user_login_name = (SELECT user_login_name FROM users LIMIT 1));
REVOKE controller FROM (SELECT user_login_name FROM users ORDER BY user_id DESC FETCH FIRST 1 ROW ONLY);