CREATE TABLE decimal_test (id INT, amount DECIMAL(18, 3));
INSERT INTO decimal_test VALUES (1, 12345.678), (2, -12345.678), (3, 0.000), (4, 999999999999999.999);
SELECT * FROM decimal_test WHERE amount >= 0;
SELECT * FROM decimal_test WHERE amount < 0;
SELECT id, amount FROM decimal_test WHERE amount BETWEEN 10000.000 AND 20000.000;
SELECT id, amount * 2.000 FROM decimal_test;
CREATE TABLE currency_rate (source DECIMAL(18, 3), target DECIMAL(18, 3));
INSERT INTO currency_rate VALUES (1.234, 0.843), (0.567, 1.782);
SELECT d.id, d.amount * c.source AS converted FROM decimal_test d JOIN currency_rate c ON c.source = d.amount;
SELECT SUM(amount) AS total_amount FROM decimal_test;
SELECT id, ROUND(amount, 2) AS rounded_amount FROM decimal_test WHERE amount != 0.000;
WITH temp AS (SELECT amount FROM decimal_test WHERE amount IS NOT NULL) SELECT SUM(amount) / COUNT(*) AS average_amount FROM temp;
SELECT d.id, CASE WHEN d.amount > 0 THEN 'Positive' WHEN d.amount < 0 THEN 'Negative' ELSE 'Zero' END AS amount_sign FROM decimal_test d;
SELECT d.id, AVG(d.amount) OVER() AS average_all, COUNT(*) OVER() AS total_count FROM decimal_test d;
DELETE FROM decimal_test WHERE amount < 1000.000;
SELECT * FROM decimal_test WHERE id IN (SELECT id FROM decimal_test WHERE amount > 10000.000);