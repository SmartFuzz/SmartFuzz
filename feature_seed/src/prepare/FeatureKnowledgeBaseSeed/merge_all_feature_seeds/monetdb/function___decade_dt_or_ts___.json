CREATE TABLE test_dates (id INT, dt_column DATE);
INSERT INTO test_dates VALUES (1, DATE '2020-01-01');
INSERT INTO test_dates VALUES (2, DATE '2029-12-31');
INSERT INTO test_dates VALUES (3, DATE '1999-06-15');
INSERT INTO test_dates VALUES (4, DATE '2000-02-29');
INSERT INTO test_dates VALUES (5, DATE '2010-10-10');
INSERT INTO test_dates VALUES (6, DATE '2009-01-05');
SELECT id, decade(dt_column) FROM test_dates WHERE dt_column >= DATE '2000-01-01';
SELECT id, decade(dt_column) AS decade_num FROM (SELECT dt_column FROM test_dates WHERE id > 2) AS subquery;
SELECT t1.id, t1.dt_column, t1.decade FROM (SELECT id, dt_column, decade(dt_column) AS decade FROM test_dates) AS t1 WHERE decade >= 2020;
CREATE TABLE additional_dates (id INT, ts_column TIMESTAMP);
INSERT INTO additional_dates VALUES (1, TIMESTAMP '2021-11-11 10:10:10');
INSERT INTO additional_dates VALUES (2, TIMESTAMP '2022-05-01 15:00:00');
SELECT id, decade(ts_column) FROM additional_dates;
SELECT d.id, d.decade FROM (SELECT id, decade(dt_column) AS decade FROM test_dates) AS d JOIN additional_dates AS a ON d.id = a.id;
SELECT AVG(d.decade) FROM (SELECT decade(dt_column) AS decade FROM test_dates) AS d;
CREATE TABLE complex_dates (id INT, dt_column TIMESTAMP, value INT);
INSERT INTO complex_dates VALUES (1, TIMESTAMP '1985-01-01 00:00:00', 10);
INSERT INTO complex_dates VALUES (2, TIMESTAMP '1995-06-15 12:00:00', 15);
INSERT INTO complex_dates VALUES (3, TIMESTAMP '1975-11-20 18:30:00', 20);
SELECT id, dt_column, decade(dt_column) FROM complex_dates WHERE value > 10;
SELECT COUNT(*) AS count_decade, decade(dt_column) AS decade_num FROM test_dates GROUP BY decade_num;