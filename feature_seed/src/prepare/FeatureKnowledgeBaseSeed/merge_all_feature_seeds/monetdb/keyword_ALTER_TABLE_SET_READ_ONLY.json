CREATE TABLE schema1.table1 (id INT PRIMARY KEY, value VARCHAR(100));
CREATE TABLE schema1.table2 (table1_id INT REFERENCES schema1.table1(id), description VARCHAR(255));
ALTER TABLE schema1.table1 SET READ ONLY;
ALTER TABLE schema1.table2 SET READ ONLY;
SELECT * FROM schema1.table1;
SELECT * FROM schema1.table2;
CREATE TABLE schema2.table3 (id INT PRIMARY KEY, data VARCHAR(200));
INSERT INTO schema2.table3 (id, data) VALUES (1, 'sample data');
ALTER TABLE schema2.table3 SET READ ONLY;
SELECT t1.value, t2.description FROM schema1.table1 t1 JOIN schema1.table2 t2 ON t1.id = t2.table1_id;
SELECT * FROM schema2.table3 WHERE id IN (SELECT table1_id FROM schema1.table2 WHERE description LIKE '%sample%');
ALTER TABLE schema1.table1 SET READ WRITE;
ALTER TABLE schema1.table1 SET INSERT ONLY;
CREATE TABLE IF NOT EXISTS schema1.table4 (id INT PRIMARY KEY, info VARCHAR(150));
INSERT INTO schema1.table4 (id, info) VALUES (1, 'info1'), (2, 'info2');
ALTER TABLE schema1.table4 SET READ ONLY;
SELECT * FROM schema1.table4 WHERE id IN (SELECT id FROM schema1.table4 WHERE info LIKE 'info%');