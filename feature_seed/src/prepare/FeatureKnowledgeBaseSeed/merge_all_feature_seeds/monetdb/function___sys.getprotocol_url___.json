CREATE TABLE urls (id INT, url CLOB);
INSERT INTO urls VALUES (1, 'http://example.com');
INSERT INTO urls VALUES (2, 'https://secure-site.org');
INSERT INTO urls VALUES (3, 'ftp://fileserver.net');
INSERT INTO urls VALUES (4, NULL);
INSERT INTO urls VALUES (5, 'not_a_url');
SELECT sys.getprotocol(url) FROM urls;
SELECT id, sys.getprotocol(url) AS protocol FROM urls WHERE url IS NOT NULL;
SELECT COUNT(*) FROM urls WHERE sys.getprotocol(url) = 'http';
SELECT COUNT(*) FROM urls WHERE sys.getprotocol(url) IN (SELECT DISTINCT sys.getprotocol(url) FROM urls);
SELECT t1.id, t1.url, t2.protocol FROM urls AS t1 JOIN (SELECT id, sys.getprotocol(url) AS protocol FROM urls WHERE url IS NOT NULL) AS t2 ON t1.id = t2.id;
CREATE TABLE url_counts AS SELECT sys.getprotocol(url) AS protocol, COUNT(*) AS count FROM urls GROUP BY protocol;
SELECT * FROM url_counts ORDER BY count DESC;