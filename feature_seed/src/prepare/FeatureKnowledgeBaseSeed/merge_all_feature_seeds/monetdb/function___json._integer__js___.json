CREATE TABLE test_json (data JSON);
INSERT INTO test_json VALUES (json '{"n": 4}');
INSERT INTO test_json VALUES (json '{"n": 3.9}');
INSERT INTO test_json VALUES (json '{"n": 2.5}');
INSERT INTO test_json VALUES (json '{"n": -1}');
INSERT INTO test_json VALUES (json '{"n": null}');
INSERT INTO test_json VALUES (json '[5]');
INSERT INTO test_json VALUES (json '[4, 6]');
INSERT INTO test_json VALUES (json '{"n": {"m": 10}}');
INSERT INTO test_json VALUES (json '{"n": "not_a_number"}');
SELECT json."integer"(data) FROM test_json;
SELECT json."integer"(json '{"a": 15}') AS result FROM test_json WHERE json."integer"(data) IS NOT NULL;
SELECT json."integer"(data) AS result FROM test_json WHERE data IS NOT NULL;
CREATE TABLE multi_test_json (id INT PRIMARY KEY, data JSON);
INSERT INTO multi_test_json (id, data) VALUES (1, json '{"n": 100}');
INSERT INTO multi_test_json (id, data) VALUES (2, json '{"n": 200}');
SELECT id, json."integer"(data) FROM multi_test_json WHERE json."integer"(data) > 150;
SELECT id, (SELECT json."integer"(data) FROM multi_test_json WHERE id = 1) AS integer_value FROM multi_test_json;
SELECT json."integer"(json '{"count": {"n": 50}}') AS subquery_value FROM multi_test_json WHERE json."integer"(data) < 100;