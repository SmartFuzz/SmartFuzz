CREATE TABLE test_strings (id INT, str VARCHAR(255));
INSERT INTO test_strings VALUES (1, E'Hello   '), (2, E'   World'), (3, E'Test\t\n   '), (4, E'   Trailing spaces   ');
SELECT id, rtrim(str) FROM test_strings;
SELECT id, rtrim(str) AS trimmed_str FROM test_strings WHERE rtrim(str) <> str;
SELECT id, rtrim(E'  Example  \t\n   ') AS trimmed_str FROM (SELECT str FROM test_strings) AS subquery;
CREATE TABLE another_table (val VARCHAR(255));
INSERT INTO another_table VALUES (E'  Join example  '), (E'   Fuzz testing   ');
SELECT a.id, rtrim(a.str) AS trimmed_str, rtrim(b.val) AS join_trimmed FROM test_strings a JOIN another_table b ON a.id = 1;
SELECT id, CASE WHEN rtrim(str) = '' THEN 'empty' ELSE rtrim(str) END AS status FROM test_strings;
SELECT COUNT(*) FROM (SELECT DISTINCT rtrim(str) FROM test_strings) AS unique_trimmed;
CREATE VIEW trimmed_view AS SELECT id, rtrim(str) AS trimmed_str FROM test_strings;
SELECT * FROM trimmed_view WHERE trimmed_str LIKE 'Hello';