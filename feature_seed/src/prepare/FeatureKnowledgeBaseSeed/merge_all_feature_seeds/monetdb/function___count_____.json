CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table VALUES (1, NULL), (2, 2), (3, NULL), (4, 4);
SELECT COUNT(*) FROM test_table;
SELECT COUNT(*) FROM test_table WHERE value IS NOT NULL;
SELECT COUNT(*) FROM test_table WHERE value IS NULL;
CREATE TABLE another_table (group_id INT, test_id INT);
INSERT INTO another_table VALUES (1, 1), (1, 2), (2, 3), (2, 4), (2, NULL);
SELECT COUNT(*) FROM another_table GROUP BY group_id;
SELECT group_id, COUNT(*) FROM another_table GROUP BY group_id HAVING COUNT(*) > 1;
SELECT COUNT(*) FROM (SELECT value FROM test_table WHERE value IS NOT NULL) AS subquery;
SELECT COUNT(*) FROM (SELECT COUNT(*) FROM another_table GROUP BY group_id) AS grouped;
SELECT COUNT(*) AS total_count FROM (SELECT id, COUNT(*) FROM test_table GROUP BY id HAVING COUNT(*) > 0) AS inner_query;
CREATE TABLE empty_table (id INT);
SELECT COUNT(*) FROM empty_table;
INSERT INTO empty_table VALUES (1), (2), (3);
SELECT COUNT(*) FROM empty_table;
SELECT COUNT(DISTINCT value) FROM test_table;
SELECT COUNT(*) FROM test_table WHERE id IN (SELECT test_id FROM another_table WHERE group_id = 1);