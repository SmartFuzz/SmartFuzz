CREATE TABLE test_table (id INT, group_id INT, value VARCHAR(100));
INSERT INTO test_table VALUES (1, 1, 'apple');
INSERT INTO test_table VALUES (2, 1, 'banana');
INSERT INTO test_table VALUES (3, 2, 'carrot');
INSERT INTO test_table VALUES (4, 2, 'date');
INSERT INTO test_table VALUES (5, NULL, 'eggfruit');
SELECT listagg(value, ', ') FROM test_table WHERE group_id IS NOT NULL GROUP BY group_id;
SELECT group_id, listagg(value, ', ') FROM test_table GROUP BY group_id ORDER BY group_id;
SELECT listagg(value, '|') FROM (SELECT value FROM test_table WHERE id IN (1, 3, 4)) AS subquery;
CREATE TABLE another_table (group_id INT, description VARCHAR(100));
INSERT INTO another_table VALUES (1, 'fruits'), (2, 'vegetables');
SELECT a.group_id, listagg(t.value, ', ') FROM another_table a INNER JOIN test_table t ON a.group_id = t.group_id GROUP BY a.group_id;
SELECT listagg(DISTINCT value, ', ') FROM test_table WHERE value IS NOT NULL;
SELECT listagg(value, ', ') AS concatenated_values FROM test_table WHERE value LIKE '%a%' AND id < 5;
SELECT outer.id, listagg(inner.value, ', ') FROM test_table AS outer LEFT JOIN (SELECT * FROM test_table WHERE value LIKE 'b%') AS inner ON outer.id = inner.id GROUP BY outer.id;