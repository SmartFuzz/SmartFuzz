CREATE TABLE ProductTarget (ProductID INT PRIMARY KEY, Name VARCHAR(100), ProductNumber VARCHAR(50), Color VARCHAR(30));
CREATE TABLE ProductSource (ProductID INT PRIMARY KEY, Name VARCHAR(100), ProductNumber VARCHAR(50), Color VARCHAR(30));
INSERT INTO ProductSource (ProductID, Name, ProductNumber, Color) VALUES (1, 'Widget', 'WID-001', 'Red');
INSERT INTO ProductSource (ProductID, Name, ProductNumber, Color) VALUES (2, 'Gadget', 'GAD-002', 'Blue');
INSERT INTO ProductTarget (ProductID, Name, ProductNumber, Color) VALUES (2, 'Gadget', 'GAD-002', 'Old-Color');
MERGE INTO ProductTarget T USING ProductSource S ON S.ProductID = T.ProductID WHEN MATCHED THEN UPDATE SET Name = S.Name, ProductNumber = S.ProductNumber, Color = S.Color WHEN NOT MATCHED THEN INSERT (ProductID, Name, ProductNumber, Color) VALUES (S.ProductID, S.Name, S.ProductNumber, S.Color);
CREATE TABLE OrderTarget (OrderID INT PRIMARY KEY, ProductID INT, Quantity INT);
CREATE TABLE OrderSource (OrderID INT PRIMARY KEY, ProductID INT, Quantity INT);
INSERT INTO OrderSource (OrderID, ProductID, Quantity) VALUES (1, 1, 10);
INSERT INTO OrderSource (OrderID, ProductID, Quantity) VALUES (2, 2, 20);
INSERT INTO OrderTarget (OrderID, ProductID, Quantity) VALUES (1, 1, 5);
MERGE INTO OrderTarget O USING OrderSource S ON S.ProductID = O.ProductID WHEN MATCHED THEN UPDATE SET Quantity = O.Quantity + S.Quantity WHEN NOT MATCHED THEN INSERT (OrderID, ProductID, Quantity) VALUES (S.OrderID, S.ProductID, S.Quantity);
WITH CTE AS (SELECT ProductID, COUNT(*) as Total FROM ProductSource GROUP BY ProductID HAVING COUNT(*) > 1) MERGE INTO ProductTarget T USING CTE ON T.ProductID = CTE.ProductID WHEN MATCHED THEN DELETE WHEN NOT MATCHED THEN INSERT (ProductID, Name, ProductNumber, Color) SELECT ProductID, 'NewProduct', 'NP-001', 'NewColor' FROM CTE;
CREATE TABLE InventoryTarget (InventoryID INT PRIMARY KEY, ProductID INT, Stock INT);
CREATE TABLE InventorySource (InventoryID INT PRIMARY KEY, ProductID INT, Stock INT);
INSERT INTO InventorySource (InventoryID, ProductID, Stock) VALUES (1, 1, 100);
INSERT INTO InventorySource (InventoryID, ProductID, Stock) VALUES (2, 2, 150);
INSERT INTO InventoryTarget (InventoryID, ProductID, Stock) VALUES (1, 1, 50);
MERGE INTO InventoryTarget I USING InventorySource S ON S.ProductID = I.ProductID WHEN MATCHED THEN UPDATE SET Stock = I.Stock + S.Stock WHEN NOT MATCHED THEN INSERT (InventoryID, ProductID, Stock) VALUES (S.InventoryID, S.ProductID, S.Stock);