CREATE TABLE timestamps (id INT, ts1 TIMESTAMP, ts2 TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '2021-12-31 18:40:40', TIMESTAMP '2021-02-20 16:30:20');
SELECT timestampdiff_month(ts1, ts2) FROM timestamps;
CREATE TABLE another_table (id INT, ts1 TIMESTAMP, ts2 TIMESTAMP);
INSERT INTO another_table VALUES (1, TIMESTAMP '2022-01-01 00:00:00', TIMESTAMP '2021-12-15 10:30:00');
SELECT a.id, timestampdiff_month(a.ts1, b.ts2) FROM timestamps a JOIN another_table b ON a.id = b.id;
SELECT id, timestampdiff_month(ts1, TIMESTAMP '2023-03-01 12:30:00') AS month_diff FROM timestamps;
SELECT id, timestampdiff_month(ts1, ts2) AS month_diff FROM timestamps WHERE ts1 IS NOT NULL AND ts2 IS NOT NULL;
SELECT id, timestampdiff_month(TIMESTAMP '2021-06-30 12:00:00', TIMESTAMP '2021-06-01 12:00:00') AS diff FROM timestamps;
SELECT id, CASE WHEN timestampdiff_month(ts1, ts2) > 0 THEN 'More Recent' ELSE 'Older or Same Month' END AS date_comparison FROM timestamps;
SELECT timestampdiff_month(MAX(ts1), MIN(ts2)) AS months_difference FROM timestamps;
SELECT COUNT(*) FROM timestamps WHERE timestampdiff_month(ts1, ts2) > 5;
WITH month_diff AS (SELECT id, timestampdiff_month(ts1, ts2) AS diff FROM timestamps) SELECT * FROM month_diff WHERE diff < 0;
SELECT id, timestampdiff_month(ts1, ts2) + 1 AS adjusted_diff FROM timestamps WHERE timestampdiff_month(ts1, ts2) IS NOT NULL;