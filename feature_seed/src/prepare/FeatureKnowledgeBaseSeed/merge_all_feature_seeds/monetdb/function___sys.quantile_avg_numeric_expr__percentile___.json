CREATE TABLE test_data (value DOUBLE);
INSERT INTO test_data VALUES (10.0), (20.0), (30.0), (40.0), (NULL);
SELECT sys.quantile_avg(value, 0.0) FROM test_data;
SELECT sys.quantile_avg(value, 1.0) FROM test_data;
SELECT sys.quantile_avg(value, 0.5) FROM test_data;
CREATE TABLE additional_data (value DOUBLE);
INSERT INTO additional_data VALUES (5.0), (15.0), (25.0), (35.0), (NULL);
SELECT sys.quantile_avg(a.value, 0.6) FROM test_data a JOIN additional_data b ON a.value > b.value;
SELECT sys.quantile_avg((SELECT AVG(value) FROM test_data WHERE value IS NOT NULL), 0.75);
SELECT sys.quantile_avg(value, 0.4) FROM (SELECT value FROM test_data WHERE value IS NOT NULL) AS subquery;
SELECT sys.quantile_avg(value, 0.9) FROM test_data WHERE value > 5.0;
CREATE TABLE complex_data (id INT, group_id INT, value DOUBLE);
INSERT INTO complex_data VALUES (1, 1, 10.0), (2, 1, 20.0), (3, 2, NULL), (4, 2, 30.0), (5, 1, 40.0);
SELECT group_id, sys.quantile_avg(value, 0.3) FROM complex_data GROUP BY group_id;
SELECT sys.quantile_avg(AVG(value), 0.5) FROM complex_data GROUP BY group_id;
SELECT sys.quantile_avg(0.5 * value, 0.2) FROM complex_data WHERE value IS NOT NULL;