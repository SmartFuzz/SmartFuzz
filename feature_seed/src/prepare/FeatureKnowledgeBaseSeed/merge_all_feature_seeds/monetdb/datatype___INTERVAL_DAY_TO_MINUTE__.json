CREATE TABLE intervals (id INT PRIMARY KEY, interval_col INTERVAL DAY TO MINUTE);
INSERT INTO intervals VALUES (1, INTERVAL '1 DAY 1 MINUTE'), (2, INTERVAL '2 DAY 10 MINUTE'), (3, INTERVAL '-1 DAY -30 MINUTE');
SELECT id, interval_col, interval_col + INTERVAL '0 DAY 10 MINUTE' AS modified_interval FROM intervals WHERE interval_col > INTERVAL '1 DAY 0 MINUTE';
SELECT id, interval_col FROM intervals WHERE id IN (SELECT id FROM intervals WHERE interval_col < INTERVAL '2 DAY 0 MINUTE');
CREATE TABLE events (event_id INT PRIMARY KEY, event_time TIMESTAMP, duration INTERVAL DAY TO MINUTE);
INSERT INTO events VALUES (1, '2023-01-01 10:00:00', INTERVAL '1 DAY 5 MINUTE'), (2, '2023-01-02 12:00:00', INTERVAL '2 DAY 20 MINUTE');
SELECT e.event_id, e.event_time + e.duration AS end_time FROM events e WHERE e.duration > INTERVAL '1 DAY 0 MINUTE';
SELECT e.event_id FROM events e JOIN intervals i ON e.duration = i.interval_col WHERE i.id = 2;
SELECT (SELECT SUM(EXTRACT(EPOCH FROM interval_col)) FROM intervals WHERE interval_col IS NOT NULL) / 60 AS total_minutes FROM intervals;
CREATE TABLE time_slots (slot_id INT PRIMARY KEY, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO time_slots VALUES (1, '2023-01-01 09:00:00', '2023-01-01 09:30:00'), (2, '2023-01-01 10:00:00', '2023-01-01 10:30:00');
SELECT ts.slot_id, ts.start_time, ts.end_time, (ts.end_time - ts.start_time) AS duration FROM time_slots ts WHERE (ts.end_time - ts.start_time) > INTERVAL '0 DAY 15 MINUTE';
SELECT id, interval_col FROM intervals ORDER BY interval_col DESC LIMIT 1;
SELECT i.id, e.event_time, e.duration FROM events e JOIN intervals i ON e.duration = i.interval_col WHERE e.event_time BETWEEN '2023-01-01 00:00:00' AND '2023-01-02 23:59:59';