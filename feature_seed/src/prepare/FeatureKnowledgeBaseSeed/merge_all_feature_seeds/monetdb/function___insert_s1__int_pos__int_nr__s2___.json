CREATE TABLE test_strings (s1 STRING);
INSERT INTO test_strings VALUES ('abcdef');
INSERT INTO test_strings VALUES ('1234567890');
INSERT INTO test_strings VALUES ('hello world');
INSERT INTO test_strings VALUES ('goodbye');
INSERT INTO test_strings VALUES ('');
SELECT insert(s1, 2, 1, 'XY') FROM test_strings WHERE s1 = 'abcdef';
SELECT insert(s1, -2, 3, 'XYZ') FROM test_strings WHERE s1 = '1234567890';
SELECT insert(s1, 0, 2, 'Hello') FROM test_strings WHERE s1 = 'goodbye';
SELECT insert(s1, -1, 1, '!') FROM test_strings WHERE s1 = 'hello world';
SELECT insert(s1, 4, 0, '123') FROM test_strings WHERE s1 = 'goodbye';
SELECT insert(s1, 0, 0, 'Start') FROM test_strings WHERE s1 = '';
SELECT insert('abcdef', 2, 1, '') AS result;
SELECT insert(s1, 2, 1, 'XY') AS new_string FROM test_strings WHERE s1 = (SELECT s1 FROM test_strings ORDER BY LENGTH(s1) DESC LIMIT 1);
SELECT insert(s1, -5, 4, 'XX') FROM (SELECT s1 FROM test_strings WHERE s1 LIKE 'hello%') AS subquery;
INSERT INTO test_strings SELECT insert(s1, 1, 2, 'ZZ') FROM test_strings;
SELECT result FROM (SELECT insert('abcdefgh', 3, 2, 'XYZ') AS result) AS subquery;
SELECT insert(s1, -10, 5, 'WOW') FROM test_strings WHERE s1 LIKE 'good%';
SELECT insert(s1, 2, 0, '!!') FROM test_strings WHERE LENGTH(s1) > 5;