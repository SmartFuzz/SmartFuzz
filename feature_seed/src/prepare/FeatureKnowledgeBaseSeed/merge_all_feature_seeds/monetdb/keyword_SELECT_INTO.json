CREATE TABLE test_table (id INT, name VARCHAR(50), age INT);
CREATE TABLE selection_table (value1 INT, value2 INT);
INSERT INTO test_table VALUES (1, 'Alice', 30);
INSERT INTO test_table VALUES (2, 'Bob', 25);
INSERT INTO selection_table VALUES (1, 100), (2, 200);
SELECT id, name INTO variable1, variable2 FROM test_table WHERE age > 28;
SELECT age, value1 INTO age_var, value_var FROM test_table JOIN selection_table ON test_table.id = selection_table.value1 WHERE test_table.age < 35;
SELECT id, MAX(age) INTO out_id, out_max_age FROM test_table GROUP BY id HAVING COUNT(*) > 1;
SELECT name INTO name_var FROM test_table WHERE id IN (SELECT value1 FROM selection_table WHERE value2 > 150);
SELECT a.id, b.name INTO a_id, b_name FROM test_table AS a JOIN test_table AS b ON a.id = b.id WHERE a.age < b.age;
SELECT DISTINCT name INTO name_list FROM test_table WHERE name LIKE 'A%' ORDER BY name ASC LIMIT 5;
SELECT * INTO result_var FROM (SELECT id, name FROM test_table WHERE age BETWEEN 20 AND 30) AS subquery;
SELECT id INTO some_id FROM (SELECT id FROM test_table ORDER BY age DESC LIMIT 1) AS temp;
SELECT a.id, b.value1 INTO id_var, value_var FROM test_table AS a LEFT JOIN selection_table AS b ON a.id = b.value1 WHERE b.value2 IS NOT NULL;
SELECT id INTO final_id FROM (SELECT id, COUNT(*) FROM test_table GROUP BY id HAVING COUNT(*) = 1) AS single_entries;
SELECT a.id, b.name INTO output_id, output_name FROM test_table a INNER JOIN test_table b ON a.age = b.age WHERE a.id != b.id;
SELECT INTO var1, var2 FROM (SELECT age, COUNT(*) FROM test_table GROUP BY age ORDER BY COUNT(*) DESC LIMIT 1) AS common_age;