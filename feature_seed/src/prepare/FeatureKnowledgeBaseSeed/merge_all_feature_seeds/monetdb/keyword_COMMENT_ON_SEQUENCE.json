CREATE SEQUENCE mysch.article_id_seq START WITH 1 INCREMENT BY 1;
COMMENT ON SEQUENCE mysch.article_id_seq IS 'sequence for article id column';
CREATE SEQUENCE mysch.order_id_seq START WITH 1000 INCREMENT BY 10;
COMMENT ON SEQUENCE mysch.order_id_seq IS NULL;
COMMENT ON SEQUENCE mysch.order_id_seq IS '';
COMMENT ON SEQUENCE mysch.non_existing_seq IS 'This comment should fail because the sequence does not exist';
CREATE SEQUENCE mysch.temp_seq MINVALUE 1 MAXVALUE 100;
COMMENT ON SEQUENCE mysch.temp_seq IS 'Temporary sequence for testing';
CREATE TABLE articles (id INT PRIMARY KEY, title VARCHAR(100));
INSERT INTO articles (id, title) VALUES (1, 'First Article');
CREATE TABLE orders (id INT PRIMARY KEY, article_id INT REFERENCES articles(id));
INSERT INTO orders (id, article_id) VALUES (1, 1);
COMMENT ON SEQUENCE mysch.article_id_seq IS (SELECT CONCAT('Current value is', nextval('mysch.article_id_seq')));
CREATE SEQUENCE mysch.test_seq INCREMENT BY 5;
COMMENT ON SEQUENCE mysch.test_seq IS (SELECT title FROM articles WHERE id = 1);
COMMENT ON SEQUENCE mysch.test_seq IS 'A sequence that increments by 5';
DROP SEQUENCE mysch.order_id_seq;
COMMENT ON SEQUENCE mysch.article_id_seq IS 'Updated sequence for article id column';
CREATE SEQUENCE mysch.user_id_seq START WITH 1 INCREMENT BY 1;
COMMENT ON SEQUENCE mysch.user_id_seq IS 'User sequence for tracking users';