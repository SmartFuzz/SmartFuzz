CREATE TABLE test_strings (id INT, str_value VARCHAR(100));
INSERT INTO test_strings VALUES (1, 'MonetDB'), (2, 'Fuzzy Testing'), (3, 'Boundary Values'), (4, NULL), (5, 'TEST');
SELECT lower(str_value) FROM test_strings;
SELECT lower(str_value) FROM test_strings WHERE str_value IS NOT NULL;
SELECT id, lower(str_value) AS lowercase_value FROM test_strings WHERE id IN (1, 3, 5);
SELECT id, lower(str_value) AS lowercase_value FROM test_strings ORDER BY id;
WITH lower_strings AS (SELECT id, lower(str_value) AS lowercase_value FROM test_strings) SELECT * FROM lower_strings WHERE lowercase_value LIKE 'monet%';
SELECT t1.id, lower(t2.str_value) AS lowercase_string FROM test_strings t1 JOIN test_strings t2 ON t1.id <> t2.id;
SELECT id, lower(str_value) AS lowercase_value FROM test_strings WHERE lower(str_value) NOT LIKE 'fuzzy%';
SELECT COUNT(*) AS lowercase_count FROM (SELECT lower(str_value) FROM test_strings WHERE str_value IS NOT NULL) AS lower_counts;