CREATE TABLE test_table (id INT, str_column VARCHAR(100));
INSERT INTO test_table VALUES (1, 'abcde'), (2, 'defgh'), (3, 'abcdefghij'), (4, 'xyzbcxyz'), (5, 'nopqrstuv');
SELECT patindex('%bc%', str_column) FROM test_table;
SELECT id, str_column, patindex('%bc%', str_column) AS position FROM test_table WHERE patindex('%bc%', str_column) > 0;
SELECT t1.id, t2.id, patindex('%bc%', t2.str_column) AS position FROM test_table t1 JOIN test_table t2 ON t1.id != t2.id;
SELECT id, str_column FROM test_table WHERE str_column IS NOT NULL AND patindex('%bc%', str_column) = 0;
SELECT MAX(patindex('%bc%', str_column)) AS last_position FROM test_table;
SELECT id FROM test_table WHERE patindex('%z%', str_column) = 0;
CREATE TABLE another_table (id INT, description VARCHAR(255));
INSERT INTO another_table VALUES (1, 'No match here'), (2, 'Looking for bcd'), (3, 'Ends with bc');
SELECT a.id, a.description, patindex('%bc%', a.description) AS match_position FROM another_table a JOIN test_table b ON patindex('%bc%', b.str_column) > 0;
SELECT t1.id FROM test_table t1 WHERE EXISTS (SELECT 1 FROM another_table t2 WHERE patindex('%bc%', t2.description) > 0 AND t1.id = t2.id);
SELECT str_column FROM test_table WHERE LENGTH(str_column) < 10 AND patindex('%bc%', str_column) > 0;
SELECT str_column FROM test_table WHERE patindex('%def%', str_column) > 0 AND patindex('%bc%', str_column) = 0;