CREATE TABLE test_timestamps (id INT PRIMARY KEY, ts1 TIMESTAMPTZ, ts2 TIMESTAMPTZ);
INSERT INTO test_timestamps (id, ts1, ts2) VALUES (1, timestamp '2021-12-31 18:40:40', timestamp '2021-12-20 16:30:20');
SELECT id, timestampdiff_hour(ts1, ts2) AS hour_diff, (1 << (SELECT COUNT(*) FROM test_timestamps)) AS bit_shifted FROM test_timestamps WHERE timestampdiff_hour(ts1, ts2) IS NOT NULL;
CREATE TABLE test_numbers (val INT);
INSERT INTO test_numbers (val) VALUES (NULL), (0), (100), (1024), (2048);
SELECT (1 << val) AS shifted_value FROM test_numbers WHERE val IS NOT NULL;
SELECT id, timestampdiff_hour(ts1, ts2), (1 << timestampdiff_hour(ts1, ts2)) AS complex_shift FROM test_timestamps WHERE ts1 IS NOT NULL AND ts2 IS NOT NULL;
CREATE TABLE complex_join (key1 INT, key2 INT, ts TIMESTAMPTZ);
INSERT INTO complex_join (key1, key2, ts) VALUES (1, 10, timestamp '2021-12-31 12:00:00'), (2, 20, timestamp '2021-01-01 12:00:00');
SELECT cj.key1, cj.key2, (SELECT COUNT(*) FROM test_timestamps) << 1 AS count_shifted FROM complex_join cj JOIN test_timestamps tt ON (tt.id = cj.key1) WHERE timestampdiff_hour(tt.ts1, tt.ts2) > 0;
CREATE TABLE boundary_test (start_time TIMESTAMPTZ, end_time TIMESTAMPTZ);
INSERT INTO boundary_test (start_time, end_time) VALUES (timestamp '2021-12-31 23:59:59', timestamp '2022-01-01 00:00:00');
SELECT timestampdiff_hour(start_time, end_time) AS diff_hours, (1 << timestampdiff_hour(start_time, end_time)) AS shift_differential FROM boundary_test;
SELECT id, (CASE WHEN timestampdiff_hour(ts1, ts2) IS NULL THEN 0 ELSE timestampdiff_hour(ts1, ts2) END) AS safe_diff FROM test_timestamps;
CREATE TABLE null_test (num INT);
INSERT INTO null_test (num) VALUES (1), (NULL), (2);
SELECT (1 << (SELECT COUNT(*) FROM null_test WHERE num IS NOT NULL)) AS shifted_non_null_first, NULL AS null_value;
SELECT timestampdiff_hour((SELECT MIN(ts1) FROM test_timestamps), (SELECT MAX(ts2) FROM test_timestamps)) AS boundary_hour FROM test_timestamps;
SELECT (SELECT COUNT(*) FROM test_timestamps) * (1 << 2) AS product_shifted FROM test_timestamps HAVING product_shifted > 0;