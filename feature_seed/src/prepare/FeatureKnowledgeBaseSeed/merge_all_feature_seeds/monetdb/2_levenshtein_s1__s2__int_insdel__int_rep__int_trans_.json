CREATE TABLE test_strings (id SERIAL PRIMARY KEY, str1 VARCHAR(100), str2 VARCHAR(100));
INSERT INTO test_strings (str1, str2) VALUES ('MonetDB', 'MonetDBX'), ('abcd', 'dbca'), ('test', 'tset'), (NULL, 'NULL');
SELECT id, levenshtein(str1, url 'https://www.example.com/' || str2, 1, 1, 1) AS edit_distance FROM test_strings WHERE levenshtein(str1, url 'https://www.example.com/' || str2, 1, 1, 1) IS NOT NULL;
SELECT id FROM test_strings a JOIN test_strings b ON a.str1 = url 'https://www.example.com/' || b.str2 WHERE levenshtein(a.str1, b.str2, 1, 1, 1) < 5;
SELECT id, COUNT(*) FROM test_strings GROUP BY levenshtein(str1, str2, 1, 1, 1) HAVING COUNT(*) > 1;
SELECT id, levenshtein(url 'https://www.sample.com/' || str1, 'sample', 2, 1, 1) AS lv_dist FROM test_strings ORDER BY lv_dist DESC;
CREATE TABLE test_complex (id SERIAL PRIMARY KEY, complex_str VARCHAR(255) NOT NULL);
INSERT INTO test_complex (complex_str) VALUES ('https://verylongurl.com/path?query=string&param=value'), ('https://anotherurl.com?empty='), (NULL);
SELECT id FROM test_complex WHERE levenshtein(complex_str, 'short', 3, 2, 1) IS NULL OR complex_str IS NULL;
SELECT str1, REGEXP_REPLACE(url 'https://www.example.com/' || str2, 'query=.*$', '') FROM test_strings;
SELECT id, MIN(levenshtein(str1, str2, 1, 1, 1)) OVER (PARTITION BY id) AS min_distance FROM test_strings;