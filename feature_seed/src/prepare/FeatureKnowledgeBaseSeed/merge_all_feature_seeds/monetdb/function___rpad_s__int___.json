CREATE TABLE test_rpad (input_str VARCHAR(100), length INT);
INSERT INTO test_rpad VALUES ('abc', 6);
INSERT INTO test_rpad VALUES ('abcdefg', 4);
INSERT INTO test_rpad VALUES ('hi', 10);
INSERT INTO test_rpad VALUES ('1234567890', 15);
INSERT INTO test_rpad VALUES ('', 5);
INSERT INTO test_rpad VALUES ('monetdb', 8);
SELECT rpad(input_str, length) AS padded_string FROM test_rpad;
SELECT rpad(input_str, length) || ' - test' AS padded_with_suffix FROM test_rpad;
SELECT rpad(rpad(input_str, length), 12) AS double_padded FROM test_rpad;
SELECT rpad('fuzzy', 10) AS single_fuzzy_pad;
SELECT rpad('test', 2) AS truncated_test;
SELECT rpad(SUBSTRING(input_str FROM 1 FOR 3), length) AS subquery_rpad FROM (SELECT input_str, length FROM test_rpad WHERE length > 4) AS sub;
WITH padded AS (SELECT rpad(input_str, length) AS padded_string FROM test_rpad) SELECT padded_string FROM padded WHERE LENGTH(padded_string) = 6;
SELECT DISTINCT rpad('data', LENGTH(input_str)) AS var_length_padding FROM test_rpad;