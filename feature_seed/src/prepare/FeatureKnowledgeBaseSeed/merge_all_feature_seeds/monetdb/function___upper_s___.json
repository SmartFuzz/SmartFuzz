CREATE TABLE test_upper (id INT, name VARCHAR(100));
INSERT INTO test_upper VALUES (1, 'MonetDB');
INSERT INTO test_upper VALUES (2, 'database');
INSERT INTO test_upper VALUES (3, 'test case');
INSERT INTO test_upper VALUES (4, NULL);
SELECT upper(name) FROM test_upper;
SELECT upper(name) FROM test_upper WHERE id = 1;
SELECT upper(name) FROM test_upper WHERE name IS NOT NULL;
CREATE TABLE another_table (id INT, description VARCHAR(100));
INSERT INTO another_table VALUES (1, 'monetdb is great');
SELECT upper(tu.name), at.description FROM test_upper tu JOIN another_table at ON tu.id = 1;
SELECT upper(CONCAT(name, ' is in uppercase')) FROM test_upper;
SELECT upper(upper(name)) FROM test_upper;
SELECT CASE WHEN name IS NOT NULL THEN upper(name) ELSE 'NULL VALUE' END AS upper_name FROM test_upper;
SELECT upper(subquery.name) FROM (SELECT name FROM test_upper WHERE id > 0) AS subquery;
CREATE TABLE important_names (entry VARCHAR(100));
INSERT INTO important_names VALUES ('Alice'), ('Bob'), ('CHARLIE');
SELECT upper(name) FROM important_names WHERE CHAR_LENGTH(name) <= 4;
SELECT name, upper(name) FROM test_upper WHERE id IN (SELECT id FROM another_table WHERE id = 1);
SELECT upper(name) AS upper_name FROM test_upper ORDER BY upper(name);
SELECT upper(name) AS uppercase_name FROM test_upper WHERE name LIKE 'M%';