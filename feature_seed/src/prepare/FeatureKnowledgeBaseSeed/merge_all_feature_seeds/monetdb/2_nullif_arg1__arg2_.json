CREATE TABLE test_table (id INT, value1 TEXT, value2 TEXT, amount DECIMAL);
INSERT INTO test_table (id, value1, value2, amount) VALUES (1, 'test', 'test', 10.5), (2, 'example', 'sample', 0.0), (3, NULL, 'check', 15.75);
SELECT id, nullif(value1, value2) + amount AS result FROM test_table WHERE nullif(value1, NULL) IS NOT NULL;
SELECT id, amount + nullif(amount, 0) AS adjusted_amount FROM test_table WHERE adjusted_amount > 10;
WITH temp AS (SELECT id, nullif(value1, value2) AS value_check FROM test_table WHERE nullif(value1, '') IS NOT NULL) SELECT COUNT(*) FROM temp WHERE value_check IS NOT NULL;
SELECT t1.id, (t1.amount + nullif(t2.amount, 0)) AS combined_amount FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.id IS NOT NULL;
SELECT id, value1, amount FROM test_table WHERE value1 IS NOT NULL AND nullif(value1, 'example') IS NULL;
CREATE TABLE other_table (trans_id INT, trans_amount DECIMAL);
INSERT INTO other_table (trans_id, trans_amount) VALUES (1, 100.5), (2, NULL);
SELECT ot.trans_id, sum(nullif(t.amount, 0)) + sum(nullif(ot.trans_amount, 0)) AS total FROM test_table t LEFT JOIN other_table ot ON t.id = ot.trans_id GROUP BY ot.trans_id HAVING total > 110;
SELECT id, (CASE WHEN amount < 5 THEN nullif('LOW', 'LOW') ELSE nullif('HIGH', 'MEDIUM') END) + amount AS status FROM test_table WHERE amount IS NOT NULL;