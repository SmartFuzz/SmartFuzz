CREATE TABLE time_test (id SERIAL PRIMARY KEY, start_time TIME NOT NULL, end_time TIME NOT NULL, event_id UUID DEFAULT uuid_generate_v4());
INSERT INTO time_test (start_time, end_time) VALUES (time '08:00:00', time '09:30:00'), (time '10:15:00', time '12:45:00'), (time '14:30:00', time '16:00:00'), (time '16:30:00', time '18:00:00');
SELECT id, sql_sub(start_time, end_time) AS duration, uuid 'e31960fb-dc8b-452d-ab30-b342723e756a' AS event_uuid FROM time_test WHERE sql_sub(start_time, end_time) IS NOT NULL;
CREATE TABLE event_log (event_id UUID PRIMARY KEY, event_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP, user_action TEXT);
INSERT INTO event_log (event_id) VALUES (uuid 'e31960fb-dc8b-452d-ab30-b342723e756a'), (uuid '4523cddf-4bc9-491c-b003-a574b96f5206'), (uuid '3de02c28-e0c3-4ea6-abc9-2258fb78eb59');
SELECT e.event_id, COUNT(t.id) AS total_events FROM event_log e LEFT JOIN time_test t ON e.event_id = t.event_id GROUP BY e.event_id HAVING COUNT(t.id) > 0;
SELECT start_time, end_time, uuid '00000000-0000-0000-0000-000000000000' AS blank_uuid FROM time_test WHERE sql_sub(NOW()::time, end_time) < '00:30:00'::interval;
WITH event_durations AS (SELECT id, sql_sub(start_time, end_time) AS duration, event_id FROM time_test) SELECT AVG(duration) AS avg_duration FROM event_durations WHERE duration > 0;
DROP TABLE IF EXISTS temporary_test;
CREATE TEMPORARY TABLE temporary_test (id SERIAL PRIMARY KEY, temp_time TIME);
INSERT INTO temporary_test VALUES (time '00:00:01'), (time '23:59:59');
SELECT *, sql_sub(temp_time, time '12:00:00') AS time_difference FROM temporary_test WHERE uuid 'fa80aed5-6381-4c48-8c97-11b6b8f089c0' IS NOT NULL;
ALTER TABLE time_test ADD COLUMN extra_time TIME DEFAULT time '00:00:00';
UPDATE time_test SET extra_time = sql_sub(start_time, time '01:00:00') WHERE extra_time IS NULL;