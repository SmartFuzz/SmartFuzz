CREATE TABLE time_zones (id INT PRIMARY KEY, event_time TIMETZ);
INSERT INTO time_zones VALUES (1, timetz '19:30:49'), (2, timetz '23:59:59'), (3, timetz '00:00:00');
SELECT sys.time_to_str(event_time, '%l hour %M:%S %p') FROM time_zones;
SELECT sys.time_to_str(event_time, '%H:%M:%S') FROM time_zones WHERE id = 1;
SELECT sys.time_to_str(event_time, '%Y-%m-%d %l:%M:%S %p') FROM time_zones WHERE id IN (1, 2);
CREATE TABLE formatted_events AS SELECT id, sys.time_to_str(event_time, '%l hour %M:%S %p') AS formatted_time FROM time_zones;
SELECT t.id, fe.formatted_time FROM formatted_events fe JOIN time_zones t ON fe.id = t.id WHERE fe.formatted_time LIKE '%hour%';
SELECT sys.time_to_str(timetz '22:15:30', '%H:%M') AS short_time;
CREATE TABLE events_combined AS SELECT e.id, sys.time_to_str(e.event_time, '%l:%M %p') AS converted_time FROM (SELECT id, event_time FROM time_zones WHERE id = 3 UNION SELECT 4, timetz '06:10:15') e;
SELECT COALESCE(sys.time_to_str(event_time, '%l:%M %p'), 'No Event') FROM time_zones WHERE id = 42;