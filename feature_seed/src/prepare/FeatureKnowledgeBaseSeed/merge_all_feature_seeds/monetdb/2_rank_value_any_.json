CREATE TABLE employees (id int, salary numeric, hire_date date, department_id int);
INSERT INTO employees (id, salary, hire_date, department_id) VALUES (1, 5000.00, '2020-01-15', 1), (2, 6000.50, NULL, 1), (3, NULL, '2023-05-10', 2), (4, 7000.25, '2021-03-22', 2), (5, 4000.75, '2022-08-30', 1);
CREATE TABLE departments (id int, name varchar(255), budget numeric);
INSERT INTO departments (id, name, budget) VALUES (1, 'HR', NULL), (2, 'Engineering', 100000.00);
SELECT d.name, rank(e.salary) OVER (PARTITION BY d.id ORDER BY e.salary) AS salary_rank FROM employees e JOIN departments d ON e.department_id = d.id WHERE e.salary IS NOT NULL AND (e.salary <= 6000 OR d.budget IS NULL);
SELECT e.id, e.salary, COUNT(*) AS higher_salaries FROM employees e JOIN employees other ON e.salary <= other.salary GROUP BY e.id HAVING COUNT(*) > 1;
SELECT d.id, d.name, rank(e.salary) OVER (PARTITION BY d.id ORDER BY e.salary DESC) AS salary_rank FROM departments d LEFT JOIN employees e ON e.department_id = d.id WHERE (e.hire_date IS NOT NULL OR e.salary IS NOT NULL) AND d.budget > 50000.00;
SELECT COUNT(*), MAX(e.salary) FROM employees e JOIN departments d ON e.department_id = d.id WHERE e.salary <= COALESCE(d.budget, 0) GROUP BY d.name HAVING MAX(e.salary) IS NOT NULL;
SELECT id, salary, (rank(salary) OVER (ORDER BY salary) + 1) * 1000 AS proposed_increase FROM employees WHERE salary IS NOT NULL;
SELECT d.name, MIN(e.salary) AS minimum_salary FROM departments d LEFT JOIN employees e ON e.department_id = d.id GROUP BY d.id HAVING MIN(e.salary) IS NOT NULL AND d.budget <= (SELECT MAX(budget) FROM departments);