CREATE TABLE test_urls (url CLOB);
INSERT INTO test_urls VALUES ('http://example.com/path/to/file.txt');
INSERT INTO test_urls VALUES ('https://www.example.org/index.html');
INSERT INTO test_urls VALUES ('ftp://ftp.example.net/docs/manual.pdf');
INSERT INTO test_urls VALUES ('https://example.com/');
INSERT INTO test_urls VALUES (NULL);
SELECT sys.getbasename(url) FROM test_urls;
SELECT sys.getbasename(url) FROM test_urls WHERE url IS NOT NULL;
SELECT url, sys.getbasename(url) AS basename FROM test_urls WHERE sys.getbasename(url) IS NOT NULL;
CREATE TABLE results AS SELECT url, sys.getbasename(url) AS basename FROM test_urls;
SELECT COUNT(*) FROM (SELECT sys.getbasename(url) FROM test_urls) AS subquery;
SELECT url, sys.getbasename(url) FROM test_urls WHERE url LIKE 'http%';
SELECT MAX(LENGTH(sys.getbasename(url))) AS max_length FROM test_urls;
SELECT url, sys.getbasename(url) FROM test_urls WHERE url IN (SELECT url FROM test_urls WHERE url LIKE '%.txt');
SELECT DISTINCT sys.getbasename(url) FROM test_urls WHERE sys.getbasename(url) IS NOT NULL ORDER BY basename;
SELECT COUNT(*) FROM test_urls WHERE sys.getbasename(url) IS NULL;