CREATE TABLE test_strings (id INT PRIMARY KEY, str_col VARCHAR(50));
INSERT INTO test_strings VALUES (1, 'hello');
INSERT INTO test_strings VALUES (2, 'world!');
INSERT INTO test_strings VALUES (3, 'abcde');
SELECT rpad(str_col, 10, '*') FROM test_strings;
SELECT rpad(str_col, 3, 'x') FROM test_strings;
SELECT rpad(str_col, 0, 'z') FROM test_strings;
SELECT rpad(str_col, 5, 'xyz') FROM test_strings;
SELECT rpad('short', 8, 'pad') AS padded_string, id FROM test_strings WHERE id = 1;
SELECT id, rpad(str_col, 15, '-') AS padded FROM test_strings WHERE rpad(str_col, 15, '-') LIKE 'hello-%';
CREATE TABLE more_strings (name VARCHAR(50));
INSERT INTO more_strings VALUES ('aaa'), ('bbbb'), ('ccccc');
SELECT name, rpad(name, 6, 'x') FROM more_strings;
SELECT name, rpad(name, 10, '') FROM more_strings;
SELECT rpad(t1.str_col, 10, 'xyz') FROM test_strings AS t1 JOIN more_strings AS t2 ON LENGTH(t1.str_col) < 5 WHERE t1.id = 3;
SELECT rpad((SELECT str_col FROM test_strings WHERE id = 2), 8, '-') AS from_subquery;
SELECT rpad(CONCAT(str_col, str_col), 12, 'x') FROM test_strings;