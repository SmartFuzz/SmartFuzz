CREATE TABLE test_intervals (id INT PRIMARY KEY, month_interval INTERVAL MONTH);
INSERT INTO test_intervals (id, month_interval) VALUES (1, '2 months'), (2, '3 months'), (3, NULL);
SELECT sum(month_interval) FROM test_intervals;
INSERT INTO test_intervals (id, month_interval) VALUES (4, '5 months');
SELECT sum(month_interval) FROM test_intervals;
INSERT INTO test_intervals (id, month_interval) VALUES (5, '-1 months'), (6, NULL);
SELECT sum(month_interval) FROM test_intervals;
CREATE TABLE test_groups (group_id INT, month_interval INTERVAL MONTH);
INSERT INTO test_groups (group_id, month_interval) VALUES (1, '1 month'), (1, '2 months'), (2, '4 months');
SELECT group_id, sum(month_interval) FROM test_groups GROUP BY group_id;
CREATE TABLE nested_test (id INT, months INTERVAL MONTH);
INSERT INTO nested_test (id, months) VALUES (1, '6 months'), (2, NULL), (3, '3 months');
SELECT (SELECT sum(months) FROM nested_test) AS total_months;
CREATE TABLE another_test (id INT, group_id INT, months INTERVAL MONTH);
INSERT INTO another_test (id, group_id, months) VALUES (1, 1, '7 months'), (2, 1, NULL), (3, 2, '1 month');
SELECT g.group_id, sum(a.months) FROM another_test a JOIN (SELECT DISTINCT group_id FROM another_test) g ON a.group_id = g.group_id GROUP BY g.group_id;
CREATE TABLE complex_test (id INT, group_id INT, month_interval INTERVAL MONTH);
INSERT INTO complex_test (id, group_id, month_interval) VALUES (1, 1, '1 month'), (2, 1, '2 months'), (3, 2, '-1 month'), (4, 2, '3 months');
SELECT sum(month_interval) FROM complex_test WHERE group_id = 1;
SELECT sum(month_interval) AS total FROM (SELECT month_interval FROM complex_test WHERE group_id = 2) AS subquery;