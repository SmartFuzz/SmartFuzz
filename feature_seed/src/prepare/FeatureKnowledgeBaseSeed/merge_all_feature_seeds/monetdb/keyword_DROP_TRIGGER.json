CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100));
CREATE TRIGGER test_trigger BEFORE INSERT ON test_table FOR EACH ROW SET new.name = UPPER(new.name);
DROP TRIGGER IF EXISTS test_trigger;
CREATE TABLE schema1.test_table (id INT PRIMARY KEY, name VARCHAR(100));
CREATE TRIGGER schema1.test_trigger BEFORE UPDATE ON schema1.test_table FOR EACH ROW SET new.name = CONCAT(new.name, ' updated');
DROP TRIGGER IF EXISTS schema1.test_trigger;
CREATE TABLE another_table (id INT PRIMARY KEY, description VARCHAR(100));
CREATE TRIGGER another_trigger AFTER DELETE ON another_table FOR EACH ROW INSERT INTO test_table (id, name) VALUES (old.id, old.description);
DROP TRIGGER IF EXISTS another_trigger;
CREATE TABLE complex_table (id INT PRIMARY KEY, value INT);
CREATE TRIGGER complex_trigger AFTER INSERT ON complex_table FOR EACH ROW UPDATE test_table SET name = CONCAT(name, ' - ', NEW.value) WHERE id = NEW.id;
DROP TRIGGER IF EXISTS complex_trigger;
CREATE SCHEMA test_schema;
CREATE TABLE test_schema.schema_table (id INT PRIMARY KEY, data VARCHAR(255));
CREATE TRIGGER schema_table_trigger BEFORE INSERT ON test_schema.schema_table FOR EACH ROW SET new.data = CONCAT('Data: ', NEW.data);
DROP TRIGGER IF EXISTS schema_table_trigger;