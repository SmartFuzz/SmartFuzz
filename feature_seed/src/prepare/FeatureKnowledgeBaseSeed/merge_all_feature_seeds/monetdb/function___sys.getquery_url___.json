CREATE TABLE urls (id INT PRIMARY KEY, url CLOB);
INSERT INTO urls VALUES (1, 'http://example.com?param1=value1&param2=value2');
INSERT INTO urls VALUES (2, 'https://example.com/path?key=value&anotherkey=anothervalue');
INSERT INTO urls VALUES (3, 'ftp://example.net/resource?data=12&info=someinfo');
INSERT INTO urls VALUES (4, 'http://test.com?');
INSERT INTO urls VALUES (5, '');
INSERT INTO urls VALUES (6, NULL);
SELECT sys.getquery(url) FROM urls WHERE id = 1;
SELECT sys.getquery(url) FROM urls WHERE id = 2;
SELECT sys.getquery(url) FROM urls WHERE id = 3;
SELECT sys.getquery(url) FROM urls WHERE id = 4;
SELECT sys.getquery(url) FROM urls WHERE id = 5;
SELECT sys.getquery(url) FROM urls WHERE id = 6;
SELECT DISTINCT sys.getquery(url) FROM urls;
SELECT COUNT(sys.getquery(url)) FROM urls WHERE sys.getquery(url) IS NOT NULL;
SELECT sys.getquery(url) FROM urls ORDER BY sys.getquery(url) LIMIT 10;
SELECT sys.getquery(url) FROM urls WHERE sys.getquery(url) LIKE '%param1=%';
CREATE TABLE responses (query CLOB, response CLOB);
INSERT INTO responses VALUES (sys.getquery(url), 'response1') FROM urls WHERE id = 1;
CREATE TABLE combined AS SELECT a.id, sys.getquery(a.url) AS query_part FROM urls a JOIN responses b ON a.url LIKE '%' || b.query || '%';