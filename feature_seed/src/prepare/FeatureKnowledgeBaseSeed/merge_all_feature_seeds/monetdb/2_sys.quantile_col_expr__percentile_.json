CREATE TABLE fuzz_test (id INT, ip_addr INET, num_value DECIMAL, date_value DATE);
INSERT INTO fuzz_test (id, ip_addr, num_value, date_value) VALUES (1, inet '192.168.1.1', 10.5, '2023-01-15');
INSERT INTO fuzz_test (id, ip_addr, num_value, date_value) VALUES (2, inet '192.168.1.1', NULL, '2023-01-16');
INSERT INTO fuzz_test (id, ip_addr, num_value, date_value) VALUES (3, inet '192.168.1.2', -1, '2023-01-17');
INSERT INTO fuzz_test (id, ip_addr, num_value, date_value) VALUES (4, inet '192.168.1.3', 0, '2023-01-18');
INSERT INTO fuzz_test (id, ip_addr, num_value, date_value) VALUES (5, inet '192.168.1.4', 5.25, NULL);
SELECT sys.quantile(num_value, 0.5) FROM fuzz_test WHERE ip_addr = inet '192.168.1.1' GROUP BY ip_addr HAVING sys.quantile(num_value, 0.5) IS NOT NULL;
SELECT ip_addr, sys.quantile(num_value, 0.7) OVER (PARTITION BY date_value) FROM fuzz_test WHERE date_value BETWEEN '2023-01-15' AND '2023-01-20' ORDER BY date_value;
SELECT A.ip_addr, A.num_value FROM fuzz_test AS A JOIN fuzz_test AS B ON A.ip_addr = B.ip_addr WHERE A.num_value = sys.quantile(B.num_value, 0.9);
SELECT COUNT(*) FROM fuzz_test WHERE sys.quantile(num_value, 0.1) = (SELECT sys.quantile(num_value, 0.1) FROM fuzz_test);
SELECT DISTINCT ip_addr, sys.quantile(num_value, 0.8) FROM fuzz_test GROUP BY ip_addr HAVING sys.quantile(num_value, 0.8) IS NOT NULL AND ip_addr = inet '192.168.1.2';
SELECT ip_addr, sys.quantile(num_value, 0.3), COUNT(*) FROM fuzz_test GROUP BY ip_addr HAVING COUNT(*) > 1 AND (ip_addr = inet '192.168.1.1' OR num_value IS NULL);