CREATE FUNCTION my_schema.my_function(int_val INT, str_val TEXT) RETURNS TEXT LANGUAGE C '{ return strdup(str_val);
}';
CREATE OR REPLACE FUNCTION my_schema.sum_values(a INT, b INT) RETURNS INT LANGUAGE CPP '{ return a + b;
}';
CREATE FUNCTION my_schema.calculate_area(radius FLOAT) RETURNS FLOAT LANGUAGE PYTHON '{ return 3.14 * radius * radius }';
CREATE FUNCTION my_schema.get_user_info(user_id INT) RETURNS TABLE(name TEXT, email TEXT) LANGUAGE R '{ query <- sprintf("SELECT name, email FROM users WHERE id = %d", user_id);
return(dbGetQuery(con, query));
}';
CREATE FUNCTION my_schema.complex_calculation(x FLOAT, y FLOAT) RETURNS FLOAT LANGUAGE PYTHON '{ return (x * y) + (x / y);
}';
CREATE FUNCTION my_schema.concatenate_strings(str1 TEXT, str2 TEXT) RETURNS TEXT LANGUAGE C '{ char *result;
asprintf(&result, "%s%s", str1, str2);
return result;
}';
CREATE FUNCTION my_schema.aggregate_total() RETURNS FLOAT LANGUAGE R '{ return(sum(dbGetQuery(con, "SELECT amount FROM sales")$amount));
}';
CREATE OR REPLACE FUNCTION my_schema.fetch_order_details(order_id INT) RETURNS TABLE(order_number INT, product_name TEXT) LANGUAGE PYTHON '{ return db.execute("SELECT order_number, product_name FROM orders WHERE id = ?", (order_id,));
}';
CREATE FUNCTION my_schema.calculate_discount(price FLOAT, discount_rate FLOAT) RETURNS FLOAT LANGUAGE PYTHON '{ return price - (price * (discount_rate / 100));
}';
CREATE FUNCTION my_schema.check_status(user_id INT) RETURNS TEXT LANGUAGE C '{ if (user_id > 0) { return strdup("Active");
} else { return strdup("Inactive");
} }';