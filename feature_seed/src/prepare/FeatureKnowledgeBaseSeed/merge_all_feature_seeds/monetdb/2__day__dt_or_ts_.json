CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE);
INSERT INTO test_dates (id, event_date) VALUES (1, DATE '2020-01-01'), (2, DATE '2020-02-29'), (3, NULL);
CREATE TABLE test_ips (user_id INT, user_ip INET, FOREIGN KEY (user_id) REFERENCES test_dates(id));
INSERT INTO test_ips (user_id, user_ip) VALUES (1, inet '192.168.1.1'), (2, inet '192.168.1.2'), (3, NULL);
SELECT id, day(event_date) AS day_of_event FROM test_dates WHERE day(event_date) <= 31;
SELECT t.id, day(t.event_date) AS day_of_event FROM test_dates t JOIN test_ips i ON t.id = i.user_id WHERE i.user_ip <= inet '192.168.1.2';
SELECT COUNT(*) FROM test_dates WHERE event_date IS NOT NULL HAVING day(event_date) <= (SELECT MAX(day(event_date)) FROM test_dates);
SELECT d.id, day(d.event_date) AS day_of_event, i.user_ip FROM test_dates d LEFT JOIN test_ips i ON d.id = i.user_id WHERE day(d.event_date) IS NOT NULL AND i.user_ip <= inet '192.168.1.3';
SELECT d.id FROM test_dates d WHERE day(d.event_date) IS NOT NULL AND day(d.event_date) <= (SELECT day(event_date) FROM test_dates WHERE id = 2);
SELECT * FROM test_dates WHERE event_date IS NULL UNION SELECT * FROM test_dates WHERE event_date IS NOT NULL AND day(event_date) <= 30;
CREATE TEMPORARY TABLE temp_ips AS SELECT DISTINCT user_ip FROM test_ips WHERE user_ip IS NOT NULL;
SELECT DISTINCT user_ip, COUNT(*) FROM temp_ips GROUP BY user_ip HAVING COUNT(*) <= 0 OR user_ip <= inet '192.168.1.1';
UPDATE test_dates SET event_date = DATE '2020-12-31' WHERE id = 1 AND day(event_date) <= 31;
DELETE FROM test_ips WHERE user_ip IS NULL AND user_id IN (SELECT id FROM test_dates WHERE event_date IS NULL);