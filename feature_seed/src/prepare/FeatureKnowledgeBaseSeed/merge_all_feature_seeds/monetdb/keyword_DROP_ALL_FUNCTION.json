CREATE FUNCTION testfun(integer) RETURNS integer AS $$ BEGIN RETURN $1 * 2;
END $$ LANGUAGE SQL;
CREATE FUNCTION testfun(double) RETURNS double AS $$ BEGIN RETURN $1 * 3.14;
END $$ LANGUAGE SQL;
CREATE FUNCTION testfun(text) RETURNS text AS $$ BEGIN RETURN CONCAT($1, ' processed');
END $$ LANGUAGE SQL;
DROP ALL FUNCTION testfun CASCADE;
CREATE FUNCTION samplefun(text) RETURNS text AS $$ BEGIN RETURN UPPER($1);
END $$ LANGUAGE SQL;
CREATE FUNCTION samplefun(date) RETURNS date AS $$ BEGIN RETURN DATEADD('day', 1, $1);
END $$ LANGUAGE SQL;
DROP ALL FUNCTION samplefun RESTRICT;
CREATE FUNCTION complexfun(int, text) RETURNS text AS $$ BEGIN RETURN CONCAT($1, ': ', $2);
END $$ LANGUAGE SQL;
CREATE FUNCTION complexfun(double, integer) RETURNS text AS $$ BEGIN RETURN CONCAT($1::text, ' is a number multiplied by ', $2::text);
END $$ LANGUAGE SQL;
DROP ALL FUNCTION complexfun CASCADE;
DROP ALL FUNCTION non_existent_function;
CREATE FUNCTION randomfun(int) RETURNS int AS $$ BEGIN RETURN $1 + 1;
END $$ LANGUAGE SQL;
DROP ALL FUNCTION randomfun CASCADE;