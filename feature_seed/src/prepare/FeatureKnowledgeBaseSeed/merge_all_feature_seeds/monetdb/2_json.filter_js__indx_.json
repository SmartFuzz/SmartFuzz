CREATE TABLE test_data (id INT PRIMARY KEY, js_data JSON, time_str VARCHAR(50));
INSERT INTO test_data (id, js_data, time_str) VALUES (1, json '["value1", 42]', '18:00:00.000+00:00');
INSERT INTO test_data (id, js_data, time_str) VALUES (2, json '["value2", null]', '25:00:00.000+05:00');
INSERT INTO test_data (id, js_data, time_str) VALUES (3, json '["value3", 32]', '12:30:00.123+01:00');
SELECT json.filter(js_data, 1) AS filtered_value, time(3) with time zone time_str AS converted_time FROM test_data WHERE json.filter(js_data, 1) IS NOT NULL;
SELECT t1.id, json.filter(t1.js_data, 1) AS filtered_value, time(3) with time zone t1.time_str AS converted_time FROM test_data t1 JOIN test_data t2 ON json.filter(t1.js_data, 1) = json.filter(t2.js_data, 0) WHERE t1.id <> t2.id;
SELECT COUNT(*) FROM test_data GROUP BY json.filter(js_data, 0) HAVING COUNT(*) > 1;
SELECT AVG(time(3) with time zone time_str) AS avg_time FROM test_data WHERE json.filter(js_data, 1) IS NOT NULL;
SELECT id, json.filter(js_data, 1) AS value FROM test_data WHERE time(3) with time zone time_str > time(3) with time zone '00:00:00.000+00:00' AND json.filter(js_data, 1) IS NOT NULL;
CREATE TEMPORARY TABLE temp_data AS SELECT id, json.filter(js_data, 0) AS json_value FROM test_data WHERE time(3) with time zone time_str IS NOT NULL;
SELECT id, json_value FROM temp_data WHERE json_value IS NOT NULL ORDER BY json_value DESC;