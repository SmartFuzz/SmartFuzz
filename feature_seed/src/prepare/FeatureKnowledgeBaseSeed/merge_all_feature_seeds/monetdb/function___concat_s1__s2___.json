CREATE TABLE test_strings (s1 VARCHAR(100), s2 VARCHAR(100));
INSERT INTO test_strings VALUES ('Hello', 'World'), (NULL, 'Test'), ('Concatenation: ', NULL), (NULL, NULL), ('Value:', ' 1');
SELECT concat(s1, s2) FROM test_strings;
SELECT concat(s1, ' is now with ', s2) FROM test_strings WHERE s1 IS NOT NULL;
SELECT CONCAT('Result: ', concat(s1, s2)) AS final_output FROM test_strings;
CREATE TABLE another_table (id INT, description VARCHAR(100));
INSERT INTO another_table VALUES (1, 'Example 1'), (2, 'Example 2');
SELECT concat(s1, ' - ', a.description) FROM test_strings AS t JOIN another_table AS a ON a.id = 1 WHERE t.s1 IS NOT NULL;
SELECT CONCAT(s1, s2) FROM (SELECT s1, s2 FROM test_strings WHERE s1 IS NOT NULL UNION SELECT s1, s2 FROM test_strings WHERE s2 IS NOT NULL) AS subquery;
SELECT (CASE WHEN s1 IS NULL THEN 'String is NULL' ELSE concat(s1, s2) END) AS result FROM test_strings;
SELECT concat('Pre: ', s1, ' - Post: ', s2) FROM test_strings WHERE s2 IS NOT NULL;