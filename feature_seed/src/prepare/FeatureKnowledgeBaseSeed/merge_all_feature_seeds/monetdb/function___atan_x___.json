CREATE TABLE angles (angle FLOAT);
INSERT INTO angles VALUES (0.0), (1.0), (-1.0), (2.0), (-2.0), (Infinity), (-Infinity), (NULL);
SELECT atan(angle) FROM angles;
SELECT atan(1.0) AS atan_value FROM angles WHERE angle = 1.0;
SELECT angle, atan(angle) FROM angles WHERE angle BETWEEN -2 AND 2;
CREATE TABLE angle_pairs (id INT, angle1 FLOAT, angle2 FLOAT);
INSERT INTO angle_pairs VALUES (1, 1.0, 2.0), (2, -1.0, 0.0);
SELECT id, atan(angle1) + atan(angle2) AS combined_atan FROM angle_pairs;
SELECT (SELECT atan(angle) FROM angles WHERE angle IS NOT NULL LIMIT 1) AS first_atan;
CREATE TABLE complex_angles (id INT, angle FLOAT);
INSERT INTO complex_angles VALUES (1, 1.0), (2, 0.5);
SELECT ca.id, ca.angle, atan(ca.angle) as atan_value, (SELECT count(*) FROM complex_angles WHERE angle >= 0) as positive_count FROM complex_angles ca;
SELECT a.angle, atan(b.angle) FROM angles a JOIN angle_pairs b ON a.angle = b.angle1 WHERE a.angle IS NOT NULL;
SELECT COUNT(*) FROM angles WHERE atan(angle) IS NOT NULL;
CREATE TABLE results (result DOUBLE);
INSERT INTO results SELECT atan(angle) FROM angles;
SELECT AVG(result) FROM results;
SELECT angle, (atan(angle) + 1.0) AS adjusted_atan FROM angles;