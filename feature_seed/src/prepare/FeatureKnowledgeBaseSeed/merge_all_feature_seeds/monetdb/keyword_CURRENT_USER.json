CREATE TABLE users (id INT, username VARCHAR(50));
INSERT INTO users (id, username) VALUES (1, 'user1');
INSERT INTO users (id, username) VALUES (2, 'user2');
CREATE TABLE roles (id INT, role_name VARCHAR(50));
INSERT INTO roles (id, role_name) VALUES (1, 'admin');
INSERT INTO roles (id, role_name) VALUES (2, 'editor');
CREATE TABLE user_roles (user_id INT, role_id INT);
INSERT INTO user_roles (user_id, role_id) VALUES (1, 1);
INSERT INTO user_roles (user_id, role_id) VALUES (1, 2);
INSERT INTO user_roles (user_id, role_id) VALUES (2, 2);
SELECT CURRENT_USER;
SELECT username FROM users WHERE id = (SELECT MIN(id) FROM users);
SELECT username FROM users WHERE id IN (SELECT user_id FROM user_roles WHERE role_id = 1);
SELECT u.username, r.role_name FROM users u JOIN user_roles ur ON u.id = ur.user_id JOIN roles r ON ur.role_id = r.id WHERE u.username = CURRENT_USER;
SELECT DISTINCT u.username FROM users u LEFT JOIN user_roles ur ON u.id = ur.user_id WHERE ur.role_id IS NULL;
SELECT COUNT(*) FROM users WHERE username = CURRENT_USER;
CREATE VIEW active_users AS SELECT username FROM users WHERE username != 'admin';
SELECT * FROM active_users;
SELECT (SELECT COUNT(*) FROM users) AS total_users, CURRENT_USER AS current_user;
UPDATE users SET username = 'new_user' WHERE username = CURRENT_USER;