CREATE TABLE test_table (id INT PRIMARY KEY, hex_value VARCHAR(8), value DECIMAL(10,2), null_value DECIMAL(10,2));
INSERT INTO test_table (id, hex_value, value, null_value) VALUES (1, 'abcd', 10.5, NULL), (2, '1234', 20.1, 5.5), (3, 'dead', 0, 0);
SELECT id, sql_div(CAST(hex_value AS BLOB), value) AS divided_value FROM test_table WHERE value IS NOT NULL;
SELECT id, sql_div(NULLIF(value, 0), sql_div(NULLIF(null_value, 0), hex_value'616263')) AS edge_case FROM test_table WHERE value <> 0;
SELECT id, sql_div(CAST(CAST(hex_value AS BLOB) AS DECIMAL), value) AS complex_division FROM test_table GROUP BY id HAVING complex_division > 0;
SELECT id, sql_div(CAST(hex'1A' AS BLOB), 1) AS division_result FROM test_table JOIN (SELECT id AS sub_id FROM test_table WHERE value < 15) subq ON test_table.id = subq.sub_id;
SELECT id, sql_div(sql_div(value, 2), null_value) AS nested_divided_value FROM test_table WHERE sql_div(value, null_value) IS NOT NULL;
CREATE TABLE related_table (related_id INT PRIMARY KEY, test_id INT, CONSTRAINT fk_test FOREIGN KEY (test_id) REFERENCES test_table(id));
INSERT INTO related_table (related_id, test_id) VALUES (1, 1), (2, 2), (3, 3);
SELECT rt.related_id, sql_div(t.value, CAST(rt.related_id AS DECIMAL)) AS division_with_relation FROM related_table rt JOIN test_table t ON rt.test_id = t.id WHERE t.value <> 0;
SELECT id, sql_div(CAST(sql_div(NULL, value), 1) AS DECIMAL) AS null_test FROM test_table GROUP BY id HAVING null_test IS NULL;