CREATE TABLE test_timestamps (id SERIAL PRIMARY KEY, ts1 TIMESTAMP, ts2 TIMESTAMP);
INSERT INTO test_timestamps (ts1, ts2) VALUES (timestamp '2021-12-31 18:40:40', timestamp '2021-12-20 16:30:20');
SELECT timestampdiff_hour(ts1, ts2) FROM test_timestamps WHERE id = 1;
SELECT id, timestampdiff_hour(ts1, ts2) AS diff_hours FROM test_timestamps;
CREATE TABLE reference_dates (start_date TIMESTAMP, end_date TIMESTAMP);
INSERT INTO reference_dates (start_date, end_date) VALUES (timestamp '2021-11-30 12:00:00', timestamp '2021-12-01 15:30:00');
SELECT timestampdiff_hour(r.start_date, r.end_date) AS diff FROM reference_dates r;
SELECT CASE WHEN timestampdiff_hour(ts1, ts2) > 0 THEN 'Future' ELSE 'Past' END AS time_status FROM test_timestamps;
CREATE TABLE nested_timestamps (id SERIAL PRIMARY KEY, sub_id INT, ts TIMESTAMP);
INSERT INTO nested_timestamps (sub_id, ts) VALUES (1, timestamp '2022-01-01 00:00:00'), (1, timestamp '2021-12-30 23:00:00');
SELECT id, timestampdiff_hour(t1.ts, (SELECT MAX(t2.ts) FROM nested_timestamps t2 WHERE t2.sub_id = t1.sub_id)) AS hour_diff FROM nested_timestamps t1;
CREATE TABLE extended_timestamps (timestamp_1 TIMESTAMP, timestamp_2 TIMESTAMP, description TEXT);
INSERT INTO extended_timestamps (timestamp_1, timestamp_2, description) VALUES (timestamp '2022-06-01 08:30:00', timestamp '2022-06-01 07:00:00', 'Morning operations'), (timestamp '2022-06-01 20:30:00', timestamp '2022-06-01 18:00:00', 'Evening operations');
SELECT description, timestampdiff_hour(timestamp_1, timestamp_2) AS diff_hours FROM extended_timestamps;
SELECT AVG(timestampdiff_hour(ts1, ts2)) AS average_diff FROM test_timestamps;
SELECT a.id, timestampdiff_hour(a.ts1, b.ts2) AS hours_diff FROM test_timestamps a JOIN reference_dates b ON a.id = 1;
SELECT timestampdiff_hour(NOW(), timestamp '2021-12-31 18:40:40') AS hours_since;
SELECT timestampdiff_hour(timestamp '2021-12-20 16:30:20', timestamp '2021-12-20 16:30:20') AS zero_diff;
SELECT timestampdiff_hour(timestamp '2021-12-31 23:59:59', timestamp '2021-12-30 00:00:00') AS edge_case_diff;