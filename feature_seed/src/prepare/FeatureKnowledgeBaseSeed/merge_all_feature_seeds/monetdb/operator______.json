CREATE TABLE nums (a INT, b INT);
INSERT INTO nums VALUES (5, 4), (10, 3), (15, 7), (22, 5);
SELECT a, b, a % b AS remainder FROM nums;
SELECT a, b, (a + 1) % (b + 2) AS adjusted_remainder FROM nums;
SELECT a, b, (a * 2) % (b + 1) AS doubled_remainder FROM nums;
CREATE TABLE more_nums (x INT, y INT);
INSERT INTO more_nums VALUES (8, 2), (20, 9), (30, 6);
SELECT n.a, n.b, m.x, m.y, (n.a % n.b) + (m.x % m.y) AS total_remainder FROM nums n JOIN more_nums m ON n.a > m.x;
SELECT (SELECT COUNT(*) FROM nums) % (SELECT COUNT(*) FROM more_nums) AS count_remainder;
SELECT a, b, (SELECT MAX(x) FROM more_nums) % b AS max_remainder FROM nums;
SELECT a, b, (SELECT SUM(y) FROM more_nums) % (a + b) AS sum_remainder FROM nums;