CREATE TABLE my_table (id INT, value TEXT);
CREATE INDEX my_index ON my_table (value);
DROP INDEX my_index;
CREATE TABLE my_table_2 (id INT, name TEXT);
CREATE INDEX my_index_2 ON my_table_2 (name);
DROP INDEX my_project.my_index_2;
DROP INDEX my_index ON my_table WHERE id = (SELECT MAX(id) FROM my_table);
DROP INDEX (SELECT index_name FROM sys.idxs WHERE idx_name = 'my_index');
CREATE INDEX my_index3 ON my_table (value, id);
DROP INDEX my_index3, my_index_2;
DROP INDEX schema_name.my_index;
DROP INDEX IF EXISTS non_existent_index ON my_table;
DROP INDEX my_index WHERE EXISTS (SELECT 1 FROM my_table_2 WHERE my_table_2.id = my_table.id);