CREATE TABLE test_ceiling (value FLOAT);
INSERT INTO test_ceiling VALUES (-95.3), (0.0), (1.2), (2.9), (3.0), (4.5), (5.999), (6.0), (-6.0), (-0.5);
SELECT ceiling(value) FROM test_ceiling;
SELECT ceiling(MAX(value)) FROM test_ceiling;
SELECT value, ceiling(value) FROM test_ceiling WHERE value < 0;
SELECT value, ceiling(value) FROM test_ceiling WHERE value BETWEEN -95.5 AND 7.0;
SELECT ceiling(a.value + b.value) FROM test_ceiling a JOIN test_ceiling b ON a.value < b.value;
SELECT DISTINCT ceiling(value * 10) FROM test_ceiling;
WITH temp_table AS (SELECT value FROM test_ceiling WHERE value > 0) SELECT ceiling(AVG(value)) FROM temp_table;
CREATE TABLE another_table (id INT, related_value FLOAT);
INSERT INTO another_table VALUES (1, -9.8), (2, 3.2), (3, -1.1);
SELECT t.id, ceiling(at.related_value) FROM another_table at JOIN test_ceiling t ON at.id = t.value;
SELECT ceiling(-95.3) AS ceiling_value;
SELECT ceiling(COALESCE(NULLIF(value, 0), 10)) FROM test_ceiling;