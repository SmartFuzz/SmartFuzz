CREATE TABLE test_table (id INT PRIMARY KEY, created_time TIME, json_data JSON);
INSERT INTO test_table (id, created_time, json_data) VALUES (1, time '14:35:45', json '{"a":[1]}');
INSERT INTO test_table (id, created_time, json_data) VALUES (2, time '12:00:00', json '{"b":null}');
SELECT id, json.length(json_data) + (time '14:35:45' - created_time) AS result FROM test_table WHERE json.length(json_data) > 0;
SELECT id, (json.length(json_data) - 1) * 1.5 AS adjusted_length FROM test_table HAVING adjusted_length > 0;
SELECT id, json.length(json_data) AS length, (time '14:00:00' - created_time) AS time_difference FROM test_table WHERE length < 3;
CREATE TABLE another_table (ref_id INT, description VARCHAR(255), FOREIGN KEY (ref_id) REFERENCES test_table(id));
INSERT INTO another_table (ref_id, description) VALUES (1, 'Test entry 1'), (2, 'Test entry 2');
SELECT at.ref_id, (json.length(t.json_data) - (time '10:00:00' - t.created_time)) AS adjusted_value FROM another_table at JOIN test_table t ON at.ref_id = t.id WHERE adjusted_value IS NOT NULL;
SELECT id, json.length(json_data) - (SELECT MAX(time '23:59:59' - created_time) FROM test_table) AS boundary_adjustment FROM test_table;
SELECT id, (json.length(json_data) - json.length(NULL)) AS json_difference FROM test_table;
SELECT id, json.length(json_data) AS json_count, (time '23:59:59' - created_time) AS end_of_day_difference FROM test_table GROUP BY json_count HAVING end_of_day_difference > time '00:00:00';