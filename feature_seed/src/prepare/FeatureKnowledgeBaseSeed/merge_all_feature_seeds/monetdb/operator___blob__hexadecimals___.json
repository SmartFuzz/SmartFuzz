CREATE TABLE hex_blob_tests (id INT, hex_value VARCHAR(255), blob_value BLOB);
INSERT INTO hex_blob_tests VALUES (1, 'abcd', blob('abcd'));
INSERT INTO hex_blob_tests VALUES (2, '1234', blob('1234'));
INSERT INTO hex_blob_tests VALUES (3, '0000', blob('0000'));
INSERT INTO hex_blob_tests VALUES (4, 'ffff', blob('ffff'));
INSERT INTO hex_blob_tests VALUES (5, '', blob(''));
INSERT INTO hex_blob_tests VALUES (6, 'deadbeef', blob('deadbeef'));
INSERT INTO hex_blob_tests VALUES (7, 'abcdef0123456789', blob('abcdef0123456789'));
INSERT INTO hex_blob_tests VALUES (8, 'ff00ff00', blob('ff00ff00'));
SELECT id, blob_value FROM hex_blob_tests WHERE hex_value = (SELECT hex_value FROM hex_blob_tests WHERE id = 1);
SELECT id, blob_value FROM hex_blob_tests WHERE blob_value = blob('abcd') OR blob_value = blob('1234');
SELECT h1.id, h1.hex_value, h2.blob_value FROM hex_blob_tests AS h1 JOIN hex_blob_tests AS h2 ON h1.id <> h2.id WHERE h1.hex_value = 'abcd' AND h2.hex_value = '1234';
SELECT id, hex_value FROM hex_blob_tests WHERE LENGTH(hex_value) > 0 ORDER BY id DESC;
SELECT COUNT(*) FROM hex_blob_tests WHERE blob_value IS NOT NULL;
SELECT DISTINCT blob_value FROM hex_blob_tests WHERE blob_value = blob('ffff') AND id IN (SELECT id FROM hex_blob_tests WHERE hex_value LIKE 'f%');
SELECT h.id, h.hex_value, (SELECT COUNT(*) FROM hex_blob_tests WHERE hex_value = h.hex_value) AS count FROM hex_blob_tests AS h ORDER BY count DESC;