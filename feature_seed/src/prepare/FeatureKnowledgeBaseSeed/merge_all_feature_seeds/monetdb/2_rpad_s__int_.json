CREATE TABLE test_table (id INT PRIMARY KEY, ip_address INET, name VARCHAR(50));
INSERT INTO test_table (id, ip_address, name) VALUES (1, inet '192.168.1.1', 'alpha');
INSERT INTO test_table (id, ip_address, name) VALUES (2, inet '192.168.1.2', NULL);
INSERT INTO test_table (id, ip_address, name) VALUES (3, inet '192.168.1.3', 'beta');
SELECT rpad(name, 10) || ' - ' || (CASE WHEN ip_address <> inet '192.168.1.1' THEN 'Different' ELSE 'Same' END) AS status FROM test_table;
SELECT * FROM test_table WHERE rpad(name, 6) <> 'alpha';
SELECT COUNT(*) FROM test_table WHERE rpad(name, 10) <> rpad('abcdef', 10);
SELECT rpad(name, 10) AS padded_name FROM test_table WHERE padded_name IS NOT NULL;
SELECT rpad(name, 3) FROM test_table WHERE ip_address <> inet '192.168.1.2' AND id IN (SELECT id FROM test_table WHERE name IS NOT NULL);
SELECT COUNT(*) FROM (SELECT DISTINCT rpad(name, 12) AS padded FROM test_table) AS subquery WHERE padded <> 'alpha       ';
SELECT id, rpad(name, 5) AS padded_name FROM test_table GROUP BY padded_name HAVING padded_name <> 'beta';
CREATE TEMPORARY TABLE temp_table AS SELECT id, rpad(name, 8) AS padded_name FROM test_table WHERE name IS NOT NULL;
SELECT (rpad(name, 6) || ' is not equal to') <> 'unknown' AS comparison FROM temp_table WHERE padded_name IS NOT NULL;