CREATE TABLE test_table (id bigint, data blob, value double precision);
INSERT INTO test_table (id, data, value) VALUES (1, blob 'abcd', 15.75), (2, blob '1234', NULL), (3, blob '5678', -8.3);
SELECT id, count(data, true) OVER (PARTITION BY value ORDER BY id) AS cnt FROM test_table WHERE data IS NOT NULL;
SELECT id, (SELECT count(value, true) FROM test_table WHERE value IS NOT NULL) AS total_counts FROM test_table;
SELECT id, count(blob 'abcd', true) OVER (PARTITION BY value ORDER BY id) FROM test_table INNER JOIN (SELECT id FROM test_table WHERE value <0) sub ON test_table.id = sub.id;
SELECT id, count(NULLIF(value, NULL), true) as filtered_count FROM test_table GROUP BY id HAVING filtered_count > 0;
SELECT id, count((SELECT blob '12ab' || data FROM test_table) , true) AS combined_count FROM test_table GROUP BY id;
SELECT id, count(data, true) AS value_count FROM test_table WHERE blob '5678' IS NOT NULL GROUP BY id HAVING value_count > 1;
SELECT id, (SELECT count(value, false) FROM test_table WHERE value IS NOT NULL) AS exp_count FROM test_table WHERE value IS NOT NULL;
SELECT id, (SELECT count(data, true) FROM test_table WHERE data IS NOT NULL) + (SELECT count(data, true) FROM test_table WHERE value < -5) AS total_count FROM test_table;