CREATE TABLE test_soundex (name VARCHAR(255));
INSERT INTO test_soundex VALUES ('MonetDB');
INSERT INTO test_soundex VALUES ('John');
INSERT INTO test_soundex VALUES ('Michael');
INSERT INTO test_soundex VALUES ('Smith');
INSERT INTO test_soundex VALUES ('Smithe');
INSERT INTO test_soundex VALUES ('Monty');
INSERT INTO test_soundex VALUES ('Avery');
INSERT INTO test_soundex VALUES (NULL);
SELECT soundex(name) FROM test_soundex;
SELECT soundex(name) FROM test_soundex WHERE name IS NOT NULL;
SELECT name, soundex(name) AS soundex_code FROM test_soundex WHERE soundex(name) IS NOT NULL;
SELECT soundex('MonetDB') AS example_soundex;
SELECT soundex(name) FROM test_soundex WHERE length(name) > 5;
SELECT soundex(name) FROM (SELECT name FROM test_soundex WHERE name LIKE 'M%') AS subquery;
SELECT s1.name, s2.name FROM test_soundex s1 JOIN test_soundex s2 ON soundex(s1.name) = soundex(s2.name) WHERE s1.name <> s2.name;
SELECT DISTINCT soundex(name) FROM test_soundex WHERE soundex(name) IN (SELECT soundex(name) FROM test_soundex GROUP BY soundex(name) HAVING COUNT(*) > 1);
CREATE TABLE soundex_test (s VARCHAR(255));
INSERT INTO soundex_test VALUES ('Avery'), ('Amy'), ('Beverly'), ('Smithy');
SELECT s, soundex(s) FROM soundex_test WHERE soundex(s) LIKE 'A%';