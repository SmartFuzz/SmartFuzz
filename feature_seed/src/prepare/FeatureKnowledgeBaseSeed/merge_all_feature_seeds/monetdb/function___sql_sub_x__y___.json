CREATE TABLE numbers (x INT, y INT);
INSERT INTO numbers VALUES (5, 7);
SELECT sql_sub(x, y) AS result FROM numbers;
CREATE TABLE transactions (id INT, amount INT);
INSERT INTO transactions VALUES (1, 100), (2, 150), (3, 200);
SELECT id, sql_sub(300, SUM(amount)) AS remaining FROM transactions GROUP BY id;
CREATE TABLE stocks (symbol VARCHAR(10), price FLOAT);
INSERT INTO stocks VALUES ('AAPL', 150.00), ('GOOGL', 2800.00);
SELECT sql_sub(price, 100) AS discounted_price FROM stocks;
SELECT sql_sub((SELECT SUM(amount) FROM transactions), (SELECT AVG(amount) FROM transactions)) AS variance;
SELECT x, y, sql_sub(x, y) AS difference FROM (SELECT x, y FROM numbers UNION SELECT 10 AS x, 5 AS y) AS combined;
CREATE TABLE budget (category VARCHAR(50), allocated INT, utilized INT);
INSERT INTO budget VALUES ('Marketing', 1000, 750), ('R&D', 2000, 1500);
SELECT category, sql_sub(allocated, utilized) AS remaining_budget FROM budget;
CREATE TABLE sales (product_id INT, revenue FLOAT);
INSERT INTO sales VALUES (1, 500.00), (2, 800.00), (3, 1200.00);
SELECT product_id, sql_sub(revenue, 300) AS profit FROM sales WHERE revenue > 600;