CREATE TABLE test_diff (id INT, value FLOAT);
INSERT INTO test_diff VALUES (1, 1.1), (2, 1.2), (3, 1.1);
SELECT diff(value) FROM test_diff WHERE id = 1;
SELECT id, value, diff(value) FROM test_diff ORDER BY id;
CREATE TABLE another_table (id INT, ref_value FLOAT);
INSERT INTO another_table VALUES (1, 1.1), (2, 1.3);
SELECT t1.id, t1.value, diff(t1.value) FROM test_diff t1 JOIN another_table t2 ON t1.value = t2.ref_value;
SELECT t1.id, t1.value, diff(t1.value) FROM (SELECT * FROM test_diff WHERE id > 1) t1 WHERE EXISTS (SELECT 1 FROM another_table t2 WHERE t2.ref_value <> t1.value);
CREATE TABLE partition_test (partition_id INT, part_value FLOAT);
INSERT INTO partition_test VALUES (1, 1.5), (1, 1.7), (2, 1.5);
SELECT part_value, diff(part_value) FROM partition_test WHERE partition_id = 1;
SELECT part_value, diff(part_value) FROM (SELECT DISTINCT part_value FROM partition_test) AS unique_parts;
SELECT id, value FROM test_diff WHERE diff(value) = TRUE;
SELECT a.id, a.value, diff(a.value) FROM test_diff a LEFT JOIN test_diff b ON a.value = b.value AND a.id <> b.id WHERE b.id IS NULL;