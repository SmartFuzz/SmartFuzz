CREATE TABLE test_table (id SERIAL PRIMARY KEY, addr VARCHAR(50), data VARCHAR(50));
INSERT INTO test_table (addr, data) VALUES ('192.168.1.5', 'Test1'), ('192.168.1.10', 'Test2'), (NULL, 'Test3');
SELECT sql_max(data, (SELECT sql_max(data) FROM test_table WHERE addr IS NOT NULL)) AS max_data FROM test_table WHERE inet(addr) IS NOT NULL;
SELECT a.addr, sql_max(b.data, a.data) AS combined_data FROM test_table a JOIN test_table b ON inet(a.addr) = inet(b.addr) WHERE a.id < 2 GROUP BY a.addr;
SELECT DISTINCT sql_max(data, '') AS max_data FROM test_table WHERE data IS NOT NULL GROUP BY addr HAVING sql_max(data, 'max_value') != 'Test2';
SELECT sql_max('Test', NULL) AS max_value UNION SELECT sql_max(NULL, 'Example') AS max_value UNION SELECT sql_max('Zebra', 'Ant') AS max_value;
WITH valid_addrs AS (SELECT inet(addr) AS inet_addr FROM test_table WHERE addr IS NOT NULL) SELECT sql_max(a.data, sql_max(b.data)) AS overall_max FROM valid_addrs a JOIN valid_addrs b ON a.inet_addr = b.inet_addr;
ALTER TABLE test_table ADD COLUMN extra_data VARCHAR(50);
UPDATE test_table SET extra_data = NULL WHERE id = 1;
SELECT sql_max(extra_data, 'default_value') AS max_extra_data FROM test_table WHERE extra_data IS NULL OR extra_data <> '';