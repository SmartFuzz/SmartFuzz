CREATE TABLE test_scale_down (id INT, value INT);
INSERT INTO test_scale_down VALUES (1, 100), (2, 200), (3, 300);
SELECT scale_down(value, 3) FROM test_scale_down;
SELECT scale_down(value + 50, 5) FROM test_scale_down WHERE id = 1;
WITH temp AS (SELECT value FROM test_scale_down WHERE value > 150) SELECT scale_down(value, 10) FROM temp;
CREATE TABLE test_divisor (divisor INT);
INSERT INTO test_divisor VALUES (1), (2), (3);
SELECT scale_down(td.value, td.divisor) FROM test_scale_down ts JOIN test_divisor td ON ts.id = td.divisor;
SELECT scale_down((SELECT SUM(value) FROM test_scale_down), 4);
SELECT scale_down((SELECT MAX(value) FROM test_scale_down) - 50, 3) FROM test_scale_down WHERE id = 1;
SELECT scale_down(value, CASE WHEN id = 2 THEN 3 ELSE 1 END) FROM test_scale_down;