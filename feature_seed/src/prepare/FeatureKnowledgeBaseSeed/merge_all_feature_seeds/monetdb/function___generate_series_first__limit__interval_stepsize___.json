CREATE TABLE timestamps (event_time TIMESTAMP);
INSERT INTO timestamps VALUES (generate_series('2023-01-01 00:00:00', '2023-01-01 01:00:00', INTERVAL '10 seconds'));
SELECT * FROM timestamps;
CREATE TABLE limits (start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO limits VALUES ('2023-01-01 00:00:00', '2023-01-01 00:02:00');
SELECT generate_series(start_time, end_time, INTERVAL '15 seconds') FROM limits;
CREATE TABLE intervals (time_interval INTERVAL);
INSERT INTO intervals VALUES (INTERVAL '30 seconds');
SELECT generate_series('2023-01-01 00:00:00', '2023-01-01 00:01:00', (SELECT time_interval FROM intervals));
CREATE TABLE complex_timestamps AS SELECT generate_series('2023-01-01 00:00:00', '2023-01-01 01:00:00', INTERVAL '5 minutes') AS step_time;
SELECT COUNT(*) FROM complex_timestamps WHERE step_time BETWEEN '2023-01-01 00:15:00' AND '2023-01-01 00:45:00';
CREATE TABLE multiple_series AS SELECT generate_series('2023-01-01 00:00:00', '2023-01-01 00:20:00', INTERVAL '1 minute') AS first_series, generate_series('2023-01-01 00:01:00', '2023-01-01 00:10:00', INTERVAL '2 minutes') AS second_series;
SELECT first_series, second_series FROM multiple_series;
SELECT generate_series('2023-01-01 00:00:00', '2023-01-01 01:00:00', INTERVAL (SELECT MAX(time_interval) FROM intervals)) AS dynamic_step_series;