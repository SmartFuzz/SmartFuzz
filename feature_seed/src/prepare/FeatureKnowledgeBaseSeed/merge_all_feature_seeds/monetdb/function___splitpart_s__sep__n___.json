CREATE TABLE test_splitpart (id INT, text STRING);
INSERT INTO test_splitpart VALUES (1, 'a|a|bc|cd');
INSERT INTO test_splitpart VALUES (2, 'x|y|z');
INSERT INTO test_splitpart VALUES (3, 'one|two|three|four|five');
SELECT splitpart(text, '|', 3) FROM test_splitpart WHERE id = 1;
SELECT splitpart(text, '|', 2) AS second_part FROM test_splitpart WHERE id = 2;
SELECT splitpart(text, '|', 5) AS fifth_part FROM test_splitpart WHERE id = 3;
SELECT splitpart(splitpart(text, '|', 2), '|', 1) FROM test_splitpart WHERE id = 3;
SELECT COUNT(*) FROM test_splitpart WHERE splitpart(text, '|', 1) = 'one';
SELECT id, splitpart(text, '|', 4) FROM test_splitpart WHERE id IN (SELECT id FROM test_splitpart WHERE text LIKE '%|four%');
SELECT id, (SELECT splitpart(text, '|', 3) FROM test_splitpart WHERE id = 1) AS part FROM test_splitpart WHERE id != 1;
CREATE TABLE another_table (ref_id INT, description STRING);
INSERT INTO another_table VALUES (1, 'details about a|a|bc|cd'), (2, 'info x|y|z');
SELECT a.ref_id, splitpart(b.description, '|', 1) FROM another_table b JOIN test_splitpart a ON a.id = b.ref_id WHERE a.id = 1;
SELECT id, splitpart(text, '|', 1) || ' - ' || splitpart(text, '|', 2) FROM test_splitpart WHERE id IN (1, 2);
SELECT (SELECT splitpart(text, '|', 1) FROM test_splitpart WHERE id = 1) AS first_part, (SELECT splitpart(text, '|', 2) FROM test_splitpart WHERE id = 3) AS second_part;