CREATE TABLE test_table (id INT, name VARCHAR(50), ip_address INET);
INSERT INTO test_table (id, name, ip_address) VALUES (1, 'foo', inet '192.168.1.1');
INSERT INTO test_table (id, name, ip_address) VALUES (2, 'bar', inet '192.168.1.2');
INSERT INTO test_table (id, name, ip_address) VALUES (3, NULL, inet '192.168.1.3');
INSERT INTO test_table (id, name, ip_address) VALUES (4, 'baz', NULL);
SELECT field(name, 'foo', 'bar', 'baz') as position FROM test_table WHERE ip_address > inet '192.168.1.0';
SELECT id, field(name, 'foo', 'bar', 'baz') as position FROM test_table WHERE (ip_address > inet '192.168.1.1' OR IP_ADDRESS IS NULL) GROUP BY id HAVING position IS NOT NULL;
SELECT DISTINCT id, field(name, 'bar', 'baz', 'foo') as position FROM test_table T1 JOIN test_table T2 ON T1.id > T2.id WHERE field(T2.name, 'foo', 'bar', 'baz') IS NOT NULL;
SELECT id, field(name, 'baz', 'bar') as position FROM test_table WHERE field(name, 'foo', 'baz', 'bar') IS NULL OR ip_address > inet '192.168.1.5';
SELECT id, COUNT(*) as count FROM test_table GROUP BY field(name, 'foo', 'bar') HAVING count > 0 AND field(name, null, 'foo') IS NULL;
SELECT id, field(name, 'nonexistent', 'foo') as position FROM test_table WHERE position = NULL OR position > 2;