CREATE TABLE test_data (id SERIAL PRIMARY KEY, data_column VARCHAR(100), uuid_column UUID, int_column INT);
INSERT INTO test_data (data_column, uuid_column, int_column) VALUES ('sample', uuid 'e31960fb-dc8b-452d-ab30-b342723e756a', 1);
INSERT INTO test_data (data_column, uuid_column, int_column) VALUES (NULL, NULL, NULL);
INSERT INTO test_data (data_column, uuid_column, int_column) VALUES ('', uuid '00000000-0000-0000-0000-000000000000', 2147483647);
SELECT bit_not(int_column) AS negated_value, uuid_column FROM test_data WHERE int_column IS NOT NULL AND data_column LIKE '%s%';
SELECT data_column, bit_not(int_column) as negated_value FROM test_data WHERE uuid_column = uuid 'e31960fb-dc8b-452d-ab30-b342723e756a';
SELECT data_column, uuid_column, (SELECT COUNT(*) FROM test_data AS t2 WHERE t2.int_column > bit_not(t1.int_column)) FROM test_data AS t1 GROUP BY data_column, uuid_column HAVING bit_not(MAX(int_column)) IS NOT NULL;
SELECT data_column, bit_not(int_column) OVER (PARTITION BY uuid_column ORDER BY int_column) as window_negation FROM test_data;
CREATE TABLE additional_data (id SERIAL PRIMARY KEY, uuid_column UUID, related_data VARCHAR(100));
INSERT INTO additional_data (uuid_column, related_data) VALUES (uuid 'e31960fb-dc8b-452d-ab30-b342723e756a', 'related_example');
SELECT t1.data_column, t2.related_data FROM test_data t1 JOIN additional_data t2 ON t1.uuid_column = t2.uuid_column WHERE t1.int_column IS NOT NULL AND t2.related_data IS NOT NULL;
SELECT null AS test_null, bit_not(COALESCE(t1.int_column, 0)) FROM test_data t1 WHERE uuid_column IS NULL OR uuid_column = uuid '00000000-0000-0000-0000-000000000000';
SELECT data_column, (SELECT COUNT(*) FROM test_data AS t3 WHERE t3.int_column IS NOT NULL AND t3.uuid_column = uuid 'e31960fb-dc8b-452d-ab30-b342723e756a') AS count_related FROM test_data t2 GROUP BY data_column HAVING COUNT(data_column) > 0;
SELECT t1.data_column, bit_not(t1.int_column) * 100 AS scaled_value FROM test_data t1 WHERE t1.int_column < 0;
SELECT data_column, bit_not(int_column) FROM test_data WHERE int_column IN (SELECT MAX(int_column) FROM test_data) ORDER BY data_column;
SELECT COALESCE(bit_not(int_column), 0) FROM test_data WHERE uuid_column = uuid 'e31960fb-dc8b-452d-ab30-b342723e756a';