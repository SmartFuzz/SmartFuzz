CREATE TABLE test_varchar (id INT, name CHARACTER VARYING);
INSERT INTO test_varchar VALUES (1, 'Alice');
INSERT INTO test_varchar VALUES (2, 'Bob');
INSERT INTO test_varchar VALUES (3, 'Catherine');
INSERT INTO test_varchar VALUES (4, 'Derek');
SELECT * FROM test_varchar WHERE LENGTH(name) < 10;
SELECT * FROM test_varchar WHERE name LIKE 'A%';
SELECT id FROM test_varchar WHERE name IN (SELECT name FROM test_varchar WHERE id < 3);
CREATE TABLE test_varchar_details (user_id INT, address CHARACTER VARYING, FOREIGN KEY (user_id) REFERENCES test_varchar(id));
INSERT INTO test_varchar_details VALUES (1, '12345 Test St, Test City');
INSERT INTO test_varchar_details VALUES (2, '67890 Sample Rd, Sample Town');
SELECT tv.name, tvd.address FROM test_varchar tv JOIN test_varchar_details tvd ON tv.id = tvd.user_id;
SELECT tv.id, REPLACE(tvd.address, 'Test', 'Demo') AS updated_address FROM test_varchar tv JOIN test_varchar_details tvd ON tv.id = tvd.user_id WHERE LENGTH(tvd.address) > 20;
SELECT COUNT(*) FROM test_varchar WHERE name IS NOT NULL;
SELECT id FROM test_varchar WHERE name <> (SELECT name FROM test_varchar WHERE id = 2);
SELECT DISTINCT name FROM test_varchar WHERE name BETWEEN 'A' AND 'C';
SELECT CONCAT(name, ' - user') AS user_info FROM test_varchar WHERE id = 3;
DELETE FROM test_varchar WHERE id = 4;
SELECT * FROM test_varchar ORDER BY id DESC;
CREATE TABLE complex_example (entry_id SERIAL PRIMARY KEY, entry_name CHARACTER VARYING, entry_description CHARACTER VARYING);
INSERT INTO complex_example (entry_name, entry_description) VALUES ('Entry One', 'This is the first entry'), ('Entry Two', 'This is the second entry');
SELECT entry_name FROM complex_example WHERE entry_description LIKE '%first%';