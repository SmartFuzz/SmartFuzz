CREATE TABLE event_logs (event_id SERIAL PRIMARY KEY, event_time TIMESTAMPTZ DEFAULT current_timestamp());
INSERT INTO event_logs (event_time) VALUES (current_timestamp());
SELECT event_id, event_time FROM event_logs WHERE event_time > current_timestamp() - INTERVAL '1 day';
CREATE TABLE users (user_id SERIAL PRIMARY KEY, signup_time TIMESTAMPTZ DEFAULT current_timestamp());
INSERT INTO users (signup_time) VALUES (current_timestamp());
SELECT u.user_id FROM users u JOIN event_logs e ON u.signup_time < e.event_time WHERE e.event_time > current_timestamp() - INTERVAL '1 hour';
SELECT COUNT(*) FROM event_logs WHERE event_time BETWEEN current_timestamp() - INTERVAL '7 days' AND current_timestamp();
CREATE TABLE session_data (session_id SERIAL PRIMARY KEY, session_start TIMESTAMPTZ DEFAULT current_timestamp(), user_id INT REFERENCES users(user_id));
INSERT INTO session_data (session_start, user_id) VALUES (current_timestamp(), 1);
SELECT s.session_id, s.session_start FROM session_data s WHERE s.session_start < current_timestamp() AND s.session_start > current_timestamp() - INTERVAL '30 minutes';
WITH recent_events AS (SELECT event_id FROM event_logs WHERE event_time > current_timestamp() - INTERVAL '2 hours') SELECT COUNT(*) FROM recent_events;