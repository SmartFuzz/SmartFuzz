CREATE TABLE test_table_1 (id INT PRIMARY KEY, value TEXT);
CREATE TABLE test_table_2 (id INT PRIMARY KEY, description TEXT, test_id INT REFERENCES test_table_1(id));
SET LOCAL TRANSACTION READ ONLY;
SET LOCAL TRANSACTION READ WRITE;
SET LOCAL TRANSACTION ISOLATION LEVEL READ UNCOMMITTED;
SET LOCAL TRANSACTION ISOLATION LEVEL READ COMMITTED;
SET LOCAL TRANSACTION ISOLATION LEVEL REPEATABLE READ;
SET LOCAL TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SET LOCAL TRANSACTION DIAGNOSTICS sqlSize;
SET LOCAL TRANSACTION READ WRITE;
INSERT INTO test_table_1 (id, value) VALUES (1, 'First');
SET LOCAL TRANSACTION READ ONLY;
SELECT * FROM test_table_1;
SET LOCAL TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SELECT * FROM test_table_1 WHERE id IN (SELECT test_id FROM test_table_2);
SET LOCAL TRANSACTION READ WRITE;
UPDATE test_table_1 SET value = 'Updated First' WHERE id = 1;
SET LOCAL TRANSACTION ISOLATION LEVEL REPEATABLE READ;
SELECT description FROM test_table_2 WHERE test_id = (SELECT id FROM test_table_1 WHERE value = 'First');
SET LOCAL TRANSACTION DIAGNOSTICS sqlSize;
DELETE FROM test_table_2 WHERE test_id NOT IN (SELECT id FROM test_table_1);
SET LOCAL TRANSACTION READ ONLY;
SELECT COUNT(*) FROM (SELECT DISTINCT value FROM test_table_1) AS distinct_values;
CREATE TABLE test_table_3 (id INT PRIMARY KEY, test_id INT REFERENCES test_table_1(id), detail TEXT);
SET LOCAL TRANSACTION READ WRITE;
INSERT INTO test_table_3 (id, test_id, detail) VALUES (1, 1, 'Detail for First');
SET LOCAL TRANSACTION ISOLATION LEVEL READ COMMITTED;
SELECT t1.value, t3.detail FROM test_table_1 t1 JOIN test_table_3 t3 ON t1.id = t3.test_id;
SET LOCAL TRANSACTION ISOLATION LEVEL SERIALIZABLE;
SELECT t1.value FROM test_table_1 t1 WHERE EXISTS (SELECT 1 FROM test_table_3 t3 WHERE t3.test_id = t1.id);