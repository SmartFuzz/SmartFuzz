CREATE TABLE test_table (id INT PRIMARY KEY, dt_col DATE, time_col TIME, value_col FLOAT);
INSERT INTO test_table (id, dt_col, time_col, value_col) VALUES (1, date '2020-01-01', time '12:00:00', 10.0);
INSERT INTO test_table (id, dt_col, time_col, value_col) VALUES (2, date '2020-01-02', time '13:30:00', NULL);
INSERT INTO test_table (id, dt_col, time_col, value_col) VALUES (3, date '2020-01-03', time '14:45:00', 5.0);
SELECT id, least(time_col, time_col) AS least_time FROM test_table WHERE dt_col = date '2020-01-01';
SELECT id, least(time_col, time '15:00:00') AS least_time FROM test_table WHERE value_col IS NULL;
SELECT id, least(time '14:00:00', least(time_col, time '15:00:00')) AS least_time FROM test_table GROUP BY id HAVING least_time IS NOT NULL;
SELECT id, least(date '2020-01-01', date '2020-01-02') AS least_date FROM (SELECT dt_col FROM test_table WHERE value_col IS NOT NULL) AS subquery;
SELECT id, least(time_col, time '15:15:15') AS least_time, COUNT(*) OVER (PARTITION BY dt_col) AS count_per_date FROM test_table;
SELECT dt_col, COUNT(*) AS total FROM test_table WHERE least(time_col, time '15:15:15') IS NOT NULL GROUP BY dt_col HAVING total > 1;