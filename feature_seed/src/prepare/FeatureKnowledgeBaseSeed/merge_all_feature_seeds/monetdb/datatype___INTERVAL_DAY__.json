CREATE TABLE intervals (id INT PRIMARY KEY, duration INTERVAL DAY);
INSERT INTO intervals VALUES (1, '3 DAY'), (2, '1 DAY 12:00:00');
SELECT id, duration FROM intervals WHERE duration > '2 DAY';
SELECT id, duration + '1 DAY' AS new_duration FROM intervals;
CREATE TABLE events (event_id INT PRIMARY KEY, event_time TIMESTAMP, duration INTERVAL DAY);
INSERT INTO events VALUES (1, '2023-01-01 00:00:00', '2 DAY'), (2, '2023-01-05 12:00:00', '1 DAY 6:00:00');
SELECT event_id, event_time + duration AS end_time FROM events;
SELECT e.event_id, e.event_time, e.duration FROM events e JOIN intervals i ON e.duration = i.duration WHERE i.id = 1;
SELECT id FROM intervals WHERE duration IN (SELECT duration FROM events WHERE event_time < '2023-01-04 00:00:00');
SELECT AVG(EXTRACT(EPOCH FROM duration)) FROM intervals;
SELECT (SELECT COUNT(*) FROM events WHERE duration < '1 DAY') AS short_events_count, (SELECT COUNT(*) FROM events WHERE duration >= '1 DAY') AS long_events_count;
SELECT EXISTS (SELECT 1 FROM intervals WHERE duration = '0 DAY');
SELECT id, EXTRACT(DAY FROM duration) AS days FROM intervals WHERE duration IS NOT NULL ORDER BY days DESC;