CREATE TABLE test_dates (id INT, dt DATE);
INSERT INTO test_dates VALUES (1, DATE '2020-01-01');
INSERT INTO test_dates VALUES (2, DATE '2020-02-29');
INSERT INTO test_dates VALUES (3, DATE '2020-03-22');
INSERT INTO test_dates VALUES (4, DATE '2020-04-30');
INSERT INTO test_dates VALUES (5, DATE '2020-05-31');
INSERT INTO test_dates VALUES (6, DATE '2020-06-15');
INSERT INTO test_dates VALUES (7, DATE '2020-12-31');
SELECT "day"(dt) FROM test_dates WHERE id = 1;
SELECT "day"(dt) FROM test_dates WHERE dt = DATE '2020-02-29';
SELECT "day"(dt) FROM test_dates WHERE dt IN (DATE '2020-03-22', DATE '2020-04-30');
SELECT id, "day"(dt) FROM test_dates ORDER BY dt DESC;
CREATE TABLE test_dates_ts (id INT, ts TIMESTAMP);
INSERT INTO test_dates_ts VALUES (1, TIMESTAMP '2020-01-01 10:00:00');
INSERT INTO test_dates_ts VALUES (2, TIMESTAMP '2020-02-29 15:00:00');
SELECT "day"(ts) FROM test_dates_ts WHERE id = 2;
CREATE TABLE test_join (id INT, dt DATE);
INSERT INTO test_join VALUES (1, DATE '2020-03-22');
INSERT INTO test_join VALUES (2, DATE '2020-03-23');
SELECT tj.id, tj.dt, "day"(tj.dt) AS day_of_month FROM test_join tj JOIN test_dates td ON "day"(td.dt) = "day"(tj.dt) WHERE td.id = 2;
SELECT tt.id, "day"(tt.ts) AS day_of_month FROM test_dates_ts tt WHERE "day"(tt.ts) >= 15;
CREATE TABLE ts_with_tz (id INT, ts_tz TIMESTAMP WITH TIME ZONE);
INSERT INTO ts_with_tz VALUES (1, TIMESTAMP '2020-01-01 10:00:00+00:00');
SELECT "day"(ts_tz) FROM ts_with_tz WHERE id = 1;