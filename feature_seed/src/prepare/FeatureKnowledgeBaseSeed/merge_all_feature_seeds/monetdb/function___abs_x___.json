CREATE TABLE test_abs (value FLOAT);
INSERT INTO test_abs VALUES (-17.4);
INSERT INTO test_abs VALUES (0.0);
INSERT INTO test_abs VALUES (17.4);
INSERT INTO test_abs VALUES (-1.0);
INSERT INTO test_abs VALUES (1.0);
INSERT INTO test_abs VALUES (NULL);
SELECT abs(value) FROM test_abs;
SELECT abs(-34.56) AS absolute_value;
SELECT abs(x) FROM (SELECT value AS x FROM test_abs) AS subquery;
SELECT t1.value, abs(t2.value) FROM test_abs t1 JOIN test_abs t2 ON t1.value < 0 AND t2.value > 0;
CREATE TABLE another_table (id INT, ref_value FLOAT);
INSERT INTO another_table VALUES (1, -20.5);
INSERT INTO another_table VALUES (2, 15.8);
SELECT a.id, abs(a.ref_value) FROM another_table a INNER JOIN test_abs b ON a.ref_value = b.value;
SELECT abs((SELECT AVG(value) FROM test_abs WHERE value < 0)) AS avg_abs_negative;
SELECT x, abs(y) FROM (SELECT value AS x, -value AS y FROM test_abs) AS complex;
SELECT COUNT(*) FROM test_abs WHERE abs(value) > 10;