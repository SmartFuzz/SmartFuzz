CREATE TABLE time_test (id INT, event_time TIME);
INSERT INTO time_test VALUES (1, TIME '18:40:05');
INSERT INTO time_test VALUES (2, TIME '00:00:00');
INSERT INTO time_test VALUES (3, TIME '23:59:59');
INSERT INTO time_test VALUES (4, TIME '12:30:45');
SELECT event_time FROM time_test WHERE event_time = TIME '18:40:05';
SELECT id, event_time FROM time_test WHERE event_time < TIME '12:00:00' ORDER BY event_time DESC;
SELECT COUNT(*) FROM time_test WHERE event_time BETWEEN TIME '09:00:00' AND TIME '17:00:00';
SELECT * FROM time_test WHERE id IN (SELECT id FROM time_test WHERE event_time < TIME '12:00:00');
SELECT t1.id, t1.event_time FROM time_test AS t1 JOIN (SELECT id FROM time_test WHERE event_time >= TIME '18:00:00') AS t2 ON t1.id = t2.id;
SELECT CASE WHEN event_time IS NOT NULL THEN 'Event time set' ELSE 'Event time not set' END AS time_status FROM time_test;
SELECT event_time FROM time_test WHERE event_time NOT IN (SELECT event_time FROM time_test WHERE event_time < TIME '00:30:00');
SELECT event_time, (event_time + TIME '01:00:00') AS one_hour_later FROM time_test;
SELECT t1.event_time, t2.event_time FROM time_test AS t1 JOIN time_test AS t2 ON t1.id != t2.id WHERE t1.event_time = TIME '12:30:45' AND t2.event_time > t1.event_time;
SELECT event_time FROM time_test WHERE event_time = TIME '23:59:59' OR event_time = TIME '00:00:00';