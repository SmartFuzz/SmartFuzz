CREATE TABLE test_table (id INT, json_data JSON, text_data VARCHAR(255));
INSERT INTO test_table (id, json_data, text_data) VALUES (1, json '{"a":[1,2,3]}', 'Hello World');
INSERT INTO test_table (id, json_data, text_data) VALUES (2, json '{"a":[4,5,6]}', 'Another String');
SELECT id, lower(text_data) AS lower_text, json_data FROM test_table WHERE json_valid(json_data);
SELECT t1.id, lower(t1.text_data) AS lower_text, t2.json_data FROM test_table t1 JOIN test_table t2 ON json_valid(t2.json_data) AND t1.id = t2.id;
SELECT id, lower(text_data), json_data FROM test_table WHERE lower(text_data) LIKE lower('hello%') GROUP BY id HAVING lower(lower(text_data)) IS NOT NULL;
SELECT id, json_agg(lower(text_data)) FROM test_table GROUP BY id HAVING COUNT(*) > 1;
SELECT t1.id, json_build_object('text', lower(t2.text_data)) AS json_info FROM test_table t1 LEFT JOIN test_table t2 ON t1.id = t2.id WHERE json_data IS NOT NULL;
SELECT id, lower(text_data), json_data FROM test_table WHERE json_data IS NULL OR json_data->>'a' IS NOT NULL;
SELECT CASE WHEN json_valid(json_data) THEN 1 ELSE 0 END AS is_valid_json, lower(text_data) FROM test_table;