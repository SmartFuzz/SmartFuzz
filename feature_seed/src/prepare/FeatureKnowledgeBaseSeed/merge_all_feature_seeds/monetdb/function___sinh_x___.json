CREATE TABLE test_sinh (value FLOAT);
INSERT INTO test_sinh VALUES (0), (1), (-1), (3.14), (2.718), (1.4), (100), (-100), (NULL);
SELECT value, sinh(value) AS hyperbolic_sine FROM test_sinh;
SELECT value, sinh(value + 2) FROM test_sinh WHERE value > 0;
SELECT a.value, b.value, sinh(a.value + b.value) AS combined_sinh FROM test_sinh a JOIN test_sinh b ON a.value > b.value;
SELECT value, sinh(value) FROM test_sinh WHERE value IS NOT NULL ORDER BY value;
SELECT AVG(sinh(value)) AS avg_hyperbolic_sine FROM test_sinh;
WITH sinh_table AS (SELECT value, sinh(value) AS result FROM test_sinh) SELECT * FROM sinh_table WHERE result > 0;
CREATE TABLE test_join (id INT, value FLOAT);
INSERT INTO test_join VALUES (1, 1.4), (2, 2.5), (3, 3.0);
SELECT j.id, j.value, sinh(t.value) AS sinh_value FROM test_join j JOIN test_sinh t ON j.value > 2;
SELECT DISTINCT sinh(value) FROM test_sinh WHERE value BETWEEN -10 AND 10;
SELECT CASE WHEN sinh(value) > 0 THEN 'Positive' ELSE 'Non-positive' END AS sinh_sign FROM test_sinh;