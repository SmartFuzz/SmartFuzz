CREATE TABLE web.log (id INT, timestamp TIMESTAMP, message TEXT);
INSERT INTO web.log (id, timestamp, message) VALUES (1, '2016-12-23 12:00:00', 'Log entry 1');
INSERT INTO web.log (id, timestamp, message) VALUES (2, '2016-12-23 13:00:00', 'Log entry 2');
INSERT INTO web.log (id, timestamp, message) VALUES (3, '2016-12-24 14:00:00', 'Log entry 3');
DELETE FROM web.log WHERE timestamp <= '2016-12-23 23:59:59';
DELETE FROM web.log WHERE id IN (SELECT id FROM web.log WHERE message LIKE '%entry%');
WITH cte AS (SELECT id FROM web.log WHERE id > 0) DELETE FROM web.log WHERE id IN (SELECT id FROM cte);
CREATE TABLE sales (id INT, amount DECIMAL(10, 2), sale_date TIMESTAMP);
INSERT INTO sales (id, amount, sale_date) VALUES (1, 100.00, '2023-10-01 08:00:00');
INSERT INTO sales (id, amount, sale_date) VALUES (2, 150.50, '2023-10-02 09:00:00');
INSERT INTO sales (id, amount, sale_date) VALUES (3, 200.75, '2023-10-03 10:00:00');
DELETE FROM sales WHERE amount < (SELECT AVG(amount) FROM sales);
DELETE FROM web.log WHERE EXISTS (SELECT 1 FROM sales WHERE sales.id = web.log.id);
DELETE FROM web.log WHERE id = (SELECT id FROM web.log ORDER BY timestamp LIMIT 1);
DELETE FROM web.log WHERE message NOT IN (SELECT message FROM web.log GROUP BY message HAVING COUNT(*) > 1);
DELETE FROM web.log WHERE id IN (SELECT a.id FROM web.log a JOIN web.log b ON a.timestamp < b.timestamp);