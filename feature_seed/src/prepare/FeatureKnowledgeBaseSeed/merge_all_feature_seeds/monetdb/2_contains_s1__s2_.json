CREATE TABLE test_data (address VARCHAR(50), subnet VARCHAR(50));
INSERT INTO test_data (address, subnet) VALUES ('192.168.1.5', '192.168.1.0/24'), ('null', '192.168.1.0/24'), ('192.168.2.5', NULL);
SELECT address, subnet FROM test_data WHERE contains(inet address, subnet) IS NOT NULL;
SELECT address, contains(address, '192') AS contains_check FROM test_data WHERE address IS NOT NULL;
SELECT address FROM (SELECT address, contains(address, (SELECT subnet FROM test_data WHERE subnet IS NOT NULL LIMIT 1)) AS inner_check FROM test_data) AS temp WHERE inner_check;
SELECT address, subnet, COUNT(*) OVER (PARTITION BY subnet) AS subnet_count FROM test_data HAVING contains(address, '192') IS TRUE;
SELECT inet address FROM test_data WHERE (inet address IS NOT NULL OR subnet IS NULL) AND contains(inet(address), '1') IS TRUE;
CREATE TABLE subnet_data (subnet VARCHAR(50), description TEXT);
INSERT INTO subnet_data (subnet, description) VALUES ('192.168.1.0/24', 'Local network'), ('192.168.2.0/24', 'Test network');
SELECT d.subnet, d.description FROM subnet_data d JOIN test_data t ON contains(t.address, d.subnet) WHERE t.address IS NOT NULL;