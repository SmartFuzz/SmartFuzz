CREATE TABLE test_timezones (id INT PRIMARY KEY, start_time TIMETZ, end_time TIMETZ);
INSERT INTO test_timezones (id, start_time, end_time) VALUES (1, timetz '08:00:00+00:00', timetz '10:00:00-00:00');
INSERT INTO test_timezones (id, start_time, end_time) VALUES (2, timetz '12:00:00+05:00', timetz '12:00:00-03:00');
SELECT id, sql_sub(start_time, end_time) AS interval_seconds FROM test_timezones WHERE sql_sub(start_time, end_time) > sec_interval '0 seconds';
SELECT id, start_time, end_time FROM test_timezones WHERE sql_sub(start_time, end_time) IS NOT NULL ORDER BY start_time DESC;
CREATE TABLE user_ips (user_id INT, ip_address INET);
INSERT INTO user_ips (user_id, ip_address) VALUES (1, inet '192.168.1.5'), (2, inet '192.168.1.4');
SELECT u.user_id, u.ip_address, (SELECT sql_sub(t.start_time, t.end_time) FROM test_timezones t WHERE t.id = u.user_id) AS time_difference FROM user_ips u WHERE u.ip_address > inet '192.168.1.3';
SELECT user_id, count(*) AS ip_count FROM user_ips GROUP BY user_id HAVING COUNT(*) > 1;
SELECT user_id FROM user_ips WHERE ip_address = (SELECT ip_address FROM user_ips WHERE user_id = 1 LIMIT 1);
SELECT user_id, sql_sub(t.start_time, t.end_time) AS difference FROM test_timezones t JOIN user_ips u ON sql_sub(t.start_time, t.end_time) > sec_interval '0 seconds' WHERE u.user_id = t.id ORDER BY sql_sub(t.start_time, t.end_time) DESC;