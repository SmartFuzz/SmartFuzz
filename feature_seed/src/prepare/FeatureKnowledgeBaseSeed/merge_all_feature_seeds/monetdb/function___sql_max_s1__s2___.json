CREATE TABLE strings_test (id INT PRIMARY KEY, str1 TEXT, str2 TEXT);
INSERT INTO strings_test VALUES (1, 'apple', 'banana');
INSERT INTO strings_test VALUES (2, 'grape', 'kiwi');
INSERT INTO strings_test VALUES (3, 'mango', 'mango');
INSERT INTO strings_test VALUES (4, 'orange', 'apple');
INSERT INTO strings_test VALUES (5, 'pear', 'peach');
SELECT sql_max(str1, str2) FROM strings_test WHERE id = 1;
SELECT sql_max('dog', 'cat') AS max_str1, sql_max('apple', 'zebra') AS max_str2;
SELECT id, sql_max(str1, str2) AS max_string FROM strings_test WHERE str1 IS NOT NULL AND str2 IS NOT NULL;
CREATE TABLE additional_test (new_id INT PRIMARY KEY, str3 TEXT);
INSERT INTO additional_test VALUES (1, 'zebra');
INSERT INTO additional_test VALUES (2, 'antelope');
SELECT a.id, sql_max(a.str1, b.str3) FROM strings_test a JOIN additional_test b ON a.id = b.new_id;
SELECT sql_max((SELECT str1 FROM strings_test WHERE id = 1), (SELECT str2 FROM strings_test WHERE id = 2));
SELECT sql_max(sql_max(str1, str2), 'kiwi') FROM strings_test WHERE id IN (1, 2);
SELECT sql_max('watermelon', sql_max(str1, str2)) FROM strings_test WHERE id = 3;
SELECT id, sql_max(str1, sql_max(str2, 'kiwi')) AS max_value FROM strings_test;
SELECT sql_max('car', (SELECT sql_max(str1) FROM strings_test WHERE id < 3)) AS overall_max;