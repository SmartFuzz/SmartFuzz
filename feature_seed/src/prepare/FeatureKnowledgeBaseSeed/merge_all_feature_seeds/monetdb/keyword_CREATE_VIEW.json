CREATE VIEW my_view AS SELECT id, name FROM users WHERE age > 18;
CREATE OR REPLACE VIEW adult_users AS SELECT * FROM users WHERE age >= 21 WITH CHECK OPTION;
CREATE VIEW complex_view AS SELECT u.id, u.name, o.order_id FROM users u JOIN orders o ON u.id = o.user_id WHERE o.amount > 100;
CREATE VIEW user_summary AS SELECT u.id, COUNT(o.order_id) AS total_orders FROM users u LEFT JOIN orders o ON u.id = o.user_id GROUP BY u.id;
CREATE VIEW selections AS SELECT id, (SELECT MAX(age) FROM users) AS max_age FROM users;
CREATE OR REPLACE VIEW nested_view AS SELECT u.name, (SELECT COUNT(*) FROM orders o WHERE o.user_id = u.id) AS order_count FROM users u;
CREATE VIEW filtered_orders AS SELECT o.* FROM orders o WHERE o.amount > (SELECT AVG(amount) FROM orders);
CREATE VIEW ordered_users AS SELECT * FROM users ORDER BY name DESC;
CREATE VIEW user_orders AS SELECT u.name, o.order_id FROM users u JOIN orders o ON u.id = o.user_id WHERE o.status = 'shipped';
CREATE OR REPLACE VIEW sales_statistics AS SELECT u.id, SUM(o.amount) AS total_sales FROM users u JOIN orders o ON u.id = o.user_id GROUP BY u.id HAVING total_sales > 500;