CREATE TABLE test_abbrev (ip INET);
INSERT INTO test_abbrev VALUES (INET '10.1.0.0/16');
SELECT sys.abbrev(ip) FROM test_abbrev;
CREATE TABLE ranges (id INT, network INET);
INSERT INTO ranges VALUES (1, INET '192.168.0.0/24'), (2, INET '10.1.0.0/16');
SELECT r.id, sys.abbrev(r.network) FROM ranges r;
SELECT CASE WHEN sys.abbrev(INET '10.1.0.0/16') = '10.1.*' THEN 'Matched' ELSE 'Not Matched' END AS Result;
CREATE TABLE ip_pairs (ip_start INET, ip_end INET);
INSERT INTO ip_pairs VALUES (INET '10.0.0.0/8', INET '10.255.255.255/8');
SELECT sys.abbrev(ip_start), sys.abbrev(ip_end) FROM ip_pairs;
SELECT COUNT(*) FROM ranges WHERE sys.abbrev(network) LIKE '10.%';
CREATE TABLE subnet_test (subnet INET);
INSERT INTO subnet_test VALUES (INET '172.16.0.0/12');
SELECT sys.abbrev(subnet) FROM subnet_test WHERE subnet IN (INET '172.16.0.0/12', INET '10.0.0.0/8');
CREATE TABLE advanced_test (address INET);
INSERT INTO advanced_test VALUES (INET '192.0.2.0/24'), (INET '203.0.113.0/24'), (INET '198.51.100.0/24');
SELECT address, sys.abbrev(address) AS abbrev FROM advanced_test WHERE address IN (SELECT address FROM advanced_test WHERE address IS NOT NULL);