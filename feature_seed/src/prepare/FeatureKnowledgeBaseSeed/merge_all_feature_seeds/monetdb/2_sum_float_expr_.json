CREATE TABLE test_table (id INT PRIMARY KEY, value FLOAT, category VARCHAR(50));
INSERT INTO test_table (id, value, category) VALUES (1, NULL, 'A'), (2, 5.5, 'B'), (3, 10.0, 'C'), (4, 2.5, 'A');
SELECT category, sum(value) % 3 AS remainder FROM test_table GROUP BY category HAVING sum(value) IS NOT NULL;
SELECT t1.category, SUM(t1.value) AS total_value FROM test_table t1 JOIN test_table t2 ON t1.id % t2.id = 0 GROUP BY t1.category HAVING SUM(t1.value) > (SELECT AVG(value) FROM test_table WHERE value IS NOT NULL);
SELECT AVG(CASE WHEN value IS NOT NULL THEN value ELSE 0 END) % 2 FROM test_table;
SELECT DISTINCT category, SUM(value) FROM (SELECT value, category FROM test_table WHERE value > (SELECT AVG(value) FROM test_table)) temp GROUP BY category HAVING SUM(value) < (SELECT SUM(value) FROM test_table) % 10;
SELECT id, value * (sum(value) % 2) AS adjusted_value FROM test_table GROUP BY id ORDER BY adjusted_value DESC;
INSERT INTO test_table (id, value, category) VALUES (5, 0.0, 'A');
CREATE TABLE temp_table (temp_id INT, temp_value FLOAT CHECK (temp_value >= 0));
INSERT INTO temp_table (temp_id, temp_value) VALUES (1, NULL), (2, 1.5), (3, 2.5);
SELECT SUM(temp_value) FROM temp_table WHERE temp_value IS NOT NULL GROUP BY temp_id HAVING SUM(temp_value) % 1 = 0;
SELECT id, SUM(value) % (SELECT COUNT(*) FROM test_table) AS mod_result FROM test_table GROUP BY id HAVING mod_result IS NOT NULL;
SELECT SUM(CAST(value AS REAL)) + (SELECT COUNT(*) FROM test_table) FROM test_table WHERE category = 'A';
SELECT category, SUM(COALESCE(value, 0.0)) % 4 AS mod_total FROM test_table GROUP BY category HAVING mod_total > 1;