CREATE TABLE test_strings (id INT PRIMARY KEY, str VARCHAR(255));
INSERT INTO test_strings (id, str) VALUES (1, 'abcde');
INSERT INTO test_strings (id, str) VALUES (2, '1234567890');
INSERT INTO test_strings (id, str) VALUES (3, 'hello world');
INSERT INTO test_strings (id, str) VALUES (4, 'MonetDB is cool');
SELECT substring(str, 1) FROM test_strings WHERE id = 1;
SELECT substring(str, 3) FROM test_strings WHERE id = 1;
SELECT substring(str, 1) FROM test_strings WHERE id = 2;
SELECT substring(str, 10) FROM test_strings WHERE id = 2;
SELECT substring(str, 1) FROM test_strings WHERE id = 3;
SELECT substring(str, 7) FROM test_strings WHERE id = 3;
SELECT substring(str, 1) FROM test_strings WHERE id = 4;
SELECT substring(str, 10) FROM test_strings WHERE id = 4;
SELECT substring(str, 5) AS result FROM (SELECT str FROM test_strings WHERE id = 1) AS subquery;
SELECT substring(str, 3) AS result FROM (SELECT str FROM test_strings WHERE id = 4) AS subquery;
SELECT a.id, substring(a.str, 2) AS sub FROM test_strings AS a JOIN test_strings AS b ON a.id = b.id WHERE b.id = 1;
SELECT substring(b.str, 1) FROM test_strings AS a JOIN test_strings AS b ON a.id = 2 WHERE b.id = 3;
SELECT substring(s, startpos) FROM (SELECT str, 6 AS startpos FROM test_strings WHERE id = 2) AS derived;
SELECT substring(s, 2) FROM (SELECT str AS s FROM test_strings WHERE id = 1 LIMIT 1) AS derived LIMIT 1;
CREATE TABLE other_strings (message VARCHAR(100));
INSERT INTO other_strings (message) VALUES ('example substring test');
SELECT substring(message, 9) FROM other_strings WHERE message LIKE 'example%';
SELECT substring(message, LENGTH(message) - 5) FROM other_strings WHERE LENGTH(message) > 10;