CREATE TABLE timestamps (id INT PRIMARY KEY, ts TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '2020-03-22 13:16:57.734639');
INSERT INTO timestamps VALUES (2, TIMESTAMP '2020-02-15 08:22:10.123456');
INSERT INTO timestamps VALUES (3, TIMESTAMP '2020-12-31 23:59:59.999999');
SELECT sys.date_trunc('year', ts) FROM timestamps;
SELECT sys.date_trunc('month', ts) FROM timestamps;
SELECT sys.date_trunc('day', ts) FROM timestamps WHERE id = 1;
SELECT sys.date_trunc('hour', ts) AS hour_truncated FROM timestamps WHERE id = 2;
SELECT sys.date_trunc('minute', ts) FROM timestamps WHERE ts < TIMESTAMP '2021-01-01 00:00:00';
SELECT sys.date_trunc('second', ts) FROM timestamps ORDER BY ts ASC;
SELECT t1.id, sys.date_trunc('week', t1.ts) AS week_start FROM timestamps t1 JOIN timestamps t2 ON t1.id != t2.id;
SELECT t.id, sys.date_trunc('quarter', t.ts) FROM (SELECT ts FROM timestamps WHERE id = 1) AS t;
SELECT t.id, sys.date_trunc('millennium', t.ts) AS millennium_truncated FROM timestamps t WHERE EXISTS (SELECT 1 FROM timestamps WHERE ts > TIMESTAMP '2019-01-01 00:00:00');
CREATE TABLE complex_timestamps (id INT PRIMARY KEY, ts TIMESTAMP);
INSERT INTO complex_timestamps SELECT id, ts FROM timestamps;
SELECT c.id, sys.date_trunc('microseconds', c.ts) AS micro_truncated FROM complex_timestamps c WHERE c.id IN (SELECT id FROM complex_timestamps WHERE ts BETWEEN TIMESTAMP '2020-02-14' AND TIMESTAMP '2020-02-16');
SELECT c.id, sys.date_trunc('decade', c.ts) AS decade_truncated FROM complex_timestamps c JOIN timestamps t ON c.id = t.id WHERE t.ts < TIMESTAMP '2022-01-01 00:00:00';