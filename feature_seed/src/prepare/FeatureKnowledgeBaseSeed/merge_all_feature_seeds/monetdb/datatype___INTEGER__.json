CREATE TABLE test_integer (id INT PRIMARY KEY, value INT);
INSERT INTO test_integer VALUES (-2147483648, 1);
INSERT INTO test_integer VALUES (2147483647, 2);
INSERT INTO test_integer VALUES (0, 3);
INSERT INTO test_integer VALUES (123456789, 4);
SELECT * FROM test_integer WHERE id BETWEEN -2147483647 AND 2147483647;
SELECT COUNT(*) FROM test_integer WHERE value > 0;
SELECT id, value FROM test_integer WHERE value = (SELECT MAX(value) FROM test_integer);
CREATE TABLE other_table (other_id INT, test_id INT, FOREIGN KEY(test_id) REFERENCES test_integer(id));
INSERT INTO other_table VALUES (1000, -2147483648);
INSERT INTO other_table VALUES (2000, 2147483647);
SELECT a.id, a.value FROM test_integer a JOIN other_table b ON a.id = b.test_id WHERE b.other_id > 1500;
CREATE VIEW integer_view AS SELECT id, value FROM test_integer WHERE value < 0;
SELECT * FROM integer_view;
DELETE FROM test_integer WHERE id < 0;
UPDATE test_integer SET value = value + 100 WHERE value < 100;
SELECT AVG(value) FROM test_integer WHERE value BETWEEN 1 AND 50;
SELECT EXISTS(SELECT 1 FROM test_integer WHERE value = 50);
SELECT id, SUM(value) FROM test_integer GROUP BY id HAVING SUM(value) > 0;