CREATE TABLE test_timestamps (id INT PRIMARY KEY, event_time TIMESTAMP(3) WITH TIME ZONE);
INSERT INTO test_timestamps VALUES (1, timestamp(3) with time zone '2020-09-28 18:40:05.123+02:00');
INSERT INTO test_timestamps VALUES (2, timestamp(3) with time zone '2023-01-01 00:00:00.000+00:00');
SELECT id, event_time FROM test_timestamps WHERE event_time < timestamp(3) with time zone '2021-01-01 00:00:00.000+00:00';
SELECT id, event_time AT TIME ZONE 'UTC' FROM test_timestamps WHERE event_time > timestamp(3) with time zone '2020-09-27 18:40:05.123+02:00';
SELECT id, event_time FROM test_timestamps WHERE event_time BETWEEN timestamp(3) with time zone '2020-09-27 18:40:05.123+02:00' AND timestamp(3) with time zone '2020-09-29 18:40:05.123+02:00';
SELECT AVG(EXTRACT(EPOCH FROM event_time)) FROM test_timestamps;
CREATE TABLE event_logs (event_id INT, description TEXT, event_time TIMESTAMP(3) WITH TIME ZONE);
INSERT INTO event_logs (event_id, description, event_time) VALUES (1, 'Test Event', timestamp(3) with time zone '2020-09-28 12:00:00.000-04:00');
SELECT e.event_id, e.description FROM event_logs e JOIN test_timestamps t ON e.event_time = t.event_time WHERE t.id = 2;
SELECT COUNT(*) FROM (SELECT id FROM test_timestamps WHERE event_time AT TIME ZONE 'UTC' < timestamp(3) with time zone '2023-12-31 23:59:59.999+01:00') AS temp;