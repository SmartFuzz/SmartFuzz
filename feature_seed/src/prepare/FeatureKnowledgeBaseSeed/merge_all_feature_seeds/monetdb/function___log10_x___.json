CREATE TABLE log_test (value FLOAT);
INSERT INTO log_test VALUES (100.0);
INSERT INTO log_test VALUES (0.0);
INSERT INTO log_test VALUES (1.0);
INSERT INTO log_test VALUES (-1.0);
INSERT INTO log_test VALUES (10.0);
INSERT INTO log_test VALUES (1000.0);
SELECT log10(value) FROM log_test WHERE value > 0;
SELECT log10(100.0) AS log_of_100;
SELECT log10(1.0) AS log_of_one;
SELECT log10(value) FROM log_test;
SELECT log10(10.0 + value) FROM log_test;
SELECT value, log10(value) FROM log_test WHERE value IN (SELECT value FROM log_test WHERE value > 0);
CREATE TABLE secondary_log_test (id INT, log_value FLOAT);
INSERT INTO secondary_log_test SELECT ROW_NUMBER() OVER (), log10(value) FROM log_test WHERE value > 0;
SELECT st.id, st.log_value FROM secondary_log_test st JOIN log_test lt ON st.id = CAST(lt.value AS INT) WHERE lt.value > 10;
SELECT COUNT(*) FROM log_test WHERE log10(value) IS NOT NULL;
SELECT AVG(log10(value)) FROM log_test WHERE value > 0;
SELECT value, log10(value) AS log_value FROM log_test WHERE value BETWEEN 1 AND 100;
INSERT INTO log_test VALUES (NULL);
SELECT log10(COALESCE(value, 1)) FROM log_test;