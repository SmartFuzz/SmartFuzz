CREATE TABLE dates_table (start_date DATE, end_date DATE);
INSERT INTO dates_table VALUES (DATE '2021-12-31', DATE '2021-12-11');
SELECT sql_sub(start_date, end_date) FROM dates_table;
INSERT INTO dates_table VALUES (DATE '2022-01-01', DATE '2022-01-01');
SELECT sql_sub(start_date, end_date) AS seconds_diff FROM dates_table WHERE seconds_diff > 0;
CREATE TABLE events (event_id INT, event_date DATE);
INSERT INTO events VALUES (1, DATE '2021-12-31'), (2, DATE '2021-12-15');
SELECT e.event_id, sql_sub(DATE '2021-12-31', e.event_date) AS seconds_diff FROM events e;
WITH date_diff AS (SELECT sql_sub(DATE '2021-12-31', DATE '2022-01-01') AS diff) SELECT diff FROM date_diff WHERE diff < 0;
CREATE TABLE holiday_dates (holiday_name VARCHAR(50), holiday_date DATE);
INSERT INTO holiday_dates VALUES ('New Year', DATE '2022-01-01'), ('Christmas', DATE '2021-12-25');
SELECT h.holiday_name, sql_sub(h.holiday_date, DATE '2021-12-31') AS seconds_to_new_year FROM holiday_dates h;
CREATE TABLE multiple_dates (date1 DATE, date2 DATE, date3 DATE);
INSERT INTO multiple_dates VALUES (DATE '2021-01-01', DATE '2021-01-02', DATE '2021-01-03');
SELECT sql_sub((SELECT date1 FROM multiple_dates), (SELECT date3 FROM multiple_dates));