CREATE TABLE test_data (id INT PRIMARY KEY, ip_address INET, description TEXT);
INSERT INTO test_data (id, ip_address, description) VALUES (1, inet '192.168.0.1', 'Sample IP');
INSERT INTO test_data (id, ip_address, description) VALUES (2, inet '192.168.0.2', 'Second IP');
INSERT INTO test_data (id, ip_address, description) VALUES (3, inet '192.168.0.3', NULL);
INSERT INTO test_data (id, ip_address, description) VALUES (4, inet NULL, '' );
SELECT * FROM test_data WHERE NOT LIKE(CAST(id AS TEXT), '1%', '#', false) AND ip_address > inet '192.168.0.0';
SELECT description, COUNT(*) FROM test_data GROUP BY description HAVING NOT LIKE(MAX(description), 'Sample%', '#', true);
SELECT * FROM (SELECT id FROM test_data WHERE ip_address IS NULL) AS subquery WHERE NOT LIKE(description, 'S%', '#', false);
SELECT ip_address FROM test_data WHERE NOT LIKE(ip_address::TEXT, '192.168.0.%', '#', false) AND ip_address > inet '192.168.0.4';
SELECT id, NOT LIKE(CAST(description AS TEXT), 'Sample%', '#', false) AS is_sample FROM test_data WHERE ip_address IS NOT NULL;
CREATE TABLE temp_data (address INET, note TEXT);
INSERT INTO temp_data (address, note) VALUES (inet '10.0.0.1', 'Local'), (inet '10.0.0.2', 'Local 2');
SELECT td.note, COUNT(*) FROM temp_data td JOIN test_data t ON NOT LIKE(td.note, 'Local%', '#', false) GROUP BY td.note HAVING COUNT(*) > 1;
SELECT COUNT(*) FROM test_data WHERE ip_address IS NOT NULL AND NOT LIKE(ip_address::TEXT, '192.168.1.%', '#', true);
SELECT (SELECT COUNT(*) * 1.0 FROM test_data WHERE NOT LIKE(description, 'Sample%', '#', false)) > (SELECT COUNT(*) FROM temp_data) AS comparison_result;