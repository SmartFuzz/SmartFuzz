CREATE TABLE url_test (id SERIAL PRIMARY KEY, raw_url VARCHAR(255) NOT NULL, valid_url URL);
INSERT INTO url_test (raw_url) VALUES ('https://example.com'), ('ftp://files.example.com'), ('invalid-url'), ('');
UPDATE url_test SET valid_url = url raw_url WHERE raw_url IS NOT NULL;
SELECT id, sys.getprotocol(valid_url) AS protocol FROM url_test WHERE valid_url IS NOT NULL;
SELECT COUNT(*) FROM (SELECT sys.getprotocol(valid_url) AS protocol FROM url_test WHERE valid_url IS NOT NULL) AS subquery GROUP BY protocol HAVING COUNT(*) > 1;
SELECT id, sys.getprotocol(url 'https://www.monetdb.org/Home'), valid_url FROM url_test WHERE valid_url IS NOT NULL;
SELECT id, sys.getprotocol(url raw_url) AS protocol FROM url_test WHERE raw_url != '' AND valid_url IS NOT NULL;
SELECT id, valid_url FROM url_test WHERE valid_url IS NULL OR instr(valid_url, 'https') > 0;
SELECT id, COUNT(*) FROM url_test WHERE valid_url IS NOT NULL GROUP BY valid_url HAVING COUNT(*) > 1;
CREATE TEMPORARY TABLE temp_urls AS SELECT id, sys.getprotocol(valid_url) AS protocol FROM url_test WHERE valid_url IS NOT NULL;
SELECT DISTINCT protocol FROM temp_urls WHERE protocol IS NOT NULL ORDER BY protocol;
INSERT INTO url_test (raw_url) VALUES ('http://www.test.com'), (NULL), (url 'ftp://thirdparty.com');
SELECT id, sys.getprotocol(url 'http://www.example.com') AS protocol, valid_url FROM url_test WHERE valid_url IS NOT NULL AND (valid_url IS NOT NULL AND raw_url IS NOT NULL);