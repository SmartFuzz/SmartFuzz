CREATE TABLE voyages (id INT PRIMARY KEY, arrival_date DATE);
INSERT INTO voyages (id, arrival_date) VALUES (1, '2023-10-01');
INSERT INTO voyages (id, arrival_date) VALUES (2, '2023-10-05');
INSERT INTO voyages (id, arrival_date) VALUES (3, '2023-10-10');
INSERT INTO voyages (id, arrival_date) VALUES (4, NULL);
SELECT * FROM voyages WHERE arrival_date IS NOT NULL;
SELECT id FROM voyages WHERE arrival_date = (SELECT MAX(arrival_date) FROM voyages WHERE arrival_date IS NOT NULL);
SELECT * FROM voyages WHERE arrival_date < '2023-10-06' AND id IN (SELECT id FROM voyages WHERE arrival_date IS NOT NULL);
SELECT COUNT(*) FROM voyages WHERE arrival_date BETWEEN '2023-10-01' AND '2023-10-10';
SELECT id, arrival_date FROM voyages ORDER BY arrival_date DESC LIMIT 1;
SELECT id FROM voyages WHERE arrival_date IS NULL UNION SELECT NULL, NULL;
CREATE TABLE ships (ship_id INT PRIMARY KEY, voyage_id INT, FOREIGN KEY (voyage_id) REFERENCES voyages(id));
INSERT INTO ships (ship_id, voyage_id) VALUES (1, 1);
INSERT INTO ships (ship_id, voyage_id) VALUES (2, 2);
SELECT s.ship_id, v.arrival_date FROM ships s JOIN voyages v ON s.voyage_id = v.id WHERE v.arrival_date < '2023-10-09';
CREATE VIEW recent_voyages AS SELECT id, arrival_date FROM voyages WHERE arrival_date >= current_date - INTERVAL '30 days';
SELECT * FROM recent_voyages WHERE arrival_date IS NOT NULL ORDER BY arrival_date;
SELECT v.id FROM voyages v LEFT JOIN ships s ON v.id = s.voyage_id WHERE s.ship_id IS NULL;
DELETE FROM voyages WHERE arrival_date < '2023-10-01';
SELECT DISTINCT arrival_date FROM voyages WHERE arrival_date IS NOT NULL ORDER BY arrival_date;