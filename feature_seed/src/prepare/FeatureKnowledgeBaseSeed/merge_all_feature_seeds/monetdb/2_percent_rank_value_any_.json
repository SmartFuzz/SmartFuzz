SELECT category, percent_rank(amount) OVER (PARTITION BY category ORDER BY amount) AS rank FROM sales WHERE amount IS NOT NULL;
SELECT s1.category, COUNT(*) FROM sales s1 JOIN sales s2 ON s1.id = s2.id WHERE s1.amount > 100 GROUP BY s1.category HAVING percent_rank(s1.amount) > 0.5;
SELECT AVG(amount) AS avg_amount, percent_rank(avg_amount) OVER (PARTITION BY category ORDER BY avg_amount) AS rank FROM sales GROUP BY category;
SELECT timestamp '2020-01-01 10:00:00' AS start_time, timestamp '2020-01-05 12:30:30' AS end_time, COUNT(*) FROM sales WHERE sale_time BETWEEN start_time AND end_time;
SELECT s.category, COUNT(*) AS count, COALESCE(NULLIF(AVG(amount), 0), 0) AS avg_sales FROM sales s GROUP BY s.category HAVING percent_rank(avg_sales) < 0.5;