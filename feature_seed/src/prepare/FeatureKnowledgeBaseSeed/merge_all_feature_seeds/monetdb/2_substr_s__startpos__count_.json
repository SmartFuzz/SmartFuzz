CREATE TABLE test_chars (id INT PRIMARY KEY, value CLOB);
INSERT INTO test_chars (id, value) VALUES (1, '0123456789'), (2, 'abcdefg'), (3, 'hijklmnop'), (4, NULL);
CREATE TABLE test_numbers (num_id INT PRIMARY KEY, num_value DECIMAL(10,2));
INSERT INTO test_numbers (num_id, num_value) VALUES (1, 1.23), (2, 4.56), (3, 7.89);
SELECT substr(c.value, 1, CAST(n.num_value / 2 AS INT)) AS sub_value FROM test_chars c JOIN test_numbers n ON n.num_id = 1 WHERE n.num_value > 3;
SELECT c.value, n.num_value, substr(c.value, 2, 1) AS middle_char FROM test_chars c JOIN test_numbers n ON n.num_id = c.id WHERE n.num_value < 5;
SELECT CAST(SUM(n.num_value) AS CLOB) AS total_value, substr(total_value, 1, 5) AS truncated_value FROM test_numbers n GROUP BY n.num_id HAVING total_value IS NOT NULL;
SELECT c.value FROM test_chars c WHERE c.value ILIKE '%' || substr(c.value, 3, 5) || '%' AND c.id % 2 = 0;
SELECT CASE WHEN c.value IS NULL THEN 'No value' ELSE substr(c.value, 1, 5) END AS safe_sub FROM test_chars c;
SELECT val, CONCAT(substring(val FROM 2), ' is processed') AS modified_val FROM (SELECT substr(c.value, 3, 2) AS val FROM test_chars c) AS subquery WHERE val IS NOT NULL;
CREATE TABLE test_complex (primary_key SERIAL PRIMARY KEY, num_col DECIMAL(10,2), str_col CLOB, foreign_key INT REFERENCES test_numbers(num_id));
INSERT INTO test_complex (num_col, str_col, foreign_key) VALUES (3.30, '12345', 1), (NULL, 'abc', 2);
SELECT COUNT(*) FROM test_complex WHERE substr(str_col, 1, 2) LIKE '12' OR (num_col IS NULL AND foreign_key = 1);