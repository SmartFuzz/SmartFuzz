CREATE TABLE time_zones (id INT PRIMARY KEY, zone_name TEXT);
INSERT INTO time_zones VALUES (1, 'UTC'), (2, 'America/New_York'), (3, 'Europe/London');
SELECT local_timezone() AS current_timezone;
SELECT (local_timezone() + 3600) AS adjusted_timezone FROM time_zones WHERE id = 1;
SELECT tz.zone_name, local_timezone() AS current_tz FROM time_zones tz WHERE tz.id IN (SELECT id FROM time_zones WHERE zone_name LIKE 'America%');
CREATE TABLE user_activity (user_id INT, activity_time TIMESTAMP);
INSERT INTO user_activity VALUES (1, TIMESTAMP '2023-10-01 10:00:00'), (2, TIMESTAMP '2023-10-02 12:30:00');
SELECT ua.user_id, ua.activity_time, local_timezone() FROM user_activity ua JOIN time_zones tz ON (ua.user_id = tz.id);
SELECT AVG(local_timezone()) AS avg_timezone FROM (SELECT local_timezone() AS tz_val FROM time_zones) AS subquery;
SELECT user_id, COUNT(*) AS activity_count FROM user_activity GROUP BY user_id HAVING COUNT(*) > (SELECT local_timezone() FROM time_zones WHERE id = 2);