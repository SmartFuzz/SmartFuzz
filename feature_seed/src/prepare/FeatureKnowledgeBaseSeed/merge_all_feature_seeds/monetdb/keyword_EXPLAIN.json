CREATE TABLE employees (id INT PRIMARY KEY, name STRING, department_id INT);
CREATE TABLE departments (id INT PRIMARY KEY, department_name STRING);
INSERT INTO departments VALUES (1, 'HR');
INSERT INTO departments VALUES (2, 'Engineering');
INSERT INTO employees VALUES (1, 'Alice', 1);
INSERT INTO employees VALUES (2, 'Bob', 2);
INSERT INTO employees VALUES (3, 'Charlie', 1);
EXPLAIN SELECT name FROM employees WHERE department_id = (SELECT id FROM departments WHERE department_name = 'Engineering');
EXPLAIN SELECT e.name, d.department_name FROM employees e JOIN departments d ON e.department_id = d.id;
EXPLAIN SELECT e.name FROM employees e WHERE e.department_id IN (SELECT id FROM departments WHERE department_name LIKE 'E%');
EXPLAIN SELECT e.name FROM employees e WHERE EXISTS (SELECT 1 FROM departments d WHERE d.id = e.department_id AND d.department_name = 'HR');
EXPLAIN SELECT e.name FROM employees e WHERE e.id = (SELECT id FROM employees WHERE name = 'Alice' LIMIT 1);
EXPLAIN SELECT e1.name FROM employees e1, employees e2 WHERE e1.department_id = e2.department_id AND e1.id <> e2.id;
EXPLAIN SELECT AVG(e.id) FROM employees e JOIN departments d ON e.department_id = d.id GROUP BY d.department_name;