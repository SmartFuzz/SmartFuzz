CREATE TABLE test_times (id INT, time_column TIMESTAMP);
INSERT INTO test_times VALUES (1, TIMESTAMP '2023-10-03 15:35:02.002345'), (2, TIMESTAMP '2023-10-03 23:59:59.999999');
INSERT INTO test_times VALUES (3, TIMESTAMP '2023-10-03 00:00:00.000000'), (4, TIMESTAMP '2023-10-03 12:30:30.500000');
SELECT "second"(time_column) FROM test_times WHERE id = 1;
SELECT "second"(time_column) FROM test_times WHERE id = 2;
SELECT "second"(time_column) FROM test_times WHERE id = 3;
SELECT "second"(time_column) FROM test_times WHERE id = 4;
SELECT id, "second"(time_column) AS seconds_extracted FROM test_times WHERE "second"(time_column) < 30;
CREATE TABLE additional_times (id INT, time_column TIMETZ);
INSERT INTO additional_times VALUES (1, TIMETZ '15:35:02.002345+01:00'), (2, TIMETZ '23:59:59.999999+00:00');
SELECT id, "second"(time_column) FROM additional_times;
SELECT a.id, a.time_column, "second"(a.time_column) AS seconds FROM test_times a JOIN additional_times b ON a.id = b.id;
SELECT (SELECT "second"(b.time_column) FROM additional_times b WHERE b.id = 1) AS seconds_in_subquery FROM test_times a WHERE a.id = 1;
SELECT "second"(TIMESTAMP '2023-10-03 18:00:00.500000') AS boundary_case;
SELECT "second"(CAST(NULL AS TIMESTAMP)) AS null_case;