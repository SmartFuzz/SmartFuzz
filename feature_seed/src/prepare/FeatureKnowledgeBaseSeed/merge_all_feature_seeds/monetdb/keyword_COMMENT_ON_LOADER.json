CREATE LOADER mysch.load_xls_data FROM 'data.xlsx' USING 'xls';
COMMENT ON LOADER mysch.load_xls_data IS 'custom loader to extract data from external xls file';
COMMENT ON LOADER mysch.load_xls_data IS NULL;
COMMENT ON LOADER mysch.load_xls_data IS '';
COMMENT ON LOADER mysch.load_xls_data IS 'Updated comment: processes XLS data';
COMMENT ON LOADER mysch.load_xls_data IS 'Testing boundary condition on loader comments';
COMMENT ON LOADER mysch.load_json_data IS 'Loader for JSON data';
CREATE LOADER mysch.load_csv_data FROM 'data.csv' USING 'csv';
COMMENT ON LOADER mysch.load_csv_data IS 'CSV loader for external data';
COMMENT ON LOADER mysch.load_csv_data IS 'Comment with digits: 12345';
CREATE LOADER another_schema.load_xml_data FROM 'data.xml' USING 'xml';
COMMENT ON LOADER another_schema.load_xml_data IS '';
COMMENT ON LOADER another_schema.load_xml_data IS NULL;
DROP LOADER mysch.load_xls_data;
COMMENT ON LOADER mysch.load_xls_data IS 'This should fail because the loader is dropped';
COMMENT ON LOADER another_schema.load_xml_data IS 'XML loader with complexity - includes nested structures';