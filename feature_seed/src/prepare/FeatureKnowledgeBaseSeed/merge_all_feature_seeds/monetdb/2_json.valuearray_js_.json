CREATE TABLE test_json (id INT, data JSON);
INSERT INTO test_json VALUES (1, json '{"a":1, "b":2}');
INSERT INTO test_json VALUES (2, json '{"a":3, "b":4}');
SELECT id, json.valuearray(data) AS values FROM test_json WHERE json.valuearray(data) > json.valuearray(json '{"a":2, "b":3}');
CREATE TABLE ips (address INET, description TEXT);
INSERT INTO ips VALUES (inet '192.168.1.5', 'office'), (inet '192.168.1.4', 'home');
SELECT address FROM ips WHERE address > (SELECT json.valuearray(data)::inet FROM test_json WHERE id = 1);
SELECT id, COUNT(*) OVER (PARTITION BY json.valuearray(data)) AS count FROM test_json GROUP BY id, json.valuearray(data) HAVING count > 1;
WITH json_data AS (SELECT data FROM test_json WHERE json.valuearray(data) IS NOT NULL) SELECT COUNT(*) FROM json_data WHERE json.valuearray(data) > json.valuearray(json '{"a":0}');
CREATE TEMPORARY TABLE mixed_data (value INT, json_data JSON);
INSERT INTO mixed_data VALUES (NULL, json '{"x":10}'), (5, json '{"x":15}');
SELECT value FROM mixed_data WHERE value IS NULL OR json.valuearray(json_data) > json.valuearray(json '{"x":5}');