CREATE TABLE test_table (id INT, created_at TIMESTAMP);
INSERT INTO test_table (id, created_at) VALUES (1, CURRENT_TIMESTAMP);
SELECT id, created_at FROM test_table WHERE created_at < CURRENT_TIMESTAMP;
SELECT id FROM test_table WHERE created_at = (SELECT MAX(created_at) FROM test_table);
CREATE TABLE another_table (description TEXT, created TIMESTAMP);
INSERT INTO another_table (description, created) VALUES ('Sample', CURRENT_TIMESTAMP);
SELECT a.id, a.created_at FROM test_table a INNER JOIN another_table b ON a.created_at < b.created;
SELECT COUNT(*) FROM test_table WHERE created_at BETWEEN CURRENT_TIMESTAMP - INTERVAL '1 DAY' AND CURRENT_TIMESTAMP;
SELECT * FROM test_table WHERE created_at = CURRENT_TIMESTAMP AND id IN (SELECT id FROM another_table);
SELECT id, created_at FROM test_table ORDER BY created_at DESC LIMIT 5;
CREATE TABLE time_log (log_id INT, log_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO time_log (log_id) VALUES (1);
SELECT log_id, log_time FROM time_log WHERE log_time >= CURRENT_TIMESTAMP - INTERVAL '1 HOUR';
SELECT (SELECT COUNT(*) FROM test_table) AS total_records, CURRENT_TIMESTAMP;
CREATE TABLE user_activity (user_id INT, activity_time TIMESTAMP);
INSERT INTO user_activity (user_id, activity_time) VALUES (1, CURRENT_TIMESTAMP);
SELECT ua.user_id, ua.activity_time FROM user_activity ua WHERE ua.activity_time < CURRENT_TIMESTAMP - INTERVAL '30 MINUTES';