CREATE TABLE strings_table (id INT PRIMARY KEY, content TEXT);
INSERT INTO strings_table VALUES (1, 'highigh'), (2, 'lowhigh'), (3, 'middlehigh');
SELECT charindex('gh', content) FROM strings_table WHERE id = 1;
SELECT charindex('high', content) FROM strings_table WHERE content LIKE '%high%';
CREATE TABLE prefixes_table (prefix TEXT);
INSERT INTO prefixes_table VALUES ('high'), ('low'), ('mid');
SELECT s.id, s.content, charindex(p.prefix, s.content) AS position FROM strings_table s JOIN prefixes_table p ON s.content LIKE '%' || p.prefix || '%';
SELECT charindex('gh', (SELECT content FROM strings_table WHERE id = 2)) AS position;
SELECT charindex('nothere', content) FROM strings_table WHERE id = 3;
SELECT charindex('lo', content) FROM (SELECT content FROM strings_table WHERE id = 2) AS subquery;
SELECT s.id, charindex('gh', s.content) FROM (SELECT content FROM strings_table WHERE id IN (1, 2)) AS s;
SELECT CASE WHEN charindex('gh', content) > 0 THEN 'Found' ELSE 'Not Found' END AS search_result FROM strings_table;
CREATE TABLE test_table AS SELECT content FROM strings_table;
SELECT charindex('gh', content) FROM test_table WHERE content IS NOT NULL;
SELECT charindex('a', '') AS empty_string_test;
SELECT charindex('', content) FROM strings_table;
CREATE TABLE combined_table AS SELECT s.content AS string_content, p.prefix FROM strings_table s, prefixes_table p;
SELECT charindex(p.prefix, string_content) FROM combined_table;