CREATE TABLE test_timestamps (id INT PRIMARY KEY, event_time TIMESTAMP, duration INTERVAL);
INSERT INTO test_timestamps VALUES (1, TIMESTAMP '2023-10-01 12:00:00', INTERVAL '2:30' minute to second);
INSERT INTO test_timestamps VALUES (2, TIMESTAMP '2023-10-01 13:15:00', INTERVAL '0:45' minute to second);
SELECT id, sql_sub(event_time, duration) AS adjusted_time FROM test_timestamps;
SELECT id, event_time - time '01:15:00' AS time_difference FROM test_timestamps WHERE event_time IS NOT NULL;
SELECT (sql_sub(event_time, duration) - TIMESTAMP '2023-10-01 11:00:00') AS time_offset FROM test_timestamps;
SELECT id, sql_sub(sql_sub(event_time, duration), INTERVAL '1:00' hour) AS final_time FROM test_timestamps WHERE duration IS NOT NULL;
CREATE TABLE test_dates (id INT PRIMARY KEY, date_event DATE);
INSERT INTO test_dates VALUES (1, DATE '2023-10-01');
INSERT INTO test_dates VALUES (2, DATE '2023-12-31');
SELECT d.id, d.date_event, (d.date_event - INTERVAL '1' DAY) AS previous_day FROM test_dates d;
SELECT t.id, t.event_time, (sql_sub(t.event_time, INTERVAL '5:00' hour) + INTERVAL '1:30' hour) AS modified_time FROM test_timestamps t WHERE modified_time > TIMESTAMP '2023-10-01 09:00:00';
SELECT t1.id, t1.event_time, t2.date_event FROM test_timestamps t1 JOIN test_dates t2 ON t1.event_time > sql_sub(t2.date_event, INTERVAL '2' DAY);
SELECT id, COUNT(*) AS total_events FROM test_timestamps GROUP BY sql_sub(event_time, INTERVAL '1 minute');
SELECT t1.id, COALESCE(t1.event_time, sql_sub(t2.date_event, INTERVAL '1' DAY)) AS effective_time FROM test_timestamps t1 FULL JOIN test_dates t2 ON t1.id = t2.id;
CREATE TABLE temp_results AS SELECT id, sql_sub(event_time, INTERVAL '0:30' minute) AS adjusted FROM test_timestamps WHERE duration > INTERVAL '0:00' MINUTE;
SELECT AVG(EXTRACT(EPOCH FROM (event_time - sql_sub(event_time, duration)))::FLOAT) AS average_difference FROM test_timestamps;