CREATE TABLE sales (id INT, amount FLOAT, category VARCHAR(50));
INSERT INTO sales VALUES (1, 100.0, 'A'), (2, 200.0, 'B'), (3, 150.0, 'A'), (4, 300.0, 'B'), (5, 250.0, 'A');
SELECT cume_dist(amount) OVER (ORDER BY amount) AS dist FROM sales;
SELECT cume_dist(amount) OVER (PARTITION BY category ORDER BY amount) AS dist FROM sales;
CREATE TABLE employee (id INT, salary FLOAT, department VARCHAR(50));
INSERT INTO employee VALUES (1, 50000, 'HR'), (2, 70000, 'IT'), (3, 60000, 'HR'), (4, 80000, 'IT'), (5, 90000, 'IT');
SELECT e.id, e.salary, cume_dist(salary) OVER (PARTITION BY department ORDER BY salary) AS salary_dist FROM employee e;
SELECT department, AVG(salary) AS avg_salary, cume_dist(avg_salary) OVER (ORDER BY avg_salary) AS dist FROM (SELECT department, salary FROM employee) AS dept_salaries GROUP BY department;
CREATE TABLE orders (order_id INT, customer_id INT, total FLOAT);
INSERT INTO orders VALUES (1, 1, 300.0), (2, 2, 150.0), (3, 1, 50.0), (4, 3, 200.0), (5, 2, 450.0);
SELECT cume_dist(total) OVER () AS total_dist FROM orders;
SELECT cume_dist(total) OVER (PARTITION BY customer_id ORDER BY total) AS dist FROM orders;