CREATE TABLE test_table (id INTEGER, numbers LIST<INTEGER>, value FLOAT, status VARCHAR);
INSERT INTO test_table VALUES (1, [1, 2, NULL], 1.5, 'active'), (2, [3, 4, 5], 2.7, 'inactive'), (3, [NULL, NULL], NULL, NULL);
SELECT id, list_slice(numbers, (32 | 4), (2 | 1)) AS sliced_values FROM test_table WHERE value > (2.0 | 1.5);
SELECT t1.id, list_slice(t1.numbers, t2.min_value, (32 | 1)) FROM test_table t1 JOIN (SELECT MIN(value) AS min_value FROM test_table WHERE status IS NOT NULL) t2 ON t1.id = 1;
SELECT id, COUNT(*) FROM (SELECT id, list_slice(numbers, -2, NULL) AS sliced FROM test_table) sub WHERE sliced IS NOT NULL GROUP BY id HAVING COUNT(sliced) > 0;
SELECT id, list_slice(numbers, 1, 3) AS sliced FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NULL) ORDER BY (list_slice(numbers, -3, -1) | 1);
CREATE TABLE additional_table (a INT, b LIST<INT>);
INSERT INTO additional_table VALUES (1, [10, 20]), (2, [30, 40]);
SELECT at.a, list_slice(at.b, (t.value | 32), 2) FROM additional_table at JOIN test_table t ON (t.id = 1 | 1);
SELECT id, list_slice(numbers, (NULL | 1), (4 | NULL)) AS sliced_numbers FROM test_table WHERE id NOT IN (SELECT id FROM additional_table);
ALTER TABLE test_table ADD COLUMN new_col BOOLEAN;
INSERT INTO test_table (id, numbers, value, status, new_col) VALUES (4, [NULL], 0.0, 'pending', NULL);