CREATE TABLE test_subtract (a FLOAT, b FLOAT);
INSERT INTO test_subtract VALUES (2.0, 3.0);
INSERT INTO test_subtract VALUES (1.5, 1.0);
INSERT INTO test_subtract VALUES (NULL, 5.0);
INSERT INTO test_subtract VALUES (5.0, NULL);
INSERT INTO test_subtract VALUES (0.0, 0.0);
INSERT INTO test_subtract VALUES (10.0, 0.0);
INSERT INTO test_subtract VALUES (0.0, 10.0);
SELECT subtract(a, b) FROM test_subtract WHERE a IS NOT NULL AND b IS NOT NULL;
SELECT subtract(a, 3) FROM test_subtract WHERE a IS NOT NULL;
SELECT subtract(10, b) FROM test_subtract WHERE b IS NOT NULL;
SELECT a, b, subtract(a, b) as result FROM test_subtract ORDER BY result;
SELECT a, b, (a - b) AS direct_subtraction FROM test_subtract;
SELECT (SELECT SUM(subtract(a, b)) FROM test_subtract) AS total_subtraction;
CREATE TABLE additional_data (c FLOAT, d FLOAT);
INSERT INTO additional_data VALUES (3.0, 1.0);
SELECT ts.a, ts.b, ad.c, ad.d, subtract(ad.c, ts.a) FROM test_subtract ts JOIN additional_data ad ON ts.a > ad.d;
SELECT subtract((SELECT MAX(a) FROM test_subtract), (SELECT MIN(b) FROM test_subtract));
SELECT subtract(3.0, (SELECT AVG(b) FROM test_subtract));
SELECT subtract((SELECT SUM(a) FROM test_subtract WHERE b > 0), (SELECT COUNT(b) FROM test_subtract));