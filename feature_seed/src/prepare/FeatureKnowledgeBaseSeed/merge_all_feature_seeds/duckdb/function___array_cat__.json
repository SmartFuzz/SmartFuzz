CREATE TABLE list_test (id INTEGER, list1 LIST<INTEGER>, list2 LIST<INTEGER>);
INSERT INTO list_test VALUES (1, [2, 3], [4, 5, 6]);
INSERT INTO list_test VALUES (2, NULL, [7, 8]);
INSERT INTO list_test VALUES (3, [9, 10], NULL);
INSERT INTO list_test VALUES (4, NULL, NULL);
SELECT list_concat(list1, list2) AS concatenated_list FROM list_test;
SELECT id, list_concat(list1, list2) AS concatenated_list FROM list_test WHERE list1 IS NOT NULL;
SELECT id, list_concat(list2, list1) AS concatenated_from_reversed FROM list_test WHERE list2 IS NOT NULL;
CREATE TABLE another_list_test (id INTEGER, other_list LIST<INTEGER>);
INSERT INTO another_list_test VALUES (1, [11, 12]), (2, [13, 14, 15]);
SELECT lt.id, list_concat(lt.list1, al.other_list) AS combined_list FROM list_test lt JOIN another_list_test al ON lt.id = 1;
SELECT id, list_concat(list1, list_concat(list2, [16, 17])) AS deeply_concatenated FROM list_test;
SELECT id, list_concat(list1, concat([18, 19])) AS concatenated_with_static FROM list_test WHERE id = 2;