CREATE TABLE tbl (id INTEGER, name VARCHAR, age INTEGER);
INSERT INTO tbl (id, name, age) VALUES (1, 'Alice', 30);
INSERT INTO tbl (id, name, age) VALUES (2, 'Bob', 25);
DESCRIBE tbl;
DESCRIBE SELECT * FROM tbl;
CREATE VIEW view_tbl AS SELECT name, age FROM tbl WHERE age > 20;
DESCRIBE view_tbl;
DESCRIBE SELECT id, name FROM tbl WHERE id IN (SELECT id FROM tbl WHERE age < 40);
CREATE TABLE tbl2 (id INTEGER, score FLOAT);
INSERT INTO tbl2 (id, score) VALUES (1, 95.5);
INSERT INTO tbl2 (id, score) VALUES (2, 89.0);
DESCRIBE SELECT a.id, a.name, b.score FROM tbl a JOIN tbl2 b ON a.id = b.id;
DESCRIBE SELECT name, (SELECT AVG(score) FROM tbl2) AS avg_score FROM tbl;