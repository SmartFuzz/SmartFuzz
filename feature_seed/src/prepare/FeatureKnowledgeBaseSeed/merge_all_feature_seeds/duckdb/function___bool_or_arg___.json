CREATE TABLE test_table (id INT, value BOOLEAN);
INSERT INTO test_table VALUES (1, TRUE), (2, FALSE), (3, NULL);
SELECT bool_or(value) FROM test_table;
INSERT INTO test_table VALUES (4, FALSE);
SELECT bool_or(value) AS any_true FROM test_table;
CREATE TABLE another_table (id INT, flag BOOLEAN);
INSERT INTO another_table VALUES (1, TRUE), (2, TRUE), (3, FALSE);
SELECT bool_or(t1.value) FROM test_table t1 JOIN another_table t2 ON t1.id = t2.id;
SELECT bool_or(CASE WHEN value IS NULL THEN FALSE ELSE value END) FROM test_table;
CREATE TABLE subquery_table (status BOOLEAN);
INSERT INTO subquery_table VALUES (TRUE), (FALSE), (FALSE), (TRUE);
SELECT bool_or(status) FROM (SELECT status FROM subquery_table) AS sub;
SELECT bool_or(value OR t2.flag) FROM test_table t1 JOIN another_table t2 ON t1.id = t2.id WHERE t1.id <= 2;
SELECT DISTINCT bool_or(value) FROM (SELECT DISTINCT value FROM test_table WHERE id > 1) AS unique_values;