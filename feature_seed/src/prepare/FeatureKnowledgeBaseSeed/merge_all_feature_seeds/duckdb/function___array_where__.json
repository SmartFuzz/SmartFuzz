CREATE TABLE test_array_where (value_list LIST<INT>, mask_list LIST<BOOLEAN>);
INSERT INTO test_array_where VALUES ([10, 20, 30, 40], [true, false, false, true]);
INSERT INTO test_array_where VALUES ([1, 2, 3, 4, 5], [false, true, true, false, false]);
INSERT INTO test_array_where VALUES ([100, 200, 300], [true, true, true]);
INSERT INTO test_array_where VALUES ([10, 20], [false, false]);
SELECT array_where(value_list, mask_list) FROM test_array_where WHERE value_list IS NOT NULL;
SELECT array_where(value_list, mask_list) FROM test_array_where WHERE mask_list IS NOT NULL;
SELECT array_where([5, 10, 15], [true, false, true]) AS filtered_array;
SELECT array_where(value_list, mask_list) AS filtered FROM test_array_where WHERE array_length(value_list) = 4;
WITH temp AS (SELECT array_where(value_list, mask_list) AS result FROM test_array_where WHERE mask_list[1] = true) SELECT result FROM temp;
CREATE TABLE other_table (num INT);
INSERT INTO other_table VALUES (1), (2), (3);
SELECT array_where(t.value_list, t.mask_list) FROM test_array_where t JOIN other_table o ON o.num = 1;
SELECT array_where(t.value_list, t.mask_list) FROM test_array_where t WHERE ARRAY_LENGTH(t.value_list) > 2;
SELECT array_where([2, 4, 6, 8], [false, true, false, true]) AS new_filtered_array;
SELECT array_where([], []) AS empty_array;