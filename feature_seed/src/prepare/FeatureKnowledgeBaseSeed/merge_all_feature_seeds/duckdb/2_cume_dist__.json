CREATE TABLE test_data (id INTEGER, value DOUBLE, category TEXT);
INSERT INTO test_data VALUES (1, 10.0, 'A'), (2, NULL, 'B'), (3, 25.0, 'A'), (4, 30.0, 'C'), (5, 0.0, 'B'), (6, 15.5, 'C');
SELECT id, value, category, cume_dist() OVER (PARTITION BY category ORDER BY value) AS dist FROM test_data WHERE value IS NOT NULL;
SELECT id, value, (3 ^ 2) AS squared_value FROM test_data WHERE value BETWEEN 10.0 AND (3 ^ 2) ORDER BY squared_value;
SELECT category, COUNT(*) AS count, cume_dist() OVER (ORDER BY COUNT(*)) AS cumulative_distribution FROM (SELECT category, value FROM test_data WHERE value IS NOT NULL GROUP BY category HAVING COUNT(value) > 1) AS grouped_data;
SELECT id, cume_dist() OVER (PARTITION BY (value ^ 2) ORDER BY id) AS cumulative_dist FROM test_data WHERE id = (SELECT MAX(id) FROM test_data WHERE category = 'C') OR category IS NULL;
SELECT id, value, cume_dist() OVER (ORDER BY (value + (NULLIF(value, value) ^ 2))) AS dist FROM test_data ORDER BY id;
SELECT t1.id, t1.value, t2.value ^ 2 FROM test_data t1 JOIN test_data t2 ON t1.category = t2.category AND t1.value > t2.value WHERE t1.value IS NOT NULL;
SELECT category, cume_dist() OVER (PARTITION BY category ORDER BY value) AS distribution FROM (SELECT id, category, NULLIF(value, 0) AS value FROM test_data WHERE id > 0) AS filtered;
CREATE TEMPORARY TABLE temp_data AS SELECT id, value ^ 3 AS cubed_value FROM test_data WHERE category = 'A';