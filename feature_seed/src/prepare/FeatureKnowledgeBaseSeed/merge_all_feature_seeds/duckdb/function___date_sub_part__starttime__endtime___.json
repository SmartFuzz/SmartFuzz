CREATE TABLE time_data (id INTEGER, starttime TIME, endtime TIME);
INSERT INTO time_data VALUES (1, TIME '01:00:00', TIME '02:30:00');
INSERT INTO time_data VALUES (2, TIME '00:00:00', TIME '01:00:00');
INSERT INTO time_data VALUES (3, TIME '06:00:00', TIME '09:00:00');
INSERT INTO time_data VALUES (4, TIME '12:00:00', TIME '13:30:00');
INSERT INTO time_data VALUES (5, TIME '08:15:00', TIME '10:45:00');
SELECT id, date_sub('hour', starttime, endtime) AS complete_hours FROM time_data;
SELECT id, date_sub('minute', starttime, endtime) AS complete_minutes FROM time_data;
SELECT id, date_sub('hour', TIME '01:00:00', TIME '01:00:00') AS complete_hours FROM time_data WHERE id = 2;
SELECT id, date_sub('hour', starttime, endtime) AS complete_hours FROM time_data WHERE endtime > starttime;
SELECT dt.id, dt.starttime, dt.endtime, date_sub('hour', dt.starttime, dt.endtime) AS complete_hours, (SELECT COUNT(*) FROM time_data t2 WHERE t2.starttime < dt.endtime) AS overlapping_partitions FROM time_data dt;
SELECT date_sub('hour', (SELECT starttime FROM time_data WHERE id = 1), (SELECT endtime FROM time_data WHERE id = 3)) AS complete_hours;
SELECT COUNT(*) FROM (SELECT id, date_sub('hour', starttime, endtime) AS complete_hours FROM time_data) AS hours_data WHERE complete_hours > 1;
SELECT dt1.id, dt1.starttime, dt1.endtime, dt2.id AS compare_id, date_sub('hour', dt1.starttime, dt2.endtime) AS complete_hours_diff FROM time_data dt1 JOIN time_data dt2 ON dt1.id <> dt2.id WHERE dt1.endtime < dt2.starttime;