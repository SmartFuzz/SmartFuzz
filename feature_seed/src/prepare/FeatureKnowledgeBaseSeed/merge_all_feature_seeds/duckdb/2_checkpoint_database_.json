CREATE TABLE test_table (id INT, event_time TIMESTAMP, description VARCHAR(255), value DOUBLE);
INSERT INTO test_table VALUES (1, TIMESTAMP '2023-01-01 12:00:00', 'A', 10.5), (2, TIMESTAMP '2023-01-05 12:00:00', 'B', NULL), (3, TIMESTAMP '2023-01-10 12:00:00', 'C', 20.0);
SELECT id, event_time, description, value, (event_time - TIMESTAMP '2023-01-01 12:00:00') AS time_diff FROM test_table WHERE value IS NOT NULL;
SELECT id, event_time, description, value, checkpoint('my_db') FROM (SELECT * FROM test_table WHERE event_time > (SELECT MAX(event_time) FROM test_table WHERE value < 15)) AS subquery;
SELECT id, COUNT(*) AS count_val FROM (SELECT * FROM test_table WHERE value IS NOT NULL OR description IS NULL) AS filtered GROUP BY id HAVING count_val > 1;
SELECT id, AVG(value) AS avg_value FROM (SELECT id, value FROM test_table WHERE value IS NOT NULL) AS avg_sub GROUP BY id ORDER BY avg_value DESC;
CREATE TABLE temp_table (temp_id INT, temp_time TIMESTAMP, temp_desc VARCHAR(100), temp_value REAL);
INSERT INTO temp_table VALUES (1, TIMESTAMP '2023-01-01 06:00:00', 'Temp A', 5.5), (2, TIMESTAMP '2023-01-02', 'Temp B', NULL);
SELECT t.id, (t.event_time - (SELECT MIN(temp_time) FROM temp_table WHERE temp_value IS NOT NULL)) AS temp_diff FROM test_table t WHERE (SELECT COUNT(*) FROM temp_table WHERE temp_value IS NOT NULL) > 0;
SELECT t.id, (checkpoint('my_db') + (SELECT MAX(event_time) FROM test_table)) AS check_time FROM test_table t WHERE t.value IS NOT NULL;