CREATE TABLE test_map (m MAP<STRING, INT>);
INSERT INTO test_map VALUES (MAP {'key1': 10, 'key2': 20, 'key3': 30});
SELECT map_contains(m, 'key2') FROM test_map;
SELECT map_contains(m, 'key4') FROM test_map;
INSERT INTO test_map VALUES (MAP {'key4': 40, 'key5': 50});
SELECT map_contains(m, 'key5') FROM test_map;
SELECT map_contains(m, 'key1') AND map_contains(m, 'key2') AS both_keys FROM test_map;
SELECT m, map_contains(m, 'key1') AS contains_key1, map_contains(m, 'key3') AS contains_key3 FROM test_map WHERE map_contains(m, 'key2') = TRUE;
CREATE TABLE another_map (m2 MAP<STRING, INT>);
INSERT INTO another_map VALUES (MAP {'key1': 100, 'key2': 200});
SELECT map_contains(t1.m, 'key1') FROM test_map AS t1 JOIN another_map AS t2 ON map_contains(t2.m2, 'key2') = TRUE;
SELECT map_contains(MAP {'nested_key1': MAP {'inner_key1': 1}}, 'nested_key1') AS nested_test;
SELECT map_contains(MAP { 'outer_key': MAP {'inner_key': 1} }, 'outer_key') AS outer_key_test;
SELECT map_contains(MAP {'key1': 10}, 'key1') OR map_contains(MAP {'key2': 20}, 'key3') AS combined_test;
SELECT map_contains((SELECT m FROM test_map WHERE map_contains(m, 'key1')), 'key1') AS subquery_check;