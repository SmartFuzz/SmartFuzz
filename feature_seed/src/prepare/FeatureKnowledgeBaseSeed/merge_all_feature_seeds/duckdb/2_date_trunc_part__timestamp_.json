CREATE TABLE timestamp_data (id INT, event_time TIMESTAMP, tags LIST<INT>);
INSERT INTO timestamp_data VALUES (1, TIMESTAMP '2021-01-01 12:00:00', [1, 2, 3]), (2, TIMESTAMP '2021-01-01 13:00:00', [4, 5]), (3, TIMESTAMP '2021-01-01 14:00:00', NULL);
SELECT id, date_trunc('minute', event_time) AS truncated_time FROM timestamp_data WHERE [1, 2] <@ COALESCE(tags, []);
SELECT id, date_trunc('hour', event_time) AS truncated_hour FROM timestamp_data WHERE event_time IS NOT NULL ORDER BY truncated_hour DESC;
SELECT id, COUNT(*) FROM (SELECT id, date_trunc('day', event_time) AS trunc_day FROM timestamp_data GROUP BY trunc_day) AS grouped_data HAVING COUNT(*) < 2;
CREATE TABLE additional_data (user_id INT, preferences LIST<INT>);
INSERT INTO additional_data VALUES (1, [1, 2, 3]), (2, [2, 3]), (3, NULL);
SELECT t.id, t.event_time FROM timestamp_data t JOIN additional_data a ON a.user_id = t.id WHERE [4, 5, 6] <@ COALESCE(a.preferences, []);
SELECT id, date_trunc('second', event_time) AS truncated_second FROM timestamp_data WHERE event_time < CURRENT_TIMESTAMP + INTERVAL '1 hour';
SELECT id, date_trunc('week', event_time) AS trunc_week, COUNT(*) FROM timestamp_data GROUP BY trunc_week HAVING trunc_week >= DATE '2021-01-01' ORDER BY trunc_week;
SELECT date_trunc('month', event_time) AS trunc_month, SUM(COALESCE(CAST(tags AS INT), 0)) FROM timestamp_data GROUP BY trunc_month;
SELECT id, date_trunc('second', event_time) AS truncated_seconds FROM timestamp_data WHERE event_time IS NULL OR event_time = TIMESTAMP '2023-01-01 00:00:00' ORDER BY truncated_seconds DESC;