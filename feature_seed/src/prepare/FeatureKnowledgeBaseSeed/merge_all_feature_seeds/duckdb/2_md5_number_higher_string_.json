CREATE TABLE test_data (id INTEGER, name VARCHAR, created_at DATE);
INSERT INTO test_data VALUES (1, 'Alice', DATE '2023-10-01'), (2, 'Bob', DATE '2023-10-02'), (3, NULL, DATE '2023-10-03'), (4, '', DATE '2023-10-04');
SELECT id, md5_number_higher(name) AS name_hash FROM test_data WHERE created_at - DATE '2023-10-03' > 0;
SELECT md5_number_higher(name) AS hash, COUNT(*) FROM test_data GROUP BY md5_number_higher(name) HAVING COUNT(*) > 1;
SELECT t1.id, (md5_number_higher(t1.name) - md5_number_higher(t2.name)) AS hash_diff FROM test_data t1 JOIN test_data t2 ON t1.id <> t2.id WHERE t1.created_at - DATE '2023-10-01' < 0;
WITH hash_values AS (SELECT id, md5_number_higher(name) AS hash_value FROM test_data WHERE name IS NOT NULL) SELECT AVG(hash_value) FROM hash_values;
CREATE TEMPORARY TABLE temp_test AS SELECT id, md5_number_higher('Test ' || id) AS test_hash FROM test_data;
SELECT id, test_hash FROM temp_test WHERE test_hash - (md5_number_higher('Test 3') + 1000) < 0;
SELECT id, md5_number_higher(name) FROM test_data WHERE id IN (SELECT id FROM test_data WHERE created_at IS NOT NULL AND created_at - DATE '2023-10-01' IS NULL);
SELECT t.id, (md5_number_higher(name) || '-' || (DATE '2023-10-02' - created_at)) AS combined_value FROM test_data t GROUP BY combined_value HAVING combined_value IS NOT NULL;