CREATE TABLE test_data (id INTEGER, value VARCHAR);
INSERT INTO test_data VALUES (1, 'A'), (2, NULL), (3, 'B'), (4, 'C'), (5, NULL);
SELECT arbitrary(value) FROM test_data;
SELECT arbitrary(value) FROM test_data WHERE id > 2;
SELECT arbitrary(value) FROM test_data GROUP BY id % 2;
CREATE TABLE additional_data (ref_id INTEGER, value VARCHAR);
INSERT INTO additional_data VALUES (1, 'X'), (2, 'Y'), (3, 'Z');
SELECT arbitrary(T.value) FROM test_data T JOIN additional_data A ON T.id = A.ref_id;
SELECT arbitrary(value) FROM (SELECT value FROM test_data WHERE value IS NOT NULL ORDER BY id LIMIT 3);
CREATE TABLE more_data (category VARCHAR, value VARCHAR);
INSERT INTO more_data VALUES ('A', 'First'), ('B', 'Second'), ('C', 'Third');
SELECT arbitrary(value) FROM more_data GROUP BY category ORDER BY category;
SELECT arbitrary(subquery.value) FROM (SELECT value FROM test_data WHERE value IS NOT NULL) AS subquery;