CREATE TABLE tbl1 (u UNION(num INTEGER, str VARCHAR));
INSERT INTO tbl1 VALUES (1), ('two'), (union_value(str := 'three'));
SELECT u FROM tbl1;
SELECT union_extract(u, 'str') AS str FROM tbl1;
SELECT u.str FROM tbl1;
SELECT union_tag(u) AS t FROM tbl1;
CREATE TABLE tbl2 (v UNION(flag BOOLEAN, num INTEGER));
INSERT INTO tbl2 VALUES (union_value(flag := TRUE)), (union_value(num := 42));
SELECT * FROM tbl2;
SELECT union_extract(v, 'num') AS num_value FROM tbl2 WHERE v IS NOT NULL;
SELECT COUNT(*) FROM tbl1 WHERE union_tag(u) = 'str';
CREATE TABLE tbl3 (id INTEGER, info UNION(num INTEGER, str VARCHAR));
INSERT INTO tbl3 VALUES (1, union_value(num := 100)), (2, union_value(str := 'hello'));
SELECT id, union_tag(info) AS tag FROM tbl3;
WITH tmp AS (SELECT union_value(num := 10) AS u) SELECT union_tag(u) FROM tmp;
SELECT id, union_extract(info, 'str') AS extracted_str FROM tbl3 WHERE info IS NOT NULL;
CREATE TABLE tbl4 (u UNION(num INTEGER, flag BOOLEAN));
INSERT INTO tbl4 VALUES (union_value(num := 5)), (union_value(flag := FALSE));
SELECT 1 AS test_union FROM tbl4 WHERE union_tag(u) = 'num';
SELECT u.num FROM tbl4 WHERE union_tag(u) = 'num' AND u.num > 0;
SELECT u.flag FROM tbl4 WHERE union_tag(u) = 'flag' AND u.flag = FALSE;
CREATE TABLE tbl5 AS SELECT id, union_value(num := id) AS u FROM (VALUES (1), (2), (3)) AS tbl(id);
SELECT union_extract(u, 'num') FROM tbl5 WHERE u IS NOT NULL;
SELECT COUNT(*) FROM tbl5 WHERE union_tag(u) = 'num';
CREATE TABLE complex_union AS SELECT id, union_value(num := id, str := CONCAT('Value ', id)) AS u FROM (VALUES (10), (20)) AS tbl(id);
SELECT union_extract(u, 'str') AS description FROM complex_union WHERE union_tag(u) = 'str';
SELECT COUNT(*) AS total FROM complex_union WHERE union_tag(u) = 'num' AND union_extract(u, 'num') < 15;