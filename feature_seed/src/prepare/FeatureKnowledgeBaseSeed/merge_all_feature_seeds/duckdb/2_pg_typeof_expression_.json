CREATE TABLE test_dates (id INT PRIMARY KEY, date_col DATE, value_col VARCHAR(255));
INSERT INTO test_dates VALUES (1, DATE '2023-01-01', 'test1'), (2, DATE '2023-01-02', 'test2'), (3, DATE NULL, 'test3');
SELECT pg_typeof((SELECT DATE '2023-01-02' - DATE '2023-01-01' FROM test_dates WHERE id = 1)) AS result_type;
SELECT id, pg_typeof(value_col) AS value_type FROM test_dates WHERE date_col IS NOT NULL;
SELECT id, pg_typeof(DATE '2023-01-01' - date_col) AS date_difference_type FROM test_dates WHERE date_col IS NOT NULL;
SELECT date_col, (SELECT pg_typeof(date_col) FROM test_dates WHERE id = 2) AS nested_type FROM test_dates WHERE DATE '2023-01-02' - date_col > 0;
SELECT id, pg_typeof(DATE '2023-01-01' - date_col), COUNT(*) FROM test_dates GROUP BY date_col HAVING pg_typeof(DATE '2023-01-01' - date_col) = 'interval';
SELECT DISTINCT pg_typeof(DATE '1990-02-28' - DATE '1990-02-27') FROM test_dates WHERE DATE '2023-01-02' IS NOT NULL;
SELECT id, pg_typeof(DATE '2023-01-02' - (SELECT date_col FROM test_dates WHERE id = 3 AND date_col IS NULL)) AS type_with_null FROM test_dates;
SELECT COUNT(*) FROM (SELECT pg_typeof(DATE '2023-01-01' - date_col) AS date_diff_type FROM test_dates) AS subquery_group HAVING date_diff_type IS NOT NULL;