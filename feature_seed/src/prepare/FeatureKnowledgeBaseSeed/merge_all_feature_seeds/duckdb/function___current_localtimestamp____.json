CREATE TABLE timestamps (id INT, event_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, current_localtimestamp());
SELECT id, event_time, current_localtimestamp() FROM timestamps WHERE event_time < current_localtimestamp();
CREATE TABLE events (event_id INT, event_time TIMESTAMP, description TEXT);
INSERT INTO events VALUES (1, current_localtimestamp() - INTERVAL '1 hour', 'Event 1');
INSERT INTO events VALUES (2, current_localtimestamp() + INTERVAL '1 hour', 'Event 2');
SELECT e.event_id, e.description, current_localtimestamp() AS local_time FROM events e WHERE e.event_time < current_localtimestamp() ORDER BY e.event_time DESC;
CREATE TABLE timezones (zone TEXT);
INSERT INTO timezones VALUES ('UTC'), ('America/New_York'), ('Europe/London');
SELECT tz.zone, current_localtimestamp() AT TIME ZONE tz.zone AS local_time FROM timezones tz;
WITH local_times AS (SELECT current_localtimestamp() AS local_time) SELECT local_time, DATE(local_time) AS local_date FROM local_times;
SELECT current_localtimestamp() AS timestamp_now, (SELECT MAX(event_time) FROM events) AS last_event_time, (SELECT COUNT(*) FROM timestamps) AS total_timestamps;
CREATE TABLE event_details (event_id INT, event_time TIMESTAMP, details TEXT);
INSERT INTO event_details SELECT event_id, event_time, description FROM events;
SELECT ed.event_id, ed.details, current_localtimestamp() AS query_time FROM event_details ed JOIN events e ON ed.event_time = e.event_time WHERE e.event_time >= current_localtimestamp() - INTERVAL '30 minutes';