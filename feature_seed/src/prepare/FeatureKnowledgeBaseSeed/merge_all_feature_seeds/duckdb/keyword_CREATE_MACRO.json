CREATE MACRO add_two_numbers(a, b) AS a + b;
CREATE OR REPLACE MACRO add_numbers(a, b) AS a + b;
CREATE MACRO IF NOT EXISTS add_numbers_if_not_exists(a, b) AS a + b;
CREATE MACRO ifelse_example(a, b, c) AS CASE WHEN a THEN b ELSE c END;
CREATE TABLE numbers AS SELECT * FROM (VALUES (1), (2), (3), (4), (5)) t(num);
CREATE MACRO get_numbers() AS (SELECT * FROM numbers);
CREATE MACRO add_default_value(a, b := 10) AS a + b;
CREATE MACRO aggregate_function(col) AS SUM(col);
CREATE MACRO arr_append_example(l, e) AS list_concat(l, list_value(e));
CREATE MACRO scalar_macro_example() AS 42;
CREATE MACRO table_macro_example() AS TABLE SELECT * FROM (VALUES ('Hello', 1), ('World', 2)) t(col1, col2);
CREATE MACRO dynamic_table(col1_value, col2_value) AS TABLE SELECT col1_value AS column1, col2_value AS column2;
CREATE OR REPLACE TEMP MACRO temporary_dynamic_table(col1_value, col2_value) AS TABLE SELECT col1_value AS column1, col2_value AS column2;
CREATE MACRO checksum_example(tbl) AS TABLE SELECT bit_xor(md5_number(COLUMNS(*))::VARCHAR) FROM query_table(tbl);
CREATE MACRO overloaded_macro(a, b) AS a + b, (a, b, c) AS a + b + c;
CREATE MACRO is_maximal_example(a TINYINT) AS a = 127, (a INT) AS a = 32767;
CREATE MACRO case_macro_example(a) AS CASE WHEN a IS NULL THEN 'NULL' ELSE 'NOT NULL' END;
CREATE MACRO recursive_macro(n) AS CASE WHEN n <= 1 THEN 1 ELSE n * recursive_macro(n - 1) END;
CREATE MACRO complex_macro(a, b) AS (SELECT a + b AS sum, a * b AS product);
CREATE MACRO nested_subquery_macro() AS (SELECT (SELECT COUNT(*) FROM numbers) AS total_count);
CREATE TABLE sample_data AS SELECT 1 AS id, 'sample' AS name;
CREATE MACRO join_example() AS SELECT a.name, b.num FROM sample_data a JOIN numbers b ON a.id = b.num;