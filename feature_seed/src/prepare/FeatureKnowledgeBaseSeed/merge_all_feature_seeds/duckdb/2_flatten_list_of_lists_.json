CREATE TABLE test_table (id INTEGER, values_list ARRAY<INTEGER>);
INSERT INTO test_table VALUES (1, [[1, 2], [3, 4]]), (2, [[5], [NULL]]), (3, [[]]), (4, [[10, 20, 30], [40]]);
SELECT id, flatten(values_list) AS flattened_values, flatten(ARRAY[[NULL], [1, 2, 3]]) AS null_flatten FROM test_table;
SELECT id, flatten(ARRAY[ARRAY[1, 2], ARRAY[3!]]) AS flattened_factorial FROM test_table WHERE id IN (SELECT id FROM test_table WHERE id > 1);
SELECT id, flatten(ARRAY[ARRAY[4!], ARRAY[2!, 3!]]) AS flatten_factorial FROM test_table GROUP BY id HAVING flatten(ARRAY[ARRAY[NULL], ARRAY[1, 2]]) IS NULL;
SELECT id, (flatten(values_list)![1]) AS factorial_of_first_item FROM test_table WHERE flatten(values_list) IS NOT NULL;
SELECT id, (SELECT 4! FROM test_table WHERE id = 1) AS factorial WHERE id = (SELECT id FROM test_table WHERE values_list = flatten(ARRAY[[1, 2], [3, 4]]));