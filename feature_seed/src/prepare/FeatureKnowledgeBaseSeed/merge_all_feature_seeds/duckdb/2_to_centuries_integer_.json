CREATE TABLE test_intervals (id INTEGER PRIMARY KEY, start_time TIMESTAMPTZ, duration INTERVAL);
INSERT INTO test_intervals (id, start_time, duration) VALUES (1, TIMESTAMPTZ '2020-01-01 00:00:00', INTERVAL 10 DAY);
INSERT INTO test_intervals (id, start_time, duration) VALUES (2, TIMESTAMPTZ '2021-01-01 00:00:00', INTERVAL '2 months');
INSERT INTO test_intervals (id, start_time, duration) VALUES (3, TIMESTAMPTZ '2022-01-01 00:00:00', INTERVAL '5 years');
SELECT id, start_time - to_centuries(id) AS adjusted_time FROM test_intervals;
SELECT id, (start_time - duration) AS adjusted_time, to_centuries(COALESCE(id, 0)) AS century FROM test_intervals;
SELECT id, start_time, EXTRACT(YEAR FROM start_time) AS year, (start_time - INTERVAL '1 DAY') + to_centuries(id) AS complex_time FROM test_intervals WHERE start_time IS NOT NULL;
SELECT DISTINCT id, (SELECT COUNT(*) FROM test_intervals t2 WHERE t1.start_time = t2.start_time - INTERVAL '3 DAYS') AS count FROM test_intervals t1;
CREATE TABLE temp_test AS SELECT id, start_time - INTERVAL '1 MONTH' AS previous_time FROM test_intervals;
SELECT id, (previous_time + INTERVAL to_centuries(1)) AS month_forward FROM temp_test WHERE previous_time IS NOT NULL;