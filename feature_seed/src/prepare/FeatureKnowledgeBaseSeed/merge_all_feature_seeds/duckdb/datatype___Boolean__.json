CREATE TABLE boolean_test (id INTEGER, flag BOOLEAN);
INSERT INTO boolean_test VALUES (1, true), (2, false), (3, NULL);
SELECT * FROM boolean_test WHERE flag = true;
SELECT * FROM boolean_test WHERE flag IS NULL;
SELECT id FROM boolean_test WHERE flag IS NOT false;
CREATE TABLE integers (i INTEGER);
INSERT INTO integers VALUES (5), (15), (NULL);
SELECT * FROM integers WHERE i > 10 AND i IS NOT NULL;
SELECT * FROM integers WHERE i < 10 OR (i IS NULL AND EXISTS (SELECT * FROM boolean_test WHERE flag IS true));
SELECT id FROM boolean_test WHERE flag = true AND id IN (SELECT i FROM integers WHERE i IS NOT NULL);
SELECT (SELECT COUNT(*) FROM boolean_test WHERE flag = true) > 0 AS has_true;
CREATE TABLE complex_test (id INTEGER, num INTEGER, is_valid BOOLEAN);
INSERT INTO complex_test VALUES (1, 10, true), (2, 20, false), (3, 30, NULL);
SELECT * FROM complex_test WHERE is_valid AND num > 15;
SELECT id FROM complex_test WHERE is_valid IS NULL OR (num <= 20 AND EXISTS (SELECT 1 FROM boolean_test WHERE flag));
SELECT id, (num > 15) AS is_greater FROM complex_test WHERE is_valid OR (num IS NULL);
CREATE TABLE join_test (id INTEGER, boolean_id INTEGER);
INSERT INTO join_test VALUES (1, 1), (2, 2), (3, NULL);
SELECT j.id FROM join_test j JOIN boolean_test b ON j.boolean_id = b.id WHERE b.flag = true;
SELECT COUNT(*) FROM join_test WHERE boolean_id IS NULL OR (SELECT flag FROM boolean_test WHERE id = boolean_id) IS NULL;