CREATE TABLE test_data (y FLOAT, x FLOAT);
INSERT INTO test_data VALUES (1, 2), (2, 3), (3, 4), (NULL, 5), (4, NULL);
SELECT regr_sxx(y, x) FROM test_data;
SELECT regr_sxx(y, x) AS variance FROM (SELECT y, x FROM test_data WHERE x IS NOT NULL);
CREATE TABLE additional_data (y FLOAT, x FLOAT);
INSERT INTO additional_data VALUES (1, 2), (2, 3), (3, 4);
SELECT regr_sxx(a.y, a.x) FROM test_data a JOIN additional_data b ON a.x = b.x;
SELECT regr_sxx(y, x) FROM (SELECT y, x FROM test_data WHERE x < 5) AS filtered_data;
SELECT x, regr_sxx(y, x) OVER (PARTITION BY x) FROM test_data WHERE y IS NOT NULL;
SELECT regr_sxx(MAX(y), MIN(x)) FROM (SELECT y, x FROM test_data) AS max_min_data;
SELECT regr_sxx(SUM(y), AVG(x)) FROM test_data GROUP BY (CASE WHEN x IS NOT NULL THEN 1 ELSE 0 END);