CREATE TABLE data (x FLOAT, y FLOAT);
INSERT INTO data VALUES (1.0, 2.0), (2.0, 4.0), (3.0, 6.0), (4.0, 8.0);
SELECT covar_pop(y, x) FROM data;
CREATE TABLE additional_data (x FLOAT, y FLOAT);
INSERT INTO additional_data VALUES (5.0, 10.0), (6.0, 12.0);
SELECT covar_pop(d.y, d.x) FROM data d JOIN additional_data a ON d.x < a.x;
SELECT covar_pop(y, x) FROM (SELECT x, y FROM data WHERE y > 2) AS filtered_data;
SELECT covar_pop(y, x) FROM (SELECT x * 2 AS x, y * 2 AS y FROM data) AS scaled_data WHERE x > 0;
SELECT covar_pop(y, x) FROM (SELECT x, y FROM data UNION SELECT x, y FROM additional_data) AS combined_data;
CREATE TABLE more_data (x FLOAT, y FLOAT);
INSERT INTO more_data VALUES (NULL, NULL), (NULL, 5.0);
SELECT covar_pop(y, x) FROM more_data WHERE x IS NOT NULL AND y IS NOT NULL;
CREATE TABLE join_data1 (id INT, x FLOAT);
CREATE TABLE join_data2 (id INT, y FLOAT);
INSERT INTO join_data1 VALUES (1, 1.0), (2, 2.0), (3, 3.0);
INSERT INTO join_data2 VALUES (1, 2.0), (2, 4.0), (3, 6.0);
SELECT covar_pop(j2.y, j1.x) FROM join_data1 j1 JOIN join_data2 j2 ON j1.id = j2.id;
SELECT covar_pop(y, x) FROM (SELECT x, y FROM data WHERE x > 0 AND y < 10) AS subquery;
SELECT covar_pop(y, x) FROM (SELECT x * 1.5 AS x, y + 1.0 AS y FROM data) AS modified_data WHERE y > 3;