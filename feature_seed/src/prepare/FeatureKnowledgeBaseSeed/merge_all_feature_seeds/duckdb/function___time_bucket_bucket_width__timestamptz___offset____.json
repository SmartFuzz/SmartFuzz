CREATE TABLE events (event_time TIMESTAMPTZ, event_name VARCHAR);
INSERT INTO events VALUES (TIMESTAMPTZ '2023-10-01 08:00:00-07', 'Event A');
INSERT INTO events VALUES (TIMESTAMPTZ '2023-10-01 08:05:00-07', 'Event B');
INSERT INTO events VALUES (TIMESTAMPTZ '2023-10-01 08:12:00-07', 'Event C');
INSERT INTO events VALUES (TIMESTAMPTZ '2023-10-01 08:25:00-07', 'Event D');
SELECT time_bucket(INTERVAL '10 minutes', event_time, INTERVAL '5 minutes') AS bucketed_time, COUNT(event_name) AS event_count FROM events GROUP BY bucketed_time ORDER BY bucketed_time;
CREATE TABLE user_activity (user_id INT, activity_time TIMESTAMPTZ);
INSERT INTO user_activity VALUES (1, TIMESTAMPTZ '2023-10-01 08:01:00-07');
INSERT INTO user_activity VALUES (2, TIMESTAMPTZ '2023-10-01 08:10:00-07');
INSERT INTO user_activity VALUES (1, TIMESTAMPTZ '2023-10-01 08:20:00-07');
SELECT u.user_id, time_bucket(INTERVAL '10 minutes', u.activity_time) AS activity_bucket FROM user_activity AS u JOIN events AS e ON u.activity_time BETWEEN e.event_time - INTERVAL '10 minutes' AND e.event_time GROUP BY u.user_id, activity_bucket;
SELECT DISTINCT time_bucket(INTERVAL '1 hour', TIMESTAMPTZ '2023-10-01 12:00:00-07', INTERVAL '15 minutes') AS hourly_bucket;
SELECT time_bucket(INTERVAL '30 minutes', TIMESTAMPTZ '2023-10-01 00:00:00-07', INTERVAL '15 minutes') AS midnight_bucket;
CREATE TABLE test_data (data_time TIMESTAMPTZ, value INT);
INSERT INTO test_data VALUES (TIMESTAMPTZ '2023-10-01 14:05:00-07', 10);
INSERT INTO test_data VALUES (TIMESTAMPTZ '2023-10-01 14:15:00-07', 20);
INSERT INTO test_data VALUES (TIMESTAMPTZ '2023-10-01 14:25:00-07', 30);
SELECT time_bucket(INTERVAL '15 minutes', data_time, INTERVAL '0 minutes') AS bucket_time, SUM(value) AS total_value FROM test_data GROUP BY bucket_time ORDER BY bucket_time;
CREATE TABLE merge_test (t1_time TIMESTAMPTZ, t1_value INT, t2_time TIMESTAMPTZ, t2_value INT);
INSERT INTO merge_test VALUES (TIMESTAMPTZ '2023-10-01 01:00:00-07', 1, TIMESTAMPTZ '2023-10-01 01:05:00-07', 2);
INSERT INTO merge_test VALUES (TIMESTAMPTZ '2023-10-01 01:10:00-07', 3, TIMESTAMPTZ '2023-10-01 01:20:00-07', 4);
SELECT time_bucket(INTERVAL '5 minutes', t1.t1_time, INTERVAL '1 minute') AS t1_bucket, SUM(t1.t1_value) AS t1_sum, time_bucket(INTERVAL '5 minutes', t2.t2_time) AS t2_bucket, SUM(t2.t2_value) AS t2_sum FROM merge_test AS t1 FULL OUTER JOIN merge_test AS t2 ON t1.t1_time = t2.t2_time GROUP BY t1_bucket, t2_bucket;