CREATE TABLE dates_table (id INT, event_date DATE);
INSERT INTO dates_table VALUES (1, DATE '1992-02-15'), (2, DATE '2023-10-01'), (3, DATE '2023-10-07');
SELECT id, event_date, dayofweek(event_date) AS weekday FROM dates_table;
SELECT id, event_date, dayofweek(event_date) AS weekday FROM dates_table WHERE event_date BETWEEN DATE '1990-01-01' AND DATE '2023-12-31';
SELECT id, event_date, dayofweek(event_date) AS weekday FROM (SELECT * FROM dates_table WHERE id < 3) AS subquery;
CREATE TABLE holidays (holiday_name VARCHAR, holiday_date DATE);
INSERT INTO holidays VALUES ('New Year', DATE '2023-01-01'), ('Christmas', DATE '2023-12-25');
SELECT d.id, d.event_date, dayofweek(d.event_date) AS weekday, h.holiday_name FROM dates_table d LEFT JOIN holidays h ON d.event_date = h.holiday_date;
SELECT DISTINCT dayofweek(event_date) FROM dates_table HAVING dayofweek(event_date) IN (0, 6);
SELECT COUNT(*) AS weekend_count FROM dates_table WHERE dayofweek(event_date) BETWEEN 0 AND 6;
CREATE TABLE special_dates (date_special DATE);
INSERT INTO special_dates VALUES (DATE '1992-12-31'), (DATE '2024-01-01');
SELECT sd.date_special, dayofweek(sd.date_special) AS weekday FROM special_dates sd JOIN dates_table d ON dayofweek(sd.date_special) = dayofweek(d.event_date);