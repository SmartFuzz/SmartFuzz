CREATE TABLE test_dates (id INTEGER, event_date DATE, duration INTERVAL);
INSERT INTO test_dates (id, event_date, duration) VALUES (1, DATE '2023-01-01', INTERVAL '10 days'), (2, DATE '2023-12-31', INTERVAL '5 days'), (3, NULL, INTERVAL '1 day');
SELECT id, dayofyear(event_date + duration) AS day_of_year FROM test_dates WHERE event_date IS NOT NULL;
SELECT id, dayofyear(event_date + INTERVAL '5 days') AS day_plus_five, CASE WHEN event_date IS NOT NULL THEN dayofyear(event_date) END AS current_day FROM test_dates;
SELECT id, dayofyear(event_date) + 1 AS next_day FROM test_dates WHERE event_date IS NOT NULL UNION SELECT id, NULL FROM test_dates WHERE event_date IS NULL;
SELECT id, dayofyear(CAST(CONCAT(event_date, ' 00:00:00') AS TIMESTAMP)) + duration AS computed_day FROM test_dates WHERE duration IS NOT NULL;
SELECT event_date, duration, dayofyear(event_date + duration) AS future_day FROM test_dates WHERE event_date IS NOT NULL ORDER BY future_day DESC;
CREATE TABLE additional_dates (id INTEGER, event_date DATE);
INSERT INTO additional_dates (id, event_date) VALUES (1, DATE '2023-06-15'), (2, DATE '2023-06-16'), (3, DATE NULL);
SELECT a.id, a.event_date, dayofyear(a.event_date) + dayofyear(b.event_date) AS combined_days FROM additional_dates a JOIN test_dates b ON a.event_date < COALESCE(b.event_date, DATE '2023-01-01');
SELECT id, COALESCE(dayofyear(event_date), 0) + (SELECT COUNT(*) FROM additional_dates WHERE event_date IS NOT NULL) AS total_days FROM test_dates;