CREATE TABLE test_list (col1 ARRAY<Integer>);
INSERT INTO test_list VALUES (ARRAY[1, 2, 3]);
SELECT list_resize(col1, 5, 0) AS resized FROM test_list;
INSERT INTO test_list VALUES (ARRAY[10, 20]);
SELECT list_resize(col1, 3) AS resized_default FROM test_list;
SELECT list_resize(col1, 0) AS resized_empty FROM test_list;
SELECT list_resize(ARRAY[], 3, 5) AS resized_new_elements FROM test_list;
CREATE TABLE test_list2 (col2 ARRAY<Integer>);
INSERT INTO test_list2 VALUES (ARRAY[5, 10, 15, 20]);
SELECT list_resize(t1.col1, 4, t2.col2[2]) AS resized_combined FROM test_list t1 JOIN test_list2 t2 ON t1.col1[1] = 1;
SELECT list_resize(ARRAY[NULL, NULL], 4) AS resized_nulls FROM test_list;
SELECT list_resize(ARRAY[5, 6, 7], 2) AS resized_shrink FROM test_list;
SELECT list_resize(list_resize(ARRAY[1, 2, 3], 5, 0), 4) AS nested_resize FROM test_list;
CREATE TABLE test_list3 (id INTEGER, col1 ARRAY<Integer>);
INSERT INTO test_list3 VALUES (1, ARRAY[1, 2]), (2, ARRAY[3, 4, 5]);
SELECT id, list_resize(col1, 6, 99) AS resized_with_id FROM test_list3 WHERE id = 1;