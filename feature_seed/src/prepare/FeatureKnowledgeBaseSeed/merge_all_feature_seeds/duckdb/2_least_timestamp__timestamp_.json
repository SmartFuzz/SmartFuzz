CREATE TABLE test_timestamps (id INT PRIMARY KEY, ts1 TIMESTAMP, ts2 TIMESTAMP);
INSERT INTO test_timestamps (id, ts1, ts2) VALUES (1, TIMESTAMP '2023-01-01 10:00:00', TIMESTAMP '2023-01-02 10:00:00');
INSERT INTO test_timestamps (id, ts1, ts2) VALUES (2, TIMESTAMP '2023-01-01 08:00:00', TIMESTAMP '2023-01-02 09:00:00');
INSERT INTO test_timestamps (id, ts1, ts2) VALUES (3, TIMESTAMP '2023-01-01 08:00:00', TIMESTAMP NULL);
INSERT INTO test_timestamps (id, ts1, ts2) VALUES (4, TIMESTAMP '2023-01-01 10:00:00', TIMESTAMP '2024-01-02 07:30:00');
SELECT id, least(ts1, ts2) AS earliest_timestamp FROM test_timestamps WHERE least(ts1, ts2) IS NOT NULL;
SELECT id, least(ts1, ts2) AS earliest_timestamp, (5 / NULLIF(EXTRACT(HOUR FROM least(ts1, ts2)), 0)) AS division_result FROM test_timestamps;
SELECT id, least(ts1, ts2) AS earliest_timestamp, (5.0 / (EXTRACT(MINUTE FROM ts2) + 1)) AS scaled_minute FROM test_timestamps WHERE ts2 IS NOT NULL;
SELECT id, COUNT(*) FILTER (WHERE least(ts1, ts2) > TIMESTAMP '2023-01-01 09:00:00') AS count_after_nine FROM test_timestamps GROUP BY id HAVING count_after_nine >= 1;
WITH temp AS (SELECT id, least(ts1, ts2) AS min_ts FROM test_timestamps) SELECT *, (5.0 / COUNT(*) OVER (PARTITION BY id)) as partition_division FROM temp;
SELECT id, least(ts1, least(ts2, TIMESTAMP '2023-01-01 12:00:00')) AS latest_earliest FROM test_timestamps ORDER BY latest_earliest DESC;