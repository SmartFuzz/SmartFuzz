CREATE TABLE test_data (id INTEGER, value FLOAT, ts TIMESTAMPTZ);
INSERT INTO test_data (id, value, ts) VALUES (1, NULL, TIMESTAMPTZ '2023-01-01 10:00:00+00'), (2, 2.5, TIMESTAMPTZ '2023-10-01 12:00:00+00'), (3, 3.6, TIMESTAMPTZ '2023-11-01 14:00:00+00');
SELECT id, reservoir_quantile(value + COALESCE(value, 0), 0.5) OVER (PARTITION BY id) AS quantile_value FROM test_data;
SELECT id, value, ts + INTERVAL (reservoir_quantile(value, 0.75, 10) * 10) DAY AS adjusted_ts FROM test_data WHERE value IS NOT NULL;
SELECT t1.id, t1.value, t2.ts + INTERVAL 5 DAY AS future_ts FROM test_data t1 JOIN (SELECT id, reservoir_quantile(value, 0.9) AS quantile_result FROM test_data GROUP BY id HAVING quantile_result > 2) t2 ON t1.id = t2.id;
SELECT t.id, reservoir_quantile(value + 1.0, 0.5) AS quantile_val, COUNT(*) OVER (PARTITION BY t.id) AS count FROM test_data t WHERE t.value IS NOT NULL GROUP BY t.id;
CREATE TABLE another_test (id INTEGER PRIMARY KEY, created_at TIMESTAMPTZ DEFAULT NOW());
INSERT INTO another_test (id) SELECT id FROM test_data WHERE value IS NULL;
SELECT ts - INTERVAL (reservoir_quantile(value, 0.25) + 1) DAY AS past_ts FROM test_data ORDER BY past_ts;
SELECT id, COUNT(*) AS count, MAX(ts) + INTERVAL (reservoir_quantile(value, 0.9) * 2) DAY AS max_future_ts FROM test_data GROUP BY id HAVING count > 0;