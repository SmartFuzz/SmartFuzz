SELECT yearweek(test_date) FROM test_dates WHERE test_date IS NOT NULL;
SELECT d1.test_date, d2.test_date, yearweek(d1.test_date) AS year_week_d1, yearweek(d2.test_date) AS year_week_d2 FROM test_dates d1 JOIN test_dates d2 ON d1.id != d2.id;
SELECT id, yearweek(test_date) AS year_week FROM test_dates WHERE yearweek(test_date) BETWEEN 202002 AND 202103;
SELECT id, test_date FROM test_dates WHERE yearweek(test_date) = (SELECT yearweek(min(test_date)) FROM test_dates);
WITH date_stats AS (SELECT yearweek(test_date) AS year_week, COUNT(*) AS count FROM test_dates GROUP BY year_week) SELECT year_week, count FROM date_stats WHERE count > 1;
SELECT id, yearweek(test_date) FROM test_dates ORDER BY yearweek(test_date) DESC LIMIT 5;
SELECT d1.id FROM test_dates d1 WHERE yearweek(d1.test_date) = (SELECT yearweek(d2.test_date) FROM test_dates d2 WHERE d2.id = 4);
DROP TABLE test_dates;