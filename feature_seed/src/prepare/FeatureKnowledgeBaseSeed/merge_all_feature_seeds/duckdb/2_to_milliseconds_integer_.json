CREATE TABLE test_data (id INTEGER, duration INTEGER, value STRING);
INSERT INTO test_data VALUES (1, 5000, 'test1'), (2, 10000, NULL), (3, 15000, 'test3');
CREATE TABLE join_data (id INTEGER, related_value STRING);
INSERT INTO join_data VALUES (1, 'related1'), (2, 'related2');
SELECT A.id, A.duration // 1000 AS seconds, to_milliseconds(A.duration) AS milliseconds FROM test_data A JOIN join_data B ON A.id = B.id WHERE A.value IS NOT NULL;
SELECT id, SUM(duration // 1000) AS total_seconds FROM test_data GROUP BY id HAVING total_seconds > 1;
SELECT id, COUNT(*) OVER (PARTITION BY value) AS value_count, to_milliseconds(duration // 2) AS half_milliseconds FROM test_data WHERE duration < 10000;
WITH RECURSIVE temp AS (SELECT 1 AS n UNION ALL SELECT n + 1 FROM temp WHERE n < 5) SELECT to_milliseconds(SUM(n * 1000)) // 1000 AS total_seconds FROM temp;
SELECT A.id, A.duration // 3 AS third_duration FROM test_data A WHERE EXISTS (SELECT 1 FROM join_data B WHERE A.id = B.id AND B.related_value IS NOT NULL);
SELECT A.id, COALESCE(A.duration // NULLIF(A.duration, 0), 0) AS safe_division FROM test_data A;
CREATE TEMPORARY TABLE edge_cases (value VARCHAR(10));
INSERT INTO edge_cases VALUES (''), (NULL), ('boundary'), ('longstring'), ('12345');
SELECT value, to_milliseconds(LENGTH(value) // 2) AS half_length_milliseconds FROM edge_cases WHERE value IS NOT NULL OR value = '';