CREATE TABLE test_values (value FLOAT);
INSERT INTO test_values VALUES (0.0), (0.5), (1.0), (-0.5), (-1.0);
SELECT value, asin(value) AS arcsine_value FROM test_values;
SELECT value, asin(value) AS arcsine_value FROM test_values WHERE value BETWEEN -1 AND 1;
CREATE TABLE additional_values (id INT, value FLOAT);
INSERT INTO additional_values VALUES (1, 0.2), (2, 0.9), (3, -0.2);
SELECT t1.value, asin(t1.value) AS arcsine_t1, t2.asin AS arcsine_t2 FROM test_values t1 JOIN (SELECT value, asin(value) AS asin FROM additional_values) t2 ON t1.value = t2.value;
SELECT value, asin(value) * 180 / PI() AS arcsine_degrees FROM test_values;
SELECT (SELECT asin(value) FROM test_values WHERE value = 0.5) AS arcsine_subquery;
SELECT value, asin(value) AS arcsine_value FROM test_values WHERE value IN (SELECT value FROM additional_values);
SELECT asin(COALESCE(NULLIF(value, 0), 0.5)) AS arcsine_value FROM test_values;
SELECT value, asin(value) AS arcsine_value FROM test_values ORDER BY value DESC;