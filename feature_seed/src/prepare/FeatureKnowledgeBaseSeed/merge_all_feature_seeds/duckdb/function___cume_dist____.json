CREATE TABLE sales (id INT, amount DOUBLE, region VARCHAR);
INSERT INTO sales VALUES (1, 200.00, 'North'), (2, 150.00, 'South'), (3, 300.00, 'East'), (4, 250.00, 'West'), (5, 100.00, 'North');
SELECT id, amount, cume_dist() OVER (ORDER BY amount) AS cumulative_distribution FROM sales;
CREATE TABLE employees (id INT, salary DOUBLE, department VARCHAR);
INSERT INTO employees VALUES (1, 60000, 'HR'), (2, 80000, 'IT'), (3, 40000, 'Finance'), (4, 70000, 'Finance'), (5, 90000, 'IT');
SELECT department, salary, cume_dist() OVER (PARTITION BY department ORDER BY salary) AS salary_cumulative_distribution FROM employees;
CREATE TABLE departments (dept_id INT, dept_name VARCHAR);
INSERT INTO departments VALUES (1, 'HR'), (2, 'IT'), (3, 'Finance');
SELECT e.id, e.salary, d.dept_name, cume_dist() OVER (PARTITION BY d.dept_name ORDER BY e.salary) AS dept_salary_dist FROM employees e JOIN departments d ON e.department = d.dept_name;
CREATE TABLE products (product_id INT, price DOUBLE, category VARCHAR);
INSERT INTO products VALUES (1, 10.00, 'Electronics'), (2, 20.00, 'Electronics'), (3, 15.00, 'Books'), (4, 25.00, 'Books');
SELECT p.product_id, p.price, p.category, cume_dist() OVER (PARTITION BY p.category ORDER BY p.price) AS category_price_dist FROM products p;
SELECT sales.id, sales.amount, cume_dist() OVER (ORDER BY sales.amount) AS overall_distribution FROM (SELECT * FROM sales ORDER BY region) AS sales;
SELECT e.id, e.salary, cume_dist() OVER (ORDER BY e.salary) AS overall_salary_distribution FROM (SELECT * FROM employees WHERE salary > 50000) AS e;