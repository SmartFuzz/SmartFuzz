CREATE TABLE test_strings (id INT, str_val TEXT);
INSERT INTO test_strings (id, str_val) VALUES (1, 'Hello'), (2, 'World'), (3, NULL);
CREATE TABLE numbers (num_id INT, num_val FLOAT);
INSERT INTO numbers (num_id, num_val) VALUES (1, 2.5), (2, 3.5), (3, NULL), (4, 4.0);
SELECT id, repeat(str_val, (num_val ** 2)) AS repeated_string FROM test_strings JOIN numbers ON test_strings.id = numbers.num_id WHERE str_val IS NOT NULL;
SELECT id, SUM(num_val) AS total_num, repeat(str_val, 3) AS repeated_str FROM test_strings LEFT JOIN numbers ON test_strings.id = numbers.num_id GROUP BY id, str_val HAVING total_num > 10;
SELECT id, repeat(repeat(str_val, 2), (3 ** 2)) AS complex_repeat FROM test_strings WHERE id IN (SELECT DISTINCT num_id FROM numbers WHERE num_val IS NOT NULL);
SELECT id, str_val, repeat(str_val, MAX(num_val)) AS repeat_combination FROM test_strings JOIN numbers ON test_strings.id = numbers.num_id GROUP BY id, str_val HAVING repeat(str_val, MAX(num_val)) IS NOT NULL;
SELECT id, repeat(COALESCE(str_val, ''), 5) AS repeat_null_handling FROM test_strings;
SELECT id, repeat('Test ' || repeat(str_val, 2), (2 ** 3)) AS nested_repeat FROM test_strings WHERE id < 3 ORDER BY id DESC;