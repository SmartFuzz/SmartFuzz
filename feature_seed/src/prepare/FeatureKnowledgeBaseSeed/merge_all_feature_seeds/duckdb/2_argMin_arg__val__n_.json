CREATE TABLE test_table (id INT, value FLOAT, category STRING, created_at TIMESTAMP);
INSERT INTO test_table VALUES (1, 10.5, 'A', '2023-01-01 00:00:00'), (2, 15.75, 'B', '2023-01-02 00:00:00'), (3, NULL, 'C', '2023-01-03 00:00:00'), (4, 8.25, 'A', '2023-01-04 00:00:00'), (5, 20.0, 'B', '2023-01-05 00:00:00');
SELECT argMin(value, id, 3) || [NULL, 25.0, 30.5] FROM test_table GROUP BY category HAVING COUNT(id) > 1;
SELECT category, argMin(value, id, 2) || [MAX(value) OVER (PARTITION BY category ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING] ] AS result FROM test_table GROUP BY category;
SELECT argMin(value, id, 2) || [created_at::STRING, 'InvalidDate'] FROM test_table WHERE created_at IS NOT NULL;
SELECT (argMin(value, id, 2) || [id]) AS combined FROM (SELECT id, value FROM test_table WHERE value IS NOT NULL) AS sub;
SELECT category, argMin(value, id + 5, 2) || [created_at] FROM test_table WHERE category IS NOT NULL GROUP BY category HAVING COUNT(*) > 0;
CREATE TABLE temp_table AS SELECT category, argMin(value, id, 1) AS min_val FROM test_table GROUP BY category;
SELECT A.category || B.category, argMin(A.value, A.id, 2) FROM test_table A JOIN test_table B ON A.category != B.category WHERE A.value IS NOT NULL GROUP BY A.category, B.category;