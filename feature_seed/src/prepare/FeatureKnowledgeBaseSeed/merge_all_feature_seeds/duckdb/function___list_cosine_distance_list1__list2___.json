CREATE TABLE test_lists (list1 ARRAY<FLOAT>, list2 ARRAY<FLOAT>);
INSERT INTO test_lists VALUES ([1, 2, 3], [1, 2, 5]);
INSERT INTO test_lists VALUES ([0, 0, 0], [0, 0, 0]);
INSERT INTO test_lists VALUES ([1, -1, 2], [2, -1, 1]);
INSERT INTO test_lists VALUES ([1, 2, 3, 4], [3, 2, 1, 0]);
INSERT INTO test_lists VALUES (NULL, [1, 2, 3]);
INSERT INTO test_lists VALUES ([1, 2, 3], NULL);
INSERT INTO test_lists VALUES ([1, 2, 3], ['string', 2, 5]);
INSERT INTO test_lists VALUES ([1, 2, 3], [1, 2]);
SELECT list_cosine_distance(list1, list2) FROM test_lists;
SELECT AVG(list_cosine_distance(list1, list2)) FROM test_lists;
SELECT COUNT(*) FROM test_lists WHERE list_cosine_distance(list1, list2) < 0.5;
SELECT list_cosine_distance(a.list1, b.list2) FROM (SELECT list1 FROM test_lists WHERE list1 IS NOT NULL) AS a JOIN (SELECT list2 FROM test_lists WHERE list2 IS NOT NULL) AS b ON a.list1 != b.list2;
CREATE TABLE more_lists (list1 ARRAY<FLOAT>);
INSERT INTO more_lists VALUES ([1, 2, 3]), ([4, 5, 6]);
SELECT list_cosine_distance(l.list1, ml.list1) FROM test_lists l JOIN more_lists ml ON l.list1[1] = ml.list1[1];