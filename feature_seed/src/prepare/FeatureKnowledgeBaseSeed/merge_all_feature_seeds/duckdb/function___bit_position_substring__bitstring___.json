CREATE TABLE bits_table (id INTEGER, bitstring BIT(10));
INSERT INTO bits_table VALUES (1, '1110101'::BITSTRING), (2, '1010101'::BITSTRING), (3, '0000000'::BITSTRING);
SELECT bit_position('010'::BITSTRING, bitstring) FROM bits_table WHERE id = 1;
SELECT bit_position('111'::BITSTRING, bitstring) FROM bits_table WHERE id = 2;
SELECT bit_position('000'::BITSTRING, bitstring) AS pos FROM bits_table WHERE id = 3;
SELECT id, bit_position('111'::BITSTRING, bitstring) FROM bits_table WHERE bitstring LIKE '111%';
WITH temp AS (SELECT id, bitstring FROM bits_table WHERE id IN (1, 2)) SELECT id, bit_position('010'::BITSTRING, bitstring) FROM temp;
CREATE TABLE other_bits (group_id INTEGER, bitstring BIT(10));
INSERT INTO other_bits VALUES (1, '0101010101'::BITSTRING), (2, '1011101010'::BITSTRING);
SELECT b.id, bit_position('010'::BITSTRING, b.bitstring) FROM bits_table b JOIN other_bits o ON b.id = o.group_id WHERE o.bitstring = '0101010101'::BITSTRING;
SELECT bit_position('101'::BITSTRING, '00000000'::BITSTRING) AS position_not_found;
SELECT bit_position('010'::BITSTRING, '1101010101'::BITSTRING) AS position_found;
SELECT COUNT(*) FROM bits_table WHERE bit_position('010'::BITSTRING, bitstring) > 0;
SELECT id, bit_position('1'::BITSTRING, bitstring) FROM bits_table WHERE id IN (SELECT id FROM bits_table WHERE id > 1);