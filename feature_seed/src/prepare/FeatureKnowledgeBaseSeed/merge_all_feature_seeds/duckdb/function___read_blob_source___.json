CREATE TABLE test_blobs (filename VARCHAR, blob_data BLOB);
INSERT INTO test_blobs VALUES ('test_blob1.bin', read_blob('test_blob1.bin'));
INSERT INTO test_blobs VALUES ('test_blob2.bin', read_blob('test_blob2.bin'));
INSERT INTO test_blobs VALUES ('test_blob3.bin', read_blob('test_blob3.bin'));
INSERT INTO test_blobs SELECT 'test_blob4.bin', read_blob(filename) FROM test_blobs WHERE filename LIKE 'test_blob%.bin';
SELECT filename FROM test_blobs WHERE LENGTH(blob_data) > 0;
SELECT filename, LENGTH(blob_data) FROM test_blobs WHERE LENGTH(blob_data) IS NOT NULL;
CREATE TABLE other_test (file_pattern VARCHAR);
INSERT INTO other_test VALUES ('test_blob*.bin');
SELECT DISTINCT filename FROM test_blobs WHERE filename IN (SELECT file_pattern FROM other_test);
SELECT COUNT(*) AS blob_count FROM test_blobs WHERE LENGTH(blob_data) < 1000;
SELECT blob_data FROM test_blobs WHERE blob_data IS NOT NULL AND filename = 'test_blob1.bin';
DELETE FROM test_blobs WHERE filename = 'test_blob2.bin';
SELECT * FROM test_blobs WHERE filename NOT IN (SELECT filename FROM test_blobs WHERE LENGTH(blob_data) = 0);
SELECT b1.filename, b2.filename FROM test_blobs b1 JOIN test_blobs b2 ON b1.filename <> b2.filename WHERE LENGTH(b1.blob_data) < LENGTH(b2.blob_data);
SELECT read_blob('non_existent_file.bin');