CREATE TABLE test_map (id INTEGER, data MAP(VARCHAR, INTEGER));
INSERT INTO test_map VALUES (1, MAP {'key1': 10, 'key2': 20});
INSERT INTO test_map VALUES (2, MAP {'keyA': 5, 'keyB': 15, 'keyC': 25});
INSERT INTO test_map VALUES (3, MAP {'keyX': 1});
SELECT data['key1'] FROM test_map WHERE id = 1;
SELECT data['keyB'][1] FROM test_map WHERE id = 2;
SELECT data['key1'] FROM test_map WHERE id = 3;
SELECT element_at(data, 'keyC') FROM test_map WHERE id = 2;
CREATE TABLE another_table (map_data MAP(INTEGER, DOUBLE));
INSERT INTO another_table VALUES (MAP {1: 1.1, 2: 2.2});
SELECT a.map_data[1], b.data['key2'] FROM another_table a JOIN test_map b ON a.map_data[1] < b.data['key1'][1];
SELECT COUNT(*) FROM test_map WHERE data['key1'] IS NOT NULL;
SELECT data['keyA'] FROM test_map WHERE data['keyC'] IS NULL;
SELECT DISTINCT data['key2'] FROM test_map WHERE id IN (SELECT id FROM test_map WHERE data['keyB'] IS NOT NULL);
SELECT data['keyZ'] FROM test_map WHERE id = 1;
CREATE TABLE complex_map (m MAP(VARCHAR, MAP(INTEGER, DOUBLE)));
INSERT INTO complex_map VALUES (MAP {'outer_key': MAP {1: 1.0, 2: 2.0}});
SELECT m['outer_key'][1] FROM complex_map;
SELECT m['outer_key'] FROM complex_map WHERE m['outer_key'][2] IS NOT NULL;
CREATE TABLE nested_table (nested_col MAP(VARCHAR, MAP(VARCHAR, INTEGER)));
INSERT INTO nested_table VALUES (MAP {'layer1': MAP {'inner1': 100, 'inner2': 200}});
SELECT nested_col['layer1']['inner2'] FROM nested_table;
SELECT CASE WHEN nested_col['layer1']['innerX'] IS NULL THEN 'Not Found' ELSE 'Found' END FROM nested_table;