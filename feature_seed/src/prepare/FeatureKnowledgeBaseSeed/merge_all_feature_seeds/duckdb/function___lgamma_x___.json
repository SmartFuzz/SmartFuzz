CREATE TABLE test_values (input FLOAT);
INSERT INTO test_values VALUES (0.5), (1.0), (2.0), (3.5), (10.0), (-1.0), (-0.5), (1e-5);
SELECT input, lgamma(input) FROM test_values;
SELECT input, lgamma(input) FROM test_values WHERE input > 0;
SELECT input, lgamma(input) FROM test_values WHERE input BETWEEN 1 AND 3;
SELECT t1.input, lgamma(t1.input) + lgamma(t2.input) AS combined_lgamma FROM test_values t1 JOIN test_values t2 ON t1.input < t2.input;
WITH lgamma_results AS (SELECT input, lgamma(input) AS gamma_val FROM test_values) SELECT AVG(gamma_val) FROM lgamma_results;
CREATE TABLE additional_values (num FLOAT);
INSERT INTO additional_values VALUES (-2.0), (-3.5);
SELECT input, lgamma(input) FROM test_values UNION SELECT num, lgamma(num) FROM additional_values;
SELECT lgamma(lgamma(input)) FROM test_values WHERE input > 2;
SELECT input, lgamma(input) AS gamma_val FROM (SELECT input FROM test_values WHERE input > 0.1) AS positive_inputs;