CREATE TABLE test_table (id INTEGER, text_field VARCHAR, numeric_field FLOAT);
INSERT INTO test_table VALUES (1, '>>>>test1<<', 3.5), (2, '----test2----', -1.2), (3, '****test3****', NULL);
SELECT id, trim(text_field, '><') AS trimmed_text, numeric_field - 2 AS adjusted_numeric FROM test_table WHERE trim(text_field, '><') IS NOT NULL;
SELECT t1.id, trim(t1.text_field, '-') AS trimmed_text, (SELECT AVG(numeric_field) FROM test_table WHERE numeric_field IS NOT NULL) - t1.numeric_field AS difference FROM test_table t1 HAVING difference > 0;
SELECT id, trim(text_field, '*-<>') AS cleaned_text FROM (SELECT id, text_field, numeric_field FROM test_table WHERE numeric_field IS NOT NULL) AS sub ORDER BY cleaned_text;
CREATE TABLE join_table (join_id INTEGER, foreign_key INTEGER, join_text VARCHAR);
INSERT INTO join_table VALUES (1, 1, '~~~join1~~~'), (2, 2, '~~~join2~~~');
SELECT t.id, trim(t.text_field, '*') AS left_trimmed, jt.join_text FROM test_table t JOIN join_table jt ON t.id = jt.foreign_key AND trim(jt.join_text, '~') <> '' ORDER BY t.id;
SELECT id, SUM(numeric_field - 1) AS total_adjusted FROM test_table GROUP BY id HAVING total_adjusted >= 0;
SELECT id, CASE WHEN trim(text_field, '>') IS NULL THEN 'Empty' ELSE trim(text_field, '>') END AS case_trimmed FROM test_table WHERE numeric_field IS NOT NULL;