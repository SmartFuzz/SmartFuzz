CREATE TABLE dates (event_name VARCHAR, event_date DATE);
INSERT INTO dates VALUES ('Birthday', DATE '1992-09-20');
INSERT INTO dates VALUES ('Graduation', DATE '2010-05-15');
INSERT INTO dates VALUES ('Anniversary', DATE '2015-08-30');
SELECT event_name, extract('year' FROM event_date) AS year FROM dates;
SELECT event_name, extract('month' FROM event_date) AS month FROM dates;
SELECT event_name, extract('day' FROM event_date) AS day FROM dates;
SELECT event_name, extract('year' FROM event_date) AS year FROM dates WHERE event_date < DATE '2000-01-01';
SELECT event_name, extract('year' FROM event_date) AS year FROM dates ORDER BY year DESC;
SELECT event_name, extract('year' FROM subquery.event_date) AS year FROM (SELECT event_date FROM dates WHERE event_name LIKE 'B%') AS subquery;
SELECT event_name, extract('year' FROM event_date) AS year FROM dates WHERE event_date BETWEEN DATE '1990-01-01' AND DATE '2020-01-01';
CREATE TABLE events (id INT, event_date DATE, venue VARCHAR);
INSERT INTO events VALUES (1, DATE '1992-09-20', 'Stadium A'), (2, DATE '2010-05-15', 'Stadium B'), (3, DATE '2015-08-30', 'Stadium C');
SELECT e.id, extract('year' FROM e.event_date) AS year, d.event_name FROM events e JOIN dates d ON e.event_date = d.event_date;
SELECT e.id, d.event_name, extract('year' FROM e.event_date) AS year FROM events e LEFT JOIN dates d ON e.event_date = d.event_date WHERE extract('month' FROM e.event_date) = 5;
SELECT DISTINCT extract('year' FROM event_date) AS year FROM dates WHERE event_date IS NOT NULL;
SELECT event_name, COUNT(*) AS occurrences FROM dates GROUP BY event_name HAVING extract('year' FROM event_date) >= 2010;