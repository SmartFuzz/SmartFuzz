CREATE TABLE numbers (a INT, b INT);
INSERT INTO numbers VALUES (8, 3), (15, 4), (100, 6), (13, 5);
SELECT a, b, a % b AS remainder FROM numbers;
SELECT (SELECT a FROM numbers WHERE a = 8) % (SELECT b FROM numbers WHERE b = 3) AS remainder;
SELECT (15 + 5) % 4 AS modified_remainder;
SELECT a, b, (a + b) % 5 AS total_remainder FROM numbers;
SELECT n1.a, n2.b, (n1.a % n2.b) AS remainder FROM numbers n1 JOIN numbers n2 ON n1.a > n2.b;
CREATE TABLE more_numbers (c INT, d INT);
INSERT INTO more_numbers VALUES (20, 7), (25, 10), (30, 12);
SELECT n.a, m.c, n.a % m.c AS remainder FROM numbers n JOIN more_numbers m ON n.a > m.c;
SELECT MAX(a % b) AS max_remainder FROM numbers;