CREATE TABLE test_dates (event_id INT, event_date DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-09-20'), (2, DATE '2000-02-29'), (3, DATE '2023-01-01'), (4, DATE '2023-12-31');
SELECT event_id, dayname(event_date) FROM test_dates;
SELECT dayname(DATE '1970-01-01') AS start_of_epoch, dayname(DATE '2038-01-19') AS end_of_epoch;
SELECT event_id, event_date, dayname(event_date) FROM test_dates WHERE event_date BETWEEN DATE '1992-01-01' AND DATE '2023-12-31';
CREATE TABLE weekdays AS SELECT event_id, dayname(event_date) AS weekday FROM test_dates;
SELECT t.event_id, t.event_date, w.weekday FROM test_dates t JOIN weekdays w ON t.event_id = w.event_id WHERE w.weekday = 'Monday';
SELECT dayname(DATE '9999-12-31') AS far_future, dayname(DATE '0001-01-01') AS far_past;
SELECT DISTINCT dayname(event_date) FROM test_dates ORDER BY dayname(event_date);
WITH weekday_counts AS (SELECT dayname(event_date) AS weekday, COUNT(*) AS count FROM test_dates GROUP BY weekday) SELECT * FROM weekday_counts WHERE count > 1;