CREATE SCHEMA test_schema1;
CREATE SCHEMA test_schema2;
CREATE SCHEMA implicit_schema1;
CREATE TABLE test_schema1.table1 (id INTEGER, name VARCHAR);
CREATE TABLE test_schema2.table2 (id INTEGER, description VARCHAR);
INSERT INTO test_schema1.table1 VALUES (1, 'Alice');
INSERT INTO test_schema1.table1 VALUES (2, 'Bob');
INSERT INTO test_schema2.table2 VALUES (1, 'Description1');
INSERT INTO test_schema2.table2 VALUES (2, 'Description2');
SELECT current_schemas(true);
SELECT (SELECT COUNT(*) FROM current_schemas(true) WHERE schema_name LIKE 'test_%') AS test_schema_count;
WITH schemas AS (SELECT * FROM current_schemas(true)) SELECT COUNT(*) FROM schemas WHERE schema_name = 'test_schema1';
SELECT DISTINCT schema_name FROM (SELECT * FROM current_schemas(true) UNION SELECT * FROM current_schemas(false)) AS all_schemas;
SELECT * FROM (SELECT schema_name FROM current_schemas(true) WHERE schema_name IS NOT NULL) AS non_null_schemas WHERE schema_name LIKE '%schema%';
SELECT COUNT(*) FROM current_schemas(true) WHERE schema_name IN (SELECT DISTINCT schema_name FROM current_schemas(false));