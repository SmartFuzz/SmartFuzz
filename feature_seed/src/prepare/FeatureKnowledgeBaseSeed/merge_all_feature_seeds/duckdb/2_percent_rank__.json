CREATE TABLE test_data (id INTEGER PRIMARY KEY, value DOUBLE, str_value VARCHAR, date_value DATE);
INSERT INTO test_data (id, value, str_value, date_value) VALUES (1, 10.0, 'A', '2023-01-01'), (2, 20.0, 'B', NULL), (3, NULL, 'C', '2023-03-01'), (4, 30.0, 'D', '2023-04-01');
SELECT id, value, percent_rank() OVER (PARTITION BY str_value ORDER BY value) as rank_value FROM test_data WHERE (id >> 1) IS NOT NULL;
SELECT id, str_value, percent_rank() OVER (ORDER BY value) as rank_value FROM test_data WHERE (value >> 1) < 15.0;
SELECT id, value, (percent_rank() OVER (PARTITION BY id ORDER BY value) * 100) >> 2 as scaled_rank FROM test_data;
SELECT id, percent_rank() OVER (ORDER BY str_value) AS rnk FROM (SELECT id, str_value FROM test_data WHERE str_value IS NOT NULL) sub;
SELECT id, (value >> 1) as shifted_value FROM test_data GROUP BY shifted_value HAVING percent_rank() OVER (ORDER BY id) IS NOT NULL;
SELECT a.id, a.value, b.str_value FROM test_data a JOIN test_data b ON (a.id >> 1) = (b.id >> 1) WHERE percent_rank() OVER (ORDER BY a.value) > 0.5;
SELECT id, (percent_rank() OVER (ORDER BY (value >> 1) + COALESCE(NULLIF(str_value, ''), '0'::VARCHAR)::DOUBLE)) AS rank_value FROM test_data;
CREATE TABLE temp_data (temp_id INTEGER, temp_value DOUBLE);
INSERT INTO temp_data (temp_id, temp_value) VALUES (1, NULL), (2, 25.0), (3, 15.0);
SELECT a.temp_id, percent_rank() OVER (ORDER BY a.temp_value) as temp_rank FROM test_data a JOIN temp_data b ON a.value >> 1 = b.temp_value WHERE b.temp_value IS NOT NULL;