CREATE TABLE sales (id INT, amount FLOAT);
INSERT INTO sales VALUES (1, 100.0), (2, 200.0), (3, 150.0), (4, 300.0), (5, 250.0);
SELECT id, amount, ntile(3) OVER (ORDER BY amount) AS bucket FROM sales;
CREATE TABLE employees (id INT, department_id INT, name VARCHAR);
INSERT INTO employees VALUES (1, 1, 'Alice'), (2, 1, 'Bob'), (3, 2, 'Charlie'), (4, 2, 'David');
SELECT e.name, ntile(2) OVER (PARTITION BY e.department_id ORDER BY e.id) AS dept_bucket FROM employees e;
SELECT e.department_id, ntile(2) OVER (ORDER BY e.id) AS bucket FROM employees e WHERE e.id IS NOT NULL;
CREATE TABLE ordered_sales AS SELECT id, amount FROM sales ORDER BY amount;
SELECT id, amount, ntile(2) OVER (ORDER BY id) AS bucket FROM ordered_sales;
WITH ranked_sales AS (SELECT id, amount, ntile(4) OVER (ORDER BY amount DESC) AS rank FROM sales) SELECT * FROM ranked_sales WHERE rank = 1;
SELECT e.id, e.name, ntile(3) OVER (PARTITION BY e.department_id ORDER BY e.name) AS name_bucket FROM employees e JOIN sales s ON e.id = s.id;
SELECT s.amount, ntile(4) OVER (ORDER BY s.amount) AS amount_bucket FROM sales s WHERE s.amount > 100.0;
SELECT ntile(2) OVER (ORDER BY e.name) AS name_buckets FROM employees e GROUP BY e.department_id;
CREATE TABLE test_table AS SELECT ntile(5) OVER (ORDER BY amount) AS test_ntile FROM sales;
SELECT id, amount, ntile(1) OVER (ORDER BY amount) AS single_bucket FROM sales;
SELECT ntile(10) OVER (ORDER BY random()) AS random_bucket FROM (SELECT random() AS random_val FROM sales LIMIT 100) AS random_table;