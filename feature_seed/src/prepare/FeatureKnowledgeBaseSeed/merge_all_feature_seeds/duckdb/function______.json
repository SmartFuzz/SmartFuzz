CREATE TABLE test_abs (value FLOAT);
INSERT INTO test_abs VALUES (-17.4), (0), (15.6), (-3.14), (2.718), (-0.5);
SELECT value, abs(value) AS absolute_value FROM test_abs;
SELECT MAX(abs(value)) AS max_absolute FROM test_abs;
SELECT AVG(abs(value)) AS avg_absolute FROM test_abs;
SELECT COUNT(*) FROM test_abs WHERE abs(value) > 10;
CREATE TABLE other_values (another_value FLOAT);
INSERT INTO other_values VALUES (-20.0), (3.5), (0.0);
SELECT a.value, b.another_value, abs(a.value + b.another_value) AS combined_abs FROM test_abs a JOIN other_values b ON a.value + b.another_value < 0;
SELECT value, abs(value) AS absolute_value FROM (SELECT value FROM test_abs WHERE value < 0 UNION SELECT value FROM test_abs WHERE value >= 0) AS sub;
SELECT SUM(abs(value)) FROM (SELECT value FROM test_abs WHERE value <> 0) AS non_zero_values;