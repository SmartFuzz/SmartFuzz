CREATE TABLE test_strings (id INTEGER, value VARCHAR);
INSERT INTO test_strings VALUES (1, 'abc'), (2, 'def'), (3, 'ghc'), (4, 'abcde');
SELECT ends_with(value, 'c') FROM test_strings WHERE id IN (1, 3);
SELECT id, value, ends_with(value, 'c') AS ends_with_c FROM test_strings;
CREATE TABLE additional_strings (id INTEGER, suffix VARCHAR);
INSERT INTO additional_strings VALUES (1, 'c'), (2, 'e'), (3, 'f');
SELECT ts.id, ts.value, ends_with(ts.value, as.suffix) FROM test_strings ts JOIN additional_strings as ON ts.id = as.id;
SELECT ts.id, ts.value, ends_with(value, (SELECT suffix FROM additional_strings WHERE id = 2)) AS ends_with_e FROM test_strings ts;
SELECT id, value FROM test_strings WHERE ends_with(value, 'c') OR ends_with(value, 'e');
CREATE TABLE complex_test (id INTEGER, part VARCHAR);
INSERT INTO complex_test VALUES (1, 'abc'), (2, 'ab'), (3, 'bc'), (4, 'abcdef');
SELECT ct.id, ct.part, ends_with(ct.part, (SELECT suffix FROM additional_strings WHERE id = 1)) AS is_end_with_c FROM complex_test ct WHERE id < 4;
SELECT ct.*, ends_with(part, 'bc') AND ends_with(part, 'c') AS complex_check FROM complex_test ct WHERE id > 1;
SELECT COUNT(*) FROM test_strings WHERE ends_with(value, 'abc') OR ends_with(value, 'de');