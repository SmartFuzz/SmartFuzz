CREATE TABLE integers (i INTEGER);
INSERT INTO integers VALUES (NULL);
INSERT INTO integers VALUES (1), (2), (NULL), (4);
SELECT COUNT(*) FROM integers WHERE i IS NULL;
SELECT COUNT(*) FROM integers WHERE i IS NOT NULL;
SELECT AVG(i) FROM integers;
SELECT MIN(i), MAX(i) FROM integers;
SELECT i IS NULL AS is_null FROM integers;
SELECT i IS NOT DISTINCT FROM NULL FROM integers;
SELECT CASE WHEN i IS NULL THEN 'Value is NULL' ELSE 'Value is not NULL' END AS value_status FROM integers;
CREATE TABLE users (id INTEGER, name VARCHAR, email VARCHAR);
INSERT INTO users VALUES (1, 'Alice', NULL), (2, NULL, 'bob@example.com'), (3, NULL, NULL);
SELECT * FROM users WHERE email IS NULL;
SELECT COUNT(*) FROM users WHERE name IS NOT NULL;
SELECT DISTINCT name FROM users WHERE name IS NOT NULL;
CREATE TABLE transactions (user_id INTEGER, amount DECIMAL);
INSERT INTO transactions VALUES (1, 100.50), (2, 200.75), (NULL, 150.00);
SELECT SUM(amount) FROM transactions WHERE user_id IS NOT NULL;
SELECT COUNT(*) FROM transactions WHERE user_id IS NULL AND amount IS NOT NULL;
CREATE TABLE orders (order_id INTEGER, user_id INTEGER, total DECIMAL);
INSERT INTO orders VALUES (1, 1, 50.00), (2, NULL, 75.00), (3, NULL, NULL);
SELECT user_id, SUM(total) AS total_spent FROM orders GROUP BY user_id;
SELECT u.name, COALESCE(t.amount, 0) AS amount FROM users u LEFT JOIN transactions t ON u.id = t.user_id;
SELECT u.id FROM users u LEFT JOIN transactions t ON u.id = t.user_id WHERE t.user_id IS NULL;
CREATE TABLE settings (key VARCHAR, value VARCHAR);
INSERT INTO settings VALUES ('theme', NULL), ('language', 'English');
SELECT key, IFNULL(value, 'default_value') AS value FROM settings;
SELECT s.key, COALESCE(s.value, 'default') AS setting_value FROM settings s;
SELECT COUNT(DISTINCT user_id) AS unique_users FROM transactions WHERE user_id IS NOT NULL AND amount IS NOT NULL;
SELECT DISTINCT u.name, o.order_id FROM users u LEFT JOIN orders o ON u.id = o.user_id WHERE o.user_id IS NOT DISTINCT FROM NULL;