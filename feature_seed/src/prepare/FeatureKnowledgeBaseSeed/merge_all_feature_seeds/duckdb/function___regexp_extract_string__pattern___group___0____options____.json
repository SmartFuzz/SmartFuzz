CREATE TABLE test_strings (id INT, str VARCHAR);
INSERT INTO test_strings VALUES (1, 'abc'), (2, 'aabbcc'), (3, 'ab123'), (4, '12345'), (5, 'xyz'), (6, '');
SELECT regexp_extract(str, '([a-z])([a-z])', 1) FROM test_strings;
SELECT id, regexp_extract(str, '([a-z])(b)', 1) AS extracted_group FROM test_strings WHERE str IS NOT NULL;
SELECT id, regexp_extract(str, '^([0-9]+)(.*)', 1) AS leading_digits FROM test_strings WHERE str LIKE '1%';
SELECT id, regexp_extract(str, '([a-z]+)', 0) AS first_match FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE str LIKE '%a%');
SELECT id, regexp_extract(str, '(.*)(abc)(.*)', 2) AS middle_part FROM test_strings WHERE str LIKE '%abc%';
SELECT id, regexp_extract(str, '[0-9]+', 0) AS number_found FROM test_strings WHERE str REGEXP '[0-9]';
SELECT id, regexp_extract(str, '([0-9]+)-([0-9]+)', 2) FROM (SELECT '12-34' AS str UNION ALL SELECT '56-78') AS temp;
SELECT id, regexp_extract(str, '[a-z]+', 0) AS full_match FROM test_strings WHERE str NOT REGEXP '^[0-9]+';
SELECT id, regexp_extract(str, '(a)(b)(c)', 3) AS group_three FROM test_strings WHERE str IN (SELECT str FROM test_strings WHERE id < 5);
SELECT id, COUNT(*) AS match_count FROM test_strings WHERE regexp_extract(str, '([a-z])\1+', 0) IS NOT NULL GROUP BY id;
SELECT str, regexp_extract(str, '^(\w+)(\s+)(\w+)', 3) AS last_name FROM test_strings WHERE str LIKE '% %';
WITH regex_results AS (SELECT id, regexp_extract(str, '([abc])', 1) AS match FROM test_strings) SELECT COUNT(*) FROM regex_results WHERE match IS NOT NULL;