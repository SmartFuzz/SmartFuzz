CREATE TABLE numbers (value INT);
INSERT INTO numbers VALUES (1), (2), (3), (4), (5), (5);
SELECT greatest(value) FROM numbers;
SELECT greatest(0, -1, -2, -3) AS MaxNegative;
SELECT greatest(NULL, 1, 2, 3) AS MaxWithNull;
CREATE TABLE more_numbers (num1 INT, num2 INT);
INSERT INTO more_numbers VALUES (10, 20), (5, 15), (25, 5);
SELECT greatest(n.num1, n.num2) FROM more_numbers AS n;
SELECT greatest(greatest(1, 2), greatest(3, 4)) AS NestedGreatest;
CREATE TABLE values1 (a FLOAT, b FLOAT);
INSERT INTO values1 VALUES (10.5, 12.3), (20.1, 19.5), (15.7, NULL);
SELECT a, b, greatest(a, b) AS MaxFromTable FROM values1;
CREATE TABLE table1 AS SELECT value FROM numbers;
CREATE TABLE table2 AS SELECT num1, num2 FROM more_numbers;
SELECT greatest(t1.value, t2.num1, t2.num2) FROM table1 t1 JOIN table2 t2 ON t1.value < t2.num1;
SELECT greatest((SELECT MAX(value) FROM numbers), (SELECT MAX(num1) FROM more_numbers)) AS OverallMax;
CREATE TABLE mixed_data (x TEXT, y INT);
INSERT INTO mixed_data VALUES ('apple', 10), ('banana', 5), ('pear', 7);
SELECT greatest(y, 25) FROM mixed_data WHERE x IN ('apple', 'banana');
SELECT greatest(999, 888, 777, NULL) AS ComplexCase;