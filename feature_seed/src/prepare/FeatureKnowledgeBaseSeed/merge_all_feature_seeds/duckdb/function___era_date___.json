CREATE TABLE dates (event_id INT, event_date DATE);
INSERT INTO dates VALUES (1, DATE '0044-03-15'), (2, DATE '0001-01-01'), (3, DATE '2021-09-10'), (4, DATE '0001-03-15 (BC)');
SELECT era(event_date) FROM dates;
SELECT event_id, era(event_date) FROM dates WHERE event_id IN (SELECT event_id FROM dates WHERE event_date < DATE '0001-01-01');
SELECT d1.event_id, era(d1.event_date) FROM dates d1 JOIN dates d2 ON d1.event_id = d2.event_id WHERE era(d1.event_date) <> era(d2.event_date);
SELECT event_id, era(event_date), (SELECT COUNT(*) FROM dates AS d WHERE era(d.event_date) = era(dates.event_date)) AS era_count FROM dates;
WITH era_values AS (SELECT event_id, era(event_date) AS era FROM dates) SELECT era, COUNT(*) AS era_count FROM era_values GROUP BY era;
SELECT event_id, era(event_date) FROM dates WHERE era(event_date) IS NOT NULL ORDER BY event_date DESC;
SELECT (SELECT era(event_date) FROM dates WHERE event_id = 1) AS first_event_era, (SELECT era(event_date) FROM dates WHERE event_id = 2) AS second_event_era;
SELECT era(event_date) AS event_era FROM dates UNION SELECT era(DATE '0050-01-01 (BC)');