CREATE TABLE files_table (file_path VARCHAR, file_size INTEGER, file_created TIMESTAMP);
INSERT INTO files_table (file_path, file_size, file_created) VALUES ('/path/to/file1.txt', 123, '2023-10-01 10:00:00'), ('/path/to/file2.txt', NULL, '2023-10-02 11:00:00');
SELECT glob(file_path) // 2 AS glob_div, file_size FROM files_table WHERE file_size IS NOT NULL;
SELECT file_path, (SELECT COUNT(*) // 1 FROM files_table WHERE file_size IS NOT NULL) AS file_count FROM files_table WHERE glob(file_path) IS NOT NULL;
WITH subquery AS (SELECT glob(file_path) AS matched_files FROM files_table WHERE file_size IS NOT NULL) SELECT COUNT(*) FROM subquery HAVING COUNT(matched_files) // 1 > 0;
SELECT file_path, file_size, (SELECT COUNT(*) FROM files_table) AS total_files, glob(file_path) FROM files_table GROUP BY file_path, file_size HAVING file_size // 1 = 0;
SELECT file_path, CASE WHEN glob(file_path) IS NULL THEN 'No match' ELSE 'Matched' END AS match_status FROM files_table WHERE file_size // 10 >= 0;
CREATE TABLE temp_files (temp_path VARCHAR, temp_size INTEGER);
INSERT INTO temp_files (temp_path, temp_size) VALUES ('/temp/path1.txt', 200), ('/temp/path2.txt', NULL);
SELECT A.file_path, A.file_size, B.temp_size // 5 FROM files_table A JOIN temp_files B ON A.file_size = B.temp_size WHERE glob(B.temp_path) IS NOT NULL;