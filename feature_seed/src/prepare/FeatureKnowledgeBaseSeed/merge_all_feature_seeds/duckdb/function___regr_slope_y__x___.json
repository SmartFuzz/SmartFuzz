CREATE TABLE test_data (id INT, x FLOAT, y FLOAT);
INSERT INTO test_data VALUES (1, 1.0, 2.0), (2, 2.0, 4.0), (3, 3.0, 6.0);
SELECT regr_slope(y, x) FROM test_data;
SELECT regr_slope(y, x) FROM (SELECT x, y FROM test_data WHERE id > 1) AS subquery;
CREATE TABLE additional_data (id INT, x FLOAT, y FLOAT);
INSERT INTO additional_data VALUES (1, 4.0, 8.0), (2, 5.0, 10.0);
SELECT regr_slope(y, x) FROM (SELECT x, y FROM test_data UNION ALL SELECT x, y FROM additional_data) AS combined_data;
SELECT AVG(y) AS average_y, regr_slope(y, x) FROM test_data GROUP BY id HAVING COUNT(*) > 1;
CREATE TABLE empty_table (x FLOAT, y FLOAT);
SELECT regr_slope(y, x) FROM empty_table;
SELECT regr_slope(y, x) FROM (SELECT x, y FROM test_data WHERE x < 3) AS filtered_data UNION SELECT regr_slope(y, x) FROM additional_data WHERE y > 9;
WITH calc_slope AS (SELECT regr_slope(y, x) AS slope FROM test_data) SELECT slope FROM calc_slope WHERE slope > 0;