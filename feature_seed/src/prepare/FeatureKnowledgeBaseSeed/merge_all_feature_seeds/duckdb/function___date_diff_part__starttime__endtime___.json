CREATE TABLE time_intervals (starttime TIME, endtime TIME);
INSERT INTO time_intervals VALUES (TIME '01:00:00', TIME '03:00:00');
INSERT INTO time_intervals VALUES (TIME '02:30:00', TIME '04:45:00');
INSERT INTO time_intervals VALUES (TIME '08:15:00', TIME '10:15:00');
SELECT date_diff('hour', starttime, endtime) FROM time_intervals;
SELECT *, date_diff('minute', starttime, endtime) AS minute_diff FROM time_intervals;
CREATE TABLE time_aggregates AS SELECT date_diff('hour', starttime, endtime) AS hour_diff FROM time_intervals;
SELECT AVG(hour_diff) FROM time_aggregates;
SELECT t1.starttime, t1.endtime, date_diff('minute', t1.starttime, t2.endtime) FROM time_intervals t1 JOIN time_intervals t2 ON t1.endtime < t2.starttime;
SELECT COUNT(*) FROM (SELECT date_diff('hour', starttime, endtime) AS hour_diff FROM time_intervals WHERE hour_diff >= 1) AS filtered_intervals;
CREATE TABLE complex_intervals AS SELECT t1.starttime AS t1_start, t2.endtime AS t2_end, date_diff('second', t1.starttime, t2.endtime) AS diff_sec FROM time_intervals t1 JOIN time_intervals t2 ON t1.starttime < t2.endtime;
SELECT t.starttime, t.endtime, date_diff('hour', t.starttime, t.endtime) FROM (SELECT * FROM time_intervals WHERE starttime < TIME '12:00:00') t;
CREATE VIEW time_differences AS SELECT id, date_diff('hour', starttime, endtime) AS hour_difference FROM (SELECT ROW_NUMBER() OVER () AS id, starttime, endtime FROM time_intervals) temp;
SELECT * FROM time_differences WHERE hour_difference > 0;