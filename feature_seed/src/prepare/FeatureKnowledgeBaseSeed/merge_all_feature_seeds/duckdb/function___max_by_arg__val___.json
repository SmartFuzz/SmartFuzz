CREATE TABLE test_table (id INT, value FLOAT, category VARCHAR);
INSERT INTO test_table VALUES (1, 10.0, 'A'), (2, 20.0, 'B'), (3, 30.0, 'A'), (4, 25.0, 'C');
SELECT max_by(value, id) FROM test_table;
SELECT category, max_by(value, id) FROM test_table GROUP BY category;
SELECT max_by(value, id) FROM (SELECT id, value FROM test_table WHERE category = 'A') AS subquery;
CREATE TABLE second_table (id INT, additional_value FLOAT);
INSERT INTO second_table VALUES (1, 15.0), (2, 35.0), (3, 25.0);
SELECT t.category, max_by(t.value, t.id) FROM test_table t JOIN second_table s ON t.id = s.id GROUP BY t.category;
SELECT max_by(value, id) FROM (SELECT id, value + (SELECT AVG(additional_value) FROM second_table) AS value FROM test_table) AS subquery;
CREATE TABLE third_table (id INT, score FLOAT);
INSERT INTO third_table VALUES (1, 45.0), (2, 55.0), (3, 25.0);
SELECT t.category, max_by(t.value, s.score) FROM test_table t JOIN third_table s ON t.id = s.id GROUP BY t.category;
SELECT id, max_by(value, id) OVER (PARTITION BY category ORDER BY value DESC ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) AS max_val FROM test_table;