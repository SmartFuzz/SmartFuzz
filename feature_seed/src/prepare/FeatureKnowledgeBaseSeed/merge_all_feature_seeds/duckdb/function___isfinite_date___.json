CREATE TABLE test_dates (id INT, test_date DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-03-07');
INSERT INTO test_dates VALUES (2, DATE '10000-01-01');
INSERT INTO test_dates VALUES (3, DATE '0001-01-01');
INSERT INTO test_dates VALUES (4, NULL);
INSERT INTO test_dates VALUES (5, DATE '2023-10-10');
SELECT id, test_date, isfinite(test_date) AS is_finite FROM test_dates;
SELECT MAX(id) FROM (SELECT id, isfinite(test_date) AS is_finite FROM test_dates WHERE isfinite(test_date) = true) AS fin_dates;
SELECT id FROM test_dates WHERE test_date < DATE '2000-01-01' AND isfinite(test_date) = true;
SELECT id FROM test_dates WHERE isfinite(test_date) = false UNION SELECT id FROM test_dates WHERE test_date IS NULL;
SELECT (SELECT COUNT(*) FROM test_dates WHERE isfinite(test_date) = true) AS finite_count, (SELECT COUNT(*) FROM test_dates WHERE isfinite(test_date) = false) AS infinite_count;