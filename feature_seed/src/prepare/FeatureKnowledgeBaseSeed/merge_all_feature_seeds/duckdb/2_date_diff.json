CREATE TABLE test_dates (id INT, start_date DATE, end_date DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-09-15', DATE '1992-11-14');
INSERT INTO test_dates VALUES (2, NULL, DATE '1992-12-01');
INSERT INTO test_dates VALUES (3, DATE '2023-01-01', DATE '2023-01-31');
SELECT id, date_diff('month', start_date, end_date) AS month_diff FROM test_dates;
SELECT id, (date_diff('month', start_date, end_date) % 2) AS month_diff_mod_2 FROM test_dates;
SELECT (SELECT count(*) FROM test_dates) AS total_records, DATE '2023-01-31' - DATE '2023-01-01' AS days_diff;
CREATE TABLE test_modulo (num1 INT, num2 INT);
INSERT INTO test_modulo VALUES (10, 3), (20, NULL), (15, 0);
SELECT num1, (num1 % COALESCE(num2, 1)) AS mod_result FROM test_modulo WHERE num2 IS NOT NULL;
SELECT num1, (date_diff('month', DATE '2000-01-01', DATE '2000-01-01' + INTERVAL '1 month') % 3) AS boundary_mod FROM test_dates;
SELECT t.id, (date_diff('month', t.start_date, t.end_date) % (SELECT count(*) FROM test_modulo WHERE num2 IS NOT NULL)) AS complex_mod FROM test_dates t;
SELECT id, start_date, end_date, date_diff('month', start_date, end_date) AS month_diff FROM test_dates WHERE month_diff IS NOT NULL HAVING month_diff > 0;