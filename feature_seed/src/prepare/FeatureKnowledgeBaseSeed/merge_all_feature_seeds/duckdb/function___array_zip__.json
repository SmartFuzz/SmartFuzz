CREATE TABLE demo_table (id INT, list1 LIST<INT>, list2 LIST<INT>, list3 LIST<INT>);
INSERT INTO demo_table VALUES (1, [1, 2], [3, 4], [5, 6]);
INSERT INTO demo_table VALUES (2, [7, 8], [9], [10, 11, 12]);
INSERT INTO demo_table VALUES (3, [13, 14, 15], [16, 17, 18], NULL);
SELECT array_zip(list1, list2) FROM demo_table;
SELECT array_zip(list1, list2, list3) FROM (SELECT list1, list2, list3 FROM demo_table WHERE id = 1);
SELECT array_zip(list1, list2) FROM (SELECT DISTINCT list1, list2 FROM demo_table WHERE list1 IS NOT NULL);
SELECT array_zip(list1, list2, list3) FROM demo_table WHERE id IN (1, 2);
CREATE TABLE list_table AS SELECT array_zip([1, 2, 3], [4, 5, 6], [7]) AS zipped FROM demo_table;
SELECT * FROM list_table WHERE zipped[0].column1 IS NOT NULL;
SELECT array_zip(list1, list2) AS zipped_lists FROM demo_table WHERE LENGTH(list1) > 0 AND LENGTH(list2) > 0;
WITH zipped AS (SELECT array_zip(list1, list2, list3) AS zip_result FROM demo_table) SELECT * FROM zipped WHERE zip_result IS NOT NULL;
SELECT array_zip(list1, (SELECT list2 FROM demo_table WHERE id = 2)) AS merged_lists FROM demo_table WHERE id = 1;
SELECT array_zip(list1, list2, list3) FROM (SELECT list1, list2, list3 FROM demo_table ORDER BY id LIMIT 2);
SELECT array_zip(list1, list2) AS combined FROM (SELECT list1, list2 FROM demo_table WHERE id = 3) WHERE combined IS NOT NULL;
CREATE TABLE zip_test AS SELECT array_zip([1, 2, NULL], [NULL, 5, 6], [7]) AS combined_result;
SELECT COUNT(*) FROM zip_test WHERE combined_result[0].column1 IS NOT NULL;