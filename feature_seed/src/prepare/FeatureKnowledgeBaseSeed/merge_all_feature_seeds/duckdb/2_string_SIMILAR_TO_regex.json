CREATE TABLE test_table (id INTEGER PRIMARY KEY, name TEXT, score FLOAT, created_at TIMESTAMP);
INSERT INTO test_table (id, name, score, created_at) VALUES (1, 'hello', 2.5, '2023-01-01 10:00:00'), (2, 'world', 3.5, '2023-01-02 11:00:00'), (3, '', 0.0, NULL), (4, 'test', NULL, '2023-01-03 12:00:00');
SELECT id, name, score * 2 AS doubled_score FROM test_table WHERE name SIMILAR TO '.*llo';
SELECT t1.id, name, (SELECT COUNT(*) FROM test_table t2 WHERE t2.score > (score * 1.5)) AS high_score_count FROM test_table t1 WHERE created_at IS NOT NULL;
SELECT AVG(score) AS average_score, COUNT(*) FROM test_table WHERE name SIMILAR TO '%';
GROUP BY name HAVING average_score > 1;
SELECT t1.id, t1.name, t1.score FROM test_table t1 JOIN test_table t2 ON t1.id * 2 = t2.id WHERE t1.name SIMILAR TO 'te%' OR (t1.score IS NULL AND t2.name IS NOT NULL);
SELECT MAX(score), name FROM test_table GROUP BY name HAVING MAX(score) > (SELECT AVG(score) FROM test_table WHERE name SIMILAR TO '.+');
CREATE TABLE temp_table AS SELECT id, score * (CASE WHEN score IS NULL THEN 1 ELSE 0 END) AS adjusted_score FROM test_table;
SELECT COUNT(*) FROM test_table WHERE (score IS NOT NULL) * ('1' SIMILAR TO '1') = 1;
DROP TABLE IF EXISTS test_table;