CREATE TABLE IF NOT EXISTS test_table (id INTEGER, name STRING, created_at TIMESTAMP, val NUMERIC);
INSERT INTO test_table VALUES (1, 'ö', TIMESTAMP '2023-10-01', 1.23), (2, 'a', TIMESTAMP '2023-10-02', 2.34), (3, NULL, TIMESTAMP '2023-10-03', NULL);
CREATE TABLE IF NOT EXISTS test_table2 (id INTEGER, sort_key STRING);
INSERT INTO test_table2 VALUES (1, icu_sort_key('a', 'EN')), (2, icu_sort_key('ö', 'DE')), (3, icu_sort_key('b', 'FR'));
SELECT t1.id, t1.name, t1.created_at, t1.val, icu_sort_key(t1.name, 'DE') AS sort_key, (t1.created_at - TIMESTAMP '2023-10-01') AS days_since FROM test_table t1 WHERE t1.val IS NOT NULL HAVING days_since > INTERVAL '0 days';
SELECT AVG(val) AS average_val, COUNT(*) AS total_rows, MIN(COALESCE(val, 0)) AS min_val FROM test_table GROUP BY icu_sort_key(name, 'EN') ORDER BY average_val DESC;
SELECT t1.id, t1.name, (t1.created_at - (SELECT MAX(created_at) FROM test_table WHERE val IS NOT NULL)) AS days_diff FROM test_table t1 INNER JOIN test_table2 t2 ON icu_sort_key(t1.name, 'EN') = t2.sort_key WHERE t1.val IS NOT NULL;
SELECT COUNT(*) FROM (SELECT t1.id, (icu_sort_key(t1.name, 'EN')) AS sort_key, (t1.created_at - TIMESTAMP '2023-09-30') AS latest_diff FROM test_table t1 WHERE t1.created_at >= TIMESTAMP '2023-10-01' HAVING latest_diff IS NOT NULL) sub_query;
SELECT t1.id, icu_sort_key(t1.name, 'FR') AS french_sort_key FROM test_table t1 WHERE t1.val IS NOT NULL ORDER BY french_sort_key ASC;
DROP TABLE IF EXISTS test_table2;