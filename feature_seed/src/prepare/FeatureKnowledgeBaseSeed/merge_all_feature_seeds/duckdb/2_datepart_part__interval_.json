CREATE TABLE test_dates (id INTEGER, event_time TIMESTAMPTZ, interval_value INTERVAL);
INSERT INTO test_dates VALUES (1, TIMESTAMPTZ '2023-10-01 12:00:00+00', INTERVAL '2 MONTH'), (2, TIMESTAMPTZ '2023-10-15 15:00:00+00', INTERVAL '3 MONTH'), (3, NULL);
SELECT id, event_time + interval_value AS updated_time FROM test_dates WHERE interval_value IS NOT NULL;
SELECT id, datepart('month', interval_value) AS month_part, event_time + datepart('year', interval_value) * INTERVAL '1 YEAR' AS incremented_time FROM test_dates WHERE event_time IS NOT NULL;
SELECT id, datepart('year', event_time + interval_value) AS year_increment, event_time FROM test_dates WHERE datepart('year', event_time) > 2022;
SELECT id, COUNT(*) AS occurrence, MAX(event_time + interval_value) AS last_event_time FROM test_dates GROUP BY id HAVING occurrence > 1;
CREATE TEMPORARY TABLE temp_dates AS SELECT event_time, datepart('month', event_time + interval '1 DAY') AS next_day_month FROM test_dates WHERE event_time IS NOT NULL;
SELECT AVG(datepart('month', updated_time)) AS average_month FROM (SELECT event_time + interval_value AS updated_time FROM test_dates WHERE interval_value IS NOT NULL) subquery;
SELECT id, datepart('year', NOW() + interval '5 DAY') AS future_year FROM test_dates;
SELECT id, event_time, (event_time + INTERVAL '1 DAY') - event_time AS duration FROM test_dates WHERE event_time IS NOT NULL;