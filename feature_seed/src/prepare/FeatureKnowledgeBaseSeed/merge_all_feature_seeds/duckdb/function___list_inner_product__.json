CREATE TABLE test_lists (list1 LIST<DOUBLE>, list2 LIST<DOUBLE>);
INSERT INTO test_lists VALUES ([1, 2, 3], [1, 2, 5]);
INSERT INTO test_lists VALUES ([0, 0, 0], [1, 1, 1]);
INSERT INTO test_lists VALUES ([], [1, 2, 3]);
INSERT INTO test_lists VALUES ([1, 1, 1], []);
INSERT INTO test_lists VALUES ([1, 2, 3], [4, 5, 6]);
SELECT list_dot_product(list1, list2) AS dot_product FROM test_lists;
CREATE TABLE test_lists2 (id INTEGER, list1 LIST<DOUBLE>, list2 LIST<DOUBLE>);
INSERT INTO test_lists2 VALUES (1, [1, 2, 3], [4, 5, 6]), (2, [10, 0, -2], [1, 2, 3]);
SELECT id, list_dot_product(list1, list2) AS dot_product FROM test_lists2 WHERE id = 1;
SELECT id, list_dot_product(list1, list2) AS dot_product FROM test_lists2 WHERE list_dot_product(list1, list2) > 10;
SELECT A.id, list_dot_product(A.list1, B.list2) AS dot_product FROM test_lists2 A JOIN test_lists2 B ON A.id = B.id WHERE A.id = 2;
CREATE TABLE empty_list (list1 LIST<DOUBLE>, list2 LIST<DOUBLE>);
INSERT INTO empty_list VALUES ([], []);
SELECT list_dot_product(list1, list2) AS dot_product FROM empty_list;
SELECT list_dot_product([1.5, 2.5, 3.5], [2.0, 3.0, 4.0]) AS dot_product;