CREATE TABLE test_table (id INT, value TEXT);
INSERT INTO test_table VALUES (1, 'A'), (2, 'B'), (3, 'C'), (4, NULL), (5, 'E');
SELECT first(value) FROM test_table;
SELECT first(value) FROM test_table ORDER BY id DESC;
CREATE TABLE another_table (id INT, group_id INT, value TEXT);
INSERT INTO another_table VALUES (1, 1, 'X'), (2, 1, 'Y'), (3, 2, 'Z'), (4, 2, 'W');
SELECT group_id, first(value) FROM another_table GROUP BY group_id;
SELECT first(value) FROM (SELECT value FROM test_table WHERE value IS NOT NULL ORDER BY id) AS subquery;
SELECT first(value) FROM test_table WHERE id >= 2;
SELECT first(value) FROM (SELECT first(value) FROM test_table GROUP BY id HAVING id <= 3) AS nested_query;
SELECT t.id, first(t.value) FROM test_table t JOIN another_table a ON t.id = a.id GROUP BY t.id;
CREATE TABLE complex_table (group_id INT, value TEXT);
INSERT INTO complex_table VALUES (1, 'M'), (1, 'N'), (2, 'O'), (2, NULL), (3, 'P');
SELECT group_id, first(value) FROM complex_table GROUP BY group_id ORDER BY group_id;
SELECT first(value) FROM (SELECT first(value) FROM test_table UNION ALL SELECT first(value) FROM complex_table) AS union_query;
SELECT first(coalesce(value, 'default')) FROM test_table;
SELECT first(value) OVER (PARTITION BY id ORDER BY id) FROM test_table;