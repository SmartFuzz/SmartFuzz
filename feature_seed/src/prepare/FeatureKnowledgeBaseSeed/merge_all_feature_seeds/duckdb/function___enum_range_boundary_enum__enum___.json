CREATE TYPE mood AS ENUM ('happy', 'sad', 'neutral');
CREATE TABLE feelings (emotion mood);
INSERT INTO feelings (emotion) VALUES ('happy'), ('sad'), ('neutral');
SELECT enum_range_boundary(NULL, 'happy'::mood) AS range_start;
SELECT enum_range_boundary('sad'::mood, NULL) AS range_end;
SELECT enum_range_boundary('sad'::mood, 'happy'::mood) AS middle_range;
SELECT enum_range_boundary('neutral'::mood, 'happy'::mood) AS neutral_to_happy;
SELECT enum_range_boundary('happy'::mood, 'neutral'::mood) AS happy_to_neutral;
SELECT (SELECT enum_range_boundary(NULL, 'happy'::mood)) AS start_range, (SELECT enum_range_boundary('sad'::mood, NULL)) AS end_range;
WITH ranges AS (SELECT enum_range_boundary(NULL, 'happy'::mood) AS start_range, enum_range_boundary('sad'::mood, NULL) AS end_range) SELECT * FROM ranges;
SELECT enum_range_boundary('happy'::mood, 'neutral'::mood) FROM feelings WHERE emotion IN (SELECT emotion FROM feelings WHERE emotion <> 'sad');
SELECT el.emotion, enum_range_boundary(NULL, el.emotion) AS range FROM feelings el;
SELECT enum_range_boundary('sad'::mood, 'neutral'::mood) AS sad_to_neutral, enum_range_boundary(NULL, NULL) AS full_range;
SELECT COUNT(*) FROM (SELECT enum_range_boundary('happy'::mood, 'sad'::mood) AS range FROM feelings) AS subquery;
SELECT ARRAY(SELECT unnest(enum_range_boundary('happy'::mood, 'neutral'::mood))) AS range_array;
SELECT (SELECT COUNT(*) FROM feelings WHERE emotion = ANY(enum_range_boundary(NULL, 'happy'::mood))) AS count_range;