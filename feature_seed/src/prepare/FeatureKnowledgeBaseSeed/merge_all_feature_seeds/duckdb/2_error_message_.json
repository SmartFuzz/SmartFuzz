CREATE TABLE test_table (id INT, value VARCHAR, bit_value INT);
INSERT INTO test_table (id, value, bit_value) VALUES (1, 'test', 5), (2, 'error_trigger', 10), (3, NULL, 15);
CREATE TABLE another_table (group_id INT, data_value INT);
INSERT INTO another_table (group_id, data_value) VALUES (1, 20), (2, 30), (3, NULL);
SELECT id, value, bit_value, error('Bitwise error check: ' || (bit_value & (SELECT max(data_value) FROM another_table WHERE group_id = 1))) FROM test_table WHERE value IS NOT NULL;
SELECT group_id, AVG(data_value) as avg_data, COUNT(*) FROM another_table GROUP BY group_id HAVING avg_data > (SELECT COUNT(id) FROM test_table) & 15;
SELECT id, value, (CASE WHEN bit_value IS NULL THEN 0 ELSE (bit_value & 7) END) as modified_bit_value, error('Accessing ID: ' || id) FROM test_table WHERE id > (SELECT MAX(id) FROM test_table WHERE value LIKE 'test%') + 1;
SELECT value, (SELECT error('Subquery check for NULL: ' || NULLIF(MAX(data_value), 0)) FROM another_table WHERE data_value IS NOT NULL) from test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NOT NULL) ORDER BY modified_bit_value DESC;
ALTER TABLE test_table ADD COLUMN new_column FLOAT;
INSERT INTO test_table (id, value, bit_value, new_column) VALUES (4, 'new_data', 0, NULL);
SELECT id, error('Combined check: ' || (value & 'string')) as process_error FROM test_table;