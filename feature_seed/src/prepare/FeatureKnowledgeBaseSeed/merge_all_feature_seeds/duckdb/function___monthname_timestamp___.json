CREATE TABLE timestamps (event_time TIMESTAMP);
INSERT INTO timestamps VALUES (TIMESTAMP '1992-01-15'), (TIMESTAMP '1995-02-20'), (TIMESTAMP '2000-03-25'), (TIMESTAMP '2005-04-30');
SELECT monthname(event_time) FROM timestamps;
SELECT event_time, monthname(event_time) as month FROM timestamps WHERE event_time > TIMESTAMP '1992-01-01';
CREATE TABLE months (month_number INT, month_name VARCHAR);
INSERT INTO months VALUES (1, 'January'), (2, 'February'), (3, 'March'), (4, 'April'), (5, 'May'), (6, 'June'), (7, 'July'), (8, 'August'), (9, 'September'), (10, 'October'), (11, 'November'), (12, 'December');
SELECT t.event_time, m.month_name FROM timestamps t JOIN months m ON m.month_number = EXTRACT(MONTH FROM t.event_time);
SELECT DISTINCT monthname(event_time) FROM timestamps WHERE monthname(event_time) IS NOT NULL;
SELECT monthname(TIMESTAMP '1980-12-31') AS month_name;
SELECT monthname(TIMESTAMP '1999-06-01') AS month_name;
SELECT event_time, monthname(event_time) AS month_name FROM (SELECT event_time FROM timestamps WHERE event_time BETWEEN TIMESTAMP '1990-01-01' AND TIMESTAMP '2000-12-31') AS filtered WHERE monthname(event_time) = 'June';
WITH month_data AS (SELECT event_time, monthname(event_time) AS month FROM timestamps) SELECT month, COUNT(*) FROM month_data GROUP BY month;