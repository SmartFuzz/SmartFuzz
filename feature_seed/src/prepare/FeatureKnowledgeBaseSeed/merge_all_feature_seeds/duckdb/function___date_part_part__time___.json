CREATE TABLE time_data (event_time TIME);
INSERT INTO time_data VALUES (TIME '10:05:30'), (TIME '23:59:59'), (TIME '00:00:00'), (TIME '15:45:15');
SELECT date_part('hour', event_time) FROM time_data;
SELECT date_part('minute', event_time) FROM time_data WHERE event_time >= TIME '00:00:00' AND event_time <= TIME '12:00:00';
SELECT date_part('second', event_time) FROM time_data WHERE date_part('minute', event_time) = 59;
SELECT t1.event_time, date_part('hour', t1.event_time) AS hour, date_part('minute', t1.event_time) AS minute FROM time_data t1 WHERE date_part('hour', t1.event_time) > 12;
CREATE TABLE events (id INT, event_time TIME, description TEXT);
INSERT INTO events VALUES (1, TIME '14:30:00', 'Lunch'), (2, TIME '19:45:00', 'Dinner');
SELECT e.description, date_part('minute', e.event_time) FROM events e WHERE date_part('hour', e.event_time) IN (SELECT DISTINCT date_part('hour', event_time) FROM time_data);
SELECT d.event_time FROM (SELECT event_time FROM time_data) AS d WHERE date_part('second', d.event_time) > 30;
SELECT COUNT(*) FROM time_data WHERE date_part('minute', event_time) = 0 AND date_part('hour', event_time) < 12;
SELECT event_time, date_part('minute', event_time) + date_part('second', event_time) AS total_seconds FROM time_data WHERE event_time LIKE '10:%';
CREATE TABLE nested_data AS SELECT date_part('hour', event_time) AS hour_part FROM time_data;
SELECT COUNT(*) FROM (SELECT date_part('minute', event_time) AS minute_part FROM time_data GROUP BY minute_part) AS grouped_minutes WHERE minute_part > 20;
SELECT event_time, (SELECT date_part('second', event_time) FROM time_data WHERE event_time = TIME '15:45:15') AS specific_seconds FROM time_data;