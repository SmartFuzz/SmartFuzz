CREATE TABLE example (text STRING);
INSERT INTO example VALUES ('hello world;
42'), ('foo;
bar;
baz'), ('duckdb is great;
regex are useful');
SELECT string_split_regex(text, ';
? ') FROM example;
SELECT string_split_regex(text, ';
') AS split_parts FROM example WHERE text IS NOT NULL;
CREATE TABLE another_example (part STRING);
INSERT INTO another_example VALUES ('part1'), ('part2'), ('part3');
SELECT e.text, a.part FROM example e JOIN another_example a ON a.part = string_split_regex(e.text, ';
')[1];
WITH split_text AS (SELECT string_split_regex(text, ';
? ') AS parts FROM example) SELECT COUNT(*) FROM split_text WHERE parts IS NOT NULL;
SELECT string_split_regex('abc?xyz|123;
def', '[;
|?]') AS result;
SELECT DISTINCT split_part FROM (SELECT string_split_regex(text, ';
? ') AS split_part FROM example) AS split_results;
SELECT string_split_regex('a;
b;
c;
d', ';
') AS split_values UNION SELECT string_split_regex('e;
f;
g;
h', ';
') AS split_values;
SELECT e.text, ARRAY_LENGTH(string_split_regex(e.text, ';
? ')) AS part_count FROM example e;