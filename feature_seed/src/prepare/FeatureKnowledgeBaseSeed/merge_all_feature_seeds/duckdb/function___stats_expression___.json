CREATE TABLE test_table (a INT, b DOUBLE, c VARCHAR);
INSERT INTO test_table VALUES (1, 1.5, 'test1'), (2, 2.5, 'test2'), (3, 3.5, 'test3');
SELECT stats(a) FROM test_table;
SELECT stats(b) FROM test_table;
SELECT stats(5) AS constant_stats;
SELECT stats(a + b) FROM test_table;
SELECT stats(a * 10) FROM test_table WHERE a < 3;
SELECT stats(COALESCE(c, 'default')) FROM test_table;
SELECT stats((SELECT AVG(b) FROM test_table WHERE a > 1) + 2) AS subquery_stats;
CREATE TABLE another_table (x INT, y DOUBLE);
INSERT INTO another_table VALUES (1, 1.0), (2, 2.0), (3, 3.0);
SELECT stats(a + (SELECT AVG(y) FROM another_table)) FROM test_table;
SELECT stats((SELECT COUNT(*) FROM test_table) + (SELECT COUNT(*) FROM another_table));
SELECT stats((SELECT SUM(b) FROM test_table) / (SELECT COUNT(*) FROM test_table WHERE a > 1));
SELECT stats(5.0 / NULLIF(a, 0)) FROM test_table;
SELECT stats((SELECT MIN(a) FROM test_table) + (SELECT MAX(b) FROM test_table));
SELECT stats(a + (SELECT MAX(x) FROM another_table WHERE y < 3)) FROM test_table WHERE b = 2.5;