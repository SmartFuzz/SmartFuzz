CREATE TABLE test_timestamps (id INT, event_time TIMESTAMP);
INSERT INTO test_timestamps VALUES (1, TIMESTAMP '2020-01-01'), (2, TIMESTAMP '1995-05-15'), (3, TIMESTAMP '2010-10-10');
SELECT id, age(event_time) FROM test_timestamps;
SELECT id, age(CURRENT_TIMESTAMP - INTERVAL '5 days') AS age_diff FROM test_timestamps WHERE event_time < CURRENT_TIMESTAMP;
CREATE TABLE nested_table AS SELECT id, age(event_time) AS age_diff FROM test_timestamps;
SELECT nt.id, nt.age_diff FROM nested_table nt JOIN test_timestamps tt ON nt.id = tt.id WHERE nt.age_diff IS NOT NULL;
SELECT id, age(event_time) AS age_diff FROM test_timestamps WHERE event_time BETWEEN TIMESTAMP '1990-01-01' AND TIMESTAMP '2000-01-01';
WITH age_calculations AS (SELECT id, age(event_time) AS calculated_age FROM test_timestamps) SELECT calculated_age FROM age_calculations WHERE calculated_age < INTERVAL '20 years';
SELECT id, age(event_time), CASE WHEN age(event_time) < INTERVAL '20 years' THEN 'Young' ELSE 'Old' END AS age_group FROM test_timestamps;
SELECT id, age(MAX(event_time)) AS max_age FROM test_timestamps GROUP BY id HAVING max_age > INTERVAL '10 years';
INSERT INTO test_timestamps VALUES (4, TIMESTAMP '1999-12-31');
SELECT id, age(event_time) AS age_diff FROM (SELECT * FROM test_timestamps WHERE id = 4) AS subquery;
SELECT id, age(TIMESTAMP '2000-01-01') + INTERVAL '30 days' AS age_plus FROM test_timestamps WHERE event_time < TIMESTAMP '2000-01-01';