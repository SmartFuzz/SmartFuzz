CREATE TABLE timestamps (event_time TIMESTAMP);
INSERT INTO timestamps VALUES (TIMESTAMP '1990-01-01'), (TIMESTAMP '2000-02-29'), (TIMESTAMP '2023-10-01');
SELECT isfinite(event_time) FROM timestamps;
SELECT event_time, isfinite(event_time) FROM timestamps WHERE event_time > TIMESTAMP '1995-12-31';
SELECT * FROM (SELECT event_time, isfinite(event_time) AS finite_check FROM timestamps) AS subquery WHERE finite_check = true;
CREATE TABLE events (id INT, event_time TIMESTAMP);
INSERT INTO events VALUES (1, TIMESTAMP '2030-01-01'), (2, TIMESTAMP '2025-05-05');
SELECT e.id, e.event_time, isfinite(e.event_time) FROM events e JOIN timestamps t ON e.event_time = t.event_time;
SELECT COUNT(*) FROM timestamps WHERE isfinite(event_time) = true;
WITH finite_timestamps AS (SELECT event_time FROM timestamps WHERE isfinite(event_time)) SELECT COUNT(*) FROM finite_timestamps;