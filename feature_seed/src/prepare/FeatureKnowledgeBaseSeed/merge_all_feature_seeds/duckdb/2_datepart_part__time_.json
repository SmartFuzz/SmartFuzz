CREATE TABLE test_timestamps (id INT, event_time TIME, description VARCHAR(255));
INSERT INTO test_timestamps VALUES (1, TIME '10:00:00', 'Event A'), (2, TIME '12:30:30', NULL), (3, TIME '15:45:15', 'Event C');
SELECT id, event_time, datepart('minute', event_time) AS minute_part FROM test_timestamps WHERE event_time IS NOT NULL;
SELECT id, event_time, datepart('minute', event_time) - INTERVAL 5 MINUTE AS adjusted_minute FROM test_timestamps WHERE event_time > TIME '10:00:00' ORDER BY adjusted_minute;
SELECT id, event_time, datepart('minute', event_time) AS minute_part FROM test_timestamps WHERE event_time < (SELECT TIME '12:00:00' - INTERVAL 1 HOUR);
SELECT id, event_time, datepart('hour', event_time) + CAST(NULL AS INTEGER) AS null_hour_part FROM test_timestamps GROUP BY id, event_time HAVING null_hour_part IS NULL;
SELECT id, event_time, (datepart('minute', event_time) - INTERVAL 5 MINUTE) AS modified_minute FROM test_timestamps ORDER BY modified_minute ASC;
SELECT t1.id, t2.description, datepart('minute', (t1.event_time - INTERVAL 1 HOUR)) AS time_difference FROM test_timestamps t1 INNER JOIN test_timestamps t2 ON t1.id = t2.id + 1;
CREATE TABLE edge_cases (timestamp_col TIMESTAMP, time_col TIME);
INSERT INTO edge_cases VALUES (TIMESTAMP '2023-01-01 00:00:00', TIME '00:00:00'), (TIMESTAMP NULL, TIME '23:59:59');
SELECT *, datepart('minute', time_col) FROM edge_cases WHERE timestamp_col IS NOT NULL AND time_col IS NOT NULL;
SELECT *, (datepart('minute', time_col) + INTERVAL 1 MINUTE) AS next_minute FROM edge_cases WHERE time_col IS NOT NULL;
SELECT id, event_time, datepart('minute', event_time) FROM test_timestamps WHERE event_time - INTERVAL 1 HOUR < TIME '14:00:00';
SELECT id, event_time, datepart('hour', event_time) AS hour_part FROM test_timestamps GROUP BY hour_part HAVING hour_part IS NOT NULL;
SELECT id, CAST(NULL AS TIME) AS null_time, datepart('minute', COALESCE(null_time, TIME '12:00:00')) AS coalesced_minute FROM test_timestamps;
SELECT id, event_time, (datepart('minute', event_time) - INTERVAL 5 MINUTE) AS min_boundary FROM test_timestamps HAVING min_boundary = 25;