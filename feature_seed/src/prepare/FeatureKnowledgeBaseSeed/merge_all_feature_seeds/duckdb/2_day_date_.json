CREATE TABLE test_dates (id INTEGER, event_date DATE NOT NULL);
INSERT INTO test_dates VALUES (1, DATE '2023-01-01'), (2, DATE '2023-02-28'), (3, DATE '2023-03-31'), (4, NULL);
SELECT id, day(event_date) - 1 AS day_minus_one FROM test_dates WHERE event_date IS NOT NULL;
SELECT id, (day(event_date) + 2) - (day(event_date) - 2) AS complex_expression FROM test_dates;
CREATE TABLE test_numbers (num1 INTEGER, num2 INTEGER);
INSERT INTO test_numbers VALUES (5, 3), (NULL, 2), (10, NULL), (1, 1);
SELECT (SELECT day(event_date) FROM test_dates WHERE id = 1) - num1 AS subquery_subtraction FROM test_numbers;
SELECT id, day(event_date) AS day_val, CASE WHEN day(event_date) IS NOT NULL THEN day(event_date) - 2 ELSE NULL END AS adjusted_day FROM test_dates;
SELECT num1, num2, (day(event_date) - 1) AS day_adjusted FROM test_dates JOIN test_numbers ON day(event_date) > num1 HAVING adjusted_day IS NOT NULL;
SELECT id, day(event_date) FROM (SELECT id, day(event_date) AS day_val FROM test_dates) AS subquery WHERE day_val > 0 ORDER BY day_val DESC;
SELECT day(event_date) - (SELECT COUNT(*) FROM test_numbers WHERE num1 IS NULL) AS day_adjustment FROM test_dates WHERE event_date IS NOT NULL;