CREATE TABLE test_data (id INTEGER PRIMARY KEY, x FLOAT, y FLOAT, category TEXT);
INSERT INTO test_data (id, x, y, category) VALUES (1, 5.0, 10.0, 'A');
INSERT INTO test_data (id, x, y, category) VALUES (2, NULL, 15.0, 'B');
INSERT INTO test_data (id, x, y, category) VALUES (3, 2.5, NULL, 'A');
INSERT INTO test_data (id, x, y, category) VALUES (4, 1.0, 0.0, 'C');
INSERT INTO test_data (id, x, y, category) VALUES (5, -1.0, -5.0, 'B');
SELECT category, regr_avgx(y, x) / (SELECT COUNT(*) FROM test_data WHERE category = 'A') AS avg_y_per_cat_a FROM test_data GROUP BY category HAVING avg_y_per_cat_a IS NOT NULL;
SELECT category, AVG(x) / (SELECT regr_avgx(y, x) FROM test_data WHERE category = 'B' AND y IS NOT NULL) AS avg_x_per_cat_b FROM test_data WHERE y IS NOT NULL GROUP BY category HAVING COUNT(*) > 0;
SELECT REGR_AVGX(y, x) AS average_y_x FROM (SELECT y, x FROM test_data WHERE x IS NOT NULL) AS derived_table WHERE (SELECT COUNT(*) FROM test_data) > 0;
SELECT AVG(x / NULLIF(y, 0)) AS avg_performance FROM test_data;
SELECT category, regr_avgx(y, x) / (SELECT COUNT(*) FROM test_data WHERE x > 0) AS adjusted_avg FROM (SELECT DISTINCT x, y, category FROM test_data) AS distinct_table GROUP BY category HAVING adjusted_avg IS NOT NULL;