CREATE TABLE test_table (a INT, b INT);
INSERT INTO test_table VALUES (1, 1), (2, 3), (4, 4), (5, 6);
SELECT nullif(a, b) AS result FROM test_table;
SELECT nullif(10, 10) AS result;
SELECT nullif(10, 20) AS result;
SELECT nullif(NULL, 10) AS result;
SELECT nullif(10, NULL) AS result;
SELECT nullif(NULL, NULL) AS result;
SELECT a, b, nullif(a, b) AS nullified FROM test_table WHERE a < 5;
SELECT (SELECT nullif(a, b) FROM test_table) AS subquery_result;
CREATE TABLE another_table (c INT, d INT);
INSERT INTO another_table VALUES (1, 2), (2, 2), (3, 4);
SELECT t1.a, t2.d, nullif(t1.a, t2.d) AS null_a_d FROM test_table t1 JOIN another_table t2 ON t1.a = t2.c;
SELECT nullif((SELECT AVG(a) FROM test_table), 5) AS avg_check;
SELECT nullif(MAX(a), MIN(b)) AS max_min_nullified FROM test_table;
WITH CTE AS (SELECT a, b FROM test_table) SELECT nullif(a, b) FROM CTE;
SELECT nullif(COALESCE(a, 0), COALESCE(b, 0)) AS coalesce_result FROM test_table;