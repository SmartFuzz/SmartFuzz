CREATE TABLE timestamps (id INTEGER, startdate TIMESTAMP, enddate TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '1992-09-30 23:59:59', TIMESTAMP '1992-10-01 01:58:00');
INSERT INTO timestamps VALUES (2, TIMESTAMP '2022-12-31 23:30:00', TIMESTAMP '2023-01-01 00:30:00');
INSERT INTO timestamps VALUES (3, TIMESTAMP '2023-01-01 12:00:00', TIMESTAMP '2023-01-01 14:30:00');
SELECT id, datesub('hour', startdate, enddate) AS hours_difference FROM timestamps WHERE datesub('hour', startdate, enddate) > 0;
SELECT id, datesub('minute', TIMESTAMP '2023-05-01 12:00:00', TIMESTAMP '2023-05-01 12:30:00') AS minutes_difference FROM timestamps;
SELECT id, datesub('day', TIMESTAMP '2023-01-10', TIMESTAMP '2023-01-15') AS days_difference FROM timestamps;
SELECT id, (SELECT datesub('hour', startdate, enddate) FROM timestamps WHERE id = 2) AS hours_diff_for_id_2 FROM timestamps;
SELECT T1.id, datesub('day', T1.startdate, T2.enddate) AS days_diff FROM timestamps T1 JOIN timestamps T2 ON T1.id < T2.id;
SELECT id, datesub('minute', TIMESTAMP '2023-02-01 08:00:00', TIMESTAMP '2023-02-01 08:01:00') AS minute_diff FROM timestamps WHERE datesub('minute', startdate, enddate) = 1;