CREATE TABLE test_struct (data STRUCT<first INT, second INT>);
INSERT INTO test_struct VALUES (row(1, 2)), (row(3, 4)), (row(5, 6));
SELECT struct_extract(data, 1) AS first_value FROM test_struct;
SELECT struct_extract(data, 2) AS second_value FROM test_struct;
SELECT struct_extract(row(10, 20), 1) AS extracted_value;
SELECT struct_extract(row(100, 200), 2) AS extracted_value;
SELECT struct_extract(data, 1) AS first_value, struct_extract(data, 2) AS second_value FROM test_struct;
SELECT (SELECT struct_extract(data, 1) FROM test_struct WHERE struct_extract(data, 1) > 2) AS filtered_value;
CREATE TABLE test_struct_nested (data STRUCT<inner STRUCT<first INT, second INT>, outer INT>);
INSERT INTO test_struct_nested VALUES (row(row(10, 20), 30)), (row(row(40, 50), 60));
SELECT struct_extract(data, 1).first AS inner_first_value FROM test_struct_nested;
SELECT struct_extract(data, 1).second AS inner_second_value FROM test_struct_nested;
SELECT struct_extract(data, 2) AS outer_value FROM test_struct_nested;
SELECT (SELECT struct_extract(data, 1).first FROM test_struct_nested WHERE struct_extract(data, 1).first > 30) AS nested_filtered_value;
CREATE TABLE t1 (id INT, info STRUCT<name STRING, age INT>);
INSERT INTO t1 VALUES (1, row('Alice', 30)), (2, row('Bob', 25));
SELECT struct_extract(info, 1) AS name FROM t1 WHERE id = 1;
SELECT struct_extract(info, 2) AS age FROM t1 WHERE id = 2;
SELECT (SELECT struct_extract(info, 1) FROM t1 WHERE id = 1 UNION SELECT struct_extract(info, 1) FROM t1 WHERE id = 2) AS names_combined;