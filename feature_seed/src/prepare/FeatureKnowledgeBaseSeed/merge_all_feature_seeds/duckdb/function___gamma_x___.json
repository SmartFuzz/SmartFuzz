CREATE TABLE test_values (value FLOAT);
INSERT INTO test_values VALUES (1), (2), (2.5), (3.5), (4), (5), (5.5), (10), (20), (100);
SELECT value, gamma(value) AS gamma_value FROM test_values WHERE value > 0;
SELECT AVG(gamma(value)) AS avg_gamma FROM test_values;
SELECT SUM(gamma(value)) AS sum_gamma FROM (SELECT value FROM test_values WHERE value < 5) AS subquery;
CREATE TABLE additional_values (val FLOAT);
INSERT INTO additional_values VALUES (6), (7.5), (8);
SELECT a.val, g1.gamma AS gamma_val_a, g2.gamma AS gamma_val_b FROM additional_values a JOIN (SELECT value, gamma(value) AS gamma FROM test_values) g1 ON a.val > g1.value JOIN (SELECT value, gamma(value) AS gamma FROM test_values) g2 ON g1.value < g2.value;
SELECT COUNT(*) AS count_non_integer FROM test_values WHERE value NOT IN (1, 2, 3, 4, 5);
SELECT value, gamma(value) FROM test_values ORDER BY gamma(value) DESC LIMIT 5;
CREATE TABLE results AS SELECT value, gamma(value) AS gamma_result FROM test_values;
SELECT r.value, r.gamma_result FROM results r WHERE r.gamma_result > 100;