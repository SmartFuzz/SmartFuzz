CREATE TABLE test_bytes (size INT);
INSERT INTO test_bytes VALUES (0);
INSERT INTO test_bytes VALUES (1023);
INSERT INTO test_bytes VALUES (1024);
INSERT INTO test_bytes VALUES (16384);
INSERT INTO test_bytes VALUES (1048576);
INSERT INTO test_bytes VALUES (1073741824);
INSERT INTO test_bytes VALUES (1099511627776);
SELECT size, format_bytes(size) FROM test_bytes;
SELECT size, format_bytes(size) FROM test_bytes WHERE size >= 0;
SELECT AVG(size), format_bytes(AVG(size)) FROM test_bytes GROUP BY size HAVING AVG(size) > 512;
CREATE TABLE joined_bytes (size_a INT, size_b INT);
INSERT INTO joined_bytes VALUES (1024, 2048), (512, 1024);
SELECT a.size_a, b.size_b, format_bytes(a.size_a + b.size_b) AS combined FROM joined_bytes a JOIN test_bytes b ON a.size_a = b.size WHERE b.size > 0;
SELECT size, format_bytes(size) FROM (SELECT MAX(size) AS size FROM test_bytes) AS max_bytes;
WITH byte_summary AS (SELECT size, format_bytes(size) AS formatted FROM test_bytes) SELECT SUM(size) AS total, SUM(formatted) AS total_readable FROM byte_summary;