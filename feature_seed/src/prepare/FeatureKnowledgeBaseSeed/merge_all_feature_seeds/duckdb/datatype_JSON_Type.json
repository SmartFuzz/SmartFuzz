CREATE TABLE json_test (data JSON);
INSERT INTO json_test VALUES (CAST('{"name": "Alice", "age": 30}' AS JSON));
INSERT INTO json_test VALUES (CAST('{"temperature": {"celsius": 25, "fahrenheit": 77}}' AS JSON));
SELECT data FROM json_test WHERE data->>'age'::INTEGER > 25;
SELECT data FROM json_test WHERE data->'temperature'->>'celsius'::FLOAT < 30;
CREATE TABLE nested_json (info JSON);
INSERT INTO nested_json VALUES (CAST('{"person": {"name": "Bob", "details": {"age": 25, "location": "NY"}}}' AS JSON));
SELECT info->'person'->>'details'->>'location' FROM nested_json WHERE info->'person'->>'name' = 'Bob';
CREATE TABLE another_table (id INTEGER, attributes JSON);
INSERT INTO another_table VALUES (1, CAST('{"interests": ["music", "sports"]}' AS JSON));
SELECT a.id, a.attributes->'interests' FROM another_table a JOIN json_test j ON a.id = j.data->>'age'::INTEGER WHERE j.data->>'name' = 'Alice';
CREATE TABLE json_structure_example (json_data JSON);
INSERT INTO json_structure_example VALUES (CAST('{"employees": [{"name": "Charlie", "role": "Developer"}, {"name": "Diana", "role": "Manager"}]}' AS JSON));
SELECT json_data->'employees'->0->>'name' FROM json_structure_example WHERE json_data->>'employees' IS NOT NULL;
SELECT CAST(json_data->'employees' AS JSON) FROM json_structure_example WHERE json_data->'employees' IS NOT NULL;
SELECT CAST('{"date": "2023-10-01"}' AS JSON)::DATE;
INSERT INTO json_test VALUES (CAST('{"valid_json": true}' AS JSON));
SELECT CAST(data AS VARCHAR) FROM json_test WHERE data IS NOT NULL;
SELECT CAST(data->>'name' AS VARCHAR) FROM json_test WHERE data->>'name' IS NOT NULL;
CREATE TABLE complex_query (metadata JSON, value INTEGER);
INSERT INTO complex_query VALUES (CAST('{"timestamp": "2023-10-01T12:00:00Z", "metrics": {"count": 5}}' AS JSON), 100);
SELECT value FROM complex_query WHERE metadata->'metrics'->>'count'::INTEGER > 4;