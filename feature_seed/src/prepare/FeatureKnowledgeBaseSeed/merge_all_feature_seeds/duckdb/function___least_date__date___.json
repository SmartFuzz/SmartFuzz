CREATE TABLE dates_table (date1 DATE, date2 DATE);
INSERT INTO dates_table VALUES (DATE '1992-09-20', DATE '1992-03-07');
INSERT INTO dates_table VALUES (DATE '1995-01-01', DATE '1994-12-31');
INSERT INTO dates_table VALUES (DATE '2000-02-29', DATE '2000-03-01');
INSERT INTO dates_table VALUES (DATE '2001-01-01', DATE '2001-01-01');
SELECT least(date1, date2) AS earliest_date FROM dates_table;
SELECT least(DATE '2023-01-01', DATE '2023-12-31') AS earliest_date;
SELECT least(DATE '2000-01-01', DATE '2020-01-01'), least(DATE '1990-01-01', DATE '1995-01-01') AS comparison FROM dates_table;
SELECT (SELECT least(date1, date2) FROM dates_table WHERE date1 < DATE '2000-12-31') AS earliest_before_2001;
CREATE TABLE more_dates (id INT, event_date DATE);
INSERT INTO more_dates VALUES (1, DATE '1995-05-15'), (2, DATE '1992-08-01'), (3, DATE '1989-12-31');
SELECT id, least(event_date, DATE '1993-01-01') AS comparison_date FROM more_dates;
SELECT least(DATE '1999-01-01', (SELECT MAX(event_date) FROM more_dates)) AS latest_comparison;