CREATE TABLE test_table (id INTEGER, value INTEGER);
INSERT INTO test_table VALUES (1, 1), (2, 2), (3, 2), (4, 3), (5, 3), (6, 3);
SELECT mode(value) FROM test_table;
CREATE TABLE sales (product_id INTEGER, amount INTEGER);
INSERT INTO sales VALUES (1, 150), (2, 150), (3, 200), (4, 150), (5, 250), (6, 250);
SELECT product_id, mode(amount) FROM sales GROUP BY product_id;
CREATE TABLE orders (order_id INTEGER, customer_id INTEGER);
INSERT INTO orders VALUES (1, 1), (2, 1), (3, 2), (4, 2), (5, 3);
SELECT customer_id, mode(order_id) FROM orders GROUP BY customer_id;
SELECT (SELECT mode(value) FROM test_table) AS most_frequent_value;
CREATE TABLE duplicates (group_id INTEGER, value INTEGER);
INSERT INTO duplicates VALUES (1, 1), (1, 1), (1, 2), (2, 3), (2, 3), (2, 3);
SELECT group_id, mode(value) FROM duplicates GROUP BY group_id;
CREATE TABLE combined AS SELECT t1.id, t1.value, t2.product_id FROM test_table AS t1 JOIN sales AS t2 ON t1.id = t2.product_id;
SELECT mode(value) FROM combined;
SELECT mode(value) AS mode_value FROM (SELECT value FROM test_table WHERE value IS NOT NULL) AS filtered_values;