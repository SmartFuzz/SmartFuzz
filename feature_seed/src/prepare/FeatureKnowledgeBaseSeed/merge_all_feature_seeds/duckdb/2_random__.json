CREATE TABLE test_data (id INT, value FLOAT, event_date DATE);
INSERT INTO test_data VALUES (1, random()), (2, random()), (3, random()), (4, random());
SELECT id, value, event_date + INTERVAL (CAST(random() * 30 AS INT)) DAY AS new_date FROM test_data;
SELECT id, COUNT(*) AS occurrence, AVG(value) AS average_value FROM (SELECT id, value + random() AS value FROM test_data) AS subquery GROUP BY id HAVING average_value > 0.5;
WITH random_intervals AS (SELECT id, value, event_date + INTERVAL (CAST(random() * 10 AS INT)) DAY AS modified_date FROM test_data) SELECT id, modified_date FROM random_intervals WHERE modified_date IS NOT NULL;
CREATE TABLE temp_data (id INT PRIMARY KEY, random_int INT DEFAULT (CAST(random() * 100 AS INT)));
INSERT INTO temp_data SELECT id, CAST(random() * 100 AS INT) FROM test_data;
SELECT a.id, a.value, b.random_int FROM test_data AS a JOIN temp_data AS b ON a.id = b.id + CAST(random() AS INT);
SELECT id, SUM(CASE WHEN value IS NULL THEN 1 ELSE 0 END) AS null_count FROM test_data GROUP BY id;
SELECT id, random()) + (event_date + INTERVAL (CAST(random() * 30 AS INT)) DAY) AS combined FROM test_data WHERE id > CAST(random() * 3 AS INT);
SELECT id, value, event_date FROM test_data WHERE event_date BETWEEN DATE '2023-01-01' AND DATE '2023-12-31' + INTERVAL (CAST(random() * 5 AS INT)) DAY;