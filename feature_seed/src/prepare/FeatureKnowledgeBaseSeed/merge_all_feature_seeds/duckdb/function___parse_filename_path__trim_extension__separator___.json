CREATE TABLE test_paths (path TEXT);
INSERT INTO test_paths VALUES ('path/to/file.csv'), ('another/path/to/document.docx'), ('./relative/path/to/image.png'), ('C:\Windows\System32\kernel32.dll');
SELECT parse_filename(path, true, 'system') FROM test_paths;
SELECT parse_filename(path, false, 'system') FROM test_paths;
SELECT parse_filename(path, true, 'forward_slash') FROM test_paths;
SELECT parse_filename(path, true, 'backslash') FROM test_paths;
SELECT parse_filename(path, false, 'forward_slash') FROM test_paths;
SELECT parse_filename(path, false, 'backslash') FROM test_paths;
SELECT parse_filename('single_file', true, 'both_slash') AS filename_trimmed;
SELECT parse_filename('single_file.ext', false, 'both_slash') AS filename_not_trimmed;
WITH file_info AS (SELECT path, parse_filename(path, true, 'system') AS filename_trimmed FROM test_paths) SELECT * FROM file_info WHERE filename_trimmed = 'file';
WITH img_files AS (SELECT path FROM test_paths WHERE path LIKE '%.png') SELECT parse_filename(path, true, 'system') FROM img_files;
SELECT parse_filename(path, true, 'both_slash') FROM test_paths WHERE path LIKE '%.docx';
CREATE TABLE file_extensions (extension TEXT);
INSERT INTO file_extensions VALUES ('.csv'), ('.docx'), ('.png'), ('.dll');
SELECT f.path, parse_filename(f.path, true, 'system') AS filename FROM test_paths f JOIN file_extensions e ON f.path LIKE '%' || e.extension;