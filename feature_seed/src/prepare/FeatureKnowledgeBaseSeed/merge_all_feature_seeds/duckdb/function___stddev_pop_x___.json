CREATE TABLE test_data (value FLOAT);
INSERT INTO test_data VALUES (1), (2), (3), (4), (5);
SELECT stddev_pop(value) FROM test_data;
CREATE TABLE additional_data (id INT, value FLOAT);
INSERT INTO additional_data VALUES (1, 6), (2, 7), (3, 8);
SELECT stddev_pop(td.value) FROM test_data td JOIN additional_data ad ON td.value < ad.value;
SELECT stddev_pop(value) FROM (SELECT value FROM test_data WHERE value > 2) AS filtered_data;
CREATE TABLE grouped_data (category INT, value FLOAT);
INSERT INTO grouped_data VALUES (1, 5), (1, 7), (1, 9), (2, 2), (2, 3), (2, 4);
SELECT category, stddev_pop(value) FROM grouped_data GROUP BY category;
SELECT AVG(value) AS avg_value, stddev_pop(value) AS stddev_value FROM (SELECT value FROM test_data UNION SELECT value FROM additional_data);
CREATE TABLE complex_data (group_id INT, num FLOAT);
INSERT INTO complex_data VALUES (1, 10), (1, 20), (2, 30), (3, 40);
SELECT group_id, stddev_pop(num) FROM (SELECT num, group_id FROM complex_data WHERE group_id IN (SELECT DISTINCT group_id FROM complex_data WHERE num > 15)) AS subquery GROUP BY group_id;
INSERT INTO test_data VALUES (NULL), (10), (15);
SELECT stddev_pop(value) FROM test_data WHERE value IS NOT NULL;
CREATE VIEW temp_view AS SELECT value FROM test_data WHERE value < 10;
SELECT stddev_pop(value) FROM temp_view;