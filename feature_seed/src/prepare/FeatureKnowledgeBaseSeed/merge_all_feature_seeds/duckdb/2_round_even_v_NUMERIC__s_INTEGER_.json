CREATE TABLE test_data (id INT, value NUMERIC, date_col DATE);
INSERT INTO test_data (id, value, date_col) VALUES (1, 24.5, DATE '2023-01-15'), (2, NULL, DATE '2023-02-20'), (3, 10.12567, DATE '2023-03-05');
SELECT id, round_even(value, -1) AS rounded_value, date_col - INTERVAL round_even(value, 0) DAY AS new_date FROM test_data WHERE value IS NOT NULL;
SELECT id, round_even((SELECT AVG(value) FROM test_data WHERE value IS NOT NULL), 1) AS avg_rounded_value FROM test_data GROUP BY id HAVING avg_rounded_value > 10;
SELECT t1.id, t1.value, t2.value AS joined_value FROM test_data AS t1 JOIN test_data AS t2 ON round_even(t1.value, 1) - round_even(t2.value, 1) < 0;
SELECT t.id, t.value, (SELECT round_even(t1.value, 0) FROM test_data AS t1 WHERE t1.id = t.id) AS subquery_round FROM test_data AS t WHERE t.value IS NOT NULL ORDER BY round_even(value, 0) DESC;
SELECT id, value, round_even(value, 2) AS precision_rounded_value FROM test_data WHERE date_col - INTERVAL 1 DAY > DATE '2023-02-01';
ALTER TABLE test_data ADD COLUMN description VARCHAR;
UPDATE test_data SET description = 'Test data entry' WHERE id = 1;
DROP TABLE IF EXISTS temp_data;