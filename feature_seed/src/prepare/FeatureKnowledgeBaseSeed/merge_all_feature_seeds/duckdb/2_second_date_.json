CREATE TABLE test_dates (id INTEGER PRIMARY KEY, event_time TIMESTAMP, value BITSTRING);
INSERT INTO test_dates (id, event_time, value) VALUES (1, TIMESTAMP '2021-08-03 11:59:44.123456', '101'::BITSTRING);
INSERT INTO test_dates (id, event_time, value) VALUES (2, TIMESTAMP '2019-01-01 00:00:00', '111'::BITSTRING);
INSERT INTO test_dates (id, event_time, value) VALUES (3, TIMESTAMP '2020-05-15 15:15:15', '000'::BITSTRING);
SELECT id, second(event_time), ~value FROM test_dates WHERE second(event_time) IS NOT NULL ORDER BY second(event_time);
SELECT id, second(event_time) AS seconds, ~value AS negated_value FROM test_dates WHERE seconds > 0 OR negated_value IS NULL;
SELECT id, second(event_time) AS seconds, COUNT(*) OVER (PARTITION BY seconds) AS count_per_second FROM test_dates ORDER BY seconds;
SELECT id, (SELECT COUNT(*) FROM test_dates AS t2 WHERE t2.value = ~test_dates.value) AS bitwise_negation_count FROM test_dates;
SELECT id, second(event_time), (second(event_time) + ~value::INTEGER) AS adjusted_seconds FROM test_dates HAVING adjusted_seconds > 10;
SELECT id, second(event_time) AS seconds FROM test_dates WHERE value IS NOT NULL AND seconds < (SELECT MAX(second(event_time)) FROM test_dates);
CREATE TEMPORARY TABLE temp_bitwise AS SELECT id, second(event_time) AS seconds, ~value AS negated_value FROM test_dates;
SELECT id, seconds FROM temp_bitwise WHERE negated_value IS NOT NULL AND seconds > (SELECT AVG(seconds) FROM temp_bitwise WHERE negated_value IS NOT NULL);