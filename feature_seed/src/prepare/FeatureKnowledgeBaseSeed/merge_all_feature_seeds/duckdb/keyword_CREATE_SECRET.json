CREATE TABLE secrets (id INTEGER PRIMARY KEY, name VARCHAR, value VARCHAR);
CREATE SECRET secret1 FROM 'value1';
CREATE SECRET secret2 FROM 'value2' WITH (description = 'This is a test secret');
CREATE SECRET secret3 FROM (SELECT value FROM secrets WHERE name = 'secret1');
CREATE SECRET secret4 FROM (SELECT value FROM (SELECT name, value FROM secrets WHERE id < 10) AS subquery);
CREATE SECRET secret5 FROM (SELECT MAX(value) FROM secrets) WHERE EXISTS (SELECT 1 FROM secrets WHERE name = 'secret4');
CREATE SECRET secret6 FROM (SELECT name FROM secrets JOIN (SELECT id FROM secrets WHERE id > 5) as ids ON secrets.id = ids.id);
CREATE SECRET secret7 FROM (SELECT COALESCE(MAX(value), 'default') FROM secrets WHERE id IS NOT NULL) WHERE NOT EXISTS (SELECT * FROM secrets WHERE name = 'secret7');