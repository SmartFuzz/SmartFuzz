CREATE TABLE string_test (s1 VARCHAR, s2 VARCHAR);
INSERT INTO string_test VALUES ('duck', 'duckdb'), ('hello', 'HELLO'), ('abc', 'abc'), ('testing', 'testing123'), ('case', 'Case');
SELECT jaro_winkler_similarity(s1, s2) FROM string_test;
SELECT s1, s2, jaro_winkler_similarity(s1, s2) AS similarity FROM string_test WHERE jaro_winkler_similarity(s1, s2) > 0.5;
SELECT s1, s2 FROM string_test WHERE jaro_winkler_similarity(s1, s2) = 1 ORDER BY s1;
SELECT s1, s2, jaro_winkler_similarity(s1, s2) AS similarity FROM string_test WHERE similarity < 0.3 ORDER BY similarity DESC;
CREATE TABLE additional_test (id INT, test1 VARCHAR, test2 VARCHAR);
INSERT INTO additional_test VALUES (1, 'similarity', 'similarity'), (2, 'fuzz', 'Fuzz');
SELECT a.test1, a.test2, jaro_winkler_similarity(a.test1, b.s1) AS sim FROM additional_test a JOIN string_test b ON a.id = 1;
WITH derived AS (SELECT s1, s2, jaro_winkler_similarity(s1, s2) AS sim FROM string_test) SELECT * FROM derived WHERE sim < 0.4;
SELECT s1, s2 FROM string_test WHERE jaro_winkler_similarity(s1, s2) > 0.0 AND LENGTH(s1) < 10;
SELECT DISTINCT s1 FROM string_test WHERE jaro_winkler_similarity(s1, 'duck') > 0.7 ORDER BY s1;
SELECT COUNT(*) FROM string_test WHERE jaro_winkler_similarity(s1, s2) = 1;
SELECT s1, s2, jaro_winkler_similarity(s1, s2) AS similarity FROM string_test WHERE LENGTH(s1) > 3 AND LENGTH(s2) > 3;