CREATE TABLE test_values (id INTEGER, value INTEGER);
INSERT INTO test_values VALUES (1, 5), (2, 10), (3, 15);
SELECT bit_xor(value) FROM test_values;
CREATE TABLE additional_values (id INTEGER, value INTEGER);
INSERT INTO additional_values VALUES (1, 1), (2, 2), (3, 3), (4, 4);
SELECT bit_xor(t.value) FROM test_values t JOIN additional_values a ON t.id = a.id;
CREATE TABLE complex_values (id INTEGER, category VARCHAR, value INTEGER);
INSERT INTO complex_values VALUES (1, 'A', 5), (2, 'A', 10), (3, 'B', 15), (4, 'B', 5);
SELECT bit_xor(value) FROM complex_values WHERE category = 'A';
SELECT bit_xor(value) FROM (SELECT value FROM additional_values WHERE id IN (SELECT id FROM test_values));
CREATE TABLE more_values (group_id INTEGER, bit_value INTEGER);
INSERT INTO more_values VALUES (1, 1), (1, 2), (1, 3), (2, 4), (2, 5);
SELECT group_id, bit_xor(bit_value) FROM more_values GROUP BY group_id;
SELECT bit_xor((SELECT value FROM complex_values WHERE category = 'B')) AS xor_result;
SELECT bit_xor(value) FROM (SELECT value FROM test_values UNION SELECT value FROM additional_values);