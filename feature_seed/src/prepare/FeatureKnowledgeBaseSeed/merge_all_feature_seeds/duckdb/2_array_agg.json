CREATE TABLE test_table (id INT, date_field DATE, value_field INT);
INSERT INTO test_table VALUES (1, DATE '2022-01-01', 10), (2, DATE '2022-01-02', 20), (3, NULL, NULL), (4, DATE '2022-01-03', 30);
SELECT array_agg(value_field) FROM test_table WHERE date_field + 1 = DATE '2022-01-02' GROUP BY id HAVING COUNT(value_field) > 0;
SELECT id, array_agg(value_field + 5) FROM test_table GROUP BY id HAVING array_agg(value_field) IS NOT NULL;
SELECT id, array_agg(value_field) FROM test_table WHERE value_field IS NOT NULL OR date_field + 1 = DATE '2022-01-05' GROUP BY id;
SELECT id, array_agg(DISTINCT value_field) FROM (SELECT value_field, date_field + 1 AS new_date FROM test_table WHERE value_field IS NOT NULL) AS subquery GROUP BY id HAVING COUNT(date_field) > 0;
CREATE TABLE another_table (foreign_id INT, foreign_value INT, created_at DATE);
INSERT INTO another_table VALUES (1, 5, DATE '2022-01-01'), (2, 10, DATE '2022-01-02');
SELECT t1.id, array_agg(t1.value_field + (SELECT COUNT(*) FROM another_table WHERE foreign_id = t1.id) FROM test_table AS t1 WHERE t1.date_field + 2 < DATE '2022-01-05' GROUP BY t1.id;
SELECT array_agg(CONCAT('Value: ', value_field::TEXT)) FROM test_table GROUP BY date_field HAVING COUNT(value_field) < 1;