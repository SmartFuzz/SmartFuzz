CREATE TABLE transactions (id INT, amount FLOAT, transaction_time TIMESTAMP);
INSERT INTO transactions VALUES (1, 100.0, current_time);
INSERT INTO transactions VALUES (2, 200.0, current_time);
SELECT id, amount, transaction_time FROM transactions WHERE transaction_time = current_time;
SELECT MAX(transaction_time) FROM transactions;
SELECT id, amount FROM transactions WHERE transaction_time >= (SELECT current_time FROM transactions WHERE id = 1);
WITH recent_transactions AS (SELECT id, amount FROM transactions WHERE transaction_time > current_time - INTERVAL '1 hour') SELECT COUNT(*) FROM recent_transactions;
SELECT a.id, b.amount FROM transactions a JOIN transactions b ON a.amount = b.amount WHERE a.transaction_time = current_time;
CREATE TABLE users (user_id INT, name VARCHAR);
INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob');
SELECT u.name, t.amount FROM users u JOIN transactions t ON u.user_id = t.id WHERE t.transaction_time = current_time;
SELECT COUNT(*) FROM transactions WHERE transaction_time < current_time AND amount > 50.0;
CREATE TABLE audit_log (id INT, log_time TIMESTAMP, message VARCHAR);
INSERT INTO audit_log VALUES (1, current_time, 'Transaction started');
SELECT * FROM audit_log WHERE log_time = current_time;