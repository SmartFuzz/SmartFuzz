CREATE TABLE numbers (a INTEGER, b INTEGER);
INSERT INTO numbers VALUES (42, 57), (100, 25), (12, 16), (101, 10), (72, 36);
SELECT gcd(a, b) FROM numbers;
SELECT gcd(gcd(42, 57), 12) as nested_gcd FROM numbers;
CREATE TABLE additional_numbers (x INTEGER, y INTEGER);
INSERT INTO additional_numbers VALUES (10, 0), (0, 10), (-20, -30);
SELECT gcd(x, y) FROM additional_numbers;
SELECT n1.a, n2.b, gcd(n1.a, n2.b) FROM numbers n1 JOIN additional_numbers n2 ON n1.a > n2.x;
WITH gcd_values AS (SELECT gcd(a, b) AS g_value FROM numbers) SELECT AVG(g_value) FROM gcd_values;
SELECT gcd(a + 1, b + 1) AS incremented_gcd FROM numbers WHERE a > 20;
SELECT gcd((SELECT MAX(a) FROM numbers), (SELECT MIN(b) FROM numbers)) AS extreme_gcd;