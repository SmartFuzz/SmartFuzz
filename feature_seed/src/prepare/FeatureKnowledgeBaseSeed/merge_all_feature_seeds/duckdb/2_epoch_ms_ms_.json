CREATE TABLE test_table (id INTEGER, ts_col BIGINT, data VARCHAR);
INSERT INTO test_table VALUES (1, 701222400000, 'test1'), (2, NULL, 'test2'), (3, 1625059200000, 'test3');
SELECT id, ~epoch_ms(ts_col) AS negated_ts FROM test_table WHERE ts_col IS NOT NULL;
SELECT id, data, epoch_ms(~(ts_col + 1)) AS processed_ts FROM test_table WHERE ts_col IS NOT NULL;
SELECT id, SUM(~epoch_ms(ts_col)) AS sum_negated_ts FROM test_table WHERE data IS NOT NULL GROUP BY id HAVING sum_negated_ts > epoch_ms(701222400000);
CREATE TABLE temp_table AS SELECT id, ~epoch_ms(ts_col) AS negated_ts FROM test_table;
SELECT a.id, b.negated_ts FROM test_table a JOIN temp_table b ON a.id = b.id WHERE b.negated_ts IS NOT NULL;
WITH negated_values AS (SELECT ~epoch_ms(ts_col) AS negated_ts FROM test_table WHERE ts_col IS NOT NULL) SELECT AVG(negated_ts) FROM negated_values WHERE negated_ts IS NOT NULL;
SELECT ~epoch_ms(COALESCE(ts_col, 0)) AS coerced_negated_ts FROM test_table;
DROP TABLE IF EXISTS temp_table;