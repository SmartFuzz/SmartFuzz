CREATE TABLE test_list (id INTEGER, my_list INTEGER[]);
INSERT INTO test_list VALUES (1, ARRAY[2, 3]), (2, ARRAY[5, 6, 7]);
SELECT list_append(my_list, 4) FROM test_list WHERE id = 1;
SELECT list_append(my_list, 8) FROM test_list WHERE id = 2;
SELECT id, list_append(my_list, 9) AS updated_list FROM test_list;
SELECT id, list_append(list_append(my_list, 10), 11) AS double_append FROM test_list;
SELECT id, list_append(ARRAY_APPEND(my_list, 12), 13) AS append_with_array_append FROM test_list;
CREATE TABLE additional_data (data INTEGER);
INSERT INTO additional_data VALUES (14), (15);
SELECT t.id, list_append(t.my_list, a.data) AS appended_list FROM test_list t JOIN additional_data a ON t.id = 1;
SELECT list_append(list_append(my_list, (SELECT COUNT(*) FROM additional_data)), 16) AS combined_append FROM test_list WHERE id = 1;
SELECT list_append(my_list, (SELECT AVG(data) FROM additional_data)) AS list_average_append FROM test_list WHERE id = 2;
CREATE TABLE empty_list (id INTEGER, my_empty_list INTEGER[]);
INSERT INTO empty_list VALUES (1, ARRAY[]::INTEGER[]);
SELECT list_append(my_empty_list, 17) FROM empty_list WHERE id = 1;
SELECT list_append(my_list, NULL) FROM test_list WHERE id = 1;
SELECT id, list_append(my_list, 2 * (SELECT COUNT(*) FROM test_list)) AS list_after_multiplication FROM test_list;