CREATE TABLE test_data (id INTEGER PRIMARY KEY, value DOUBLE, timestamp_value TIMESTAMP);
INSERT INTO test_data (id, value, timestamp_value) VALUES (1, 1000, TIMESTAMP '2022-01-01 00:00:00');
INSERT INTO test_data (id, value, timestamp_value) VALUES (2, NULL, TIMESTAMP '2023-01-01 00:00:00');
INSERT INTO test_data (id, value, timestamp_value) VALUES (3, 0, TIMESTAMP '2023-01-01 00:00:00');
INSERT INTO test_data (id, value, timestamp_value) VALUES (4, -30, TIMESTAMP '2020-01-01 00:00:00');
WITH computed_values AS (SELECT id, log10(value) AS log_value, timestamp_value + INTERVAL (log10(value) * 1 DAY) AS new_timestamp FROM test_data WHERE value IS NOT NULL) SELECT id, log_value, new_timestamp FROM computed_values WHERE new_timestamp > TIMESTAMP '2022-01-01 00:00:00' ORDER BY new_timestamp;
SELECT a.id, a.value + (SELECT log10(a.value) FROM test_data a WHERE a.id = 1) AS adjusted_value FROM test_data a WHERE a.value IS NOT NULL GROUP BY a.id HAVING adjusted_value > 10;
SELECT id, value, timestamp_value + INTERVAL (CASE WHEN value NULL THEN 0 ELSE log10(value) END) DAY AS modified_timestamp FROM test_data ORDER BY modified_timestamp;
SELECT a.id, a.value, log10(a.value) + (SELECT COUNT(*) FROM test_data b WHERE b.timestamp_value < a.timestamp_value) AS rich_log_value FROM test_data a WHERE a.value IS NOT NULL;
CREATE TEMPORARY TABLE temp_data AS SELECT *, log10(value) AS log_value FROM test_data WHERE value IS NOT NULL;