CREATE TABLE test_table (id INTEGER, text_column VARCHAR(255), num_column INTEGER);
INSERT INTO test_table (id, text_column, num_column) VALUES (1, 'hello world;
42', 0), (2, NULL, 5), (3, 'sample;
56', -1);
SELECT regexp_split_to_table(text_column, ';
? ') AS parts, COUNT(*) OVER (PARTITION BY text_column) AS part_count FROM test_table WHERE num_column >= 0 HAVING part_count > 1;
SELECT (SELECT text_column FROM test_table WHERE id = 1) AS subquery_text, 4! + (SELECT COUNT(*) FROM test_table) AS factorial_plus_count;
SELECT text_column, 3! AS factorial, regexp_split_to_table(text_column, ';
? ') AS parts FROM test_table WHERE parts IS NOT NULL ORDER BY factorial;
SELECT id, !num_column AS neg_num FROM test_table WHERE text_column IS NOT NULL AND LENGTH(text_column) > 0;
CREATE TEMPORARY TABLE temp_split AS SELECT regexp_split_to_table(text_column, ';
? ') AS fragments FROM test_table;
SELECT f, COUNT(*) FROM temp_split GROUP BY f HAVING COUNT(*) > 1;
CREATE TABLE edge_case_table (edge_num INTEGER CHECK (edge_num >= 0));
