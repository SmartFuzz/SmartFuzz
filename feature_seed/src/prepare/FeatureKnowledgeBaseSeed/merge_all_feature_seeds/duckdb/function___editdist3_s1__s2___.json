CREATE TABLE test_strings (s1 VARCHAR, s2 VARCHAR);
INSERT INTO test_strings VALUES ('duck', 'db'), ('hello', 'hllo'), ('case', 'Case'), ('abcd', 'abcde'), ('', 'nonempty');
SELECT s1, s2, editdist3(s1, s2) AS edit_distance FROM test_strings;
SELECT A.s1, B.s2, editdist3(A.s1, B.s2) AS edit_distance FROM test_strings A JOIN test_strings B ON A.s1 <> B.s1;
SELECT editdist3('test', 'TEST'), editdist3('swap', 'waps') AS second_distance;
SELECT (SELECT editdist3('duck', 'db') AS distance) AS duck_distance;
SELECT editdist3(s1, s2) FROM (SELECT 'abc' AS s1, 'ab' AS s2) AS subquery;
CREATE TABLE additional_test (str1 VARCHAR, str2 VARCHAR);
INSERT INTO additional_test VALUES ('fuzzy', 'fizy'), ('kitten', 'sitting'), ('sneeze', 'sneeze');
SELECT A.str1, A.str2, editdist3(A.str1, A.str2) FROM additional_test A WHERE editdist3(A.str1, A.str2) <= 5;
WITH CTESample AS (SELECT 'apple' AS item1, 'aple' AS item2) SELECT item1, item2, editdist3(item1, item2) FROM CTESample;
SELECT COUNT(*) FROM (SELECT DISTINCT editdist3(s1, s2) FROM test_strings) AS distances WHERE distances.edit_distance > 0;
SELECT s1, s2 FROM test_strings WHERE editdist3(s1, s2) < 3 ORDER BY editdist3(s1, s2);