CREATE TABLE events (event_name STRING, event_time TIMESTAMP WITH TIME ZONE);
INSERT INTO events VALUES ('Conference', make_timestamptz(2023, 10, 1, 10, 0, 0.000000, 'UTC'));
INSERT INTO events VALUES ('Lunch', make_timestamptz(2023, 10, 1, 12, 30, 0.000000, 'CET'));
INSERT INTO events VALUES ('Dinner', make_timestamptz(2023, 10, 1, 19, 0, 0.000000, 'EST'));
SELECT event_name, event_time FROM events WHERE event_time > make_timestamptz(2023, 9, 30, 0, 0, 0.000000, 'UTC');
SELECT event_name FROM events WHERE event_time < make_timestamptz(2023, 10, 2, 0, 0, 0.000000, 'CET') AND event_name LIKE 'C%';
CREATE TABLE event_types (event_type STRING);
INSERT INTO event_types VALUES ('Meeting'), ('Social'), ('Workshop');
SELECT e.event_name, e.event_time FROM events e JOIN event_types et ON et.event_type = 'Meeting' WHERE e.event_name = 'Conference';
SELECT event_name, event_time AT TIME ZONE 'UTC' AS utc_time FROM events;
SELECT COUNT(*) FROM events WHERE event_time BETWEEN make_timestamptz(2023, 10, 1, 0, 0, 0.000000, 'CET') AND make_timestamptz(2023, 10, 1, 23, 59, 59.999999, 'CET');
SELECT make_timestamptz(1992, 9, 20, 15, 34, 27.123456, 'GMT') AS historical_event_time;
SELECT make_timestamptz(1999, 12, 31, 23, 59, 59.999999, 'PST') AS new_year_eve_time;
WITH adjusted_events AS (SELECT event_name, event_time AT TIME ZONE 'UTC' AS adjusted_time FROM events) SELECT * FROM adjusted_events WHERE adjusted_time > make_timestamptz(2023, 9, 1, 0, 0, 0.000000, 'UTC');
SELECT event_name, event_time FROM events WHERE EXTRACT(YEAR FROM event_time) = 2023;