CREATE TABLE test_data (id INTEGER, name VARCHAR, created_at TIMESTAMP, amount FLOAT, description VARCHAR);
INSERT INTO test_data VALUES (1, 'Test User', TIMESTAMP '2023-01-01 00:00:00', 100.50, NULL), (2, 'Another User', TIMESTAMP '2023-06-01 00:00:00', 200.75, 'Sample description'), (3, NULL, TIMESTAMP '2023-03-01 00:00:00', NULL, 'Third record'), (4, '', TIMESTAMP '2023-12-31 23:59:59', 0.0, 'Empty name');
SELECT id, substr(name, 1, 2) AS name_part, created_at + INTERVAL (SELECT COUNT(*) FROM test_data) DAY AS updated_at FROM test_data WHERE name IS NOT NULL;
SELECT id, substr(COALESCE(name, 'N/A'), 1, 3) || ' - ' || CAST(amount AS VARCHAR) AS user_info FROM test_data WHERE created_at BETWEEN TIMESTAMP '2023-01-01' AND TIMESTAMP '2023-12-31';
SELECT AVG(amount) AS avg_amount, substr(description, 1, 5) FROM test_data GROUP BY substr(description, 1, 5) HAVING COUNT(*) > 1;
SELECT id, (substr(name, 1, 1) || '...' || CAST(amount + 10 AS VARCHAR)) AS complex_concat FROM test_data ORDER BY complex_concat DESC;
SELECT id, (SELECT COUNT(*) FROM test_data WHERE created_at < test_data.created_at) AS prior_records, substr(name, 1, 2) AS name_substring FROM test_data;
SELECT id, amount, created_at + INTERVAL (CASE WHEN amount < 100 THEN 5 ELSE 15 END) DAY AS modified_date FROM test_data WHERE id IN (SELECT id FROM test_data WHERE amount IS NOT NULL);