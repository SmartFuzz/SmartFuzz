CREATE TABLE test_strings (id INTEGER, str VARCHAR);
INSERT INTO test_strings VALUES (1, 'Hello World'), (2, 'DUCKDB'), (3, 'fUzZ tEstInG');
SELECT lower(str) FROM test_strings;
SELECT id, lower(str) AS lower_str FROM test_strings WHERE id = 1;
SELECT id, lower(str) AS lower_str FROM test_strings WHERE str LIKE 'D%';
SELECT id FROM test_strings WHERE lower(str) = 'fuzz testing';
CREATE TABLE additional_strings (str VARCHAR);
INSERT INTO additional_strings VALUES ('SQL'), ('Functionality'), ('TEST CASES');
SELECT lower(t.str) AS lower_str FROM test_strings t JOIN additional_strings a ON lower(t.str) = lower(a.str);
SELECT id, lower(CONCAT(str, ' - modified')) AS modified_str FROM test_strings;
SELECT lower(substr(str, 1, 5)) AS lower_subs FROM test_strings;
SELECT lower(str) FROM (SELECT str FROM test_strings WHERE id < 3) AS subquery;
CREATE TABLE mixed_data (name VARCHAR, age INTEGER);
INSERT INTO mixed_data VALUES ('Alice', 30), ('BOB', 25);
SELECT name, lower(name) AS lower_name FROM mixed_data;
SELECT lower(subquery.name) FROM (SELECT name FROM mixed_data WHERE age > 20) AS subquery;
SELECT lower(str) FROM (SELECT str FROM test_strings UNION SELECT str FROM additional_strings) AS combined;