CREATE TABLE angles (id INT, degree FLOAT);
INSERT INTO angles (id, degree) VALUES (1, 0), (2, 90), (3, 180), (4, 270), (5, 360);
CREATE TABLE values (id INT, radians_val FLOAT);
INSERT INTO values (id, radians_val) VALUES (1, radians(0)), (2, radians(90)), (3, radians(180)), (4, radians(270));
SELECT a.id, a.degree, v.radians_val FROM angles a JOIN values v ON a.id = v.id WHERE radians(a.degree) @> [radians(90), radians(270)];
SELECT id, degree FROM angles WHERE radians(degree) IS NOT NULL HAVING radians(degree) > radians(45);
WITH RadiansCTE AS (SELECT id, radians(degree) AS radian_value FROM angles) SELECT id FROM RadiansCTE WHERE radian_value @> [0.0, radians(180)];
SELECT a.id, COUNT(*) AS count FROM angles a JOIN values v ON a.id = v.id GROUP BY a.id HAVING radians(a.degree) @> [radians(0), radians(90)];
CREATE TABLE list_test (col_a LIST<FLOAT>);
INSERT INTO list_test (col_a) VALUES (ARRAY[radians(0), radians(90), radians(180)]);
SELECT * FROM list_test WHERE col_a @> [radians(90), radians(180)];
SELECT radians((SELECT MAX(degree) FROM angles)) AS max_radians FROM angles WHERE max_radians @> [radians(90)];
CREATE TABLE fuzz_test (num FLOAT, is_null BOOLEAN);
INSERT INTO fuzz_test (num, is_null) VALUES (NULL, TRUE), (45.5, FALSE), (radians(45), TRUE);
SELECT num FROM fuzz_test WHERE is_null = FALSE AND radians(num) IS NOT NULL;
DROP TABLE IF EXISTS temp_test CASCADE;
CREATE TEMP TABLE temp_test AS SELECT id, radians(degree) AS rad_value FROM angles WHERE degree < 360;