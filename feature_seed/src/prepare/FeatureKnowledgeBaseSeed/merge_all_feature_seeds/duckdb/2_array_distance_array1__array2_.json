CREATE TABLE test_data (id INTEGER PRIMARY KEY, values1 FLOAT[], values2 FLOAT[], event_date DATE);
INSERT INTO test_data (id, values1, values2, event_date) VALUES (1, array_value(1.0, 2.0, 3.0), array_value(2.0, 3.0, 4.0), DATE '1992-03-22');
INSERT INTO test_data (id, values1, values2, event_date) VALUES (2, array_value(3.0, NULL, 5.0), array_value(1.0, 1.0, 1.0), DATE '2000-01-01');
INSERT INTO test_data (id, values1, values2, event_date) VALUES (3, array_value(0.0, 1.0, 2.0), array_value(5.0, 5.0, 5.0), DATE '2023-10-01');
SELECT id, array_distance(values1, values2) AS distance, event_date + INTERVAL (distance > 0)::INTEGER DAY AS new_date FROM test_data WHERE event_date IS NOT NULL;
SELECT id, array_distance(values1, values2) AS distance FROM test_data WHERE distance > 1.0 HAVING distance IS NOT NULL;
SELECT id, SUM(array_distance(values1, values2)) OVER (PARTITION BY id) AS total_distance FROM test_data GROUP BY id HAVING total_distance > 0;
SELECT id, (event_date + INTERVAL 1 DAY) AS next_day, array_distance(array_value(1.0, 2.0), array_value(1.0, 2.1)) + (SELECT MAX(-1) FROM test_data) AS computed_value FROM test_data WHERE event_date < DATE '2000-01-01' ORDER BY next_day;
SELECT id, array_distance(values1, values2) AS distance, (CASE WHEN distance IS NULL THEN 'NULL Distance' ELSE 'Valid Distance' END) AS distance_status FROM test_data WHERE values2 IS NOT NULL;