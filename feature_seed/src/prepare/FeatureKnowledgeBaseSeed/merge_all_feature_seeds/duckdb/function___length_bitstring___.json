CREATE TABLE test_bitstring (id INT, data BITSTRING);
INSERT INTO test_bitstring (id, data) VALUES (1, '1101011'::BITSTRING);
INSERT INTO test_bitstring (id, data) VALUES (2, '10101010'::BITSTRING);
INSERT INTO test_bitstring (id, data) VALUES (3, '111'::BITSTRING);
INSERT INTO test_bitstring (id, data) VALUES (4, '0'::BITSTRING);
SELECT id, length(data) AS bit_length FROM test_bitstring;
SELECT id, length(data) AS bit_length FROM test_bitstring WHERE id > 1;
SELECT id, length(data) AS bit_length FROM test_bitstring WHERE length(data) = 3;
SELECT t1.id, length(t2.data) AS bit_length FROM test_bitstring t1 JOIN test_bitstring t2 ON t1.id <> t2.id;
SELECT id, length(data) AS bit_length FROM test_bitstring WHERE length(data) IN (SELECT length(data) FROM test_bitstring WHERE id < 3) AND length(data) > 0;
SELECT id, length(data) AS bit_length FROM test_bitstring WHERE length(data) = (SELECT MAX(length(data)) FROM test_bitstring);
WITH length_data AS (SELECT id, length(data) AS bit_length FROM test_bitstring) SELECT * FROM length_data WHERE bit_length > 2;
SELECT id, length(COALESCE(data, '0000'::BITSTRING)) AS bit_length FROM test_bitstring;
SELECT id, length(data) + 1 AS increased_bit_length FROM test_bitstring WHERE id < 3;