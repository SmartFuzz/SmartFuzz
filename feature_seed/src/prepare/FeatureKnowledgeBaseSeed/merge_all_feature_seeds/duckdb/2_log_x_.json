CREATE TABLE test_table (id INT, value FLOAT, description VARCHAR, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, value, description) VALUES (1, 100.0, 'Sample 1'), (2, NULL, 'Sample 2'), (3, 0.00001, 'Sample 3'), (4, -100.0, 'Sample 4');
SELECT id, log(value + 1) AS log_value FROM test_table WHERE value IS NOT NULL;
SELECT id, log(value) AS log_value FROM test_table WHERE value >= 0;
SELECT id, (log(value) + 5) AS adjusted_log FROM test_table WHERE description LIKE 'Sample%';
SELECT id, value, log(COALESCE(value, 1)) AS log_value FROM test_table GROUP BY id, value HAVING log_value > 2;
SELECT t1.id, log(COALESCE(t1.value, 1) + t2.value) AS combined_log FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id + 1;
SELECT id, (CASE WHEN value IS NULL THEN 0 ELSE log(value) END) AS safe_log FROM test_table;
CREATE TABLE additional_table (reference_id INT, value_string VARCHAR);
INSERT INTO additional_table (reference_id, value_string) VALUES (1, '200'), (2, NULL);
SELECT at.reference_id, log(CAST(at.value_string AS FLOAT) + COALESCE(t.value, 0)) AS combined_log FROM additional_table at LEFT JOIN test_table t ON at.reference_id = t.id;
SELECT id, log(value + 2) AS log_plus_two FROM test_table ORDER BY log_plus_two DESC;
CREATE TEMPORARY TABLE temp_table AS SELECT id, log(value) AS log_value FROM test_table WHERE value > 0;