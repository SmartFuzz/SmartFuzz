CREATE TABLE test_table (id INT, bitstring_col BIT(8), value_col INT);
INSERT INTO test_table VALUES (1, B'11001100', 15), (2, B'10101010', 5), (3, B'11110000', NULL), (4, B'00010001', 20);
SELECT id, bit_and(bitstring_col >> 1) AS shifted_and FROM test_table GROUP BY id HAVING shifted_and IS NOT NULL;
SELECT id, (SELECT bit_and(bitstring_col) FROM test_table WHERE value_col IS NOT NULL) >> 1 AS subquery_result FROM test_table;
SELECT id, (bit_and(COALESCE(bitstring_col, B'00000000')) >> 2) AS coerced_result FROM test_table;
WITH extreme_values AS (SELECT B'11111111' AS extreme_bitstring) SELECT bit_and(extreme_bitstring >> 3) FROM extreme_values;
SELECT id, bit_and((bitstring_col >> 1) + 4) AS combined_result FROM test_table GROUP BY id HAVING combined_result > 0;
CREATE TEMP TABLE temp_table AS SELECT id, value_col FROM test_table WHERE value_col IS NOT NULL;
INSERT INTO temp_table VALUES (5, 25), (NULL, 10);
SELECT id, bit_and(bitstring_col) AS final_result FROM test_table WHERE id IN (SELECT id FROM temp_table WHERE id IS NOT NULL) GROUP BY id;