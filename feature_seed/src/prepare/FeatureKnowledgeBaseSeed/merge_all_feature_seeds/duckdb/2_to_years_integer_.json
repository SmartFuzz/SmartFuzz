CREATE TABLE test_edges (id INTEGER PRIMARY KEY, year_interval INTERVAL, value INTEGER);
INSERT INTO test_edges (id, year_interval, value) VALUES (1, to_years(5), 10), (2, to_years(-2), NULL), (3, to_years(3), 20);
SELECT id, value // (SELECT COUNT(*) FROM test_edges WHERE value IS NOT NULL) AS normalized_value FROM test_edges WHERE year_interval = to_years(3);
SELECT id, value, (value // 2) + (SELECT COUNT(*) FROM test_edges WHERE year_interval = to_years(5)) AS complex_calculation FROM test_edges ORDER BY complex_calculation;
SELECT id, (to_years(value) // 2) AS interval_years FROM test_edges WHERE value IS NOT NULL;
INSERT INTO test_edges (id, year_interval, value) VALUES (4, to_years(0), 0), (5, to_years(3), 5);
SELECT id, value, (CASE WHEN value IS NOT NULL THEN value // 3 ELSE NULL END) AS division_case FROM test_edges WHERE year_interval IS NOT NULL;
SELECT t1.id, t2.value FROM test_edges t1 JOIN test_edges t2 ON t1.id = t2.id // 2 WHERE t1.year_interval = to_years(5);
SELECT id, value, (to_years(value // 2) + to_years(1)) AS future_interval FROM test_edges GROUP BY id, value HAVING future_interval IS NOT NULL;
UPDATE test_edges SET value = (value // (SELECT COUNT(*) FROM test_edges WHERE value > 0)) WHERE year_interval IS NOT NULL;