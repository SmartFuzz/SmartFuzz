CREATE TABLE test_data (id INTEGER, value VARCHAR, amount DECIMAL(10,5));
INSERT INTO test_data VALUES (1, '1', 3.14159), (2, '2', NULL), (3, '', 0.12345), (4, 'NULL', 2.71828);
SELECT id, map() AS empty_map, (amount + CAST(value AS DECIMAL(10,5))) AS calculated_value FROM test_data;
SELECT id, (SELECT COUNT(*) FROM test_data t2 WHERE t2.amount IS NULL OR t2.id = t1.id) AS null_count FROM test_data t1;
SELECT id, (SUM(amount) + (SELECT COUNT(*) FROM test_data WHERE value != '')) AS aggregate_with_count FROM test_data GROUP BY id HAVING aggregate_with_count > 1;
CREATE TABLE second_table (ref_id INTEGER, desc_value VARCHAR);
INSERT INTO second_table VALUES (1, 'Description 1'), (2, NULL), (3, 'Description 3');
SELECT t1.id, (COALESCE(SUM(amount), 0.0) + CAST(COALESCE(STRING_AGG(desc_value, ','), '') AS DECIMAL(10,5))) AS total FROM test_data t1 LEFT JOIN second_table t2 ON t1.id = t2.ref_id GROUP BY t1.id;
SELECT id, (SELECT COUNT(*) FROM (SELECT value FROM test_data WHERE amount IS NOT NULL) AS inner_table) AS value_count FROM test_data;
SELECT id, (map() + (amount - 2.5)) AS adjusted_amount FROM test_data WHERE adjusted_amount > 0;