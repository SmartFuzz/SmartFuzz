CREATE TABLE test_intervals (id INTEGER, interval_months INTEGER);
INSERT INTO test_intervals VALUES (1, 0), (2, 1), (3, -1), (4, 12), (5, 24), (6, 60);
SELECT id, to_months(interval_months) AS month_interval FROM test_intervals WHERE interval_months >= 0;
SELECT id, to_months(interval_months) AS month_interval FROM test_intervals WHERE interval_months < 0;
SELECT t1.id, to_months(t1.interval_months) AS months, t2.description FROM test_intervals t1 JOIN (SELECT 'Interval Test' AS description) t2 ON t1.id = 1;
WITH monthly_intervals AS (SELECT id, to_months(interval_months) AS month_interval FROM test_intervals) SELECT id, month_interval FROM monthly_intervals WHERE month_interval > 12;
CREATE TABLE additional_intervals (start_date DATE);
INSERT INTO additional_intervals VALUES ('2021-01-01'), ('2022-01-01'), ('2023-01-01');
SELECT a.start_date, DATE_ADD(start_date, INTERVAL to_months(t.interval_months) MONTH) AS new_date FROM additional_intervals a JOIN test_intervals t ON t.id = 2;
SELECT id, to_months(interval_months) AS month_interval FROM test_intervals WHERE interval_months IN (SELECT DISTINCT interval_months FROM test_intervals WHERE interval_months > 0);
SELECT SUM(to_months(interval_months)) AS total_months FROM test_intervals;