CREATE TABLE radians_table (angle FLOAT);
INSERT INTO radians_table VALUES (0), (pi() / 2), (pi()), (3 * pi() / 2), (2 * pi());
SELECT degrees(angle) FROM radians_table;
SELECT degrees(pi() / 4) AS degrees_quarter_pi;
SELECT degrees(0) AS degrees_zero, degrees(pi()) AS degrees_pi;
SELECT degrees((SELECT avg(angle) FROM radians_table)) AS avg_degrees;
SELECT degrees((SELECT min(angle) FROM radians_table WHERE angle > 0)) AS min_positive_degrees;
CREATE TABLE additional_angles (angle FLOAT);
INSERT INTO additional_angles VALUES (pi() / 3), (pi() * 5 / 6);
SELECT degrees(a.angle + b.angle) AS total_degrees FROM radians_table a JOIN additional_angles b ON a.angle < b.angle;
SELECT degrees(angle) * 2 AS double_degrees FROM radians_table WHERE angle > pi();
CREATE TABLE angles_view AS SELECT degrees(angle) AS degree_angle FROM radians_table;
SELECT * FROM angles_view WHERE degree_angle < 360;