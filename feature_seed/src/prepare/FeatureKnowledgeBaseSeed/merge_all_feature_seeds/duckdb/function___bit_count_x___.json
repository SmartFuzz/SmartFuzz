CREATE TABLE numbers (val INTEGER);
INSERT INTO numbers VALUES (0), (1), (2), (3), (4), (5), (16), (31), (255), (256);
SELECT val, bit_count(val) AS bits_set FROM numbers;
SELECT bit_count((SELECT MAX(val) FROM numbers)) AS max_bits_set;
SELECT bit_count((SELECT MIN(val) FROM numbers)) AS min_bits_set;
SELECT COUNT(*) FROM numbers WHERE bit_count(val) = 0;
SELECT COUNT(*) FROM numbers WHERE bit_count(val) BETWEEN 1 AND 3;
SELECT val, bit_count(val) AS bits_set FROM numbers WHERE val < (SELECT AVG(val) FROM numbers);
CREATE TABLE extra_numbers (val INTEGER);
INSERT INTO extra_numbers VALUES (7), (15), (31), (63), (127);
SELECT n.val, e.val, bit_count(n.val) + bit_count(e.val) AS total_bits_set FROM numbers n JOIN extra_numbers e ON n.val < e.val;
SELECT bit_count(COALESCE((SELECT MAX(val) FROM numbers), 0)) AS safe_max_bits_set;
SELECT val, bit_count(val) AS bits_set FROM (SELECT val FROM numbers WHERE val > 10) AS subquery;