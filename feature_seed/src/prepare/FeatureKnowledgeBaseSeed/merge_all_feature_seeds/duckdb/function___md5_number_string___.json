CREATE TABLE test_strings (input_string VARCHAR);
INSERT INTO test_strings VALUES (''), ('a'), ('123'), ('!@#$%^&*()'), ('Lorem ipsum dolor sit amet, consectetur adipiscing elit. Integer nec odio. Praesent libero. Sed cursus ante dapibus diam.'), (NULL);
SELECT md5_number(input_string) FROM test_strings;
SELECT md5_number('test') AS hash_test, md5_number('test') FROM (SELECT 'test' AS input_string) AS subquery;
SELECT md5_number(CONCAT(a.input_string, b.input_string)) FROM (SELECT input_string FROM test_strings LIMIT 5) AS a JOIN (SELECT input_string FROM test_strings LIMIT 5 OFFSET 1) AS b ON a.input_string != b.input_string;
SELECT input_string, md5_number(input_string) FROM (SELECT input_string FROM test_strings WHERE input_string IS NOT NULL) AS non_null_strings;
SELECT COUNT(*) AS hash_count, md5_number(input_string) AS hash_value FROM (SELECT input_string FROM test_strings) GROUP BY hash_value HAVING hash_count > 1;
CREATE TABLE more_strings AS SELECT input_string FROM test_strings WHERE LENGTH(input_string) > 10;
SELECT md5_number(more_strings.input_string) FROM more_strings WHERE EXISTS (SELECT 1 FROM test_strings WHERE test_strings.input_string = more_strings.input_string);
SELECT md5_number(md5_number(input_string)) FROM test_strings;