CREATE TABLE test_table (id INTEGER PRIMARY KEY, timestamp_col TIMESTAMP, angle_col FLOAT);
INSERT INTO test_table (id, timestamp_col, angle_col) VALUES (1, TIMESTAMP '1992-03-22 01:02:03', 90), (2, TIMESTAMP '1992-03-23 01:02:03', 0), (3, TIMESTAMP '1992-03-24 01:02:03', NULL), (4, TIMESTAMP NULL, 180);
SELECT id, sin(angle_col) + INTERVAL 5 DAY AS adjusted_time FROM test_table WHERE angle_col IS NOT NULL;
SELECT t1.id, sin(90) + INTERVAL (SELECT COUNT(*) FROM test_table WHERE angle_col IS NOT NULL) DAY AS adjusted_time FROM test_table t1 WHERE t1.timestamp_col < TIMESTAMP '1992-03-23 00:00:00';
SELECT id, timestamp_col + INTERVAL CAST(sin(angle_col) AS INT) DAY AS new_timestamp FROM test_table GROUP BY id, timestamp_col HAVING new_timestamp IS NOT NULL;
SELECT t1.id, t1.timestamp_col, sin(t1.angle_col) AS sine_value FROM test_table t1 JOIN test_table t2 ON t1.id <> t2.id AND sin(t2.angle_col) > 0 WHERE t1.timestamp_col IS NOT NULL ORDER BY sine_value;
CREATE TEMPORARY TABLE temp_table AS SELECT id, sin(angle_col) AS sine_value FROM test_table WHERE angle_col IS NOT NULL;
SELECT MIN(sine_value) + INTERVAL 1 DAY FROM temp_table GROUP BY id HAVING MIN(sine_value) IS NOT NULL;
SELECT id, sin(angle_col) + INTERVAL 10 DAY AS future_date FROM (SELECT * FROM test_table WHERE id = 1 UNION ALL SELECT * FROM test_table WHERE id = 2) as subquery HAVING future_date IS NOT NULL;