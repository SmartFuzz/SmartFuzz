CREATE TABLE test_strings (id INTEGER, str_value STRING);
INSERT INTO test_strings VALUES (1, 'Hello🦆'), (2, 'DuckDB'), (3, 'FuzzTesting'), (4, '❤️‍🔥'), (5, '🐉🦄');
SELECT id, right(str_value, 3) FROM test_strings;
SELECT id, right(str_value, CASE WHEN LENGTH(str_value) > 5 THEN 5 ELSE LENGTH(str_value) END) FROM test_strings;
SELECT id, right(str_value, 0) AS empty_string FROM test_strings;
SELECT id, right(str_value, LENGTH(str_value)) AS full_string FROM test_strings;
SELECT id, right(str_value, -1) AS negative_count FROM test_strings;
SELECT id, right((SELECT str_value FROM test_strings WHERE id = 1), 3) AS subquery_example FROM test_strings;
SELECT T.id, right(T.str_value, 2) AS right_two_chars FROM test_strings T INNER JOIN (SELECT id FROM test_strings WHERE id > 2) AS S ON T.id = S.id;
WITH StringData AS (SELECT str_value FROM test_strings) SELECT right(str_value, 4) FROM StringData;
CREATE TABLE additional_strings (val STRING);
INSERT INTO additional_strings VALUES ('Example1'), ('Example2'), ('TestString');
SELECT a.val, right(a.val, 4) AS right_chars FROM additional_strings AS a UNION SELECT str_value, right(str_value, 2) FROM test_strings WHERE LENGTH(str_value) >= 2;