CREATE TABLE numbers (a INTEGER, b INTEGER, c INTEGER, d FLOAT, e VARCHAR(10));
INSERT INTO numbers VALUES (42, 57, 0, NULL, 'text1'), (10, 15, 1, NULL, 'text2'), (null, null, 2, 3.14, 'text3');
SELECT least_common_multiple(a, (SELECT MAX(b) FROM numbers WHERE c < 2)) FROM numbers WHERE (a <@ [2, 10, 12]) OR e = 'text1';
SELECT a, least_common_multiple(a, b) AS lcm, CASE WHEN d IS NULL THEN 'NULL' ELSE 'NOT NULL' END AS null_status FROM numbers GROUP BY a, lcm HAVING lcm < 100;
SELECT AVG(least_common_multiple(a, b)) OVER (PARTITION BY c) AS avg_lcm FROM (SELECT a, b, c FROM numbers WHERE [a, b] <@ [1, 2, 3, 4, 5]) AS subquery;
SELECT least_common_multiple(MAX(a), MIN(b)) FROM numbers WHERE (e IS NOT NULL OR d IS NULL);
CREATE TABLE conditions (f DATE, g BOOLEAN);
INSERT INTO conditions VALUES (CURRENT_DATE, TRUE), (NULL, FALSE);
SELECT least_common_multiple(COALESCE((SELECT COUNT(*) FROM conditions WHERE g <@ [FALSE]), 1), 2) AS LCM_value;
SELECT a, least_common_multiple(a, MAX(b)) FROM numbers JOIN conditions ON conditions.f IS NOT NULL WHERE a IS NOT NULL GROUP BY a HAVING least_common_multiple(a, MAX(b)) < 100;