CREATE TABLE test_table (id INTEGER PRIMARY KEY, values_list LIST<INTEGER>, other_value INTEGER);
INSERT INTO test_table VALUES (1, [1, 2, 3], NULL);
INSERT INTO test_table VALUES (2, NULL, 10);
INSERT INTO test_table VALUES (3, [4, 5], 20);
INSERT INTO test_table VALUES (4, [NULL], NULL);
SELECT id, array_push_back(values_list, 6) AS updated_list FROM test_table WHERE other_value IS NOT NULL;
SELECT id, values_list || [7] AS concatenated_list FROM test_table WHERE values_list IS NOT NULL;
SELECT id, array_push_back(values_list, (SELECT MAX(other_value) FROM test_table WHERE id < 3)) AS list_with_max FROM test_table;
SELECT id, values_list || (SELECT array_push_back(values_list, 9) FROM test_table WHERE id = 1) AS nested_concat FROM test_table;
WITH updated AS (SELECT id, array_push_back(values_list, 10) AS new_list FROM test_table) SELECT id, new_list || [20] AS combined_list FROM updated WHERE new_list IS NOT NULL;
SELECT id, array_push_back(NULL, 5) AS null_push_test FROM test_table;
SELECT id, values_list || (SELECT NULL) AS null_concat FROM test_table WHERE values_list IS NOT NULL;
SELECT id, (SELECT array_push_back(values_list, 8) FROM test_table WHERE id = 2) || [1, 2] AS edge_case_concat FROM test_table WHERE id = 1;