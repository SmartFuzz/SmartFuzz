CREATE TABLE test_errors (id INT, description VARCHAR);
INSERT INTO test_errors VALUES (1, error('access_mode'));
SELECT id, description FROM test_errors WHERE description = error('access_mode');
CREATE TABLE nested_example (a INT, b VARCHAR);
INSERT INTO nested_example VALUES (1, error('invalid_input'));
SELECT a, (SELECT error('nested_error_handling') FROM nested_example WHERE b = 'some_value') FROM nested_example;
CREATE TABLE join_example (id INT, value INT);
INSERT INTO join_example VALUES (1, error('join_error'));
SELECT je.id, (SELECT error('join_subquery_error') FROM join_example WHERE value > 0) as error_message FROM join_example je;
CREATE TABLE complex_table (id INT, type VARCHAR);
INSERT INTO complex_table VALUES (1, 'type1'), (2, 'type2'), (3, error('complex_error'));
SELECT ct.id, ct.type, error('complex_join_error') FROM complex_table ct JOIN test_errors te ON ct.id = te.id WHERE te.description IS NOT NULL;