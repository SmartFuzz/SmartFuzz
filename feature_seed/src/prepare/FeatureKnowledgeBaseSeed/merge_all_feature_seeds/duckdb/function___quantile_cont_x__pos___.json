CREATE TABLE test_data (value FLOAT);
INSERT INTO test_data VALUES (10.0), (20.0), (30.0), (40.0), (50.0);
SELECT quantile_cont(value, 0.0) FROM test_data;
SELECT quantile_cont(value, 1.0) FROM test_data;
SELECT quantile_cont(value, 0.5) FROM test_data;
SELECT quantile_cont(value, 0.75) FROM test_data;
SELECT quantile_cont(value, [0.0, 0.5, 1.0]) FROM test_data;
SELECT quantile_cont(value, [0.1, 0.9]) FROM test_data;
CREATE TABLE another_data (group_id INT, value FLOAT);
INSERT INTO another_data VALUES (1, 15.0), (1, 25.0), (2, 35.0), (2, 45.0);
SELECT group_id, quantile_cont(value, 0.5) FROM another_data GROUP BY group_id;
SELECT group_id, quantile_cont(value, [0.25, 0.75]) FROM another_data GROUP BY group_id;
WITH ranked_values AS (SELECT value, ROW_NUMBER() OVER (ORDER BY value) AS rn FROM test_data) SELECT quantile_cont(value, 0.5) FROM ranked_values;
SELECT a.group_id, quantile_cont(a.value, 0.5) FROM another_data a JOIN (SELECT DISTINCT group_id FROM another_data) b ON a.group_id = b.group_id GROUP BY a.group_id;
CREATE TABLE random_data (value FLOAT);
INSERT INTO random_data VALUES (NULL), (NULL), (25.0), (30.0), (NULL), (35.0);
SELECT quantile_cont(value, 0.5) FROM random_data;
SELECT quantile_cont(value, 0.25) FROM random_data WHERE value IS NOT NULL;