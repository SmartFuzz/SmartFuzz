CREATE TABLE test_table (text_column VARCHAR);
INSERT INTO test_table VALUES ('hello world;
42'), ('foo bar;
123;
baz'), ('one;
two;
three;
four;
five'), ('singleentry'), (''), (NULL);
SELECT regexp_split_to_array(text_column, ';
') FROM test_table;
SELECT t.text_column, regexp_split_to_array(t.text_column, ';
? ') AS split_result FROM test_table t;
SELECT t1.text_column, t2.split_result FROM test_table t1 JOIN (SELECT text_column, regexp_split_to_array(text_column, ';
? ') AS split_result FROM test_table) t2 ON t1.text_column = t2.text_column;
SELECT AVG(LENGTH(split_element)) FROM (SELECT unnest(regexp_split_to_array(text_column, ';
? ')) AS split_element FROM test_table) AS split_elements;
SELECT text_column, COUNT(split_element) FROM (SELECT text_column, unnest(regexp_split_to_array(text_column, ';
? ')) AS split_element FROM test_table) AS split_table GROUP BY text_column;
SELECT text_column, regexp_split_to_array(text_column, '([;
]+)') AS split_result FROM test_table WHERE text_column IS NOT NULL;
SELECT t.text_column, LENGTH(split_element) FROM test_table t CROSS JOIN unnest(regexp_split_to_array(t.text_column, ';
? ')) AS split_element WHERE split_element <> '';