CREATE TABLE test_table (id INTEGER, value INTEGER);
INSERT INTO test_table VALUES (1, 1), (2, 2), (3, 2), (4, 3), (5, 4), (6, 5);
SELECT bitstring_agg(value) FROM test_table;
CREATE TABLE another_table (id INTEGER, ref_value INTEGER);
INSERT INTO another_table VALUES (1, 1), (2, 1), (3, 2), (4, 4);
SELECT bitstring_agg(t.value) FROM test_table t JOIN another_table a ON t.value = a.ref_value;
CREATE TABLE min_max_table (min_value INTEGER, max_value INTEGER);
INSERT INTO min_max_table VALUES (0, 5);
SELECT bitstring_agg(value) FROM test_table WHERE value BETWEEN (SELECT min_value FROM min_max_table) AND (SELECT max_value FROM min_max_table);
SELECT bitstring_agg(value) FROM (SELECT DISTINCT value FROM test_table WHERE value IS NOT NULL) AS distinct_values;
CREATE TABLE complex_table (coll_id INTEGER, value INTEGER, category VARCHAR);
INSERT INTO complex_table VALUES (1, 1, 'A'), (2, 2, 'A'), (3, 1, 'B'), (4, 3, 'B'), (5, 4, 'C');
SELECT category, bitstring_agg(value) FROM complex_table GROUP BY category;
SELECT id, bitstring_agg(value) OVER (PARTITION BY id ORDER BY value) FROM test_table ORDER BY id;
SELECT bitstring_agg(value) FROM (SELECT value FROM test_table UNION SELECT ref_value FROM another_table) AS combined;