CREATE TABLE test_dates (id INTEGER, test_date DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-02-15'), (2, DATE '2023-10-01'), (3, DATE '2000-02-29'), (4, DATE '1970-01-01'), (5, DATE '2023-12-31');
SELECT id, test_date, isodow(test_date) AS iso_weekday FROM test_dates;
SELECT id, test_date, isodow(test_date) AS iso_weekday FROM test_dates WHERE YEAR(test_date) = 1992;
SELECT id, test_date, isodow(test_date) AS iso_weekday FROM test_dates WHERE isodow(test_date) IN (1, 7);
CREATE TABLE weekend_dates AS SELECT test_date FROM test_dates WHERE isodow(test_date) IN (6, 7);
SELECT COUNT(*) AS weekend_count FROM weekend_dates;
SELECT id, test_date FROM test_dates WHERE isodow(test_date) = (SELECT MAX(isodow(test_date)) FROM test_dates);
SELECT test_date, isodow(test_date) AS iso_weekday FROM (SELECT test_date FROM test_dates WHERE id = 3) AS subquery;
SELECT t1.test_date, t2.isodow_date FROM test_dates t1 JOIN (SELECT test_date, isodow(test_date) AS isodow_date FROM test_dates WHERE isodow(test_date) = 5) t2 ON t1.test_date = t2.test_date;
SELECT id, test_date, CASE WHEN isodow(test_date) = 1 THEN 'Monday' WHEN isodow(test_date) = 2 THEN 'Tuesday' WHEN isodow(test_date) = 3 THEN 'Wednesday' WHEN isodow(test_date) = 4 THEN 'Thursday' WHEN isodow(test_date) = 5 THEN 'Friday' WHEN isodow(test_date) = 6 THEN 'Saturday' ELSE 'Sunday' END AS day_name FROM test_dates;