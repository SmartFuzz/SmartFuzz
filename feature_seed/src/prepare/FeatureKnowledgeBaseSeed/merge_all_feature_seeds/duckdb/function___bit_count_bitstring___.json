CREATE TABLE bit_table (id INT, bitstring BIT(8));
INSERT INTO bit_table VALUES (1, '10101010'::BIT), (2, '11110000'::BIT), (3, '00000000'::BIT);
SELECT id, bit_count(bitstring) FROM bit_table;
CREATE TABLE another_table (ref_id INT, value INT);
INSERT INTO another_table VALUES (1, 100), (1, 200), (2, 300);
SELECT b.id, bit_count(b.bitstring) AS set_bits, SUM(a.value) AS total_value FROM bit_table b JOIN another_table a ON b.id = a.ref_id GROUP BY b.id;
SELECT id, bit_count('1101'::BIT) AS count1, bit_count('11011'::BIT) AS count2, bit_count(bitstring) AS bit_count_value FROM bit_table WHERE bitstring IS NOT NULL;
WITH counted_bits AS (SELECT id, bit_count(bitstring) AS bit_count_value FROM bit_table) SELECT COUNT(*) FROM counted_bits WHERE bit_count_value > 4;
CREATE TABLE additional_table (x BIT(4));
INSERT INTO additional_table VALUES ('1111'::BIT), ('0000'::BIT), ('1010'::BIT);
SELECT a.x, bit_count(a.x) FROM additional_table a WHERE bit_count(a.x) = 2;
SELECT b.id, bit_count(b.bitstring) FROM bit_table b WHERE b.id IN (SELECT ref_id FROM another_table WHERE value > 50);