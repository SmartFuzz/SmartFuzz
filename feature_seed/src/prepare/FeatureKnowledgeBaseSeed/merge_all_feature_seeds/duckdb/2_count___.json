CREATE TABLE test_table (id INTEGER, binary_data BITSTRING, value VARCHAR(255), created_at TIMESTAMP);
INSERT INTO test_table (id, binary_data, value, created_at) VALUES (1, '10101'::BITSTRING, 'Sample Text', '2023-01-01 00:00:00'), (2, NULL, 'Another Sample', '2023-01-02 01:00:00'), (3, '11100'::BITSTRING, '', '2023-01-03 02:00:00');
SELECT COUNT(*) FROM (SELECT id, binary_data << 2 AS shifted_data FROM test_table WHERE created_at IS NOT NULL) AS shifted_results GROUP BY shifted_data HAVING COUNT(*) > 0;
SELECT COUNT(*) FROM (SELECT id, value, (binary_data << 1) AS bit_shift_result FROM test_table WHERE value IS NOT NULL) AS inner_query GROUP BY bit_shift_result HAVING COUNT(*) > 1;
SELECT COUNT(*) FROM (SELECT id, (CASE WHEN binary_data IS NULL THEN 0 ELSE 1 END) AS is_null_check, value FROM test_table) AS outer_query GROUP BY is_null_check;
SELECT COUNT(*) FROM (SELECT id, binary_data << 1 AS shifted_value, (SELECT COUNT(*) FROM test_table t2 WHERE t2.id = test_table.id) AS correlated_count FROM test_table) AS correlated_query GROUP BY shifted_value HAVING correlated_count > 1;
INSERT INTO test_table (id, binary_data, value, created_at) VALUES (4, '000001'::BITSTRING, NULL, '2023-01-04 03:00:00');
SELECT COUNT(*) FROM (SELECT DISTINCT id, (value || ' extended') AS extended_value FROM test_table WHERE binary_data << 3 IS NOT NULL) AS distinct_values GROUP BY extended_value HAVING COUNT(*) < 10;
SELECT COUNT(*) FROM (SELECT id, (CASE WHEN value = '' THEN NULL ELSE value END) AS checked_value FROM test_table) AS check_query WHERE checked_value IS NULL;