CREATE TABLE test_table (id INTEGER, value TIMESTAMP, score FLOAT);
INSERT INTO test_table (id, value, score) VALUES (1, TIMESTAMP '1992-03-27', 5.0), (2, TIMESTAMP '1992-03-22', NULL), (3, TIMESTAMP '1992-03-30', 10.0);
SELECT id, max(score, 2) FROM (SELECT id, score FROM test_table WHERE value - TIMESTAMP '1992-03-25' > INTERVAL '0 days') GROUP BY id HAVING max(score, 2) IS NOT NULL;
SELECT t1.id, max(t2.score, 1) FROM test_table t1 JOIN test_table t2 ON t1.value - t2.value = INTERVAL '5 days' GROUP BY t1.id ORDER BY max(t2.score, 1) DESC;
SELECT id, max(NULLIF(score, 0), 3) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value - TIMESTAMP '1992-03-23' < INTERVAL '10 days') GROUP BY id HAVING max(NULLIF(score, 0), 3) > 4;
CREATE TABLE temp_table AS SELECT id, value, score FROM test_table WHERE value IS NOT NULL;
INSERT INTO temp_table (id, value, score) VALUES (4, TIMESTAMP '1992-03-10', 0.0), (5, TIMESTAMP '1992-03-20', 15.0);
SELECT max(t1.score, 2) FROM temp_table t1 WHERE t1.value - (SELECT MIN(value) FROM temp_table) < INTERVAL '7 days' GROUP BY t1.id;
CREATE TEMP TABLE complex_table AS SELECT id, value, max(score) OVER (PARTITION BY id ORDER BY value DESC) AS max_score FROM test_table;
SELECT t.id, max(t.score, 2) FROM (SELECT id, value, score FROM test_table ORDER BY value DESC LIMIT 10) AS t GROUP BY t.id HAVING max(t.score, 2) IS NOT NULL;