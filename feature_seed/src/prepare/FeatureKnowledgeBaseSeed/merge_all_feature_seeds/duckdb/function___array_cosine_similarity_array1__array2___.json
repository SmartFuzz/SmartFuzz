CREATE TABLE arrays_table (id INTEGER, array1 FLOAT[], array2 FLOAT[]);
INSERT INTO arrays_table VALUES (1, array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
SELECT array_cosine_similarity(array1, array2) FROM arrays_table WHERE id = 1;
INSERT INTO arrays_table VALUES (2, array_value(0.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
SELECT array_cosine_similarity(array1, array2) FROM arrays_table WHERE id = 2;
CREATE TABLE test_arrays (arr1 FLOAT[], arr2 FLOAT[]);
INSERT INTO test_arrays VALUES (array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT));
SELECT array_cosine_similarity(arr1, arr2) FROM test_arrays;
CREATE TABLE more_arrays AS SELECT array_value(1.0, 2.0, 3.0) AS arr1, array_value(4.0, 5.0, 6.0) AS arr2;
SELECT array_cosine_similarity(arr1, arr2) FROM more_arrays;
CREATE TABLE complex_test AS SELECT id, array_value(1.0, 2.0, 3.0) AS arr1, array_value(3.0, 2.0, 1.0) AS arr2 FROM (SELECT 1 AS id) AS sub;
SELECT array_cosine_similarity(arr1, arr2) FROM complex_test;
CREATE TABLE large_arrays (values1 FLOAT[], values2 FLOAT[]);
INSERT INTO large_arrays VALUES (array_value(1::FLOAT, 1::FLOAT, 1::FLOAT, 1::FLOAT, 1::FLOAT), array_value(1::FLOAT, 1::FLOAT, 1::FLOAT, 1::FLOAT, 1::FLOAT));
SELECT array_cosine_similarity(values1, values2) FROM large_arrays;
SELECT array_cosine_similarity(array_value(3.0, 4.0), array_value(0.0, 0.0));
CREATE TABLE array_test AS SELECT array_value(1.0, 2.0) AS a1, array_value(2.0, 3.0) AS a2 UNION ALL SELECT array_value(4.0, 5.0) AS a1, array_value(5.0, 6.0) AS a2;
SELECT array_cosine_similarity(a1, a2) FROM array_test;
SELECT array_cosine_similarity(array_value(10.0, 10.0), array_value(1.0, NULL));