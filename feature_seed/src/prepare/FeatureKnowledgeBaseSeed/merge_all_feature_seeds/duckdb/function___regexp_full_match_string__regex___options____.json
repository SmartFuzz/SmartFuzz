CREATE TABLE test_strings (id INT, str TEXT);
INSERT INTO test_strings VALUES (1, 'anabanana'), (2, 'banana'), (3, 'anan'), (4, 'an'), (5, 'aaaaanaaaa'), (6, 'hello');
SELECT id, str, regexp_full_match(str, '(an)*') AS matches FROM test_strings;
SELECT id, str, regexp_full_match(str, '^(an)*$') AS matches FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE str LIKE 'a%');
SELECT id, str, regexp_full_match(str, '^[a-z]{4,6}$') AS matches FROM test_strings WHERE regexp_full_match(str, '^an$') OR regexp_full_match(str, '^banana$');
CREATE TABLE regex_tests (pattern TEXT, test_str TEXT);
INSERT INTO regex_tests VALUES ('(an)*', 'anabanana'), ('(an)+', 'banana'), ('^an$', 'an'), ('^.*ana.*$', 'hello');
SELECT rt.test_str, rt.pattern, regexp_full_match(rt.test_str, rt.pattern) AS is_match FROM regex_tests rt JOIN test_strings ts ON ts.str = rt.test_str;
SELECT COUNT(*) FROM test_strings WHERE regexp_full_match(str, '^[an]+' AND id > 1) GROUP BY str;
WITH regex_results AS (SELECT id, str, regexp_full_match(str, '.*ana.*') AS matches FROM test_strings) SELECT COUNT(*) FROM regex_results WHERE matches;
SELECT str FROM test_strings WHERE regexp_full_match(str, '^[^a]*$') AND id <= 6;