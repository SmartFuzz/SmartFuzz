CREATE TABLE test_struct (data STRUCT<i: INTEGER, s: STRING>);
INSERT INTO test_struct VALUES (ROW(1, 'one'));
INSERT INTO test_struct VALUES (ROW(2, 'two'));
INSERT INTO test_struct VALUES (ROW(3, 'three'));
SELECT data['i'] FROM test_struct;
SELECT data['s'] FROM test_struct WHERE data['i'] > 1;
CREATE TABLE nested_test AS SELECT ROW(ROW(1, 'a'), ROW(2, 'b')) AS nested_data;
SELECT nested_data['f0']['i'] FROM nested_test;
SELECT nested_data['f1']['s'] FROM nested_test WHERE nested_data['f0']['i'] = 1;
CREATE TABLE advanced_test (info STRUCT<a: INTEGER, details: STRUCT<description: STRING>>);
INSERT INTO advanced_test VALUES (ROW(1, ROW('first'))), (ROW(2, ROW('second')));
SELECT info['details']['description'] FROM advanced_test WHERE info['a'] = 2;
CREATE TABLE join_test (id INTEGER, data STRUCT<x: INTEGER, y: STRING>);
INSERT INTO join_test VALUES (1, ROW(10, 'join_one')), (2, ROW(20, 'join_two'));
SELECT jt.data['x'] FROM join_test jt JOIN advanced_test at ON jt.id = at.info['a'];
CREATE TABLE complex_test AS SELECT ROW(ROW(1, 'data1'), ROW(2, 'data2')) AS complex_data;
SELECT complex_data['f0']['f0'] as id FROM complex_test;
SELECT complex_data['f1']['f1'] FROM complex_test WHERE complex_data['f0']['f0'] = 1;