CREATE TABLE test_dates (event_date DATE);
INSERT INTO test_dates VALUES (DATE '1992-04-20'), (DATE '1992-04-01'), (DATE '1992-03-15'), (DATE '2001-01-01');
SELECT time_bucket(INTERVAL '1 month', event_date) AS bucket_month FROM test_dates;
SELECT time_bucket(INTERVAL '2 weeks', event_date, DATE '1992-04-01') AS bucket_2_weeks FROM test_dates;
SELECT time_bucket(INTERVAL '1 year', event_date, DATE '2000-01-01') AS bucket_year FROM test_dates;
SELECT time_bucket(INTERVAL '3 days', event_date, DATE '1992-04-01') AS bucket_3_days FROM test_dates WHERE event_date > DATE '1992-03-10';
WITH date_buckets AS (SELECT event_date, time_bucket(INTERVAL '1 month', event_date) AS bucket FROM test_dates) SELECT bucket, COUNT(*) FROM date_buckets GROUP BY bucket;
CREATE TABLE origin_test (origin_date DATE);
INSERT INTO origin_test VALUES (DATE '2000-01-03'), (DATE '2000-01-01');
SELECT t.event_date, time_bucket(INTERVAL '1 week', t.event_date, o.origin_date) AS bucket_week FROM test_dates t JOIN origin_test o ON t.event_date > o.origin_date;
SELECT MIN(event_date) AS min_date, MAX(event_date) AS max_date, time_bucket(INTERVAL '5 days', event_date) AS bucket_5_days FROM test_dates GROUP BY bucket_5_days;
SELECT t.event_date, time_bucket(INTERVAL '1 week', t.event_date, DATE '2000-01-01') FROM test_dates t WHERE t.event_date IN (SELECT event_date FROM test_dates WHERE event_date BETWEEN DATE '1992-04-01' AND DATE '1992-05-01');