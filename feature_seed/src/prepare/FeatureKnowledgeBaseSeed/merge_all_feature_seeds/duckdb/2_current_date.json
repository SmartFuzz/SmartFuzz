CREATE TABLE test_dates (id INT PRIMARY KEY, event_date TIMESTAMP, description VARCHAR);
INSERT INTO test_dates (id, event_date, description) VALUES (1, CURRENT_TIMESTAMP - INTERVAL '3 DAY', 'Event 1'), (2, CURRENT_TIMESTAMP - INTERVAL '10 DAY', 'Event 2'), (3, CURRENT_TIMESTAMP - INTERVAL '20 DAY', 'Event 3');
SELECT id, event_date, description, current_date - event_date AS days_since_event FROM test_dates WHERE event_date IS NOT NULL;
SELECT id, event_date, description FROM test_dates WHERE event_date < current_date - INTERVAL '5 DAY' ORDER BY event_date DESC;
CREATE TABLE test_summary AS SELECT COUNT(*) AS event_count, current_date AS report_date FROM test_dates GROUP BY current_date;
SELECT t1.id, t1.description, (current_date - t1.event_date) AS age_of_event FROM test_dates t1 JOIN (SELECT id, current_date - MIN(event_date) AS days_passed FROM test_dates GROUP BY id) t2 ON t1.id = t2.id WHERE t2.days_passed IS NOT NULL;
SELECT id, event_date, description, CASE WHEN event_date > current_date - INTERVAL '1 DAY' THEN 'Recent' ELSE 'Old' END AS event_age FROM test_dates HAVING event_age = 'Recent' ORDER BY event_date;
SELECT DISTINCT id, event_date, description FROM test_dates WHERE (current_date - event_date) < INTERVAL '15 DAY' AND description IS NOT NULL;
INSERT INTO test_dates (id, event_date, description) VALUES (4, NULL, 'Event 4');
SELECT id, event_date, description, current_date - COALESCE(event_date, CURRENT_DATE) AS adjustment FROM test_dates;