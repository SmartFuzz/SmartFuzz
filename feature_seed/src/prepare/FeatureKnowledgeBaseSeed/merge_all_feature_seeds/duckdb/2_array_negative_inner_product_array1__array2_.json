CREATE TABLE test_arrays (id INT, values1 ARRAY<FLOAT>, values2 ARRAY<FLOAT>);
INSERT INTO test_arrays VALUES (1, array_value(1.0::FLOAT, 2.0::FLOAT, NULL), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
INSERT INTO test_arrays VALUES (2, array_value(3.0::FLOAT, 4.5::FLOAT, 5.0::FLOAT), array_value(4.0::FLOAT, 5.0::FLOAT, 6.0::FLOAT));
INSERT INTO test_arrays VALUES (3, array_value(NULL, NULL, NULL), array_value(NULL, NULL, NULL));
SELECT t.id, array_negative_inner_product(t.values1, t.values2) AS negative_inner_product FROM test_arrays t WHERE t.id IN (SELECT id FROM test_arrays WHERE array_length(values1) = 3);
SELECT id, array_negative_inner_product(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT)) + (DATE '1992-03-22' + INTERVAL (3 - id) DAY) AS calculation FROM test_arrays;
SELECT t.id, array_negative_inner_product(t.values1, t.values2) FROM test_arrays t JOIN (SELECT DISTINCT id FROM test_arrays WHERE id < 3) AS ids ON t.id = ids.id;
WITH temp AS (SELECT id, array_negative_inner_product(values1, values2) AS negative_product FROM test_arrays) SELECT id, negative_product FROM temp WHERE negative_product < 0;
SELECT id, array_negative_inner_product(array_value(1.0::FLOAT, 2.0::FLOAT), array_value(3.0::FLOAT, NULL)::FLOAT) FROM test_arrays HAVING COUNT(*) > 0;
DROP TABLE test_arrays;