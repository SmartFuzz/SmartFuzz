CREATE TABLE transactions (id INTEGER, amount FLOAT, date TIMESTAMP DEFAULT current_timestamp());
INSERT INTO transactions (id, amount) VALUES (1, 100.0), (2, 150.0), (3, 200.0);
SELECT COUNT(*) FROM transactions WHERE date >= today();
SELECT SUM(amount) FROM transactions WHERE date < today();
CREATE TABLE users (user_id INTEGER, signup_date DATE);
INSERT INTO users (user_id, signup_date) VALUES (1, today() - INTERVAL '1 day'), (2, today());
SELECT u.user_id, t.amount FROM users u JOIN transactions t ON date(u.signup_date) = date(t.date) WHERE t.amount > 100;
SELECT DISTINCT date(t.date) as transaction_date FROM transactions t WHERE date(t.date) = today();
SELECT AVG(amount) FROM transactions WHERE date(date) BETWEEN today() - INTERVAL '30 days' AND today();
SELECT u.user_id, COUNT(t.id) as transaction_count FROM users u LEFT JOIN transactions t ON date(u.signup_date) = date(t.date) GROUP BY u.user_id HAVING COUNT(t.id) > 0;