CREATE TABLE sales (id INT, amount FLOAT, sales_date DATE);
INSERT INTO sales VALUES (1, 100.00, '2023-01-01'), (2, 150.00, '2023-01-02'), (3, 200.00, '2023-01-03'), (4, NULL, '2023-01-04'), (5, 250.00, '2023-01-05');
SELECT id, amount, lead(amount, 3, 0) OVER (ORDER BY sales_date) AS future_amount FROM sales;
CREATE TABLE products (product_id INT, price FLOAT);
INSERT INTO products VALUES (1, 10.00), (2, 20.00), (3, 30.00);
SELECT s.id, s.amount, p.price, lead(s.amount, 2, 0) OVER (ORDER BY s.sales_date) AS future_amount FROM sales s JOIN products p ON s.id = p.product_id;
CREATE TABLE inventory (product_id INT, stock INT);
INSERT INTO inventory VALUES (1, 100), (2, 150), (3, 200);
SELECT s.sales_date, s.amount, lead(s.amount, 1, 0) OVER (PARTITION BY p.product_id ORDER BY s.sales_date) AS next_day_amount FROM sales s JOIN products p ON s.id = p.product_id WHERE s.amount IS NOT NULL;
WITH ranked_sales AS (SELECT id, amount, lead(amount, 3, 0) OVER (ORDER BY sales_date) AS future_amount FROM sales) SELECT * FROM ranked_sales WHERE future_amount > 0;
SELECT lead(amount, 2, NULL) OVER (ORDER BY sales_date) AS skip_two from sales;
CREATE TABLE temp_sales AS SELECT * FROM sales WHERE amount IS NOT NULL;
SELECT id, amount, lead(amount, 1, 0) OVER (ORDER BY sales_date) AS next_amount FROM temp_sales WHERE amount > 150;