CREATE TABLE test_strings (id INTEGER, value VARCHAR);
INSERT INTO test_strings VALUES (1, '    test'), (2, '   example'), (3, '     sample'), (4, 'no leading spaces');
SELECT id, ltrim(value) AS trimmed_value FROM test_strings;
SELECT id, ltrim(value) AS trimmed_value FROM (SELECT value FROM test_strings WHERE id = 1) AS subquery;
SELECT id, ltrim CONCAT(value, '    ') AS complex_trimmed_value FROM (SELECT value FROM test_strings) AS subquery ORDER BY id;
CREATE TABLE test_strings_2 (id INTEGER, value VARCHAR);
INSERT INTO test_strings_2 VALUES (1, '    joined   '), (2, '    tables  ');
SELECT a.id, ltrim(a.value) AS first_trimmed, ltrim(b.value) AS second_trimmed FROM test_strings a INNER JOIN test_strings_2 b ON a.id = b.id;
SELECT id, ltrim(value) AS trimmed_value FROM test_strings WHERE ltrim(value) = 'example';
SELECT COUNT(*) FROM (SELECT ltrim(value) AS trimmed_value FROM test_strings) AS t WHERE trimmed_value = 'sample';
SELECT ltrim('    varying spaces   ') || ' after' AS modified_string;