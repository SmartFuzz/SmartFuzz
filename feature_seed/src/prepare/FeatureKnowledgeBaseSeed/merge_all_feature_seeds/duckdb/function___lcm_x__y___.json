CREATE TABLE nums (a INTEGER, b INTEGER);
INSERT INTO nums VALUES (42, 57), (8, 12), (15, 20), (6, 14), (25, 5);
SELECT a, b, lcm(a, b) AS lcm_value FROM nums;
SELECT lcm(x, y) FROM (SELECT a AS x, b AS y FROM nums WHERE a > 10) AS subquery;
SELECT n1.a, n2.b, lcm(n1.a, n2.b) AS lcm_value FROM nums n1 JOIN nums n2 ON n1.a < n2.b;
CREATE TABLE results AS SELECT a, b, lcm(a, b) AS lcm_value FROM nums;
SELECT AVG(lcm_value) FROM (SELECT a, b, lcm(a, b) AS lcm_value FROM nums) AS subquery;
WITH lcm_values AS (SELECT a, b, lcm(a, b) AS lcm_value FROM nums) SELECT SUM(lcm_value) FROM lcm_values WHERE lcm_value > 100;
SELECT lcm(a, 1) AS lcm_with_one FROM nums;
SELECT lcm(NULL, 100) AS lcm_with_null FROM nums;
SELECT a, b, lcm(a, b + 1) AS lcm_incremented FROM nums;
CREATE TABLE more_nums (x INTEGER, y INTEGER);
INSERT INTO more_nums VALUES (3, 7), (4, 6), (18, 24);
SELECT m.x, m.y, lcm(n.a, m.x) FROM nums n JOIN more_nums m ON n.a < m.y;
SELECT lcm(lcm(42, 57), lcm(15, 25)) AS nested_lcm;