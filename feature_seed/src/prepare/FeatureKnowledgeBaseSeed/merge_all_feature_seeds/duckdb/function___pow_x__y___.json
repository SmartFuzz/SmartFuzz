CREATE TABLE powers_table (base FLOAT, exponent FLOAT, result FLOAT);
INSERT INTO powers_table VALUES (2, 3, pow(2, 3));
INSERT INTO powers_table VALUES (3, 2, pow(3, 2));
INSERT INTO powers_table VALUES (10, 0, pow(10, 0));
INSERT INTO powers_table VALUES (0, 5, pow(0, 5));
INSERT INTO powers_table VALUES (-2, 3, pow(-2, 3));
INSERT INTO powers_table VALUES (-2, 2, pow(-2, 2));
SELECT base, exponent, result FROM powers_table WHERE result > 5;
SELECT base, exponent FROM powers_table WHERE result = pow(base, exponent);
CREATE TABLE additional_values (x FLOAT, y FLOAT);
INSERT INTO additional_values VALUES (2, 3);
INSERT INTO additional_values VALUES (1, 1);
SELECT a.x, a.y, pow(a.x, a.y) AS power_result FROM additional_values a JOIN powers_table p ON a.x = p.base WHERE p.result IS NOT NULL;
SELECT pow(SELECT SUM(base) FROM powers_table, (SELECT AVG(exponent) FROM powers_table));
SELECT AVG(pow(base, exponent)) FROM powers_table WHERE exponent > 1;
CREATE VIEW power_summary AS SELECT base, exponent, pow(base, exponent) AS computed_power FROM powers_table;
SELECT * FROM power_summary WHERE computed_power < 100;