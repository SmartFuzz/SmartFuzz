CREATE TABLE test_data (id INTEGER PRIMARY KEY, value FLOAT, list_values LIST<FLOAT>);
INSERT INTO test_data VALUES (1, 4.5, [3, 6, NULL, 2]), (2, 3.14, [NULL, 2.71, 1.0, 0.5]), (3, 1.618, [NULL, 1.0, 2.0]);
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data WHERE value >= 1.5;
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data WHERE value ^ 2 >= 20;
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data WHERE value IN (SELECT value FROM test_data WHERE list_values IS NOT NULL);
CREATE TABLE test_metrics (test_id INTEGER, metric FLOAT);
INSERT INTO test_metrics VALUES (1, 2.5), (2, 0.0), (3, NULL);
SELECT tm.test_id, array_reverse_sort(list_values) AS reversed_list FROM test_data td JOIN test_metrics tm ON tm.metric = (td.value ^ 2) WHERE td.id = tm.test_id;
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data WHERE EXISTS (SELECT 1 FROM test_metrics WHERE metric > 2.0);
SELECT td.id, (array_reverse_sort(list_values) ^ 2)[1] AS second_highest FROM test_data td WHERE array_length(list_values) > 2;
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data WHERE id IN (SELECT test_id FROM test_metrics WHERE metric IS NULL);
CREATE TABLE additional_data (data_id INTEGER, data_list LIST<FLOAT>);
INSERT INTO additional_data VALUES (1, [1.0, 2.0]), (2, [NULL]), (3, []);
SELECT ad.data_id, (array_reverse_sort(ad.data_list) ^ 2) AS squared_reversed_values FROM additional_data ad WHERE ad.data_list IS NOT NULL;
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data td WHERE list_values @> [] OR value < 0;
SELECT id FROM (SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data) sub WHERE reversed_list IS NULL;
ALTER TABLE test_data ADD COLUMN extra_value VARCHAR;
UPDATE test_data SET extra_value = 'new' WHERE value = 3.14;
SELECT id, array_reverse_sort(list_values) AS reversed_list FROM test_data WHERE array_length(list_values) > 0 ORDER BY (value ^ 3) DESC;
DROP TABLE test_metrics;