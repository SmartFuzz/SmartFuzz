CREATE TABLE test_strings (str VARCHAR);
INSERT INTO test_strings VALUES ('abc');
INSERT INTO test_strings VALUES ('');
INSERT INTO test_strings VALUES (NULL);
INSERT INTO test_strings VALUES ('a');
INSERT INTO test_strings VALUES ('abcde');
INSERT INTO test_strings VALUES (REPEAT('a', 100));
INSERT INTO test_strings VALUES (REPEAT('a', 255));
INSERT INTO test_strings VALUES (REPEAT('a', 1024));
SELECT str, bit_length(str) AS length_bits FROM test_strings;
SELECT str, bit_length(str) AS length_bits FROM test_strings WHERE str IS NOT NULL;
SELECT bit_length(subquery1.str) FROM (SELECT str FROM test_strings WHERE LENGTH(str) > 0) AS subquery1;
SELECT t1.str, bit_length(t1.str) FROM test_strings AS t1 JOIN (SELECT str FROM test_strings WHERE LENGTH(str) < 10) AS t2 ON t1.str = t2.str;
SELECT t1.str, bit_length(t1.str) FROM test_strings AS t1 INNER JOIN (SELECT REPEAT('a', 10) AS str) AS t2 ON t1.str = t2.str;
SELECT COUNT(*) AS total_strings, SUM(bit_length(str)) AS total_bit_length FROM test_strings;
SELECT CASE WHEN str IS NULL THEN 'NULL' ELSE str END AS adjusted_str, bit_length(adjusted_str) AS length_bits FROM test_strings;