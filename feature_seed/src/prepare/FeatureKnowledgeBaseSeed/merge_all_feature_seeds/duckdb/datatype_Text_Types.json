CREATE TABLE test_table (id INT, name VARCHAR(255));
INSERT INTO test_table VALUES (1, 'John Doe');
INSERT INTO test_table VALUES (2, 'Jane Smith');
SELECT * FROM test_table WHERE name LIKE 'J%';
SELECT id, name FROM test_table WHERE LENGTH(name) = 10;
SELECT * FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name = 'John Doe');
CREATE TABLE another_table (id INT, description VARCHAR(100));
INSERT INTO another_table VALUES (1, 'A description of something very long that exceeds typical lengths');
SELECT a.id, a.name, b.description FROM test_table a JOIN another_table b ON a.id = b.id WHERE a.name LIKE '%Doe';
SELECT MAX(LENGTH(name)) FROM test_table;
SELECT COUNT(*) FROM test_table WHERE name NOT LIKE 'J%';
SELECT name FROM test_table WHERE id NOT IN (SELECT id FROM another_table);
CREATE TABLE complex_table (id INT, data VARCHAR(50), ref_id INT);
INSERT INTO complex_table VALUES (1, 'Sample Data', 1), (2, 'Another Sample', 1);
SELECT a.data FROM complex_table a INNER JOIN test_table b ON a.ref_id = b.id WHERE b.name = 'John Doe';
SELECT * FROM test_table WHERE name IS NOT NULL AND name <> '';
SELECT name FROM test_table WHERE (id, name) IN (SELECT id, name FROM test_table WHERE (id + 1) % 2 = 0);
UPDATE test_table SET name = 'Updated Name' WHERE id = 1;
DELETE FROM another_table WHERE id = 1;