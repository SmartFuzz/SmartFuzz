CREATE TABLE dates_table (id INT, event_date DATE);
INSERT INTO dates_table VALUES (1, DATE '1992-02-15');
INSERT INTO dates_table VALUES (2, DATE '1993-07-01');
INSERT INTO dates_table VALUES (3, DATE '2000-12-31');
INSERT INTO dates_table VALUES (4, DATE '2020-01-01');
INSERT INTO dates_table VALUES (5, DATE '2023-10-10');
SELECT id, month(event_date) AS event_month FROM dates_table;
SELECT id, month(event_date) AS event_month FROM dates_table WHERE event_month BETWEEN 1 AND 6;
SELECT id, month(event_date) AS event_month, COUNT(*) FROM dates_table GROUP BY event_month;
SELECT dt.id, month(dt.event_date) AS event_month, (SELECT COUNT(*) FROM dates_table WHERE month(event_date) = month(dt.event_date)) AS month_count FROM dates_table dt;
WITH month_counts AS (SELECT month(event_date) AS event_month, COUNT(*) AS month_count FROM dates_table GROUP BY month(event_date)) SELECT mc.event_month, mc.month_count FROM month_counts mc WHERE mc.month_count > 1;
CREATE TABLE second_dates_table (identifier INT, ref_date DATE);
INSERT INTO second_dates_table VALUES (1, DATE '1992-02-15'), (2, DATE '1993-05-30');
SELECT d.id, d.event_date, m.event_month FROM dates_table d JOIN (SELECT id, month(ref_date) AS event_month FROM second_dates_table WHERE identifier = 1) m ON m.id = d.id;
SELECT d.id, month(d.event_date) AS event_month FROM dates_table d WHERE d.event_date IN (SELECT ref_date FROM second_dates_table WHERE identifier > 1);
SELECT id, month(event_date) AS event_month FROM (SELECT id, event_date FROM dates_table WHERE id < 3) sub;