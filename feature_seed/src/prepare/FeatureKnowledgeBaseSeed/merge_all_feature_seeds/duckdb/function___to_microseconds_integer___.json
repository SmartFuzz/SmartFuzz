CREATE TABLE test_intervals (id INTEGER, microseconds_interval INTERVAL);
INSERT INTO test_intervals VALUES (1, to_microseconds(5));
INSERT INTO test_intervals VALUES (2, to_microseconds(0));
INSERT INTO test_intervals VALUES (3, to_microseconds(-1));
INSERT INTO test_intervals VALUES (4, to_microseconds(1000000));
INSERT INTO test_intervals VALUES (5, to_microseconds(-1000000));
SELECT id, microseconds_interval, microseconds_interval + to_microseconds(100) AS incremented_interval FROM test_intervals;
SELECT id, microseconds_interval FROM test_intervals WHERE microseconds_interval = to_microseconds(0);
SELECT id, microseconds_interval FROM test_intervals WHERE microseconds_interval < to_microseconds(100);
WITH interval_data AS (SELECT id, microseconds_interval FROM test_intervals WHERE id > 1) SELECT id, microseconds_interval * 2 AS doubled_interval FROM interval_data;
CREATE TABLE additional_data (id INTEGER, interval_value INTERVAL);
INSERT INTO additional_data VALUES (1, to_microseconds(30)), (2, to_microseconds(15));
SELECT a.id, a.interval_value, b.microseconds_interval FROM additional_data a JOIN test_intervals b ON a.id = b.id WHERE a.interval_value >= to_microseconds(15);
SELECT COUNT(*) FROM test_intervals WHERE microseconds_interval <> to_microseconds(-1);
SELECT AVG(EXTRACT(EPOCH FROM microseconds_interval)) FROM test_intervals;