CREATE TABLE test_table (id INT PRIMARY KEY, text_col TEXT, num_col BIGINT);
INSERT INTO test_table (id, text_col, num_col) VALUES (1, '🦆', 15), (2, NULL, 20), (3, '', 0);
SELECT id, hash(text_col) AS hashed_text, ~num_col AS negated_num FROM test_table WHERE num_col > ~0 ORDER BY hashed_text;
SELECT id, (SELECT COUNT(*) FROM test_table AS t2 WHERE t2.num_col BETWEEN 5 AND 20) AS count_in_range FROM test_table;
SELECT t1.id, t1.text_col, AVG(t2.num_col) AS avg_num FROM test_table AS t1 JOIN test_table AS t2 ON t1.id != t2.id GROUP BY t1.id, t1.text_col HAVING hash(t1.text_col) IS NOT NULL;
CREATE TABLE other_table (ref_id INT, value TEXT);
INSERT INTO other_table (ref_id, value) VALUES (1, 'Sample 1'), (2, 'Sample 2'), (3, NULL);
SELECT t1.id, t1.text_col, hash(t1.text_col) AS hashed_value, (SELECT ~AVG(t2.num_col) FROM other_table AS t2 WHERE t2.ref_id = t1.id) AS negated_avg FROM test_table AS t1 WHERE t1.text_col IS NOT NULL;
SELECT id, text_col, hash(text_col) + ~num_col AS combined_value FROM test_table HAVING combined_value > 0;
UPDATE test_table SET num_col = NULL WHERE id = 3;
SELECT id, ~num_col AS negated FROM test_table WHERE text_col IS NOT NULL AND hash(text_col) IS NOT NULL;
SELECT id, hash(text_col), (SELECT MAX(~num_col) FROM test_table) FROM test_table GROUP BY id HAVING hash(text_col) IS NOT NULL AND COUNT(*) > 1;