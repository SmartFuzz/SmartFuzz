CREATE TABLE strings_table (text STRING, repeat_count INT);
INSERT INTO strings_table VALUES ('A', 5);
INSERT INTO strings_table VALUES ('B', 0);
INSERT INTO strings_table VALUES ('C', -3);
INSERT INTO strings_table VALUES ('D', 1);
INSERT INTO strings_table VALUES ('', 10);
SELECT text, repeat(text, repeat_count) AS repeated_string FROM strings_table;
SELECT text, repeat(text, repeat_count) AS repeated_string FROM strings_table WHERE repeat_count > 0;
SELECT repeat('X', repeat_count) AS repeated_string FROM (SELECT repeat_count FROM strings_table WHERE text = 'A') AS subquery;
SELECT t1.text, repeat(t2.text, t2.repeat_count) AS repeated_string FROM strings_table t1 JOIN strings_table t2 ON t1.repeat_count = t2.repeat_count WHERE t1.text != t2.text;
SELECT repeat(repeat('A', 2), 3) AS nested_repeat;
SELECT repeat('Hello', (SELECT MAX(repeat_count) FROM strings_table)) AS repeated_hello;
WITH repeated AS (SELECT text, repeat(text, repeat_count) AS repeated_string FROM strings_table) SELECT * FROM repeated WHERE LENGTH(repeated_string) > 5;