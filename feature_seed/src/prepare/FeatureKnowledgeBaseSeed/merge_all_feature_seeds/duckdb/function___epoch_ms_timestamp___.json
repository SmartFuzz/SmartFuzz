CREATE TABLE timestamps (event_time TIMESTAMP);
INSERT INTO timestamps VALUES (TIMESTAMP '2020-01-01 00:00:00'), (TIMESTAMP '2023-10-01 12:34:56.789123'), (TIMESTAMP '1970-01-01 00:00:00');
SELECT epoch_ms(event_time) FROM timestamps;
SELECT epoch_ms(TIMESTAMP '2023-10-01 12:34:56.789123') AS epoch_milliseconds;
SELECT epoch_ms(TIMESTAMP '1970-01-01 00:00:01') AS epoch_ms_one_second;
SELECT epoch_ms(TIMESTAMP '2030-01-01 00:00:00') AS epoch_ms_future;
SELECT event_time, epoch_ms(event_time) FROM timestamps WHERE event_time >= TIMESTAMP '2022-01-01';
WITH subquery AS (SELECT event_time FROM timestamps WHERE event_time < TIMESTAMP '2022-01-01') SELECT epoch_ms(event_time) FROM subquery;
SELECT COUNT(*), AVG(epoch_ms(event_time)) FROM timestamps GROUP BY event_time;
SELECT epoch_ms(t1.event_time) FROM timestamps t1 JOIN (SELECT event_time FROM timestamps WHERE event_time < TIMESTAMP '2022-01-01') t2 ON t1.event_time = t2.event_time;
SELECT t1.event_time, epoch_ms(t1.event_time) AS epoch FROM timestamps t1 WHERE epoch_ms(t1.event_time) > 0 ORDER BY epoch DESC;
INSERT INTO timestamps VALUES (TIMESTAMP '9999-12-31 23:59:59.999999');
SELECT epoch_ms(TIMESTAMP '9999-12-31 23:59:59.999999') AS epoch_ms_end_of_time;