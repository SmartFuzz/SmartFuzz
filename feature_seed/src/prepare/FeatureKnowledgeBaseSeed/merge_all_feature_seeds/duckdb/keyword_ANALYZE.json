CREATE TABLE test_table (id INTEGER, value DOUBLE);
INSERT INTO test_table VALUES (1, 10.5), (2, 20.0), (3, 30.5);
CREATE TABLE test_table2 (id INTEGER, description TEXT);
INSERT INTO test_table2 VALUES (1, 'First'), (2, 'Second'), (3, 'Third');
CREATE TABLE test_table3 (id INTEGER, foreign_id INTEGER);
INSERT INTO test_table3 VALUES (1, 1), (2, 2), (3, 2);
ANALYZE test_table;
ANALYZE test_table2;
ANALYZE test_table3;
ANALYZE (SELECT id FROM test_table WHERE value > 15);
ANALYZE (SELECT * FROM (SELECT id, value FROM test_table) AS sub_query);
ANALYZE (SELECT a.id, b.description FROM test_table AS a JOIN test_table2 AS b ON a.id = b.id);
ANALYZE test_table, test_table2;
ANALYZE (SELECT id FROM test_table WHERE id IN (SELECT foreign_id FROM test_table3 WHERE foreign_id IS NOT NULL));
ANALYZE (SELECT a.id, COUNT(b.id) FROM test_table AS a LEFT JOIN test_table3 AS b ON a.id = b.foreign_id GROUP BY a.id);
ANALYZE (SELECT id, AVG(value) FROM (SELECT * FROM test_table WHERE value < 25) AS filtered_table GROUP BY id);