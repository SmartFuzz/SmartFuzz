CREATE TABLE test_timestamps (ts TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES (TIMESTAMPTZ '2023-10-05 12:00:00+00:00');
INSERT INTO test_timestamps VALUES (TIMESTAMPTZ '9999-12-31 23:59:59+00:00');
INSERT INTO test_timestamps VALUES (TIMESTAMPTZ '1970-01-01 00:00:00+00:00');
INSERT INTO test_timestamps VALUES (TIMESTAMPTZ '1969-12-31 23:59:59+00:00');
INSERT INTO test_timestamps VALUES (TIMESTAMPTZ '2000-01-01 00:00:00+00:00');
INSERT INTO test_timestamps VALUES (TIMESTAMPTZ '1582-10-15 00:00:00+00:00');
SELECT isfinite(ts) FROM test_timestamps;
SELECT (CASE WHEN isfinite(ts) THEN 'Finite' ELSE 'Infinite' END) AS timestamp_status FROM test_timestamps;
SELECT t1.ts, t2.other_col FROM test_timestamps t1 JOIN (SELECT '2023-10-06 12:00:00+00:00'::TIMESTAMPTZ AS other_col) t2 ON isfinite(t1.ts);
SELECT ts FROM test_timestamps WHERE isfinite(ts) AND ts < TIMESTAMPTZ '9999-12-31 00:00:00+00:00';
WITH finite_timestamps AS (SELECT ts FROM test_timestamps WHERE isfinite(ts)) SELECT COUNT(*) FROM finite_timestamps;
SELECT ts, isfinite(ts) AS finite FROM (SELECT ts FROM test_timestamps WHERE ts IS NOT NULL) AS subquery;
CREATE TABLE another_table (id INT, timestamp_col TIMESTAMPTZ);
INSERT INTO another_table SELECT ROW_NUMBER() OVER (), ts FROM test_timestamps;
SELECT a.id, isfinite(a.timestamp_col) FROM another_table a JOIN test_timestamps t ON a.timestamp_col = t.ts;