CREATE TABLE test_strings (id INTEGER PRIMARY KEY, text_string VARCHAR);
INSERT INTO test_strings VALUES (1, 'my_string_with_ü');
INSERT INTO test_strings VALUES (2, 'boundary_case_with_😊');
INSERT INTO test_strings VALUES (3, 'string_with_special_characters_!@#$%^&*()');
INSERT INTO test_strings VALUES (4, 'long_string_with_repeated_sequences_aaaaaaaaaaaaaaaaaaaaa');
SELECT encode(text_string) FROM test_strings WHERE id = 1;
SELECT encode(text_string) FROM test_strings WHERE text_string LIKE '%case%';
SELECT encode((SELECT text_string FROM test_strings WHERE id = 2)) AS encoded_utf8_case;
SELECT t1.id, encode(t2.text_string) FROM test_strings t1 JOIN test_strings t2 ON t1.id < t2.id;
SELECT encode(CONCAT(text_string, ' - ', text_string)) FROM test_strings WHERE id = 3;
SELECT encode((SELECT text_string FROM test_strings WHERE id IN (1, 2) LIMIT 1)) AS encoded_combined;
CREATE TABLE more_strings (id INTEGER PRIMARY KEY, str_val VARCHAR);
INSERT INTO more_strings VALUES (1, 'another_string_with_ü'), (2, 'second_string_with_✨');
SELECT encode(c.str_val) FROM more_strings c JOIN test_strings t ON LENGTH(c.str_val) > 20;
SELECT encode(NULLIF(text_string, '')) FROM test_strings;
SELECT encode(COALESCE(text_string, 'default_string')) FROM test_strings WHERE id = 4;