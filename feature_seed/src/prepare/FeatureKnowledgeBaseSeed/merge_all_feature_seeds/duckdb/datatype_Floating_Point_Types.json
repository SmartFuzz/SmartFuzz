CREATE TABLE float_test (id INTEGER PRIMARY KEY, value DOUBLE);
INSERT INTO float_test (id, value) VALUES (1, 1.0);
INSERT INTO float_test (id, value) VALUES (2, -1.0);
INSERT INTO float_test (id, value) VALUES (3, 0.0);
INSERT INTO float_test (id, value) VALUES (4, 1.7976931348623157E308);
INSERT INTO float_test (id, value) VALUES (5, -1.7976931348623157E308);
INSERT INTO float_test (id, value) VALUES (6, 2.2250738585072014E-308);
INSERT INTO float_test (id, value) VALUES (7, -2.2250738585072014E-308);
SELECT id, value FROM float_test WHERE value BETWEEN 1.0 AND 2.0;
SELECT * FROM float_test WHERE value IS NOT NULL;
SELECT id, value * 2 AS double_value FROM float_test;
SELECT AVG(value) AS avg_float FROM float_test;
SELECT id FROM float_test WHERE value IN (SELECT value FROM float_test WHERE id < 3);
CREATE TABLE another_table (id INTEGER PRIMARY KEY, description VARCHAR);
INSERT INTO another_table (id, description) VALUES (1, 'Test Value 1');
INSERT INTO another_table (id, description) VALUES (2, 'Test Value 2');
SELECT a.id, a.value, b.description FROM float_test a JOIN another_table b ON a.id = b.id;
SELECT id, value FROM float_test WHERE value > (SELECT AVG(value) FROM float_test);
CREATE VIEW float_view AS SELECT id, value FROM float_test WHERE value >= 0.0;
SELECT * FROM float_view ORDER BY value DESC;