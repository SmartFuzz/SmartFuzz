CREATE TABLE my_table (id INT, my_list ARRAY);
INSERT INTO my_table VALUES (1, [4, 5, 6]), (2, [7, 8, 9]);
SELECT array_extract(my_list, 1) FROM my_table WHERE id = 1;
SELECT array_extract(my_list, 2) FROM my_table WHERE id = 1;
SELECT array_extract(my_list, 3) FROM my_table WHERE id = 2;
SELECT array_extract(my_list, 1) AS first_element, id FROM my_table;
SELECT array_extract(my_list, array_length(my_list)) AS last_element FROM my_table;
SELECT array_extract(my_list, 3) FROM my_table WHERE my_list IS NOT NULL;
CREATE TABLE another_table (ref_id INT, ref_list ARRAY);
INSERT INTO another_table VALUES (1, [10, 20]), (2, [30, 40, 50]);
SELECT a.id, array_extract(a.my_list, 2) AS second_element, b.ref_id FROM my_table AS a JOIN another_table AS b ON a.id = b.ref_id;
SELECT b.ref_id, array_extract(a.my_list, 1) AS first_elem FROM my_table AS a JOIN another_table AS b ON array_length(a.my_list) > 2 WHERE b.ref_list IS NOT NULL;
SELECT array_extract(my_list, 3) FROM my_table WHERE id IN (SELECT ref_id FROM another_table WHERE array_length(ref_list) > 2);
SELECT array_extract(array_extract(my_list, 3), 1) FROM my_table WHERE id = 1 AND my_list[1] IS NOT NULL;
SELECT array_extract(my_list, 1) AS first_element, array_extract(my_list, 2) AS second_element FROM my_table WHERE id < 3;
SELECT id, array_extract(my_list, 1) AS first_elem FROM my_table UNION SELECT id, array_extract(ref_list, 2) FROM another_table;