CREATE TABLE test_strings (str VARCHAR);
INSERT INTO test_strings VALUES ('hello'), ('duckdb'), ('test'), ('quick'), ('brownfox');
SELECT rpad(str, 10, '-') FROM test_strings;
SELECT rpad(str, 10, '0') AS padded FROM test_strings WHERE rpad(str, 10, '0') LIKE '0%';
SELECT rpad(str, 5, '#') AS padded FROM test_strings WHERE LENGTH(rpad(str, 5, '#')) = 5;
SELECT rpad('abc', 5, 'x') AS padded_string FROM (SELECT str FROM test_strings WHERE str = 'test');
SELECT a.str, rpad(a.str, 10, '-') AS right_padded, b.additional_text FROM test_strings AS a JOIN (SELECT 'additional' AS additional_text) AS b ON LENGTH(a.str) < 10;
WITH padded_strings AS (SELECT str, rpad(str, 10, ' ') AS padded FROM test_strings) SELECT * FROM padded_strings WHERE LENGTH(padded) = 10;
SELECT rpad(str, -5, ' ') AS error_case FROM test_strings;
SELECT rpad(str, 20, '*') AS long_padding FROM (SELECT str FROM test_strings) AS inner_query;