CREATE TABLE t1 (id INTEGER, value STRING);
CREATE TABLE t2 (id INTEGER, value STRING);
INSERT INTO t1 VALUES (1, 'A'), (2, 'B');
INSERT INTO t2 VALUES (1, 'C'), (2, 'D');
SELECT * FROM query_table(['t1', 't2']);
SELECT * FROM query_table(['t1', 't2'], true);
CREATE TABLE t3 (id INTEGER, value STRING);
INSERT INTO t3 VALUES (3, 'E'), (4, 'F');
SELECT * FROM query_table(['t1', 't2', 't3']);
SELECT * FROM query_table(['t1', 't3'], true);
WITH combined AS (SELECT * FROM query_table(['t1', 't2'])) SELECT COUNT(*) FROM combined;
WITH combined AS (SELECT * FROM query_table(['t1', 't2'], true)) SELECT value FROM combined WHERE id = 1;
SELECT a.value, b.value FROM query_table(['t1', 't2']) AS a JOIN query_table(['t2', 't3']) AS b ON a.id = b.id;
CREATE TABLE t4 (id INTEGER PRIMARY KEY, category STRING);
INSERT INTO t4 VALUES (5, 'G'), (6, 'H');
SELECT * FROM query_table(['t2', 't4']);
SELECT * FROM query_table(['t1', 't4'], true);
SELECT id, STRING_AGG(value) FROM query_table(['t1', 't2', 't4']) GROUP BY id;
SELECT DISTINCT value FROM query_table(['t1']) UNION SELECT DISTINCT value FROM query_table(['t2']);