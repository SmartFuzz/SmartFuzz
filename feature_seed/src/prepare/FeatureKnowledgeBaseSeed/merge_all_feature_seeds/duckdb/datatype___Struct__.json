CREATE TABLE test_struct (s STRUCT(key1 VARCHAR, key2 INTEGER));
INSERT INTO test_struct VALUES (struct_pack(key1 := 'value1', key2 := 1));
INSERT INTO test_struct VALUES (struct_pack(key1 := 'value2', key2 := 2));
SELECT * FROM test_struct;
SELECT s.key1 FROM test_struct;
SELECT struct_extract(s, 'key1') FROM test_struct;
CREATE TABLE nested_struct (s STRUCT(data STRUCT(key1 VARCHAR, key2 INTEGER)));
INSERT INTO nested_struct VALUES (struct_pack(data := struct_pack(key1 := 'nested_value', key2 := 100)));
SELECT s.data.key1 FROM nested_struct;
CREATE TABLE complex_struct (s STRUCT(a STRUCT(b VARCHAR, c INTEGER), d ARRAY<INTEGER>));
INSERT INTO complex_struct VALUES (struct_pack(a := struct_pack(b := 'deep_value', c := 10), d := [1, 2, 3]));
SELECT s.a.c FROM complex_struct;
CREATE TABLE multi_struct (s STRUCT(a STRUCT(b VARCHAR), c STRUCT(d VARCHAR, e INTEGER)));
INSERT INTO multi_struct VALUES (struct_pack(a := struct_pack(b := 'valueX'), c := struct_pack(d := 'valueY', e := 99)));
SELECT s.a.b, s.c.e FROM multi_struct;
CREATE TABLE struct_join (id INTEGER, s STRUCT(x INTEGER, y INTEGER));
INSERT INTO struct_join VALUES (1, struct_pack(x := 10, y := 20));
INSERT INTO struct_join VALUES (2, struct_pack(x := 30, y := 40));
SELECT id, s.x + s.y AS sum FROM struct_join WHERE s.x > 10;
SELECT s.d FROM (SELECT struct_pack(d := 5) AS s) AS derived_table;
CREATE TABLE struct_comparison (s STRUCT(k1 INTEGER, k2 INTEGER));
INSERT INTO struct_comparison VALUES (struct_pack(k1 := 1, k2 := 2));
INSERT INTO struct_comparison VALUES (struct_pack(k1 := 3, k2 := 4));
SELECT (s1.s < s2.s) AS comparison_result FROM struct_comparison AS s1, struct_comparison AS s2 WHERE s1.s.k1 != s2.s.k2;
SELECT a.x, b.y FROM (SELECT struct_pack(x := 1) AS s) AS a JOIN (SELECT struct_pack(y := 2) AS s) AS b ON a.s.x < b.s.y;
CREATE TABLE invalid_struct (s STRUCT(x INTEGER));
INSERT INTO invalid_struct VALUES (struct_pack(x := 10));
SELECT struct_pack(y := s.x) FROM invalid_struct;
SELECT {'key1': 100, 'key2': NULL} AS s;
SELECT struct_insert(s, z := 200) FROM (SELECT struct_pack(x := 1, y := 2) AS s);
CREATE TABLE table_with_structs (info STRUCT(name VARCHAR, details STRUCT(age INT, height FLOAT)));
INSERT INTO table_with_structs VALUES (struct_pack(name := 'Alice', details := struct_pack(age := 30, height := 5.5)));
SELECT info.details.age FROM table_with_structs;
CREATE TABLE multiple_structs (s STRUCT(first STRUCT(name VARCHAR), second STRUCT(value INTEGER)));
INSERT INTO multiple_structs VALUES (struct_pack(first := struct_pack(name := 'Foo'), second := struct_pack(value := 10)));
SELECT s.first.name, s.second.value FROM multiple_structs;
SELECT struct_extract({'keyA': 5, 'keyB': NULL}, 'keyB') AS result;