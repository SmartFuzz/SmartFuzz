CREATE TABLE test_struct (id INTEGER, data STRUCT<i: INTEGER, s: VARCHAR>);
INSERT INTO test_struct VALUES (1, {'i': 15, 's': 'text'}), (2, {'i': NULL, 's': 'another text'}), (3, {'i': 8, 's': 'sample'});
SELECT data.i << 1 AS bit_shifted_i, data.s, (SELECT COUNT(*) FROM test_struct) FROM test_struct;
SELECT (data.i << 2) AS shifted_value FROM test_struct WHERE data.i IS NOT NULL;
SELECT id, struct.entry(data).i << struct.entry(data).i AS complex_shift FROM test_struct ORDER BY complex_shift DESC;
SELECT COUNT(*) FROM (SELECT data.i, data.s FROM test_struct WHERE data.i << 1 > 0) AS subquery;
SELECT data.s, (struct.entry(data).i << 3) AS shifted_i FROM test_struct WHERE shifted_i = 120 OR shifted_i IS NULL;
SELECT B.id, B.data << 1 FROM (SELECT id, struct.entry(data) AS data FROM test_struct) AS B JOIN test_struct AS A ON A.id = B.id WHERE A.data.i IS NOT NULL;
SELECT AVG(CASE WHEN data.i IS NULL THEN 0 ELSE data.i << 1 END) AS avg_shifted_i FROM test_struct HAVING avg_shifted_i > 10;
CREATE TABLE test_table AS SELECT id, struct.entry(data).i AS number FROM test_struct WHERE struct.entry(data).i IS NOT NULL;