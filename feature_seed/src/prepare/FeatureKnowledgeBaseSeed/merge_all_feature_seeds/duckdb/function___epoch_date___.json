CREATE TABLE dates (event_date DATE);
INSERT INTO dates VALUES (DATE '1970-01-01'), (DATE '1992-02-15'), (DATE '2000-01-01'), (DATE '2030-12-31'), (DATE '1960-06-30');
SELECT event_date, epoch(event_date) AS epoch_seconds FROM dates;
SELECT event_date, epoch(event_date) AS epoch_seconds FROM dates WHERE event_date > DATE '1980-01-01';
SELECT event_date, epoch(event_date) AS epoch_seconds FROM dates WHERE epoch(event_date) BETWEEN 0 AND 1672531199;
SELECT event_date, epoch(event_date) AS epoch_seconds FROM dates ORDER BY epoch_seconds DESC;
SELECT d1.event_date, epoch(d1.event_date) AS epoch_seconds FROM dates d1 JOIN dates d2 ON epoch(d1.event_date) > epoch(d2.event_date);
SELECT (SELECT epoch(event_date) FROM dates WHERE event_date = DATE '1992-02-15') AS specific_epoch;
CREATE TABLE events (id INT, event_date DATE);
INSERT INTO events VALUES (1, DATE '1970-01-01'), (2, DATE '1992-02-15'), (3, DATE '2000-01-01');
SELECT e.id, e.event_date, epoch(e.event_date) AS epoch_seconds FROM events e JOIN dates d ON e.event_date = d.event_date;
SELECT e.id, (SELECT epoch(d.event_date) FROM dates d WHERE d.event_date = e.event_date) AS event_epoch FROM events e;
SELECT COUNT(*) AS total_events, MIN(epoch(event_date)) AS min_epoch, MAX(epoch(event_date)) AS max_epoch FROM dates;
SELECT event_date, CASE WHEN epoch(event_date) < 0 THEN 'Before Epoch' ELSE 'After Epoch' END AS epoch_status FROM dates;