CREATE TABLE test_data (id INTEGER, value INTEGER);
INSERT INTO test_data VALUES (1, 5), (2, 3), (3, 7), (4, 1);
SELECT MIN(value) FROM test_data;
SELECT MIN(value) FROM test_data WHERE id > 1;
CREATE TABLE additional_data (id INTEGER, value INTEGER);
INSERT INTO additional_data VALUES (1, 10), (2, 0), (3, 12);
SELECT MIN(value) FROM (SELECT value FROM test_data UNION SELECT value FROM additional_data);
SELECT MIN(subquery.min_value) FROM (SELECT MIN(value) AS min_value FROM test_data) AS subquery;
SELECT MIN(a.value) FROM test_data a JOIN additional_data b ON a.id = b.id WHERE b.value > 5;
SELECT MIN(value) FROM test_data GROUP BY id;
SELECT MIN(value) FROM (SELECT MIN(value) AS min_value FROM test_data) AS derived_table WHERE min_value > 0;
SELECT MIN(value) FROM (SELECT value FROM additional_data WHERE value < 5) AS filtered_data WHERE filtered_data.value IS NOT NULL;
CREATE TABLE nested_test (group_id INTEGER, val INTEGER);
INSERT INTO nested_test VALUES (1, 2), (1, 3), (2, 1), (2, 4);
SELECT group_id, MIN(val) FROM nested_test GROUP BY group_id;
SELECT MIN(val) FROM (SELECT val FROM nested_test WHERE group_id = 1) AS group_one;
SELECT MIN(nested.min_value) FROM (SELECT group_id, MIN(val) AS min_value FROM nested_test GROUP BY group_id) AS nested;