CREATE TABLE transactions (id INTEGER, transaction_time TIMESTAMP);
INSERT INTO transactions (id, transaction_time) VALUES (1, get_current_timestamp());
INSERT INTO transactions (id, transaction_time) VALUES (2, get_current_timestamp() + INTERVAL '1 hour');
CREATE TABLE audit_logs (log_id INTEGER, transaction_id INTEGER, log_time TIMESTAMP);
INSERT INTO audit_logs (log_id, transaction_id, log_time) SELECT 1, id, get_current_timestamp() FROM transactions WHERE id = 1;
SELECT id, transaction_time FROM transactions WHERE transaction_time <= get_current_timestamp();
CREATE TABLE users (user_id INTEGER, last_login TIMESTAMP);
INSERT INTO users (user_id, last_login) VALUES (1, get_current_timestamp()), (2, get_current_timestamp() - INTERVAL '2 days');
SELECT u.user_id, t.transaction_time FROM users u JOIN transactions t ON u.user_id = t.id WHERE t.transaction_time > get_current_timestamp() - INTERVAL '1 hour';
SELECT get_current_timestamp() AS current_time, (SELECT COUNT(*) FROM transactions) AS total_transactions;
WITH recent_transactions AS (SELECT id, transaction_time FROM transactions WHERE transaction_time > get_current_timestamp() - INTERVAL '1 day') SELECT COUNT(*) FROM recent_transactions;