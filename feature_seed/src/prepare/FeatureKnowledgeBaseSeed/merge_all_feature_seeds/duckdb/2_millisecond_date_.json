CREATE TABLE events (id INTEGER PRIMARY KEY, event_time TIMESTAMP, interval_days INTEGER);
INSERT INTO events VALUES (1, TIMESTAMP '2022-01-01 10:00:00', 5), (2, TIMESTAMP '2022-01-02 12:30:00', 10);
SELECT id, event_time + INTERVAL (millisecond(event_time) / 1000) SECOND AS updated_time FROM events;
SELECT e.id, e.event_time, millisecond(e.event_time) AS milliseconds FROM events e WHERE millisecond(e.event_time) IS NOT NULL;
SELECT e.id, COUNT(*) AS count, AVG(millisecond(e.event_time)) AS avg_milliseconds FROM events e GROUP BY e.id HAVING AVG(millisecond(e.event_time)) > 0;
SELECT e1.id, e1.event_time, (SELECT e2.event_time + INTERVAL (millisecond(e2.event_time) / 1000) SECOND FROM events e2 WHERE e1.interval_days = e2.id) AS adjusted_time FROM events e1;
SELECT e.id, millisecond(e.event_time) + (SELECT COUNT(*) FROM events e2 WHERE e2.id < e.id) AS computed_value FROM events e ORDER BY computed_value DESC;
CREATE TABLE timestamps (record_id INTEGER PRIMARY KEY, record_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '2021-12-31 23:59:59.999999'), (2, TIMESTAMP '2021-01-01 00:00:00.000000');
SELECT t.record_id, millisecond(t.record_time + INTERVAL (SELECT MAX(interval_days) FROM events)) AS final_millisecond FROM timestamps t;
SELECT e.id, SUM(millisecond(e.event_time)) OVER (PARTITION BY e.id ORDER BY e.event_time ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW) AS running_sum FROM events e;