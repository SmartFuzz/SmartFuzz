CREATE TABLE test_strings (input_string TEXT);
INSERT INTO test_strings VALUES ('http://d.org');
INSERT INTO test_strings VALUES ('$^.*');
INSERT INTO test_strings VALUES ('(abc|def)');
INSERT INTO test_strings VALUES ('hello[world]');
INSERT INTO test_strings VALUES ('something\backslash');
SELECT regexp_escape(input_string) FROM test_strings;
SELECT t1.input_string, regexp_escape(t1.input_string) AS escaped_string FROM test_strings t1 WHERE LENGTH(t1.input_string) > 5;
CREATE TABLE regex_results AS SELECT regexp_escape(input_string) AS regex_string FROM test_strings;
SELECT r.regex_string, COUNT(*) FROM regex_results r JOIN test_strings t ON r.regex_string LIKE '%' || t.input_string || '%' GROUP BY r.regex_string;
INSERT INTO test_strings VALUES ('wildcard*example');
SELECT regexp_escape(input_string) AS escaped_string, LENGTH(regexp_escape(input_string)) AS escaped_length FROM test_strings;
CREATE TABLE complex_test AS SELECT t1.input_string, regexp_escape(t1.input_string) AS escaped_string, t2.other_col FROM test_strings t1 JOIN (SELECT 'sample_text' AS other_col) t2 ON t1.input_string LIKE '%' || t2.other_col || '%';
SELECT regexp_escape('normal string'), regexp_escape('!@#$%^&*()_+|') AS special_characters;
SELECT DISTINCT regexp_escape(input_string) FROM test_strings WHERE input_string LIKE '%\%';
SELECT t1.input_string, t2.regex_string FROM test_strings t1 LEFT JOIN (SELECT input_string, regexp_escape(input_string) AS regex_string FROM test_strings) t2 ON t1.input_string = t2.input_string WHERE t1.input_string IS NOT NULL;