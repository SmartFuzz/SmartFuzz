CREATE TABLE test_data (id INT, text_col VARCHAR, num_col DECIMAL(10, 2));
INSERT INTO test_data VALUES (1, 'abc123', 10.50), (2, 'def456', 20.75), (3, NULL, NULL), (4, '', 30.10);
SELECT id, regexp_extract(text_col, '([a-z]+)(\d+)', 1) + num_col AS result FROM test_data WHERE num_col IS NOT NULL;
SELECT id, regexp_extract(text_col, '([a-z]+)(\d+)', 1) AS extracted_value, num_col + (SELECT COUNT(*) FROM test_data WHERE text_col IS NOT NULL) AS derived_value FROM test_data;
SELECT id, COUNT(*) AS cnt, SUM(num_col) + (SELECT MAX(COALESCE(num_col, 0)) FROM test_data) FROM test_data GROUP BY text_col HAVING extracted_value IS NOT NULL;
CREATE TABLE another_table (a INT, b VARCHAR);
INSERT INTO another_table VALUES (10, 'xyz'), (20, 'uvw');
SELECT a, b, regexp_extract(b, '([a-z]+)', 1) + (SELECT COUNT(num_col) FROM test_data WHERE num_col > 15) AS fuzzy_result FROM another_table LEFT JOIN test_data ON a = FLOOR(num_col) WHERE regexp_extract(b, '([a-z]+)', 1) IS NOT NULL;
SELECT id, ISNULL(regexp_extract(text_col, '([a-z]+)', 1)) + (num_col / NULLIF(num_col, 0)) AS complex_evaluation FROM test_data;
ALTER TABLE test_data ADD COLUMN new_col VARCHAR;
UPDATE test_data SET new_col = regexp_extract(text_col, '([a-z]+)(\d+)', 0) WHERE id = 1;