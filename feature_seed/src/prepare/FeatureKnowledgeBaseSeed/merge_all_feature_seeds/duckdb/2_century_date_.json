CREATE TABLE test_dates (id INTEGER PRIMARY KEY, date_value DATE, value NUMERIC);
INSERT INTO test_dates VALUES (1, DATE '1900-01-01', 100.5), (2, DATE '1999-12-31', 200.2), (3, DATE '2000-01-01', NULL), (4, DATE NULL, 400.8);
SELECT id, century(date_value) - (SELECT COUNT(*) FROM test_dates WHERE value > 150) AS century_adjusted FROM test_dates;
SELECT id, date_value, century(date_value) - value AS difference FROM test_dates WHERE value IS NOT NULL;
SELECT id, century(date_value), COUNT(*) AS count_per_century FROM test_dates GROUP BY century(date_value) HAVING COUNT(*) > (SELECT AVG(value) FROM test_dates WHERE value IS NOT NULL);
SELECT id, century(date_value) AS century_val FROM test_dates ORDER BY century_val DESC LIMIT 2;
WITH date_century AS (SELECT id, century(date_value) AS century_num FROM test_dates WHERE date_value IS NOT NULL) SELECT century_num, COUNT(*) FROM date_century GROUP BY century_num;