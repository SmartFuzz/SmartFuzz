CREATE TABLE test_files (filename VARCHAR);
INSERT INTO test_files VALUES ('valid_utf8.txt'), ('invalid_utf8.txt'), ('empty.txt');
SELECT read_text(filename) FROM test_files WHERE filename = 'valid_utf8.txt';
SELECT read_text(filename) FROM test_files WHERE filename = 'invalid_utf8.txt';
SELECT read_text(filename) FROM test_files WHERE filename = 'empty.txt';
SELECT (CASE WHEN read_text(filename) IS NOT NULL THEN 'Valid UTF-8' ELSE 'Invalid UTF-8' END) AS utf8_status FROM test_files;
CREATE TABLE another_test_files (file_pattern VARCHAR);
INSERT INTO another_test_files VALUES ('*.txt');
SELECT read_text(file_pattern) FROM another_test_files;
CREATE TABLE final_test (source VARCHAR);
INSERT INTO final_test VALUES ('hello.txt'), ('goodbye.txt'), ('more_files.txt');
SELECT read_text(source) AS content FROM final_test WHERE source IN (SELECT filename FROM test_files WHERE filename LIKE '%.txt');