CREATE TABLE timestamps (id INT, ts TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '1990-01-01'), (2, TIMESTAMP '2000-05-15'), (3, TIMESTAMP '2100-12-31');
SELECT id, century(ts) AS century_value FROM timestamps;
SELECT century(TIMESTAMP '1899-12-31') AS boundary_century_before_1900;
SELECT century(TIMESTAMP '2000-01-01') AS boundary_century_start_2000;
SELECT century(TIMESTAMP '2099-01-01') AS boundary_century_end_2099;
CREATE TABLE additional_dates (date_id INT, ts TIMESTAMP);
INSERT INTO additional_dates VALUES (1, TIMESTAMP '1998-07-21'), (2, TIMESTAMP '2015-03-01'), (3, TIMESTAMP '2022-12-31');
SELECT ad.date_id, century(ad.ts) AS century_value FROM additional_dates ad JOIN timestamps t ON ad.date_id = t.id;
SELECT t.id, t.ts, century(t.ts) AS century_value FROM timestamps t WHERE t.ts > TIMESTAMP '1980-01-01';
SELECT COUNT(*) AS century_count, century(ts) AS century_value FROM timestamps GROUP BY century(ts);
SELECT MAX(century(ts)) AS max_century FROM timestamps;
WITH century_record AS (SELECT ts, century(ts) AS century_value FROM timestamps) SELECT COUNT(*) FROM century_record WHERE century_value = 20;