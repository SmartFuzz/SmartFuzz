CREATE TABLE bitstring_test (id INT, bitstring_value BIT);
INSERT INTO bitstring_test VALUES (1, B'1010'), (2, B'1100'), (3, B'1111'), (4, B'1001');
SELECT bit_and(bitstring_value) FROM bitstring_test;
CREATE TABLE additional_test (id INT, other_bitstring BIT);
INSERT INTO additional_test VALUES (1, B'1110'), (2, B'0101'), (3, B'0011');
SELECT bit_and(t1.bitstring_value) FROM bitstring_test AS t1 JOIN additional_test AS t2 ON t1.id = t2.id;
SELECT bit_and(bitstring_value) FROM (SELECT bitstring_value FROM bitstring_test WHERE id IN (1, 2)) AS subquery;
CREATE TABLE complex_test (id INT, group_id INT, bitstring_value BIT);
INSERT INTO complex_test VALUES (1, 1, B'1101'), (2, 1, B'1011'), (3, 2, B'0001'), (4, 2, B'1110');
SELECT group_id, bit_and(bitstring_value) FROM complex_test GROUP BY group_id;
CREATE TABLE more_complex_test (id INT, ref_id INT, bitstring_value BIT);
INSERT INTO more_complex_test VALUES (1, 1, B'0011'), (2, 1, B'0101'), (3, 2, B'1111'), (4, 2, B'0000');
SELECT m.ref_id, bit_and(m.bitstring_value) AS result FROM more_complex_test AS m JOIN complex_test AS c ON m.ref_id = c.group_id GROUP BY m.ref_id;
SELECT bit_and(b1.bitstring_value) FROM bitstring_test AS b1, additional_test AS b2 WHERE b1.id < b2.id;