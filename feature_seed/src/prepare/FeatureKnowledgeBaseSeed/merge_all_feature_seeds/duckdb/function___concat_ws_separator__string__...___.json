CREATE TABLE fruits (name VARCHAR);
INSERT INTO fruits VALUES ('Banana'), ('Apple'), (NULL), ('Melon');
SELECT concat_ws(', ', name) FROM fruits;
CREATE TABLE veggies (name VARCHAR);
INSERT INTO veggies VALUES ('Carrot'), (NULL), ('Celery');
SELECT concat_ws(', ', (SELECT name FROM fruits), (SELECT name FROM veggies));
CREATE TABLE dishes (fruit VARCHAR, veggie VARCHAR);
INSERT INTO dishes VALUES ('Banana', 'Carrot'), ('Apple', NULL), (NULL, 'Celery'), ('Melon', 'Carrot');
SELECT concat_ws(', ', fruit, veggie) FROM dishes;
SELECT concat_ws(', ', (SELECT name FROM fruits WHERE name IS NOT NULL ORDER BY name), (SELECT name FROM veggies WHERE name IS NOT NULL ORDER BY name));
CREATE TABLE mixed (part1 VARCHAR, part2 VARCHAR);
INSERT INTO mixed VALUES ('Apricot', 'Feta'), (NULL, 'Salami'), ('Peach', NULL);
SELECT concat_ws(' - ', part1, part2) FROM mixed;
CREATE TABLE advanced (a VARCHAR, b VARCHAR, c VARCHAR);
INSERT INTO advanced VALUES ('Item1', NULL, 'Tag1'), (NULL, 'Item2', 'Tag2'), ('Item3', 'Item4', NULL);
SELECT concat_ws(' | ', a, b, c) FROM advanced;