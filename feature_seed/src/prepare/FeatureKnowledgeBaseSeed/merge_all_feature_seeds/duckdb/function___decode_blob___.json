CREATE TABLE blob_test (data BLOB);
INSERT INTO blob_test VALUES (decode('\xC3\xBC'::BLOB));
INSERT INTO blob_test VALUES (decode('\xE2\x9C\x94'::BLOB));
INSERT INTO blob_test VALUES (decode('\xC3\x28'::BLOB));
SELECT decode(data) FROM blob_test WHERE data IS NOT NULL;
SELECT decode(data) FROM blob_test WHERE data = decode('\xC3\xBC'::BLOB);
CREATE TABLE another_table (data_1 BLOB, data_2 BLOB);
INSERT INTO another_table VALUES (decode('\xC2\xA9'::BLOB), decode('\xF0\x9F\x98\x81'::BLOB));
SELECT decode(a.data_1) AS decoded_1, decode(b.data_2) AS decoded_2 FROM blob_test AS a JOIN another_table AS b ON a.data = b.data_1;
SELECT decode(data) FROM (SELECT data FROM blob_test WHERE data IS NOT NULL) AS subquery;
CREATE TABLE join_test (id INT, data_blob BLOB);
INSERT INTO join_test VALUES (1, decode('\xC3\xBC'::BLOB)), (2, decode('\xE2\x9C\x94'::BLOB));
SELECT jt.id, decode(jt.data_blob) FROM join_test AS jt WHERE decode(jt.data_blob) IS NOT NULL;
SELECT a.id, decode(a.data_blob) FROM join_test AS a JOIN (SELECT id, data_blob FROM join_test WHERE id > 1) AS b ON a.id = b.id;
WITH valid_blobs AS (SELECT decode(data) AS decoded FROM blob_test WHERE data IS NOT NULL) SELECT COUNT(*) FROM valid_blobs;
SELECT decode(data) FROM blob_test WHERE decode(data) LIKE '%ü%';
CREATE TABLE error_test (error_data BLOB);
INSERT INTO error_test VALUES (decode('\xFF'::BLOB));
SELECT decode(error_data) FROM error_test WHERE error_data IS NOT NULL;