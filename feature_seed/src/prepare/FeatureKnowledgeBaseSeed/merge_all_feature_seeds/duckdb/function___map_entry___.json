CREATE TABLE test_map (key INT, value VARCHAR);
INSERT INTO test_map VALUES (100, 'a'), (5, 'b');
SELECT map([key], [value])[key] FROM test_map;
SELECT map([100, 5], ['a', 'b'])[100] AS element_a;
SELECT map([key], [value])[5] FROM test_map WHERE key IN (100, 5);
CREATE TABLE nested_table AS SELECT map([1, 2], ['one', 'two']) AS test_map FROM test_map;
SELECT test_map[1] FROM nested_table;
SELECT test_map[key] FROM (SELECT map([100, 5], ['a', 'b']) AS test_map, key FROM test_map) AS sub_query WHERE key = 100;
WITH cte AS (SELECT key, value FROM test_map) SELECT map([100, 5], ['a', 'b'])[key] FROM cte WHERE value = 'a';
CREATE TABLE another_table (map_col MAP<INT, VARCHAR>);
INSERT INTO another_table VALUES (map([1, 2], ['one', 'two']));
SELECT map_col[1] FROM another_table WHERE map_col[2] = 'two';
SELECT map([key], [value])[key] FROM test_map ORDER BY key DESC;
SELECT DISTINCT map([key], [value])[5] FROM test_map WHERE value = 'b';