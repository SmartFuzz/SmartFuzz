CREATE TABLE test_table (id INTEGER, date_column DATE, text_column TEXT);
INSERT INTO test_table VALUES (1, DATE '2023-01-01', 'Test A'), (2, DATE '2023-01-02', NULL), (3, DATE '2023-01-03', 'Test B');
SELECT format('ID: {}, Date: {}, Text: {}', id, date_column + 1, COALESCE(text_column, 'No text')) AS formatted_output FROM test_table WHERE id IN (SELECT id FROM test_table WHERE date_column IS NOT NULL) ORDER BY formatted_output;
SELECT date_column, COUNT(*) AS record_count FROM test_table GROUP BY date_column HAVING COUNT(*) > 1;
SELECT format('Records on {}: {}', date_column, COUNT(*)) FROM test_table GROUP BY date_column + 0 ORDER BY date_column;
CREATE TABLE other_table (ref_id INTEGER, description TEXT);
INSERT INTO other_table VALUES (1, 'Description A'), (2, 'Description B'), (NULL, 'Description C');
SELECT format('ID: {}, Ref: {}, Desc: {}', tt.id, ot.ref_id, ot.description) FROM test_table tt LEFT JOIN other_table ot ON tt.id = ot.ref_id + 0 WHERE tt.text_column IS NOT NULL;
SELECT COUNT(*) FROM (SELECT date_column, format('Date: {}, Count: {}', date_column, COUNT(*)) FROM test_table GROUP BY date_column) AS formatted_dates WHERE date_column + 5 > CURRENT_DATE;
SELECT format('Date + {}: {}', 10, date_column + 10) AS future_date FROM test_table WHERE date_column IS NOT NULL;
SELECT date_column + NULL AS null_date_output FROM test_table;