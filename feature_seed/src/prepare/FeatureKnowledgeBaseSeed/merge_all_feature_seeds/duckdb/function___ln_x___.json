CREATE TABLE ln_test (value FLOAT);
INSERT INTO ln_test VALUES (1.0), (2.718), (10.0), (0.0), (-5.0);
SELECT ln(value) FROM ln_test;
SELECT ln(NULL);
SELECT ln(value) FROM ln_test WHERE value IS NOT NULL;
SELECT ln(2) + ln(3) AS log_sum;
SELECT ln(value) FROM ln_test WHERE value > 0;
SELECT CASE WHEN value > 0 THEN ln(value) ELSE NULL END AS ln_value FROM ln_test;
CREATE TABLE ln_results AS SELECT value, ln(value) AS ln_value FROM ln_test WHERE value > 0;
CREATE TABLE ln_combined AS SELECT a.value, b.value FROM ln_test AS a JOIN ln_test AS b ON a.value < b.value;
SELECT a.value, b.value, ln(a.value * b.value) AS ln_product FROM ln_test AS a JOIN ln_test AS b ON a.value > 0 AND b.value > 0;
INSERT INTO ln_test (value) SELECT COUNT(*) FROM (SELECT DISTINCT value FROM ln_test);
WITH positive_ln AS (SELECT value, ln(value) AS ln_value FROM ln_test WHERE value > 0) SELECT AVG(ln_value) FROM positive_ln;