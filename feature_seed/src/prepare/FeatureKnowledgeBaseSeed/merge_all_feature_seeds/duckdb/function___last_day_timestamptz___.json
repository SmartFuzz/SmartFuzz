CREATE TABLE test_timestamps (id INT, event_time TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES (1, TIMESTAMPTZ '2023-09-30 12:00:00 UTC'), (2, TIMESTAMPTZ '2023-10-31 15:30:00 UTC'), (3, TIMESTAMPTZ '2023-07-01 00:00:00 UTC');
SELECT id, last_day(event_time) AS last_day_of_month FROM test_timestamps;
SELECT id, event_time, last_day(event_time) AS last_day_of_month FROM test_timestamps WHERE event_time BETWEEN TIMESTAMPTZ '2023-01-01 UTC' AND TIMESTAMPTZ '2023-12-31 UTC';
SELECT id, last_day(event_time) AS last_day_of_month FROM test_timestamps WHERE last_day(event_time) = TIMESTAMPTZ '2023-10-31 00:00:00 UTC';
CREATE TABLE events (event_id INT, event_date TIMESTAMPTZ);
INSERT INTO events VALUES (1, TIMESTAMPTZ '2023-10-05 18:00:00 UTC'), (2, TIMESTAMPTZ '2023-10-15 09:30:00 UTC');
SELECT e.event_id, e.event_date, last_day(e.event_date) AS last_day_of_event FROM events AS e JOIN test_timestamps AS t ON date(e.event_date) = date(t.event_time);
SELECT id, last_day(TIMESTAMPTZ '2023-02-29 23:59:59 UTC') AS last_day_feb FROM test_timestamps;
SELECT id + 1 AS next_id, last_day(event_time) AS last_day_of_month FROM test_timestamps ORDER BY last_day(event_time) DESC;
SELECT COUNT(*) AS num_last_days FROM test_timestamps WHERE last_day(event_time) = TIMESTAMPTZ '2023-10-31 00:00:00 UTC';
WITH last_days AS (SELECT id, last_day(event_time) AS last_day FROM test_timestamps) SELECT * FROM last_days WHERE last_day > TIMESTAMPTZ '2023-09-01 UTC';