CREATE TABLE dates_table (id INTEGER PRIMARY KEY, event_date DATE);
INSERT INTO dates_table (id, event_date) VALUES (1, DATE '2023-01-01'), (2, DATE '2023-12-31'), (3, DATE '2023-06-15');
SELECT id, greatest(event_date, event_date - INTERVAL 30 DAY) AS latest_event_date FROM dates_table;
SELECT id, event_date - INTERVAL (SELECT COUNT(*) FROM dates_table) DAY AS adjusted_date FROM dates_table WHERE event_date > DATE '2023-01-01';
WITH date_diff AS (SELECT id, greatest(event_date, DATE '2022-01-01') AS later_date, event_date - INTERVAL 5 DAY AS past_date FROM dates_table) SELECT *, later_date - past_date AS date_difference FROM date_diff;
CREATE TABLE events_table (event_id INTEGER PRIMARY KEY, occurrence_date DATE, event_name STRING);
INSERT INTO events_table (event_id, occurrence_date, event_name) VALUES (1, NULL, 'New Year'), (2, DATE '2023-07-04', 'Independence Day'), (3, DATE '2023-11-25', 'Black Friday');
SELECT e.event_id, greatest(e.occurrence_date, d.event_date) AS most_recent_date FROM events_table e JOIN dates_table d ON e.occurrence_date = d.event_date WHERE d.id = (SELECT MAX(id) FROM dates_table);
SELECT id, COUNT(*) AS event_count FROM events_table GROUP BY id HAVING COUNT(*) > 0 AND greatest(occurrence_date, DATE '2023-07-01') IS NOT NULL;
SELECT id, event_date, (greatest(event_date, DATE '2023-01-01') - INTERVAL 1 DAY) AS adjusted_date FROM dates_table ORDER BY adjusted_date DESC;