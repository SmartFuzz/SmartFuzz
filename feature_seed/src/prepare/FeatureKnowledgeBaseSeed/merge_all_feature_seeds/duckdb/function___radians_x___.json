CREATE TABLE degrees_table (degree_value FLOAT);
INSERT INTO degrees_table VALUES (0), (90), (180), (270), (360);
SELECT degree_value, radians(degree_value) AS radian_value FROM degrees_table;
CREATE TABLE conversions AS SELECT degree_value, radians(degree_value) AS radian_value FROM degrees_table;
SELECT SUM(radian_value) FROM conversions;
WITH radian_values AS (SELECT degree_value, radians(degree_value) AS radian_value FROM degrees_table) SELECT AVG(radian_value) FROM radian_values;
CREATE TABLE additional_degrees (degree_value FLOAT);
INSERT INTO additional_degrees VALUES (45), (60), (120);
SELECT d.degree_value, a.degree_value, radians(d.degree_value) + radians(a.degree_value) AS combined_radians FROM degrees_table d JOIN additional_degrees a ON d.degree_value < a.degree_value;
SELECT d.degree_value, radians(d.degree_value) AS radian_value, CASE WHEN radians(d.degree_value) < 1 THEN 'Less than One' ELSE 'One or More' END AS classification FROM degrees_table d;
SELECT d.degree_value, radians(d.degree_value) AS radian_value FROM degrees_table WHERE degree_value IN (SELECT degree_value FROM additional_degrees);