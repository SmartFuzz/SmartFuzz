CREATE TABLE test_dates (id INTEGER, created TIMESTAMP, updated TIMESTAMP, duration INTEGER);
INSERT INTO test_dates VALUES (1, TIMESTAMP '2021-01-01 10:00:00', TIMESTAMP '2021-01-01 12:30:00', 150);
INSERT INTO test_dates VALUES (2, TIMESTAMP '2021-01-02 14:00:00', TIMESTAMP '2021-01-02 16:45:00', 165);
INSERT INTO test_dates VALUES (3, TIMESTAMP '2021-01-03 08:15:00', TIMESTAMP NULL, NULL);
SELECT id, created, updated, (updated - created) AS time_diff, to_hours((updated - created) / 3600) AS hours_diff FROM test_dates WHERE updated IS NOT NULL;
SELECT id, created, updated, to_hours(5) - 1 AS adjusted_interval FROM test_dates WHERE created < (SELECT MAX(updated) FROM test_dates);
SELECT id, to_hours(duration) AS duration_hours FROM test_dates WHERE duration IS NOT NULL GROUP BY duration_hours HAVING duration_hours >= 3;
SELECT id, (SELECT to_hours(MAX(duration)) FROM test_dates WHERE duration IS NOT NULL) - MIN(to_hours(duration)) AS diff FROM test_dates;
SELECT t1.id FROM test_dates t1 JOIN test_dates t2 ON t1.updated - t2.created = INTERVAL '1 hour' WHERE t1.updated IS NOT NULL AND t2.created IS NOT NULL;
SELECT id, created, updated, (to_hours(5) - 2) AS subtracted_hours FROM test_dates WHERE (updated IS NULL OR created IS NULL);