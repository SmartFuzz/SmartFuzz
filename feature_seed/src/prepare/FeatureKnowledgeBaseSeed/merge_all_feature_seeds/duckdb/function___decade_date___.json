CREATE TABLE dates_table (event_name VARCHAR, event_date DATE);
INSERT INTO dates_table VALUES ('Event A', DATE '1990-05-15'), ('Event B', DATE '1995-10-20'), ('Event C', DATE '2002-07-14');
SELECT decade(event_date) FROM dates_table WHERE event_date BETWEEN DATE '1990-01-01' AND DATE '2000-12-31';
SELECT event_name, decade(event_date) AS event_decade FROM dates_table WHERE decade(event_date) = 199;
CREATE TABLE additional_dates (description VARCHAR, start_date DATE, end_date DATE);
INSERT INTO additional_dates VALUES ('Period 1', DATE '1985-03-01', DATE '1989-12-31'), ('Period 2', DATE '1995-01-01', DATE '1999-12-31');
SELECT t.event_name, t.event_date, a.description FROM dates_table AS t JOIN additional_dates AS a ON t.event_date BETWEEN a.start_date AND a.end_date;
SELECT AVG(decade(event_date)) FROM dates_table;
SELECT DISTINCT decade(event_date) AS unique_decades FROM dates_table;
CREATE TABLE years_table (year_id INT, year_value DATE);
INSERT INTO years_table VALUES (1, DATE '2000-01-01'), (2, DATE '2010-01-01'), (3, DATE '2020-01-01');
SELECT a.event_name, decade(a.event_date) AS event_decade, b.year_id FROM dates_table a LEFT JOIN years_table b ON decade(a.event_date) = decade(b.year_value);
WITH date_info AS (SELECT event_name, decade(event_date) AS event_decade FROM dates_table) SELECT event_decade, COUNT(*) FROM date_info GROUP BY event_decade;
SELECT COUNT(*) FROM (SELECT DISTINCT decade(event_date) FROM dates_table) AS unique_decades_count;