CREATE TABLE numbers (value FLOAT);
INSERT INTO numbers VALUES (17.4), (3.2), (-5.8), (0), (1.1), (4.9), (null);
SELECT ceiling(value) FROM numbers;
SELECT value, ceiling(value) FROM numbers WHERE value IS NOT NULL;
SELECT ceiling(AVG(value)) FROM numbers;
SELECT DISTINCT ceiling(value) FROM numbers ORDER BY value;
CREATE TABLE more_numbers (num FLOAT);
INSERT INTO more_numbers VALUES (2.3), (15.7), (6.5);
SELECT a.value, b.num, ceiling(a.value + b.num) AS rounded_sum FROM numbers a JOIN more_numbers b ON a.value IS NOT NULL AND b.num IS NOT NULL;
SELECT ceiling(SUM(value)) FROM (SELECT value FROM numbers WHERE value > 0) AS filtered_numbers;
SELECT ceiling(MAX(value)) FROM numbers WHERE value < 10;