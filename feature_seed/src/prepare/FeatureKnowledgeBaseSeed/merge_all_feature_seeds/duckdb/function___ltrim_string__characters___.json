CREATE TABLE test_strings (id INTEGER, str VARCHAR);
INSERT INTO test_strings VALUES (1, '>>>>test<<'), (2, '****welcome!'), (3, '----special!!!'), (4, '   leading spaces'), (5, '<<<multiple<<<><><>');
SELECT id, ltrim(str, '><') AS trimmed_str FROM test_strings;
SELECT id, ltrim(ltrim(str, '><'), '-') AS double_trimmed_str FROM test_strings;
SELECT id, ltrim(str || '>>>', '<>') AS concatenated_trimmed FROM test_strings;
SELECT id, ltrim((SELECT str FROM test_strings WHERE id = 2), '*') AS subquery_trimmed FROM test_strings WHERE id = 1;
SELECT t1.id, ltrim(t1.str, '-') AS trimmed, t2.extra FROM test_strings t1 JOIN (SELECT id, 'extra_data' AS extra FROM test_strings) t2 ON t1.id = t2.id;
SELECT id, ltrim((SELECT str FROM test_strings WHERE id = 3) || '****', '-') AS complex_trimmed FROM test_strings;
SELECT ltrim('    leading spaces    ', ' ') AS trimmed_spaces;
SELECT ltrim('<><>nothing>><', '<>') AS trimmed_nothing;