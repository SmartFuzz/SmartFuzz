CREATE TABLE test_arrays (id INT, array1 FLOAT[], array2 FLOAT[]);
INSERT INTO test_arrays VALUES (1, array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
SELECT array_cosine_distance(array1, array2) FROM test_arrays WHERE id = 1;
INSERT INTO test_arrays VALUES (2, array_value(0.0::FLOAT, 1.0::FLOAT), array_value(0.0::FLOAT, 1.0::FLOAT));
SELECT array_cosine_distance(array1, array2) FROM test_arrays WHERE id = 2;
INSERT INTO test_arrays VALUES (3, array_value(-1.0::FLOAT, -2.0::FLOAT, -3.0::FLOAT), array_value(-2.0::FLOAT, -3.0::FLOAT, -4.0::FLOAT));
SELECT array_cosine_distance(array1, array2) FROM test_arrays WHERE id = 3;
INSERT INTO test_arrays VALUES (4, array_value(1.5::FLOAT, NULL), array_value(1.5::FLOAT, 2.5::FLOAT));
SELECT array_cosine_distance(array1, array2) FROM test_arrays WHERE id = 4 AND array1 IS NOT NULL AND array2 IS NOT NULL;
INSERT INTO test_arrays VALUES (5, array_value(100.0::FLOAT, -200.0::FLOAT, 300.0::FLOAT), array_value(400.0::FLOAT, 500.0::FLOAT, 600.0::FLOAT));
SELECT array_cosine_distance(array1, array2) FROM test_arrays WHERE id = 5;
INSERT INTO test_arrays VALUES (6, array_value(1.0::FLOAT, 1.0::FLOAT, 1.0::FLOAT), array_value(1.0::FLOAT, 1.0::FLOAT, 1.0::FLOAT));
SELECT array_cosine_distance(array1, array2) FROM test_arrays WHERE id = 6;
CREATE TABLE more_arrays (id INT, array1 FLOAT[], array2 FLOAT[]);
INSERT INTO more_arrays VALUES (1, array_value(1.0::FLOAT, 2.0::FLOAT), array_value(2.0::FLOAT, 1.0::FLOAT));
SELECT a.id, array_cosine_distance(a.array1, b.array2) FROM test_arrays AS a JOIN more_arrays AS b ON a.id = 1;
SELECT array_cosine_distance(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(4.0::FLOAT, 5.0::FLOAT, 6.0::FLOAT)) AS distance, array_cosine_distance(array_value(7.0::FLOAT, 8.0::FLOAT), array_value(9.0::FLOAT, 10.0::FLOAT)) AS distance2;