CREATE TABLE test_dates (id INTEGER PRIMARY KEY, date_val DATE, time_val TIME, num_val FLOAT);
INSERT INTO test_dates (id, date_val, time_val, num_val) VALUES (1, DATE '2023-01-01', TIME '12:00:00', 1.1);
INSERT INTO test_dates (id, date_val, time_val, num_val) VALUES (2, NULL, TIME '12:30:00', NULL);
INSERT INTO test_dates (id, date_val, time_val, num_val) VALUES (3, DATE '1992-03-07', TIME '13:00:00', 2.2);
INSERT INTO test_dates (id, date_val, time_val, num_val) VALUES (4, DATE '9999-12-31', TIME '23:59:59', 3.3);
INSERT INTO test_dates (id, date_val, time_val, num_val) VALUES (5, DATE '1970-01-01', TIME NULL, -1.1);
SELECT id, date_val, isfinite(date_val), (TIME '12:00:00' - INTERVAL 5 HOUR) AS adjusted_time FROM test_dates WHERE num_val IS NOT NULL;
SELECT id, date_val, (isfinite(date_val) AND (TIME '14:00:00' - INTERVAL 1 HOUR) > TIME '13:00:00') AS check_time FROM test_dates WHERE date_val IS NOT NULL;
SELECT id, date_val, (SELECT COUNT(*) FROM test_dates WHERE isfinite(date_val) AND date_val < DATE '2000-01-01') AS valid_dates_count FROM test_dates;
SELECT id, date_val, num_val, (isfinite(date_val) - (num_val IS NULL)::INTEGER) AS null_check FROM test_dates HAVING null_check < 1;
WITH adjusted_dates AS (SELECT id, date_val, isfinite(date_val) AS finite_check FROM test_dates) SELECT COUNT(*) FROM adjusted_dates WHERE finite_check = TRUE;