CREATE TABLE test_timestamps (event_time TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES ('2022-11-07 08:43:04.123456+00'::TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES ('1970-01-01 00:00:00+00'::TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES ('2038-01-19 03:14:07+00'::TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES ('1969-12-31 23:59:59.999999+00'::TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES ('2022-11-07 08:43:04.123456-05'::TIMESTAMPTZ);
SELECT epoch_us(event_time) FROM test_timestamps;
SELECT event_time, epoch_us(event_time) AS epoch_microseconds FROM test_timestamps WHERE event_time >= '2000-01-01+00'::TIMESTAMPTZ;
CREATE TABLE events (event_id INT, event_time TIMESTAMPTZ);
INSERT INTO events VALUES (1, '2020-01-01 00:00:00+00'::TIMESTAMPTZ), (2, '2021-01-01 00:00:00+00'::TIMESTAMPTZ);
SELECT e.event_id, epoch_us(e.event_time) FROM events e JOIN test_timestamps t ON e.event_time = t.event_time;
SELECT t.event_time, epoch_us(t.event_time) AS epoch_microseconds FROM test_timestamps t WHERE epoch_us(t.event_time) < 0;
SELECT epoch_us(t.event_time) AS epoch_microseconds, COUNT(*) FROM test_timestamps t GROUP BY epoch_microseconds ORDER BY epoch_microseconds;
SELECT (SELECT epoch_us(event_time) FROM test_timestamps ORDER BY event_time LIMIT 1) AS first_event_epoch, (SELECT epoch_us(event_time) FROM test_timestamps ORDER BY event_time DESC LIMIT 1) AS last_event_epoch;
CREATE TABLE timezone_test (id INT, timestamp_col TIMESTAMPTZ);
INSERT INTO timezone_test VALUES (1, '2022-11-07 08:43:04+00'::TIMESTAMPTZ), (2, '2022-12-07 08:43:04+02'::TIMESTAMPTZ);
SELECT id, epoch_us(timestamp_col) FROM timezone_test WHERE timestamp_col < current_timestamp;
WITH epoch_values AS (SELECT epoch_us(event_time) AS epoch FROM test_timestamps) SELECT AVG(epoch) FROM epoch_values;