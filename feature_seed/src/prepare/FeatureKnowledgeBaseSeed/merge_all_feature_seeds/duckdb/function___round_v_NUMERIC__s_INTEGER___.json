CREATE TABLE test_numeric (value NUMERIC, precision INTEGER);
INSERT INTO test_numeric VALUES (42.4332, 2);
INSERT INTO test_numeric VALUES (99.9999, 4);
INSERT INTO test_numeric VALUES (12.34567, -1);
INSERT INTO test_numeric VALUES (-1.234, 1);
INSERT INTO test_numeric VALUES (0.0, 3);
INSERT INTO test_numeric VALUES (123456.789, 2);
SELECT ROUND(value, precision) FROM test_numeric;
SELECT ROUND(value, 3) AS rounded_value FROM test_numeric WHERE value > 0;
SELECT ROUND(value, precision) AS rounded_val FROM (SELECT value, precision FROM test_numeric WHERE precision >= 0) AS subquery;
CREATE TABLE test_results AS SELECT ROUND(value, precision) AS rounded_val FROM test_numeric;
CREATE TABLE other_numeric (val NUMERIC);
INSERT INTO other_numeric VALUES (-10.987654), (5.678912);
SELECT ROUND(a.value, a.precision) AS rounded_value, b.val FROM test_numeric a JOIN other_numeric b ON ROUND(a.value, a.precision) > b.val;
SELECT ROUND((SELECT AVG(value) FROM test_numeric), 1);
SELECT ROUND(SUM(value), 2) FROM test_numeric WHERE precision >= 0;
SELECT COUNT(*) AS rounded_count FROM (SELECT ROUND(value, precision) FROM test_numeric) AS rounded_values WHERE rounded_values IS NOT NULL;