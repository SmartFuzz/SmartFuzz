CREATE TABLE events (event_time TIMESTAMP, event_name VARCHAR);
INSERT INTO events VALUES (TIMESTAMP '1992-09-20 20:38:40', 'Event A'), (TIMESTAMP '1992-09-20 21:45:15', 'Event B'), (TIMESTAMP '1992-09-20 22:15:30', 'Event C');
SELECT date_trunc('hour', event_time) AS truncated_hour, event_name FROM events;
CREATE TABLE users (user_id INT, created_at TIMESTAMP);
INSERT INTO users VALUES (1, TIMESTAMP '1992-09-20 20:00:00'), (2, TIMESTAMP '1992-09-20 22:05:00');
SELECT u.user_id, date_trunc('hour', u.created_at) AS registration_hour, e.event_name FROM users u JOIN events e ON u.created_at <= e.event_time;
SELECT u.user_id, date_trunc('minute', e.event_time) AS truncated_minute FROM users u LEFT JOIN events e ON u.user_id = 1 ORDER BY e.event_time ASC;
SELECT COUNT(*) AS event_count, date_trunc('day', event_time) AS event_day FROM events GROUP BY event_day;
SELECT user_id, date_trunc('second', created_at) AS truncated_second FROM users WHERE user_id IN (SELECT user_id FROM users WHERE created_at < TIMESTAMP '1992-09-20 21:00:00');
WITH event_summary AS (SELECT date_trunc('hour', event_time) AS event_hour, COUNT(*) AS total_events FROM events GROUP BY event_hour) SELECT * FROM event_summary WHERE total_events > 1;
SELECT date_trunc('minute', current_timestamp) AS current_minute, (SELECT COUNT(*) FROM events) AS total_events;