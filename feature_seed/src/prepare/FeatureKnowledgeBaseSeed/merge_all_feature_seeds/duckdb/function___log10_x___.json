CREATE TABLE test_values (value FLOAT);
INSERT INTO test_values VALUES (1), (10), (100), (1000), (10000), (0), (-1), (NULL);
SELECT value, log10(value) AS log10_value FROM test_values;
SELECT value, log10(value) AS log10_value FROM test_values WHERE value > 0;
SELECT value, log10(value * 10) AS log10_scaled FROM test_values;
SELECT value, log10(value) AS log10_value FROM test_values WHERE log10(value) IS NOT NULL;
SELECT (SELECT log10(value) FROM test_values WHERE value = 1000) AS log10_1000, (SELECT log10(value) FROM test_values WHERE value = 10) AS log10_10;
CREATE TABLE more_test_values (id INT, value FLOAT);
INSERT INTO more_test_values VALUES (1, 1), (2, 10), (3, 100), (4, 1000);
SELECT mt.id, mt.value, log10(mt.value) AS log10_value FROM more_test_values mt JOIN test_values tv ON mt.value > tv.value;
SELECT count(*) AS count_positive_log10 FROM test_values WHERE log10(value) IS NOT NULL AND value > 0;