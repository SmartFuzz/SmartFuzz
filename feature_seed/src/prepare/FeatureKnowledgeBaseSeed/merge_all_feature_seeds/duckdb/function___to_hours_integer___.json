CREATE TABLE events (event_id INTEGER, event_name VARCHAR, duration_hours INTEGER);
INSERT INTO events VALUES (1, 'Event A', 5), (2, 'Event B', 10), (3, 'Event C', 24);
SELECT event_name, to_hours(duration_hours) AS duration_interval FROM events;
CREATE TABLE users (user_id INTEGER, user_name VARCHAR);
INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob');
SELECT u.user_name, e.event_name FROM users u JOIN events e ON u.user_id = e.event_id;
SELECT e.event_name, to_hours(e.duration_hours) + 1 AS extended_duration FROM events e WHERE e.duration_hours < 10;
WITH duration_calculation AS (SELECT event_name, to_hours(duration_hours) AS calculated_duration FROM events) SELECT * FROM duration_calculation WHERE calculated_duration > to_hours(8);
SELECT e.event_name, to_hours(e.duration_hours) - to_hours(3) AS remaining_duration FROM events e WHERE e.duration_hours > 5;
CREATE TABLE registrations (registration_id INTEGER, user_id INTEGER, event_id INTEGER);
INSERT INTO registrations VALUES (1, 1, 1), (2, 2, 2);
SELECT u.user_name, e.event_name, to_hours(e.duration_hours) AS event_duration FROM users u JOIN registrations r ON u.user_id = r.user_id JOIN events e ON r.event_id = e.event_id WHERE to_hours(e.duration_hours) > to_hours(5);