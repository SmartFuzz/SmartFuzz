CREATE TABLE test_strings (input_string VARCHAR);
INSERT INTO test_strings VALUES ('mühleisen'), ('café'), ('français'), ('jalapeño'), ('naïve'), ('año'), ('ü'), ('é'), ('invalid_input'), (NULL);
SELECT strip_accents(input_string) FROM test_strings;
SELECT input_string, strip_accents(input_string) AS stripped FROM test_strings WHERE input_string IS NOT NULL;
SELECT DISTINCT strip_accents(input_string) FROM test_strings;
SELECT strip_accents(a.input_string) AS stripped_1, strip_accents(b.input_string) AS stripped_2 FROM test_strings a JOIN test_strings b ON a.input_string != b.input_string;
CREATE TABLE accents_test AS SELECT input_string, strip_accents(input_string) AS stripped_string FROM test_strings;
SELECT COUNT(*) FROM accents_test WHERE stripped_string LIKE '%eisen%';
SELECT strip_accents(CONCAT(input_string, ' is a string')) FROM test_strings;
WITH stripped AS (SELECT strip_accents(input_string) AS stripped_string FROM test_strings) SELECT stripped_string FROM stripped WHERE stripped_string IS NOT NULL;
SELECT CASE WHEN strip_accents(input_string) IS NULL THEN 'Null string' ELSE strip_accents(input_string) END AS result FROM test_strings;