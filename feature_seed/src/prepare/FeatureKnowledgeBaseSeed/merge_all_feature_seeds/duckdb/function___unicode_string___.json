CREATE TABLE test_unicode (col1 STRING);
INSERT INTO test_unicode VALUES ('âbcd'), ('â'), ('');
INSERT INTO test_unicode VALUES (NULL);
SELECT unicode(col1) FROM test_unicode;
SELECT unicode((SELECT col1 FROM test_unicode WHERE col1 IS NOT NULL LIMIT 1));
SELECT unicode(REPLACE(col1, 'a', '')) FROM test_unicode;
SELECT unicode(CONCAT(col1, 'x')) FROM test_unicode;
SELECT unicode((SELECT MAX(col1) FROM test_unicode));
SELECT unicode((SELECT MIN(col1) FROM test_unicode));
SELECT unicode(SUBSTR(col1, 1, 1)) FROM test_unicode WHERE col1 IS NOT NULL;
SELECT CASE WHEN col1 IS NULL THEN -1 ELSE unicode(col1) END AS unicode_value FROM test_unicode;
CREATE TABLE other_table (col2 STRING);
INSERT INTO other_table VALUES ('hello'), ('world');
SELECT unicode(t.col1) FROM test_unicode t JOIN other_table o ON t.col1 LIKE '%' || o.col2 || '%' WHERE t.col1 IS NOT NULL;
SELECT DISTINCT unicode(col1) FROM test_unicode WHERE LENGTH(col1) > 0;
SELECT unicode(UPPER(col1)) FROM test_unicode WHERE LENGTH(col1) > 0;