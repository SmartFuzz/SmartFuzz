CREATE TABLE test_data (id INT, text_value VARCHAR(50), time_value TIME, some_date DATE);
INSERT INTO test_data (id, text_value, time_value, some_date) VALUES (1, '>>>hello world>>>', TIME '12:00:00', DATE '2023-10-01');
INSERT INTO test_data (id, text_value, time_value, some_date) VALUES (2, '<<another test<<', TIME '08:30:00', DATE '2023-10-02');
INSERT INTO test_data (id, text_value, time_value, some_date) VALUES (3, '      whitespace     ', TIME '23:59:59', DATE '2023-01-01');
SELECT id, ltrim(text_value, '><') AS trimmed_value, time_value + INTERVAL (CASE WHEN some_date IS NULL THEN 1 ELSE 0 END) HOUR AS new_time FROM test_data WHERE ltrim(text_value, ' ') <> '' GROUP BY id, time_value HAVING new_time > TIME '12:00:01';
SELECT id, ltrim(text_value, '>>>') AS trimmed_value FROM test_data WHERE time_value + INTERVAL 2 HOUR < TIME '15:00:00';
SELECT id, ltrim(text_value, ' ') AS trimmed_value, MAX(time_value + INTERVAL 3 HOUR) OVER() AS max_time FROM test_data ORDER BY trimmed_value, max_time DESC;
SELECT DISTINCT ltrim(text_value, ' '), (time_value + INTERVAL 5 HOUR) FROM test_data WHERE ltrim(text_value, ' ') IS NOT NULL AND time_value IS NOT NULL;
CREATE TEMP TABLE temp_data AS SELECT id, ltrim(text_value, '   ') AS cleaned_text, time_value + INTERVAL 1 HOUR AS adjusted_time FROM test_data WHERE text_value NOT LIKE '%test%';
SELECT t1.id, t2.clean_text FROM temp_data AS t2 JOIN test_data AS t1 ON t1.id = t2.id WHERE ltrim(t1.text_value, '<>') IS NOT NULL;