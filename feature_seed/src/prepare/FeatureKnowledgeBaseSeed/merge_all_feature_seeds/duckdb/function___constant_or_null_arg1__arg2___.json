CREATE TABLE test_cases (arg1 INT, arg2 INT);
INSERT INTO test_cases VALUES (42, NULL), (7, 10), (NULL, 5), (NULL, NULL);
SELECT constant_or_null(arg1, arg2) AS result FROM test_cases;
SELECT constant_or_null(100, NULL) AS result;
SELECT constant_or_null(NULL, 200) AS result;
SELECT constant_or_null(3, (SELECT arg2 FROM test_cases WHERE arg1=42)) AS result;
SELECT constant_or_null((SELECT MAX(arg1) FROM test_cases), (SELECT arg2 FROM test_cases WHERE arg1=7)) AS result;
SELECT t1.arg1, constant_or_null(t1.arg1, t2.arg2) AS result FROM test_cases AS t1 JOIN test_cases AS t2 ON t1.arg1 IS NOT NULL;
WITH sample_data AS (SELECT arg1, arg2 FROM test_cases) SELECT constant_or_null(arg1, NULL) AS result FROM sample_data;
SELECT CASE WHEN arg2 IS NULL THEN constant_or_null(arg1, arg2) ELSE arg1 END AS result FROM test_cases;
SELECT constant_or_null(5, (SELECT NULL)) AS result;
SELECT constant_or_null((SELECT COUNT(*) FROM test_cases), 1) AS result;
SELECT constant_or_null(arg1 * 2, NULL) AS result FROM test_cases WHERE arg2 IS NOT NULL;