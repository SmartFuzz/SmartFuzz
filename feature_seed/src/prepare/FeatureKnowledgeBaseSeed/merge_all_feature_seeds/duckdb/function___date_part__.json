CREATE TABLE dates (event_name VARCHAR, event_date DATE);
INSERT INTO dates VALUES ('Event A', DATE '1999-01-01'), ('Event B', DATE '2001-05-15'), ('Event C', DATE '2005-12-31');
SELECT datepart('year', event_date) FROM dates;
SELECT DATEPART('month', event_date) AS month, COUNT(*) FROM dates GROUP BY month;
CREATE TABLE events (event_name VARCHAR, start_date DATE, end_date DATE);
INSERT INTO events VALUES ('Event D', DATE '2010-06-01', DATE '2010-06-02'), ('Event E', DATE '2012-07-20', DATE '2012-07-22');
SELECT e.event_name, DATEPART('year', e.start_date) AS start_year, DATEPART('year', e.end_date) AS end_year FROM events e;
SELECT e.event_name, DATEPART('day', e.start_date) AS start_day FROM events e WHERE DATEPART('month', e.start_date) = 6;
SELECT event_name, DATEPART('month', event_date) AS event_month, DATEPART('year', event_date) AS event_year FROM dates WHERE DATEPART('year', event_date) > 2000;
SELECT event_name, (SELECT datepart('month', start_date) FROM events WHERE event_name = 'Event D') AS event_d_month FROM dates WHERE event_name = 'Event A';
SELECT event_name, DATEPART('day', event_date) AS event_day FROM dates WHERE DATEPART('year', event_date) = 1999 OR DATEPART('year', event_date) = 2001;
CREATE TABLE holiday_dates (holiday_name VARCHAR, holiday_date DATE);
INSERT INTO holiday_dates VALUES ('New Year', DATE '2023-01-01'), ('Christmas', DATE '2023-12-25');
SELECT hd.holiday_name, DATEPART('month', hd.holiday_date) AS holiday_month FROM holiday_dates hd JOIN dates d ON DATEPART('year', hd.holiday_date) = DATEPART('year', d.event_date) WHERE d.event_name = 'Event A';