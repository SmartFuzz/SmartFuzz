CREATE TABLE test_strings (id INTEGER, input_string VARCHAR);
INSERT INTO test_strings VALUES (1, '123');
INSERT INTO test_strings VALUES (2, 'abc');
INSERT INTO test_strings VALUES (3, NULL);
INSERT INTO test_strings VALUES (4, '');
INSERT INTO test_strings VALUES (5, 'The quick brown fox jumps over the lazy dog');
CREATE TABLE user_data (user_id INTEGER, user_name VARCHAR);
INSERT INTO user_data VALUES (1, 'Alice');
INSERT INTO user_data VALUES (2, 'Bob');
SELECT MD5(input_string) FROM test_strings;
SELECT user_id, MD5(user_name) FROM user_data;
SELECT MD5(CONCAT(input_string, user_name)) FROM test_strings, user_data WHERE test_strings.id = user_data.user_id;
SELECT MD5(input_string) AS hash_value FROM test_strings WHERE input_string IS NOT NULL;
WITH hashed_strings AS (SELECT MD5(input_string) AS hash_value FROM test_strings) SELECT hash_value FROM hashed_strings WHERE hash_value IS NOT NULL;
SELECT MD5('') AS empty_string_hash, MD5(NULL) AS null_string_hash;
SELECT MD5(cast(x AS VARCHAR)) FROM (SELECT COUNT(*) as x FROM test_strings);
SELECT MD5(CONCAT(a.input_string, b.user_name)) FROM test_strings a JOIN user_data b ON a.id = b.user_id;
SELECT MD5('A' || 'B' || 'C' || 'D') AS complex_hash;
SELECT DISTINCT MD5(input_string) FROM test_strings;
SELECT MD5('Case Sensitive') AS case_sensitive_hash, MD5('case sensitive') AS case_insensitive_hash;