CREATE TABLE events (event_time TIMESTAMP, event_name VARCHAR);
INSERT INTO events VALUES (TIMESTAMP '1992-04-20 15:26:00', 'Event A');
INSERT INTO events VALUES (TIMESTAMP '1992-04-21 15:26:00', 'Event B');
INSERT INTO events VALUES (TIMESTAMP '1992-04-22 15:26:00', 'Event C');
SELECT time_bucket(INTERVAL '1 day', event_time) AS bucket, COUNT(*) AS event_count FROM events GROUP BY bucket;
SELECT time_bucket(INTERVAL '1 week', event_time) AS week_bucket, ARRAY_AGG(event_name) AS events FROM events GROUP BY week_bucket;
SELECT e.event_name, time_bucket(INTERVAL '2 weeks', e.event_time, TIMESTAMP '1992-04-01 00:00:00') AS two_week_bucket FROM events e WHERE e.event_time >= TIMESTAMP '1992-04-20';
WITH event_buckets AS (SELECT time_bucket(INTERVAL '3 days', event_time) AS bucket, COUNT(*) AS count FROM events GROUP BY bucket) SELECT bucket, count FROM event_buckets WHERE count > 1;
CREATE TABLE user_activity (user_id INT, activity_time TIMESTAMP);
INSERT INTO user_activity VALUES (1, TIMESTAMP '1992-04-21 12:00:00'), (2, TIMESTAMP '1992-04-21 12:30:00'), (1, TIMESTAMP '1992-04-22 13:00:00');
SELECT a.user_id, time_bucket(INTERVAL '1 hour', a.activity_time) AS hour_bucket, COUNT(*) AS activity_count FROM user_activity a JOIN events e ON DATE(a.activity_time) = DATE(e.event_time) GROUP BY a.user_id, hour_bucket;