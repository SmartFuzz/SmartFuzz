CREATE TABLE test_literals (id INTEGER, description STRING);
INSERT INTO test_literals VALUES (1, 'Single quote: ''');
INSERT INTO test_literals VALUES (2, 'Hello
World');
INSERT INTO test_literals VALUES (3, E'Hello\nWorld');
INSERT INTO test_literals VALUES (4, $$Quotes: $$'$$$$$'$$$ $$);
SELECT id, description FROM test_literals WHERE id = 1;
SELECT d > '2023-01-01' AS comparison_result FROM (VALUES (DATE '2024-01-01')) t(d);
SELECT E'Value: 100\nNext value: 200';
SELECT id, description || ' updated' AS updated_description FROM test_literals WHERE id = 2;
SELECT id, CASE WHEN id = 1 THEN 'First' ELSE 'Not First' END AS label FROM test_literals;
SELECT 100_000_000;
SELECT 1_2.3E3;
SELECT .5, 1.0E-1;
SELECT 'Test with space' || 'and concatenation' AS combined;
SELECT 'Implicit' 'Concatenation' AS greeting;
SELECT 'Invalid' 'Concatenation' 'Test' AS greeting;
SELECT 1e2 + 3e1;
SELECT d = '2022-01-01'::VARCHAR FROM (VALUES (DATE '2022-01-01')) t(d);
SELECT 1.5 + 100_000_000;
SELECT 'Hello' || NULL AS result;
SELECT 'Sample: ' || E'Hello\nWorld' AS result;
SELECT $$Hello$$ || $$ World$$ AS message;
SELECT 6.02214e23 AS avogadro_constant;
SELECT 1e-10 + 5.5 AS precision_sum;
SELECT COUNT(*) FROM (VALUES (1), (2), (3)) AS t(x) WHERE x > 2;
CREATE TABLE nums (value INTEGER);
INSERT INTO nums VALUES (100), (200), (300);
SELECT value FROM nums WHERE value > 150 ORDER BY value DESC;
SELECT AVG(value) FROM nums;
SELECT * FROM (SELECT 1 AS a, 2 AS b) AS subquery WHERE a + b = 3;