CREATE TABLE test_data (id INTEGER, numbers LIST<INTEGER>, bits BITSTRING, created_at TIMESTAMP);
INSERT INTO test_data VALUES (1, [2, 3, NULL], '101010'::BITSTRING, '2022-01-01 10:00:00');
INSERT INTO test_data VALUES (2, [NULL, NULL], '001100'::BITSTRING, '2022-01-01 10:05:00');
INSERT INTO test_data VALUES (3, [1, 4, 5], '000011'::BITSTRING, '2022-01-01 10:10:00');
INSERT INTO test_data VALUES (4, [], '110110'::BITSTRING, '2022-01-01 10:15:00');
SELECT id, array_aggr(numbers, 'min') << 1 AS shifted_min FROM test_data GROUP BY id HAVING shifted_min IS NOT NULL;
SELECT id, numbers, bits << 2 AS shifted_bits FROM test_data WHERE bits IS NOT NULL AND array_aggr(numbers, 'max') IS NOT NULL;
SELECT id, array_aggr(numbers, 'min') AS min_number, bits << 1 AS shifted_bits FROM test_data GROUP BY id HAVING min_number < 4 OR shifted_bits IS NULL;
SELECT id, (SELECT array_aggr(numbers, 'count') FROM test_data WHERE id = 3) << 3 AS counted_shifted FROM test_data;
SELECT id, (SELECT COUNT(*) FROM test_data WHERE numbers IS NOT NULL) AS valid_count, MIN(bits) << 4 AS min_shifted_bits FROM test_data GROUP BY id;