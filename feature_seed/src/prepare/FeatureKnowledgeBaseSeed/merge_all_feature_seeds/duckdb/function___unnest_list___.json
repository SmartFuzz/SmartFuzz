CREATE TABLE test_list (id INT, values LIST<INT>);
INSERT INTO test_list VALUES (1, [1, 2, 3]), (2, [4, 5]), (3, NULL);
SELECT id, unnest(values) AS value FROM test_list;
SELECT id, value FROM test_list, unnest(values) AS value;
WITH unnested_data AS (SELECT id, unnest(values) AS value FROM test_list) SELECT id, COUNT(value) FROM unnested_data GROUP BY id;
SELECT id, SUM(value) FROM test_list, unnest(values) AS value GROUP BY id;
CREATE TABLE another_test (id INT, num INT);
INSERT INTO another_test VALUES (1, 10), (1, 20), (2, 30);
SELECT a.id, value FROM test_list a JOIN another_test b ON a.id = b.id, unnest(a.values) AS value;
SELECT id, unnest(values) AS value FROM test_list WHERE values IS NOT NULL;
SELECT id, COUNT(value) FROM (SELECT id, unnest(values) AS value FROM test_list) AS unnested WHERE value > 2 GROUP BY id;