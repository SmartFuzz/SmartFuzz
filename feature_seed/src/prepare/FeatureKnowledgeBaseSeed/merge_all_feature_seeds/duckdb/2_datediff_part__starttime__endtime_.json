CREATE TABLE test_data (id INT, start_time TIME, end_time TIME, data_list LIST[INT], notes VARCHAR(255));
INSERT INTO test_data VALUES (1, TIME '01:00:00', TIME '02:00:00', [1, 2, 3], 'Test 1'), (2, TIME '02:00:00', TIME '06:00:00', [4, 5, 6], NULL);
SELECT id, datediff('hour', start_time, end_time) AS hours_diff, data_list <-> [1, 2, 4] AS list_distance FROM test_data WHERE notes IS NOT NULL;
SELECT id, (SELECT COUNT(*) FROM test_data t2 WHERE t2.id < test_data.id) AS correlated_count, datediff('hour', start_time, end_time) AS hours_diff FROM test_data ORDER BY hours_diff DESC;
SELECT id, start_time, end_time, datediff('hour', start_time, end_time) AS hours_diff, data_list <-> (SELECT [1, 2, 3]) AS list_distance FROM test_data HAVING hours_diff > 2;
CREATE TABLE secondary_data (ref_id INT, values_list LIST[INT]);
INSERT INTO secondary_data VALUES (1, [3, 4, 5]), (2, [6, 7, NULL]);
SELECT a.id, a.start_time, a.end_time, datediff('hour', a.start_time, a.end_time) AS hours_diff, a.data_list <-> b.values_list AS list_dist FROM test_data a JOIN secondary_data b ON a.id = b.ref_id WHERE list_dist IS NOT NULL;
SELECT id, datediff('hour', start_time, end_time) AS hour_diff FROM test_data WHEN hour_diff IS NOT NULL ORDER BY hour_diff;
CREATE TABLE edge_cases (case_id INT, case_time TIME, case_string VARCHAR(255), case_list LIST[INT]);
INSERT INTO edge_cases VALUES (1, TIME '23:59:59', 'Edge Case', [1, 2, 3]), (2, TIME '00:00:00', NULL, [4, 5, 6]), (3, TIME '12:30:00', 'Mid Case', []);
SELECT ec.case_id, datediff('hour', TIME '00:00:00', ec.case_time) AS hour_diff, ec.case_list <-> [1, 3] AS distance, ec.case_string FROM edge_cases ec WHERE length(ec.case_string) > 0;