CREATE TABLE employees (id INTEGER, name VARCHAR, department VARCHAR);
INSERT INTO employees VALUES (1, 'Alice', 'HR'), (2, 'Bob', 'Finance'), (3, 'Charlie', 'HR'), (4, 'Diana', 'Finance');
SELECT array_agg(name) FROM employees WHERE department = 'HR';
CREATE TABLE departments (dept_id INTEGER, dept_name VARCHAR);
INSERT INTO departments VALUES (1, 'HR'), (2, 'Finance');
SELECT d.dept_name, array_agg(e.name) FROM departments d LEFT JOIN employees e ON d.dept_name = e.department GROUP BY d.dept_name;
CREATE TABLE projects (project_id INTEGER, project_name VARCHAR, assigned_dept VARCHAR);
INSERT INTO projects VALUES (101, 'Project A', 'HR'), (102, 'Project B', 'Finance'), (103, 'Project C', 'HR');
SELECT p.project_name, array_agg(e.name) AS employees FROM projects p LEFT JOIN employees e ON p.assigned_dept = e.department GROUP BY p.project_name ORDER BY p.project_name;
SELECT array_agg(e.name ORDER BY e.name DESC) FROM employees;
SELECT id, array_agg(name ORDER BY name) AS employee_names FROM employees GROUP BY id;
CREATE TABLE test_data (value INTEGER);
INSERT INTO test_data SELECT generate_series(1, 10);
SELECT array_agg(value) FROM test_data WHERE value % 2 = 0;
SELECT array_agg(e.name) FROM employees e JOIN departments d ON e.department = d.dept_name WHERE d.dept_id = 2 GROUP BY e.department HAVING COUNT(e.id) > 1;
CREATE TABLE temp_summary AS SELECT department, array_agg(name) AS employee_names FROM employees GROUP BY department;