CREATE TABLE fuzz_test (id INTEGER PRIMARY KEY, regex_field VARCHAR, number_field INTEGER, date_field DATE);
INSERT INTO fuzz_test (id, regex_field, number_field, date_field) VALUES (1, 'abc', 123, '2023-10-01');
INSERT INTO fuzz_test (id, regex_field, number_field, date_field) VALUES (2, 'def', NULL, NULL);
INSERT INTO fuzz_test (id, regex_field, number_field, date_field) VALUES (3, '' , 0, '1900-01-01');
CREATE TABLE reference_table (ref_id INTEGER PRIMARY KEY, ref_value VARCHAR);
INSERT INTO reference_table (ref_id, ref_value) VALUES (1, 'value1');
CREATE TRIGGER insert_fuzz_test BEFORE INSERT ON fuzz_test FOR EACH ROW BEGIN IF NEW.regex_field REGEXP '^[a-z]+$' THEN SET_ROW_COUNT(row_count(), 1);
END IF;
END;
CREATE PROCEDURE test_regex_and_row_count() BEGIN INSERT INTO fuzz_test (id, regex_field, number_field, date_field) SELECT id, 'xyz', number_field, date_field FROM reference_table;
RETURN row_count();
END;
SELECT id, regex_field, REGEXP(regex_field, '.*[a-z].*'), set_row_count(row_count(), 1) FROM fuzz_test WHERE regex_field IS NOT NULL;
SELECT id, COUNT(*) AS count, AVG(number_field) FROM fuzz_test GROUP BY regex_field HAVING AVG(NULLIF(number_field, 0)) > 50;
SELECT id FROM fuzz_test WHERE number_field IS NOT NULL AND regex_field REGEXP CONCAT('^', TRIM(''), '.*');
SELECT id FROM (SELECT id, regex_field FROM fuzz_test) AS subquery WHERE regex_field REGEXP '^[d-f]+';
UPDATE fuzz_test SET regex_field = 'test' WHERE number_field IS NULL OR date_field < DATE('2000-01-01');
CREATE TABLE temp_fuzz (id_temp INTEGER PRIMARY KEY, data VARCHAR);
INSERT INTO temp_fuzz SELECT id, number_field::VARCHAR FROM fuzz_test WHERE date_field > '2000-01-01';
SELECT temp_fuzz.id_temp, SUM(fuzz_test.number_field) as sum_numbers FROM temp_fuzz JOIN fuzz_test ON temp_fuzz.id_temp = fuzz_test.id GROUP BY temp_fuzz.id_temp HAVING sum_numbers IS NOT NULL;
SELECT DISTINCT id FROM fuzz_test WHERE regex_field REGEXP 'e.f' OR number_field = (SELECT MAX(number_field) FROM fuzz_test);