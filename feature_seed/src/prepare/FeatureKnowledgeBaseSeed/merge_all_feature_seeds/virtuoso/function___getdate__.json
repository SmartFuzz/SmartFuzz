CREATE TABLE test_dates (id INT, created_at TIMESTAMP, updated_at TIMESTAMP);
INSERT INTO test_dates (id, created_at, updated_at) VALUES (1, getdate(), getdate());
INSERT INTO test_dates (id, created_at, updated_at) VALUES (2, now(), now());
SELECT id, created_at, updated_at FROM test_dates WHERE created_at = getdate();
SELECT id, created_at FROM test_dates WHERE EXTRACT(HOUR FROM created_at) = EXTRACT(HOUR FROM getdate());
SELECT id FROM test_dates WHERE updated_at >= getdate() - INTERVAL '1 DAY';
SELECT id, count(*) FROM test_dates GROUP BY id HAVING MAX(updated_at) = getdate();
CREATE TABLE test_users (user_id INT, signup_date TIMESTAMP);
INSERT INTO test_users (user_id, signup_date) SELECT id, getdate() FROM test_dates;
SELECT u.user_id FROM test_users u JOIN test_dates d ON u.signup_date = d.created_at WHERE d.id = (SELECT MAX(id) FROM test_dates);
SELECT id FROM test_dates WHERE created_at < getdate() AND updated_at > getdate() - INTERVAL '2 HOUR';