CREATE TABLE emp (dept VARCHAR(50), job VARCHAR(50), sal NUMERIC);
INSERT INTO emp (dept, job, sal) VALUES ('Sales', 'Manager', 100000);
INSERT INTO emp (dept, job, sal) VALUES ('Sales', 'Salesperson', 60000);
INSERT INTO emp (dept, job, sal) VALUES ('Engineering', 'Engineer', 90000);
INSERT INTO emp (dept, job, sal) VALUES ('Engineering', 'Manager', 120000);
INSERT INTO emp (dept, job, sal) VALUES ('HR', 'Manager', 80000);
SELECT dept, job, SUM(sal) FROM emp GROUP BY GROUPING SETS ((dept, job), (dept), ());
SELECT dept, SUM(sal) FROM emp GROUP BY GROUPING SETS ((dept), ());
SELECT job, SUM(sal) FROM emp GROUP BY GROUPING SETS ((job), ());
SELECT dept, job, COUNT(*) FROM emp GROUP BY GROUPING SETS ((dept, job), (dept), (job));
SELECT dept, SUM(sal) FROM (SELECT dept, job, sal FROM emp WHERE sal > 50000) AS filtered_employees GROUP BY GROUPING SETS ((dept), ());
SELECT dept, COALESCE(SUM(sal), 0) FROM emp GROUP BY GROUPING SETS ((dept), ());
SELECT dept, job, AVG(sal) FROM emp GROUP BY GROUPING SETS ((dept, job), (dept), (job), ());
CREATE TABLE department (dept_id INT, dept_name VARCHAR(50));
INSERT INTO department (dept_id, dept_name) VALUES (1, 'Sales');
INSERT INTO department (dept_id, dept_name) VALUES (2, 'Engineering');
INSERT INTO department (dept_id, dept_name) VALUES (3, 'HR');
SELECT d.dept_name, e.job, SUM(e.sal) FROM emp e JOIN department d ON e.dept = d.dept_name GROUP BY GROUPING SETS ((d.dept_name, e.job), (d.dept_name), (e.job), ());
SELECT e.dept, SUM(e.sal) FROM emp e LEFT JOIN department d ON e.dept = d.dept_name GROUP BY GROUPING SETS ((e.dept), ());