CREATE TABLE mime_test (id INT PRIMARY KEY, part_1 VARCHAR(255), part_2 VARCHAR(255) NULL, mime_type VARCHAR(50));
INSERT INTO mime_test VALUES (1, 'this is a first', 'this is a second', 'text/plain');
SELECT mime_body(vector(mime_part(null, null, null, part_1), mime_part(null, null, 'base64', part_2))) FROM mime_test WHERE id = 1;
CREATE TABLE rdf_class_test (subject VARCHAR(255), predicate VARCHAR(255), object VARCHAR(255));
INSERT INTO rdf_class_test VALUES ('subject1', 'predicate1', 'object1'), ('subject2', 'predicate2', 'object2');
SELECT * WHERE { ?s a rdf_class_test.object FILTER( ?s = 'subject1' ) };
SELECT mime_body(vector(mime_part(null, null, null, (SELECT part_1 FROM mime_test WHERE id = 1)), mime_part(null, null, 'base64', (SELECT part_2 FROM mime_test WHERE id = 1)))) as mime_result FROM rdf_class_test WHERE subject IN (SELECT subject FROM rdf_class_test WHERE object = 'object1');
SELECT mime_body(vector(mime_part(null, null, 'base64', part_1), mime_part(null, null, null, 'default_text'))) FROM mime_test WHERE part_2 IS NULL;
SELECT mime_body(vector(mime_part(null, null, 'base64', '')  )) FROM mime_test WHERE part_1 = (SELECT MAX(part_1) FROM mime_test) GROUP BY part_1 HAVING COUNT(*) > 0;
ALTER TABLE mime_test ADD COLUMN additional_part VARCHAR(255);
INSERT INTO mime_test (id, part_1, part_2, mime_type, additional_part) VALUES (2, 'first_part', NULL, 'text/plain', NULL);
SELECT mime_body(vector(mime_part(null, null, null, additional_part), mime_part(null, null, 'base64', 'second_part'))) FROM mime_test WHERE part_2 IS NULL AND additional_part IS NOT NULL;