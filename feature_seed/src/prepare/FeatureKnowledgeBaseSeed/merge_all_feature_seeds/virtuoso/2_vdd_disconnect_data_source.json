CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100), created_at TIMESTAMP, status BOOLEAN);
INSERT INTO test_table (id, name, created_at, status) VALUES (1, 'Test1', CURRENT_TIMESTAMP, TRUE), (2, 'Test2', NULL, FALSE), (3, NULL, CURRENT_TIMESTAMP, NULL);
SELECT CASE WHEN status IS NULL THEN 'Status Unknown' ELSE 'Status Known' END AS status_check, COUNT(*) FROM test_table GROUP BY status_check HAVING COUNT(*) > 1;
SELECT * FROM test_table WHERE (status OR (name IS NOT NULL AND created_at > NOW() - INTERVAL '1 day')) AND id < 3;
SELECT id, vdd_disconnect_data_source((SELECT name FROM test_table WHERE status IS TRUE AND id = 1)) AS disconnect_status FROM test_table WHERE id = 2 OR status IS NULL;
SELECT id, vdd_disconnect_data_source(SELECT COUNT(*) FROM test_table WHERE created_at IS NULL OR created_at < '1970-01-01') FROM test_table WHERE (name IS NULL OR name != '') OR (created_at IS NOT NULL AND status = TRUE);
SELECT id, vdd_disconnect_data_source(NULL) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE status IS TRUE LIMIT 1) OR name IS NOT NULL;
SELECT COUNT(*) FROM test_table WHERE NOT (vdd_disconnect_data_source((SELECT COUNT(*) FROM test_table WHERE name LIKE 'Test%')) OR (id IS NULL AND created_at IS NULL));
CREATE TABLE tmp_table AS SELECT * FROM test_table WHERE FALSE;
SELECT * FROM test_table WHERE NOT EXISTS (SELECT * FROM tmp_table WHERE test_table.id = tmp_table.id) OR id NOT IN (SELECT id FROM test_table WHERE status = FALSE);
DROP TABLE IF EXISTS tmp_table;