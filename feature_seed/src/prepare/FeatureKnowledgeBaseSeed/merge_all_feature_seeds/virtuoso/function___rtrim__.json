CREATE TABLE test_strings (id INT, test_str VARCHAR(100));
INSERT INTO test_strings VALUES (1, 'hello    ');
INSERT INTO test_strings VALUES (2, 'world!!!');
INSERT INTO test_strings VALUES (3, '   whitespace   ');
INSERT INTO test_strings VALUES (4, 'test****');
SELECT id, rtrim(test_str) AS trimmed_str FROM test_strings WHERE id = 1;
SELECT id, rtrim(test_str, ' ') AS trimmed_space FROM test_strings WHERE id = 3;
SELECT id, rtrim(test_str, '!') AS trimmed_exclamation FROM test_strings WHERE id = 2;
SELECT id, rtrim(test_str, '*') AS trimmed_asterisk FROM test_strings WHERE id = 4;
SELECT id, rtrim(test_str) AS trimmed_str FROM (SELECT test_str FROM test_strings WHERE id = 1) AS subquery;
SELECT t1.id, rtrim(t1.test_str) AS trimmed_str FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.id = t2.id WHERE t1.id = 1;
SELECT id, rtrim(test_str) AS trimmed_str FROM test_strings WHERE rtrim(test_str) = 'test';
SELECT COUNT(*) AS trimmed_rows FROM (SELECT rtrim(test_str) AS trimmed_str FROM test_strings WHERE rtrim(test_str) != '') AS subquery;
SELECT id, rtrim(test_str) AS trimmed_str FROM (SELECT test_str FROM test_strings UNION SELECT 'mixed spaces    ') AS subquery;