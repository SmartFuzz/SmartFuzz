CREATE TABLE test_table (id SERIAL PRIMARY KEY, data1 INTEGER, data2 VARCHAR(32), udt_inst SER_UDT);
INSERT INTO test_table (data1, data2, udt_inst) VALUES (1, 'test', new SER_UDT ());
INSERT INTO test_table (data1, data2, udt_inst) VALUES (2, NULL, new SER_UDT ());
INSERT INTO test_table (data1, data2, udt_inst) VALUES (3, 'example', new SER_UDT ());
UPDATE test_table SET udt_inst = udt_set(udt_inst, 'A', data1 * 10) WHERE data2 != 'test';
SELECT id, udt_set(udt_inst, 'B', data1 + 5) AS modified_inst FROM test_table WHERE data1 != 2;
SELECT COUNT(*) FROM (SELECT id, udt_set(udt_inst, 'A', data1) AS modified_inst FROM test_table WHERE modified_inst IS NOT NULL) AS subquery HAVING COUNT(*) != 0;
SELECT data1, data2 FROM test_table WHERE EXISTS (SELECT 1 FROM test_table AS t2 WHERE t2.data1 != test_table.data1 AND udt_set(t2.udt_inst, 'B', data1) != NULL);
SELECT T1.id FROM test_table AS T1 JOIN test_table AS T2 ON T1.data1 != T2.data1 WHERE udt_set(T1.udt_inst, 'A', 50) IS NOT NULL;
SELECT MIN(data1) AS min_value FROM test_table GROUP BY data2 HAVING MIN(data1) != (SELECT MAX(data1) FROM test_table WHERE data2 IS NOT NULL);