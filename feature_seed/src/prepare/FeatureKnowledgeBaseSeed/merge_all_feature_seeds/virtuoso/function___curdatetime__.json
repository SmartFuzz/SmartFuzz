CREATE TABLE test_datetime (id INT PRIMARY KEY, created_at DATETIME);
INSERT INTO test_datetime (id, created_at) VALUES (1, curdatetime());
SELECT curdatetime() AS current_time;
SELECT curdatetime(0) AS current_time_no_fraction;
SELECT curdatetime(1000000) AS current_time_full_fraction;
SELECT * FROM test_datetime WHERE created_at < curdatetime();
SELECT id, created_at FROM test_datetime WHERE created_at >= curdatetime(500000);
SELECT * FROM (SELECT id, curdatetime() AS current_time FROM test_datetime) AS subquery WHERE current_time > curdatetime();
SELECT COALESCE(MIN(created_at), curdatetime()) AS min_datetime FROM test_datetime;
SELECT DISTINCT created_at FROM test_datetime WHERE created_at BETWEEN curdatetime(200000) AND curdatetime(800000);
CREATE TABLE another_table (id INT PRIMARY KEY, timestamp_field DATETIME);
INSERT INTO another_table (id, timestamp_field) VALUES (1, curdatetime(100000));
SELECT a.id, a.timestamp_field, curdatetime(300000) FROM another_table a JOIN test_datetime t ON a.id = t.id WHERE t.created_at > curdatetime(400000);
SELECT t1.id FROM test_datetime t1 JOIN (SELECT id, curdatetime(20000) as adjusted_time FROM test_datetime) t2 ON t1.created_at > t2.adjusted_time;
SELECT curdatetime(0) - INTERVAL '1 HOUR' AS one_hour_ago;
SELECT curdatetime(-1000) AS negative_fraction;
SELECT curdatetime(1000000) AS max_fraction;
SELECT curdatetime(500000) AS half_fraction;