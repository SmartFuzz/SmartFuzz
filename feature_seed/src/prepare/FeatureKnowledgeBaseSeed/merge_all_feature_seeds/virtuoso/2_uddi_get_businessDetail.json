CREATE TABLE businessEntities (id INT PRIMARY KEY, name VARCHAR(255), details XML);
INSERT INTO businessEntities (id, name, details) VALUES (1, 'Business A', '<root><details><type>Type A</type></details></root>');
INSERT INTO businessEntities (id, name, details) VALUES (2, 'Business B', '<root><details><type>Type B</type><info><![CDATA[Info B]]></info></details></root>');
SELECT uddi_get_businessDetail(1) AS business_info, xml_tree_doc(details) FROM businessEntities WHERE id = 1;
SELECT name, xml_tree_doc('<companies>' || details || '</companies>') FROM businessEntities WHERE id IN (SELECT id FROM businessEntities WHERE name LIKE 'Business%');
SELECT name, COUNT(*) OVER (PARTITION BY xml_tree_doc(details)) AS type_count FROM businessEntities GROUP BY name, xml_tree_doc(details);
SELECT * FROM businessEntities WHERE details IS NOT NULL AND xml_tree_doc(details) IS NOT NULL;
SELECT uddi_get_businessDetail(id) FROM businessEntities WHERE name IN (SELECT name FROM businessEntities WHERE name IS NOT NULL);
CREATE TEMPORARY TABLE tempBusiness AS SELECT * FROM businessEntities WHERE details IS NOT NULL;
SELECT xml_tree_doc('<array>' || STRING_AGG(CAST(details AS VARCHAR), ',') || '</array>') FROM tempBusiness GROUP BY id HAVING COUNT(*) > 1;