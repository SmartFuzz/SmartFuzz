CREATE TABLE xml_test (id INT PRIMARY KEY, xml_data XML);
INSERT INTO xml_test (id, xml_data) VALUES (1, '<root><item>Value 1</item></root>'), (2, '<root><item>Value 2</item></root>');
CREATE TABLE test_data (id INT PRIMARY KEY, value VARCHAR(50));
INSERT INTO test_data (id, value) VALUES (1, 'Test Value'), (2, NULL), (3, 'Another Value');
SELECT DB.DBA.XML_SET_NS_DECL('northwind', 'http://demo.openlinksw.com/schemas/northwind#', 2) AS ns_decl, datatype(value) FROM test_data WHERE value IS NOT NULL;
SELECT id, SUM(CASE WHEN value IS NULL THEN 1 ELSE 0 END) AS null_count FROM test_data GROUP BY id HAVING null_count > 0;
SELECT id, DB.DBA.XML_SET_NS_DECL('testns', CONCAT('<data>', value, '</data>'), 1) FROM test_data WHERE datatype(value) = 'string' ORDER BY id;
SELECT id, DB.DBA.XML_SET_NS_DECL('ns', xml_data, 2) FROM xml_test WHERE id IN (SELECT id FROM test_data WHERE value IS NOT NULL) ORDER BY id;
SELECT id, DB.DBA.XML_SET_NS_DECL('other', xml_data, 2) AS namespace_decl, (SELECT COUNT(*) FROM test_data WHERE value IS NOT NULL) AS non_null_count FROM xml_test;
WITH xml_cte AS (SELECT DB.DBA.XML_SET_NS_DECL('dynamic', xml_data, 1) AS decl, id FROM xml_test) SELECT decl, COUNT(id) FROM xml_cte GROUP BY decl HAVING COUNT(id) > 0;