CREATE TABLE DB.DBA.TEST_TABLE (ID INT, NAME VARCHAR(100));
INSERT INTO DB.DBA.TEST_TABLE (ID, NAME) VALUES (1, 'Test Name');
SELECT ID, NAME FROM DB.DBA.TEST_TABLE WHERE ID = 1;
CREATE PROCEDURE DB.DBA.TEST_PROC AS BEGIN SELECT COUNT(*) FROM DB.DBA.TEST_TABLE;
END;
CALL DB.DBA.TEST_PROC;
CREATE TABLE DB.DBA.NESTED_TABLE (ID INT, TEST_ID INT, DESCRIPTION VARCHAR(255));
INSERT INTO DB.DBA.NESTED_TABLE (ID, TEST_ID, DESCRIPTION) VALUES (1, 1, 'Nested Test');
SELECT t.NAME, nt.DESCRIPTION FROM DB.DBA.TEST_TABLE t JOIN DB.DBA.NESTED_TABLE nt ON t.ID = nt.TEST_ID WHERE t.ID = 1;
CREATE TABLE DB.DBA.USER_TABLE (USER_ID INT, USERNAME VARCHAR(50));
INSERT INTO DB.DBA.USER_TABLE (USER_ID, USERNAME) VALUES (1, 'User1');
SELECT USERNAME FROM DB.DBA.USER_TABLE WHERE USER_ID IN (SELECT ID FROM DB.DBA.TEST_TABLE WHERE ID = 1);
SET @current_qualifier = 'MY_DB';
CALL db.dba.user_set_qualifier('user_name', @current_qualifier);
SELECT * FROM DB..SYS_KEYS;
INSERT INTO DB.DBA.TEST_TABLE (ID, NAME) SELECT ID, NAME FROM DB..SYS_KEYS WHERE ID > 0;
CREATE TABLE DB.DBA.MULTI_JOIN_TABLE (JOIN_ID INT, TEST_ID INT, USER_ID INT);
INSERT INTO DB.DBA.MULTI_JOIN_TABLE (JOIN_ID, TEST_ID, USER_ID) VALUES (1, 1, 1);
SELECT mt.JOIN_ID FROM DB.DBA.MULTI_JOIN_TABLE mt JOIN DB.DBA.TEST_TABLE t ON mt.TEST_ID = t.ID JOIN DB.DBA.USER_TABLE u ON mt.USER_ID = u.USER_ID WHERE u.USERNAME = 'User1' AND t.NAME = 'Test Name';
CREATE VIEW DB.DBA.TEST_VIEW AS SELECT ID, NAME FROM DB.DBA.TEST_TABLE WHERE ID > 0;
SELECT * FROM DB.DBA.TEST_VIEW;
CREATE TABLE DB.DBA.ERROR_TEST_TABLE (COL1 INT, COL2 INT UNIQUE);
INSERT INTO DB.DBA.ERROR_TEST_TABLE (COL1, COL2) VALUES (1, 1);
INSERT INTO DB.DBA.ERROR_TEST_TABLE (COL1, COL2) VALUES (2, 1);