SELECT locate(sub_string, main_string) AS position FROM test_strings WHERE id = 1;
SELECT locate(sub_string, main_string) AS position FROM test_strings WHERE id = 2;
SELECT locate(sub_string, main_string) AS position FROM test_strings WHERE id = 3;
SELECT locate(sub_string, main_string) AS position FROM test_strings WHERE id = 4;
SELECT locate(sub_string, main_string) AS position FROM test_strings WHERE id = 5;
SELECT locate(sub_string, main_string) FROM (SELECT main_string, sub_string FROM test_strings WHERE id IN (1, 2));
SELECT a.id, locate(b.sub_string, a.main_string) AS position FROM test_strings a JOIN test_strings b ON a.id <> b.id;
SELECT locate('string', 'string locate string test string') AS position;
