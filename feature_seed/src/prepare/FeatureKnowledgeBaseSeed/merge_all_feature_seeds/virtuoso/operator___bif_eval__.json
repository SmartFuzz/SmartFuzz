CREATE TABLE test_table1 (id INT PRIMARY KEY, value VARCHAR(100));
CREATE TABLE test_table2 (id INT PRIMARY KEY, test_table1_id INT, FOREIGN KEY (test_table1_id) REFERENCES test_table1(id));
INSERT INTO test_table1 (id, value) VALUES (1, 'test1');
INSERT INTO test_table1 (id, value) VALUES (2, 'test2');
INSERT INTO test_table2 (id, test_table1_id) VALUES (1, 1);
INSERT INTO test_table2 (id, test_table1_id) VALUES (2, 2);
SELECT * FROM test_table1 WHERE id IN (SELECT test_table1_id FROM test_table2);
SELECT * FROM test_table1 WHERE value LIKE 'test%';
SELECT tt1.value, (SELECT COUNT(*) FROM test_table2 WHERE test_table1_id = tt1.id) AS related_count FROM test_table1 AS tt1;
SELECT tt1.value, tt2.id FROM test_table1 tt1 JOIN test_table2 tt2 ON tt1.id = tt2.test_table1_id WHERE tt1.value = 'test1';
SELECT * FROM (SELECT id, value FROM test_table1) AS subquery WHERE value = 'test1';
SELECT tt1.value FROM test_table1 tt1 WHERE EXISTS (SELECT 1 FROM test_table2 tt2 WHERE tt2.test_table1_id = tt1.id);
CREATE OR REPLACE VIEW test_view AS SELECT value FROM test_table1 WHERE id > 1;
SELECT * FROM test_view;
SELECT * FROM (SELECT tt1.id, tt1.value FROM test_table1 tt1 LEFT JOIN test_table2 tt2 ON tt1.id = tt2.test_table1_id) AS complex_query WHERE tt2.id IS NULL;