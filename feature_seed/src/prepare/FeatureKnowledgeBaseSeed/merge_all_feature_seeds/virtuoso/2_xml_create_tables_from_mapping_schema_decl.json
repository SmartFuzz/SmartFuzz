CREATE TABLE "Demo"."demo"."Categories" ("CategoryID" INTEGER PRIMARY KEY, "Description" VARCHAR);
CREATE TABLE "Demo"."demo"."Products" ("ProductID" INTEGER PRIMARY KEY, "ProductName" VARCHAR, "CategoryID" INTEGER);
INSERT INTO "Demo"."demo"."Categories" ("CategoryID", "Description") VALUES (1, 'Electronics');
INSERT INTO "Demo"."demo"."Categories" ("CategoryID", "Description") VALUES (2, 'Books');
INSERT INTO "Demo"."demo"."Products" ("ProductID", "ProductName", "CategoryID") VALUES (1, 'Smartphone', 1);
INSERT INTO "Demo"."demo"."Products" ("ProductID", "ProductName", "CategoryID") VALUES (2, 'Laptop', 1);
SELECT * FROM (SELECT "ProductName", "CategoryID" FROM "Demo"."demo"."Products") AS subquery WHERE "CategoryID" = 1;
SELECT "ProductName" FROM "Demo"."demo"."Products" WHERE "CategoryID" = (SELECT "CategoryID" FROM "Demo"."demo"."Categories" WHERE "Description" = 'Electronics');
SELECT COUNT(*) FROM "Demo"."demo"."Products" WHERE "CategoryID" IS NULL;
WITH TempCategories AS (SELECT * FROM "Demo"."demo"."Categories" WHERE "Description" IS NOT NULL) SELECT * FROM TempCategories;
ALTER TABLE "Demo"."demo"."Products" ADD CONSTRAINT "FK_CategoryID" FOREIGN KEY ("CategoryID") REFERENCES "Demo"."demo"."Categories" ("CategoryID");
SELECT "Description" FROM "Demo"."demo"."Categories" WHERE "CategoryID" = (SELECT "CategoryID" FROM "Demo"."demo"."Products" WHERE "ProductName" = 'Smartphone') AND sameTerm("Description", 'Electronics');
DROP TABLE "Demo"."demo"."Products";
SELECT * FROM (SELECT "Description" FROM "Demo"."demo"."Categories") AS categories WHERE sameTerm("Description", 'Electronics') OR "CategoryID" IS NULL;
_result := xml_create_tables_from_mapping_schema_decl('http://localhost.localdomain/xmlrepository', 'catmp.xsd', 'UTF-8', 'x-any');
SELECT SUM(CASE WHEN "CategoryID" IS NULL THEN 0 ELSE 1 END) as NotNullCount FROM "Demo"."demo"."Products" HAVING COUNT(*) > 0;
SELECT "ProductName" FROM "Demo"."demo"."Products" AS p WHERE EXISTS (SELECT 1 FROM "Demo"."demo"."Categories" AS c WHERE c."CategoryID" = p."CategoryID" AND sameTerm(c."Description", 'Electronics'));