DELETE FROM business_entities WHERE id = (SELECT MIN(id) FROM business_entities WHERE status IS NULL);
DELETE FROM business_entities WHERE name = (SELECT name FROM (SELECT name FROM business_entities WHERE status IS NOT NULL ORDER BY registered_at DESC LIMIT 1) AS subquery);
DELETE FROM business_entities WHERE id IN (SELECT id FROM (SELECT id FROM business_entities WHERE status = 1 GROUP BY id HAVING COUNT(*) > 1) AS duplicate_entities);
