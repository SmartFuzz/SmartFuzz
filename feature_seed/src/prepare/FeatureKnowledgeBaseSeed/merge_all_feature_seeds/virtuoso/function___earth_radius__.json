CREATE TABLE geolocation (id INT, name VARCHAR(100), location GEOMETRY);
INSERT INTO geolocation (id, name, location) VALUES (1, 'Location A', POINT(1.0 1.0));
INSERT INTO geolocation (id, name, location) VALUES (2, 'Location B', POINT(2.0 2.0));
INSERT INTO geolocation (id, name, location) VALUES (3, 'Location C', POINT(3.0 3.0));
SELECT earth_radius();
SELECT earth_radius() AS average_radius FROM geolocation WHERE id = 1;
SELECT earth_radius() AS average_radius FROM geolocation WHERE id IN (SELECT id FROM geolocation WHERE name LIKE 'Location%');
SELECT AVG(earth_radius()) AS avg_radius FROM (SELECT earth_radius() AS earth_radius FROM geolocation) AS subquery;
SELECT g.id, g.name, earth_radius() AS radius FROM geolocation g JOIN (SELECT earth_radius() AS average FROM geolocation) AS avg_table ON g.id = avg_table.average;
SELECT COALESCE(earth_radius(), 0) AS radius FROM geolocation WHERE id IS NOT NULL;
SELECT earth_radius() + 100 AS adjusted_radius FROM geolocation WHERE location IS NOT NULL LIMIT 1;