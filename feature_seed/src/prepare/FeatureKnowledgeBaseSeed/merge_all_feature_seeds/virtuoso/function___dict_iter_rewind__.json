CREATE DICTIONARY dict_large_key_value (key STRING, value INTEGER, size INTEGER);
DECLARE dict, dkey, dvalue ANY;
dict := dict_new(100);
dict_put(dict, 'item1', 10);
dict_put(dict, 'item2', 20);
dict_put(dict, 'item3', 30);
dict_iter_rewind(dict);
WHILE (dict_iter_next(dict, dkey, dvalue));
dbg_obj_princ('Key: ' || dkey || ', Value: ' || dvalue);
dict := dict_new(0);
dict_iter_rewind(dict);
IF NOT dict_iter_next(dict, dkey, dvalue) THEN;
dbg_obj_princ('No items in empty dictionary');
END IF;
dict := dict_new(5);
dict_put(dict, 'a', 1);
dict_put(dict, 'b', 2);
dict_put(dict, 'c', 3);
dict_put(dict, 'd', 4);
dict_put(dict, 'e', 5);
dict_iter_rewind(dict);
WHILE (dict_iter_next(dict, dkey, dvalue));
SELECT CONCAT('Key: ', dkey, ', Value: ', dvalue);
dict := dict_new(3);
dict_put(dict, 'alpha', 100);
dict_put(dict, 'beta', 200);
dict_put(dict, 'gamma', 300);
dict_iter_rewind(dict);
CREATE FUNCTION dict_iterator_test();
{;
DECLARE dict, dkey, dvalue ANY;
dict := dict_new(10);
dict_put(dict, 'x', 1);
dict_put(dict, 'y', 2);
dict_put(dict, 'z', 3);
dict_iter_rewind(dict);
WHILE (dict_iter_next(dict, dkey, dvalue));
DBG_OBJ_PRINC('Key is ' || dkey || ', corresponding value is ' || dvalue);
};
CALL dict_iterator_test();