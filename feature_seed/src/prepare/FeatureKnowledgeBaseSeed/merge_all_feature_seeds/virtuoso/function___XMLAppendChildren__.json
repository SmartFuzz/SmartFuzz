CREATE TABLE xml_test (id INT, xml_content XML);
INSERT INTO xml_test (id, xml_content) VALUES (1, xtree_doc('<a><b>Hello</b></a>'));
CREATE PROCEDURE XMLAppendChildren_test_1() { DECLARE DESCRIPTION VARCHAR(40);
DECLARE ENTITY, ent ANY;
result_names(DESCRIPTION, ENTITY);
result('EXAMPLE1', 'Appending new child elements');
ent := xpath_eval('//b', (SELECT xml_content FROM xml_test WHERE id = 1));
result('The document to modify', xpath_eval('/', ent));
result('The node to be extended', ent);
XMLAppendChildren(ent, xtree_doc('<comma/>'), ' world', xtree_doc('<excl/>'));
result('The changed document', xpath_eval('/', ent));
result('The original entity is updated', ent);
};
CALL XMLAppendChildren_test_1();
CREATE PROCEDURE XMLAppendChildren_test_2() { DECLARE DESCRIPTION VARCHAR(40);
DECLARE ENTITY, ent ANY;
result_names(DESCRIPTION, ENTITY);
result('EXAMPLE2', 'Appending that causes text node concatenation');
ent := xpath_eval('//b', (SELECT xml_content FROM xml_test WHERE id = 1));
result('The document to modify', xpath_eval('/', ent));
result('The node to be extended', ent);
XMLAppendChildren(ent, ', ', ' world', '!');
result('The changed document', xpath_eval('/', ent));
result('The original entity is updated', ent);
};
CALL XMLAppendChildren_test_2();
CREATE PROCEDURE XMLAppendChildren_test_3() { DECLARE DESCRIPTION VARCHAR(40);
DECLARE ENTITY, ent ANY;
result_names(DESCRIPTION, ENTITY);
result('EXAMPLE3', 'Attempting to append invalid entities');
ent := xpath_eval('//b', (SELECT xml_content FROM xml_test WHERE id = 1));
result('The document to modify', xpath_eval('/', ent));
result('The node to be extended', ent);
XMLAppendChildren(ent, 'Not an XML node', 'Also not XML', 'Another invalid');
result('The changed document', xpath_eval('/', ent));
result('The original entity is updated', ent);
};
CALL XMLAppendChildren_test_3();
