CREATE PROCEDURE XMLAppendChildren_test_5() { DECLARE DESCRIPTION VARCHAR(40);
DECLARE ENTITY, ent ANY;
result_names(DESCRIPTION, ENTITY);
result('EXAMPLE5', 'Testing with invalid source types');
ent := xpath_eval('//a', (SELECT xml_content FROM xml_test WHERE id = 1));
result('The document to modify', xpath_eval('/', ent));
result('The node to be extended', ent);
XMLAppendChildren(ent, xtree_doc('<newchild/>'));
result('The changed document', xpath_eval('/', ent));
result('The original entity is updated', ent);
};
CALL XMLAppendChildren_test_5();