CREATE TABLE employees (id INT, name VARCHAR(100), department VARCHAR(100));
CREATE TABLE departments (id INT, name VARCHAR(100));
INSERT INTO departments (id, name) VALUES (1, 'HR'), (2, 'Engineering'), (3, 'Sales');
INSERT INTO employees (id, name, department) VALUES (1, 'Alice', 'HR'), (2, 'Bob', NULL), (3, 'Charlie', 'Engineering'), (4, 'David', 'Sales');
SELECT XMLFOREST(name AS 'employee_name', department AS 'department_name') FROM employees WHERE id = 1;
SELECT XMLFOREST(name AS 'employee_name', department AS 'department_name') FROM employees WHERE id = 2;
SELECT XMLFOREST(name AS 'employee_name', department AS 'department_name') FROM employees WHERE department = 'Engineering';
SELECT XMLFOREST(name AS 'employee_name', (SELECT name FROM departments WHERE id = employees.department) AS 'department_name') FROM employees;
SELECT XMLFOREST(name AS 'employee_name', (SELECT name FROM departments d WHERE d.id = e.department) AS 'department_name') FROM employees e;
SELECT XMLFOREST((SELECT name FROM employees WHERE id = 1) AS 'employee_name', (SELECT name FROM departments WHERE id = 1) AS 'department_name') FROM dual;
SELECT XMLFOREST((SELECT name FROM employees WHERE department IS NOT NULL) AS 'employee_name', (SELECT COUNT(*) FROM employees) AS 'total_employees') FROM dual;
SELECT XMLFOREST(NULL AS 'empty_element', (SELECT name FROM employees WHERE id = 3) AS 'employee_name') FROM dual;
SELECT XMLFOREST(name AS 'employee_name', NULL AS 'no_department') FROM employees WHERE id = 4;
SELECT XMLFOREST(NULL AS 'nonexistent', (SELECT name FROM departments WHERE id = 10) AS 'department_name') FROM dual;