CREATE TABLE parent (id INT PRIMARY KEY, name VARCHAR(50));
CREATE TABLE child (id INT PRIMARY KEY, parent_id INT, CONSTRAINT fk_parent FOREIGN KEY (parent_id) REFERENCES parent(id));
ALTER TABLE child ADD CONSTRAINT unique_child_name UNIQUE (name);
INSERT INTO parent (id, name) VALUES (1, 'Parent 1');
INSERT INTO child (id, parent_id, name) VALUES (1, 1, 'Child 1'), (2, 1, 'Child 2');
SELECT * FROM child WHERE parent_id IN (SELECT id FROM parent WHERE name LIKE 'Parent%');
ALTER SESSION SET fk_check_input_values = 0;
SELECT fk_check_input_values();
INSERT INTO child (id, parent_id, name) VALUES (3, 2, 'Child 3');
ALTER SESSION SET fk_check_input_values = 1;
SELECT * FROM parent WHERE id IN (SELECT DISTINCT parent_id FROM child);
DELETE FROM child WHERE parent_id = 1 AND name = 'Child 1';
INSERT INTO child (id, parent_id, name) VALUES (4, 1, 'Child 4');
SELECT child.id, parent.name FROM child JOIN parent ON child.parent_id = parent.id WHERE parent.name = 'Parent 1';
CREATE TABLE temp_data (id INT PRIMARY KEY, some_value VARCHAR(100));
INSERT INTO temp_data (id, some_value) SELECT child.id, child.name FROM child;
ALTER TABLE temp_data ADD CONSTRAINT fk_temp_parent FOREIGN KEY (id) REFERENCES parent(id);
ALTER SESSION SET fk_check_input_values = 0;
INSERT INTO temp_data (id, some_value) VALUES (5, 'New Value');
ALTER SESSION SET fk_check_input_values = 1;
INSERT INTO temp_data (id, some_value) VALUES (6, 'Another Value');
SELECT * FROM child WHERE id > (SELECT MAX(id) FROM temp_data);