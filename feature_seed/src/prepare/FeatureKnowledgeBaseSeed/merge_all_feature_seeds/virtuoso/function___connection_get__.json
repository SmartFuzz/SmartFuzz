CREATE TABLE test_table (id integer, value varchar(255));
INSERT INTO test_table (id, value) VALUES (1, 'test_data');
SELECT connection_set('var_demo', 'test_data_1');
SELECT connection_get('var_demo');
SELECT connection_set('var_demo', 'test_data_2');
SELECT connection_get('var_demo') AS retrieved_data;
INSERT INTO test_table (id, value) VALUES (2, connection_get('var_demo'));
CREATE TABLE another_table (id integer, test_id integer, description varchar(255));
INSERT INTO another_table (id, test_id, description) VALUES (1, 1, 'description_1');
INSERT INTO another_table (id, test_id, description) VALUES (2, 1, 'description_2');
SELECT a.id, a.description FROM another_table a INNER JOIN test_table t ON a.test_id = t.id WHERE t.value = connection_get('var_demo');
SELECT connection_get('var_demo') FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);
SELECT connection_set('another_var', (SELECT value FROM test_table WHERE id = 1));
SELECT connection_get('another_var') AS new_variable;
SELECT connection_set('complex_structure', (SELECT value FROM test_table WHERE id IN (SELECT MAX(id) FROM test_table)));
SELECT connection_get('complex_structure');
SELECT connection_set('nested_var', (SELECT COUNT(*) FROM another_table WHERE test_id = (SELECT MAX(id) FROM test_table)));
SELECT connection_get('nested_var');