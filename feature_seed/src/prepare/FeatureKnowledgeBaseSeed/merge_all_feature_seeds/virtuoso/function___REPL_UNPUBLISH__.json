CREATE TABLE publications (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO publications (id, name) VALUES (1, 'demo-publication');
CREATE TABLE subscribers (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO subscribers (id, name) VALUES (1, 'subscriber1');
INSERT INTO subscribers (id, name) VALUES (2, 'subscriber2');
CREATE TABLE replication_messages (id INT PRIMARY KEY, publication_id INT, subscriber_id INT, message TEXT);
INSERT INTO replication_messages (id, publication_id, subscriber_id, message) VALUES (1, 1, 1, 'Message for subscriber 1');
INSERT INTO replication_messages (id, publication_id, subscriber_id, message) VALUES (2, 1, 2, 'Message for subscriber 2');
SELECT * FROM publications WHERE id = (SELECT MAX(id) FROM publications);
DELETE FROM replication_messages WHERE id IN (SELECT id FROM replication_messages WHERE publication_id = (SELECT id FROM publications WHERE name = 'demo-publication'));
SELECT * FROM replication_messages WHERE subscriber_id IN (SELECT id FROM subscribers WHERE name LIKE 'subscriber%');
DB.DBA.REPL_UNPUBLISH('demo-publication');
SELECT COUNT(*) FROM publications WHERE name = 'demo-publication' AND id NOT IN (SELECT publication_id FROM replication_messages);
CREATE TABLE grants (id INT PRIMARY KEY, publication_id INT, grantee VARCHAR(255));
INSERT INTO grants (id, publication_id, grantee) VALUES (1, 1, 'user1');
DELETE FROM grants WHERE publication_id = (SELECT id FROM publications WHERE name = 'demo-publication');
SELECT * FROM grants WHERE publication_id = (SELECT id FROM publications WHERE name = 'demo-publication');
DB.DBA.REPL_UNPUBLISH('nonexistent-publication');
DB.DBA.REPL_UNPUBLISH(NULL);
DB.DBA.REPL_UNPUBLISH('');
CREATE TABLE empty_results (id INT PRIMARY KEY, info VARCHAR(255));
INSERT INTO empty_results (id, info) VALUES (1, 'No results to process');
SELECT * FROM empty_results WHERE info NOT IN (SELECT info FROM empty_results WHERE id = 1);