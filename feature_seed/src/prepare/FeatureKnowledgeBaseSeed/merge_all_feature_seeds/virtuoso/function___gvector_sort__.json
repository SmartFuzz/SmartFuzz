CREATE TABLE test_array (id INT, group_key INT, value INT);
INSERT INTO test_array VALUES (1, 1, 5), (2, 1, 3), (3, 1, 8), (4, 2, 2), (5, 2, 7), (6, 2, 6);
SELECT gvector_sort(array_agg(value), 2, 0, TRUE) FROM test_array GROUP BY group_key;
CREATE TABLE test_dict (key INT PRIMARY KEY, value INT);
INSERT INTO test_dict VALUES (1, 10), (2, 20), (3, 15), (4, 5);
SELECT gvector_sort(array_agg((key, value)), 2, 0, FALSE) FROM test_dict;
CREATE TABLE test_lines (line_number INT, line_value INT);
INSERT INTO test_lines VALUES (1, 10), (2, 5), (3, 20), (4, 15);
SELECT gvector_sort(array_agg(line_value), 1, 0, TRUE) FROM test_lines;
CREATE TABLE test_params (param_name VARCHAR(50), param_value INT);
INSERT INTO test_params VALUES ('alpha', 2), ('beta', 1), ('gamma', 3);
SELECT gvector_sort(array_agg(param_value), 1, 0, FALSE) FROM test_params;
CREATE TABLE test_complex (group_id INT, item_id INT, value INT);
INSERT INTO test_complex VALUES (1, 1, 10), (1, 2, 5), (2, 1, 15), (2, 2, 20);
SELECT gvector_sort(array_agg(value), 2, 0, TRUE) FROM test_complex GROUP BY group_id;
CREATE TABLE test_empty (id INT, group_key INT, value INT);
SELECT gvector_sort(array_agg(value), 2, 0, TRUE) FROM test_empty GROUP BY group_key;
CREATE TABLE test_single_group (group_key INT, value INT);
INSERT INTO test_single_group VALUES (1, 10);
SELECT gvector_sort(array_agg(value), 1, 0, TRUE) FROM test_single_group GROUP BY group_key;