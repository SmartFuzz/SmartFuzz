CREATE TABLE t_books (book_id int NOT NULL, book_title varchar(255) NOT NULL, book_xml long varchar);
INSERT INTO t_books (book_id, book_title) VALUES (1, 'XML Basics');
INSERT INTO t_books (book_id, book_title) VALUES (2, 'Advanced XML');
UPDATE t_books SET book_xml = '<library><book><title>XML Basics</title><author>John Doe</author></book></library>' WHERE book_id = 1;
UPDATE t_books SET book_xml = '<library><book><title>Advanced XML</title><author>Jane Smith</author></book></library>' WHERE book_id = 2;
SELECT xpath_eval('//author', xml_tree_doc(book_xml), 1) AS author_name FROM t_books WHERE book_id = 1;
SELECT xpath_eval('//author', xml_tree_doc(book_xml), 0) AS authors FROM t_books WHERE book_id = 1;
SELECT xpath_eval('//author', xml_tree_doc(book_xml), 1) AS author_name FROM t_books WHERE book_id = 2;
SELECT xpath_eval('//book/title', xml_tree_doc(book_xml), 0) AS titles FROM t_books;
CREATE TABLE t_articles (article_id int NOT NULL, article_title varchar(255) NOT NULL, article_xml long varchar);
INSERT INTO t_articles (article_id, article_title) VALUES (1, 'The Art of XML');
INSERT INTO t_articles (article_id, article_title) VALUES (2, 'Understanding XPath');
UPDATE t_articles SET article_xml = '<articles><article><title>The Art of XML</title><author>John Doe</author><content>...</content></article></articles>' WHERE article_id = 1;
UPDATE t_articles SET article_xml = '<articles><article><title>Understanding XPath</title><author>Jane Smith</author><content>...</content></article></articles>' WHERE article_id = 2;
SELECT xpath_eval('//article/author', xml_tree_doc(article_xml), 0) AS authors FROM t_articles;
SELECT xpath_eval('//title', xml_tree_doc(article_xml), 1) AS article_title FROM t_articles WHERE article_id = 1;
SELECT xpath_eval('//article/title', xml_tree_doc(article_xml), 0) AS all_titles FROM t_articles;
CREATE TABLE t_users (user_id int NOT NULL, user_data long varchar);
INSERT INTO t_users (user_id, user_data) VALUES (1, '<user><name>John Doe</name><email>john@example.com</email></user>');
INSERT INTO t_users (user_id, user_data) VALUES (2, '<user><name>Jane Smith</name><email>jane@example.com</email></user>');
SELECT xpath_eval('//email', xml_tree_doc(user_data), 1) AS email FROM t_users WHERE user_id = 1;
SELECT xpath_eval('//name', xml_tree_doc(user_data), 1) AS name FROM t_users WHERE user_id = 2;
SELECT xpath_eval('//name', xml_tree_doc(user_data), 0) AS all_names FROM t_users;
SELECT xpath_eval('//user/name', xml_tree_doc('<users><user><name>John Doe</name></user><user><name>Jane Smith</name></user></users>'), 0) AS all_user_names;