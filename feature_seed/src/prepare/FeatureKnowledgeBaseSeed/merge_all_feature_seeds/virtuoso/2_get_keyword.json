CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(50), num_value INT);
INSERT INTO test_table VALUES (1, 'first', 10), (2, 'second', 20), (3, 'third', NULL), (4, '', 0);
SELECT id, get_keyword(value, vector('first', 'second', 'third', 'fourth'), 'NOT FOUND!') || ' - ' || num_value AS result FROM test_table WHERE num_value IS NOT NULL;
SELECT id, get_keyword(value, vector('nonexistent', 'second', 'third'), 'DEFAULT') || ' - COUNT: ' || COUNT(id) FROM test_table GROUP BY value HAVING num_value > 5;
SELECT id, (SELECT COUNT(*) FROM test_table tt2 WHERE tt2.num_value = get_keyword(value, vector('first', 'second', 'third'), NULL)) AS occurrences FROM test_table;
CREATE TABLE temp_table (temp_id INT, temp_value VARCHAR(50));
INSERT INTO temp_table SELECT id, get_keyword(value, vector('first', 'second', 'third', NULL), 'EMPTY') || '-temp' FROM test_table;
SELECT tt.temp_id, tt.temp_value, (SELECT MAX(num_value) FROM test_table WHERE num_value IS NOT NULL) || ' - found' FROM temp_table tt WHERE temp_value IS NOT NULL;
SELECT get_keyword(value, vector(1, 2, 3, NULL), NULL) AS result FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);
UPDATE test_table SET value = get_keyword(value, vector('current', 'next', 'last'), 'Unknown') || ' updated' WHERE value IS NOT NULL;