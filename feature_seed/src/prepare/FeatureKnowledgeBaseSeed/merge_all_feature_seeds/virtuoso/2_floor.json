CREATE TABLE test_fuzz (id INT PRIMARY KEY, value DECIMAL(10, 4), term1 VARCHAR(255), term2 VARCHAR(255));
INSERT INTO test_fuzz (id, value, term1, term2) VALUES (1, -0.5135, 'example1', 'example2'), (2, 0.5135, 'example3', 'example1'), (3, 123.4567, 'example2', NULL);
SELECT floor(value) AS floored_value, sameTerm(term1, term2) AS term_identity FROM test_fuzz WHERE value IS NOT NULL;
SELECT id, value, floor(value) + 1 AS adjusted_value FROM test_fuzz WHERE value > 0 HAVING adjusted_value > 1;
SELECT DISTINCT id, floor(value) FROM test_fuzz WHERE sameTerm(term1, term2) OR value IS NULL ORDER BY floor(value);
SELECT id, floor(floor(value) * 2) AS double_floored FROM test_fuzz WHERE value < 0 UNION ALL SELECT id, NULL AS double_floored FROM test_fuzz WHERE term2 IS NULL;
CREATE TABLE additional_fuzz (id INT PRIMARY KEY, associated_id INT, FOREIGN KEY (associated_id) REFERENCES test_fuzz(id));
INSERT INTO additional_fuzz (id, associated_id) VALUES (1, 1), (2, 2), (3, NULL);
SELECT a.id, floor(b.value) AS floored_value FROM additional_fuzz a JOIN test_fuzz b ON a.associated_id = b.id WHERE floor(b.value) < 0;
SELECT id, sameTerm(term1, term2) AS is_identical, floor(value) FROM test_fuzz GROUP BY id, is_identical HAVING is_identical = TRUE;
SELECT id, JSON_ARRAYAGG(floor(value)) AS floored_values FROM test_fuzz GROUP BY id;