CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(255), options JSON);
INSERT INTO users (id, username, options) VALUES (1, 'user1', '{"theme": "dark", "notifications": "enabled"}');
INSERT INTO users (id, username, options) VALUES (2, 'user2', '{"theme": "light", "notifications": "disabled"}');
SELECT options FROM users WHERE id = 1;
SELECT options FROM users WHERE username = 'user2';
SELECT u.options FROM users u INNER JOIN (SELECT id FROM users WHERE username = 'user1') AS subquery ON u.id = subquery.id;
SELECT JSON_EXTRACT(options, '$.theme') FROM users WHERE id = (SELECT MAX(id) FROM users);
SELECT u.id, u.username, JSON_EXTRACT(u.options, '$.notifications') FROM users u WHERE JSON_EXTRACT(u.options, '$.theme') = 'dark';
UPDATE users SET options = JSON_SET(options, '$.notifications', 'disabled') WHERE id = 1;
SELECT options FROM users WHERE id IN (SELECT id FROM users WHERE options IS NOT NULL);
SELECT options FROM users WHERE id = (SELECT id FROM users ORDER BY id ASC LIMIT 1);