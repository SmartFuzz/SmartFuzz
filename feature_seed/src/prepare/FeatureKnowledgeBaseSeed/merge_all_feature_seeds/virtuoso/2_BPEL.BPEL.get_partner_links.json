SELECT BPEL.BPEL.get_partner_links((SELECT COUNT(*) * 2 FROM partner_links));
SELECT BPEL.BPEL.get_partner_links(NULLIF((SELECT COUNT(*) * 3 FROM partner_links WHERE link_type = 'services:LoanService'), 0));
SELECT BPEL.BPEL.get_partner_links((SELECT MAX(link_id) + 1 FROM partner_links));
SELECT BPEL.BPEL.get_partner_links((SELECT SUM(link_id) FROM partner_links));
SELECT BPEL.BPEL.get_partner_links((SELECT COUNT(*) FROM partner_links) - (SELECT COUNT(*) * 0 FROM partner_links));
SELECT BPEL.BPEL.get_partner_links(MAX(link_id) * (SELECT COUNT(*) FROM partner_links)) FROM partner_links GROUP BY link_type HAVING COUNT(link_id) > 1;
SELECT BPEL.BPEL.get_partner_links((SELECT link_id FROM partner_links WHERE link_name = 'client') * 3);
SELECT BPEL.BPEL.get_partner_links((SELECT AVG(link_id) FROM partner_links) + (SELECT COUNT(link_id) FROM partner_links));