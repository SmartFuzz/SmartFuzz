CREATE TABLE partner_links (link_id INT PRIMARY KEY, link_name VARCHAR(50), link_type VARCHAR(50), role VARCHAR(50));
INSERT INTO partner_links (link_id, link_name, link_type, role) VALUES (1, 'client', 'tns:LoanFlow', 'LoanFlowRequester');
INSERT INTO partner_links (link_id, link_name, link_type, role) VALUES (2, 'creditRatingService', 'services:CreditRatingService', 'CreditRatingServiceProvider');
INSERT INTO partner_links (link_id, link_name, link_type, role) VALUES (3, 'UnitedLoanService', 'services:LoanService', 'LoanServiceProvider');
