CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'test1');
INSERT INTO test_table (id, value) VALUES (2, 'test2');
INSERT INTO test_table (id, value) VALUES (3, 'test3');
CREATE TABLE another_table (ref_id INT, description VARCHAR(255));
INSERT INTO another_table (ref_id, description) VALUES (1, 'description1');
INSERT INTO another_table (ref_id, description) VALUES (2, 'description2');
INSERT INTO another_table (ref_id, description) VALUES (3, 'description3');
SELECT string_to_file('stat.dv', serialize(stat_export()), -2) FROM (SELECT * FROM test_table INNER JOIN another_table ON test_table.id = another_table.ref_id) AS joined;
CREATE TABLE empty_table (id INT);
SELECT string_to_file('stat_empty.dv', serialize(stat_export()), -2) FROM empty_table;
CREATE TABLE large_table AS SELECT ROW_NUMBER() OVER () AS id, 'test' AS value FROM tbl_generator(1000);
SELECT string_to_file('stat_large.dv', serialize(stat_export()), -2) FROM large_table;
SELECT string_to_file('stat_join.dv', serialize(stat_export()), -2) FROM (SELECT COUNT(*) AS total, MAX(value) AS max_value FROM test_table GROUP BY value HAVING COUNT(*) > 1) AS aggregated;
SELECT string_to_file('stat_nested.dv', serialize(stat_export()), -2) FROM (SELECT id, (SELECT COUNT(*) FROM another_table WHERE ref_id = test_table.id) AS ref_count FROM test_table) AS nested_counts;