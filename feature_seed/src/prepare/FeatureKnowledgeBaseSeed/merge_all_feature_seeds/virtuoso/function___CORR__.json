CREATE TABLE test_data (id INT PRIMARY KEY, value1 FLOAT, value2 FLOAT, group_id INT);
INSERT INTO test_data (id, value1, value2, group_id) VALUES (1, 10.0, 20.0, 1);
INSERT INTO test_data (id, value1, value2, group_id) VALUES (2, 15.0, 25.0, 1);
INSERT INTO test_data (id, value1, value2, group_id) VALUES (3, 20.0, null, 1);
INSERT INTO test_data (id, value1, value2, group_id) VALUES (4, null, 30.0, 1);
INSERT INTO test_data (id, value1, value2, group_id) VALUES (5, 25.0, 35.0, 1);
INSERT INTO test_data (id, value1, value2, group_id) VALUES (6, 30.0, null, 2);
SELECT CORR(value1, value2) FROM test_data WHERE group_id = 1;
SELECT group_id, CORR(value1, value2) FROM test_data GROUP BY group_id;
SELECT AVG(value1) AS avg1, AVG(value2) AS avg2, CORR(value1, value2) AS correlation FROM (SELECT value1, value2 FROM test_data WHERE value1 IS NOT NULL AND value2 IS NOT NULL) AS filtered_data;
CREATE TABLE another_table (id INT, test_id INT, value3 FLOAT);
INSERT INTO another_table (id, test_id, value3) VALUES (1, 1, 5.0);
INSERT INTO another_table (id, test_id, value3) VALUES (2, 2, 10.0);
SELECT CORR(td.value1, at.value3) FROM test_data td JOIN another_table at ON td.id = at.test_id WHERE td.value1 IS NOT NULL AND at.value3 IS NOT NULL;
SELECT CORR(sub.value1, sub.value2) FROM (SELECT value1, value2 FROM test_data WHERE group_id = 1) AS sub WHERE sub.value1 IS NOT NULL AND sub.value2 IS NOT NULL;
SELECT sub.group_id, CORR(sub.value1, sub.value2) FROM (SELECT value1, value2, group_id FROM test_data) AS sub WHERE sub.value1 IS NOT NULL AND sub.value2 IS NOT NULL GROUP BY sub.group_id;