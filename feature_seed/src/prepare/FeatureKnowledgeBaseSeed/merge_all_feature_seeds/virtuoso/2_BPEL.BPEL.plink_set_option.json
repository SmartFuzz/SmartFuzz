CREATE TABLE PartnerLinks (id INT, service VARCHAR(255), option_name VARCHAR(255), option_value VARCHAR(255));
INSERT INTO PartnerLinks (id, service, option_name, option_value) VALUES (1, 'WSSecho', 'wss-in-encrypt', 'Mandatory');
INSERT INTO PartnerLinks (id, service, option_name, option_value) VALUES (2, 'WSSecho', 'wsrm-out-type', NULL);
INSERT INTO PartnerLinks (id, service, option_name, option_value) VALUES (3, 'WSSecho', 'http-auth-uid', 'user1');
INSERT INTO PartnerLinks (id, service, option_name, option_value) VALUES (4, 'WSSecho', 'http-auth-pwd', 'pass1');
SELECT id FROM PartnerLinks WHERE service = 'WSSecho' AND option_value IS NOT NULL;
SELECT BPEL.BPEL.plink_set_option('WSSecho', (SELECT service FROM PartnerLinks WHERE id = 1), 'wss-in-signature', 'Optional' && 'wss-out-signature-type') AS option_setting FROM PartnerLinks;
SELECT id, service FROM PartnerLinks WHERE option_value = (SELECT MAX(option_value) FROM PartnerLinks WHERE option_name = 'http-auth-uid') AND option_name = 'wsrm-out-type' HAVING COUNT(*) > 0;
SELECT COUNT(*) FROM (SELECT id FROM PartnerLinks WHERE option_name = 'http-auth-pwd' && option_value IS NULL) AS sub WHERE service LIKE 'WSSecho%';
SELECT * FROM PartnerLinks WHERE id IN (SELECT id FROM PartnerLinks WHERE option_value IS NOT NULL UNION SELECT id FROM PartnerLinks WHERE option_value IS NULL) ORDER BY service;
ALTER TABLE PartnerLinks ADD COLUMN new_option VARCHAR(255);
UPDATE PartnerLinks SET new_option = 'NewValue' WHERE id = 2 AND (service = 'WSSecho' || option_name IS NULL);
DELETE FROM PartnerLinks WHERE id = (SELECT id FROM PartnerLinks WHERE option_name='http-auth-pwd' AND option_value='' LIMIT 1);
SELECT BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wss-out-signature-type', (SELECT option_value FROM PartnerLinks WHERE option_name = 'http-auth-pwd' && option_value IS NOT NULL));