CREATE TABLE properties_test (id INT, class_name VARCHAR(255), property_name VARCHAR(255), property_value VARCHAR(255));
INSERT INTO properties_test VALUES (1, 'java.lang.Math', 'PI', java_get_property('java.lang.Math', NULL, 'PI', 'D'));
INSERT INTO properties_test VALUES (2, 'java.util.TimeZone', 'Default', java_get_property('java.util.TimeZone', NULL, 'getDefault', 'Ljava/util/TimeZone;
'));
SELECT * FROM properties_test WHERE java_get_property('java.lang.Math', NULL, 'PI', 'D') > CAST('3' AS DECIMAL);
SELECT id, class_name, property_name FROM properties_test WHERE property_value IS NULL OR property_value = java_get_property('java.lang.Math', NULL, 'PI', 'D');
SELECT COUNT(*) FROM properties_test WHERE java_get_property('java.util.TimeZone', NULL, 'getDisplayName', 'Ljava/lang/String;
') > 'Greenwich Mean Time';
WITH timezones AS (SELECT java_get_property('java.util.TimeZone', tz, 'getDisplayName', 'Ljava/lang/String;
') as display_name FROM (SELECT java_call_method('java.util.TimeZone', NULL, 'getDefault', 'Ljava/util/TimeZone;
') AS tz) AS t) SELECT display_name FROM timezones WHERE display_name IS NOT NULL ORDER BY display_name;
CREATE TEMPORARY TABLE temp_properties AS (SELECT java_get_property('java.lang.Math', NULL, 'PI', 'D') AS pi_value, property_value FROM properties_test);
SELECT pi_value, property_value FROM temp_properties WHERE pi_value < java_get_property('java.lang.Math', NULL, 'E', 'D');
SELECT AVG(CAST(java_get_property('java.lang.Math', NULL, 'PI', 'D') AS DECIMAL)) AS average_pi FROM properties_test HAVING average_pi > 3;