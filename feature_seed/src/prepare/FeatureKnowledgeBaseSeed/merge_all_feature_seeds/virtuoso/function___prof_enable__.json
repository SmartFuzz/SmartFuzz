CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO test_table (id, name) VALUES (1, 'Test User');
SELECT * FROM test_table;
CREATE TABLE another_table (id INT PRIMARY KEY, test_id INT, description VARCHAR(255), FOREIGN KEY(test_id) REFERENCES test_table(id));
INSERT INTO another_table (id, test_id, description) VALUES (1, 1, 'Description for Test User');
SELECT a.id, b.description FROM test_table a JOIN another_table b ON a.id = b.test_id;
SELECT name FROM test_table WHERE id IN (SELECT test_id FROM another_table WHERE description LIKE '%Test%');
SELECT COUNT(*) FROM test_table WHERE EXISTS (SELECT * FROM another_table WHERE another_table.test_id = test_table.id);
CREATE FUNCTION test_function() RETURNS VOID AS $$ BEGIN PERFORM prof_enable(1);
END;
$$ LANGUAGE plpgsql;
CREATE PROCEDURE test_procedure() AS $$ BEGIN PERFORM prof_enable(0);
END;
$$ LANGUAGE plpgsql;
SELECT prof_enable(1);
SELECT prof_enable(0);
SELECT * FROM pg_read_file('virtprof.out');