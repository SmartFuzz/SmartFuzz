CREATE TABLE java_test (id INT PRIMARY KEY, classpath VARCHAR(255));
INSERT INTO java_test (id, classpath) VALUES (1, '/usr/local/virtuoso/classes:/usr/local/jakarta-tomcat-3.3.1/lib/tomcat.jar');
SELECT * FROM java_test WHERE id = (SELECT MAX(id) FROM java_test);
SELECT classpath FROM java_test WHERE id IN (SELECT id FROM java_test WHERE classpath LIKE '%/usr/local%');
CREATE TABLE java_vm_status (status_id INT PRIMARY KEY, status VARCHAR(100));
INSERT INTO java_vm_status (status_id, status) VALUES (1, 'Initialized');
INSERT INTO java_vm_status (status_id, status) VALUES (2, 'Attached');
SELECT status FROM java_vm_status WHERE status_id = (SELECT MAX(status_id) FROM java_vm_status WHERE status = 'Attached');
SELECT a.classpath, b.status FROM java_test a JOIN java_vm_status b ON a.id = b.status_id WHERE a.id < 3;
CREATE TABLE java_error_log (error_id INT PRIMARY KEY, error_message VARCHAR(255));
INSERT INTO java_error_log (error_id, error_message) VALUES (1, 'SQL error: Classpath supplied but Java VM already initialized.');
SELECT error_message FROM java_error_log WHERE error_id IN (SELECT error_id FROM java_error_log WHERE error_message LIKE '%SQL error%');
CALL java_vm_attach('/usr/local/virtuoso/classes:/usr/local/jakarta-tomcat-3.3.1/lib/tomcat.jar', vector('-Dtomcat.home=/usr/local/jakarta-tomcat-3.3.1', 0));
CALL java_vm_attach(NULL);