CREATE TABLE test_table (id INT PRIMARY KEY, value NVARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'Initial value');
 import_jar (null, vector ('java.lang.System'));
SELECT java_lang_System::getProperty('java.vm.name') AS vm_name FROM test_table WHERE id = 1;
SELECT * FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value LIKE 'Initial%');
SELECT * FROM test_table WHERE id > (SELECT MAX(id) FROM test_table WHERE value IS NOT NULL);
 unimport_jar (null, vector ('java.lang.System'));
 select java_lang_System::getProperty('java.vm.name');
SELECT EXISTS (SELECT 1 FROM test_table WHERE id = 1) AS exists_id;
SELECT value FROM test_table WHERE id = (SELECT MIN(id) FROM test_table) FOR UPDATE;
DROP TABLE test_table;