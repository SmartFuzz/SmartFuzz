CREATE TABLE rdf_test (id INT PRIMARY KEY, namespace VARCHAR(255), local_part VARCHAR(255), data VARCHAR(255));
INSERT INTO rdf_test VALUES (1, 'foaf', 'knows', 'some data'), (2, 'schema', 'name', NULL), (3, 'dc', 'title', 'another title');
SELECT id, __xml_ns_uname(namespace, local_part) AS fullname FROM rdf_test WHERE fullname SIMILAR TO 'http://xmlns.com/foaf/0.1/%';
SELECT id, COUNT(*) OVER(PARTITION BY __xml_ns_uname(namespace, local_part)) AS uname_count FROM rdf_test GROUP BY id, namespace, local_part HAVING uname_count > 1;
SELECT id FROM rdf_test WHERE local_part SIMILAR TO '' OR data IS NULL;
SELECT __xml_ns_uname(namespace, local_part) AS fullname FROM rdf_test WHERE fullname SIMILAR TO 'http://xmlns.com/foaf/0.[1-9].%';
SELECT id, __xml_ns_uname('dc', 'title') AS uname, CASE WHEN data IS NULL THEN 'No Data' ELSE data END AS data_status FROM rdf_test WHERE uname SIMILAR TO 'http://xmlns.com/.*';
SELECT id, __xml_ns_uname(namespace, local_part) FROM rdf_test ORDER BY __xml_ns_uname(namespace, local_part) SIMILAR TO 'http://dc/.*' DESC;
SELECT namespace, COUNT(*) AS count FROM rdf_test GROUP BY namespace HAVING COUNT(*) > (SELECT COUNT(*) FROM rdf_test WHERE local_part IS NOT NULL) / 2;
CREATE TEMPORARY TABLE temp_rdf AS SELECT __xml_ns_uname(namespace, local_part) AS temp_fullname FROM rdf_test WHERE namespace IS NOT NULL;
INSERT INTO temp_rdf SELECT __xml_ns_uname(namespace, local_part) FROM rdf_test WHERE local_part SIMILAR TO 'k.*';
SELECT __xml_ns_uname('schema', 'name') AS schema_name FROM rdf_test UNION SELECT __xml_ns_uname('dc', 'title') FROM rdf_test WHERE data IS NOT NULL;