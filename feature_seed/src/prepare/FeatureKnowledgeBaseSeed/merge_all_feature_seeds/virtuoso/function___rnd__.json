CREATE TABLE test_numbers (id INT IDENTITY PRIMARY KEY, random_value INT);
INSERT INTO test_numbers (random_value) VALUES (rnd(10));
INSERT INTO test_numbers (random_value) SELECT rnd(100) FROM test_numbers WHERE id < 5;
SELECT * FROM test_numbers WHERE random_value = rnd(10);
SELECT rnd(20) AS random_value FROM (SELECT id FROM test_numbers) AS subquery;
CREATE TABLE other_table (id INT PRIMARY KEY, value INT);
INSERT INTO other_table (id, value) VALUES (1, rnd(50)), (2, rnd(50));
SELECT nt.id, nt.random_value FROM test_numbers nt JOIN other_table ot ON nt.random_value = ot.value WHERE ot.id = rnd(2);
WITH random_values AS (SELECT rnd(15) AS rv FROM test_numbers) SELECT * FROM random_values WHERE rv < 10;
SELECT COUNT(*) FROM (SELECT rnd(5) AS random_val FROM test_numbers) AS random_subquery WHERE random_val >= 3;