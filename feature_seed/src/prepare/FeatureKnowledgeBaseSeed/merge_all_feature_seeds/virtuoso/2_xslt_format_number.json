CREATE TABLE test_data (id INT PRIMARY KEY, num_value FLOAT, geom GEOMETRY, str_value VARCHAR(255));
INSERT INTO test_data (id, num_value, geom, str_value) VALUES (1, NULL, ST_GeomFromText('POINT(1 1)'), '5351'), (2, 53.51, ST_GeomFromText('POINT(2 2)'), '53.51'), (3, 5.56, ST_GeomFromText('POINT(3 3)'), NULL);
SELECT xslt_format_number(num_value, '#,###') AS formatted_number FROM test_data WHERE bif:st_overlaps(geom, ST_GeomFromText('POLYGON((0 0, 4 0, 4 4, 0 4, 0 0))'));
SELECT id, xslt_format_number(num_value, '0000.####') as formatted_value FROM test_data WHERE bif:st_overlaps(geom, ST_GeomFromText('POINT(1 1')) OR (num_value IS NOT NULL AND num_value > 0);
SELECT xslt_format_number(SUM(num_value), '#.00') AS total_formatted FROM test_data GROUP BY str_value HAVING total_formatted IS NOT NULL;
SELECT id, xslt_format_number(AVG(num_value), '0.0') as avg_formatted FROM test_data WHERE str_value IS NOT NULL GROUP BY id ORDER BY avg_formatted DESC;
SELECT xslt_format_number(n.num_value, '#.0000') FROM (SELECT DISTINCT num_value FROM test_data WHERE num_value IS NOT NULL) n WHERE n.num_value < 1000 AND n.num_value > 0;
INSERT INTO test_data (id, num_value, geom, str_value) VALUES (4, 99999.99, ST_GeomFromText('POINT(4 4)'), '99999.99');
SELECT id, xslt_format_number(NULLIF(num_value, 0), ',000') AS zero_handling FROM test_data WHERE str_value IS NOT NULL;
SELECT xslt_format_number(MAX(num_value), '#,##0.##') AS max_value FROM test_data WHERE bif:st_overlaps(geom, ST_GeomFromText('POINT(2 2)'));