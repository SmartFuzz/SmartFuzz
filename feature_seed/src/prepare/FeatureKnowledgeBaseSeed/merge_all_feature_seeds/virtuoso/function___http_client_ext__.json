CREATE TABLE http_requests (id INT PRIMARY KEY, url VARCHAR(255), username VARCHAR(100), password VARCHAR(100));
INSERT INTO http_requests (id, url, username, password) VALUES (1, 'http://example.com/api', 'user1', 'pass1');
INSERT INTO http_requests (id, url, username, password) VALUES (2, 'https://secure.example.com/api', 'user2', 'pass2');
INSERT INTO http_requests (id, url, username, password) VALUES (3, 'http://example.com/api?param1=value1', NULL, NULL);
INSERT INTO http_requests (id, url, username, password) VALUES (4, 'https://example.com/api/endpoint/path?param2=value2', 'user3', '');
SELECT http_client_ext(url, username, password) AS response FROM http_requests WHERE id = 1;
SELECT http_client_ext(url, username, password) AS response FROM http_requests WHERE url LIKE 'https://%';
SELECT http_client_ext(url, username, password) AS response FROM http_requests WHERE username IS NOT NULL AND password IS NOT NULL;
SELECT http_client_ext(SELECT url FROM http_requests WHERE id = 2, (SELECT username FROM http_requests WHERE id = 2), (SELECT password FROM http_requests WHERE id = 2)) AS response;
SELECT COUNT(*) AS total_responses FROM http_requests WHERE http_client_ext(url, username, password) IS NOT NULL;
UPDATE http_requests SET url = 'http://example.com/api?param1=value1&param2=value2' WHERE id = 3;
DELETE FROM http_requests WHERE id = 4;
SELECT http_client_ext(url, NULL, NULL) AS response WITH RECURSIVE reqs AS (SELECT url FROM http_requests WHERE id = 1 UNION ALL SELECT url FROM http_requests WHERE url LIKE 'http://%') SELECT COUNT(*) FROM reqs;
CREATE TABLE http_responses (req_id INT, response_body VARCHAR(4000), FOREIGN KEY (req_id) REFERENCES http_requests(id));
INSERT INTO http_responses (req_id, response_body) SELECT id, http_client_ext(url, username, password) FROM http_requests WHERE username IS NOT NULL;
SELECT http_client_ext(url, username, password) FROM (SELECT url, username, password FROM http_requests WHERE id IN (SELECT id FROM http_requests WHERE url LIKE 'http://%')) AS filtered_requests;