CREATE TABLE http_requests (client_ip VARCHAR(15), url VARCHAR(255), request_id INT, status VARCHAR(20));
INSERT INTO http_requests (client_ip, url, request_id, status) VALUES ('127.0.0.1', '/long.vsp', 1234567, 'pending');
INSERT INTO http_requests (client_ip, url, request_id, status) VALUES ('192.168.1.1', '/long.vsp', 345678, 'pending');
DECLARE ps any;
ps := http_pending_req();
SELECT * FROM http_requests WHERE client_ip = '192.168.1.1' AND url = '/long.vsp' AND request_id = 345678;
http_kill ('192.168.1.1', '/long.vsp', 345678);
