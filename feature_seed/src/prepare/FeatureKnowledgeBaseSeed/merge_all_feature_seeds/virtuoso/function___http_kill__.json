http_kill ('10.0.0.5', '/short.vsp', 999999);
http_kill ('192.168.1.1', '/nonexistent.vsp', 123456);
http_kill ('192.168.1.1', '/long.vsp', (SELECT MAX(request_id) FROM http_requests WHERE client_ip = '192.168.1.1'));
