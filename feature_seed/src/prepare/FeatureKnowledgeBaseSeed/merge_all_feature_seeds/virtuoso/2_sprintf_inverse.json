CREATE TABLE test_strings (id INT, str_value VARCHAR(255), num_value INT);
INSERT INTO test_strings VALUES (1, 'qwe123asd456zxc', 123), (2, '---123', NULL), (3, NULL, 456);
SELECT id, sprintf_inverse(str_value, 'qwe%dasd%dzxc%s', 2) AS extracted_values FROM test_strings WHERE num_value IS NOT NULL;
SELECT id, (sprintf_inverse(str_value, 'qwe%dasd%dzxc%s', 2) IS NOT NULL) AS is_valid FROM test_strings WHERE id > 1;
SELECT id, (5 - (SELECT COUNT(*) FROM test_strings WHERE num_value IS NULL)) AS remaining FROM test_strings GROUP BY id HAVING remaining > 0;
SELECT id, sprintf_inverse(str_value, '---%s', 2) AS extracted_empty FROM test_strings WHERE (5 - num_value) < 5;
SELECT id, (sprintf_inverse(str_value, '---%s', 2) IS NOT NULL) AS is_extracted FROM test_strings ORDER BY (5 - num_value), id;
SELECT (SELECT MAX(num_value) - MIN(num_value) FROM test_strings WHERE num_value IS NOT NULL) AS range_diff;
SELECT id, sprintf_inverse(str_value, 'qwe%dasd%dzxc%s', 2) AS extracted FROM (SELECT str_value FROM test_strings) AS subquery WHERE id = 1;
SELECT id, (SELECT sprintf_inverse(str_value, '---%s', 2) FROM test_strings WHERE str_value IS NOT NULL) AS nested_values FROM test_strings;