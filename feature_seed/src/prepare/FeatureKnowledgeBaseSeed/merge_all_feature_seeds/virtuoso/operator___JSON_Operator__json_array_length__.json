CREATE TABLE test_json (id INT PRIMARY KEY, data JSON);
INSERT INTO test_json (id, data) VALUES (1, '[1, 2, 3]');
INSERT INTO test_json (id, data) VALUES (2, '[]');
INSERT INTO test_json (id, data) VALUES (3, '[1, 2, [3, 4]]');
INSERT INTO test_json (id, data) VALUES (4, '[{"key": "value"}, {"key2": "value2"}]');
INSERT INTO test_json (id, data) VALUES (5, NULL);
SELECT id, json_array_length(data) AS array_length FROM test_json WHERE data IS NOT NULL;
SELECT id FROM test_json WHERE json_array_length(data) = 0;
SELECT id FROM test_json WHERE json_array_length(data) > 2;
SELECT id, json_array_length(data) FROM test_json WHERE json_array_length(data) = (SELECT MAX(json_array_length(data)) FROM test_json) ORDER BY id;
SELECT t1.id, json_array_length(t2.data) AS length FROM test_json t1 JOIN test_json t2 ON t1.id != t2.id WHERE json_array_length(t2.data) > 0;
SELECT t1.id FROM test_json t1 WHERE EXISTS (SELECT 1 FROM test_json t2 WHERE t2.id = t1.id AND json_array_length(t2.data) IS NOT NULL);
SELECT id FROM test_json WHERE json_array_length(data) BETWEEN 0 AND 2;
SELECT data, json_array_length(data) AS length FROM test_json WHERE json_array_length(data) NOT IN (SELECT array_length FROM (SELECT json_array_length(data) AS array_length FROM test_json) AS t);
SELECT data, json_array_length(data) FROM test_json WHERE (json_array_length(data) = (SELECT COUNT(*) FROM test_json WHERE data IS NOT NULL));
CREATE TABLE test_json_nested (id INT PRIMARY KEY, data JSON);
INSERT INTO test_json_nested (id, data) VALUES (1, '[{"key": [1, 2, 3]}]');
SELECT id, json_array_length(data -> 'key') AS array_length FROM test_json_nested;