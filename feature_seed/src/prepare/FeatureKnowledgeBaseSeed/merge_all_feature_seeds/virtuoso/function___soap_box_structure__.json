CREATE TABLE soap_test (id INT PRIMARY KEY, data STRUCTURE);
INSERT INTO soap_test (id, data) VALUES (1, soap_box_structure('varString', 'hello', 'varInt', 1234));
INSERT INTO soap_test (id, data) VALUES (2, soap_box_structure('varString', 'world', 'varFloat', 12.34));
INSERT INTO soap_test (id, data) VALUES (3, soap_box_structure('varString', 'value', 'varInt', 0));
INSERT INTO soap_test (id, data) VALUES (4, soap_box_structure('varString', '', 'varInt', -1));
INSERT INTO soap_test (id, data) VALUES (5, soap_box_structure('varString', 'long_string_here_to_test_boundary_conditions', 'varInt', 999999999));
SELECT * FROM soap_test WHERE data LIKE soap_box_structure('varString', '%', 'varInt', 1);
SELECT * FROM soap_test WHERE id IN (SELECT id FROM soap_test WHERE data IS NOT NULL);
SELECT id FROM soap_test WHERE data = soap_box_structure('varString', 'hello', 'varInt', 1234) AND id = 1;
CREATE TABLE additional_test (id INT PRIMARY KEY, details STRUCTURE);
INSERT INTO additional_test (id, details) VALUES (1, soap_box_structure('detailString', 'test detail', 'detailInt', 42));
SELECT a.id FROM soap_test a JOIN additional_test b ON a.id = b.id WHERE b.details = soap_box_structure('detailString', 'test detail', 'detailInt', 42);
SELECT data FROM soap_test WHERE EXISTS (SELECT 1 FROM additional_test WHERE additional_test.id = soap_test.id);
UPDATE soap_test SET data = soap_box_structure('varString', 'updated value', 'varInt', 55) WHERE id = 1;
DELETE FROM soap_test WHERE data = soap_box_structure('varString', 'world', 'varFloat', 12.34);