CREATE TABLE test_table (id INT, value VARCHAR(255));
CREATE TABLE policy_table (policy_id INT, policy_name VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'example1'), (2, 'example2');
INSERT INTO policy_table (policy_id, policy_name) VALUES (1, 'policyA'), (2, 'policyB');
SELECT * FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value LIKE 'example%');
SELECT a.id, b.policy_name FROM test_table a JOIN policy_table b ON a.id = b.policy_id;
SET POLICY 'policyA' FOR test_table USING (SELECT id FROM test_table WHERE value = 'example1');
SET POLICY (SELECT policy_name FROM policy_table WHERE policy_id = 1) FOR test_table;
CREATE VIEW example_view AS SELECT a.id, b.policy_name FROM test_table a JOIN policy_table b ON a.id = b.policy_id;
INSERT INTO test_table (id, value) SELECT id, value FROM (SELECT 3 AS id, 'example3' AS value) AS temp;
CREATE TABLE another_table (another_id INT, fk_id INT);
INSERT INTO another_table (another_id, fk_id) SELECT 1, id FROM test_table WHERE id < 3;
SET POLICY 'policyA' FOR another_table USING (SELECT fk_id FROM another_table WHERE another_id = 1);
DELETE FROM another_table WHERE fk_id NOT IN (SELECT id FROM test_table);
SELECT * FROM another_table WHERE fk_id IN (SELECT id FROM test_table WHERE value = 'example2');