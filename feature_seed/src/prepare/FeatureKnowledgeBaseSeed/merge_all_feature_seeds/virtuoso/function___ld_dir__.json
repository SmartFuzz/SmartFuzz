CREATE TABLE test_data (id INT, file_path VARCHAR(255), file_type VARCHAR(50), base_uri VARCHAR(255));
INSERT INTO test_data (id, file_path, file_type, base_uri) VALUES (1, '/data1/file1.gz', '%.gz', 'http://bsbm.org');
INSERT INTO test_data (id, file_path, file_type, base_uri) VALUES (2, '/data2/file2.txt', '%.txt', 'http://bsbm.org');
INSERT INTO test_data (id, file_path, file_type, base_uri) VALUES (3, '/data3/file3.gz', '%.gz', 'http://bsbm.org');
SELECT * FROM test_data WHERE file_type LIKE '%.gz';
SELECT COUNT(*) FROM test_data WHERE base_uri = 'http://bsbm.org';
SELECT MAX(id) AS max_id FROM test_data;
WITH selected_files AS (SELECT file_path FROM test_data WHERE file_type LIKE '%.gz') SELECT * FROM selected_files;
INSERT INTO test_data (id, file_path, file_type, base_uri) SELECT MAX(id) + 1, file_path, '%.gz', base_uri FROM test_data WHERE file_type LIKE '%.gz';
CREATE INDEX idx_file_path ON test_data(file_path);
DELETE FROM test_data WHERE file_path = '/data2/file2.txt' AND base_uri = 'http://bsbm.org';
UPDATE test_data SET base_uri = 'http://new-bsbm.org' WHERE id = 1;
SELECT file_path, COUNT(*) FROM test_data GROUP BY file_type HAVING COUNT(*) > 1;
INSERT INTO test_data (id, file_path, file_type, base_uri) VALUES (4, '/data4/file4.gz', '%.gz', (SELECT base_uri FROM test_data WHERE id = 1 LIMIT 1));
SELECT DISTINCT base_uri FROM test_data WHERE file_path LIKE '/data%';