CREATE TABLE rdf_data (id INT PRIMARY KEY, xml_data XML, path VARCHAR(255));
INSERT INTO rdf_data (id, xml_data, path) VALUES (1, '<root><value>10</value></root>', '/data8/file1.xml');
INSERT INTO rdf_data (id, xml_data, path) VALUES (2, '<root><value>20</value></root>', '/data8/file2.xml');
INSERT INTO rdf_data (id, xml_data, path) VALUES (3, '<root><value>NULL</value></root>', '/data8/file3.xml');
INSERT INTO rdf_data (id, xml_data, path) VALUES (4, '<root><value>-5</value></root>', '/data8/file4.xml');
INSERT INTO rdf_data (id, xml_data, path) VALUES (5, '<root><value>99999</value></root>', '/data8/file5.xml');
SELECT id, xpath_integer('/root/value', xml_data) AS extracted_value FROM rdf_data WHERE extracted_value IS NOT NULL;
SELECT id, xpath_integer('/root/value', xml_data) AS extracted_value FROM rdf_data GROUP BY extracted_value HAVING extracted_value > 0;
CREATE TEMPORARY TABLE temp_data AS SELECT path, xpath_integer('/root/value', xml_data) AS extracted_value FROM rdf_data;
SELECT d1.id, d1.extracted_value FROM (SELECT id, xpath_integer('/root/value', xml_data) AS extracted_value FROM temp_data) d1 JOIN rdf_data d2 ON d1.extracted_value = d2.id WHERE d2.path LIKE '%.xml';
SELECT ld_dir_all('/data8/', '%.xml', 'http://bsbm.org') AS directory_load_status;
SELECT d.id, ld_dir_all('/data8/', '%.xml', 'http://example.org') AS load_result FROM rdf_data d WHERE xpath_integer('/root/value', xml_data) BETWEEN 0 AND 1000;
SELECT COUNT(*) FROM rdf_data WHERE xpath_integer('/root/value', xml_data) IS NULL;
UPDATE rdf_data SET xml_data = '<root><value>0</value></root>' WHERE id = 3;
DELETE FROM rdf_data WHERE xpath_integer('/root/value', xml_data) < 0;