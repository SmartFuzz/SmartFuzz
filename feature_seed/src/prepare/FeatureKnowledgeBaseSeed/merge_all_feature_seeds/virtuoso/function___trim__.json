CREATE TABLE test_strings (id INT, value VARCHAR(255));
INSERT INTO test_strings (id, value) VALUES (1, '   leading spaces'), (2, 'trailing spaces   '), (3, '   both   '), (4, 'no spaces');
SELECT id, TRIM(value) AS trimmed_value FROM test_strings;
SELECT id, LTRIM(value) AS left_trimmed_value FROM test_strings;
SELECT id, RTRIM(value) AS right_trimmed_value FROM test_strings;
SELECT id, TRIM('a' FROM 'aaaabaaa') AS trimmed_value FROM (SELECT 'aaaabaaa' AS value) AS subquery;
SELECT id, TRIM(BOTH 'abc' FROM 'abcdeabc') AS trimmed_value FROM (SELECT 'abcdeabc' AS value) AS subquery;
SELECT id, COUNT(*) FROM test_strings WHERE TRIM(value) = 'no spaces' GROUP BY TRIM(value);
WITH trimmed_strings AS (SELECT id, TRIM(value) AS trimmed_value FROM test_strings) SELECT trimmed_value, COUNT(*) FROM trimmed_strings GROUP BY trimmed_value;
SELECT ts.id FROM test_strings ts JOIN (SELECT id, TRIM(value) AS trimmed_value FROM test_strings) AS trimmed ON ts.id = trimmed.id WHERE trimmed.trimmed_value <> '   both   ';