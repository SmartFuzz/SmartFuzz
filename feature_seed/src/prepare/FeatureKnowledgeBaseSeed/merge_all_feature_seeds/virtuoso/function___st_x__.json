CREATE TABLE geometries (id INT PRIMARY KEY, geom GEOMETRY);
INSERT INTO geometries (id, geom) VALUES (1, ST_Point(10, 20));
INSERT INTO geometries (id, geom) VALUES (2, ST_Point(-5, -10));
INSERT INTO geometries (id, geom) VALUES (3, ST_Point(NULL, NULL));
INSERT INTO geometries (id, geom) VALUES (4, ST_Point(100, 200));
SELECT ST_X(geom) FROM geometries WHERE id = 1;
SELECT *, ST_X(geom) AS x_coord FROM geometries WHERE id IN (SELECT id FROM geometries WHERE id > 1);
SELECT g1.id, ST_X(g1.geom) AS x_coord1, ST_X(g2.geom) AS x_coord2 FROM geometries g1 JOIN geometries g2 ON g1.id != g2.id LIMIT 5;
SELECT DISTINCT ST_X(geom) FROM geometries WHERE geom IS NOT NULL;
SELECT ST_X(ST_Point(-123.4567, 765.4321)) AS x_coord;
SELECT g.id, ST_X(g.geom) FROM (SELECT id, geom FROM geometries WHERE id < 4) AS g;
SELECT AVG(ST_X(geom)) FROM geometries WHERE geom IS NOT NULL;
SELECT ST_X(ST_Centroid(geom)) FROM geometries WHERE id = 2;
SELECT COUNT(*) FROM geometries WHERE ST_X(geom) > 0;
WITH geo_data AS (SELECT geom FROM geometries) SELECT ST_X(geom) FROM geo_data WHERE geom IS NOT NULL;
SELECT ST_X(ST_MakePoint(0.0, 0.0)) AS origin_x;
SELECT ST_X(ST_Transform(geom, 4326)) AS x_transformed FROM geometries WHERE id = 3;