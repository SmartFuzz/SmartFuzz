CREATE TABLE users (id INT PRIMARY KEY, name VARCHAR(100), user_option VARCHAR(255));
INSERT INTO users (id, name, user_option) VALUES (1, 'Alice', 'optionA'), (2, 'Bob', NULL), (3, 'Charlie', 'optionC');
SELECT u.name, USER_GET_OPTION(u.user_option) AS user_option_value FROM users u WHERE u.id = 1;
SELECT u1.name AS user1, u2.name AS user2 FROM users u1 JOIN users u2 ON SPARQL: sameTerm(u1.user_option, u2.user_option) WHERE u1.id != u2.id;
SELECT DISTINCT u.name FROM users u WHERE USER_GET_OPTION(u.user_option) IS NOT NULL GROUP BY u.name HAVING COUNT(*) > 1;
SELECT u.name, USER_GET_OPTION(u.user_option) AS user_option_value FROM users u WHERE SPARQL: sameTerm(u.user_option, 'optionA') OR SPARQL: sameTerm(u.user_option, 'optionX') IS FALSE;
CREATE TABLE user_activity (activity_id INT, user_id INT, activity_type VARCHAR(100), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO user_activity (activity_id, user_id, activity_type) VALUES (1, 1, 'login'), (2, 2, 'logout'), (3, 1, 'update');
SELECT ua.activity_type, COUNT(*) FROM user_activity ua JOIN users u ON ua.user_id = u.id WHERE u.user_option IS NOT NULL GROUP BY ua.activity_type HAVING COUNT(*) > 1;
SELECT a.activity_type, USER_GET_OPTION(MAX(a.created_at)) FROM user_activity a WHERE USER_GET_OPTION(a.activity_type) IS NOT NULL GROUP BY a.activity_type;
SELECT u.id, SPARQL: sameTerm(USER_GET_OPTION(u.user_option), 'optionC') AS is_optionC FROM users u WHERE u.name IS NOT NULL AND USER_GET_OPTION(u.user_option) IS NOT NULL;