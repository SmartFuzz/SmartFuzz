CREATE TABLE example_table (id INT PRIMARY KEY, name VARCHAR(255), age INT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO example_table (id, name, age) VALUES (1, 'Alice', 30);
INSERT INTO example_table (id, name, age) VALUES (2, 'Bob', 25);
INSERT INTO example_table (id, name, age) VALUES (3, 'Charlie', 35);
SELECT * FROM example_table WHERE age > 30;
SELECT id, name FROM example_table WHERE created_at > '2023-01-01';
SELECT COUNT(*) FROM example_table WHERE name LIKE 'A%';
CREATE TABLE another_table (user_id INT, status VARCHAR(50), FOREIGN KEY (user_id) REFERENCES example_table(id));
INSERT INTO another_table (user_id, status) VALUES (1, 'active');
INSERT INTO another_table (user_id, status) VALUES (2, 'inactive');
SELECT et.name, at.status FROM example_table et JOIN another_table at ON et.id = at.user_id WHERE at.status = 'active';
SELECT et.name, (SELECT COUNT(*) FROM another_table WHERE user_id = et.id) AS status_count FROM example_table et WHERE et.age < (SELECT AVG(age) FROM example_table);
SELECT et.name, at.status FROM example_table et LEFT JOIN another_table at ON et.id = at.user_id WHERE et.age BETWEEN 20 AND 30 ORDER BY et.created_at DESC;
UPDATE example_table SET age = age + 1 WHERE id = 1;
DELETE FROM another_table WHERE user_id = 3;
SELECT DISTINCT et.name FROM example_table et WHERE EXISTS (SELECT 1 FROM another_table at WHERE at.user_id = et.id AND at.status = 'active');