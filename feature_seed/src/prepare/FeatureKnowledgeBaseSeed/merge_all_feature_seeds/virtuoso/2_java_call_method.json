CREATE TABLE test_table (id INT PRIMARY KEY, num_value FLOAT, str_value VARCHAR(255));
INSERT INTO test_table (id, num_value, str_value) VALUES (1, 10.0, '5'), (2, NULL, 'hello'), (3, 0, '0'), (4, 100.5, '100');
SELECT id, java_call_method('Math', 'log', num_value) / NULLIF(num_value, 0) AS result FROM test_table WHERE str_value IS NOT NULL;
SELECT id, java_call_method('Math', 'sqrt', (10.0 / num_value)) AS sqrt_value FROM test_table WHERE num_value IS NOT NULL;
SELECT a.id, a.num_value, java_call_method('Math', 'pow', (a.num_value + 1), 2) / (b.num_value + 1) AS computed_value FROM test_table a JOIN test_table b ON a.id <> b.id WHERE b.num_value IS NOT NULL;
SELECT id, COUNT(*) OVER (PARTITION BY java_call_method('Math', 'ceil', num_value)) AS count_per_group FROM test_table GROUP BY java_call_method('Math', 'ceil', num_value);
SELECT id, java_call_method('Math', 'pow', num_value, 2) AS squared_value FROM test_table HAVING squared_value > 20.0 / (SELECT COUNT(*) FROM test_table);
SELECT id, num_value FROM test_table WHERE java_call_method('Math', 'round', num_value) = 0;
SELECT id, (CASE WHEN str_value IS NOT NULL THEN java_call_method('Math', 'log', LENGTH(str_value)) ELSE -1 END) AS log_length FROM test_table;
CREATE TEMP TABLE another_table (id INT, value VARCHAR(255));
INSERT INTO another_table (id, value) VALUES (1, '100'), (2, '200'), (3, NULL);
SELECT a.id, java_call_method('Math', 'max', (SELECT value FROM another_table WHERE id = a.id), num_value) AS max_value FROM test_table a LEFT JOIN another_table b ON a.id = b.id;
SELECT id, java_call_method('Math', 'pow', num_value, 1.0 / NULLIF((SELECT COUNT(*) FROM test_table), 0)) AS inv_power FROM test_table;