CREATE TABLE xml_test (id INT PRIMARY KEY, doc XML);
INSERT INTO xml_test VALUES (1, xtree_doc('<root><item><a>valueA</a><b>valueB</b></item></root>'));
INSERT INTO xml_test VALUES (2, xtree_doc('<root><item><x>valueX</x><y>valueY</y></item></root>'));
DECLARE ent XML;
SET ent = (SELECT doc FROM xml_test WHERE id = 1);
DECLARE ent_to_replace XML;
SET ent_to_replace = xquery_eval('//b', ent);
XMLReplace(ent, ent_to_replace, 'newValueB');
SELECT doc FROM xml_test WHERE id = 1;
DECLARE ent2 XML;
SET ent2 = (SELECT doc FROM xml_test WHERE id = 2);
XMLReplace(ent2, xquery_eval('//x', ent2), 'newValueX', xquery_eval('//y', ent2), NULL);
SELECT doc FROM xml_test WHERE id = 2;
DECLARE ent3 XML;
SET ent3 = xtree_doc('<parent><child><leaf>1</leaf><leaf>2</leaf></child></parent>');
XMLReplace(ent3, xquery_eval('//leaf', ent3), xtree_doc('<replacement>Replaced</replacement>'));
SELECT ent3;
XMLReplace(ent3, xquery_eval('//child', ent3), NULL);
SELECT ent3;
DECLARE ent4 XML;
SET ent4 = xtree_doc('<a><b>Text1</b> <c>Text2</c> <d>Text3</d></a>');
XMLReplace(ent4, xquery_eval('//b', ent4), '');
SELECT ent4;
XMLReplace(ent4, xquery_eval('//c', ent4), NULL, xquery_eval('//d', ent4), 'NewText');
SELECT ent4;