CREATE TABLE table_publication (id INT, data VARCHAR(255), created_at TIMESTAMP);
INSERT INTO table_publication (id, data, created_at) VALUES (1, 'Initial data', CURRENT_TIMESTAMP);
 DB.DBA.REPL_PUB_INIT_IMAGE ('table_publication', 'tbl_pub.log', 1000000);
CREATE TABLE another_table (id INT, description VARCHAR(255));
INSERT INTO another_table (id, description) VALUES (1, 'Description for initial data');
 DB.DBA.REPL_PUB_INIT_IMAGE ('another_table', 'tbl_another.log', 1000000);
SELECT * FROM table_publication WHERE id IN (SELECT id FROM another_table WHERE description LIKE '%Description%');
CREATE TABLE complex_table (id INT, ref_id INT, info VARCHAR(255));
INSERT INTO complex_table (id, ref_id, info) VALUES (1, 1, 'Complex info 1'), (2, 1, 'Complex info 2');
 DB.DBA.REPL_PUB_INIT_IMAGE ('complex_table', 'tbl_complex.log', 1000000);
SELECT a.id, a.data FROM table_publication a JOIN complex_table b ON a.id = b.ref_id;
 DB.DBA.REPL_PUB_INIT_IMAGE ('table_publication', 'tbl_pub.log.1', 1000000);
 replay 'tbl_pub.log';
SELECT COUNT(*) FROM table_publication WHERE created_at > (CURRENT_TIMESTAMP - INTERVAL '1 DAY');
 replay 'tbl_pub.log.1';
CREATE TABLE large_data_table AS SELECT * FROM generate_series(1, 1000000) AS id;
 DB.DBA.REPL_PUB_INIT_IMAGE ('large_data_table', 'tbl_large_data.log', 1000000);
SELECT DISTINCT id FROM (SELECT id FROM large_data_table UNION SELECT id FROM table_publication) AS combined;
 DB.DBA.REPL_PUB_INIT_IMAGE ('table_publication', 'tbl_pub.log.2', 1000000);
 replay 'tbl_large_data.log';