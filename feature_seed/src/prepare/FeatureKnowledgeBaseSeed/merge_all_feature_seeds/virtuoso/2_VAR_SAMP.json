CREATE TABLE test_data (id INT, value NUMERIC, category VARCHAR(255));
INSERT INTO test_data (id, value, category) VALUES (1, 10.5, 'A'), (2, 20.0, 'B'), (3, NULL, 'A'), (4, 15.25, 'B'), (5, 30.5, 'A');
SELECT category, VAR_SAMP(value) AS sample_variance FROM test_data WHERE value IS NOT NULL GROUP BY category HAVING VAR_SAMP(value) > 0;
SELECT id, (SELECT VAR_SAMP(value) FROM test_data WHERE category = t.category) AS variance FROM test_data t WHERE t.value IS NOT NULL;
SELECT category, VAR_SAMP(CASE WHEN value IS NULL THEN 0 ELSE value END) as variance_with_default FROM test_data GROUP BY category;
CREATE TABLE more_data (id INT, value VARCHAR(10), related_id INT, FOREIGN KEY (related_id) REFERENCES test_data(id));
INSERT INTO more_data (id, value, related_id) VALUES (1, '15.5', 1), (2, 'NULL', 2), (3, '30.0', NULL);
SELECT md.related_id, VAR_SAMP(CAST(md.value AS NUMERIC)) AS sample_variance FROM more_data md GROUP BY md.related_id HAVING VAR_SAMP(CAST(md.value AS NUMERIC)) IS NOT NULL;
SELECT a.category, VAR_SAMP(t.value) FROM (SELECT value, category FROM test_data WHERE category IN (SELECT category FROM test_data GROUP BY category HAVING COUNT(*) > 1)) AS t JOIN test_data a ON a.category = t.category GROUP BY a.category;
WITH nested AS (SELECT category, VAR_SAMP(value) AS var_value FROM test_data GROUP BY category) SELECT category, var_value FROM nested WHERE var_value IS NOT NULL ORDER BY var_value DESC;