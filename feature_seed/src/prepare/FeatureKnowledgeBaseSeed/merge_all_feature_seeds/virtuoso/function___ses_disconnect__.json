CREATE TABLE sessions (session_id INT PRIMARY KEY, user_id INT, status VARCHAR(20));
INSERT INTO sessions (session_id, user_id, status) VALUES (1, 100, 'active');
INSERT INTO sessions (session_id, user_id, status) VALUES (2, 101, 'inactive');
INSERT INTO sessions (session_id, user_id, status) VALUES (3, 102, 'active');
SELECT * FROM sessions WHERE status = 'active';
SELECT COUNT(*) FROM sessions WHERE status = 'active';
UPDATE sessions SET status = 'inactive' WHERE session_id = 1;
DELETE FROM sessions WHERE session_id = 2;
SELECT user_id FROM sessions WHERE session_id IN (SELECT session_id FROM sessions WHERE status = 'active');
SELECT s1.user_id FROM sessions s1 JOIN sessions s2 ON s1.user_id = s2.user_id WHERE s1.status = 'active' AND s2.status = 'inactive';
SELECT s1.user_id, s1.status FROM sessions s1 WHERE s1.session_id = (SELECT MAX(session_id) FROM sessions);
CREATE TABLE logs (log_id INT PRIMARY KEY, session_id INT, action VARCHAR(50));
INSERT INTO logs (log_id, session_id, action) VALUES (1, 1, 'disconnect_attempt');
SELECT l.* FROM logs l WHERE l.session_id = (SELECT s.session_id FROM sessions s WHERE s.status = 'inactive');
CREATE SEQUENCE session_seq START WITH 1 INCREMENT BY 1;
INSERT INTO sessions (session_id, user_id, status) VALUES (NEXTVAL(session_seq), 103, 'active');
SELECT s.user_id, COUNT(l.log_id) FROM sessions s LEFT JOIN logs l ON s.session_id = l.session_id GROUP BY s.user_id HAVING COUNT(l.log_id) > 1;
DELETE FROM sessions WHERE session_id = ANY (SELECT session_id FROM sessions WHERE status = 'inactive');
SELECT s.* FROM sessions s WHERE s.session_id = (SELECT MIN(session_id) FROM sessions WHERE status = 'active') LIMIT 1;