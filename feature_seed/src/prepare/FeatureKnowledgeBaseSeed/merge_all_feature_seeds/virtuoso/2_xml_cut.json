CREATE TABLE xml_test (id INT PRIMARY KEY, data XML NOT NULL);
INSERT INTO xml_test (id, data) VALUES (1, '<root><a>1</a><b>2</b></root>');
INSERT INTO xml_test (id, data) VALUES (2, '<root><a>3</a><b>4</b></root>');
SELECT xml_cut(data) < xml_cut('<root><c>5</c></root>') FROM xml_test WHERE id = 1;
SELECT id FROM xml_test WHERE xml_cut(data) < xml_cut('<root><b>1</b></root>') AND data IS NOT NULL;
SELECT id, xml_cut(data) AS new_data FROM xml_test WHERE xml_cut(data) < xml_cut('<root><x>10</x></root>') ORDER BY id ASC;
SELECT COUNT(*) FROM (SELECT xml_cut(data) FROM xml_test WHERE xml_cut(data) < xml_cut('<root><x>0</x></root>')) AS subquery;
SELECT a.id FROM xml_test a JOIN (SELECT xml_cut(data) AS cut_data FROM xml_test WHERE id = 1) b ON xml_cut(a.data) < b.cut_data;
SELECT id, xml_cut(data) AS cut_data FROM xml_test GROUP BY cut_data HAVING COUNT(cut_data) < 3;
SELECT x.id FROM (SELECT id, xml_cut(data) AS cut_data FROM xml_test) x WHERE x.cut_data < xml_cut('<root><y>2</y></root>') OR x.cut_data IS NULL;