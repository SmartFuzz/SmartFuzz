CREATE GRAPH <g1>;
CREATE   XML  DOCUMENT <xml_doc1> AS '<root><child1/><child2/></root>' IN <g1>;
CREATE   XML  DOCUMENT <xml_doc2> AS '<root><child3/></root>' IN <g1>;
SELECT  * FROM  <g1> WHERE  RDF_TYPE = 'xml:Document';
DECLARE ENTITY ent1 ANY;
ent1 := xpath_eval('//child1', xtree_doc('<root><child1/><child2/></root>'));
XMLInsertAfter(ent1, xtree_doc('<child4/>'), xtree_doc('<child5/>'));
SELECT * FROM <g1> WHERE RDF_TYPE = 'xml:Document';
DECLARE ENTITY ent2 ANY;
ent2 := xpath_eval('//child3', xtree_doc('<root><child3/></root>'));
XMLInsertAfter(ent2, 'New Child 1', xtree_doc('<child6/>'));
SELECT * FROM <g1> WHERE RDF_TYPE = 'xml:Document';
DECLARE ENTITY ent3 ANY;
ent3 := xpath_eval('//child1/text()', xtree_doc('<root><child1>Hello</child1></root>'));
XMLInsertAfter(ent3, ', World!');
SELECT * FROM <g1> WHERE RDF_TYPE = 'xml:Document';
SELECT COUNT(*) FROM <g1> WHERE RDF_TYPE = 'xml:Document';
CREATE XML DOCUMENT <xml_doc3> AS '<root><child7/><child8/></root>' IN <g1>;
DECLARE ENTITY ent4 ANY;
ent4 := xpath_eval('//child7', xtree_doc('<root><child7/><child8/></root>'));
XMLInsertAfter(ent4, xtree_doc('<child9/><child10/>'), xtree_doc('<child11/>'));
SELECT * FROM <g1> WHERE RDF_TYPE = 'xml:Document';
CREATE XML DOCUMENT <xml_doc4> AS '<root></root>' IN <g1>;
DECLARE ENTITY ent5 ANY;
ent5 := xpath_eval('//root', xtree_doc('<root></root>'));
XMLInsertAfter(ent5, xtree_doc('<emptyChild/>'));
SELECT * FROM <g1> WHERE RDF_TYPE = 'xml:Document';