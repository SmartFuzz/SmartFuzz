CREATE TABLE test_files (id INT, file_path VARCHAR(255));
INSERT INTO test_files (id, file_path) VALUES (1, 'test_file_1.txt'), (2, 'test_file_2.txt');
SELECT file_to_string(file_path) AS file_content FROM test_files WHERE id = 1;
SELECT file_to_string(file_path) AS file_content FROM test_files WHERE id = (SELECT MAX(id) FROM test_files);
SELECT file_to_string(file_path) AS file_content FROM test_files WHERE id IN (SELECT id FROM test_files WHERE id <> 2);
SELECT file_to_string(file_path) AS file_content FROM test_files WHERE EXISTS (SELECT 1 FROM test_files WHERE id = 2);
SELECT file_to_string(file_path) AS file_content FROM test_files WHERE id = 1 OR id = (SELECT MIN(id) FROM test_files);
SELECT COUNT(*) AS file_count, file_to_string(file_path) AS file_content FROM test_files GROUP BY file_path HAVING COUNT(*) > 0;
WITH temp_files AS (SELECT file_path FROM test_files WHERE id < 3) SELECT file_to_string(file_path) FROM temp_files;
SELECT file_to_string(file_path) AS file_content FROM test_files WHERE LENGTH(file_path) < 255 AND id = 1;