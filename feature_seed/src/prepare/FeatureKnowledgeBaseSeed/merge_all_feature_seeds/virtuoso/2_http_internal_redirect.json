CREATE TABLE redirects (id INT PRIMARY KEY, path VARCHAR(255) NOT NULL, status_code INT DEFAULT 200);
INSERT INTO redirects (path, status_code) VALUES ('/original/path', 200), ('/another/path', 303), ('/final/path', NULL);
SELECT * FROM redirects WHERE status_code > 200;
CREATE PROCEDURE redirect_procedure() { DECLARE full_path VARCHAR;
DECLARE status_code INT;
SELECT path INTO full_path FROM redirects WHERE status_code IS NOT NULL LIMIT 1;
status_code := (SELECT COUNT(*) FROM redirects WHERE status_code > 200);
IF http_internal_redirect(full_path) > 0 THEN RETURN status_code;
ELSE RETURN NULL;
END IF;
};
SELECT full_path FROM (SELECT path AS full_path FROM redirects WHERE status_code IS NULL) AS temp WHERE (SELECT COUNT(*) FROM redirects) > 1;
CREATE TABLE test_data (id INT, url VARCHAR(255), visit_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_data (id, url) VALUES (1, 'http://example.com'), (2, 'http://example.org');
SELECT COUNT(*) FROM test_data WHERE url > 'http://example.com' GROUP BY url HAVING COUNT(*) > 0;
CREATE TABLE edge_cases (value VARCHAR(255));
INSERT INTO edge_cases (value) VALUES (NULL), ('boundary_string'), ('');
SELECT http_internal_redirect('http://example.com') AS redirect, (SELECT COUNT(*) FROM edge_cases WHERE value > '') AS count FROM dual;
SELECT path FROM redirects WHERE http_internal_redirect((SELECT MAX(path) FROM redirects WHERE status_code IS NULL)) > 0;
SELECT A.path FROM redirects A JOIN redirects B ON A.status_code > B.status_code WHERE (SELECT COUNT(*) FROM redirects) > 0;
IF (SELECT COUNT(*) FROM redirects) > 2 THEN http_internal_redirect('/high/traffic/path');
END IF;