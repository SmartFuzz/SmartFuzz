CREATE TABLE test_table1 (X INT, Y INT);
INSERT INTO test_table1 (X, Y) VALUES (1, 10), (2, NULL), (NULL, 20), (3, 30);
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.X) FROM (SELECT X FROM test_table1 ORDER BY X) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.Y) FROM (SELECT Y FROM test_table1 ORDER BY Y) as subquery;
CREATE TABLE test_table2 (A INT, B INT, C INT);
INSERT INTO test_table2 (A, B, C) VALUES (NULL, 1, NULL), (2, NULL, 2), (NULL, 3, 3), (4, NULL, NULL);
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.B) FROM (SELECT B FROM test_table2 WHERE A IS NOT NULL ORDER BY B) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.C) FROM (SELECT C FROM test_table2 ORDER BY C) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.X) FROM (SELECT DISTINCT X FROM test_table1 WHERE X IS NOT NULL ORDER BY X) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.Y) FROM (SELECT DISTINCT Y FROM test_table1 ORDER BY Y) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.X) FROM (SELECT X FROM test_table1 INNER JOIN test_table2 ON test_table1.X = test_table2.A ORDER BY X) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.B) FROM (SELECT B FROM test_table2 LEFT JOIN test_table1 ON test_table1.X = test_table2.A WHERE test_table1.X IS NULL ORDER BY B) as subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_AGG(subquery.Val) FROM (SELECT CASE WHEN X IS NULL THEN Y ELSE X END AS Val FROM test_table1 UNION SELECT CASE WHEN A IS NULL THEN B ELSE A END FROM test_table2) as subquery;