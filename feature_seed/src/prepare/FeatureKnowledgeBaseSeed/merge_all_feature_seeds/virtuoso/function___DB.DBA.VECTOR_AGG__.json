CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table (id, value) VALUES (1, 10), (2, 20), (3, 30);
SELECT DB.DBA.VECTOR_AGG(value) FROM test_table ORDER BY id;
SELECT DB.DBA.VECTOR_AGG(subquery.value) FROM (SELECT value FROM test_table WHERE value > 10 ORDER BY id) as subquery;
CREATE TABLE another_table (id INT, category VARCHAR(50));
INSERT INTO another_table (id, category) VALUES (1, 'A'), (2, 'B'), (3, 'A');
SELECT DB.DBA.VECTOR_AGG(a.value) FROM test_table a JOIN another_table b ON a.id = b.id WHERE b.category = 'A' ORDER BY a.id;
SELECT DB.DBA.VECTOR_AGG(subquery.value) FROM (SELECT value FROM test_table ORDER BY value DESC LIMIT 2) as subquery;
SELECT DB.DBA.VECTOR_AGG(value) FROM (SELECT value FROM test_table WHERE value IS NOT NULL ORDER BY value) as subquery;
CREATE TABLE test_table_2 (id INT, extra_value INT, FOREIGN KEY (id) REFERENCES test_table(id));
INSERT INTO test_table_2 (id, extra_value) VALUES (1, 100), (1, 200), (2, 300);
SELECT DB.DBA.VECTOR_AGG(subquery.extra_value) FROM (SELECT extra_value FROM test_table_2 WHERE id = 1 ORDER BY extra_value) as subquery;
SELECT DB.DBA.VECTOR_AGG(a.value) FROM test_table a LEFT JOIN test_table_2 b ON a.id = b.id GROUP BY a.value ORDER BY a.id;