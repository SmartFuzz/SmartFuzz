SELECT nntp_auth_post('Sample Content', NULL) WHERE EXISTS (SELECT 1 FROM users WHERE username = 'user1') AND bif:st_distance(point(NULL, NULL), point(2, 2)) > 0;
SELECT nntp_auth_post('Message with distance', CAST(bif:st_distance(point(1.5, 1.5), point(2, 2)) AS FLOAT)) FROM messages WHERE author_id IN (SELECT id FROM users WHERE email LIKE '%@example.com');