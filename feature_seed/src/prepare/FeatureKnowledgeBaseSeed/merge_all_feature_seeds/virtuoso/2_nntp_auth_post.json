CREATE TABLE messages (id SERIAL PRIMARY KEY, content TEXT NOT NULL, author_id INT NOT NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
CREATE TABLE users (id SERIAL PRIMARY KEY, username VARCHAR(255) NOT NULL, email VARCHAR(255) NOT NULL);
INSERT INTO users (username, email) VALUES ('user1', 'user1@example.com'), ('user2', 'user2@example.com'), ('user3', 'user3@example.com');
INSERT INTO messages (content, author_id) VALUES ('First message', 1), ('Second message', 2), ('Third message', 3);
SELECT m.content, u.username, bif:st_distance(point(1,1), point(2,2)) AS distance FROM messages m JOIN users u ON m.author_id = u.id WHERE EXISTS (SELECT 1 FROM messages m2 WHERE m2.author_id = u.id AND m2.created_at < NOW() - INTERVAL '1 DAY') ORDER BY distance;
SELECT m.content, u.username FROM messages m JOIN users u ON m.author_id = u.id WHERE m.content IS NOT NULL OR (SELECT COUNT(*) FROM messages m2 WHERE m2.author_id = u.id) > 0 HAVING bif:st_distance(point(1,1), point(0,0)) < 10;
SELECT u.username, COUNT(m.id) AS message_count FROM users u LEFT JOIN messages m ON u.id = m.author_id GROUP BY u.username HAVING message_count > (SELECT AVG(sub.message_count) FROM (SELECT COUNT(*) AS message_count FROM messages GROUP BY author_id) AS sub) ORDER BY message_count DESC;
