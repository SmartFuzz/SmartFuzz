CREATE TABLE TestDB (id INT, name VARCHAR(100));
INSERT INTO TestDB (id, name) VALUES (1, 'Sample Entry');
SELECT dbname();
USE TestDB;
SELECT dbname();
CREATE TABLE AnotherDB (id INT, description VARCHAR(255));
INSERT INTO AnotherDB (id, description) VALUES (1, 'Another Sample Entry');
SELECT dbname();
USE AnotherDB;
SELECT dbname();
SELECT (SELECT dbname() FROM DUAL) AS CurrentDB;
SELECT * FROM (SELECT dbname() AS DBName) AS Subquery;
CREATE TABLE Demo (id INT, category VARCHAR(50));
INSERT INTO Demo (id, category) VALUES (1, 'Category A');
INSERT INTO Demo (id, category) VALUES (2, 'Category B');
SELECT dbname(), COUNT(*) FROM Demo GROUP BY dbname();
SELECT dbname() FROM (SELECT id, name FROM TestDB) AS InnerQuery;
DELETE FROM TestDB WHERE id = 1;
SELECT dbname() AS CurrentDBName, (SELECT COUNT(*) FROM AnotherDB) AS AnotherDBCount;
DROP TABLE TestDB;
DROP TABLE AnotherDB;
DROP TABLE Demo;