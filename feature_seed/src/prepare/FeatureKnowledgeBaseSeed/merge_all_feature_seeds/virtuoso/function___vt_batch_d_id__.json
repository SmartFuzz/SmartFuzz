CREATE TABLE documents (id INT PRIMARY KEY, content VARCHAR(255));
INSERT INTO documents (id, content) VALUES (1, 'First document');
INSERT INTO documents (id, content) VALUES (2, 'Second document');
INSERT INTO documents (id, content) VALUES (3, 'Third document');
SELECT * FROM documents WHERE id = 1;
SELECT * FROM documents WHERE id IN (SELECT id FROM documents WHERE content LIKE '%document%');
UPDATE documents SET content = 'Updated first document' WHERE id = (SELECT MIN(id) FROM documents);
UPDATE documents SET content = 'Updated second document' WHERE id IN (SELECT d.id FROM documents d JOIN (SELECT id FROM documents WHERE content LIKE '%document%') sub ON d.id = sub.id);
DELETE FROM documents WHERE id = (SELECT MAX(id) FROM documents);
SELECT COUNT(*) FROM documents WHERE id BETWEEN 1 AND (SELECT MAX(id) FROM documents);
INSERT INTO documents (id, content) VALUES (4, (SELECT CONCAT('Document ', id) FROM documents ORDER BY id LIMIT 1));
SELECT d.content FROM documents d WHERE d.id = (SELECT id FROM documents ORDER BY content DESC LIMIT 1);
UPDATE documents SET content = 'New content for id 2' WHERE id = 2 AND EXISTS (SELECT 1 FROM documents WHERE id = 2);
SELECT * FROM documents WHERE id NOT IN (SELECT id FROM documents WHERE content LIKE '%First%');