CREATE TABLE test_table (id INT, name VARCHAR(100), value INT);
INSERT INTO test_table (id, name, value) VALUES (1, 'test1', NULL);
INSERT INTO test_table (id, name, value) VALUES (2, 'test2', 100);
INSERT INTO test_table (id, name, value) VALUES (3, 'test3', NULL);
SELECT isnull(value) FROM test_table;
SELECT id, isnull(value) AS is_value_null FROM test_table;
SELECT id, name FROM test_table WHERE isnull(value) = 1;
CREATE TABLE another_table (related_id INT, description VARCHAR(100), amount INT);
INSERT INTO another_table (related_id, description, amount) VALUES (1, 'desc1', NULL);
INSERT INTO another_table (related_id, description, amount) VALUES (2, 'desc2', 200);
SELECT t.id, t.name, a.description, isnull(a.amount) AS is_amount_null FROM test_table t LEFT JOIN another_table a ON t.id = a.related_id;
SELECT t.id, isnull(a.amount) FROM test_table t LEFT JOIN another_table a ON t.id = a.related_id WHERE isnull(t.value) = 1;
SELECT (SELECT name FROM test_table WHERE id = 1) AS test_name, isnull((SELECT value FROM test_table WHERE id = 1));
SELECT COUNT(*) FROM test_table WHERE isnull(value) = 1;
SELECT id, name, isnull(value) AS is_value_null FROM test_table WHERE id IN (SELECT related_id FROM another_table WHERE isnull(amount) = 1);
SELECT isnull((SELECT AVG(amount) FROM another_table WHERE related_id = t.id)) AS is_avg_null FROM test_table t;