CREATE TABLE test_table (id INT PRIMARY KEY, value_x NUMERIC, value_y NUMERIC);
INSERT INTO test_table (id, value_x, value_y) VALUES (1, 10.5, 5.5), (2, NULL, 2.5), (3, 0, 0.0), (4, 10.5, NULL), (5, 20.1, 10.1);
SELECT COVAR_SAMP(value_x, value_y - 1.0) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value_y IS NOT NULL);
SELECT AVG(value_x - value_y) AS avg_diff FROM test_table GROUP BY CASE WHEN value_x > value_y THEN 'above' ELSE 'below' END HAVING COVAR_SAMP(value_x, value_y) IS NOT NULL;
SELECT SUM(LEAST(value_x, value_y - 5)) AS adjusted_sum FROM test_table WHERE value_x IS NOT NULL AND value_y IS NOT NULL;
SELECT id, COVAR_SAMP(CAST(value_x AS FLOAT), CAST(value_y AS FLOAT)) FROM test_table WHERE value_x IS NOT NULL AND value_y IS NOT NULL GROUP BY id;
SELECT COUNT(*) FROM (SELECT DISTINCT(value_x - value_y) FROM test_table) AS unique_differences;
SELECT COVAR_SAMP(COALESCE(value_x, 0), value_y) FROM test_table;
SELECT id FROM test_table WHERE COVAR_SAMP(value_x + 5, value_y - 2) IS NOT NULL ORDER BY value_x DESC;
UPDATE test_table SET value_x = NULL WHERE id = 3;
SELECT id, COVAR_SAMP(value_x, NULLIF(value_y, 0)) AS sample_cov FROM test_table GROUP BY id HAVING sample_cov IS NOT NULL;
SELECT COVAR_SAMP(CAST(value_x AS DECIMAL(10, 2)) - CAST(value_y AS DECIMAL(10, 2)), value_y) FROM test_table WHERE value_x IS NOT NULL AND value_y IS NOT NULL;
SELECT COUNT(*) FROM test_table WHERE value_x - NULL IS NULL;
CREATE TEMPORARY TABLE temp_table AS SELECT id, value_x, value_y FROM test_table WHERE value_x IS NOT NULL;
INSERT INTO temp_table (id, value_x, value_y) VALUES (6, 15.5, 4.5);