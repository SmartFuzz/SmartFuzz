CREATE GRAPH <http://example.com/graph1>;
CREATE GRAPH <http://example.com/graph2>;
DB.DBA.TTLP_MT (file_to_string_output ('./data1.ttl'), '', 'http://example.com/graph1', 512);
DB.DBA.TTLP_MT (file_to_string_output ('./data2.nt'), '', 'http://example.com/graph2', 512);
SELECT * FROM <http://example.com/graph1> WHERE {?s ?p ?o} LIMIT 10;
SELECT * FROM <http://example.com/graph2> WHERE {?s ?p ?o} LIMIT 10;
DELETE FROM RDF_QUAD WHERE G = DB.DBA.RDF_MAKE_IID_OF_QNAME('http://example.com/graph1');
SELECT COUNT(*) FROM <http://example.com/graph1> WHERE {?s ?p ?o};
SELECT (COUNT(?s) AS ?count) WHERE { GRAPH <http://example.com/graph1> { ?s ?p ?o } };
SELECT ?s ?p ?o WHERE { GRAPH <http://example.com/graph1> { ?s ?p ?o } } ORDER BY ?s LIMIT 5;
DB.DBA.TTLP_MT (file_to_string_output ('./complex-data.nq'), '', 'http://example.com/complexGraph', 512);
SELECT * WHERE { { SELECT ?s WHERE { ?s ?p ?o } LIMIT 1 } UNION { SELECT ?s WHERE { ?s ?p2 ?o2 } } };
WITH { SELECT ?p WHERE { <http://example.com/graph1> ?p ?o }} AS ?predicates SELECT * WHERE { GRAPH <http://example.com/graph1> { ?s ?p ?o } };
SELECT ?graph WHERE { GRAPH ?graph { ?s ?p ?o } };
CREATE PROCEDURE test_procedure AS BEGIN DB.DBA.TTLP_MT (file_to_string_output ('./data.procedure.ttl'), '', 'http://example.com/procedureGraph');
END;
EXEC test_procedure;
DROP SILENT GRAPH <http://example.com/procedureGraph>;
SELECT COUNT(*) FROM <http://example.com/procedureGraph>;
