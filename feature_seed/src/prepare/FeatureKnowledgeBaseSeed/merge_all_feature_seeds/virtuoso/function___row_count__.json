CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
INSERT INTO test_table (id, name) VALUES (2, 'Bob');
BEGIN;
INSERT INTO test_table (id, name) VALUES (3, 'Charlie');
SELECT row_count();
END;
BEGIN;
DELETE FROM test_table WHERE name = 'Bob';
SELECT row_count();
END;
BEGIN;
UPDATE test_table SET name = 'Alice B.' WHERE id = 1;
SELECT row_count();
END;
CREATE TABLE another_table (id INT PRIMARY KEY, test_id INT, value VARCHAR(100), FOREIGN KEY (test_id) REFERENCES test_table(id));
INSERT INTO another_table (id, test_id, value) VALUES (1, 1, 'Test1');
INSERT INTO another_table (id, test_id, value) VALUES (2, 1, 'Test2');
BEGIN;
INSERT INTO another_table (id, test_id, value) SELECT 3, id, 'Test3' FROM test_table WHERE id = 1;
SELECT row_count();
END;
BEGIN;
DELETE FROM another_table WHERE value = 'Test1';
SELECT row_count();
END;
BEGIN;
UPDATE another_table SET value = 'Test2 Updated' WHERE id = 2;
SELECT row_count();
END;
BEGIN;
INSERT INTO test_table (id, name) VALUES (4, 'David');
SELECT row_count();
END;
BEGIN;
INSERT INTO test_table (id, name) VALUES (5, 'Eve');
INSERT INTO test_table (id, name) VALUES (6, 'Frank');
SELECT row_count();
END;
BEGIN;
SELECT (SELECT COUNT(*) FROM test_table) AS total;
SELECT row_count();
END;
CREATE TABLE complex_table (id INT PRIMARY KEY, description VARCHAR(100));
INSERT INTO complex_table (id, description) VALUES (1, 'Complex Case');
BEGIN;
DELETE FROM test_table WHERE id IN (SELECT test_id FROM another_table WHERE value LIKE 'Test%');
SELECT row_count();
END;
BEGIN;
SELECT id, (SELECT COUNT(*) FROM another_table WHERE test_id = id) AS related_count FROM test_table;
SELECT row_count();
END;