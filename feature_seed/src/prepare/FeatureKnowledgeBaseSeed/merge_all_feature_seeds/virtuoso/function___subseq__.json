CREATE TABLE test_strings (id INT, str VARCHAR(255));
INSERT INTO test_strings (id, str) VALUES (1, 'ExampleString');
INSERT INTO test_strings (id, str) VALUES (2, NULL);
SELECT subseq(str, 0, 7) FROM test_strings WHERE id = 1;
SELECT subseq(str, 0) FROM test_strings WHERE id = 1;
SELECT subseq(str, 7, 14) FROM test_strings WHERE id = 1;
SELECT subseq(str, 0, 14) FROM test_strings WHERE id = 1;
SELECT subseq(str, 7, 7) FROM test_strings WHERE id = 1;
SELECT subseq(str, 10, 5) FROM test_strings WHERE id = 1;
SELECT subseq(str, 0, 20) FROM test_strings WHERE id = 1;
SELECT subseq(str, 5, NULL) FROM test_strings WHERE id = 1;
SELECT subseq(str, 10, 20) FROM test_strings WHERE id = 1;
SELECT subseq(str, 0, 4) AS part FROM test_strings WHERE id = 1;
SELECT subseq(NULL, 0, 7) FROM test_strings WHERE id = 2;
SELECT subseq(str, 1, 7) FROM (SELECT str FROM test_strings WHERE id = 1) AS t;
SELECT subseq((SELECT str FROM test_strings WHERE id = 1), 0, 4) AS part FROM test_strings;
SELECT subseq(str, 0, 7) FROM test_strings WHERE id = 1 UNION SELECT subseq(str, 1, 3) FROM test_strings WHERE id = 1;
SELECT subseq(str, 0, 255) FROM test_strings WHERE id = 1;
SELECT subseq('This is a test string with slashes / and more', 0, INSTR('This is a test string with slashes / and more', '/') + 0) FROM test_strings WHERE id = 1;