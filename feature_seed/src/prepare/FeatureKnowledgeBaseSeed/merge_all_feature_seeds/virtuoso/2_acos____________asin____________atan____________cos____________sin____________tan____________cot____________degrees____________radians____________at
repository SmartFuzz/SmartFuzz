CREATE TABLE trigonometric_test (id INT PRIMARY KEY, angle_double DOUBLE PRECISION, angle_string VARCHAR(50));
INSERT INTO trigonometric_test (id, angle_double, angle_string) VALUES (1, 0.0, '0'), (2, pi(), '3.14159'), (3, 1.5708, 'PI/2'), (4, -1.0, NULL);
SELECT id, sin(angle_double) AS sin_value, cos(angle_string::DOUBLE PRECISION) AS cos_value FROM trigonometric_test;
SELECT id, acos(cos(angle_double)) AS angle_from_cos FROM trigonometric_test WHERE angle_double IS NOT NULL;
SELECT id, atan2(sin(angle_double), cos(angle_double)) AS angle_in_radians FROM trigonometric_test;
SELECT id, degrees(atan(cot(angle_double))) AS degree_value FROM trigonometric_test HAVING degree_value > 0;
SELECT id, ROUND(sin(angle_double), 4) AS rounded_sin FROM trigonometric_test ORDER BY rounded_sin DESC;
SELECT id, SUM(sin(angle_double)) OVER (PARTITION BY angle_string) AS total_sin_value FROM trigonometric_test;
SELECT id, tan(radians(angle_double)) AS tangent_value FROM trigonometric_test WHERE angle_double BETWEEN -1 AND 1;
SELECT id, CASE WHEN angle_string IS NULL THEN NULL ELSE asin(NULLIF(angle_double, 0)) END AS asin_result FROM trigonometric_test;
SELECT id, (SELECT COUNT(*) FROM trigonometric_test WHERE angle_double > 1) AS count_above_one, sin((SELECT angle_double FROM trigonometric_test WHERE id = 2)) AS sin_value FROM trigonometric_test WHERE angle_double < pi();
SELECT id, (SELECT COUNT(*) FROM trigonometric_test WHERE angle_double IS NOT NULL) AS non_null_count, cos(degrees(atan2(angle_double, NULLIF(angle_double, 0)))) AS cosine_value FROM trigonometric_test GROUP BY id HAVING cosine_value IS NOT NULL;