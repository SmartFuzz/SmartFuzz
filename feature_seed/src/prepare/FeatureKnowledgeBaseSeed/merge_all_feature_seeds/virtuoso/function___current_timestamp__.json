CREATE TABLE transaction_log (id INT PRIMARY KEY, timestamp DATETIME, description VARCHAR(255));
INSERT INTO transaction_log (id, timestamp, description) VALUES (1, current_timestamp, 'First transaction');
SELECT id, timestamp, description FROM transaction_log WHERE timestamp = current_timestamp;
CREATE TABLE user_activity (user_id INT, activity_time DATETIME);
INSERT INTO user_activity (user_id, activity_time) VALUES (101, current_timestamp);
SELECT u.user_id, u.activity_time, t.description FROM user_activity u JOIN transaction_log t ON u.activity_time = t.timestamp WHERE t.id = 1;
CREATE TABLE server_status (status_id INT PRIMARY KEY, last_checked DATETIME);
INSERT INTO server_status (status_id, last_checked) VALUES (1, current_timestamp);
SELECT last_checked FROM server_status WHERE last_checked > current_timestamp - INTERVAL '5' MINUTE;
SELECT COUNT(*) FROM transaction_log WHERE timestamp BETWEEN current_timestamp - INTERVAL '1' HOUR AND current_timestamp;
SELECT MAX(timestamp) FROM user_activity WHERE activity_time <= current_timestamp;
SELECT timestamp, (SELECT COUNT(*) FROM transaction_log WHERE timestamp = current_timestamp) AS transaction_count FROM dual;
CREATE TABLE session_data (session_id INT, session_start DATETIME);
INSERT INTO session_data (session_id, session_start) VALUES (1, current_timestamp);
SELECT sd.session_id, sd.session_start, (SELECT COUNT(*) FROM session_data WHERE session_start = current_timestamp) AS session_count FROM session_data sd WHERE sd.session_id = 1;
SELECT * FROM transaction_log WHERE timestamp IN (SELECT MAX(timestamp) FROM transaction_log GROUP BY description HAVING COUNT(*) > 1);