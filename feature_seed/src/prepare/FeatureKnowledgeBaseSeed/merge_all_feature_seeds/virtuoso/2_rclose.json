CREATE TABLE test_data (id INT PRIMARY KEY, json_data JSON, remote_src VARCHAR(255));
INSERT INTO test_data (id, json_data, remote_src) VALUES (1, '[{"val": 1}, {"val": 2}]', 'DSN1'), (2, '[{"val": 3}, {"val": null}]', 'DSN2');
SELECT rclose(rexecute('SELECT * FROM test_data WHERE json_array_length(json_data) > 1 AND remote_src = CAST(NULL AS VARCHAR)')) AS close_status;
SELECT rclose(rexecute('SELECT id, json_array_length(json_data) AS len FROM test_data GROUP BY id HAVING len > 1')) AS close_status;
CREATE TEMPORARY TABLE temp_data AS SELECT id, json_array_length(json_data) FROM test_data WHERE json_array_length(json_data) IS NOT NULL;
SELECT id FROM temp_data WHERE id IN (SELECT id FROM test_data WHERE remote_src IS NOT NULL) ORDER BY json_array_length(json_data) DESC;
SELECT rclose(rexecute('SELECT id FROM test_data WHERE remote_src IS NOT NULL AND json_array_length(json_data) = CAST(INFINITY AS INT)')) AS close_status;
SELECT rclose(rexecute('SELECT id, json_data, json_array_length(json_data), remote_src FROM test_data WHERE json_array_length(json_data) = 0 AND remote_src NOT LIKE ''%DN%'' ORDER BY id DESC')) AS close_status;
SELECT rclose(rexecute('SELECT id FROM test_data WHERE json_array_length(json_data) = CAST(''1.0'' AS DECIMAL) OR remote_src IS NULL')) AS close_status;
SELECT rclose(rexecute('SELECT json_array_length(json_data) AS json_length FROM test_data WHERE remote_src = ''%FAIL%'' AND json_array_length(json_data) < 0')) AS close_status;