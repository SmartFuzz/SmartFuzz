CREATE TABLE xml_documents (id INT PRIMARY KEY, doc LONG VARCHAR);
INSERT INTO xml_documents (id, doc) VALUES (1, '<root><element>Sample XML</element></root>');
INSERT INTO xml_documents (id, doc) VALUES (2, '<root><element>Another Sample XML</element></root>');
DECLARE tree ANY;
tree := xper_doc(file_to_string((SELECT doc FROM xml_documents WHERE id = 1)), 1, 'http://localhost.localdomain/', 'ISO');
DECLARE tree2 ANY;
tree2 := xper_doc(file_to_string('file://doc.xml'));
DECLARE large_tree ANY;
large_tree := xper_doc(file_to_string_output('huge_doc.xml'));
DECLARE nested_tree ANY;
nested_tree := xper_doc(file_to_string((SELECT doc FROM xml_documents WHERE id = (SELECT MAX(id) FROM xml_documents))));
DECLARE complex_tree ANY;
complex_tree := xper_doc(file_to_string(CONCAT('<root>', (SELECT doc FROM xml_documents WHERE id = 1), '</root')));
SELECT * FROM xml_documents WHERE LENGTH(doc) < 10485760;
SELECT id, xper_doc(file_to_string(doc)) FROM xml_documents WHERE id IN (SELECT id FROM xml_documents WHERE id < 3);
SELECT doc FROM xml_documents WHERE LENGTH(doc) < 5000 LIMIT 1;
CREATE TABLE large_xml_documents (id INT PRIMARY KEY, doc LONG VARCHAR);
INSERT INTO large_xml_documents (id, doc) VALUES (1, '<root>Large Document</root>');
DECLARE large_xper_tree ANY;
large_xper_tree := xper_doc(file_to_string((SELECT doc FROM large_xml_documents WHERE id = 1)), 1, 'http://localhost.localdomain/', 'ISO');