CREATE TABLE rdf_table (id INT PRIMARY KEY, name VARCHAR(100), value FLOAT, created_at TIMESTAMP);
INSERT INTO rdf_table (id, name, value, created_at) VALUES (1, 'data1', 10.5, '2023-10-01 10:00:00');
INSERT INTO rdf_table (id, name, value, created_at) VALUES (2, 'data2', NULL, '2023-10-02 11:00:00');
INSERT INTO rdf_table (id, name, value, created_at) VALUES (3, 'data3', 20.5, NULL);
SELECT DB.DBA.SPARQL_RDB2RDF_LIST_TABLES();
SELECT id, name, value, (value * 2) AS double_value FROM rdf_table WHERE id = (SELECT MAX(id) FROM rdf_table) AND value IS NOT NULL;
SELECT MAX(value) AS max_value, (max_value * 3) AS multiplied_value FROM (SELECT value FROM rdf_table WHERE created_at < '2023-10-03') AS subquery GROUP BY created_at HAVING COUNT(name) > 0;
SELECT t1.id, t1.name, t1.value * t2.amount AS calculated_value FROM rdf_table t1 JOIN (SELECT id, SUM(value) AS amount FROM rdf_table GROUP BY id) t2 ON t1.id = t2.id WHERE t2.amount IS NOT NULL;
SELECT t1.id, t1.name, (CASE WHEN t1.value IS NULL THEN 'No Value' ELSE CAST(t1.value AS VARCHAR(100)) END) AS value_string FROM rdf_table t1 WHERE t1.value * 5 > 50;
SELECT (SELECT COUNT(*) FROM rdf_table WHERE value IS NOT NULL) * (SELECT COUNT(*) FROM rdf_table WHERE value IS NULL) AS null_value_product;