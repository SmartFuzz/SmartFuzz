CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, value) VALUES (1, 'test'), (2, NULL), (3, 'fuzz');
SELECT txn_killall(1);
SELECT * FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NULL);
SELECT * FROM test_table WHERE (SELECT COUNT(*) FROM test_table) > 2;
CREATE TABLE transaction_logs (log_id INT PRIMARY KEY, transaction_time TIMESTAMP, status VARCHAR(50));
INSERT INTO transaction_logs (log_id, transaction_time, status) SELECT id, created_at, 'ACTIVE' FROM test_table;
SELECT bif:exec('SELECT COUNT(*) FROM test_table WHERE value IS NOT NULL;
');
SELECT bif:exec('INSERT INTO transaction_logs (log_id, transaction_time, status) VALUES ((SELECT COALESCE(MAX(log_id), 0) + 1 FROM transaction_logs), CURRENT_TIMESTAMP, ''COMPLETED'');
');
SELECT txn_killall(1), bif:exec('SELECT value FROM test_table WHERE id = (SELECT MIN(id) FROM test_table WHERE value IS NOT NULL LIMIT 1);
');
SELECT txn_killall(1) FROM test_table WHERE id BETWEEN (SELECT MIN(id) FROM test_table) AND (SELECT MAX(id) FROM test_table);