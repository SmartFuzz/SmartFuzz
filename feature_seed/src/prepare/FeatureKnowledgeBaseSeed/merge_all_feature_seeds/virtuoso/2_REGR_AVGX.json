CREATE TABLE regression_data (id INT PRIMARY KEY, x_value FLOAT, y_value FLOAT);
INSERT INTO regression_data (id, x_value, y_value) VALUES (1, 1.0, NULL), (2, NULL, 2.0), (3, 2.0, 4.0), (4, 3.0, 6.0), (5, 4.0, 8.0);
SELECT REGR_AVGX(x_value) OVER (ORDER BY id) AS avg_x FROM regression_data WHERE y_value >= (SELECT COUNT(*) FROM regression_data) / 2;
SELECT id, x_value, y_value FROM regression_data WHERE y_value >= REGR_AVGX(x_value) AND x_value IS NOT NULL;
SELECT REGR_AVGX(x_value) FROM (SELECT x_value, y_value FROM regression_data WHERE y_value IS NOT NULL) AS subquery HAVING COUNT(*) > 1;
SELECT REGR_AVGX(x_value) AS avg_x FROM regression_data WHERE x_value >= 0 ORDER BY x_value DESC;
SELECT REGR_AVGX(x_value) FROM regression_data WHERE id IN (SELECT id FROM regression_data WHERE x_value >= 3) GROUP BY x_value HAVING COUNT(y_value) >= 1;
SELECT REGR_AVGX(x_value) FROM regression_data WHERE (x_value + 1.0) >= (SELECT AVG(x_value) FROM regression_data WHERE y_value IS NOT NULL);
SELECT AVG(REGR_AVGX(x_value)) FROM (SELECT x_value, y_value FROM regression_data) AS temp WHERE y_value IS NOT NULL;
SELECT REGR_AVGX(x_value) FROM regression_data WHERE x_value IN (SELECT DISTINCT x_value FROM regression_data WHERE y_value <= 5) HAVING MAX(y_value) >= 6;