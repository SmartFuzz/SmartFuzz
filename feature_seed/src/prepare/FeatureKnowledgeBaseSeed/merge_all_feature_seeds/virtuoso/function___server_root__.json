SELECT server_root();
SELECT server_root(), virtuoso_ini_path();
SELECT COUNT(*) FROM (SELECT server_root() AS root FROM DUAL) AS subquery;
SELECT a.root, b.ini_path FROM (SELECT server_root() AS root FROM DUAL) AS a JOIN (SELECT virtuoso_ini_path() AS ini_path FROM DUAL) AS b ON a.root IS NOT NULL;
CREATE TABLE test_server_root (id INT, root_path VARCHAR(255));
INSERT INTO test_server_root (id, root_path) VALUES (1, server_root());
SELECT * FROM test_server_root WHERE root_path = server_root();
SELECT server_root() AS dir, LENGTH(server_root()) AS path_length FROM DUAL;
WITH server_info AS (SELECT server_root() AS root) SELECT root FROM server_info WHERE root IS NOT NULL;
SELECT DISTINCT server_root() FROM (SELECT server_root() FROM DUAL UNION ALL SELECT server_root() FROM DUAL) AS combined_paths;