CREATE TABLE TestTable (ID INT, Data VARCHAR(255), Class URI);
INSERT INTO TestTable (ID, Data, Class) VALUES (1, 'ExampleData', <http://example.org/Class>);
INSERT INTO TestTable (ID, Data, Class) VALUES (2, NULL, <http://example.org/Class>);
INSERT INTO TestTable (ID, Data, Class) VALUES (3, '', <http://example.org/Class>);
INSERT INTO TestTable (ID, Data, Class) VALUES (4, 'AnotherExample', <http://example.org/DifferentClass>);
SELECT md5_final(MD5_CTX_INIT) AS checksum FROM (SELECT a ?s FROM TestTable WHERE Data IS NOT NULL) AS aliasedSub;
SELECT COUNT(*) FROM (SELECT a ?s FROM TestTable WHERE Data IS NOT NULL GROUP BY Data HAVING COUNT(Data) > 1) AS derivedTable;
SELECT Data, md5_final(MD5_CTX_INIT) FROM TestTable WHERE Data LIKE '%' + CAST(2 AS VARCHAR) + '%' ORDER BY Data;
SELECT a ?s FROM (SELECT ID, Data FROM TestTable WHERE Data IS NOT NULL OR Data = '') AS subquery WHERE ID IN (SELECT ID FROM TestTable WHERE Class = <http://example.org/Class> AND Data IS NOT NULL);
SELECT md5_final(MD5_CTX_INIT) FROM TestTable WHERE Data IS NULL UNION SELECT md5_final(MD5_CTX_INIT) FROM TestTable WHERE TRIM(Data) = '';
SELECT Data, COUNT(*) OVER (PARTITION BY md5_final(MD5_CTX_INIT)) FROM TestTable WHERE a ?s;
SELECT a ?s, COUNT(*) FROM TestTable WHERE Data IN (SELECT Data FROM TestTable WHERE CLASS = <http://example.org/Class>) GROUP BY a ?s HAVING COUNT(Data) > 1;
CREATE TEMPORARY TABLE TempTable AS SELECT Data, a ?s FROM TestTable WHERE Data IS NOT NULL;
SELECT md5_final(MD5_CTX_INIT) FROM TestTable WHERE EXISTS (SELECT 1 FROM TempTable WHERE TempTable.Data = TestTable.Data);