CREATE TABLE csv.tutorial.contacts (Id INTEGER NOT NULL, Fname VARCHAR(20), Sname VARCHAR(20), Age INTEGER, CONSTRAINT demo_table_pk PRIMARY KEY (Id));
CREATE TABLE csv.tutorial.backup_contacts (Id INTEGER NOT NULL, Fname VARCHAR(20), Sname VARCHAR(20), Age INTEGER, CONSTRAINT backup_table_pk PRIMARY KEY (Id));
