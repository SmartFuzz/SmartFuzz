CREATE TABLE test_table (id INT PRIMARY KEY, data XML, value VARCHAR(255), num_value INT);
INSERT INTO test_table (id, data, value, num_value) VALUES (1, '<root><item>value1</item></root>', 'test', 10);
INSERT INTO test_table (id, data, value, num_value) VALUES (2, '<root><item>value2</item></root>', NULL, NULL);
SELECT * FROM test_table WHERE xmlsql_update(data, '<root><item>value3</item></root>', id) IS NULL;
UPDATE test_table SET value = 'updated' WHERE IS NULL AND num_value IS NOT NULL;
SELECT id, xmlsql_update(data, '<root><item>value1_updated</item></root>', id) AS updated_data FROM test_table WHERE value IS NULL;
SELECT id FROM (SELECT id, COUNT(value) OVER () AS total FROM test_table) AS sub WHERE total IS NULL;
INSERT INTO test_table (id, data, value, num_value) VALUES (3, NULL, 'test', 20);
UPDATE test_table SET data = xmlsql_update(data, '<root><item>value4</item></root>', id) WHERE id = 3 AND value IS NULL;
SELECT COUNT(*) FROM test_table WHERE (SELECT COUNT(*) FROM test_table) IS NULL;
SELECT id, data FROM test_table WHERE xmlsql_update(data, '<root><item>value5</item></root>', id) IS NULL GROUP BY id HAVING COUNT(value) > 0;