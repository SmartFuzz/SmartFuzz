CREATE TABLE test_log (value FLOAT);
INSERT INTO test_log (value) VALUES (0.513513);
INSERT INTO test_log (value) VALUES (1.0);
INSERT INTO test_log (value) VALUES (2.718281828459045);
INSERT INTO test_log (value) VALUES (0.0);
INSERT INTO test_log (value) VALUES (-1.0);
INSERT INTO test_log (value) VALUES (100.0);
INSERT INTO test_log (value) VALUES (0.0001);
SELECT CONCAT('the LOG of ', value, ' is: ', CAST(log(value) AS VARCHAR)) FROM test_log WHERE value > 0;
SELECT CONCAT('the LOG of 1 is: ', CAST(log(1) AS VARCHAR));
SELECT CONCAT('the LOG of 2 is: ', CAST(log(2) AS VARCHAR));
SELECT CONCAT('the LOG of e is: ', CAST(log(EXP(1)) AS VARCHAR));
SELECT t1.value, CONCAT('the LOG of ', t1.value, ' is: ', CAST(log(t1.value) AS VARCHAR)) AS log_value FROM test_log t1 INNER JOIN (SELECT value FROM test_log WHERE value > 0) t2 ON t1.value = t2.value;
SELECT CONCAT('the LOG of (', t1.value, '+', t2.value, ') is: ', CAST(log(t1.value + t2.value) AS VARCHAR)) FROM test_log t1, test_log t2 WHERE t1.value > 0 AND t2.value > 0 LIMIT 5;
SELECT CONCAT('the LOG of MAX value is: ', CAST(log(MAX(value)) AS VARCHAR)) FROM test_log WHERE value > 0;