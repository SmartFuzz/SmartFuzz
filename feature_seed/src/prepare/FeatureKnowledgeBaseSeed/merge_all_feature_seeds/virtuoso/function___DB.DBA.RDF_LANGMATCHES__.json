CREATE TABLE DB.DBA.RDF_QUAD (S VARCHAR, P VARCHAR, O VARCHAR);
INSERT INTO DB.DBA.RDF_QUAD (S, P, O) VALUES (DB.DBA.RDF_MAKE_IID_OF_QNAME_SAFE('http://example.org/#x'), 'label', 'en');
INSERT INTO DB.DBA.RDF_QUAD (S, P, O) VALUES (DB.DBA.RDF_MAKE_IID_OF_QNAME_SAFE('http://example.org/#y'), 'label', 'fr');
INSERT INTO DB.DBA.RDF_QUAD (S, P, O) VALUES (DB.DBA.RDF_MAKE_IID_OF_QNAME_SAFE('http://example.org/#z'), 'label', 'es');
SELECT DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ('en'), 'en');
SELECT DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ('fr'), 'fr');
SELECT DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ('es'), 'en');
SELECT DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ('de'), '*') AS lang_match FROM DB.DBA.RDF_QUAD WHERE S = DB.DBA.RDF_MAKE_IID_OF_QNAME_SAFE('http://example.org/#z');
SELECT COUNT(*) FROM (SELECT DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(O), '*') AS lang_match FROM DB.DBA.RDF_QUAD) AS subquery WHERE lang_match = 1;
SELECT a.P, b.O FROM DB.DBA.RDF_QUAD AS a JOIN DB.DBA.RDF_QUAD AS b ON a.S = b.S WHERE DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(a.O), 'en') AND DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(b.O), '*');
SELECT DISTINCT S FROM DB.DBA.RDF_QUAD WHERE DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(O), 'fr') OR DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(O), 'es');
SELECT P, O FROM DB.DBA.RDF_QUAD WHERE S IN (SELECT S FROM DB.DBA.RDF_QUAD WHERE DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(O), 'en')) AND DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(O), 'fr');
SELECT COUNT(*) FROM DB.DBA.RDF_QUAD WHERE DB.DBA.RDF_LANGMATCHES(DB.DBA.RDF_LANGUAGE_OF_OBJ(O), 'de') AND S = DB.DBA.RDF_MAKE_IID_OF_QNAME_SAFE('http://example.org/#x');