CREATE TABLE remote_test_table (id INT, name VARCHAR(255), age INT);
CREATE TABLE local_test_table (id INT, description TEXT, remote_id INT);
INSERT INTO remote_test_table (id, name, age) VALUES (1, 'John Doe', 30);
INSERT INTO local_test_table (id, description, remote_id) VALUES (1, 'Description for John', 1);
CALL sql_gettypeinfo('remote_data_source', SQL_ALL_TYPES);
CALL sql_gettypeinfo('remote_data_source', 1);
CALL sql_gettypeinfo('remote_data_source', 12);
SELECT * FROM sql_gettypeinfo('remote_data_source');
SELECT * FROM local_test_table WHERE remote_id = (SELECT id FROM remote_test_table WHERE name = 'John Doe');
SELECT a.id, a.name, b.description FROM remote_test_table a JOIN local_test_table b ON a.id = b.remote_id;
SELECT COUNT(*) FROM sql_gettypeinfo('unknown_dsn');
SELECT * FROM sql_gettypeinfo('remote_data_source', 9999);
SELECT * FROM (SELECT * FROM sql_gettypeinfo('remote_data_source', SQL_ALL_TYPES) AS types) AS type_info WHERE types.type_name IS NOT NULL;
SELECT types.type_name, COUNT(*) FROM sql_gettypeinfo('remote_data_source') AS types GROUP BY types.type_name HAVING COUNT(*) > 0;