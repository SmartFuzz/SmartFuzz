CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255) NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, value) VALUES (1, 'Test'), (2, NULL), (3, 'EdgeCase'), (4, 'ValueLessThan2');
SELECT soap_print_box(value) AS xml_value FROM test_table WHERE soap_print_box(value) > soap_print_box('');
SELECT id, soap_print_box(value) FROM test_table WHERE id > (SELECT MAX(id) FROM test_table WHERE value IS NOT NULL) ORDER BY id;
SELECT soap_print_box(MIN(NULLIF(value, 'ValueLessThan2'))) FROM test_table GROUP BY value HAVING MIN(id) > 2;
SELECT id, soap_print_box(value) FROM (SELECT id, value FROM test_table WHERE value IS NOT NULL) AS subquery WHERE id > (SELECT COUNT(*) FROM test_table WHERE value IS NULL);
CREATE TABLE another_table (ref_id INT REFERENCES test_table(id), ref_value VARCHAR(100));
INSERT INTO another_table (ref_id, ref_value) VALUES (1, 'Reference1'), (2, NULL), (3, 'ReferenceEdgeCase');
SELECT soap_print_box(a.ref_value) FROM another_table a JOIN test_table b ON soap_print_box(a.ref_value) > soap_print_box(b.value) WHERE b.created_at < '2023-01-01';
SELECT soap_print_box(value) FROM test_table WHERE value IS NULL OR soap_print_box(value) > soap_print_box('Test');