CREATE TABLE ftp_test (id INTEGER PRIMARY KEY, status VARCHAR(20), file_name VARCHAR(255));
INSERT INTO ftp_test (status, file_name) VALUES ('init', 'virtuoso30.tar.gz');
SELECT ftp_put('ftp.openlinksw.com', 'user_name', 'password', 'virtuoso30.tar.gz', 'virtuoso30.tar.gz') AS result;
UPDATE ftp_test SET status = 'in_progress' WHERE file_name = 'virtuoso30.tar.gz';
SELECT ftp_put(ftp_host, ftp_user, ftp_password, file_name, file_name) FROM (SELECT 'ftp.openlinksw.com' AS ftp_host, 'user_name' AS ftp_user, 'password' AS ftp_password, file_name FROM ftp_test) AS ftp_params;
DELETE FROM ftp_test WHERE id = (SELECT id FROM ftp_test WHERE file_name = 'virtuoso30.tar.gz' LIMIT 1);
SELECT (SELECT ftp_put('ftp.openlinksw.com', 'user_name', 'password', file_name, file_name) FROM ftp_test WHERE status = 'init') AS ftp_result;
CREATE TABLE user_credentials (username VARCHAR(50), password VARCHAR(50));
INSERT INTO user_credentials (username, password) VALUES ('user_name', 'password');
SELECT ftp_put('ftp.openlinksw.com', (SELECT username FROM user_credentials WHERE username = 'user_name'), (SELECT password FROM user_credentials WHERE username = 'user_name'), 'virtuoso30.tar.gz', 'virtuoso30.tar.gz') AS result;
UPDATE ftp_test SET status = 'completed' WHERE file_name = (SELECT file_name FROM ftp_test WHERE id = 1);
SELECT * FROM ftp_test WHERE status IN (SELECT status FROM ftp_test WHERE status LIKE 'in_%');