CREATE TABLE test_data (id INT, value VARCHAR(255));
INSERT INTO test_data (id, value) VALUES (1, 'A'), (2, NULL), (3, 'B'), (4, NULL), (5, 'C');
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM test_data;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM test_data WHERE value IS NOT NULL;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM test_data WHERE id > 3;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM test_data WHERE value IS NULL;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(subquery.value) FROM (SELECT value FROM test_data ORDER BY id) AS subquery;
CREATE TABLE additional_data (id INT, ref_id INT, value VARCHAR(255));
INSERT INTO additional_data (id, ref_id, value) VALUES (1, 1, 'D'), (2, 2, NULL), (3, 1, NULL), (4, 3, 'E');
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(a.value) FROM test_data AS a JOIN additional_data AS b ON a.id = b.ref_id WHERE b.value IS NOT NULL;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(a.value) FROM test_data AS a LEFT JOIN additional_data AS b ON a.id = b.ref_id GROUP BY a.id;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(CASE WHEN value IS NULL THEN 'Fallback' ELSE value END) FROM test_data;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM (SELECT value FROM test_data WHERE id IN (SELECT ref_id FROM additional_data WHERE value IS NOT NULL)) AS subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM test_data UNION SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM additional_data;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(value) FROM (SELECT value FROM test_data ORDER BY id DESC LIMIT 3) AS subquery;
SELECT DB.DBA.VECTOR_OF_NONNULLS_OR_NULL_AGG(subquery.value) FROM (SELECT value FROM test_data WHERE value IS NOT NULL) AS subquery WHERE EXISTS (SELECT 1 FROM additional_data WHERE additional_data.ref_id = test_data.id);