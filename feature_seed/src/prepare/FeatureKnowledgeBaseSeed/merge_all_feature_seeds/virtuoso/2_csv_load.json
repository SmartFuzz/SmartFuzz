CREATE TABLE test_csv_load (id INTEGER, data VARCHAR, created_at TIMESTAMP DEFAULT NOW());
INSERT INTO test_csv_load (id, data) VALUES (1, 'test_data_1'), (2, 'test_data_2');
CREATE PROCEDURE load_and_hash_csv (IN file_name VARCHAR) BEGIN DECLARE tb_name VARCHAR;
DECLARE sess ANY;
DECLARE ar ANY;
sess := file_open(file_name);
ar := csv_table_def(file_name);
ar := split_and_decode(ar, 0, '\0\0');
tb_name := trim(ar[2], '"');
exec(csv_table_def(file_name));
csv_load(sess, 0, NULL, concat('DB.DBA.', tb_name));
SELECT bif:crc64(data) FROM DB.DBA.test_csv_load;
END;
SELECT id, bif:crc64(data) AS hash FROM (SELECT id, data FROM test_csv_load WHERE id IS NOT NULL) AS subquery WHERE hash IS NOT NULL;
DROP TABLE IF EXISTS temp_table;
CREATE TABLE temp_table (id INTEGER PRIMARY KEY, value VARCHAR);
INSERT INTO temp_table (id, value) VALUES (1, 'A'), (2, 'B'), (3, NULL);
SELECT value, bif:crc64(COALESCE(value, 'NULL')) FROM temp_table WHERE bif:crc64(value) IS NOT NULL;
SELECT DISTINCT t1.id, (SELECT bif:crc64(value) FROM temp_table AS t2 WHERE t1.id = t2.id) AS value_hash FROM temp_table AS t1 WHERE id IS NOT NULL;
SELECT COUNT(*) FROM test_csv_load WHERE bif:crc64(data) IS NOT NULL GROUP BY data HAVING COUNT(data) > 1;
CREATE PROCEDURE test_procedure (IN file_name VARCHAR) BEGIN DECLARE result VARCHAR;
SET result = (SELECT bif:crc64(CONCAT('File loaded: ', file_name)));
CALL load_and_hash_csv(file_name);
SELECT result AS process_result;
END;