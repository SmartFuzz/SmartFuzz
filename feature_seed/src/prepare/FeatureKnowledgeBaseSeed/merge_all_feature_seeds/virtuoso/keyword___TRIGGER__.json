CREATE TABLE article (id INT PRIMARY KEY, title VARCHAR(255), content TEXT);
CREATE TABLE audit_log (op VARCHAR(10), id INT, log_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
CREATE TRIGGER trg_ins_article AFTER INSERT ON article FOR EACH ROW BEGIN INSERT INTO audit_log (op, id) VALUES ('INS', NEW.id);
END;
CREATE TRIGGER trg_upd_article BEFORE UPDATE ON article FOR EACH ROW REFERENCING OLD AS old_row NEW AS new_row BEGIN INSERT INTO audit_log (op, id) VALUES ('UPD', old_row.id);
END;
CREATE TRIGGER trg_del_article AFTER DELETE ON article FOR EACH ROW BEGIN INSERT INTO audit_log (op, id) VALUES ('DEL', OLD.id);
END;
CREATE TRIGGER trg_ins_multi_table AFTER INSERT ON article FOR EACH ROW BEGIN INSERT INTO audit_log (op, id) VALUES ('INS', NEW.id);
INSERT INTO other_table (related_id) VALUES (NEW.id);
END;
CREATE TRIGGER trg_upd_conditional BEFORE UPDATE ON article FOR EACH ROW WHEN NEW.title IS NOT NULL BEGIN INSERT INTO audit_log (op, id) VALUES ('UPD', OLD.id);
END;
CREATE TRIGGER trg_ins_complex AFTER INSERT ON article FOR EACH ROW BEGIN DECLARE num_rows INT;
SELECT COUNT(*) INTO num_rows FROM article;
IF num_rows > 100 THEN INSERT INTO audit_log (op, id) VALUES ('EXCEEDS_LIMIT', NEW.id);
END IF;
END;
DROP TRIGGER trg_ins_article ON article;
DROP TRIGGER trg_upd_article ON article;
DROP TRIGGER trg_del_article ON article;
DROP TRIGGER trg_ins_multi_table ON article;
DROP TRIGGER trg_upd_conditional ON article;
DROP TRIGGER trg_ins_complex ON article;