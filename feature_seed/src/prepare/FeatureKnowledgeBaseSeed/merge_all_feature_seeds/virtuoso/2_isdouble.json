CREATE TABLE test_data (id SERIAL PRIMARY KEY, num_col DOUBLE PRECISION, str_col VARCHAR(255), nullable_col DOUBLE PRECISION NULL);
INSERT INTO test_data (num_col, str_col, nullable_col) VALUES (1.5, 'test', NULL), (2.3, 'double precision', 3.9), (NULL, 'null value', NULL);
SELECT id, isdouble(num_col + COALESCE(nullable_col, 0)) AS is_double_result FROM test_data;
SELECT id, num_col + 5 AS sum_result FROM test_data WHERE isdouble(num_col + 5) = 1;
SELECT id, str_col, isdouble((num_col + 2.0) / NULLIF(nullable_col, 0)) AS is_double_calculation FROM test_data;
SELECT id, AVG(num_col) OVER (PARTITION BY str_col) AS avg_num_per_str FROM test_data GROUP BY id, str_col HAVING isdouble(avg_num_per_str) = 1;
INSERT INTO test_data (num_col, str_col, nullable_col) VALUES (1.0, 'boundary test', 0.0), (1e-10, 'small value', NULL);
SELECT id, isdouble(num_col + (SELECT MAX(num_col) FROM test_data WHERE str_col LIKE 'double%')) AS complex_case FROM test_data;
SELECT id, isdouble(CASE WHEN num_col IS NOT NULL THEN num_col + 100 ELSE 0 END) AS case_is_double FROM test_data;
CREATE TABLE temp_data AS SELECT id, str_col, num_col + NULLIF(nullable_col, 0) AS calculated_col FROM test_data;
SELECT id, isdouble(num_col + (SELECT SUM(calculated_col) FROM temp_data)) AS total_is_double FROM temp_data;