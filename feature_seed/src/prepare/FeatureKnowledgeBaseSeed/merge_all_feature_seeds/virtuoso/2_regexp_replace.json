CREATE TABLE fuzz_test (id INT PRIMARY KEY, text_col VARCHAR(255), num_col INT, date_col DATE);
INSERT INTO fuzz_test (id, text_col, num_col, date_col) VALUES (1, '     multiple     spaces     here    ', 15, '2023-01-01');
INSERT INTO fuzz_test (id, text_col, num_col, date_col) VALUES (2, 'single space here', 5, NULL);
INSERT INTO fuzz_test (id, text_col, num_col, date_col) VALUES (3, 'text with digits 123456', 25, '2022-12-31');
INSERT INTO fuzz_test (id, text_col, num_col, date_col) VALUES (4, NULL, 8, '2023-03-01');
SELECT DISTINCT id, REGEXP_REPLACE(text_col, '( ){2,}', ' ') AS normalized_text FROM fuzz_test WHERE num_col NOT BETWEEN 1 AND 20 ORDER BY normalized_text;
SELECT t1.id, t1.text_col, REGEXP_REPLACE(t1.text_col, '( ){2,}', ' ') AS cleaned_text FROM fuzz_test t1 JOIN fuzz_test t2 ON t1.num_col = t2.num_col AND t1.text_col IS NOT NULL WHERE t1.date_col NOT BETWEEN '2022-01-01' AND '2023-01-01';
SELECT COUNT(*) AS count FROM (SELECT id, REGEXP_REPLACE(text_col, '( ){2,}', ' ') AS modified_text FROM fuzz_test HAVING modified_text IS NOT NULL AND modified_text NOT BETWEEN 'a' AND 'z') AS derived_table;
CREATE TABLE additional_test (another_col INT, reference_id INT, FOREIGN KEY (reference_id) REFERENCES fuzz_test(id));
INSERT INTO additional_test (another_col, reference_id) VALUES (1, 1), (2, NULL), (3, 2);
SELECT a.another_col, a.reference_id, REGEXP_REPLACE(ft.text_col, '( ){2,}', ' ') AS cleaned_text FROM additional_test a LEFT JOIN fuzz_test ft ON a.reference_id = ft.id WHERE ft.id NOT BETWEEN 2 AND 3 ORDER BY cleaned_text;
SELECT CASE WHEN NULL IS NOT NULL THEN 'Should not occur' ELSE REGEXP_REPLACE(text_col, '( ){2,}', '') END AS check_case FROM fuzz_test WHERE text_col NOT BETWEEN 'start' AND 'end';