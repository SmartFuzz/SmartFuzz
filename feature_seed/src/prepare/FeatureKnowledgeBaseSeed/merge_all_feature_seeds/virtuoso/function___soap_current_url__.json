CREATE TABLE resources (id INT PRIMARY KEY, url VARCHAR(255), host VARCHAR(255));
INSERT INTO resources (id, url, host) VALUES (1, 'http://example.com/resource1', 'example.com');
INSERT INTO resources (id, url, host) VALUES (2, 'http://example.com/resource2', NULL);
SELECT soap_current_url() AS current_url FROM resources WHERE id = 1;
SELECT soap_current_url() AS current_url FROM resources WHERE id = 2;
SELECT r1.url, r2.host FROM resources r1 JOIN resources r2 ON r1.id = r2.id WHERE r1.id = 1;
UPDATE resources SET host = '192.168.1.1' WHERE id = 2;
SELECT soap_current_url() AS current_url FROM (SELECT * FROM resources WHERE host IS NOT NULL) AS t;
SELECT soap_current_url() AS current_url FROM resources WHERE url LIKE 'http://%';
SELECT soap_current_url() AS current_url FROM resources WHERE id = (SELECT MAX(id) FROM resources);
DELETE FROM resources WHERE id = 3;
SELECT COUNT(*) FROM (SELECT DISTINCT host FROM resources) AS distinct_hosts;
INSERT INTO resources (id, url, host) VALUES (3, 'http://example.com/resource3', 'example.com');
SELECT r.url FROM resources r WHERE r.host IN (SELECT DISTINCT host FROM resources);