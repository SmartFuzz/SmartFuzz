CREATE GRAPH <http://example.org/testGraph>;
DB.DBA.RDF_LOAD_RDFXML(file_to_string('testData/small.rdf'), '', 'http://example.org/testGraph');
DB.DBA.RDF_LOAD_RDFXML(file_to_string('testData/medium.rdf'), '', 'http://example.org/testGraph');
DB.DBA.RDF_LOAD_RDFXML(file_to_string('testData/large.rdf'), '', 'http://example.org/testGraph');
SELECT COUNT(*) FROM <http://example.org/testGraph> WHERE {?s ?p ?o};
SPARQL SELECT ?s ?p ?o WHERE {?s ?p ?o} ORDER BY ?s LIMIT 10;
INSERT DATA { GRAPH <http://example.org/testGraph> { <http://example.org/subject1> <http://example.org/predicate1> <http://example.org/object1> } };
DELETE WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o } };
SPARQL SELECT ?s WHERE { GRAPH <http://example.org/testGraph> { ?s ?p <http://example.org/object1> } };
DB.DBA.RDF_LOAD_RDFXML(http_get('http://example.org/ontology/example.owl'), '', 'http://example.org/testGraph');
CREATE GRAPH <http://example.org/anotherGraph>;
DB.DBA.RDF_LOAD_RDFXML(file_to_string('testData/complex.rdf'), '', 'http://example.org/anotherGraph');
SELECT COUNT(*) FROM <http://example.org/anotherGraph> WHERE {?s ?p ?o} HAVING (COUNT(?o) > 5);
SPARQL SELECT ?s COUNT(?o) AS ?objectCount WHERE { GRAPH <http://example.org/anotherGraph> { ?s ?p ?o } } GROUP BY ?s HAVING (?objectCount > 1);