CREATE SEQUENCE my_sequence;
SELECT sequence_next('my_sequence');
SELECT sequence_next('my_sequence');
SELECT sequence_next('my_sequence');
SELECT sequence_remove('my_sequence');
SELECT sequence_next('my_sequence');
CREATE SEQUENCE test_sequence;
INSERT INTO my_table (id) VALUES (1);
SELECT sequence_set('test_sequence', 5);
SELECT sequence_next('test_sequence');
SELECT sequence_remove('test_sequence');
SELECT sequence_next('test_sequence');
CREATE SEQUENCE another_sequence;
SELECT sequence_next('another_sequence');
SELECT COUNT(*) FROM (SELECT sequence_next('another_sequence') AS seq_value) AS seq_table;
CREATE VIEW sequence_view AS SELECT sequence_next('another_sequence') AS seq_value;
SELECT * FROM sequence_view;
SELECT sequence_remove('another_sequence');
SELECT * FROM sequence_view;
SELECT sequence_next('another_sequence');
CREATE SEQUENCE nested_sequence;
SELECT (SELECT sequence_next('nested_sequence')) AS inner_seq_value;
SELECT sequence_remove('nested_sequence');
SELECT (SELECT sequence_next('nested_sequence')) AS inner_seq_value_after_removal;