CREATE TABLE tModels (id INTEGER PRIMARY KEY, name VARCHAR(100), criteria VARCHAR(255), creation_date TIMESTAMP);
INSERT INTO tModels (id, name, criteria, creation_date) VALUES (1, 'Model A', 'criteria1', '2023-01-01 00:00:00');
INSERT INTO tModels (id, name, criteria, creation_date) VALUES (2, 'Model B', 'criteria2', '2023-01-02 00:00:00');
INSERT INTO tModels (id, name, criteria, creation_date) VALUES (3, 'Model C', NULL, '2023-01-03 00:00:00');
INSERT INTO tModels (id, name, criteria, creation_date) VALUES (4, 'Model D', 'criteria3', NULL);
SELECT * FROM tModels WHERE id IN (SELECT id FROM tModels WHERE creation_date IS NOT NULL);
SELECT uddi_find_tModel(name) FROM (SELECT name FROM tModels WHERE criteria IN ('criteria1', 'criteria2')) AS valid_criteria;
SELECT * FROM tModels WHERE criteria IS NULL OR criteria IN (SELECT criteria FROM tModels WHERE id = 3);
SELECT COUNT(*) FROM tModels WHERE creation_date IN (SELECT MAX(creation_date) FROM tModels GROUP BY criteria) HAVING COUNT(id) > 1;
SELECT id, name FROM tModels WHERE id IN (SELECT id FROM tModels WHERE criteria LIKE 'criteria%') ORDER BY creation_date DESC;
SELECT * FROM (SELECT id, criteria FROM tModels WHERE criteria IS NOT NULL) AS subquery WHERE id IN (1, 2, 3);
CREATE TEMPORARY TABLE tempModels AS SELECT * FROM tModels WHERE criteria IS NOT NULL;
UPDATE tModels SET criteria = NULL WHERE id IN (SELECT id FROM tempModels WHERE name IN ('Model A', 'Model C'));
SELECT name, (SELECT COUNT(*) FROM tModels) AS total FROM tModels WHERE name IN (SELECT name FROM tModels WHERE criteria IS NOT NULL) HAVING total > 0;
SELECT uddi_find_tModel(name) FROM tModels WHERE name IN (SELECT name FROM tModels WHERE id IN (1, 4));
DELETE FROM tModels WHERE id IN (SELECT id FROM tModels WHERE criteria IS NULL AND (id IN (1,2,3,4)));