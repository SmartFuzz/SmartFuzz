CREATE TABLE my_news (m_id integer, m_group varchar, m_text long varchar, primary key (m_id, m_group));
CREATE PROCEDURE get_my_news (in server varchar, in grp varchar) { declare res, ent any;
declare i, l integer;
res := nntp_get (server, 'article', grp, 0, 1000);
i := 0;
l := length (res);
while (i < l) { ent := res[i];
insert replacing my_news (m_id, m_group, m_text) values (ent[0], grp, ent[1]);
i := i + 1;
} };
EXECUTE get_my_news('news.techno-link.com:119', 'comp.lang.java.api');
SELECT DISTINCT m_group FROM my_news WHERE m_id > 5;
SELECT m_id, mail_header(m_text, 'Subject') as subject FROM my_news WHERE m_group = 'comp.lang.java.api' ORDER BY m_id DESC;
SELECT COUNT(*) FROM my_news WHERE m_group IN (SELECT DISTINCT m_group FROM my_news WHERE m_id < 10);
INSERT INTO my_news (m_id, m_group, m_text) VALUES (1, 'comp.lang.java.api', 'First article text');
INSERT INTO my_news (m_id, m_group, m_text) VALUES (2, 'comp.lang.java.api', 'Second article text');
SELECT m_id, m_text FROM my_news WHERE m_text LIKE '%Java%' AND m_group = 'comp.lang.java.api' LIMIT 10;
DELETE FROM my_news WHERE m_id = (SELECT MAX(m_id) FROM my_news WHERE m_group = 'comp.lang.java.api');
UPDATE my_news SET m_text = 'Updated article text.' WHERE m_id = 1 AND m_group = 'comp.lang.java.api';
WITH latest_news AS (SELECT m_id, m_text FROM my_news WHERE m_group = 'comp.lang.java.api' ORDER BY m_id DESC LIMIT 5) SELECT * FROM latest_news WHERE m_text IS NOT NULL;
SELECT grp, COUNT(*) as total_articles FROM my_news GROUP BY grp HAVING total_articles > 1;
SELECT m_id, m_group, m_text FROM my_news WHERE m_text IS NOT NULL AND m_id IN (SELECT m_id FROM my_news WHERE m_group = 'comp.lang.java.api') ORDER BY m_group;