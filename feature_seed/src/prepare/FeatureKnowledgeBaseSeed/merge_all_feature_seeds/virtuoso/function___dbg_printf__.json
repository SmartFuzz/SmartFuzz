CREATE TABLE debug_logs (id INT PRIMARY KEY, message VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO debug_logs (message) VALUES (dbg_printf('Starting application with status: %d', 0));
SELECT * FROM debug_logs WHERE message LIKE 'Starting application%';
INSERT INTO debug_logs (message) VALUES (dbg_printf('Error: Frammitz status: %d.\nProgram terminated', 1));
INSERT INTO debug_logs (message) VALUES (dbg_printf('Connection failed: %s with error code: %d', 'Network Timeout', 1001));
SELECT COUNT(*) FROM debug_logs WHERE message LIKE 'Error:%';
INSERT INTO debug_logs (message) VALUES (dbg_printf('User %s logged in successfully at %s', 'admin', CURRENT_TIMESTAMP()));
INSERT INTO debug_logs (message) VALUES (dbg_printf('System health check: CPU usage at %.2f%%, Memory usage at %.2f%%', 75.5, 65.0));
SELECT DISTINCT message FROM debug_logs WHERE created_at > NOW() - INTERVAL '1 DAY' ORDER BY created_at DESC;
UPDATE debug_logs SET message = dbg_printf('Updated message for log ID %d', id) WHERE id = 1;
DELETE FROM debug_logs WHERE created_at < NOW() - INTERVAL '30 DAYS';
INSERT INTO debug_logs (message) VALUES (dbg_printf('Warning: High memory usage detected: %d%%', (SELECT MAX(usage) FROM memory_stats)));
SELECT message FROM debug_logs WHERE message IS NOT NULL AND message LIKE 'Warning:%' ORDER BY created_at;
WITH recent_logs AS (SELECT message FROM debug_logs WHERE created_at > NOW() - INTERVAL '2 HOURS') SELECT count(*) FROM recent_logs WHERE message LIKE '%Error%';
INSERT INTO debug_logs (message) VALUES (dbg_printf('Multi-query test: %s, %s', (SELECT status FROM system_status), (SELECT status_info FROM system_info)));