CREATE TABLE test_strings (id INT, str VARCHAR(255));
INSERT INTO test_strings (id, str) VALUES (1, 'hello'), (2, 'WORLD'), (3, ''), (4, '123abc');
SELECT str, initcap(str) AS capitalized FROM test_strings;
SELECT id, initcap(str) AS capital FROM (SELECT id, str FROM test_strings WHERE id > 0) AS subquery;
SELECT t1.id, initcap(t1.str) AS capital FROM test_strings t1 JOIN test_strings t2 ON t1.id = t2.id;
SELECT initcap(t1.str || ' ' || t2.str) AS combined_capital FROM test_strings t1, test_strings t2 WHERE t1.id <> t2.id;
SELECT initcap(COALESCE(str, 'default value')) AS capitalized FROM test_strings;
SELECT initcap(initcap(str)) AS double_capital FROM test_strings;
SELECT CASE WHEN initcap(str) <> str THEN 'Changed' ELSE 'Unchanged' END AS status FROM test_strings;
SELECT id, initcap(str) AS capitalized FROM test_strings ORDER BY capitalized ASC;