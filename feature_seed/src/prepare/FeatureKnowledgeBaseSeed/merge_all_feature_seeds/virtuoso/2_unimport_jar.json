CREATE TABLE test_table (id INT PRIMARY KEY, data NVARCHAR(255), xml_data XML);
INSERT INTO test_table (id, data, xml_data) VALUES (1, 'Test', '<root id="1"><value>Sample</value></root>');
INSERT INTO test_table (id, data, xml_data) VALUES (2, NULL, '<root id="2"><value>Null Test</value></root>');
SELECT id, data, xpath_string('/root/@id', xml_data) AS extracted_id FROM test_table WHERE data IS NOT NULL;
SELECT id, data, xpath_string('/root/value', xml_data) AS value FROM test_table WHERE id IN (SELECT id FROM test_table WHERE data IS NOT NULL);
SELECT t1.id, t1.data, t2.data AS joined_data FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.data IS NOT NULL;
SELECT id, xpath_string('/root/@id', xml_data) AS id_attr FROM test_table GROUP BY id_attr HAVING COUNT(*) > 0;
SELECT id, data, xpath_string('/root/value', xml_data) AS value FROM test_table ORDER BY value;
SELECT id, data, xpath_string('/root/@id', xml_data) AS extracted_id FROM test_table WHERE extracted_id::INT IS NOT NULL;
SELECT unimport_jar(NULL, vector('java.lang.System')) AS result from dual;
SELECT id, xml_data, unimport_jar(NULL, vector('java.lang.System')) FROM test_table WHERE xpath_string('/root/@id', xml_data) = '1';
CREATE TEMPORARY TABLE temp_table AS SELECT id, data FROM test_table WHERE data IS NOT NULL;
INSERT INTO temp_table (id, data) SELECT id, unimport_jar(NULL, vector('java.lang.System')) FROM test_table;
SELECT id, xpath_string('/root/value', xml_data) AS value FROM test_table WHERE value IS NOT NULL;