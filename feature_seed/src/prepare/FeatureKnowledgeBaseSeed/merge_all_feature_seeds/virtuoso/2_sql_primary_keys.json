CREATE TABLE Orders (OrderID INT, CustomerName VARCHAR(255), OrderDate DATE NULL, Amount DECIMAL(10, 2));
INSERT INTO Orders (OrderID, CustomerName, OrderDate, Amount) VALUES (1, 'John Doe', '2023-01-01', 150.75);
INSERT INTO Orders (OrderID, CustomerName, OrderDate, Amount) VALUES (2, 'Jane Smith', NULL, 200.50);
SELECT sql_primary_keys('Local Virtuoso', 'Demo', NULL, 'Orders'), xpath_integer('<data><value>3</value></data>', '/data/value') AS ExtractedValue;
SELECT COUNT(*), AVG(Amount) AS AverageAmount FROM Orders WHERE Amount IS NOT NULL GROUP BY CustomerName HAVING AVG(Amount) > (SELECT AVG(Amount) FROM Orders) ORDER BY AverageAmount DESC;
SELECT o.OrderID, o.CustomerName, o.OrderDate, o.Amount, (SELECT COUNT(*) FROM Orders WHERE OrderDate IS NOT NULL) AS TotalOrders FROM Orders o WHERE o.Amount > (SELECT AVG(Amount) FROM Orders) OR o.CustomerName LIKE 'J%';
SELECT o.CustomerName, o.Amount, COUNT(*) OVER (PARTITION BY o.CustomerName ORDER BY o.OrderDate) AS CountByCustomer FROM Orders o WHERE o.OrderDate >= '2023-01-01' AND o.Amount IS NOT NULL;
SELECT * FROM (SELECT sql_primary_keys('Local Virtuoso', 'Demo', NULL, 'Orders') as KeyInfo) AS PKInfo WHERE xpath_integer(KeyInfo, '/data/value') > 0;