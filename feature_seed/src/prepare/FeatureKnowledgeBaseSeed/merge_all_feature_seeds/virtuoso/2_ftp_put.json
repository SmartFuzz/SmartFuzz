CREATE TABLE ftp_tests (id INT PRIMARY KEY, file_name VARCHAR(255), file_size INT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO ftp_tests (id, file_name, file_size) VALUES (1, 'virtuoso30.tar.gz', 1024);
INSERT INTO ftp_tests (id, file_name, file_size) VALUES (2, '', 256);
INSERT INTO ftp_tests (id, file_name, file_size) VALUES (3, 'empty_file.txt', 0);
INSERT INTO ftp_tests (id, file_name, file_size) VALUES (4, NULL, NULL);
SELECT ftp_put('ftp.openlinksw.com', 'user_name', 'password', (SELECT file_name FROM ftp_tests WHERE file_size >= 0), 'output.txt') AS upload_result;
SELECT file_name FROM ftp_tests WHERE created_at >= (SELECT MAX(created_at) FROM ftp_tests) OR file_size < 512;
SELECT file_name, COUNT(*) FROM ftp_tests GROUP BY file_name HAVING COUNT(*) >= 1;
SELECT ftp_put('ftp.openlinksw.com', 'user_name', 'password', (SELECT MAX(file_size) FROM ftp_tests WHERE file_size IS NOT NULL), 'output_max_size.txt') WHERE (SELECT COUNT(*) FROM ftp_tests) >= 2;
CREATE TABLE ftp_requests (request_id INT PRIMARY KEY, response_code INT, request_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO ftp_requests (request_id, response_code) VALUES (1, 200);
INSERT INTO ftp_requests (request_id, response_code) VALUES (2, 404);
SELECT ftp_put('ftp.openlinksw.com', 'user_name', 'password', (SELECT 'upload_' || file_name FROM ftp_tests WHERE response_code >= 200), 'combined_output.txt') AS combined_upload;
SELECT file_name FROM ftp_tests WHERE file_size >= (SELECT AVG(file_size) FROM ftp_tests) AND file_name IS NOT NULL;
SELECT file_name FROM ftp_tests WHERE file_size IS NULL OR (SELECT COUNT(*) FROM ftp_requests WHERE request_id >= 1) > 0;
SELECT file_name, ftp_put('ftp.openlinksw.com', 'user_name', 'password', file_name, 'uploaded_' || file_name) FROM ftp_tests WHERE file_size >= (SELECT MIN(file_size) FROM ftp_tests) ORDER BY file_size DESC;