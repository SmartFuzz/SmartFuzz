CREATE TABLE rsa_keys (id INT PRIMARY KEY, key_name VARCHAR(255) NOT NULL, key_data VARCHAR(5000), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO rsa_keys (id, key_name, key_data) VALUES (1, 'MyRSAkey', 'MIG..skipped..MBAAE=');
SELECT key_name, xenc_key_RSA_read(key_name, key_data) AS imported_key FROM rsa_keys WHERE key_data IS NOT NULL AND CHAR_LENGTH(key_data) > 10;
SELECT key_name, (SELECT COUNT(*) / NULLIF(COUNT(*), 0) FROM rsa_keys) AS ratio FROM rsa_keys HAVING ratio > 0;
INSERT INTO rsa_keys (id, key_name, key_data) VALUES (2, 'KeyWithNULL', NULL);
SELECT key_name, (SELECT xenc_key_RSA_read(key_name, key_data) FROM rsa_keys WHERE id = 1) / (SELECT 1) AS division_check FROM rsa_keys WHERE key_data IS NOT NULL;
SELECT key_name, (xenc_key_RSA_read(key_name, 'MIG..skipped..MBAAE=') / (SELECT COUNT(*) FROM rsa_keys)) AS key_ratio FROM rsa_keys GROUP BY key_name HAVING key_ratio > 0;
CREATE TEMPORARY TABLE temp_keys AS SELECT id, key_name, xenc_key_RSA_read(key_name, key_data) AS key_imported FROM rsa_keys WHERE key_data IS NOT NULL;
SELECT AVG(COALESCE(key_data::FLOAT, 0)) FROM rsa_keys GROUP BY key_name HAVING AVG(key_data::FLOAT) > 0;
SELECT key_name, key_data, xenc_key_RSA_read(key_name, key_data) AS key_imported FROM rsa_keys WHERE key_data = '' OR key_data IS NOT NULL;