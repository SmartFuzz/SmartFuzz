CREATE TABLE test_table (id INT, value VARCHAR(50));
INSERT INTO test_table (id, value) VALUES (1, 'A'), (2, 'B'), (3, 'C');
SELECT DB.DBA.BAG_AGG(value) FROM test_table;
SELECT DB.DBA.BAG_AGG(value) FROM test_table WHERE id > 1;
SELECT DB.DBA.BAG_AGG(value) FROM test_table ORDER BY id;
CREATE TABLE second_table (ref_id INT, description VARCHAR(50));
INSERT INTO second_table (ref_id, description) VALUES (1, 'Desc1'), (2, 'Desc2'), (3, 'Desc3');
SELECT DB.DBA.BAG_AGG(t.value) FROM test_table t JOIN second_table st ON t.id = st.ref_id;
SELECT DB.DBA.BAG_AGG(value) FROM (SELECT value FROM test_table WHERE id < 3) AS subquery;
SELECT DB.DBA.BAG_AGG(value) FROM (SELECT value FROM test_table ORDER BY value ASC) AS subquery GROUP BY id;
SELECT DB.DBA.BAG_AGG(t.value) FROM test_table t JOIN (SELECT ref_id FROM second_table WHERE description LIKE 'Desc%') AS subquery ON t.id = subquery.ref_id;
CREATE TABLE third_table (category VARCHAR(50), amount INT);
INSERT INTO third_table (category, amount) VALUES ('A', 100), ('B', 200), ('C', 300);
SELECT DB.DBA.BAG_AGG(amount) FROM third_table GROUP BY category;
SELECT DB.DBA.BAG_AGG(value) FROM test_table WHERE id IN (SELECT ref_id FROM second_table);
SELECT DB.DBA.BAG_AGG(DISTINCT value) FROM test_table;
SELECT DB.DBA.BAG_AGG(value) FROM test_table UNION SELECT DB.DBA.BAG_AGG(description) FROM second_table;