CREATE TABLE TEST_XMLS (I integer primary key, XMLVAL XMLType);
INSERT INTO TEST_XMLS values (1, XMLType('<emp><empno>221</empno><ename>John</ename></emp>'));
INSERT INTO TEST_XMLS values (2, XMLType('<po><pono>331</pono><poname>PO_1</poname></po>'));
INSERT INTO TEST_XMLS values (3, XMLType('<oil-rig xml:id="14a_04" water="0.413"/><oil-rig xml:id="14b_04" water="0.402"/>'));
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM TEST_XMLS as e WHERE e.XMLVAL.getRootElement() is not null;
SELECT e.I, e.XMLVAL.getClobVal() FROM TEST_XMLS as e WHERE e.XMLVAL.getRootElement() is null;
INSERT INTO TEST_XMLS values (4, XMLType('<root><child><subchild>Text</subchild></child></root>'));
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM TEST_XMLS as e WHERE e.XMLVAL.getRootElement() is not null ORDER BY e.I;
CREATE TABLE TEST_XMLS2 (J integer primary key, XMLDATA XMLType);
INSERT INTO TEST_XMLS2 values (1, XMLType('<item><name>Widget</name><price>19.99</price></item>'));
INSERT INTO TEST_XMLS2 values (2, XMLType('<item><name>Gadget</name><price>29.99</price></item>'));
SELECT e.I, e.XMLVAL.getRootElement().getClobVal(), x.J FROM TEST_XMLS e JOIN TEST_XMLS2 x ON e.I = x.J WHERE e.XMLVAL.getRootElement() is not null;
SELECT e.I, e.XMLVAL.getClobVal() FROM TEST_XMLS as e WHERE e.XMLVAL.getRootElement() is not null UNION SELECT x.J, x.XMLDATA.getClobVal() FROM TEST_XMLS2 x WHERE x.XMLDATA.getRootElement() is not null;
INSERT INTO TEST_XMLS values (5, XMLType('<fragment><part1/><part2/></fragment>'));
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM TEST_XMLS e WHERE e.XMLVAL.getRootElement() is null ORDER BY e.I DESC;
CREATE TABLE TEST_XMLS3 (K integer primary key, XMLITEM XMLType);
INSERT INTO TEST_XMLS3 values (1, XMLType('<data><value>A</value></data>'));
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM TEST_XMLS e JOIN TEST_XMLS3 x ON e.I = x.K WHERE e.XMLVAL.getRootElement() is null;
SELECT DISTINCT e.XMLVAL.getRootElement().getClobVal() FROM TEST_XMLS e GROUP BY e.XMLVAL.getRootElement() HAVING COUNT(e.I) > 1;
INSERT INTO TEST_XMLS values (6, XMLType('<collection><item/><item/></collection>'));
SELECT e.I, e.XMLVAL.getRootElement().getClobVal() FROM TEST_XMLS e WHERE e.XMLVAL.getRootElement() is null AND LENGTH(e.XMLVAL.getClobVal()) < 50;