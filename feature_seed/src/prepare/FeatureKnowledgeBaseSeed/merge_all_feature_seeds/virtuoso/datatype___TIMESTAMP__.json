CREATE TABLE events (id INT PRIMARY KEY, event_name VARCHAR(255), event_time TIMESTAMP);
INSERT INTO events (id, event_name, event_time) VALUES (1, 'New Year Party', TIMESTAMP '2023-01-01 00:00:00');
INSERT INTO events (id, event_name, event_time) VALUES (2, 'Summer Festival', TIMESTAMP '2023-06-15 12:30:00');
INSERT INTO events (id, event_name, event_time) VALUES (3, 'Winter Wonderland', TIMESTAMP '2023-12-25 18:00:00');
SELECT * FROM events WHERE event_time > TIMESTAMP '2023-01-01 00:00:00';
SELECT e1.event_name FROM events e1 JOIN events e2 ON e1.event_time < e2.event_time WHERE e2.event_name = 'Summer Festival';
SELECT COUNT(*) FROM events WHERE event_time BETWEEN TIMESTAMP '2023-01-01 00:00:00' AND TIMESTAMP '2023-12-31 23:59:59';
UPDATE events SET event_time = TIMESTAMP '2023-06-15 14:00:00' WHERE event_name = 'Summer Festival';
DELETE FROM events WHERE event_time < TIMESTAMP '2023-01-01 00:00:00';
SELECT event_name FROM events WHERE event_time IS NOT NULL ORDER BY event_time DESC OFFSET 5 LIMIT 5;
SELECT e1.event_name, e2.event_name FROM events e1 CROSS JOIN events e2 WHERE e1.event_time < e2.event_time;
CREATE TABLE event_logs (log_id INT PRIMARY KEY, event_id INT, log_time TIMESTAMP, FOREIGN KEY (event_id) REFERENCES events(id));
INSERT INTO event_logs (log_id, event_id, log_time) VALUES (1, 1, TIMESTAMP '2023-01-01 01:00:00');
SELECT el.log_time, e.event_name FROM event_logs el INNER JOIN events e ON el.event_id = e.id WHERE el.log_time >= TIMESTAMP '2023-01-01 00:00:00' ORDER BY el.log_time;
WITH UpcomingEvents AS (SELECT event_name, event_time FROM events WHERE event_time > CURRENT_TIMESTAMP) SELECT * FROM UpcomingEvents WHERE event_time < TIMESTAMP '2023-07-01 00:00:00';