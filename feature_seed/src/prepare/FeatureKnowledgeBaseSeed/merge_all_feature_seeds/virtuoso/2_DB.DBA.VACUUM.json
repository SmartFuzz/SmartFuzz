CREATE TABLE test_data (id INT PRIMARY KEY, name VARCHAR(255), info XML, value FLOAT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_data (id, name, info, value) VALUES (1, 'Record 1', '<root id="1"><data>Some data</data></root>', 3.14159);
INSERT INTO test_data (id, name, info, value) VALUES (2, 'Record 2', '<root id="2"><data>More data</data></root>', 2.71828);
INSERT INTO test_data (id, name, info, value) VALUES (3, 'Record 3', '<root id="3"><data>Other data</data></root>', NULL);
INSERT INTO test_data (id, name, info, value) VALUES (4, 'Record 4', '<root id="4"><data></data></root>', -999.99999);
SELECT id, name, DB.DBA.VACUUM() AS vacuum_status FROM test_data WHERE value IS NOT NULL;
SELECT id, name, xpath_string('/root/@id', info) AS extracted_id FROM test_data WHERE created_at < NOW() AND value > 0.0;
SELECT AVG(value) AS average_value, COUNT(*) AS total_records FROM test_data GROUP BY name HAVING average_value > 1;
SELECT name, COUNT(*) FROM (SELECT name, value FROM test_data WHERE value IS NOT NULL UNION ALL SELECT name, CAST(info AS VARCHAR) FROM test_data WHERE info IS NOT NULL) AS combined_data GROUP BY name HAVING COUNT(*) > 1;
CREATE TEMPORARY TABLE temp_test AS SELECT * FROM test_data WHERE value IS NOT NULL;
SELECT DISTINCT value - 10 AS modified_value FROM temp_test WHERE modified_value > 0;
ALTER TABLE test_data ADD COLUMN additional_info VARCHAR(255);
UPDATE test_data SET additional_info = 'Updated info' WHERE id IN (SELECT id FROM temp_test WHERE LENGTH(name) > 4);
SELECT t.id, t.name, t.value, xpath_string('/root/@id', t.info) AS extracted_id FROM test_data t WHERE EXISTS (SELECT 1 FROM temp_test tt WHERE tt.id = t.id);
SELECT value, COUNT(*) OVER (PARTITION BY value) AS value_count FROM test_data WHERE value IS NOT NULL ORDER BY value;
SELECT NULLIF(value - 1, 0) AS safe_value FROM test_data WHERE safe_value IS NOT NULL;