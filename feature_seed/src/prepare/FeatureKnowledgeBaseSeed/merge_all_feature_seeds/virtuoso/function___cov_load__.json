CREATE TABLE coverage_data (id INT PRIMARY KEY, file_name VARCHAR(255), coverage_details TEXT);
INSERT INTO coverage_data (id, file_name, coverage_details) VALUES (1, 'test_coverage_1.json', 'Coverage Data for Test 1');
INSERT INTO coverage_data (id, file_name, coverage_details) VALUES (2, 'test_coverage_2.json', 'Coverage Data for Test 2');
INSERT INTO coverage_data (id, file_name, coverage_details) VALUES (3, 'test_coverage_3.json', 'Coverage Data for Test 3');
SELECT * FROM coverage_data WHERE id = (SELECT MAX(id) FROM coverage_data);
SELECT COUNT(*) FROM coverage_data WHERE file_name LIKE 'test_coverage_%';
SELECT DISTINCT file_name FROM coverage_data WHERE coverage_details IS NOT NULL;
SELECT file_name, (SELECT COUNT(*) FROM coverage_data) AS total_files FROM coverage_data WHERE coverage_details LIKE '%Test%';
DELETE FROM coverage_data WHERE id IN (SELECT id FROM coverage_data WHERE coverage_details IS NULL);
SELECT file_name FROM coverage_data WHERE EXISTS (SELECT * FROM coverage_data AS inner_data WHERE inner_data.id = coverage_data.id AND inner_data.coverage_details LIKE '%Data%');
UPDATE coverage_data SET coverage_details = 'Updated Coverage Data' WHERE id = (SELECT MIN(id) FROM coverage_data);
SELECT * FROM coverage_data WHERE file_name IN (SELECT DISTINCT file_name FROM coverage_data WHERE id < 3);
INSERT INTO coverage_data (id, file_name, coverage_details) SELECT MAX(id) + 1, 'test_coverage_4.json', 'Coverage Data for Test 4' FROM coverage_data;