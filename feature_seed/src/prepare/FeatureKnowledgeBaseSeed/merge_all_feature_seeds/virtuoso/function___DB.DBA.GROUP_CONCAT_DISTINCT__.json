foaf:name 'Alice';
foaf:based_near <http://linkeddata.uriburner.com/about/id/entity/http/sws.geonames.org/12345>. } };
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/person2> a foaf:Person;
foaf:name 'Bob';
foaf:based_near <http://linkeddata.uriburner.com/about/id/entity/http/sws.geonames.org/67890>. } };
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/person1> foaf:based_near <http://linkeddata.uriburner.com/about/id/entity/http/sws.geonames.org/24680>. } };
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/person3> a foaf:Person;
foaf:name 'Charlie';
foaf:based_near <http://linkeddata.uriburner.com/about/id/entity/http/sws.geonames.org/13579>. } };
SELECT ?name, (sql:GROUP_CONCAT_DISTINCT(?near, ' , ')) WHERE { GRAPH ?g { ?person a foaf:Person;
foaf:name ?name;
foaf:based_near ?near. } } GROUP BY ?name LIMIT 5;
SELECT ?name, (sql:GROUP_CONCAT_DISTINCT(?near, ' , ')) WHERE { GRAPH <http://example.org/graph1> { ?person a foaf:Person;
foaf:name ?name;
foaf:based_near ?near. } } GROUP BY ?name ORDER BY ?name LIMIT 10;
SELECT ?name, (sql:GROUP_CONCAT_DISTINCT(?near, ' , ')) WHERE { GRAPH <http://example.org/graph1> { ?person a foaf:Person;
foaf:name ?name;
foaf:based_near ?near. } UNION { GRAPH <http://example.org/graph2> { ?person a foaf:Person;
foaf:name ?name;
foaf:based_near ?near. } } } GROUP BY ?name LIMIT 10;
SELECT ?name, (sql:GROUP_CONCAT_DISTINCT(?near, ' , ')) WHERE { GRAPH ?g { ?person a foaf:Person;
foaf:name ?name;
foaf:based_near ?near. } } GROUP BY ?name HAVING (COUNT(?near) > 1) LIMIT 3;
SELECT ?name, (sql:GROUP_CONCAT_DISTINCT(?near, ' , ')) WHERE { GRAPH <http://example.org/graph1> { ?person a foaf:Person;
foaf:name ?name;
foaf:based_near ?near. } OPTIONAL { ?otherPerson a foaf:Person;
foaf:based_near ?near. } } GROUP BY ?name ORDER BY COUNT(?otherPerson) DESC LIMIT 3;