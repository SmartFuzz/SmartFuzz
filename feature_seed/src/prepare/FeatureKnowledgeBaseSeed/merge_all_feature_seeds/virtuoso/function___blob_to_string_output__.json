CREATE TABLE Categories (ID INT PRIMARY KEY, Description LONG VARCHAR);
INSERT INTO Categories (ID, Description) VALUES (1, 'Soft drinks, coffees, teas, beers, and ales');
INSERT INTO Categories (ID, Description) VALUES (2, 'Sweet and savory sauces, relishes, spreads, and seasonings');
INSERT INTO Categories (ID, Description) VALUES (3, 'Desserts, candies, and sweet breads');
INSERT INTO Categories (ID, Description) VALUES (4, 'Cheeses');
INSERT INTO Categories (ID, Description) VALUES (5, 'Breads, crackers, pasta, and cereal');
INSERT INTO Categories (ID, Description) VALUES (6, 'Prepared meats');
INSERT INTO Categories (ID, Description) VALUES (7, 'Dried fruit and bean curd');
INSERT INTO Categories (ID, Description) VALUES (8, 'Seaweed and fish');
SELECT string_output_string(blob_to_string_output(Description)) FROM Categories WHERE ID = 1;
SELECT string_output_string(blob_to_string_output(Description)) FROM Categories WHERE ID IN (2, 3);
SELECT string_output_string(blob_to_string_output(Description)) FROM (SELECT Description FROM Categories WHERE ID > 4) AS Subquery;
SELECT string_output_string(blob_to_string_output(C1.Description)) FROM Categories C1 JOIN (SELECT ID FROM Categories WHERE ID < 5) AS C2 ON C1.ID = C2.ID;
SELECT COUNT(*) FROM (SELECT DISTINCT string_output_string(blob_to_string_output(Description)) FROM Categories) AS UniqueDescriptions;
SELECT string_output_string(blob_to_string_output(Description)) AS ConvertedDescription FROM Categories ORDER BY ID DESC;
SELECT string_output_string(blob_to_string_output(Description)) FROM Categories WHERE LENGTH(Description) > 40;
WITH Converted AS (SELECT string_output_string(blob_to_string_output(Description)) AS ConvertedDescription FROM Categories) SELECT * FROM Converted WHERE LENGTH(ConvertedDescription) > 20;