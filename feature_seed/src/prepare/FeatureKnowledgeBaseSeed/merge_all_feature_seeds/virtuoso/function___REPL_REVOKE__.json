CREATE TABLE demo (id INT PRIMARY KEY, name VARCHAR(255));
CREATE TABLE table_publication (pub_id INT PRIMARY KEY, pub_name VARCHAR(255));
INSERT INTO demo (id, name) VALUES (1, 'User1');
INSERT INTO table_publication (pub_id, pub_name) VALUES (1, 'Publication1');
 DB.DBA.REPL_REVOKE ('table_publication', 'demo');
 DB.DBA.REPL_REVOKE ((SELECT pub_name FROM table_publication WHERE pub_id = 1), (SELECT name FROM demo WHERE id = 1));
 DB.DBA.REPL_REVOKE ('table_publication', (SELECT name FROM demo WHERE id = (SELECT MAX(id) FROM demo)));
 DB.DBA.REPL_REVOKE ('table_publication', (SELECT MAX(name) FROM demo GROUP BY name HAVING COUNT(*) > 1));
 DB.DBA.REPL_REVOKE ('table_publication', 'non_existent_user');
 DB.DBA.REPL_REVOKE ('non_existent_publication', 'demo');
CREATE TABLE another_demo (id INT PRIMARY KEY, demo_id INT, FOREIGN KEY(demo_id) REFERENCES demo(id));
INSERT INTO another_demo (id, demo_id) VALUES (1, 1);
 DB.DBA.REPL_REVOKE ('table_publication', (SELECT name FROM demo WHERE id IN (SELECT demo_id FROM another_demo)));
 DB.DBA.REPL_REVOKE ('table_publication', (SELECT name FROM demo WHERE NAME LIKE 'User%'));