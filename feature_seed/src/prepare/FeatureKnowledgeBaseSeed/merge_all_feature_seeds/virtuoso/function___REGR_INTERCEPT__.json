CREATE TABLE regression_data (id INT, x_value FLOAT, y_value FLOAT);
INSERT INTO regression_data (id, x_value, y_value) VALUES (1, 10.0, 20.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (2, 20.0, 30.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (3, NULL, 40.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (4, 30.0, NULL);
INSERT INTO regression_data (id, x_value, y_value) VALUES (5, 40.0, 50.0);
SELECT REGR_INTERCEPT(y_value, x_value) FROM regression_data;
SELECT SUM(y_value) AS total_y, REGR_INTERCEPT(y_value, x_value) FROM regression_data GROUP BY x_value;
SELECT a.id, REGR_INTERCEPT(b.y_value, b.x_value) FROM regression_data a JOIN regression_data b ON a.id != b.id GROUP BY a.id;
SELECT REGR_INTERCEPT(y_value, x_value) FROM (SELECT x_value, y_value FROM regression_data WHERE x_value IS NOT NULL AND y_value IS NOT NULL) AS subquery;
CREATE TABLE additional_data (id INT, value FLOAT);
INSERT INTO additional_data (id, value) VALUES (1, 15.0);
INSERT INTO additional_data (id, value) VALUES (2, 25.0);
SELECT REGR_INTERCEPT(d.y_value, d.x_value) FROM regression_data d JOIN additional_data a ON d.id = a.id;
SELECT REGR_INTERCEPT(y_value, x_value) FROM (SELECT x_value, y_value FROM regression_data WHERE x_value IS NOT NULL) AS filtered_data WHERE filtered_data.y_value IS NOT NULL;
SELECT REGR_INTERCEPT(y_value, x_value) FROM (SELECT x_value, y_value FROM regression_data WHERE y_value > 10.0) AS subquery WHERE x_value < 50.0;