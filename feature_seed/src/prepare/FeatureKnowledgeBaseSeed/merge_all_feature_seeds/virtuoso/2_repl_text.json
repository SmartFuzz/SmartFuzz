CREATE TABLE foo (id INT, description TEXT, value FLOAT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO foo VALUES (1, 'first entry', 100.0, CURRENT_TIMESTAMP);
INSERT INTO foo VALUES (2, 'second entry', NULL, CURRENT_TIMESTAMP);
INSERT INTO foo VALUES (3, 'third entry', 200.5, CURRENT_TIMESTAMP);
INSERT INTO foo VALUES (4, 'fourth entry', 300.75, NULL);
SELECT id, description, value FROM foo WHERE value IN (SELECT 100.0);
SELECT id FROM foo WHERE id IN (1, 2, 3) AND created_at > NOW() - INTERVAL '1 DAY';
INSERT INTO foo VALUES (5, 'fifth entry', NULL, NULL);
SELECT repl_text('demo-publication', 'INSERT INTO foo (id, description, value) VALUES (?, ?)', (SELECT MIN(id) FROM foo), 'new entry') WHERE EXISTS (SELECT * FROM foo WHERE value IS NULL);
SELECT id, COUNT(*) FROM foo GROUP BY id HAVING COUNT(*) IN (SELECT COUNT(*) FROM foo WHERE value IS NOT NULL) AND COUNT(*) > 0;
SELECT MAX(value) AS max_value, MIN(value) AS min_value FROM foo WHERE id IN (SELECT id FROM foo WHERE description LIKE 'f%') AND value IS NOT NULL;
CREATE TABLE bar (id INT PRIMARY KEY, foo_id INT, FOREIGN KEY (foo_id) REFERENCES foo(id));
INSERT INTO bar VALUES (1, 1);
INSERT INTO bar VALUES (2, (SELECT id FROM foo WHERE description = 'first entry'));
SELECT b.id, f.description, f.value FROM bar b JOIN foo f ON b.foo_id = f.id WHERE f.value IN (SELECT value FROM (SELECT DISTINCT value FROM foo) AS distinct_values);
SELECT repl_text('demo-publication', 'UPDATE foo SET description = ? WHERE id = ?', 'updated entry', (SELECT id FROM foo WHERE value <= 0));
SELECT COUNT(*) FROM foo WHERE NULL IN (SELECT value FROM foo WHERE description IS NOT NULL);
INSERT INTO foo VALUES (NULL, NULL, NULL, NULL) WHERE 'dummy' IN ('dummy', 'not dummy', 'another one');