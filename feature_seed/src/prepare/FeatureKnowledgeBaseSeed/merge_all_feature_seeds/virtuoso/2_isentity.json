CREATE TABLE test_data (id INT PRIMARY KEY, xml_data XML, value_string VARCHAR(100), num_value DECIMAL(10,2));
INSERT INTO test_data (id, xml_data, value_string, num_value) VALUES (1, '<entity>Test</entity>', 'abc', 123.45);
INSERT INTO test_data (id, xml_data, value_string, num_value) VALUES (2, '<entity></entity>', 'xyz', NULL);
INSERT INTO test_data (id, xml_data, value_string, num_value) VALUES (3, NULL, '', 0.00);
SELECT id, xml_data, value_string FROM test_data WHERE isentity(xml_data) AND isLiteral(value_string);
SELECT id, COUNT(*) FROM test_data GROUP BY id HAVING isentity(xml_data) OR (num_value IS NULL AND value_string = 'abc');
SELECT id, xml_data FROM (SELECT id, xml_data FROM test_data WHERE isentity(xml_data) AND value_string LIKE 'a%') AS subquery WHERE isLiteral(value_string);
SELECT id, xml_data, value_string FROM test_data d1 JOIN test_data d2 ON d1.id = d2.id WHERE isentity(d1.xml_data) AND isLiteral(d2.value_string) AND d1.num_value > 100;
SELECT id, NUMERIC(1,0) AS zero_value FROM test_data WHERE value_string IS NULL GROUP BY value_string HAVING isentity(xml_data);
CREATE TABLE temp_table AS SELECT id, isentity(xml_data) AS entity_check FROM test_data;
ALTER TABLE temp_table ADD COLUMN num_check DECIMAL(10,2);
INSERT INTO temp_table (id, entity_check) VALUES (4, TRUE);
SELECT id, COUNT(*) FROM temp_table WHERE num_check IS NULL AND id IN (SELECT id FROM test_data WHERE isentity(xml_data));