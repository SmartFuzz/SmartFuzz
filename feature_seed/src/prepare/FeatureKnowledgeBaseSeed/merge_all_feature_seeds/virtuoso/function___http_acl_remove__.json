CREATE TABLE acl_rules (id INTEGER PRIMARY KEY, rule_name VARCHAR(255), condition VARCHAR(255));
INSERT INTO acl_rules (rule_name, condition) VALUES ('rule1', 'condition1');
INSERT INTO acl_rules (rule_name, condition) VALUES ('rule2', 'condition2');
INSERT INTO acl_rules (rule_name, condition) VALUES ('rule3', 'condition3');
DELETE FROM acl_rules WHERE id = (SELECT id FROM acl_rules WHERE rule_name = 'rule1' LIMIT 1);
DELETE FROM acl_rules WHERE id IN (SELECT id FROM acl_rules WHERE condition LIKE 'condition%');
DELETE FROM acl_rules WHERE id IN (SELECT id FROM acl_rules WHERE id NOT IN (SELECT id FROM acl_rules WHERE condition = 'condition2'));
DELETE FROM acl_rules WHERE id = (SELECT MIN(id) FROM acl_rules WHERE rule_name LIKE 'rule%');
DELETE FROM acl_rules WHERE rule_name IN (SELECT DISTINCT rule_name FROM acl_rules WHERE condition IS NOT NULL);
DELETE FROM acl_rules WHERE rule_name IN (SELECT rule_name FROM acl_rules WHERE EXISTS (SELECT 1 FROM acl_rules AS sub WHERE sub.id = acl_rules.id AND sub.condition = 'condition3'));
DELETE FROM acl_rules WHERE rule_name NOT IN (SELECT DISTINCT rule_name FROM acl_rules WHERE condition = 'condition2') AND condition IS NOT NULL;
DELETE FROM acl_rules WHERE EXISTS (SELECT 1 FROM acl_rules AS sub WHERE sub.id = acl_rules.id AND sub.condition = 'condition1' AND sub.rule_name = 'rule1');