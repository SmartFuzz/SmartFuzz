CREATE TYPE my_type AS (id INT, name VARCHAR(100));
CREATE TABLE my_table OF my_type;
INSERT INTO my_table VALUES (NEW my_type(1, 'Alice'));
INSERT INTO my_table VALUES (NEW my_type(2, 'Bob'));
SELECT * FROM my_table;
SELECT NEW my_type(id, name) FROM my_table WHERE id = 1;
SELECT id FROM my_table WHERE NEW my_type(id, name).name = 'Alice';
SELECT a.id, b.name FROM my_table a JOIN my_table b ON a.id = NEW my_type(b.id, b.name).id;
WITH new_instance AS (SELECT NEW my_type(3, 'Charlie') AS new_obj) SELECT new_obj.id FROM new_instance;
SELECT NEW my_type(4, 'David') AS new_instance WHERE new_instance.name IS NOT NULL;
SELECT (SELECT NEW my_type(5, 'Eva') FROM dual) AS created_instance;
CREATE TABLE another_table OF my_type;
INSERT INTO another_table SELECT NEW my_type(id, name) FROM my_table WHERE id > 1;
SELECT NEW my_type(m.id, m.name) FROM my_table m WHERE m.id IN (SELECT id FROM another_table WHERE name IS NOT NULL);