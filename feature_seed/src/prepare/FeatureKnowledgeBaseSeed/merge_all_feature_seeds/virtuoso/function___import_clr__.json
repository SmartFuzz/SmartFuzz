CREATE TABLE test_table (id INT, name VARCHAR(255));
INSERT INTO test_table VALUES (1, 'Alice');
INSERT INTO test_table VALUES (2, 'Bob');
CREATE FUNCTION sanity::test_string_input(name VARCHAR(255)) RETURNS VARCHAR AS 'return "Hello " + name + ", from Virtuoso";
' LANGUAGE clr;
DB..import_clr (vector ('sanity'), vector ('sanity'));
SELECT sanity::test_string_input(name) FROM test_table WHERE id = 1;
SELECT sanity::test_string_input(name) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name LIKE 'A%');
SELECT sanity::test_string_input(test_table.name) AS greeting FROM test_table WHERE id BETWEEN 1 AND 2;
SELECT COUNT(*) AS total FROM (SELECT DISTINCT name FROM test_table) AS unique_names;
SELECT id, sanity::test_string_input(name) AS greeting FROM test_table ORDER BY id DESC;
DELETE FROM test_table WHERE id = 2;
SELECT sanity::test_string_input(name) FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);
UPDATE test_table SET name = 'Charlie' WHERE id = 1;
SELECT id, sanity::test_string_input(name) FROM test_table WHERE name IN (SELECT name FROM test_table WHERE id != 1);