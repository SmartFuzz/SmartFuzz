CREATE TABLE test_json_data (id INT PRIMARY KEY, details JSON, created_at TIMESTAMP DEFAULT get_timestamp());
INSERT INTO test_json_data (id, details) VALUES (1, '{"key": "value1", "array": [1, 2, 3]}'), (2, '{"key": "value2", "array": [4, 5, 6]}');
SELECT id, json_array_length(details->'array') AS array_length, get_timestamp() FROM test_json_data WHERE json_array_length(details->'array') > 2;
SELECT t1.id, t1.details, t1.created_at FROM test_json_data t1 JOIN (SELECT id, json_array_length(details->'array') AS array_length FROM test_json_data WHERE details IS NOT NULL) t2 ON t1.id = t2.id WHERE t1.created_at <= get_timestamp();
SELECT id, json_array_length(details->'array') AS array_length FROM test_json_data WHERE created_at >= (SELECT get_timestamp() - INTERVAL '1 DAY');
SELECT id, json_array_length(details->'array') AS array_length FROM test_json_data WHERE json_array_length(details->'array') IS NOT NULL AND details->>'key' = 'value1';
CREATE TABLE test_null_handling (id INT PRIMARY KEY, info JSON DEFAULT NULL, created_at TIMESTAMP DEFAULT get_timestamp());
INSERT INTO test_null_handling (id, info) VALUES (1, NULL), (2, '{"data": ["text", NULL]}');
SELECT id, json_array_length(info->'data') AS data_length FROM test_null_handling WHERE info IS NOT NULL OR get_timestamp() IS NULL;
SELECT id, json_array_length(info->'data') AS data_length FROM test_null_handling GROUP BY data_length HAVING data_length > 0 ORDER BY get_timestamp() DESC;