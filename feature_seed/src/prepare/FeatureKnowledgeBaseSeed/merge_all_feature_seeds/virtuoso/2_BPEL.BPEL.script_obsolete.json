CREATE TABLE bpel_scripts (id INT PRIMARY KEY, script_name VARCHAR(100), is_obsolete BOOLEAN, version INT);
INSERT INTO bpel_scripts (id, script_name, is_obsolete, version) VALUES (1, 'script_one', FALSE, 1);
INSERT INTO bpel_scripts (id, script_name, is_obsolete, version) VALUES (2, 'script_two', TRUE, 1);
INSERT INTO bpel_scripts (id, script_name, is_obsolete, version) VALUES (3, 'script_three', FALSE, 2);
SELECT BPEL.BPEL.script_obsolete((SELECT MAX(id) FROM bpel_scripts WHERE is_obsolete = FALSE));
SELECT 1 IN (SELECT version FROM bpel_scripts WHERE script_name = 'script_one' AND is_obsolete = FALSE);
SELECT COUNT(*) FROM (SELECT BPEL.BPEL.script_obsolete(id) FROM bpel_scripts WHERE is_obsolete = FALSE) AS obsolete_scripts;
SELECT id FROM bpel_scripts WHERE is_obsolete IN (SELECT TRUE FROM bpel_scripts GROUP BY is_obsolete HAVING COUNT(*) > 0);
SELECT BPEL.BPEL.script_obsolete((SELECT id FROM bpel_scripts WHERE script_name IN ('script_one', 'script_two') AND is_obsolete = TRUE)) AS obsolete_result;
CREATE TABLE test_cases (id INT PRIMARY KEY, description VARCHAR(256), result BOOLEAN);
INSERT INTO test_cases (id, description, result) VALUES (1, 'Test obsolete script', TRUE);
INSERT INTO test_cases (id, description, result) VALUES (2, 'Test current script', FALSE);
SELECT id FROM test_cases WHERE result IN (SELECT DISTINCT result FROM test_cases);
UPDATE bpel_scripts SET is_obsolete = TRUE WHERE id IN (SELECT id FROM test_cases WHERE result = TRUE);
SELECT BPEL.BPEL.script_obsolete(id) FROM bpel_scripts WHERE id IN (SELECT id FROM bpel_scripts WHERE version = (SELECT MIN(version) FROM bpel_scripts));
DROP TABLE IF EXISTS obsolete_scripts;
CREATE TEMPORARY TABLE obsolete_scripts AS SELECT id FROM bpel_scripts WHERE is_obsolete = TRUE;