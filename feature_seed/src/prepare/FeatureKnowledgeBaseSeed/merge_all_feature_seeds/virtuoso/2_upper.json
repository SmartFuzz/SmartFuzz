CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100) NULL, value DECIMAL(10,2));
INSERT INTO test_table (id, name, value) VALUES (1, 'alice', 10.50), (2, NULL, 20.00), (3, 'bob', NULL), (4, 'charlie', 0.00), (5, 'david', -15.75);
SELECT id, upper(name) AS uppercase_name FROM test_table WHERE value > 5 OR (value IS NULL AND upper(name) IS NOT NULL);
SELECT DISTINCT id, upper(name) AS uppercase_name FROM test_table WHERE (value < 0 OR upper(name) LIKE 'A%') GROUP BY id HAVING COUNT(*) > 1;
SELECT id, upper(name) AS uppercase_name FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NOT NULL AND value = (SELECT max(value) FROM test_table));
SELECT id, upper(name) AS uppercase_name FROM test_table WHERE id = (SELECT MAX(id) FROM test_table) OR upper(name) IS NOT NULL;
SELECT id, upper(name) AS uppercase_name FROM test_table WHERE (id + 5 OR upper(name) IS NULL) GROUP BY id, upper(name) HAVING SUM(value) IS NOT NULL;
SELECT id, upper(name) AS uppercase_name FROM (SELECT id, name FROM test_table WHERE value IS NOT NULL) AS subquery JOIN test_table t ON upper(subquery.name) = upper(t.name) OR t.value IS NULL ORDER BY upper(subquery.name) ASC;
INSERT INTO test_table (id, name) VALUES (6, upper(NULL)), (7, upper(''));
SELECT id, upper(name) AS uppercase_name FROM test_table WHERE upper(name) IS NOT NULL AND (value > 0 OR value IS NULL) ORDER BY COALESCE(value, DEFAULT) DESC;