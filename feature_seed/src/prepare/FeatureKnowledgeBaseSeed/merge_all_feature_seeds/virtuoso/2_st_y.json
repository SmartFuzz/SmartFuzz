CREATE TABLE geo_points (id INT PRIMARY KEY, geom GEOMETRY, name VARCHAR(255));
INSERT INTO geo_points (id, geom, name) VALUES (1, ST_Point(10, 20), 'Point A');
INSERT INTO geo_points (id, geom, name) VALUES (2, ST_Point(15, 25), 'Point B');
INSERT INTO geo_points (id, geom, name) VALUES (3, ST_Point(20, NULL), 'Point C');
SELECT name, st_y(geom) AS y_coordinate FROM geo_points WHERE st_y(geom) IS NOT NULL;
SELECT A.name FROM geo_points A JOIN geo_points B ON bif:st_within(A.geom, B.geom) WHERE A.id = 1;
SELECT A.name, st_y(A.geom) FROM geo_points A JOIN geo_points B ON bif:st_within(A.geom, B.geom) WHERE B.id = 2;
SELECT COUNT(*) FROM (SELECT DISTINCT st_y(geom) FROM geo_points) AS unique_y;
SELECT st_y(geom) FROM geo_points WHERE geom IS NOT NULL AND st_y(geom) < (SELECT AVG(st_y(geom)) FROM geo_points);
SELECT AVG(st_y(geom)) AS average_y FROM geo_points GROUP BY st_y(geom) HAVING average_y > 10;
CREATE TABLE geo_shapes (id INT PRIMARY KEY, region GEOMETRY, description VARCHAR(255));
INSERT INTO geo_shapes (id, region, description) VALUES (1, ST_PolygonFromText('POLYGON((10 20, 10 30, 20 30, 20 20, 10 20))'), 'Polygon A');
SELECT A.description FROM geo_shapes A JOIN geo_points B ON bif:st_within(B.geom, A.region) WHERE B.geom IS NOT NULL;
SELECT B.name, COUNT(*) FROM geo_shapes A JOIN geo_points B ON bif:st_within(B.geom, A.region) GROUP BY B.name HAVING COUNT(*) > 1;
SELECT B.name, st_y(B.geom) FROM geo_points B WHERE st_y(B.geom) IS NOT NULL AND B.geom NOT IN (SELECT region FROM geo_shapes) ORDER BY st_y(B.geom) DESC;
SELECT st_y(ST_Point(NULL, NULL)) AS null_y, st_y(ST_Point(10, -10)) AS valid_y;
SELECT A.id, st_y(A.geom) FROM geo_points A LEFT JOIN geo_shapes B ON bif:st_within(A.geom, B.region) WHERE B.id IS NULL ORDER BY st_y(A.geom) DESC;