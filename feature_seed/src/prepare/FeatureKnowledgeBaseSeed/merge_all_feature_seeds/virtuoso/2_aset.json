CREATE TABLE test_array (id INT PRIMARY KEY, arr VARCHAR(255));
INSERT INTO test_array (id, arr) VALUES (1, 'initial_value');
SELECT aset(arr, 3, bif:score()) FROM test_array WHERE id = 1;
CREATE TABLE test_scores (document VARCHAR(255), score FLOAT);
INSERT INTO test_scores (document, score) VALUES ('doc1', 1.5), ('doc2', NULL);
INSERT INTO test_scores (document, score) VALUES (NULL, 2.0);
SELECT document, aset(CAST(score AS VARCHAR), 0, 65) FROM test_scores WHERE score IS NOT NULL;
SELECT id, bif:score() FROM test_array JOIN test_scores ON aset(arr, 0, 65) = CAST(document AS VARCHAR) WHERE score > 1;
SELECT aset(revstr(arr), 0, -1) FROM test_array WHERE arr IS NOT NULL;
CREATE TABLE complex_table (col1 INT, col2 VARCHAR(255), col3 FLOAT, PRIMARY KEY (col1));
INSERT INTO complex_table (col1, col2, col3) VALUES (1, '', 1.0), (2, 'text', NULL);
SELECT col1, bif:score() FROM complex_table WHERE NULLIF(col2, '') IS NOT NULL GROUP BY col1 HAVING COUNT(col2) > 0;
SELECT aset(arr, 1, score) FROM (SELECT arr, bif:score() AS score FROM test_array) AS scores WHERE id = 1;
SELECT bif:score() FROM (SELECT NULLIF(CAST(arr AS VARCHAR), '') AS arr_value FROM test_array) AS subquery WHERE arr_value IS NOT NULL;
UPDATE test_array SET arr = revstr(aset(arr, 0, 97)) WHERE id = 1;
SELECT aset(arr, 2, 90 + bif:score()) FROM test_array WHERE LENGTH(arr) > 5;