CREATE TABLE rpc_test (id INT PRIMARY KEY, dsn VARCHAR(255), response_time INT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO rpc_test (id, dsn, response_time) VALUES (1, 'server1', 100), (2, 'server2', 200), (3, NULL);
SELECT id, vdd_measure_rpc_time(dsn) AS estimated_time FROM rpc_test WHERE response_time != (SELECT MAX(response_time) FROM rpc_test);
SELECT id, dsn FROM rpc_test WHERE vdd_measure_rpc_time(dsn) != response_time AND created_at IS NOT NULL;
SELECT AVG(response_time) AS avg_time FROM rpc_test GROUP BY dsn HAVING avg_time != (SELECT MAX(response_time) FROM rpc_test);
CREATE TABLE rpc_extended (id INT PRIMARY KEY, rpc_id INT, status VARCHAR(50), FOREIGN KEY(rpc_id) REFERENCES rpc_test(id));
INSERT INTO rpc_extended (id, rpc_id, status) VALUES (1, 1, 'SUCCESS'), (2, 2, 'FAILED');
SELECT re.id, rt.dsn, vdd_measure_rpc_time(rt.dsn) AS rpc_time FROM rpc_test rt JOIN rpc_extended re ON rt.id = re.rpc_id WHERE vdd_measure_rpc_time(rt.dsn) != (SELECT AVG(vdd_measure_rpc_time(dsn)) FROM rpc_test WHERE dsn IS NOT NULL);
DROP TABLE IF EXISTS temp_rpc_test;
CREATE TEMPORARY TABLE temp_rpc_test AS SELECT id, vdd_measure_rpc_time(dsn) FROM rpc_test WHERE dsn IS NOT NULL AND response_time != 0;
SELECT COUNT(*) FROM temp_rpc_test WHERE id != (SELECT MIN(id) FROM temp_rpc_test);
SELECT id, dsn FROM rpc_test WHERE (vdd_measure_rpc_time(dsn) IS NULL OR response_time IS NULL) ORDER BY dsn ASC;