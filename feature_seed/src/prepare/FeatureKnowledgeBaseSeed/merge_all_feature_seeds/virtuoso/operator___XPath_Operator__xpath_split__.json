CREATE TABLE xml_data (id INTEGER PRIMARY KEY, xml_content XML);
INSERT INTO xml_data (id, xml_content) VALUES (1, '<root><item>A</item><item>B</item><item>C</item></root>');
INSERT INTO xml_data (id, xml_content) VALUES (2, '<root><item>1</item><item>2</item></root>');
SELECT xpath_split(xpath('//item', xml_content), ',') FROM xml_data WHERE id = 1;
SELECT xpath_split(xpath('//item', xml_content), ',') AS split_items FROM xml_data WHERE id IN (1, 2);
SELECT id, xpath_split(xpath('//item', xml_content), ',') AS split_items FROM xml_data ORDER BY id;
SELECT id FROM xml_data WHERE EXISTS (SELECT 1 FROM xml_data WHERE xpath_count('//item', xml_content) > 2);
SELECT id, COUNT(*) AS item_count FROM xml_data CROSS JOIN xpath_split(xpath('//item', xml_content), ',') GROUP BY id;
WITH split_items AS (SELECT id, xpath_split(xpath('//item', xml_content), ',') AS items FROM xml_data) SELECT id, items FROM split_items WHERE items IS NOT NULL;
SELECT id, xpath_split(xpath('//item', xml_content), ',') AS split_items FROM xml_data WHERE id = (SELECT MAX(id) FROM xml_data);