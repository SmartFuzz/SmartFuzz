CREATE TABLE Services (service_id INT PRIMARY KEY, service_name VARCHAR(255), category VARCHAR(255), endpoint VARCHAR(255));
INSERT INTO Services (service_id, service_name, category, endpoint) VALUES (1, 'Weather Service', 'Weather', 'http://weather.example.com');
INSERT INTO Services (service_id, service_name, category, endpoint) VALUES (2, 'Stock Price Service', 'Finance', 'http://stocks.example.com');
INSERT INTO Services (service_id, service_name, category, endpoint) VALUES (3, 'Payment Gateway', 'Finance', 'http://payment.example.com');
INSERT INTO Services (service_id, service_name, category, endpoint) VALUES (4, 'Location Service', 'Geolocation', 'http://location.example.com');
SELECT * FROM Services WHERE category = 'Finance';
SELECT service_name FROM Services WHERE service_name LIKE '%Service%';
SELECT * FROM Services WHERE service_id IN (SELECT service_id FROM Services WHERE category = 'Finance');
SELECT service_name, endpoint FROM Services WHERE service_id = (SELECT MAX(service_id) FROM Services);
SELECT * FROM Services s JOIN (SELECT category FROM Services GROUP BY category HAVING COUNT(*) > 1) c ON s.category = c.category;
SELECT * FROM Services WHERE service_name IN (SELECT DISTINCT service_name FROM Services WHERE service_id < 3);