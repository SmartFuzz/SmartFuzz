CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table (id, value) VALUES (1, NULL);
INSERT INTO test_table (id, value) VALUES (2, 5);
SELECT * FROM test_table WHERE value IS NOT NULL;
SELECT * FROM test_table WHERE id IS NOT NULL AND value IS NOT NULL;
SELECT id, value FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NOT NULL);
SELECT t1.id, t2.value FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.value IS NOT NULL;
SELECT COUNT(*) FROM test_table WHERE value IS NOT NULL AND id > 0;
SELECT * FROM (SELECT id, value FROM test_table WHERE value IS NOT NULL) AS subquery WHERE id < 10;
CREATE TABLE another_table (ref_id INT, ref_value INT);
INSERT INTO another_table (ref_id, ref_value) VALUES (1, NULL);
INSERT INTO another_table (ref_id, ref_value) VALUES (2, 10);
SELECT a.ref_id FROM another_table a WHERE a.ref_value IS NOT NULL AND EXISTS (SELECT * FROM test_table t WHERE t.id = a.ref_id);
SELECT DISTINCT t.id FROM test_table t JOIN another_table a ON t.id = a.ref_id WHERE a.ref_value IS NOT NULL;
SELECT COALESCE(value, 'default') FROM test_table WHERE value IS NOT NULL;
DELETE FROM test_table WHERE value IS NULL;
SELECT * FROM test_table WHERE NOT (value IS NULL);