CREATE TABLE tModel (id INTEGER PRIMARY KEY, name VARCHAR(255), category VARCHAR(255), description TEXT);
INSERT INTO tModel (id, name, category, description) VALUES (1, 'Model A', 'Category 1', 'Description for Model A');
INSERT INTO tModel (id, name, category, description) VALUES (2, 'Model B', 'Category 2', 'Description for Model B');
INSERT INTO tModel (id, name, category, description) VALUES (3, 'Model C', 'Category 1', 'Description for Model C');
INSERT INTO tModel (id, name, category, description) VALUES (4, 'Model D', 'Category 3', 'Description for Model D');
SELECT * FROM tModel WHERE category = 'Category 1';
SELECT name FROM tModel WHERE description LIKE '%Model%';
SELECT COUNT(*) FROM tModel WHERE category = 'Category 2';
SELECT DISTINCT category FROM tModel;
SELECT name FROM tModel WHERE id IN (SELECT id FROM tModel WHERE category = 'Category 1');
SELECT name, description FROM tModel WHERE id NOT IN (SELECT id FROM tModel WHERE category = 'Category 3');
SELECT name, COUNT(id) FROM tModel GROUP BY category HAVING COUNT(id) > 1;
SELECT min(id) AS min_id, max(id) AS max_id FROM tModel;
SELECT name FROM tModel WHERE category = (SELECT category FROM tModel WHERE id = 1);
SELECT name FROM tModel WHERE EXISTS (SELECT * FROM tModel WHERE category = 'Category 1');
SELECT name FROM tModel WHERE category = 'Category 2' AND LENGTH(description) > 15;
SELECT t1.name FROM tModel t1 JOIN tModel t2 ON t1.category = t2.category WHERE t1.id != t2.id;
DELETE FROM tModel WHERE id = 4;
SELECT * FROM tModel WHERE name LIKE 'Model%' AND description IS NOT NULL LIMIT 10;
SELECT category, COUNT(*) AS count FROM tModel GROUP BY category ORDER BY count DESC;