CREATE TABLE websites (id INT PRIMARY KEY, url VARCHAR(255), path VARCHAR(255), export_path VARCHAR(255));
INSERT INTO websites (id, url, path, export_path) VALUES (1, 'www.foo.com', '/help/', 'sites/www_foo_com');
INSERT INTO websites (id, url, path, export_path) VALUES (2, 'www.bar.com', '/about/', 'sites/www_bar_com');
INSERT INTO websites (id, url, path, export_path) VALUES (3, 'www.baz.com', '/contact/', 'sites/www_baz_com');
SELECT * FROM websites WHERE url = 'www.foo.com' AND path LIKE '/help/%';
SELECT * FROM websites WHERE id IN (SELECT id FROM websites WHERE url = 'www.bar.com');
SELECT * FROM websites WHERE export_path = 'sites/www_foo_com' AND url NOT IN (SELECT url FROM websites WHERE id = 3);
SELECT url, export_path FROM websites WHERE url LIKE 'www.%' AND path IS NOT NULL;
SELECT COUNT(*) FROM websites WHERE export_path LIKE 'sites/%' AND path NOT LIKE '/';
UPDATE websites SET export_path = '/backup/sites/www_foo_com' WHERE url = 'www.foo.com' AND path = '/help/';
DELETE FROM websites WHERE id = (SELECT id FROM websites WHERE url = 'www.baz.com' LIMIT 1);
SELECT DISTINCT url FROM websites WHERE export_path LIKE 'sites/%' ORDER BY url;
INSERT INTO websites (id, url, path, export_path) SELECT MAX(id) + 1, url, path, export_path FROM websites;
SELECT url, COUNT(*) FROM websites GROUP BY url HAVING COUNT(*) > 1;
SELECT url FROM websites WHERE url NOT LIKE 'www.%' UNION SELECT url FROM websites WHERE id > 1;
CREATE VIEW site_exports AS SELECT url, export_path FROM websites WHERE export_path IS NOT NULL;