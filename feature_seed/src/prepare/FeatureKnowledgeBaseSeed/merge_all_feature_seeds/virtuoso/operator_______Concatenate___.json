CREATE TABLE test_strings (id INT, value1 VARCHAR(255), value2 VARCHAR(255));
INSERT INTO test_strings (id, value1, value2) VALUES (1, 'abc', 'def');
INSERT INTO test_strings (id, value1, value2) VALUES (2, NULL, 'xyz');
INSERT INTO test_strings (id, value1, value2) VALUES (3, '123', NULL);
INSERT INTO test_strings (id, value1, value2) VALUES (4, NULL, NULL);
SELECT value1 || value2 FROM test_strings WHERE id = 1;
SELECT value1 || COALESCE(value2, 'default') FROM test_strings WHERE id = 2;
SELECT COALESCE(value1, 'default1') || COALESCE(value2, 'default2') FROM test_strings WHERE id = 3;
SELECT 'Result: ' || value1 || ' and ' || value2 AS concatenated FROM test_strings;
SELECT (SELECT value1 FROM test_strings WHERE id = 1) || (SELECT value2 FROM test_strings WHERE id = 2) AS combined;
SELECT a.value1 || b.value2 FROM test_strings a JOIN test_strings b ON a.id = 1 AND b.id = 2;
SELECT (value1 || ' - ') || (SELECT value2 FROM test_strings WHERE id = 1) AS combined_value FROM test_strings WHERE id = 3;
SELECT CONCAT(value1, value2) FROM (SELECT value1, value2 FROM test_strings WHERE id IN (1, 2)) AS subquery;
SELECT value1 || (SELECT ' concatenated' FROM DUAL) AS result FROM test_strings WHERE id = 1;
SELECT CASE WHEN value1 IS NOT NULL THEN value1 || ' exists' ELSE 'no value' END AS check_value FROM test_strings WHERE id = 3;