CREATE TABLE publications (id INT PRIMARY KEY, name VARCHAR(100));
CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(50));
INSERT INTO publications (id, name) VALUES (1, 'table_publication');
INSERT INTO users (id, username) VALUES (1, 'demo');
GRANT REPL_GRANT ON publications TO demo;
GRANT REPL_GRANT ON (SELECT name FROM publications WHERE id = 1) TO demo;
GRANT REPL_GRANT ON (SELECT * FROM publications JOIN users ON publications.id = users.id) TO demo;
GRANT REPL_GRANT ON publications WHERE id IN (SELECT id FROM users WHERE username = 'demo') TO demo;
GRANT REPL_GRANT ON (SELECT name FROM publications) TO demo;
DECLARE @user VARCHAR(50) = 'demo';
GRANT REPL_GRANT ON publications TO @user;
CREATE INDEX idx_user ON users(username);
GRANT REPL_GRANT ON (SELECT name FROM publications WHERE EXISTS (SELECT 1 FROM users WHERE username = 'demo')) TO demo;
GRANT REPL_GRANT ON (SELECT name FROM publications WHERE id BETWEEN 1 AND 10) TO demo;