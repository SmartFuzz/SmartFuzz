CREATE TABLE certificates (id INT PRIMARY KEY, cert_data TEXT);
INSERT INTO certificates (id, cert_data) VALUES (1, '-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----');
INSERT INTO certificates (id, cert_data) VALUES (2, '-----BEGIN CERTIFICATE-----...-----END CERTIFICATE-----');
CREATE TABLE emails (id INT PRIMARY KEY, email_data TEXT);
INSERT INTO emails (id, email_data) VALUES (1, 'Content-Type: multipart/signed;
protocol="application/x-pkcs7-signature";
micalg=sha-1\n...');
INSERT INTO emails (id, email_data) VALUES (2, 'Content-Type: multipart/signed;
protocol="application/x-pkcs7-signature";
micalg=sha-1\n...');
SELECT smime_verify(file_to_string((SELECT email_data FROM emails WHERE id = 1)), vector((SELECT cert_data FROM certificates WHERE id IN (1,2))), NULL, 1);
SELECT smime_verify(file_to_string((SELECT email_data FROM emails WHERE id = 2)), vector((SELECT cert_data FROM certificates WHERE id = 1)), NULL, 1);
SELECT smime_verify(file_to_string((SELECT email_data FROM emails WHERE id = (SELECT MAX(id) FROM emails))), vector((SELECT cert_data FROM certificates WHERE id = (SELECT MIN(id) FROM certificates))), NULL, 1);
SELECT smime_verify(file_to_string((SELECT email_data FROM emails ORDER BY id DESC LIMIT 1)), vector((SELECT ARRAY_AGG(cert_data) FROM certificates)), NULL, 1);
SELECT smime_verify(file_to_string((SELECT email_data FROM emails LIMIT 1 OFFSET 1)), vector(ARRAY(SELECT cert_data FROM certificates)), NULL, 1);