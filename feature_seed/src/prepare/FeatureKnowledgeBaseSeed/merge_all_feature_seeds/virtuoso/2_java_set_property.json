CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255), instance_obj VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'A'), (2, 'B'), (3, NULL);
SELECT id FROM test_table WHERE java_set_property(NULL, value) <= 'C';
SELECT id FROM test_table WHERE id <= (SELECT COUNT(*) FROM test_table WHERE value IS NOT NULL);
SELECT java_set_property(NULL, value) FROM test_table WHERE (java_set_property(NULL, value) <= 'B') AND (value IS NOT NULL);
SELECT id, java_set_property(NULL, value) AS property_value FROM test_table GROUP BY property_value HAVING property_value IS NOT NULL;
SELECT id FROM test_table WHERE java_set_property(NULL, (SELECT MAX(LENGTH(value)) FROM test_table)) <= '3';
INSERT INTO test_table (id, value) VALUES (4, 'C'), (5, 'D');
SELECT java_set_property(instance_obj, value) FROM test_table WHERE instance_obj IS NOT NULL AND (id <= (SELECT MIN(id) FROM test_table));
CREATE TEMP TABLE temp_table AS SELECT id, value FROM test_table WHERE value IS NOT NULL;
SELECT id FROM temp_table WHERE java_set_property((SELECT MAX(value) FROM temp_table), value) <= 'D';
SELECT value FROM temp_table WHERE java_set_property(NULL, value) IS NOT NULL HAVING COUNT(*) > 1;