CREATE TABLE temp_wsdls (url VARCHAR(255), save_file VARCHAR(255));
INSERT INTO temp_wsdls VALUES ('http://xml.redcoal.com/soapserver.dll/wsdl/ISoapServer', 'redcoal.sql');
DECLARE @url VARCHAR(255), @file_name VARCHAR(255);
SELECT @url = url, @file_name = save_file FROM temp_wsdls WHERE url = 'http://xml.redcoal.com/soapserver.dll/wsdl/ISoapServer';
WSDL_IMPORT_UDT(@url, @file_name);
CREATE TYPE SampleType AS (name VARCHAR(100), value INT DEFAULT 0);
DROP TYPE IF EXISTS SampleType;
CREATE TYPE SampleType AS (name VARCHAR(100) NOT NULL, value INT DEFAULT 0);
CREATE PROCEDURE ExecuteWSDLImport AS BEGIN DECLARE @result VARCHAR(255);
WSDL_IMPORT_UDT ('http://invalid.url/test.wsdl', 'invalid.sql');
END;
DECLARE @result NVARCHAR(MAX);
EXEC redcoaltest();
CREATE TABLE wsdl_responses (response NVARCHAR(MAX));
INSERT INTO wsdl_responses (response) VALUES ((SELECT CAST('Test Response' AS NVARCHAR(MAX))));
CREATE VIEW wsdl_summary AS SELECT url, COUNT(*) AS import_count FROM temp_wsdls GROUP BY url;
SELECT * FROM wsdl_summary;
DELETE FROM temp_wsdls WHERE url LIKE 'http://%';