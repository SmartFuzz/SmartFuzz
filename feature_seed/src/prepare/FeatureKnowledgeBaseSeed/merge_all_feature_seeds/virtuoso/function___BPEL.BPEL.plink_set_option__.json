CREATE TABLE PartnerLinks (name VARCHAR(255), option_name VARCHAR(255), option_value VARCHAR(255));
INSERT INTO PartnerLinks (name, option_name, option_value) VALUES ('WSSecho', 'wss-in-encrypt', 'Mandatory');
INSERT INTO PartnerLinks (name, option_name, option_value) VALUES ('WSSecho', 'wss-in-signature', 'Optional');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wss-in-encrypt', 'Mandatory');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'http-auth-uid', 'user1');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'http-auth-pwd', 'pass1');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wss-priv-key', 'private-key1');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wss-pub-key', 'public-key1');
CREATE TABLE SecurityOptions (option_type VARCHAR(255), option_value VARCHAR(255));
INSERT INTO SecurityOptions (option_type, option_value) VALUES ('wss-in-signers', 'key1,key2');
INSERT INTO SecurityOptions (option_type, option_value) VALUES ('wss-out-signature-type', 'RSA-SHA256');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wsrm-in-type', 'AtMostOnce');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wsrm-out-type', 'ExactlyOnce');
SELECT * FROM PartnerLinks WHERE name = 'WSSecho';
SELECT po.option_name, po.option_value FROM PartnerLinks pl JOIN SecurityOptions po ON pl.option_name = po.option_type WHERE pl.name = 'WSSecho';
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wss-out-signature-function', 'custom_signature_func');
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wsrm-in-type', (SELECT option_value FROM SecurityOptions WHERE option_type = 'wsrm-in-type' LIMIT 1));
BPEL.BPEL.plink_set_option('WSSecho', 'service', 'wss-out-encrypt-key', (SELECT option_value FROM SecurityOptions WHERE option_type = 'wss-out-encrypt-key' LIMIT 1));