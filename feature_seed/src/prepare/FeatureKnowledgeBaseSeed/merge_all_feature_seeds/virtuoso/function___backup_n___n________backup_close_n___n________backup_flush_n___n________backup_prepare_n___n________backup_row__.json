CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100), created_at TIMESTAMP);
INSERT INTO test_table (id, name, created_at) VALUES (1, 'Test Data 1', CURRENT_TIMESTAMP);
INSERT INTO test_table (id, name, created_at) VALUES (2, 'Test Data 2', CURRENT_TIMESTAMP);
COMMIT;
BACKUP_PREPARE;
SELECT _ROW FROM test_table WHERE id = 1;
BACKUP_ROW (SELECT _ROW FROM test_table WHERE id = 1);
BACKUP_FLUSH;
BACKUP_ROW (SELECT _ROW FROM test_table WHERE id = 2);
BACKUP_CLOSE;
BACKUP('/dev/null');
BACKUP_PREPARE;
INSERT INTO test_table (id, name, created_at) VALUES (3, 'Test Data 3', CURRENT_TIMESTAMP);
BACKUP_ROW (SELECT _ROW FROM test_table WHERE id = 3);
BACKUP_CLOSE;
BACKUP('/dev/null');
BACKUP_PREPARE;
SELECT _ROW FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name LIKE 'Test%');
BACKUP_ROW (SELECT _ROW FROM test_table WHERE id = 1);
BACKUP_FLUSH;
BACKUP_ROW (SELECT _ROW FROM test_table WHERE id = 2);
BACKUP_CLOSE;
BACKUP_PREPARE;
SELECT _ROW FROM test_table ORDER BY created_at DESC LIMIT 1;
BACKUP_ROW (SELECT _ROW FROM test_table ORDER BY created_at ASC LIMIT 1);
BACKUP_CLOSE;