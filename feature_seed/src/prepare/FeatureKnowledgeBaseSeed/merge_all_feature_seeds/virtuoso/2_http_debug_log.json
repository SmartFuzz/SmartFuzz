CREATE TABLE webdav_logs (id INT PRIMARY KEY, log_message VARCHAR(500), log_time TIMESTAMP);
INSERT INTO webdav_logs (id, log_message, log_time) VALUES (1, 'Starting WebDAV logging', CURRENT_TIMESTAMP);
SELECT http_debug_log('dav.log') AS log_status, xpath_integer(log_message, '/path/to/element') AS extracted_value FROM webdav_logs WHERE log_time >= CURRENT_TIMESTAMP - INTERVAL '1 DAY';
WITH recent_logs AS (SELECT log_message FROM webdav_logs WHERE log_time > CURRENT_TIMESTAMP - INTERVAL '1 HOUR') SELECT http_debug_log(NULL), COUNT(*) AS total_logs FROM recent_logs HAVING total_logs > 0;
CREATE TABLE xml_data (id INT PRIMARY KEY, data XML);
INSERT INTO xml_data (id, data) VALUES (1, '<root><value>42</value></root>');
SELECT http_debug_log('dav.log'), xpath_integer(data, '/root/value') AS extracted_integer FROM xml_data WHERE id = 1 AND extracted_integer IS NOT NULL;
SELECT http_debug_log(NULL), COUNT(*) FROM (SELECT data FROM xml_data WHERE id < 10) AS subquery GROUP BY data HAVING COUNT(data) >= 1;
DROP TABLE IF EXISTS temp_logs;
CREATE TEMPORARY TABLE temp_logs AS SELECT log_message, http_debug_log('temp_dav.log') FROM webdav_logs WHERE log_time IS NULL;
UPDATE webdav_logs SET log_time = CURRENT_TIMESTAMP WHERE id = (SELECT MAX(id) FROM webdav_logs);