CREATE GRAPH <http://example.com>;
DB.DBA.RDF_LOAD_RDFXML_MT(file_to_string_output('tmp/large_file.rdf'), '', 'http://example.com');
SELECT * FROM <http://example.com> WHERE {?s ?p ?o};
CREATE GRAPH <http://test.com>;
INSERT DATA { GRAPH <http://test.com> { <http://test.com/s1> <http://test.com/p1> <http://test.com/o1> } };
SELECT DISTINCT ?s WHERE { GRAPH <http://example.com> { ?s ?p ?o } } LIMIT 100;
SELECT ?s ?p ?o WHERE { GRAPH <http://example.com> { ?s ?p ?o } UNION SELECT ?s ?p ?o WHERE { GRAPH <http://test.com> { ?s ?p ?o } } };
CREATE TEMPORARY TABLE temp_data (id INT, name VARCHAR(255));
INSERT INTO temp_data VALUES (1, 'Test'), (2, 'Another Test');
SELECT * FROM temp_data WHERE id IN (SELECT id FROM temp_data WHERE name LIKE '%Test%');
DELETE FROM RDF_QUAD WHERE G = DB.DBA.RDF_MAKE_IID_OF_QNAME('http://example.com');
CREATE OR REPLACE FUNCTION MY_LOAD_FILE(full_uri VARCHAR) RETURNS VARCHAR AS $$ BEGIN DECLARE dattext VARCHAR;
dattext := CAST(XML_URI_GET_AND_CACHE(full_uri) AS VARCHAR);
DB.DBA.RDF_LOAD_RDFXML_MT(dattext, full_uri, full_uri);
RETURN full_uri;
END;
$$ LANGUAGE plpgsql;
EXECUTE MY_LOAD_FILE('http://example.com/file.rdf');
SELECT ?s ?p ?o FROM <http://example.com> WHERE (?p IN (SELECT ?p FROM <http://example.com> WHERE ?o = 'http://example.com/some_object')) LIMIT 50;
CREATE INDEX idx_s ON RDF_QUAD (s);
SELECT COUNT(*) FROM RDF_QUAD WHERE G = DB.DBA.RDF_MAKE_IID_OF_QNAME('http://example.com');
DB.DBA.RDF_LOAD_RDFXML_MT(file_to_string_output('tmp/small_file.rdf'), '', 'http://example.com/small');
CREATE TABLE IF NOT EXISTS log_table (log_id SERIAL PRIMARY KEY, log_message TEXT, log_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO log_table (log_message) VALUES ('Loading RDF/XML from large_file.rdf started');
SELECT EXISTS (SELECT 1 FROM RDF_QUAD WHERE G = DB.DBA.RDF_MAKE_IID_OF_QNAME('http://example.com'));
CALL MY_SPARQL_REPORT('Report for loading RDF files completed.');
DROP GRAPH <http://test.com>;
CREATE VIEW rdf_view AS SELECT ?s ?p ?o FROM <http://example.com>;
SELECT * FROM rdf_view WHERE ?p = <http://www.w3.org/1999/02/22-rdf-syntax-ns#type>;