CREATE TABLE odbcCustomers (id INT, name VARCHAR, email VARCHAR, created_at TIMESTAMP);
INSERT INTO odbcCustomers VALUES (1, 'John Doe', 'john@example.com', CURRENT_TIMESTAMP);
INSERT INTO odbcCustomers VALUES (2, 'Jane Smith', 'jane@example.com', CURRENT_TIMESTAMP);
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcCustomers#', 1, 'urn:rdf:materialized:view:odbc:Customers');
CREATE VIEW transientCustomerView AS SELECT * FROM odbcCustomers WHERE created_at > NOW() - INTERVAL '1 month';
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcCustomers#', 0, 'urn:rdf:materialized:view:odbc:Customers', 1, 1);
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcCustomers#', 1, 'urn:rdf:materialized:view:odbc:Customers', 0, 1);
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcCustomers#', 1, 'urn:rdf:materialized:view:odbc:Customers', 1, 0);
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcCustomers#', 0, 'urn:rdf:materialized:view:odbc:Customers', 0, 0);
CREATE TABLE odbcOrders (order_id INT, customer_id INT, order_date TIMESTAMP, amount DECIMAL);
INSERT INTO odbcOrders VALUES (101, 1, CURRENT_TIMESTAMP, 250.75);
INSERT INTO odbcOrders VALUES (102, 2, CURRENT_TIMESTAMP, 100.50);
CREATE VIEW transientOrderView AS SELECT o.order_id, c.name FROM odbcOrders o JOIN odbcCustomers c ON o.customer_id = c.id WHERE o.order_date > NOW() - INTERVAL '1 month';
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcOrders#', 1, 'urn:rdf:materialized:view:odbc:Orders');
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcOrders#', 0, 'urn:rdf:materialized:view:odbc:Orders', 1, 1);
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcOrders#', 1, 'urn:rdf:materialized:view:odbc:Orders', 1, 0);
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/odbcOrders#', 0, 'urn:rdf:materialized:view:odbc:Orders', 0, 0);
CREATE VIEW complexView AS SELECT c.name, SUM(o.amount) AS total_amount FROM odbcCustomers c LEFT JOIN odbcOrders o ON c.id = o.customer_id GROUP BY c.name HAVING SUM(o.amount) > 200;
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/complexView#', 1, 'urn:rdf:materialized:view:odbc:ComplexView');
RDF_VIEW_SYNC_TO_PHYSICAL ('http://www.openlinksw.com/schemas/complexView#', 0, 'urn:rdf:materialized:view:odbc:ComplexView', 1, 1);