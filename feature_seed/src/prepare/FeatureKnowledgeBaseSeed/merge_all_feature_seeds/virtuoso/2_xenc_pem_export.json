CREATE TABLE cert_data (id INT PRIMARY KEY, key_data TEXT, name VARCHAR(100), c VARCHAR(2), o VARCHAR(100), ou VARCHAR(100), email VARCHAR(255));
INSERT INTO cert_data VALUES (1, '-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----', 'Test User', 'US', 'Test Org', 'Test Org Unit', 'test@example.com');
SELECT xenc_pem_export(key_data) AS pem_output FROM cert_data WHERE name ILIKE '%Test%';
SELECT xenc_pem_export(key_data) FROM cert_data WHERE c ILIKE (SELECT 'US' UNION SELECT NULL);
SELECT count(*) FROM (SELECT xenc_pem_export(key_data) AS pem_output, name FROM cert_data WHERE name ILIKE '%' || NULL || '%' GROUP BY name HAVING length(pem_output) > 0) AS subquery;
SELECT xenc_pem_export(COALESCE(key_data, 'Default Value')) FROM cert_data WHERE o ILIKE '%Org%';
CREATE TABLE cert_log (log_id INT PRIMARY KEY, cert_id INT, log_date TIMESTAMP DEFAULT CURRENT_TIMESTAMP, FOREIGN KEY(cert_id) REFERENCES cert_data(id));
INSERT INTO cert_log (log_id, cert_id) VALUES (1, 1);
SELECT log_date, xenc_pem_export(COALESCE((SELECT key_data FROM cert_data WHERE id = log.cert_id), 'Fallback Key')) AS pem_output FROM cert_log log WHERE log.cert_id IN (SELECT id FROM cert_data WHERE name ILIKE 'Test%');
SELECT xenc_pem_export(NULLIF(key_data, '')) FROM cert_data WHERE name ILIKE '%User%';
CREATE TABLE user_actions (action_id INT PRIMARY KEY, action_description VARCHAR(255), user_email VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO user_actions (action_id, action_description, user_email) VALUES (1, 'Exported certificate', 'test@example.com');
SELECT ua.action_description, xenc_pem_export(ud.key_data) FROM user_actions ua JOIN cert_data ud ON ua.user_email ILIKE ud.email WHERE ua.created_at >= NOW() - INTERVAL '1 day';
SELECT xenc_pem_export(key_data) FROM cert_data WHERE key_data ILIKE '%' || (SELECT 'certificate' UNION SELECT NULLIF('not_found', 'not_found')) || '%';
SELECT DISTINCT xenc_pem_export(key_data) FROM cert_data WHERE key_data IS NOT NULL ORDER BY xenc_pem_export(key_data) LIMIT 10;
ALTER TABLE cert_data ADD COLUMN processed BOOLEAN DEFAULT FALSE;
UPDATE cert_data SET processed = TRUE WHERE key_data IS NOT NULL AND key_data ILIKE '-----BEGIN%';
SELECT xenc_pem_export(key_data) AS pem_output FROM cert_data WHERE processed IS TRUE AND (name ILIKE 'Te%' OR c ILIKE 'U%');
DROP TABLE IF EXISTS temp_cert_data;