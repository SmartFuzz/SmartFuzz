CREATE TABLE java_objects (id INTEGER PRIMARY KEY, object_ref VARCHAR(255));
INSERT INTO java_objects (object_ref) VALUES (java_new_object('java.util.Date', vector('L', 1000)));
INSERT INTO java_objects (object_ref) VALUES (java_new_object('java.util.ArrayList'));
INSERT INTO java_objects (object_ref) VALUES (java_new_object('java.lang.String', vector('L', 'Hello World')));
INSERT INTO java_objects (object_ref) VALUES (java_new_object('java.util.Date', vector('L', 0)));
INSERT INTO java_objects (object_ref) VALUES (java_new_object('java.util.HashMap', vector('L', 42)));
SELECT object_ref FROM java_objects WHERE id IN (SELECT id FROM java_objects WHERE object_ref IS NOT NULL);
SELECT * FROM java_objects WHERE object_ref LIKE java_new_object('java.lang.String', vector('L', '%'));
SELECT COUNT(*) FROM java_objects WHERE object_ref = java_new_object('java.util.Date');
SELECT object_ref FROM java_objects WHERE object_ref IN (java_new_object('java.util.Set'), java_new_object('java.util.Queue'));
INSERT INTO java_objects (object_ref) VALUES (java_new_object('java.util.List', vector('L', 1, 2, 3, 4, 5)));
UPDATE java_objects SET object_ref = java_new_object('java.util.Map', vector('L', 'key', 'value')) WHERE id = 1;
DELETE FROM java_objects WHERE object_ref = java_new_object('java.util.Date', vector('L', 1000));