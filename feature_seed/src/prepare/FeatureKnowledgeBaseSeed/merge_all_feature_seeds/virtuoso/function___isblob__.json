CREATE TABLE test_blob_table (id INT PRIMARY KEY, data LONG VARCHAR);
INSERT INTO test_blob_table (id, data) VALUES (1, 'This is a test string.');
INSERT INTO test_blob_table (id, data) VALUES (2, 'Another test string.');
SELECT isblob(data) FROM test_blob_table WHERE id = 1;
SELECT isblob(data) AS is_blob FROM test_blob_table WHERE id = 2;
CREATE TABLE test_nested_table (id INT PRIMARY KEY, ref_id INT REFERENCES test_blob_table(id), info VARCHAR(255));
INSERT INTO test_nested_table (id, ref_id, info) VALUES (1, 1, 'Nested info linked to blob.');
SELECT nt.info, isblob(tb.data) FROM test_nested_table nt JOIN test_blob_table tb ON nt.ref_id = tb.id;
CREATE TABLE longvarchar_table (id INT PRIMARY KEY, content LONG VARCHAR);
INSERT INTO longvarchar_table (id, content) VALUES (1, 'Data with long varchar type.');
SELECT id, isblob(content) FROM longvarchar_table WHERE LENGTH(content) > 0;
WITH BlobCheck AS (SELECT id, isblob(data) AS blob_status FROM test_blob_table) SELECT * FROM BlobCheck WHERE blob_status = 1;
SELECT COUNT(*) FROM test_blob_table WHERE isblob(data) = 1;
SELECT tb.id, CASE WHEN isblob(data) = 1 THEN 'Blob' ELSE 'Not a Blob' END AS Blob_Status FROM test_blob_table tb;