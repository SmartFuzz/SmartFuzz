CREATE TABLE temp_keys (key_name VARCHAR(50), session_key BINARY(24), key_length INT);
INSERT INTO temp_keys (key_name, session_key, key_length) VALUES ('test_key_1', xenc_key_AES_rand_create('key1', 128), 128);
INSERT INTO temp_keys (key_name, session_key, key_length) VALUES ('test_key_2', xenc_key_AES_rand_create('key2', 256), 256);
INSERT INTO temp_keys (key_name, session_key, key_length) VALUES ('test_key_3', xenc_key_AES_rand_create('key3', 192), 192);
SELECT key_name, key_length FROM temp_keys WHERE key_length IN (128, 192, 256);
SELECT key_name FROM temp_keys WHERE session_key IN (SELECT session_key FROM temp_keys WHERE key_length = 128);
DELETE FROM temp_keys WHERE key_length < 192;
SELECT COUNT(*) FROM temp_keys WHERE session_key = xenc_key_AES_rand_create('key4', 128) AND key_length = 128;
INSERT INTO temp_keys (key_name, session_key, key_length) SELECT 'subquery_key', xenc_key_AES_rand_create('subquery_key', key_length), key_length FROM temp_keys WHERE key_length > 128;
WITH key_generation AS (SELECT 'gen_key_' || ROW_NUMBER() OVER() AS key_name, xenc_key_AES_rand_create(ROW_NUMBER() OVER(), 128) AS session_key FROM temp_keys) INSERT INTO temp_keys SELECT * FROM key_generation;