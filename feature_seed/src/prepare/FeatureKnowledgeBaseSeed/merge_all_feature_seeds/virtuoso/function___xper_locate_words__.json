CREATE TABLE xper_entities (id INT PRIMARY KEY, entity_data XML, text_data TEXT);
INSERT INTO xper_entities (id, entity_data, text_data) VALUES (1, '<root><child>Hello world!</child></root>', 'Hello world!');
INSERT INTO xper_entities (id, entity_data, text_data) VALUES (2, '<root><child>This is a test XML for locating words.</child></root>', 'This is a test XML for locating words.');
INSERT INTO xper_entities (id, entity_data, text_data) VALUES (3, '<root><child>Another test with some different text.</child></root>', 'Another test with some different text.');
SELECT xper_locate_words(entity_data, 'Hello') FROM xper_entities WHERE id = 1;
SELECT xper_locate_words(entity_data, 'test XML') FROM xper_entities WHERE id = 2;
SELECT xper_locate_words(entity_data, 'different text') FROM xper_entities WHERE id = 3;
SELECT xper_locate_words(entity_data, 'Hello world, this is a non-existent phrase') FROM xper_entities WHERE id = 1;
SELECT id, xper_locate_words(entity_data, text_data) AS fragment FROM xper_entities WHERE text_data LIKE '%test%';
SELECT id FROM xper_entities WHERE xper_locate_words(entity_data, 'test') IS NOT NULL;
SELECT (SELECT xper_locate_words(entity_data, 'Another') FROM xper_entities WHERE id = 3) AS fragment1, (SELECT xper_locate_words(entity_data, 'test') FROM xper_entities WHERE id = 2) AS fragment2;
SELECT xper_locate_words(entity_data, 'XML') FROM xper_entities WHERE id IN (1, 2, 3);
SELECT e.id, xper_locate_words(e.entity_data, 'Hello') AS hello_fragment FROM xper_entities e JOIN (SELECT id FROM xper_entities WHERE text_data LIKE '%Hello%') t ON e.id = t.id;
DELETE FROM xper_entities WHERE id = 3;
SELECT xper_locate_words(entity_data, 'non-existent') FROM xper_entities WHERE id NOT IN (SELECT id FROM xper_entities WHERE text_data LIKE '%Hello%');