CREATE TABLE points (id INTEGER PRIMARY KEY, geom GEOMETRY);
INSERT INTO points (id, geom) VALUES (1, ST_Point(10, 20));
INSERT INTO points (id, geom) VALUES (2, ST_Point(10, 20, 30));
INSERT INTO points (id, geom) VALUES (3, ST_Point(10, 20, 30, 40));
INSERT INTO points (id, geom) VALUES (4, ST_Point(10, 20, NULL, 40));
INSERT INTO points (id, geom) VALUES (5, ST_Point(NULL, NULL, 30, 40));
SELECT id, ST_Zmflag(geom) FROM points;
SELECT p1.id, ST_Zmflag(p1.geom) AS zmflag1, ST_Zmflag(p2.geom) AS zmflag2 FROM points p1 JOIN points p2 ON p1.id <> p2.id;
SELECT id, ST_Zmflag(ST_Point(0, 0, 0, 0)) AS zmflag FROM points WHERE id = 1;
SELECT id, ST_Zmflag(ST_MakePoint(10, 20, 30, 40)) AS zmflag FROM points WHERE geom IS NOT NULL;
SELECT id, ST_Zmflag(ST_Point(1, 2)) FROM (SELECT geom FROM points WHERE id = 2) AS subquery;
SELECT id FROM points WHERE ST_Zmflag(geom) = 0 UNION SELECT id FROM points WHERE ST_Zmflag(geom) = 1;
CREATE TABLE more_points (id SERIAL, geom GEOMETRY);
INSERT INTO more_points (geom) VALUES (ST_Point(1, 1, 1, 1)), (ST_Point(2, 2)), (ST_Point(3, 3, NULL, 3));
SELECT p.id, ST_Zmflag(p.geom) FROM points p JOIN more_points mp ON ST_Distance(p.geom, mp.geom) < 10;
SELECT p.id, ST_Zmflag(ST_Centroid(mp.geom)) FROM points p INNER JOIN more_points mp ON p.id = 1;