CREATE TABLE test_strings (id INTEGER PRIMARY KEY, original VARCHAR, compressed VARCHAR);
INSERT INTO test_strings (id, original) VALUES (1, 'sample text for compression');
INSERT INTO test_strings (id, original) VALUES (2, 'another example, testing compression function!');
CREATE PROCEDURE gz_test_compression (IN str VARCHAR) BEGIN DECLARE res ANY;
DECLARE _out VARCHAR;
DECLARE _len INTEGER;
RESULT_NAMES (_out, _len);
res := string_output ();
RESULT (str, LENGTH(str));
str := gz_compress(str);
RESULT ('binary', LENGTH(str));
gz_uncompress(str, res);
RESULT (res, LENGTH(res));
END;
CALL gz_test_compression('quick brown fox jumps over the lazy dog');
CALL gz_test_compression('The quick brown fox jumps over the lazy dog.');
SELECT id, original, LENGTH(original), gz_compress(original) AS compressed FROM test_strings;
SELECT COUNT(*), MIN(original), MAX(original) FROM test_strings WHERE LENGTH(original) > 10;
CREATE TABLE compressed_data (id INTEGER PRIMARY KEY, data BINARY);
INSERT INTO compressed_data (id, data) SELECT id, gz_compress(original) FROM test_strings;
SELECT id, LENGTH(data) AS compressed_length FROM compressed_data WHERE LENGTH(data) > 20;
CREATE PROCEDURE gz_test_complex (IN str1 VARCHAR, IN str2 VARCHAR) BEGIN DECLARE res1 ANY;
DECLARE res2 ANY;
DECLARE _out1 VARCHAR;
DECLARE _out2 VARCHAR;
DECLARE _len1 INTEGER;
DECLARE _len2 INTEGER;
RESULT_NAMES (_out1, _len1, _out2, _len2);
res1 := string_output ();
res2 := string_output ();
RESULT (str1, LENGTH(str1));
str1 := gz_compress(str1);
str2 := gz_compress(str2);
RESULT ('compressed str1', LENGTH(str1));
RESULT ('compressed str2', LENGTH(str2));
gz_uncompress(str1, res1);
gz_uncompress(str2, res2);
RESULT (res1, LENGTH(res1));
RESULT (res2, LENGTH(res2));
END;
CALL gz_test_complex('data string for compression testing', 'another string for gz_compress testing');