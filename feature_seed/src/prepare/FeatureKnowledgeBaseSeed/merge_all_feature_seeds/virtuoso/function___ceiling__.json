CREATE TABLE test_numbers (value DECIMAL(10, 4));
INSERT INTO test_numbers (value) VALUES (12.3456), (-12.3456), (0.5135), (0), (2.9999), (-3.0001), (5.5000), (NaN), (Infinity);
SELECT ceiling(value) FROM test_numbers;
SELECT ceiling(value) AS rounded_value FROM test_numbers WHERE value > -1;
SELECT ceiling(value) AS rounded_value FROM test_numbers WHERE value < 0;
SELECT ceiling(value) + 1 AS adjusted_value FROM test_numbers WHERE value > 0;
SELECT ceiling(MAX(value)) AS max_ceiling_value FROM test_numbers;
SELECT ceiling(MIN(value)) AS min_ceiling_value FROM test_numbers;
SELECT value, ceiling(value) FROM (SELECT value FROM test_numbers WHERE value IS NOT NULL) AS subquery;
SELECT a.value, b.value, ceiling(a.value + b.value) AS combined_ceiling FROM test_numbers AS a JOIN test_numbers AS b ON a.value < b.value;
SELECT COUNT(*) FROM test_numbers WHERE ceiling(value) > 0;
SELECT DISTINCT ceiling(value) FROM test_numbers WHERE value BETWEEN -5 AND 5;
CREATE TABLE test_aggregates AS SELECT ceiling(SUM(value)) AS total_ceiling FROM test_numbers;
SELECT ceiling(COALESCE(NULLIF(value, -12.3456), 0)) AS coalesced_ceiling FROM test_numbers;