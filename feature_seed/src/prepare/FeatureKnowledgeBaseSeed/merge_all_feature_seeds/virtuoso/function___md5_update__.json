CREATE TABLE test_md5 (id INT PRIMARY KEY, data VARCHAR(255), md5_context VARCHAR(255));
INSERT INTO test_md5 (id, data, md5_context) VALUES (1, 'test data', md5('test data'));
INSERT INTO test_md5 (id, data, md5_context) VALUES (2, 'sample data', md5('sample data'));
SELECT md5_update(md5_context, 'new data') FROM test_md5 WHERE id = 1;
SELECT md5_update(md5_context, 'another update') FROM test_md5 WHERE id = 2;
SELECT md5_update(md5_context, '') FROM test_md5 WHERE id = 1;
INSERT INTO test_md5 (id, data, md5_context) VALUES (3, '', md5(''));
SELECT md5_update(md5_context, ' ') FROM test_md5 WHERE id = 3;
WITH updated_md5 AS (SELECT md5_update(md5_context, 'complex data') as new_md5 FROM test_md5 WHERE id = 1) SELECT * FROM updated_md5;
SELECT a.id, md5_update(b.md5_context, 'joined data') FROM test_md5 a JOIN test_md5 b ON a.id != b.id WHERE a.id = 1;
SELECT md5_update(md5_context, 'max length testing') FROM test_md5 WHERE data = (SELECT data FROM test_md5 ORDER BY LENGTH(data) DESC LIMIT 1);
SELECT md5_update(md5_context, 'very long data string that exceeds normal expectation for testing purposes and boundary conditions') FROM test_md5 WHERE id = 1;
INSERT INTO test_md5 (id, data, md5_context) SELECT 4, data, md5_context FROM test_md5 WHERE id = 1;
SELECT COUNT(*) FROM test_md5 WHERE md5_update(md5_context, 'update from count') IS NOT NULL;
SELECT DISTINCT md5_update(md5_context, 'distinct update') FROM test_md5;
SELECT md5_update(md5_context, (SELECT data FROM test_md5 WHERE id = 2)) FROM test_md5 WHERE id = 1;