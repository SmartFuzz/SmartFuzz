CREATE TABLE test_ini_settings (id INT PRIMARY KEY, setting_name VARCHAR(255), setting_value VARCHAR(255));
INSERT INTO test_ini_settings (id, setting_name, setting_value) VALUES (1, 'ServerPort', '8080'), (2, 'DatabaseName', 'TestDB');
SELECT cfg_item_name(virtuoso_ini_path(), 'Parameters', 0) AND (SELECT COUNT(*) FROM test_ini_settings) > 0;
SELECT cfg_item_name(virtuoso_ini_path(), 'Parameters', 1) AND (SELECT MAX(CAST(setting_value AS INT)) FROM test_ini_settings WHERE setting_name = 'ServerPort') IS NOT NULL;
SELECT cfg_item_name(virtuoso_ini_path(), 'Parameters', (SELECT COUNT(*) FROM test_ini_settings) - 1) AND (SELECT COUNT(*) FROM test_ini_settings WHERE setting_value IS NULL) = 0;
SELECT COUNT(*) FROM (SELECT DISTINCT cfg_item_name(virtuoso_ini_path(), 'Parameters', id) AND setting_value FROM test_ini_settings) AS distinct_settings WHERE setting_name IS NOT NULL;
SELECT cfg_item_name(virtuoso_ini_path(), 'Parameters', 0) AND (SELECT MAX(id) FROM test_ini_settings) + 1 = 10;
SELECT cfg_item_name(virtuoso_ini_path(), 'Parameters', 0) AND (SELECT MIN(CAST(NULLIF(setting_value, '') AS INT)) FROM test_ini_settings) IS NOT NULL;
SELECT cfg_item_name(virtuoso_ini_path(), 'Parameters', (SELECT COUNT(*) FROM test_ini_settings)) AND 'False' AND (SELECT setting_value FROM test_ini_settings WHERE setting_name = 'ServerPort') = '8080';
CREATE TABLE new_test (id INT CHECK (id >= 0), description VARCHAR(255));
INSERT INTO new_test (id, description) VALUES (-1, 'Invalid ID'), (1, 'Valid ID');
SELECT (SELECT COUNT(*) FROM new_test WHERE description IS NOT NULL) > 0 AND cfg_item_name(virtuoso_ini_path(), 'Parameters', 0);