CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(100), value DECIMAL(10,2));
INSERT INTO test_table (id, name, value) VALUES (1, 'test1', 123.45);
INSERT INTO test_table (id, name, value) VALUES (2, 'test2', 678.90);
SELECT soap_print_box((SELECT MAX(value) FROM test_table WHERE name = 'test1'));
SELECT soap_print_box(value) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value > 100);
SELECT soap_print_box((SELECT SUM(value) FROM test_table WHERE id >= 1));
SELECT soap_print_box((SELECT name FROM test_table WHERE id = 1) || ' ' || (SELECT name FROM test_table WHERE id = 2));
SELECT soap_print_box((SELECT value FROM test_table WHERE id = (SELECT MIN(id) FROM test_table)));
WITH cte AS (SELECT id, value FROM test_table WHERE value < 500) SELECT soap_print_box(AVG(value)) FROM cte;
CREATE TABLE another_table (id INTEGER PRIMARY KEY, description VARCHAR(200));
INSERT INTO another_table (id, description) VALUES (1, 'Another test box');
SELECT soap_print_box((SELECT description FROM another_table WHERE id = 1) || ': Value is ' || (SELECT value FROM test_table WHERE id = 1));
SELECT soap_print_box(CONCAT(name, ': ', value)) FROM test_table WHERE name LIKE 'test%';
SELECT soap_print_box((SELECT COUNT(*) FROM test_table) || ' rows found.');
SELECT soap_print_box((SELECT COALESCE(MAX(value), 0) FROM test_table)) AS formatted_value;