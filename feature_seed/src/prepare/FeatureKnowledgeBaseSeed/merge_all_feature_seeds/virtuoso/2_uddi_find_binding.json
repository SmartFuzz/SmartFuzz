CREATE TABLE bindings (id INT PRIMARY KEY, name VARCHAR(255), bindingTemplate TEXT, spatial_data POINT);
INSERT INTO bindings (id, name, bindingTemplate, spatial_data) VALUES (1, 'binding1', 'Template1', POINT(1, 1)), (2, 'binding2', 'Template2', POINT(2, 2));
SELECT * FROM bindings WHERE bif:st_overlaps(spatial_data, POINT(1, 1)) AND id IN (SELECT id FROM bindings WHERE bindingTemplate LIKE 'Template%');
SELECT id, name FROM bindings WHERE bif:st_overlaps(spatial_data, POINT(1.5, 1.5)) GROUP BY name HAVING COUNT(id) > 0;
SELECT id, name, COUNT(*) OVER (PARTITION BY name) AS count_per_binding FROM bindings WHERE id IN (SELECT id FROM bindings WHERE bif:st_overlaps(spatial_data, POINT(2, 2)));
SELECT uddi_find_binding((SELECT bindingTemplate FROM bindings WHERE id = 1)) AS result WHERE bif:st_overlaps(spatial_data, POINT(NULLIF(name, 'binding2')));
SELECT * FROM (SELECT id, COUNT(*) FROM bindings GROUP BY name HAVING MAX(id) > (SELECT MAX(id) FROM bindings WHERE id < 1)) AS subquery WHERE bif:st_overlaps(spatial_data, POINT(1, 1));
INSERT INTO bindings (id, name, bindingTemplate, spatial_data) VALUES (3, 'binding3', NULL, POINT(NAN,NAN));
SELECT uddi_find_binding(NULL) AS search_result WHERE bif:st_overlaps(spatial_data, POINT(1, '1'));
DROP TABLE IF EXISTS temp_bindings;
CREATE TEMPORARY TABLE temp_bindings AS SELECT * FROM bindings WHERE bindingTemplate IS NOT NULL;