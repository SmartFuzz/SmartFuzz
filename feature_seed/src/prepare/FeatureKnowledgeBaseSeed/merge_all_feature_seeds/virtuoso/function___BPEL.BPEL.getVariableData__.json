CREATE TABLE requests (id INTEGER PRIMARY KEY, req_payload VARCHAR);
INSERT INTO requests (id, req_payload) VALUES (1, '<destRequest><city>New York</city><country>USA</country></destRequest>');
INSERT INTO requests (id, req_payload) VALUES (2, '<destRequest><city>Tokyo</city><country>Japan</country></destRequest>');
DECLARE city, country VARCHAR;
city := CAST(BPEL.BPEL.getVariableData('requests', 'req_payload', '/destRequest/city/text()') AS VARCHAR);
country := CAST(BPEL.BPEL.getVariableData('requests', 'req_payload', '/destRequest/country/text()') AS VARCHAR);
SELECT city, country FROM (SELECT CAST(BPEL.BPEL.getVariableData('requests', 'req_payload', '/destRequest/city/text()') AS VARCHAR) AS city, CAST(BPEL.BPEL.getVariableData('requests', 'req_payload', '/destRequest/country/text()') AS VARCHAR) AS country FROM requests) AS derived_table;
SELECT * FROM requests WHERE id IN (SELECT id FROM requests WHERE req_payload LIKE '%Tokyo%');
CREATE TABLE countries (id INTEGER PRIMARY KEY, country_name VARCHAR);
INSERT INTO countries (id, country_name) VALUES (1, 'USA');
INSERT INTO countries (id, country_name) VALUES (2, 'Japan');
SELECT r.city, c.country_name FROM (SELECT CAST(BPEL.BPEL.getVariableData('requests', 'req_payload', '/destRequest/city/text()') AS VARCHAR) AS city, id FROM requests) AS r JOIN countries c ON r.id = c.id;
city := CAST(BPEL.BPEL.getVariableData('requests', 'req_payload', '/destRequest/city/text()') AS VARCHAR) WHERE city IS NOT NULL;
