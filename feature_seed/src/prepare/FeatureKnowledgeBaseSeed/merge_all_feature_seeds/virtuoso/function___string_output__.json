CREATE TABLE test_table (id INTEGER PRIMARY KEY, content LONG VARCHAR);
CREATE PROCEDURE test_string_output (IN input_text VARCHAR) { DECLARE output_stream ANY;
DECLARE result VARCHAR;
result_names(result);
output_stream := string_output();
http(input_text, output_stream);
INSERT INTO test_table (content) VALUES (output_stream);
result(string_output_string(output_stream));
};
CALL test_string_output('Hello World');
SELECT * FROM test_table;
CREATE PROCEDURE nested_test (IN param VARCHAR) { DECLARE inner_output ANY;
inner_output := string_output();
http(param, inner_output);
result(string_output_string(inner_output));
};
CREATE TABLE nested_table (id INTEGER PRIMARY KEY, message LONG VARCHAR);
INSERT INTO nested_table (id, message) VALUES (1, string_output_string(string_output()));
CALL nested_test('Nested procedure test');
SELECT * FROM nested_table WHERE message = (SELECT message FROM nested_table WHERE id = 1);
CREATE TABLE second_test_table (reference_id INTEGER, description LONG VARCHAR);
INSERT INTO second_test_table (reference_id, description) SELECT id, content FROM test_table;
CREATE PROCEDURE complex_test (IN input_text VARCHAR) { DECLARE complex_output ANY;
complex_output := string_output();
http(concat('Complex: ', input_text), complex_output);
INSERT INTO test_table (content) VALUES (complex_output);
result(complex_output);
};
CALL complex_test('Testing complex scenarios');
SELECT * FROM test_table WHERE id IN (SELECT reference_id FROM second_test_table WHERE reference_id < 5);
CREATE TABLE additional_test_table (num INTEGER, info LONG VARCHAR);
INSERT INTO additional_test_table (num) VALUES (1);
CREATE PROCEDURE multi_output_test (IN input_text VARCHAR) { DECLARE output1 ANY;
DECLARE output2 ANY;
output1 := string_output();
output2 := string_output();
http(input_text, output1);
http(concat('Output: ', input_text), output2);
INSERT INTO additional_test_table (info) VALUES (output1);
INSERT INTO additional_test_table (info) VALUES (output2);
};
CALL multi_output_test('Multi-output test');
SELECT * FROM additional_test_table WHERE num = (SELECT MAX(num) FROM additional_test_table);