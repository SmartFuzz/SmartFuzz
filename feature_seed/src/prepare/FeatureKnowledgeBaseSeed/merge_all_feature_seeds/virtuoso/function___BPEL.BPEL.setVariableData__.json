CREATE TABLE countries (id INT PRIMARY KEY, name VARCHAR(100), code VARCHAR(10));
INSERT INTO countries (id, name, code) VALUES (1, 'United States', 'US');
INSERT INTO countries (id, name, code) VALUES (2, 'Canada', 'CA');
INSERT INTO countries (id, name, code) VALUES (3, 'Mexico', 'MX');
CREATE TABLE responses (id INT PRIMARY KEY, country_code VARCHAR(10), response_text TEXT);
INSERT INTO responses (id, country_code, response_text) VALUES (1, 'US', '<destResponse><country>United States</country></destResponse>');
INSERT INTO responses (id, country_code, response_text) VALUES (2, 'CA', '<destResponse><country>Canada</country></destResponse>');
INSERT INTO responses (id, country_code, response_text) VALUES (3, 'MX', '<destResponse><country>Mexico</country></destResponse>');
DECLARE country_type any;
SET country_type = (SELECT code FROM countries WHERE name = 'Canada');
IF (country_type IS NULL) THEN BPEL.BPEL.setVariableData('res', txtree_doc(']]&gt;
<destResponse><country>Unknown</country></destResponse><![CDATA['), 'repl_payload');
ELSE BPEL.BPEL.setVariableData('res', country_type, 'repl_payload', '/destResponse/country');
END IF;
SET country_type = (SELECT code FROM countries WHERE id = 1);
IF (country_type IS NULL) THEN BPEL.BPEL.setVariableData('res', txtree_doc(']]&gt;
<destResponse><country>Unknown</country></destResponse><![CDATA['), 'repl_payload');
ELSE BPEL.BPEL.setVariableData('res', country_type, 'repl_payload', '/destResponse/country');
END IF;
SET country_type = (SELECT code FROM countries ORDER BY RANDOM() LIMIT 1);
IF (country_type IS NULL) THEN BPEL.BPEL.setVariableData('res', txtree_doc(']]&gt;
<destResponse><country>Unknown</country></destResponse><![CDATA['), 'repl_payload');
ELSE BPEL.BPEL.setVariableData('res', country_type, 'repl_payload', '/destResponse/country');
END IF;
SET country_type = (SELECT c.code FROM countries c JOIN responses r ON c.code = r.country_code WHERE r.id = 1);
IF (country_type IS NULL) THEN BPEL.BPEL.setVariableData('res', txtree_doc(']]&gt;
<destResponse><country>Unknown</country></destResponse><![CDATA['), 'repl_payload');
ELSE BPEL.BPEL.setVariableData('res', country_type, 'repl_payload', '/destResponse/country');
END IF;
SET country_type = (SELECT c.code FROM countries c WHERE c.id = 4);
IF (country_type IS NULL) THEN BPEL.BPEL.setVariableData('res', txtree_doc(']]&gt;
<destResponse><country>Unknown</country></destResponse><![CDATA['), 'repl_payload');
ELSE BPEL.BPEL.setVariableData('res', country_type, 'repl_payload', '/destResponse/country');
END IF;