CREATE TABLE products (id INT PRIMARY KEY, price FLOAT, description TEXT);
INSERT INTO products (id, price, description) VALUES (1, 19.99, 'Affordable float item'), (2, NULL, 'NULL price item'), (3, 3999999999.99, 'Expensive float item');
CREATE TABLE sales (sale_id INT PRIMARY KEY, product_id INT, quantity INT, sale_date DATE, FOREIGN KEY (product_id) REFERENCES products(id));
INSERT INTO sales (sale_id, product_id, quantity, sale_date) VALUES (1, 1, 3, '2023-10-01'), (2, 2, 1, '2023-10-02'), (3, NULL, 5, '2023-10-03');
SELECT s.sale_id, s.quantity FROM sales s WHERE isfloat((SELECT price FROM products p WHERE p.id = s.product_id AND p.price IS NOT NULL)) = 1;
SELECT p.id, bif:contains(p.description, 'Affordable') AS match_found FROM products p WHERE p.price IS NOT NULL HAVING isfloat(p.price) = 1 AND match_found = 1;
SELECT s.sale_date, COUNT(*) AS total_sales FROM sales s WHERE s.sale_date IS NOT NULL GROUP BY s.sale_date HAVING MAX(s.quantity) > 2;
SELECT p.description, AVG(s.quantity) AS average_quantity FROM products p JOIN sales s ON p.id = s.product_id WHERE bif:contains(p.description, 'item') GROUP BY p.description HAVING isfloat(average_quantity) = 1;
SELECT sale_id FROM sales WHERE product_id IN (SELECT id FROM products WHERE isfloat(price) = 1) AND quantity IS NULL OR quantity < 0;