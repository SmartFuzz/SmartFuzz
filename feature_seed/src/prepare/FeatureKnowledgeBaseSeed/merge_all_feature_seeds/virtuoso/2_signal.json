CREATE TABLE test_table (id INT PRIMARY KEY, data VARCHAR(255), xml_data XML);
INSERT INTO test_table (id, data, xml_data) VALUES (1, 'sample', xml_tree_doc('<root><value>1</value></root>'));
INSERT INTO test_table (id, data, xml_data) VALUES (2, NULL, xml_tree_doc('<root><value>2</value></root>'));
INSERT INTO test_table (id, data, xml_data) VALUES (3, 'test', NULL);
SELECT id, data, xml_data FROM test_table WHERE id IN (SELECT id FROM test_table WHERE data IS NOT NULL) AND xml_data IS NOT NULL;
SELECT signal('45000', 'Testing exception signaling with id=1') FROM test_table WHERE id = 1;
SELECT id, data, xml_data FROM test_table WHERE id = (SELECT MAX(id) FROM test_table WHERE data IS NOT NULL);
SELECT id, data, xml_data FROM test_table WHERE xml_data = xml_tree_doc('<root><value>1</value></root>') AND data IS NOT NULL;
SELECT xml_data, signal('45001', 'Testing with xml operators') FROM test_table WHERE data LIKE '%sample%';
SELECT id, data, xml_data FROM test_table WHERE data = CAST('sample' AS VARCHAR(255)) AND xml_data IS NULL;
SELECT id, data, xml_data FROM test_table WHERE id BETWEEN 1 AND (SELECT MAX(id) FROM test_table) GROUP BY data HAVING COUNT(*) > 1;
SELECT id, signal('45002', 'Embedding signaling in complex queries'), data FROM test_table WHERE data = 'test' ORDER BY id;
SELECT id, data, xml_data FROM test_table WHERE xml_data = xml_tree_doc('<root><value>3</value></root>') OR (data IS NULL AND id < 3);