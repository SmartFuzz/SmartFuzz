CREATE TABLE test_strings (id INT, str_value STRING);
INSERT INTO test_strings VALUES (1, 'Hello, world!');
INSERT INTO test_strings VALUES (2, 'Virtuoso is a great database!');
INSERT INTO test_strings VALUES (3, 'Goodbye, world!');
SELECT strrchr(str_value, 'o') AS last_occurrence FROM test_strings WHERE id = 1;
SELECT strrchr(str_value, 'o') AS last_occurrence FROM test_strings WHERE id = 2;
SELECT strrchr(str_value, 'x') AS last_occurrence FROM test_strings WHERE id = 3;
SELECT strrchr(str_value, CAST(111 AS INT)) AS last_occurrence FROM test_strings;
SELECT strrchr(str_value, 'g') AS last_occurrence FROM (SELECT str_value FROM test_strings WHERE id IN (2, 3));
SELECT id, str_value, strrchr(str_value, ',') AS last_comma FROM test_strings ORDER BY last_comma DESC;
SELECT id, str_value FROM test_strings WHERE strrchr(str_value, 'l') IS NOT NULL;
SELECT id, str_value FROM test_strings WHERE str_value LIKE '%world%' AND strrchr(str_value, 'w') IS NOT NULL;
SELECT id, str_value FROM test_strings WHERE str_value IN (SELECT str_value FROM test_strings WHERE strrchr(str_value, 'i') IS NOT NULL);
WITH last_occurrences AS (SELECT id, str_value, strrchr(str_value, 'a') AS last_a FROM test_strings) SELECT * FROM last_occurrences WHERE last_a IS NOT NULL;