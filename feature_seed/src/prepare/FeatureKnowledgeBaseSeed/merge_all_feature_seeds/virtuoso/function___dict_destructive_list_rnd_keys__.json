CALL DB.DBA.DICT_ADD(dict_var, 'key2', 'value2');
CALL DB.DBA.DICT_ADD(dict_var, 'key3', 'value3');
CALL DB.DBA.DICT_ADD(dict_var, 'key4', 'value4');
CALL DB.DBA.DICT_ADD(dict_var, 'key5', 'value5');
DECLARE triples ANY;
