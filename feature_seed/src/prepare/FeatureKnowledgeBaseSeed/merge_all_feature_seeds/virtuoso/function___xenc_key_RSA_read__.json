CREATE TABLE rsa_keys (id INT PRIMARY KEY, key_name VARCHAR(255), key_data VARCHAR(2048));
INSERT INTO rsa_keys (id, key_name, key_data) VALUES (1, 'MyRSAkey', 'MIG..skipped..MBAAE=');
INSERT INTO rsa_keys (id, key_name, key_data) VALUES (2, 'TestKey1', 'MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQ...');
INSERT INTO rsa_keys (id, key_name, key_data) VALUES (3, 'KeyWithSpecialChars!@#$', 'MIIBIjANBgkqhkiG9w0B...');
SELECT * FROM rsa_keys WHERE key_data IS NOT NULL;
SELECT * FROM rsa_keys WHERE LENGTH(key_data) < 2048;
SELECT (SELECT COUNT(*) FROM rsa_keys) AS total_keys, (SELECT key_name FROM rsa_keys WHERE id = 1) AS key_name FROM dual;
SELECT rk.key_name FROM rsa_keys rk JOIN (SELECT key_name FROM rsa_keys WHERE id = 2) AS subquery ON rk.key_name = subquery.key_name;
SELECT CASE WHEN EXISTS (SELECT * FROM rsa_keys WHERE key_name = 'MyRSAkey') THEN 'Key exists' ELSE 'Key does not exist' END AS key_status;
INSERT INTO rsa_keys (id, key_name, key_data) SELECT MAX(id) + 1, 'NewKey', 'MIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8A...' FROM rsa_keys;
DELETE FROM rsa_keys WHERE key_name = 'MyRSAkey' AND id = (SELECT id FROM rsa_keys WHERE key_name = 'MyRSAkey' LIMIT 1);
CREATE INDEX idx_key_name ON rsa_keys(key_name);
SELECT key_name, key_data FROM rsa_keys WHERE key_data LIKE '%MIG%';