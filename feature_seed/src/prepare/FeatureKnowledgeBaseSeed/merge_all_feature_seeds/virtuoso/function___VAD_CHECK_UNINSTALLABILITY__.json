CREATE TABLE packages (id INT PRIMARY KEY, name VARCHAR(255), status VARCHAR(255));
INSERT INTO packages (id, name, status) VALUES (1, 'package1', 'installed');
INSERT INTO packages (id, name, status) VALUES (2, 'package2', 'uninstalled');
INSERT INTO packages (id, name, status) VALUES (3, 'package3', 'installed');
SELECT * FROM packages WHERE id = 1 AND status = 'installed';
SELECT CASE WHEN EXISTS (SELECT 1 FROM packages WHERE id = 1 AND status = 'installed') THEN 'uninstallable' ELSE 'not uninstallable' END AS uninstall_status;
SELECT p.name FROM packages p INNER JOIN (SELECT id FROM packages WHERE status = 'installed') i ON p.id = i.id WHERE p.name LIKE 'package%';
SELECT p.name, (SELECT COUNT(*) FROM packages WHERE status = 'installed') AS total_installed FROM packages p WHERE p.status = 'installed';
SELECT p1.name AS PackageName, (SELECT COUNT(*) FROM packages p2 WHERE p2.status = 'installed' AND p2.id = p1.id) AS IsInstallable FROM packages p1 WHERE EXISTS (SELECT 1 FROM packages p2 WHERE p2.status = 'installed' AND p2.id = p1.id);
SELECT p.name FROM packages p LEFT JOIN (SELECT id FROM packages WHERE status = 'installed') i ON p.id = i.id WHERE i.id IS NULL;