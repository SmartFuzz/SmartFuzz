CREATE TABLE test_data (id INT, value1 FLOAT, value2 FLOAT);
INSERT INTO test_data (id, value1, value2) VALUES (1, 10.0, 15.0);
INSERT INTO test_data (id, value1, value2) VALUES (2, 20.0, 25.0);
INSERT INTO test_data (id, value1, value2) VALUES (3, NULL, 35.0);
INSERT INTO test_data (id, value1, value2) VALUES (4, 40.0, NULL);
INSERT INTO test_data (id, value1, value2) VALUES (5, 25.0, 30.0);
SELECT COVAR_SAMP(value1, value2) FROM test_data;
SELECT AVG(value1) AS avg1, AVG(value2) AS avg2, COVAR_SAMP(value1, value2) FROM test_data GROUP BY id;
SELECT id, COVAR_SAMP(value1, value2) OVER (PARTITION BY id) FROM test_data;
SELECT COVAR_SAMP(t1.value1, t2.value2) FROM test_data t1 JOIN test_data t2 ON t1.id <> t2.id;
SELECT COVAR_SAMP(value1, value2) FROM test_data WHERE value1 IS NOT NULL AND value2 IS NOT NULL;
SELECT COVAR_SAMP(value1, value2) FROM (SELECT value1, value2 FROM test_data WHERE id > 2) AS subquery;
DROP TABLE IF EXISTS test_data;