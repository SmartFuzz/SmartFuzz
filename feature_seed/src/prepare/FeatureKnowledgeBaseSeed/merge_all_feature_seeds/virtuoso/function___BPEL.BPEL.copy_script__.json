CREATE TABLE scripts (id INTEGER PRIMARY KEY, script_name VARCHAR(255));
INSERT INTO scripts (id, script_name) VALUES (1, 'Original Script');
SELECT BPEL.BPEL.copy_script((SELECT id FROM scripts WHERE script_name = 'Original Script'));
INSERT INTO scripts (id, script_name) VALUES (2, 'Another Script');
SELECT BPEL.BPEL.copy_script(2);
SELECT BPEL.BPEL.copy_script((SELECT MAX(id) FROM scripts));
SELECT BPEL.BPEL.copy_script((SELECT id FROM scripts WHERE script_name LIKE 'Sc%'));
CREATE TABLE script_metadata (script_id INTEGER, created_at TIMESTAMP, FOREIGN KEY (script_id) REFERENCES scripts(id));
INSERT INTO script_metadata (script_id, created_at) VALUES (1, NOW());
INSERT INTO script_metadata (script_id, created_at) VALUES (2, NOW());
SELECT BPEL.BPEL.copy_script((SELECT script_id FROM script_metadata WHERE created_at = (SELECT MAX(created_at) FROM script_metadata)));
SELECT BPEL.BPEL.copy_script((SELECT MIN(id) FROM scripts WHERE id > 0));
INSERT INTO scripts (id, script_name) VALUES (3, 'Complex Script');
SELECT BPEL.BPEL.copy_script((SELECT id FROM scripts WHERE id IN (SELECT script_id FROM script_metadata WHERE created_at < '2023-10-01 00:00:00')));
DELETE FROM scripts WHERE id = 1;
SELECT BPEL.BPEL.copy_script((SELECT id FROM scripts WHERE script_name = 'Another Script'));