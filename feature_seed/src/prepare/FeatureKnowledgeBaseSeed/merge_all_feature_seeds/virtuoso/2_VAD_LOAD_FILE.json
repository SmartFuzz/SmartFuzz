CREATE TABLE test_data (id INT PRIMARY KEY, data XML, value FLOAT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_data VALUES (1, '<root><item>10</item><item>20</item></root>', 10.5, '2023-01-01 12:00:00');
INSERT INTO test_data VALUES (2, '<root><item>30</item><item>40</item></root>', 15.0, NULL);
INSERT INTO test_data VALUES (3, '<root><item>50</item><item>60</item></root>', NULL, '2023-02-01 12:00:00');
SELECT id, VAD_LOAD_FILE(xpath_split(data, 'item')) AS item_values FROM test_data WHERE value IS NOT NULL AND created_at > '2022-12-31';
SELECT id, xpath_split(data, 'item') AS items, SUM(value) OVER (PARTITION BY id ORDER BY created_at) AS cumulative_value FROM test_data WHERE value > 12.0;
SELECT id, (SELECT COUNT(*) FROM test_data WHERE value < 20.0) AS under_20_count, VAD_LOAD_FILE(xpath_split(data, 'item')) AS item_values FROM test_data WHERE value IS NOT NULL GROUP BY id HAVING SUM(value) > 12.5;
SELECT id, xpath_split(data, 'item') AS items FROM test_data WHERE value IS NULL OR value > (SELECT AVG(value) FROM test_data);
ALTER TABLE test_data ADD COLUMN remarks VARCHAR(255);
UPDATE test_data SET remarks = 'High Value' WHERE value > 15.0;
INSERT INTO test_data (id, data, value) VALUES (4, '<root><item>70</item><item>80</item></root>', 12.5);
SELECT id, VAD_LOAD_FILE(xpath_split(data, 'item')) AS item_values, CASE WHEN value IS NULL THEN 'Unknown' ELSE 'Known' END AS value_status FROM test_data WHERE id IN (SELECT id FROM test_data WHERE value IS NOT NULL);
SELECT id, COUNT(xpath_split(data, 'item')) AS item_count FROM test_data GROUP BY id HAVING COUNT(*) > 1;
DROP TABLE IF EXISTS test_data;