CREATE TABLE test_character (id INTEGER, name CHARACTER(10));
INSERT INTO test_character (id, name) VALUES (1, 'John');
INSERT INTO test_character (id, name) VALUES (2, 'Alice');
INSERT INTO test_character (id, name) VALUES (3, 'Bob');
SELECT * FROM test_character WHERE LENGTH(name) < 10;
SELECT id, name FROM test_character WHERE name LIKE 'A%';
SELECT * FROM (SELECT id, name FROM test_character WHERE id > 0) AS subquery WHERE name IS NOT NULL;
CREATE TABLE test_another (id INTEGER, description CHARACTER(20));
INSERT INTO test_another (id, description) VALUES (1, 'Sample description');
INSERT INTO test_character (id, name) VALUES (4, 'Max');
SELECT c.id, c.name, a.description FROM test_character c JOIN test_another a ON c.id = a.id;
SELECT id, name FROM test_character WHERE name BETWEEN 'A' AND 'M';
UPDATE test_character SET name = 'LongerName' WHERE id = 1;
DELETE FROM test_character WHERE LENGTH(name) > 10;
SELECT COUNT(*) FROM test_character WHERE name IS NULL;
SELECT name FROM test_character WHERE name IN (SELECT description FROM test_another);
CREATE TABLE test_nested (id INTEGER, name CHARACTER(15));
INSERT INTO test_nested (id, name) VALUES (1, 'FirstName');
INSERT INTO test_nested (id, name) VALUES (2, 'SecondName');
SELECT (SELECT name FROM test_nested WHERE id = 1) AS first_name, (SELECT name FROM test_nested WHERE id = 2) AS second_name;
SELECT id FROM test_character WHERE name = (SELECT MAX(name) FROM test_character);