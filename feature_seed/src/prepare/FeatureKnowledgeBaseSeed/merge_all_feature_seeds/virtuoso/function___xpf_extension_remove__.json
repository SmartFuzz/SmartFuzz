CREATE TABLE user_defined_functions (function_name VARCHAR(255), return_type VARCHAR(255), function_body TEXT);
INSERT INTO user_defined_functions (function_name, return_type, function_body) VALUES ('myExtensionFunction', 'string', '(...)');
SELECT * FROM user_defined_functions WHERE function_name = 'myExtensionFunction';
SELECT u.function_name FROM user_defined_functions u JOIN another_table a ON u.function_name = a.function_name WHERE a.some_column = 'some_value';
DELETE FROM user_defined_functions WHERE function_name = 'myExtensionFunction';
CREATE TABLE test_functions (function_name VARCHAR(255), user_id INT);
INSERT INTO test_functions (function_name, user_id) VALUES ('testFunction1', 1), ('testFunction2', 2);
SELECT f.function_name FROM test_functions f WHERE f.user_id IN (SELECT user_id FROM another_table WHERE condition = true);
CREATE FUNCTION complexFunction() RETURNS VOID AS $$ BEGIN SELECT * FROM user_defined_functions WHERE function_name = 'someFunction';
END $$ LANGUAGE plpgsql;
SELECT u.function_name FROM user_defined_functions u WHERE u.function_name NOT IN (SELECT function_name FROM test_functions WHERE user_id = 1);
DELETE FROM user_defined_functions WHERE function_name IN (SELECT function_name FROM test_functions WHERE user_id = 2);