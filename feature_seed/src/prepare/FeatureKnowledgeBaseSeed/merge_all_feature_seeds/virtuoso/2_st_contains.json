CREATE TABLE geospatial_data (id INT PRIMARY KEY, geo_geometry GEOMETRY, description VARCHAR(255));
INSERT INTO geospatial_data VALUES (1, bif:st_polygon('POLYGON((0 0, 0 10, 10 10, 10 0, 0 0))'), 'Area 1');
INSERT INTO geospatial_data VALUES (2, bif:st_polygon('POLYGON((5 5, 5 15, 15 15, 15 5, 5 5))'), 'Area 2');
INSERT INTO geospatial_data VALUES (3, bif:st_point(0, 52), 'Point of interest');
SELECT g.description, COUNT(*) FROM geospatial_data g WHERE bif:st_contains(g.geo_geometry, bif:st_point(0, 5)) AND g.geo_geometry IS NOT NULL GROUP BY g.description HAVING COUNT(*) > 0 ORDER BY COUNT(*) DESC;
SELECT g1.description FROM geospatial_data g1 JOIN geospatial_data g2 ON bif:st_contains(g1.geo_geometry, g2.geo_geometry) WHERE g2.geo_geometry IS NOT NULL AND g1.geo_geometry IS NOT NULL;
SELECT COUNT(*) FROM (SELECT g.description, bif:st_contains(g.geo_geometry, bif:st_point(0, 52)) AS contained FROM geospatial_data g WHERE g.geo_geometry IS NOT NULL) AS subquery WHERE contained IS TRUE;
SELECT g.description FROM geospatial_data g WHERE bif:st_contains(g.geo_geometry, bif:st_point(10, 10)) OR (g.geo_geometry IS NULL AND g.description IS NOT NULL);
CREATE TABLE test_data (id SERIAL PRIMARY KEY, point GEOMETRY, value INT);
INSERT INTO test_data (point, value) VALUES (bif:st_point(12, 34), NULL), (bif:st_point(25, 45), 15), (bif:st_polygon('POLYGON((10 10, 10 20, 20 20, 20 10, 10 10))'), 30);
SELECT COUNT(*) FROM test_data WHERE point IS NULL OR point IS NOT NULL AND (value IS NULL);
SELECT COUNT(*) FROM geospatial_data g WHERE bif:st_contains(g.geo_geometry, bif:st_point(NULL, NULL)) AND g.geo_geometry IS NOT NULL;
SELECT CASE WHEN COUNT(*) = 0 THEN 'None' ELSE 'Exists' END AS status FROM geospatial_data WHERE ISNULL(bif:st_contains(g.geo_geometry, bif:st_point(30, 30))) GROUP BY status;
SELECT id, CASE WHEN g.geo_geometry IS NOT NULL THEN 'Valid Geometry' ELSE 'Invalid Geometry' END as geometry_status FROM geospatial_data g WHERE bif:st_contains(g.geo_geometry, bif:st_point(5,5));