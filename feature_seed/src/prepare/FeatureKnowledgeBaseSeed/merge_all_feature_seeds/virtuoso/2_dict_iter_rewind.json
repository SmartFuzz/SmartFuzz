CREATE TABLE test_dict (id INT PRIMARY KEY, data ANY);
INSERT INTO test_dict VALUES (1, dict_new(10));
SELECT id, dict_iter_rewind(data), (SELECT COUNT(*) FROM test_dict WHERE id = 1) / 1 FROM test_dict;
INSERT INTO test_dict VALUES (2, dict_new(10));
SELECT id, dict_iter_rewind(data), 'Value: ' || (SELECT dkey FROM dict_iter_next(data, dkey, dvalue)) / NULL FROM test_dict WHERE id = 2;
CREATE TABLE test_numbers (num FLOAT);
INSERT INTO test_numbers VALUES (10.5), (20.0), (NULL);
SELECT num / (SELECT MIN(num) FROM test_numbers WHERE num IS NOT NULL) AS normalized_num FROM test_numbers;
SELECT id, dict_iter_rewind(data), (SELECT SUM(num) FROM test_numbers) / COUNT(num) FROM test_dict;
CREATE TABLE test_strings (str VARCHAR(255));
INSERT INTO test_strings VALUES ('1'), ('2'), ('three');
SELECT str, (dict_iter_rewind((SELECT dict_new(3) FROM test_strings)) / 1.0) FROM test_strings;
CREATE TABLE complex_test (id INT PRIMARY KEY, num1 INT, num2 INT);
INSERT INTO complex_test VALUES (1, 10, 0), (2, 20, NULL), (3, NULL, 30);
SELECT id, num1, num2, (SELECT AVG(num1) / (num2 + 1)) FROM complex_test GROUP BY id HAVING COUNT(*) > 1;
CREATE TABLE temp_dict (temp_data ANY);
INSERT INTO temp_dict VALUES (dict_new(10)), (dict_new(10));
SELECT temp_data, (dict_iter_rewind(temp_data) / 2) FROM temp_dict WHERE (SELECT COUNT(*) FROM temp_dict) > 0;
CREATE TABLE final_test (id INT PRIMARY KEY, val1 ANY, val2 ANY);
INSERT INTO final_test VALUES (1, dict_new(2), 'test'), (2, dict_new(3), NULL);
SELECT id, (SELECT dict_iter_rewind(val1)), (val2 / 5) FROM final_test WHERE val2 IS NOT NULL;