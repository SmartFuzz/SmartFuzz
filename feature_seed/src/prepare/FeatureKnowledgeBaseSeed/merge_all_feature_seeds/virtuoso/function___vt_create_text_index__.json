CREATE TABLE test_table (id integer primary key, name varchar, description long varchar);
vt_create_text_index('test_table', 'description', 'id', 0);
CREATE TABLE parent_table (p_id integer primary key, p_name varchar);
CREATE TABLE child_table (c_id integer primary key, c_description long varchar, p_id integer references parent_table(p_id));
vt_create_text_index('child_table', 'c_description', 'c_id', 1);
INSERT INTO test_table (id, name, description) VALUES (1, 'Item 1', 'This is a description for item 1.');
INSERT INTO test_table (id, name, description) VALUES (2, 'Item 2', 'This is another description for item 2.');
INSERT INTO parent_table (p_id, p_name) VALUES (1, 'Parent 1');
INSERT INTO child_table (c_id, c_description, p_id) VALUES (1, 'Child description 1', 1);
INSERT INTO child_table (c_id, c_description, p_id) VALUES (2, 'Child description 2', 1);
vt_create_text_index('test_table', 'name', null, 1);
SELECT * FROM test_table WHERE description MATCH 'description';
SELECT * FROM child_table WHERE c_description MATCH 'description';
CREATE TABLE xml_table (xml_id integer primary key, xml_data long varchar);
CREATE INDEX idx_xml_data ON xml_table (xml_data);
vt_create_text_index('xml_table', 'xml_data', 'xml_id', 1);
SELECT * FROM xml_table WHERE xml_data MATCH '<tag>';
CREATE TABLE complex_table (ct_id integer primary key, ct_info long varchar, ct_ref integer references test_table(id));
vt_create_text_index('complex_table', 'ct_info', null, 0);
SELECT * FROM complex_table ct JOIN test_table tt ON ct.ct_ref = tt.id WHERE ct_info MATCH 'info';
SELECT * FROM test_table WHERE id IN (SELECT ct_ref FROM complex_table WHERE ct_info MATCH 'info');
SELECT * FROM test_table WHERE id NOT IN (SELECT ct_ref FROM complex_table WHERE ct_info MATCH 'info');