CREATE TABLE test_dates (id INTEGER PRIMARY KEY, event_time DATETIME);
INSERT INTO test_dates (id, event_time) VALUES (1, CAST('1999-12-31 11:59' AS DATETIME));
INSERT INTO test_dates (id, event_time) VALUES (2, CAST('1999-12-31 11:59:59.999999' AS DATETIME));
INSERT INTO test_dates (id, event_time) VALUES (3, CAST('1999-12-31 11:59:00.000001' AS DATETIME));
INSERT INTO test_dates (id, event_time) VALUES (4, CAST('1999-12-31 12:00:00' AS DATETIME));
INSERT INTO test_dates (id, event_time) VALUES (5, CAST('1999-12-31 11:59:00 Z' AS DATETIME));
INSERT INTO test_dates (id, event_time) VALUES (6, CAST('1999-12-31 11:59:00 +02:00' AS DATETIME));
INSERT INTO test_dates (id, event_time) VALUES (7, CAST('1999-12-31 11:59:00 -02:00' AS DATETIME));
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 1;
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 2;
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 3;
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 4;
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 5;
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 6;
SELECT is_timezoneless(event_time) FROM test_dates WHERE id = 7;
SELECT d.id, is_timezoneless(d.event_time) FROM test_dates d WHERE d.id IN (SELECT t.id FROM test_dates t WHERE t.id < 5);
SELECT d1.id, is_timezoneless(d1.event_time), d2.id, is_timezoneless(d2.event_time) FROM test_dates d1 JOIN test_dates d2 ON d1.id = d2.id + 1;
SELECT d.id, (SELECT is_timezoneless(event_time) FROM test_dates WHERE id = d.id) AS timezoneless_status FROM test_dates d;
SELECT id, is_timezoneless(CAST('2023-10-01 12:30:00 +05:30' AS DATETIME)) AS timezone_result FROM test_dates WHERE id = 7;