CREATE TABLE backup_test (id INT PRIMARY KEY, data VARCHAR(255), backup_time TIMESTAMP);
INSERT INTO backup_test (id, data, backup_time) VALUES (1, 'Test Data', CURRENT_TIMESTAMP);
SELECT * FROM backup_test WHERE data IS NOT NULL && backup_time <= NOW();
SELECT id, COUNT(*) FROM backup_test GROUP BY data HAVING COUNT(*) > 1 && MAX(backup_time) < CURRENT_TIMESTAMP;
SELECT id FROM backup_test WHERE id IN (SELECT id FROM backup_test WHERE data = 'Test Data' && backup_time IS NOT NULL);
SELECT backup_context_clear() && (SELECT COUNT(*) FROM backup_test WHERE data IS NOT NULL) AS backup_status;
SELECT (SELECT COUNT(*) FROM backup_test WHERE data LIKE '%Test%') AS matching_data_count && backup_context_clear();
CREATE TABLE backup_edge_cases (num INT, optional_data VARCHAR(100));
INSERT INTO backup_edge_cases (num, optional_data) VALUES (NULL, NULL), (1, 'One'), (2, 'Two'), (3, 'Three');
SELECT num, optional_data FROM backup_edge_cases WHERE (num IS NULL || optional_data IS NOT NULL) && num < 4 ORDER BY optional_data;
SELECT (SELECT COUNT(*) FROM backup_edge_cases WHERE num IS NOT NULL && optional_data IS NULL) AS null_cases && backup_context_clear();