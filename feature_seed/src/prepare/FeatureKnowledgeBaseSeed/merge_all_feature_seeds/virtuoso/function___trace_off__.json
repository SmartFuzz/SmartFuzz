CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(255));
CREATE TABLE logs (log_id INT PRIMARY KEY, user_id INT, log_message VARCHAR(255), log_type VARCHAR(50), FOREIGN KEY (user_id) REFERENCES users(id));
INSERT INTO users (id, username) VALUES (1, 'test_user');
INSERT INTO logs (log_id, user_id, log_message, log_type) VALUES (1, 1, 'User logged in', 'user_log');
INSERT INTO logs (log_id, user_id, log_message, log_type) VALUES (2, 1, 'Failed login attempt', 'failed_log');
SELECT * FROM users WHERE id IN (SELECT user_id FROM logs WHERE log_type = 'user_log');
SELECT * FROM logs WHERE log_type = 'failed_log' AND log_id IN (SELECT log_id FROM logs WHERE user_id = 1);
SELECT COUNT(*) FROM logs WHERE log_type IN (SELECT log_type FROM (VALUES ('user_log'), ('failed_log')) AS t(log_type));
SELECT username FROM users WHERE id = (SELECT user_id FROM logs WHERE log_message = 'User logged in' LIMIT 1);
 trace_off ('user_log', 'failed_log');