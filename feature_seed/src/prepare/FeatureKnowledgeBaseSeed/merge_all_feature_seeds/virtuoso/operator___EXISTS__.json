CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'test1');
INSERT INTO test_table (id, value) VALUES (2, 'test2');
SELECT EXISTS (SELECT 1 FROM test_table WHERE value = 'test1');
SELECT EXISTS (SELECT 1 FROM test_table WHERE id = 3);
SELECT EXISTS (SELECT 1 FROM test_table WHERE value IN (SELECT value FROM test_table WHERE id = 1));
CREATE TABLE second_table (id INT PRIMARY KEY, test_id INT, FOREIGN KEY (test_id) REFERENCES test_table(id));
INSERT INTO second_table (id, test_id) VALUES (1, 1);
INSERT INTO second_table (id, test_id) VALUES (2, 2);
SELECT EXISTS (SELECT 1 FROM test_table t JOIN second_table s ON t.id = s.test_id WHERE t.value = 'test1');
SELECT EXISTS (SELECT 1 FROM second_table WHERE test_id NOT IN (SELECT id FROM test_table));
SELECT EXISTS (SELECT 1 FROM test_table WHERE id IN (SELECT test_id FROM second_table WHERE id = 1));
SELECT EXISTS (SELECT 1 FROM second_table s WHERE EXISTS (SELECT 1 FROM test_table t WHERE t.id = s.test_id AND t.value = 'test2'));
SELECT EXISTS (SELECT 1 FROM test_table WHERE id IN (SELECT test_id FROM second_table) HAVING COUNT(*) > 0);
SELECT EXISTS (SELECT 1 FROM test_table WHERE id = (SELECT MAX(id) FROM test_table));
SELECT EXISTS (SELECT 1 FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value LIKE 'test%'));