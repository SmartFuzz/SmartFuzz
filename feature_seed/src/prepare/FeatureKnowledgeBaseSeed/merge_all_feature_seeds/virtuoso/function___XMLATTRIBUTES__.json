CREATE TABLE test_table (id INT, attr1 VARCHAR(100), attr2 VARCHAR(100), attr3 VARCHAR(100));
INSERT INTO test_table (id, attr1, attr2, attr3) VALUES (1, 'value1', 'value2', NULL);
INSERT INTO test_table (id, attr1, attr2, attr3) VALUES (2, NULL, 'value4', 'value5');
INSERT INTO test_table (id, attr1, attr2, attr3) VALUES (3, 'value6', NULL, 'value7');
SELECT XMLELEMENT('Root', XMLATTRIBUTES(attr1, 'Attribute1', attr2, 'Attribute2')) FROM test_table WHERE id = 1;
SELECT XMLELEMENT('Root', XMLATTRIBUTES(attr1, 'Attribute1', attr2, 'Attribute2')) FROM test_table WHERE attr3 IS NOT NULL;
SELECT XMLELEMENT('Root', XMLATTRIBUTES(attr1, 'Attribute1', attr2, 'Attribute2', attr3, 'Attribute3')) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE attr1 IS NOT NULL);
SELECT XMLELEMENT('Root', XMLATTRIBUTES(attr1, 'Attribute1')) FROM (SELECT attr1 FROM test_table WHERE id = 2) AS subquery;
SELECT XMLELEMENT('Root', XMLATTRIBUTES(t1.attr1, 'Attribute1', t2.attr2, 'Attribute2')) FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.id = 3;
SELECT XMLELEMENT('Root', XMLATTRIBUTES(attr1, 'Attribute1', attr2, 'Attribute2')) FROM test_table WHERE attr1 IS NULL AND attr2 IS NULL;