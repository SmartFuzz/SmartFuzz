CREATE TABLE BPEL_Scripts (id INT PRIMARY KEY, script_name VARCHAR(255), is_obsolete BOOLEAN, created_at TIMESTAMP);
INSERT INTO BPEL_Scripts (id, script_name, is_obsolete, created_at) VALUES (1, 'Script A', FALSE, CURRENT_TIMESTAMP);
INSERT INTO BPEL_Scripts (id, script_name, is_obsolete, created_at) VALUES (2, 'Script B', FALSE, CURRENT_TIMESTAMP);
INSERT INTO BPEL_Scripts (id, script_name, is_obsolete, created_at) VALUES (3, 'Script C', FALSE, CURRENT_TIMESTAMP);
SELECT * FROM BPEL_Scripts WHERE is_obsolete = FALSE;
SELECT * FROM BPEL_Scripts WHERE id IN (SELECT id FROM BPEL_Scripts WHERE script_name LIKE 'Script%');
UPDATE BPEL_Scripts SET is_obsolete = TRUE WHERE id = 1;
SELECT COUNT(*) FROM BPEL_Scripts WHERE is_obsolete = TRUE;
SELECT script_name FROM BPEL_Scripts WHERE is_obsolete = TRUE ORDER BY created_at DESC;
DELETE FROM BPEL_Scripts WHERE id = 4;
SELECT * FROM BPEL_Scripts WHERE id NOT IN (SELECT id FROM BPEL_Scripts WHERE is_obsolete = TRUE);
SELECT script_name FROM BPEL_Scripts WHERE is_obsolete = TRUE AND created_at > NOW() - INTERVAL '1 DAY';
UPDATE BPEL_Scripts SET is_obsolete = FALSE WHERE id = (SELECT MAX(id) FROM BPEL_Scripts);
SELECT script_name FROM BPEL_Scripts WHERE id = (SELECT MIN(id) FROM BPEL_Scripts WHERE is_obsolete = FALSE) OR is_obsolete = TRUE;
INSERT INTO BPEL_Scripts (id, script_name, is_obsolete, created_at) SELECT id, script_name, FALSE, CURRENT_TIMESTAMP FROM BPEL_Scripts WHERE is_obsolete = TRUE;
CREATE INDEX idx_obsolete ON BPEL_Scripts (is_obsolete);
CALL BPEL.BPEL.script_obsolete(1);