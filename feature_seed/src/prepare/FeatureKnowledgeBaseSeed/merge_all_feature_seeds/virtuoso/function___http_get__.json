CREATE TABLE test_http_get (id INT PRIMARY KEY, response VARCHAR(500));
DECLARE header VARCHAR(255);
INSERT INTO test_http_get (id, response) VALUES (1, http_get ('http://www.openlinksw.com/'));
INSERT INTO test_http_get (id, response) VALUES (2, http_get ('http://www.openlinksw.com/', header, 'GET'));
INSERT INTO test_http_get (id, response) VALUES (3, http_get ('http://example.com/some_link.html', header, 'POST', '', 'a=1&b=2'));
INSERT INTO test_http_get (id, response) VALUES (4, http_get ('http://www.openlinksw.com/', NULL, 'GET', '', '', 'proxy.server.com:8080'));
INSERT INTO test_http_get (id, response) SELECT 5, http_get(CONCAT('http://example.com/resource/', id)) FROM (SELECT id FROM (SELECT ROW_NUMBER() OVER () AS id FROM test_http_get) AS temp WHERE id < 10) AS subquery;
DECLARE header_info VARCHAR(255);
INSERT INTO test_http_get (id, response) VALUES (6, http_get ('http://www.openlinksw.com/', header_info, 'GET', 'User-Agent: TestAgent'));
INSERT INTO test_http_get (id, response) SELECT 7, http_get(temp.url) FROM (SELECT 'http://test.com/api' AS url) AS temp;
INSERT INTO test_http_get (id, response) VALUES (8, http_get ('http://invalid.url', header, 'GET'));
UPDATE test_http_get SET response = http_get ('http://www.example.com') WHERE id = 1;
DELETE FROM test_http_get WHERE id = 6;
SELECT * FROM test_http_get WHERE response IS NOT NULL;
SELECT COUNT(*) FROM test_http_get WHERE response LIKE '%<html>%';
SELECT AVG(LENGTH(response)) FROM test_http_get WHERE response IS NOT NULL;
SELECT id, response FROM test_http_get ORDER BY LENGTH(response) DESC LIMIT 5;