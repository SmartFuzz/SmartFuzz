CREATE PROCEDURE my_redirect_1() BEGIN DECLARE full_path varchar;
SET full_path = '/DAV/VAD/test/1';
http_internal_redirect(full_path);
END;
CREATE PROCEDURE my_redirect_2() BEGIN DECLARE full_path varchar;
SET full_path = '/DAV/VAD/test/2';
http_internal_redirect(full_path);
END;
CREATE PROCEDURE my_redirect_3() BEGIN DECLARE full_path varchar;
SET full_path = '/DAV/VAD/test/3';
http_internal_redirect(full_path);
END;
CREATE TABLE test_table (id INT, name VARCHAR(255));
INSERT INTO test_table (id, name) VALUES (1, 'Test Name 1');
INSERT INTO test_table (id, name) VALUES (2, 'Test Name 2');
CREATE PROCEDURE my_complex_redirect() BEGIN DECLARE full_path varchar;
SET full_path = (SELECT CONCAT('/DAV/VAD/', name) FROM test_table WHERE id = 1);
http_internal_redirect(full_path);
END;
CREATE PROCEDURE my_nested_redirect() BEGIN DECLARE full_path varchar;
SET full_path = (SELECT full_path FROM (SELECT '/DAV/VAD/test/4' AS full_path) AS sub);
http_internal_redirect(full_path);
END;
CREATE PROCEDURE my_multi_table_redirect() BEGIN DECLARE full_path varchar;
SET full_path = (SELECT CONCAT('/DAV/VAD/', name) FROM test_table JOIN another_table ON test_table.id = another_table.test_id WHERE another_table.value = 'Some value');
http_internal_redirect(full_path);
END;
CREATE TABLE another_table (test_id INT, value VARCHAR(255));
INSERT INTO another_table (test_id, value) VALUES (1, 'Some value');
INSERT INTO another_table (test_id, value) VALUES (2, 'Another value');
CREATE PROCEDURE my_redirect_with_charset() BEGIN DECLARE full_path varchar;
SET full_path = '/DAV/VAD/test/5';
http_internal_redirect(full_path);
SET http_charset='utf-8';
END;