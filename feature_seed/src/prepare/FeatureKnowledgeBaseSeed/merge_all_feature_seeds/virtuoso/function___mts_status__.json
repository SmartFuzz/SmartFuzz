CREATE TABLE test_transactions (id INT PRIMARY KEY, status VARCHAR(20));
CREATE TABLE test_mts (connection_id INT PRIMARY KEY, connection_status VARCHAR(20));
INSERT INTO test_transactions (id, status) VALUES (1, '2pc enabled');
INSERT INTO test_transactions (id, status) VALUES (2, '2pc disabled');
INSERT INTO test_mts (connection_id, connection_status) VALUES (1, 'connected');
INSERT INTO test_mts (connection_id, connection_status) VALUES (2, 'disconnected');
SELECT mts_status('MTS') AS mts_connection_status FROM test_mts WHERE connection_id = 1;
SELECT mts_status('TRANSACTION') AS transaction_status FROM test_transactions WHERE id = 1;
SELECT mts_status('TRANSACTION') AS transaction_status FROM test_transactions WHERE id IN (SELECT id FROM test_transactions WHERE status = '2pc enabled');
SELECT mts_status('MTS') AS mts_connection_status FROM test_mts WHERE connection_id IN (SELECT connection_id FROM test_mts WHERE connection_status = 'connected') ORDER BY connection_id DESC;
SELECT mts_status('TRANSACTION') AS transaction_status FROM (SELECT id, status FROM test_transactions WHERE status = '2pc disabled') AS subquery;
SELECT mts_status('MTS') AS mts_connection_status FROM test_mts LEFT JOIN test_transactions ON test_mts.connection_id = test_transactions.id WHERE test_mts.connection_status = 'disconnected' AND test_transactions.status = '2pc enabled';
SELECT mts_status('TRANSACTION') AS transaction_status FROM (SELECT id, status FROM test_transactions WHERE id BETWEEN 1 AND 5) AS transaction_subquery;
SELECT mts_status('MTS') AS mts_connection_status FROM (SELECT connection_id, connection_status FROM test_mts LIMIT 1) AS mts_subquery;
DELETE FROM test_transactions WHERE id = 1;
DELETE FROM test_mts WHERE connection_id = 2;