CREATE TABLE test_data (id INT, json_data JSON, value INT NULL, text_value VARCHAR(255));
INSERT INTO test_data (id, json_data, value, text_value) VALUES (1, '[1, 2, 3]', NULL, 'Test'), (2, '[4, 5, 6]', 18, 'Example'), (3, '[7, 8, 9]', -18, NULL);
SELECT id, json_array_length(json_data) AS array_length, bit_not(value) AS negated_value FROM test_data WHERE value IS NOT NULL;
SELECT id, (SELECT bit_not(value) FROM test_data WHERE id = 2) AS negated_value, json_array_length(json_data) AS array_length FROM test_data HAVING array_length > 2;
SELECT t.id, json_array_length(t.json_data) AS length, bit_not(t.value) AS inverted FROM test_data t WHERE t.value IS NOT NULL AND EXISTS (SELECT 1 FROM test_data WHERE id = t.id AND text_value IS NOT NULL);
SELECT t1.id, json_array_length(t1.json_data) AS length, COALESCE(bit_not(t2.value), 0) AS negated_value FROM test_data t1 LEFT JOIN test_data t2 ON t1.id = t2.id WHERE text_value = 'Test' GROUP BY t1.id HAVING negated_value < 0;
SELECT id, value, bit_not(value), json_array_length(json_data) FROM test_data WHERE json_data IS NOT NULL ORDER BY bit_not(value) DESC;
UPDATE test_data SET value = NULL WHERE id = 1;
SELECT id, bit_not(value + 1) AS modified_value FROM test_data WHERE value IS NOT NULL ORDER BY json_array_length(json_data);