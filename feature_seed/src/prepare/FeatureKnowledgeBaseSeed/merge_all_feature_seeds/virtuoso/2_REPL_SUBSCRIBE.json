CREATE TABLE subscriptions (id INT PRIMARY KEY, publication_name VARCHAR(50) NOT NULL, local_owner VARCHAR(50) NOT NULL);
INSERT INTO subscriptions VALUES (1, 'demo-publication', 'dav');
SELECT id FROM subscriptions WHERE local_owner IS NOT NULL;
SELECT id, publication_name FROM subscriptions WHERE publication_name = 'demo-publication' AND (SELECT COUNT(*) FROM subscriptions) IS NOT NULL;
SELECT 'Subscription Status: ' || CASE WHEN EXISTS (SELECT 1 FROM subscriptions WHERE local_owner IS NOT NULL) THEN 'Active' ELSE 'Inactive' END AS status;
INSERT INTO subscriptions VALUES (2, 'test-publication', NULL);
CREATE TABLE replication (owner VARCHAR(50), publication_name VARCHAR(50), status VARCHAR(20), replication_time TIMESTAMP);
SELECT owner FROM replication WHERE status IS NOT NULL AND EXISTS (SELECT 1 FROM subscriptions WHERE publication_name = 'test-publication');
SELECT id, COUNT(*) OVER (PARTITION BY publication_name) AS count FROM subscriptions WHERE publication_name IS NOT NULL GROUP BY id, publication_name HAVING COUNT(*) IS NOT NULL;
CALL DB.DBA.REPL_SUBSCRIBE('demo-srv', (SELECT publication_name FROM subscriptions WHERE id = 1 AND local_owner IS NOT NULL), 'dav', (SELECT local_owner FROM subscriptions WHERE id = 1));
CALL DB.DBA.REPL_SUBSCRIBE('demo-srv', NULLIF((SELECT publication_name FROM subscriptions WHERE id = 1), 'demo-publication'), 'dav', 'dav', 'demo', 'demo');
SELECT id, MAX(replication_time) AS last_sync FROM replication WHERE owner IS NOT NULL GROUP BY id HAVING last_sync IS NOT NULL;
DROP TABLE IF EXISTS temp_subscriptions;
CREATE TABLE temp_subscriptions AS SELECT * FROM subscriptions WHERE local_owner IS NOT NULL;
INSERT INTO temp_subscriptions VALUES (3, 'new-publication', 'new_owner');
SELECT * FROM temp_subscriptions WHERE publication_name LIKE '%' || COALESCE(NULL, 'new-publication') || '%' AND id IS NOT NULL;
CALL DB.DBA.REPL_SUBSCRIBE('new-srv', 'new-publication', 'dav', 'dav', (SELECT local_owner FROM subscriptions WHERE id = 3 LIMIT 1), (SELECT local_owner FROM subscriptions WHERE id = 2));