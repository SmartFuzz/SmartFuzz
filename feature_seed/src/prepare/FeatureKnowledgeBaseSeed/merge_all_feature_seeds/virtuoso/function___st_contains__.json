CREATE CLASS Geography;
CREATE PROPERTY Geography:geometry geo:geometry;
INSERT DATA { GRAPH <http://example.org/geo> { <http://example.org/point1> geo:geometry bif:st_point(0, 52) . <http://example.org/area1> geo:geometry bif:st_polygon(('0 50', '5 50', '5 55', '0 55', '0 50')) . } };
INSERT DATA { GRAPH <http://example.org/geo> { <http://example.org/point2> geo:geometry bif:st_point(1, 51) . <http://example.org/area2> geo:geometry bif:st_polygon(('1 51', '6 51', '6 56', '1 56', '1 51')) . } };
SELECT ?c COUNT (*) WHERE { ?m geo:geometry ?geo . ?m a ?c . FILTER (bif:st_contains(?geo, bif:st_point(0, 52))) } GROUP BY ?c ORDER BY DESC 2;
SELECT ?c COUNT (*) WHERE { ?m geo:geometry ?geo . ?m a ?c . FILTER (bif:st_contains(?geo, bif:st_point(1, 51))) } GROUP BY ?c ORDER BY DESC 2;
SELECT ?c COUNT (*) WHERE { { SELECT ?geo WHERE { ?m geo:geometry ?geo . FILTER (bif:st_contains(?geo, bif:st_point(0, 52))) } } } GROUP BY ?c ORDER BY DESC 2;
SELECT ?c ?geo WHERE { ?m geo:geometry ?geo . ?m a ?c . FILTER (bif:st_contains(?geo, bif:st_polygon(('0 50', '5 50', '5 55', '0 55', '0 50')))) } ORDER BY ?c;
SELECT ?geo (COUNT(?m) AS ?count) WHERE { ?m geo:geometry ?geo . FILTER (bif:st_contains(?geo, bif:st_polygon(('0 50', '5 50', '5 55', '0 55', '0 50')))) } GROUP BY ?geo;
SELECT ?geo1 ?geo2 WHERE { ?m1 geo:geometry ?geo1 . ?m2 geo:geometry ?geo2 . FILTER (bif:st_contains(?geo1, ?geo2)) } ORDER BY ?geo1, ?geo2;
SELECT ?c COUNT (*) WHERE { ?m geo:geometry ?geo . ?m a ?c . FILTER (bif:st_contains(?geo, bif:st_point(0, 52)) || bif:st_contains(?geo, bif:st_point(1, 51))) } GROUP BY ?c;