CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(255) NOT NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (name) VALUES ('test1');
INSERT INTO test_table (name) VALUES (NULL);
SELECT identity_value() AS last_id FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);
SELECT id, name FROM test_table WHERE id = (SELECT identity_value() FROM test_table WHERE name = 'test1');
SELECT id FROM test_table WHERE id = identity_value() AND name IS NOT NULL;
INSERT INTO test_table (name) VALUES ('test2');
SELECT identity_value() = (SELECT MAX(id) FROM test_table);
CREATE TABLE another_table (another_id INTEGER PRIMARY KEY, ref_id INTEGER REFERENCES test_table(id), value NUMERIC(10,2));
INSERT INTO another_table (ref_id, value) VALUES ((SELECT identity_value() FROM test_table), RAND() * 100);
SELECT A.id, A.name, B.value FROM test_table A JOIN another_table B ON A.id = B.ref_id WHERE A.id = identity_value() AND B.value IS NOT NULL;
SELECT count(*) FROM test_table WHERE created_at < NOW() AND id = identity_value();
CREATE TABLE temp_results AS SELECT * FROM test_table WHERE name LIKE 'test%';
SELECT id, COALESCE(MAX(ref_id), 0) AS max_ref_id FROM another_table GROUP BY id HAVING max_ref_id = identity_value();
SELECT * FROM test_table ORDER BY name COLLATE BINARY ASC;
INSERT INTO test_table (name) VALUES (CAST(NULL AS VARCHAR));
SELECT name FROM test_table WHERE id = (SELECT identity_value() FROM test_table) AND name IS NOT NULL;
SELECT DISTINCT name, identity_value() AS curr_id FROM test_table WHERE id IS NOT NULL AND name <> '';
UPDATE test_table SET name = NULL WHERE id = identity_value();
SELECT value FROM another_table WHERE ref_id = identity_value() AND value > ((SELECT AVG(value) FROM another_table) * 2);