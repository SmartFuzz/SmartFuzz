CREATE GRAPH <http://geo-api-demo/>;
INSERT DATA { GRAPH <http://geo-api-demo/> { <point2d> <shape> "POINT(1 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . <point4d> <shape> "POINTZM(0 1 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . <box1> <shape> "BOX(0 0, 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . <linestring> <shape> "LINESTRING(10 21, 12 23, 10 25)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . <polygon1> <shape> "POLYGON((1 3,2 4,1 5,0 4,1 3))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . <multipolygon> <shape> "MULTIPOLYGON(((1 3,2 4,1 5,0 4,1 3)),((1 2,2 1,1 0,0 1,1 2)))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
SPARQL SELECT ?s, bif:ST_Translate(?o, 0, 0) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } ORDER BY ASC(str(?s));
SPARQL SELECT ?shape, bif:ST_Translate(?shape, -10.5, 20.8) FROM <http://geo-api-demo/> WHERE { ?shape <shape> ?o } ORDER BY ASC(?shape);
SPARQL SELECT ?s, bif:ST_Translate(?o, 100, 200) FROM <http://geo-api-demo/> WHERE { ?s <shape> ?o };
SPARQL SELECT ?s, bif:ST_Translate(?o, 1.1, 2.2) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } ORDER BY ASC(?s) LIMIT 10;
SPARQL SELECT ?s, bif:ST_Translate(?o, -1, -1) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o . FILTER(?p=<http://www.openlinksw.com/schemas/virtrdf#Geometry>) } ORDER BY ASC(str(?s));
SPARQL SELECT ?g1, bif:ST_Translate(bif:ST_Union(?g1, ?g2), 5.0, 5.0) FROM <http://geo-api-demo/> WHERE { { ?g1 ?p1 ?o1 } UNION { ?g2 ?p2 ?o2 } } GROUP BY ?g1;
SPARQL SELECT ?s, bif:ST_Translate(?o, 0.0, -0.5) WHERE { ?s ?p ?o FILTER(bif:ST_Intersects(?o, BOX(0 0, 10 10))) } ORDER BY ?s;
SPARQL SELECT ?s, bif:ST_Translate(?o, RAND()*10, RAND()*10) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } ORDER BY ASC(str(?s));
SPARQL WITH { SELECT ?s, bif:ST_Translate(?o, 2.5, -3.5) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } } AS %result SELECT ?s ?translated FROM %result WHERE ?translated != bif:ST_Translate(?o, 0, 0);