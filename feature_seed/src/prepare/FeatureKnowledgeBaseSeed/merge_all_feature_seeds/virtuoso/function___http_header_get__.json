CREATE TABLE test_headers (id INT, header_value VARCHAR(255));
INSERT INTO test_headers (id, header_value) VALUES (1, 'Content-Type: text/html');
INSERT INTO test_headers (id, header_value) VALUES (2, 'Cache-Control: no-cache');
INSERT INTO test_headers (id, header_value) VALUES (3, 'Location: /home');
SELECT http_header (concat (http_header_get (), (SELECT header_value FROM test_headers WHERE id = 1))) AS response_header;
SELECT http_header (concat (http_header_get (), (SELECT header_value FROM test_headers WHERE id IN (1, 2)))) AS response_header;
SELECT http_header (concat (http_header_get (), (SELECT header_value FROM test_headers ORDER BY id LIMIT 1))) AS response_header;
SELECT http_header (concat (http_header_get (), 'X-Custom-Header: value')) AS response_header;
SELECT http_header (concat (http_header_get (), (SELECT GROUP_CONCAT(header_value) FROM test_headers))) AS response_header;
SELECT http_header (concat (http_header_get (), (SELECT header_value FROM test_headers WHERE id = (SELECT MAX(id) FROM test_headers)))) AS response_header;