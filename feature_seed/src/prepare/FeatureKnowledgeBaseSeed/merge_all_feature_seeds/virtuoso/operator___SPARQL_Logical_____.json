CREATE TABLE Employees (ID INT PRIMARY KEY, Name VARCHAR(100), Department VARCHAR(100));
CREATE TABLE Departments (DeptID INT PRIMARY KEY, DeptName VARCHAR(100));
INSERT INTO Employees (ID, Name, Department) VALUES (1, 'Alice', 'HR');
INSERT INTO Employees (ID, Name, Department) VALUES (2, 'Bob', 'Engineering');
INSERT INTO Employees (ID, Name, Department) VALUES (3, 'Charlie', 'Finance');
INSERT INTO Departments (DeptID, DeptName) VALUES (1, 'HR');
INSERT INTO Departments (DeptID, DeptName) VALUES (2, 'Engineering');
INSERT INTO Departments (DeptID, DeptName) VALUES (3, 'Finance');
SELECT Name FROM Employees WHERE Department = 'HR' || Department = 'Engineering';
SELECT Name FROM Employees WHERE ID IN (SELECT ID FROM Employees WHERE Department = 'HR') || ID IN (SELECT ID FROM Employees WHERE Department = 'Finance');
SELECT e.Name FROM Employees e INNER JOIN Departments d ON e.Department = d.DeptName WHERE d.DeptName = 'HR' || d.DeptName = 'Engineering';
SELECT Name FROM Employees WHERE Department = (SELECT DeptName FROM Departments WHERE DeptID = 1) || Department = (SELECT DeptName FROM Departments WHERE DeptID = 2);
SELECT DISTINCT e.Name FROM Employees e LEFT JOIN Departments d ON e.Department = d.DeptName WHERE d.DeptName = 'Engineering' || e.ID = 1;
SELECT e.Name FROM Employees e WHERE (Name LIKE 'A%') || (Department LIKE 'Eng%');