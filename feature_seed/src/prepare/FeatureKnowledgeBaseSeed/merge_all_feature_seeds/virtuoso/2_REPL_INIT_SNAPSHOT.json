CREATE TABLE Demo.demo.Shippers (id INT PRIMARY KEY, ship_name VARCHAR(255), ship_capacity FLOAT, created_at TIMESTAMP DEFAULT NOW());
INSERT INTO Demo.demo.Shippers (id, ship_name, ship_capacity) VALUES (1, 'Ship A', 1000.0), (2, 'Ship B', 1500.5), (3, 'Ship C', NULL);
SELECT REPL_INIT_SNAPSHOT(REPL_SERVER_NAME('localhost:1121'), 'Demo.demo.Shippers', 1 + 1), ship_name FROM Demo.demo.Shippers WHERE ship_capacity IS NOT NULL AND id + 1 = 3;
SELECT ship_name, COUNT(*) FROM Demo.demo.Shippers GROUP BY ship_name HAVING COUNT(*) + 1 > 1;
SELECT REPL_INIT_SNAPSHOT(REPL_SERVER_NAME('localhost:1121'), 'Demo.demo.Shippers', (SELECT MAX(id) FROM Demo.demo.Shippers) + 1) AS snapshot, MIN(ship_capacity) FROM Demo.demo.Shippers WHERE ship_capacity IS NOT NULL;
CREATE TABLE Demo.demo.Orders (order_id INT PRIMARY KEY, ship_id INT, quantity INT, FOREIGN KEY (ship_id) REFERENCES Demo.demo.Shippers(id));
INSERT INTO Demo.demo.Orders (order_id, ship_id, quantity) VALUES (100, 1, 5), (101, 2, 3), (102, NULL);
SELECT o.order_id, s.ship_name FROM Demo.demo.Orders o JOIN Demo.demo.Shippers s ON o.ship_id = s.id WHERE (o.quantity + 1) IS NULL OR s.ship_capacity < (SELECT AVG(ship_capacity) FROM Demo.demo.Shippers);
SELECT REPL_INIT_SNAPSHOT(REPL_SERVER_NAME('localhost:1121'), 'Demo.demo.Shippers', (SELECT COUNT(*) FROM Demo.demo.Orders) + (SELECT COUNT(*) FROM Demo.demo.Shippers)) AS snapshot_count, ship_name FROM Demo.demo.Shippers WHERE ship_capacity IS NOT NULL ORDER BY ship_capacity + 0.0;
SELECT (NULL + 1) AS null_addition_result, REPL_INIT_SNAPSHOT(REPL_SERVER_NAME('localhost:1121'), 'Demo.demo.Shippers', 0 + 1) AS snapshot_result;