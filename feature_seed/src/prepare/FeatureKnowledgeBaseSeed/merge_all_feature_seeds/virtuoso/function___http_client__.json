CREATE TABLE test_http_requests (id INT PRIMARY KEY, url VARCHAR(255), auth_username VARCHAR(100), auth_password VARCHAR(100));
INSERT INTO test_http_requests (id, url, auth_username, auth_password) VALUES (1, 'http://example.com', 'user1', 'pass1');
INSERT INTO test_http_requests (id, url, auth_username, auth_password) VALUES (2, 'https://example.com', NULL, NULL);
INSERT INTO test_http_requests (id, url, auth_username, auth_password) VALUES (3, 'http://test.com/resource', 'user3', 'pass3');
SELECT http_client(url) FROM test_http_requests WHERE id = 1;
SELECT http_client(url) FROM test_http_requests WHERE id = 2;
SELECT http_client(url) FROM test_http_requests WHERE id = 3;
SELECT id, http_client(url) AS response FROM test_http_requests WHERE url LIKE '%example.com';
SELECT http_client(url) FROM test_http_requests WHERE id = (SELECT MAX(id) FROM test_http_requests);
SELECT url FROM test_http_requests WHERE url LIKE 'http%' AND AUTH_USERNAME IS NOT NULL AND AUTH_PASSWORD IS NOT NULL;
SELECT id, (SELECT http_client(url) FROM test_http_requests WHERE id = tr.id) AS response FROM test_http_requests AS tr;
SELECT (http_client(url)) AS response FROM test_http_requests WHERE id IN (SELECT id FROM test_http_requests WHERE url LIKE 'https%');
