CREATE TABLE test_xml (id INTEGER PRIMARY KEY, xml_data XMLType);
INSERT INTO test_xml (id, xml_data) VALUES (1, XMLType('<valid><element>content</element></valid>', 'file://xmlschema/test0001/clean.xsd'));
INSERT INTO test_xml (id, xml_data) VALUES (2, XMLType('<bad />', 'file://xmlschema/test0001/clean.xsd'));
INSERT INTO test_xml (id, xml_data) VALUES (3, XMLType('<valid><element>content</element></valid>', 'file://xmlschema/test0001/clean.xsd'));
SELECT xml_data.isSchemaValidated() FROM test_xml WHERE id = 1;
SELECT xml_data.isSchemaValidated() FROM test_xml WHERE id = 2;
SELECT xml_data.isSchemaValidated() FROM (SELECT xml_data FROM test_xml WHERE id IN (1, 2)) AS subquery;
SELECT t1.id, t1.xml_data.isSchemaValidated() FROM test_xml t1 JOIN (SELECT id FROM test_xml WHERE id = 2) t2 ON t1.id = t2.id;
SELECT COUNT(*) FROM (SELECT xml_data.isSchemaValidated() FROM test_xml WHERE xml_data.isSchemaValidated() = 0) AS invalid_data;
SELECT (SELECT xml_data.isSchemaValidated() FROM test_xml WHERE id = 3) AS validation_result, (SELECT COUNT(*) FROM test_xml) AS total_records;