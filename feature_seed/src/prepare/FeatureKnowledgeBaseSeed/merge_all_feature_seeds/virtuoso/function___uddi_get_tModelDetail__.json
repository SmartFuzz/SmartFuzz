CREATE TABLE tModel (id INT PRIMARY KEY, name VARCHAR(255), description TEXT);
CREATE TABLE tModelDetails (tModel_id INT, detail TEXT, FOREIGN KEY (tModel_id) REFERENCES tModel(id));
INSERT INTO tModel (id, name, description) VALUES (1, 'Test Model A', 'Description of Test Model A');
INSERT INTO tModelDetails (tModel_id, detail) VALUES (1, 'Detail 1 for Test Model A');
INSERT INTO tModelDetails (tModel_id, detail) VALUES (1, 'Detail 2 for Test Model A');
INSERT INTO tModel (id, name, description) VALUES (2, 'Test Model B', 'Description of Test Model B');
SELECT * FROM tModel WHERE id = 1;
SELECT detail FROM tModelDetails WHERE tModel_id = (SELECT id FROM tModel WHERE name = 'Test Model A');
SELECT t.name, d.detail FROM tModel t JOIN tModelDetails d ON t.id = d.tModel_id WHERE t.id = 1;
SELECT t.name, COUNT(d.detail) AS detail_count FROM tModel t LEFT JOIN tModelDetails d ON t.id = d.tModel_id GROUP BY t.id HAVING detail_count > 0;
SELECT t.name, d.detail FROM tModel t LEFT JOIN tModelDetails d ON t.id = d.tModel_id WHERE t.name LIKE '%Test%' ORDER BY d.detail DESC;
SELECT EXISTS(SELECT 1 FROM tModel WHERE id = 1);
UPDATE tModel SET description = 'Updated description for Test Model A' WHERE id = 1;
DELETE FROM tModelDetails WHERE tModel_id = 2;
SELECT t.name, d.detail FROM tModel t LEFT JOIN (SELECT tModel_id, detail FROM tModelDetails WHERE detail LIKE '%Detail%') d ON t.id = d.tModel_id WHERE t.id IN (SELECT id FROM tModel WHERE description LIKE '%Test%');
SELECT t.id, COALESCE(d.detail, 'No details available') AS details FROM tModel t LEFT JOIN (SELECT tModel_id, detail FROM tModelDetails) d ON t.id = d.tModel_id WHERE t.id = (SELECT MAX(id) FROM tModel);