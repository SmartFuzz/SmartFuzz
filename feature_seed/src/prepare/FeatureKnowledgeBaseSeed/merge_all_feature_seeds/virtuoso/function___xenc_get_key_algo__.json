CREATE TABLE keys (key_id VARCHAR(255), key_value VARCHAR(255));
INSERT INTO keys (key_id, key_value) VALUES ('myKey', 'sampleKeyValue');
SELECT xenc_get_key_algo((SELECT key_value FROM keys WHERE key_id = 'myKey'));
CREATE TABLE algorithms (algo_id VARCHAR(255), algo_uri VARCHAR(255));
INSERT INTO algorithms (algo_id, algo_uri) VALUES ('1', 'http://www.w3.org/2000/09/xmldsig#dsa-sha1');
SELECT a.algo_uri FROM algorithms a JOIN keys k ON k.key_value = 'myKey' WHERE a.algo_id = '1';
SELECT xenc_get_key_algo('myKey' || 'ExtraData') FROM dual;
SELECT xenc_get_key_algo(NULL);
SELECT xenc_get_key_algo('');
CREATE TABLE test_keys (test_id INT, test_key VARCHAR(255));
INSERT INTO test_keys (test_id, test_key) VALUES (1, 'myKey');
SELECT xenc_get_key_algo((SELECT test_key FROM test_keys WHERE test_id = 1) || 'AdditionalSuffix');
SELECT xenc_get_key_algo((SELECT test_key FROM test_keys WHERE test_id IN (1, 2)));
SELECT xenc_get_key_algo((SELECT MAX(test_key) FROM test_keys));
SELECT xenc_get_key_algo((SELECT test_key FROM test_keys ORDER BY test_id DESC LIMIT 1));
SELECT xenc_get_key_algo((SELECT DISTINCT test_key FROM test_keys));
CREATE TABLE key_metadata (meta_id INT, key_id VARCHAR(255), meta_value VARCHAR(255));
INSERT INTO key_metadata (meta_id, key_id, meta_value) VALUES (1, 'myKey', 'metadataValue');
SELECT xenc_get_key_algo((SELECT key_id FROM key_metadata WHERE meta_value = 'metadataValue' AND key_id = 'myKey'));