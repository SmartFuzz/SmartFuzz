CREATE TABLE aes_keys (id INT PRIMARY KEY, key_name VARCHAR(50), key_length INT, secret VARCHAR(50));
INSERT INTO aes_keys (id, key_name, key_length, secret) VALUES (1, 'ses_key', 128, 'mysecret');
SELECT xenc_key_AES_create(key_name, key_length, secret) FROM aes_keys WHERE key_name = 'ses_key';
INSERT INTO aes_keys (id, key_name, key_length, secret) VALUES (2, 'test_key', 256, 'anothersecret');
SELECT xenc_key_AES_create(key_name, key_length, secret) FROM aes_keys WHERE key_length = 256 AND secret LIKE 'another%';
WITH keys AS (SELECT key_name, key_length, secret FROM aes_keys WHERE key_length BETWEEN 128 AND 256) SELECT xenc_key_AES_create(key_name, key_length, secret) FROM keys;
INSERT INTO aes_keys (id, key_name, key_length, secret) VALUES (3, 'edge_case_key', 0, 'emptysecret');
SELECT xenc_key_AES_create('boundary_case_key', 128, '');
SELECT xenc_key_AES_create('boundary_case_key', 512, 'toolongsecret') FROM dual;
INSERT INTO aes_keys (id, key_name, key_length, secret) VALUES (4, 'valid_key', 128, 'securepassword');
SELECT xenc_key_AES_create(key_name, key_length, secret) FROM aes_keys WHERE id IN (SELECT id FROM aes_keys WHERE key_length <= 128);
INSERT INTO aes_keys (id, key_name, key_length, secret) VALUES (5, 'duplicate_key', 128, 'mysecret');
SELECT COUNT(*) FROM aes_keys WHERE secret = 'mysecret' GROUP BY key_name HAVING COUNT(*) > 1;