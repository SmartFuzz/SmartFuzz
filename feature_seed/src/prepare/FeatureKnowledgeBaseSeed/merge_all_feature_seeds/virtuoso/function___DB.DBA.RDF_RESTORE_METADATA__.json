CALL DB.DBA.RDF_RESTORE_METADATA('backup_file.rdf');
CALL DB.DBA.RDF_RESTORE_METADATA('http://example.org/backup_graph');
CALL DB.DBA.RDF_RESTORE_METADATA((SELECT RDF_GRAPH FROM BACKUP_METADATA WHERE ID = 1));
CALL DB.DBA.RDF_RESTORE_METADATA((SELECT RDF_URI FROM BACKUP_FILES WHERE FILE_TYPE = 'rdf' AND LAST_UPDATED > '2023-01-01'));
CALL DB.DBA.RDF_RESTORE_METADATA('backup_file.rdf') WHERE (SELECT COUNT(*) FROM BACKUP_METADATA) > 0;
CALL DB.DBA.RDF_RESTORE_METADATA((SELECT RDF_GRAPH FROM ALL_BACKUPS WHERE BACKUP_DATE = '2023-01-01' AND STATUS = 'valid'));
CALL DB.DBA.RDF_RESTORE_METADATA((SELECT RDF_DATA FROM BACKUP_FILES WHERE FILE_NAME LIKE '%.rdf' ORDER BY LAST_MODIFIED DESC LIMIT 1));
CALL DB.DBA.RDF_RESTORE_METADATA('backup_file.rdf') WITH REPLACE YES;
CALL DB.DBA.RDF_RESTORE_METADATA((SELECT GRAPH_URI FROM RDF_BACKUPS WHERE BACKUP_USER = 'admin' LIMIT 5));
CALL DB.DBA.RDF_RESTORE_METADATA((SELECT GRAPH FROM RDF_BACKUP_HISTORY WHERE BACKUP_TYPE = 'full' ORDER BY BACKUP_TIME DESC LIMIT 1));
CALL DB.DBA.RDF_RESTORE_METADATA('C:/backups/backup_file.rdf') ON ERROR CONTINUE;
CALL DB.DBA.RDF_RESTORE_METADATA(CONCAT('graph:', (SELECT GRAPH_NAME FROM ACTIVE_GRAPHS WHERE IS_ACTIVE = TRUE LIMIT 1)));