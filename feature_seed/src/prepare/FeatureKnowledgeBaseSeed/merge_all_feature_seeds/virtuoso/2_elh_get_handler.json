CREATE TABLE test_locale (id INT PRIMARY KEY, lang VARCHAR(50), value VARCHAR(255));
INSERT INTO test_locale (id, lang, value) VALUES (1, 'en', 'Hello'), (2, 'fr', 'Bonjour'), (3, 'es', 'Hola');
SELECT id, value FROM test_locale WHERE elh_get_handler('MY-ENCODING', lang) IS NOT NULL AND value NOT BETWEEN 'A' AND 'I';
SELECT lang, COUNT(*) as count FROM test_locale GROUP BY lang HAVING count NOT BETWEEN 0 AND 10;
SELECT id, elh_get_handler('MY-ENCODING', lang) AS encoded FROM test_locale WHERE encoded NOT BETWEEN 'A' AND 'Z';
SELECT value FROM test_locale WHERE value NOT BETWEEN (SELECT MIN(value) FROM test_locale) AND (SELECT MAX(value) FROM test_locale WHERE lang IS NOT NULL);
CREATE TABLE nested_join (j_id INT PRIMARY KEY, test_id INT, FOREIGN KEY(test_id) REFERENCES test_locale(id));
INSERT INTO nested_join (j_id, test_id) VALUES (1, 1), (2, 2), (3, NULL);
SELECT nj.j_id, tl.value FROM nested_join nj JOIN test_locale tl ON nj.test_id = tl.id WHERE tl.lang NOT BETWEEN 'a' AND 'z' OR tl.value IS NULL;
SELECT elh_get_handler('MY-ENCODING', lang) AS handler_output, COUNT(*) FROM test_locale GROUP BY handler_output HAVING handler_output NOT BETWEEN 'A' AND 'C';
CREATE TEMPORARY TABLE temp_locale AS SELECT id, lang FROM test_locale WHERE value NOT BETWEEN 'A' AND 'Z' ORDER BY lang;
SELECT lang, COUNT(*) FROM temp_locale GROUP BY lang HAVING COUNT(*) NOT BETWEEN 1 AND (SELECT COUNT(*) FROM test_locale WHERE lang IS NOT NULL);