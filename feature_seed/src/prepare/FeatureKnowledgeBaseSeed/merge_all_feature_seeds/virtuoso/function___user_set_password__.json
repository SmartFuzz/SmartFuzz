CREATE TABLE users (user_name VARCHAR(255) PRIMARY KEY, password VARCHAR(255));
INSERT INTO users (user_name, password) VALUES ('admin', 'old_password');
INSERT INTO users (user_name, password) VALUES ('user1', 'user1_password');
UPDATE users SET password = 'new_secure_password' WHERE user_name = 'admin';
SELECT user_name FROM users WHERE user_name IN (SELECT user_name FROM users WHERE password = 'user1_password');
UPDATE users SET password = (SELECT CONCAT('new_', user_name, '_password') FROM users WHERE user_name = 'user1') WHERE user_name = 'user1';
SELECT user_name FROM users WHERE EXISTS (SELECT * FROM users WHERE password != 'old_password');
UPDATE users SET password = 'P@ssw0rd123!' WHERE user_name = 'admin' AND user_name BETWEEN 'admin' AND 'user1';
SELECT user_name FROM users WHERE password LIKE '%new_secure_password%' AND user_name NOT IN (SELECT user_name FROM users WHERE password IS NULL);
CREATE TABLE admin_users (user_name VARCHAR(255), access_level INT, PRIMARY KEY(user_name));
INSERT INTO admin_users (user_name, access_level) VALUES ('admin', 1);
UPDATE users SET password = 'Password!1' WHERE user_name = (SELECT user_name FROM admin_users WHERE access_level = 1 LIMIT 1);
SELECT u.user_name FROM users u JOIN admin_users a ON u.user_name = a.user_name WHERE a.access_level = 1 ORDER BY u.user_name DESC;