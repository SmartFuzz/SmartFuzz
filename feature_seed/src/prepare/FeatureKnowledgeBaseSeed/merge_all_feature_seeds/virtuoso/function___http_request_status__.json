CREATE TABLE http_response_status (id INT PRIMARY KEY, status_code VARCHAR(10) NOT NULL, description VARCHAR(255));
INSERT INTO http_response_status (id, status_code, description) VALUES (1, '200 OK', 'Successful request');
INSERT INTO http_response_status (id, status_code, description) VALUES (2, '301 Moved Permanently', 'Redirects the client to a different URI');
INSERT INTO http_response_status (id, status_code, description) VALUES (3, '403 Forbidden', 'Client does not have access rights');
INSERT INTO http_response_status (id, status_code, description) VALUES (4, '404 Not Found', 'The server can not find the requested resource');
INSERT INTO http_response_status (id, status_code, description) VALUES (5, '500 Internal Server Error', 'The server has encountered a situation it doesn't know how to handle');
SELECT * FROM http_response_status WHERE status_code LIKE '4%';
SELECT status_code, COUNT(*) FROM http_response_status GROUP BY status_code HAVING COUNT(*) > 0;
DELETE FROM http_response_status WHERE id IN (SELECT id FROM http_response_status WHERE status_code = '404 Not Found');
UPDATE http_response_status SET description = 'Request was successful, but information may be different' WHERE status_code = '200 OK';
SELECT status_code FROM http_response_status WHERE id = (SELECT MAX(id) FROM http_response_status);
SELECT MAX(id), MIN(id), COUNT(*) FROM http_response_status;
WITH StatusCounts AS (SELECT status_code, COUNT(*) as count FROM http_response_status GROUP BY status_code) SELECT * FROM StatusCounts WHERE count > 2;
SELECT * FROM http_response_status AS h WHERE h.id IN (SELECT id FROM http_response_status WHERE status_code LIKE '4%') ORDER BY id DESC;
INSERT INTO http_response_status (id, status_code, description) SELECT (SELECT COALESCE(MAX(id), 0) + 1 FROM http_response_status), '418 I'm a teapot', 'Any attempt to instruct the teapot to brew coffee should result in an error response';
CREATE TABLE http_response_logs (log_id INT PRIMARY KEY, status_id INT REFERENCES http_response_status(id), log_message VARCHAR(255), log_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO http_response_logs (log_id, status_id, log_message) VALUES (1, 1, 'Request processed successfully');
SELECT h.status_code, l.log_message FROM http_response_status h JOIN http_response_logs l ON h.id = l.status_id WHERE l.log_time > NOW() - INTERVAL '1 DAY';