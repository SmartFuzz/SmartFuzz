CREATE TABLE test_table (id INTEGER PRIMARY KEY, value NVARCHAR(50));
INSERT INTO test_table (id, value) VALUES (1, 'test1');
INSERT INTO test_table (id, value) VALUES (2, 'test2');
INSERT INTO test_table (id, value) VALUES (3, 'test3');
DECLARE vec ANY;
vec := vector('test1', 'test2', 'test3');
dbg_obj_print(vec);
DECLARE numVec ANY;
numVec := vector(1, 2, 3, 4, 5);
dbg_obj_print(numVec);
DECLARE complexVec ANY;
complexVec := vector(vector('nested1', 'nested2'), vector('nested3', 'nested4'));
dbg_obj_print(complexVec);
CREATE TABLE another_table (id INTEGER PRIMARY KEY, description NVARCHAR(100));
INSERT INTO another_table (id, description) SELECT id, value FROM test_table;
SELECT dbg_obj_print(value) FROM another_table WHERE id = 1;
SELECT dbg_obj_print(value) FROM (SELECT value FROM test_table WHERE id < 3) AS subquery;
DECLARE mergedVec ANY;
mergedVec := vector((SELECT value FROM test_table), (SELECT description FROM another_table));
dbg_obj_print(mergedVec);
CREATE VIEW combined_view AS SELECT t.id, t.value, a.description FROM test_table t JOIN another_table a ON t.id = a.id;
SELECT dbg_obj_print(value) FROM combined_view WHERE id = 2;