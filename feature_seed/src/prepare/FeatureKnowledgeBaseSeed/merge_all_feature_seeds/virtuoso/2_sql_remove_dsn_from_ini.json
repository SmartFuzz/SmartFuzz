CREATE TABLE remote_sources (id INT PRIMARY KEY, dsn_name VARCHAR(255) NOT NULL UNIQUE, connection_string VARCHAR(512), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO remote_sources (id, dsn_name, connection_string) VALUES (1, 'TestDSN', 'Server=myServer;
Database=myDB;
User Id=myUser;
Password=myPass');
SELECT id <> (SELECT id FROM remote_sources WHERE dsn_name = 'TestDSN') AS is_dsn_removed FROM remote_sources;
DELETE FROM remote_sources WHERE id <> (SELECT id FROM remote_sources WHERE dsn_name = 'TestDSN');
INSERT INTO remote_sources (id, dsn_name, connection_string) VALUES (2, 'TestDSN2', 'Server=myServer;
Database=myDB;
User Id=myUser;
Password=myPass');
SELECT COUNT(*) FROM remote_sources WHERE dsn_name <> (SELECT dsn_name FROM remote_sources WHERE id = 2);
SELECT MAX(id) FROM remote_sources WHERE connection_string <> 'InvalidConnectionString' GROUP BY dsn_name HAVING COUNT(dsn_name) <> 2;
UPDATE remote_sources SET connection_string = NULL WHERE id = 1 AND dsn_name <> 'TestDSN';
SELECT SUM(CASE WHEN connection_string IS NULL THEN 1 ELSE 0 END) AS null_count, COUNT(*) FROM remote_sources GROUP BY dsn_name HAVING null_count <> COUNT(*);
SELECT dsn_name, (SELECT COUNT(*) FROM remote_sources WHERE dsn_name <> remote_sources.dsn_name) AS not_equal_count FROM remote_sources;
CREATE TABLE temp_sources (temp_id INT, temp_dsn VARCHAR(255));
INSERT INTO temp_sources (temp_id, temp_dsn) VALUES (3, 'TempDSN');
SELECT * FROM remote_sources WHERE id IS NOT NULL AND temp_dsn IN (SELECT dsn_name FROM remote_sources IF temp_id <> temp_id);
SELECT dsn_name FROM remote_sources WHERE EXISTS (SELECT 1 FROM temp_sources WHERE temp_dsn <> dsn_name);
SELECT * FROM remote_sources WHERE NOT EXISTS (SELECT 1 FROM temp_sources WHERE temp_id <> remote_sources.id);
ALTER TABLE remote_sources ADD COLUMN updated_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP;
DROP TABLE IF EXISTS temp_sources;