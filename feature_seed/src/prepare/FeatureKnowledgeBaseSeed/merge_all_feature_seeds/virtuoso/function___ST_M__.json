CREATE TABLE geo_data (id SERIAL PRIMARY KEY, geom GEOMETRY);
INSERT INTO geo_data (geom) VALUES (ST_Point(10, 20, 30, 40));
INSERT INTO geo_data (geom) VALUES (ST_Point(5, 15, 25, 35));
INSERT INTO geo_data (geom) VALUES (ST_Point(0, 0, 0, 0));
SELECT st_m(geom) FROM geo_data WHERE id = 1;
SELECT st_m(geom) FROM geo_data WHERE id IN (SELECT id FROM geo_data WHERE ST_M(geom) > 35);
SELECT a.id, st_m(a.geom), st_m(b.geom) FROM geo_data a JOIN geo_data b ON a.id <> b.id;
SELECT st_m(ST_Point((SELECT ST_X(geom) FROM geo_data WHERE id = 2), (SELECT ST_Y(geom) FROM geo_data WHERE id = 2), 50, 60));
SELECT CASE WHEN st_m(geom) < 30 THEN 'Near' ELSE 'Far' END AS distance_category FROM geo_data;
SELECT AVG(st_m(geom)) AS average_m FROM geo_data;
SELECT st_m(ST_Collect(geom)) FROM geo_data;
DELETE FROM geo_data WHERE st_m(geom) < 30;
SELECT st_m(geom) FROM (SELECT geom FROM geo_data WHERE id > 0) AS subquery;
CREATE TABLE additional_data (id INT, geom GEOMETRY, FOREIGN KEY (id) REFERENCES geo_data(id));
INSERT INTO additional_data (id, geom) VALUES (1, ST_Point(9, 19, 29, 39));
SELECT a.id, st_m(a.geom) AS m_value, b.geom FROM geo_data a LEFT JOIN additional_data b ON a.id = b.id WHERE b.geom IS NOT NULL;