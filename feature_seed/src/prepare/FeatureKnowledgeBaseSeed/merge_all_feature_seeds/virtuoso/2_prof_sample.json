CREATE TABLE profiling_test (id INT PRIMARY KEY, section_name VARCHAR(255), exec_time INT, success_flag INT);
INSERT INTO profiling_test VALUES (1, 'section_A', 20, 0), (2, 'section_B', 35, 1), (3, 'section_C', 15, 0);
SELECT prof_sample((SELECT section_name FROM profiling_test WHERE success_flag = 0 LIMIT 1), SUM(exec_time), MAX(success_flag)) FROM profiling_test WHERE exec_time > 10;
INSERT INTO profiling_test (section_name, exec_time, success_flag) SELECT 'section_D', 100, bif:st_overlaps(geometry_column, geometry_value) FROM geometry_table WHERE id = 2;
SELECT prof_sample('section_with_NULL', 30, COALESCE(success_flag, 0)) FROM profiling_test WHERE success_flag IS NULL;
SELECT prof_sample('grouped_section', SUM(exec_time), AVG(success_flag)) FROM profiling_test GROUP BY section_name HAVING SUM(exec_time) > 50;
CREATE TABLE geometry_table (id INT PRIMARY KEY, geometry_column GEOMETRY NOT NULL);
INSERT INTO geometry_table VALUES (2, ST_GeomFromText('POINT(1 2)'));
SELECT prof_sample('complex_case', 55, CASE WHEN COUNT(*) > 1 THEN 0 ELSE 1 END) FROM profiling_test WHERE section_name IN (SELECT section_name FROM profiling_test WHERE exec_time < 50) GROUP BY section_name HAVING COUNT(*) > 1;
SELECT prof_sample('boundary_value_section', 0, MIN(success_flag)) FROM profiling_test WHERE exec_time = (SELECT MAX(exec_time) FROM profiling_test) OR exec_time = (SELECT MIN(exec_time) FROM profiling_test);
SELECT prof_sample('spatial_overlap', 45, bif:st_overlaps(geometry_column, ST_GeomFromText('POLYGON((0 0, 2 0, 2 2, 0 2, 0 0))'))) FROM geometry_table INNER JOIN profiling_test ON profiling_test.id = geometry_table.id WHERE profiling_test.exec_time IS NOT NULL;