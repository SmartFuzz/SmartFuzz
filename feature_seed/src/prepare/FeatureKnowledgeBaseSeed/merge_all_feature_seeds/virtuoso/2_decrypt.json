CREATE TABLE test_table (id INT PRIMARY KEY, data VARCHAR(255), content BLOB, score FLOAT);
INSERT INTO test_table (id, data, content, score) VALUES (1, 'test data', encrypt('sample text', 'kaes'), 1.234);
INSERT INTO test_table (id, data, content, score) VALUES (2, NULL, encrypt(NULL, 'kaes'), NULL);
INSERT INTO test_table (id, data, content, score) VALUES (3, 'another test', encrypt('another text', 'kaes'), bif:score());
SELECT id, decrypt(content, 'kaes') AS decrypted_content, bif:score() FROM test_table WHERE data IS NOT NULL;
SELECT id, COUNT(*) OVER (PARTITION BY score ORDER BY id) AS cnt FROM test_table WHERE bif:score() > 1.0;
SELECT id, decrypt(content, 'kaes') AS decrypted_content FROM test_table WHERE score = (SELECT MAX(score) FROM test_table) OR data = '';
SELECT id, SUM(bif:score() * score) AS weighted_score FROM test_table GROUP BY id HAVING weighted_score IS NOT NULL;
SELECT t1.id, t1.data, decrypt(t1.content, 'kaes') FROM test_table t1 JOIN test_table t2 ON t1.score = t2.score AND t2.data = 'test data';
SELECT id, decrypt(content, 'kaes') AS decrypted_content FROM test_table WHERE data IN (SELECT data FROM test_table WHERE score IS NOT NULL) AND score > 0;