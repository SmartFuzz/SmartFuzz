CREATE TABLE test_table (id int, name varchar(100), value int);
INSERT INTO test_table (id, name, value) VALUES (1, 'Alice', 10);
INSERT INTO test_table (id, name, value) VALUES (2, 'Bob', 20);
INSERT INTO test_table (id, name, value) VALUES (3, 'Charlie', 30);
CREATE TABLE related_table (rid int, tid int, description varchar(255));
INSERT INTO related_table (rid, tid, description) VALUES (1, 1, 'Desc A');
INSERT INTO related_table (rid, tid, description) VALUES (2, 1, 'Desc B');
INSERT INTO related_table (rid, tid, description) VALUES (3, 2, 'Desc C');
CREATE PROCEDURE xml_test1 (IN q varchar) { DECLARE st any;
st := string_output ();
xml_auto (q, vector (), st);
result_names (q);
result (string_output_string (st));
};
CALL xml_test1('SELECT id, name FROM test_table WHERE value = ? FOR XML PATH('row'));
CALL xml_test1('SELECT t.id, t.name, r.description FROM test_table t JOIN related_table r ON t.id = r.tid WHERE t.value = ? FOR XML PATH('entry'));
CALL xml_test1('SELECT a.id, a.name, b.description FROM test_table a LEFT JOIN related_table b ON a.id = b.tid WHERE a.value > ? AND b.description IS NOT NULL FOR XML PATH('item'), ROOT('root'));
CALL xml_test1('SELECT id, name FROM test_table WHERE id IN (SELECT tid FROM related_table WHERE description LIKE ''%A%'') FOR XML PATH('user'));
CREATE TABLE complex_table (cid int, cname varchar(100), cvalue int, parent_id int);
INSERT INTO complex_table (cid, cname, cvalue, parent_id) VALUES (1, 'Parent', 100, NULL);
INSERT INTO complex_table (cid, cname, cvalue, parent_id) VALUES (2, 'Child 1', 50, 1);
INSERT INTO complex_table (cid, cname, cvalue, parent_id) VALUES (3, 'Child 2', 75, 1);
CALL xml_test1('SELECT c.cid, c.cname, (SELECT cname FROM complex_table WHERE parent_id = c.cid FOR XML PATH('subitem')) as children FROM complex_table c WHERE c.cvalue > ? FOR XML PATH('complexEntry'));