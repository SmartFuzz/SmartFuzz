CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(100), balance DECIMAL(10, 2));
INSERT INTO users (id, username, balance) VALUES (1, 'user1', 100.00), (2, 'user2', NULL), (3, 'user3', 50.25), (4, 'user4', 0.00);
SELECT SUM(balance) * (SELECT COUNT(*) FROM users WHERE balance IS NOT NULL) AS total_balance FROM users;
SELECT username() * 2 AS user_multiplication FROM users WHERE id = 1;
SELECT username(), AVG(balance) FROM users GROUP BY username() HAVING AVG(balance) > 25;
SELECT (username() || ' has balance: ' || COALESCE(balance, 0)) AS user_info FROM users WHERE balance IS NOT NULL;
SELECT username() AS current_user, COUNT(*) AS counts FROM (SELECT * FROM users WHERE balance < 100 GROUP BY username()) AS user_counts;
SELECT u.username, (u.balance * (SELECT COUNT(*) FROM users) + NULL) AS adjusted_balance FROM users AS u WHERE adjusted_balance IS NOT NULL;
SELECT u1.username, (SELECT COUNT(*) FROM users AS u2 WHERE u2.balance > u1.balance) * 10 AS rank FROM users AS u1;
SELECT username() FROM users WHERE id = (SELECT MAX(id) FROM users WHERE balance IS NOT NULL);