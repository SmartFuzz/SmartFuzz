CREATE TABLE numbers (id INT, value INT);
INSERT INTO numbers (id, value) VALUES (1, 10);
INSERT INTO numbers (id, value) VALUES (2, 4);
INSERT INTO numbers (id, value) VALUES (3, 0);
SELECT value, mod(value, 3) AS modulus FROM numbers;
SELECT n1.value, n2.value, mod(n1.value, n2.value) AS modulus FROM numbers n1 JOIN numbers n2 ON n1.id = 1 AND n2.id = 2;
SELECT mod(value, 5) AS modulus FROM (SELECT value FROM numbers WHERE id = 1) AS subquery;
SELECT mod((SELECT value FROM numbers WHERE id = 1), (SELECT value FROM numbers WHERE id = 2)) AS modulus;
SELECT mod(a.value, b.value) FROM (SELECT value FROM numbers WHERE id = 1) AS a, (SELECT value FROM numbers WHERE id = 3) AS b;
SELECT COALESCE(mod(value, 0), 'Division by zero error') AS result FROM numbers WHERE id = 3;