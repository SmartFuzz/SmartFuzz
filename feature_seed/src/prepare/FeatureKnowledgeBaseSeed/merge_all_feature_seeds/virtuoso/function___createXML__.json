CREATE TABLE XMLTYPE_TEST (I integer primary key, XMLVAL long xml);
INSERT INTO XMLTYPE_TEST values (1, createXML('<emp><empno>221</empno><ename>John</ename></emp>'));
INSERT INTO XMLTYPE_TEST values (2, createXML('<po><pono>331</pono><poname>PO_1</poname></po>'));
INSERT INTO XMLTYPE_TEST values (3, createXML('<emp><empno>222</empno><ename>Jane</ename><details><age>30</age><dept>HR</dept></details></emp>'));
INSERT INTO XMLTYPE_TEST values (4, createXML('<po><pono>332</pono><poname>PO_2</poname><items><item><itemid>1</itemid><quantity>10</quantity></item><item><itemid>2</itemid><quantity>20</quantity></item></items></po>'));
SELECT e.XMLVAL.extract('//empno/text()').getNumVal() as EMPNO FROM XMLTYPE_TEST as e WHERE e.XMLVAL.existsNode('/emp/empno') = 1;
SELECT e.XMLVAL.extract('//poname/text()').getStringVal() as PONAME FROM XMLTYPE_TEST as e WHERE e.XMLVAL.existsNode('/po/poname') = 1;
SELECT e.XMLVAL.extract('//emp/ename/text()').getStringVal() as ENAME FROM XMLTYPE_TEST as e WHERE e.XMLVAL.existsNode('/emp/ename') = 1 AND e.I = 1;
SELECT e.XMLVAL.extract('//age/text()').getNumVal() as AGE FROM XMLTYPE_TEST as e WHERE e.XMLVAL.existsNode('/emp/details/age') = 1;
SELECT (SELECT e.XMLVAL.extract('//poname/text()').getStringVal() FROM XMLTYPE_TEST as e WHERE e.XMLVAL.existsNode('/po/poname') = 1 AND e.I = 2) as PONAME, (SELECT e.XMLVAL.extract('//empno/text()').getNumVal() FROM XMLTYPE_TEST as e WHERE e.XMLVAL.existsNode('/emp/empno') = 1 AND e.I = 1) as EMPNO;
CREATE TABLE XMLTYPE_TEST_2 (ID integer primary key, XMLDATA long xml);
INSERT INTO XMLTYPE_TEST_2 values (1, createXML('<company><name>ABC Corp</name><employees><emp><empno>221</empno><ename>John</ename></emp><emp><empno>222</empno><ename>Jane</ename></emp></employees></company>'));
SELECT emp.XMLVAL.extract('//name/text()').getStringVal() as COMPANY_NAME FROM XMLTYPE_TEST_2 as emp WHERE emp.XMLDATA.existsNode('/company/name') = 1;