CREATE TABLE connection_test (id INT PRIMARY KEY, var_name VARCHAR(50), var_value VARCHAR(100));
INSERT INTO connection_test (id, var_name, var_value) VALUES (1, 'test_var1', '100'), (2, 'test_var2', '200');
DECLARE ses_vars ANY;
ses_vars := connection_vars();
SELECT COUNT(*) FROM connection_test WHERE CAST(var_value AS INT) > CAST(ses_vars['test_var1'] AS INT);
SELECT var_name FROM (SELECT var_name, var_value FROM connection_test) AS subquery WHERE SUBSTRING(var_value, 1, 3) > '150';
SELECT var_name, AVG(CASE WHEN var_value IS NULL THEN 0 ELSE CAST(var_value AS FLOAT) END) AS avg_value FROM connection_test GROUP BY var_name HAVING avg_value > 50;
INSERT INTO connection_test (id, var_name, var_value) VALUES (3, 'test_var3', NULL);
SELECT * FROM connection_test WHERE id IN (SELECT id FROM connection_test WHERE var_value IS NOT NULL AND CAST(var_value AS INT) > 150);
UPDATE connection_test SET var_value = NULL WHERE id = 1;
SELECT var_name FROM connection_test WHERE var_value IS NULL AND id > 0;
CREATE TEMPORARY TABLE temp_vars AS SELECT var_name, COUNT(*) AS count_vars FROM connection_test GROUP BY var_name HAVING count_vars > 1;
SELECT var_name, (SELECT COUNT(*) FROM temp_vars WHERE var_name = connection_test.var_name) AS occurrences FROM connection_test WHERE EXISTS (SELECT 1 FROM temp_vars WHERE COUNT(*) > 1) ORDER BY occurrences DESC;