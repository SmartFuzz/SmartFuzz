CREATE TABLE graphs (graph_name VARCHAR(100) PRIMARY KEY, owner_name VARCHAR(100));
INSERT INTO graphs (graph_name, owner_name) VALUES ('private_graph', 'demo');
INSERT INTO graphs (graph_name, owner_name) VALUES ('public_graph', 'admin');
SELECT DISTINCT g.owner_name FROM graphs g JOIN user_permissions up ON g.owner_name = up.uname WHERE up.perms & 1 = 1;
DB.DBA.RDF_DEFAULT_USER_PERMS_SET ((SELECT uname FROM user_permissions WHERE perms < 3), 3, 0);
DB.DBA.RDF_DEFAULT_USER_PERMS_SET ('unknown_user', 5, 0);
SELECT COUNT(*) FROM graphs WHERE owner_name IN (SELECT uname FROM user_permissions WHERE perms & 4 = 4);
CREATE TABLE temp_permissions (uname VARCHAR(100), perms INT);
INSERT INTO temp_permissions (uname, perms) SELECT uname, perms FROM user_permissions WHERE perms > 0;
DB.DBA.RDF_DEFAULT_USER_PERMS_SET ((SELECT uname FROM temp_permissions WHERE perms = 1), 1, 1);
DELETE FROM user_permissions WHERE uname = 'old_user';
