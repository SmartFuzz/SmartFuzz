CREATE TABLE user_permissions (uname VARCHAR(100), perms INT, other INT);
INSERT INTO user_permissions (uname, perms, other) VALUES ('demo', 0, 1);
INSERT INTO user_permissions (uname, perms, other) VALUES ('admin', 7, 0);
DB.DBA.RDF_DEFAULT_USER_PERMS_SET ('demo', 0, 1);
