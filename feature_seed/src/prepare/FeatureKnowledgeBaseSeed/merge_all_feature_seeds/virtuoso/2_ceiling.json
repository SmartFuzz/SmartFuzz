CREATE TABLE test_data (id INT, value FLOAT, text_field VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_data (id, value, text_field) VALUES (1, 12.3456, 'example1'), (2, -12.3456, 'example2'), (3, 0.513513, NULL);
SELECT ceiling(value) AS rounded_value, bif:score() FROM test_data WHERE text_field IS NOT NULL AND value > 0;
SELECT id, ceiling(AVG(value)) AS avg_value FROM test_data GROUP BY id HAVING avg_value < 10;
SELECT ceiling(bif:score()) AS score_rounded FROM (SELECT text_field, bif:score() FROM test_data WHERE text_field IS NOT NULL) AS scores;
SELECT id, ceiling(value) + bif:score() AS combined_score FROM test_data WHERE created_at < NOW() - INTERVAL '7 days' ORDER BY combined_score DESC;
SELECT t1.id, t1.value FROM test_data t1 JOIN test_data t2 ON ceiling(t1.value) = ceiling(t2.value) WHERE t1.id != t2.id;
SELECT id, ceiling(NVL(value, 0)) AS non_null_value FROM test_data;
SELECT text_field, COUNT(*) FROM test_data GROUP BY text_field HAVING COUNT(*) > ceiling(2.0);
SELECT DISTINCT ceiling(bif:score()) AS unique_scores FROM (SELECT value, bif:score() FROM test_data) AS score_table WHERE value IS NOT NULL;