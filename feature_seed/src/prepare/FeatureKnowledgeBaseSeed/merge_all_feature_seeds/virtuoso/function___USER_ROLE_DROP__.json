DROP ROLE IF EXISTS 'non_existent_role';
DROP ROLE 'admin' WHERE EXISTS (SELECT * FROM user_roles WHERE role_name = 'admin');
DROP ROLE 'test_role' CASCADE;
DROP ROLE 'user' WHERE role_id IN (SELECT role_id FROM role_permissions WHERE permission = 'delete_all');
DROP ROLE 'group_role' IF EXISTS (SELECT COUNT(*) FROM user_groups WHERE group_name = 'group_role' HAVING COUNT(*) > 0);
DROP ROLE 'manager' IF EXISTS (SELECT * FROM roles WHERE role_type = 'manager' AND active = TRUE);
DROP ROLE 'duplicate_role' WHERE NOT EXISTS (SELECT * FROM roles WHERE role_name = 'duplicate_role' AND usage_count > 0) AND EXISTS (SELECT * FROM role_history WHERE role_name = 'duplicate_role' AND DATE(created_at) < '2020-01-01');
DROP ROLE (SELECT role_name FROM roles WHERE creation_date < '2010-01-01' AND NOT EXISTS (SELECT * FROM active_sessions WHERE role_name = roles.role_name));
DROP ROLE 'test_role' IF EXISTS (SELECT * FROM roles WHERE permissions IN (SELECT permission FROM role_permissions WHERE can_delete = TRUE) LIMIT 1);
DROP ROLE 'old_role' IF EXISTS (SELECT 1 FROM user_roles INNER JOIN role_assignments ON user_roles.role_id = role_assignments.role_id WHERE user_roles.role_name = 'old_role' AND role_assignments.role_count = 0);