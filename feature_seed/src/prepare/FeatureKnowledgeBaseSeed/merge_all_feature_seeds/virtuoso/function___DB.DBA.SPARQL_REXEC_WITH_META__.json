CREATE GRAPH <http://example.org/testGraph>;
INSERT DATA INTO <http://example.org/testGraph> { <http://example.org/subject1> <http://example.org/predicate1> <http://example.org/object1> . <http://example.org/subject2> <http://example.org/predicate2> <http://example.org/object2> . };
SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o . } };
SELECT (COUNT(?o) AS ?count) WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o . } };
SELECT ?s WHERE { GRAPH <http://example.org/testGraph> { ?s <http://example.org/predicate1> ?o1 . ?s <http://example.org/predicate2> ?o2 . } };
SELECT ?s WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o . FILTER (?o = <http://example.org/object1>) . } };
SELECT ?s ?o WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o . BIND(CONCAT(STR(?s), STR(?p)) AS ?newVar) . } };
SELECT ?s WHERE { VALUES ?s { <http://example.org/subject1> <http://example.org/subject2> } . GRAPH <http://example.org/testGraph> { ?s ?p ?o . } };
CONSTRUCT { ?s <http://example.org/predicate1> ?o } WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o . FILTER (STR(?o) = 'someValue') . } };
SELECT * FROM { SELECT ?s WHERE { GRAPH <http://example.org/testGraph> { ?s ?p ?o . } } } AS %subQuery WHERE { FILTER(?s != <http://example.org/subject2>) };
SELECT ?s WHERE { SERVICE <http://example.org/sparqlService> { GRAPH <http://example.org/testGraph> { ?s ?p ?o . } } };
SELECT ?s WHERE { GRAPH <http://example.org/testGraph1> { ?s ?p ?o } UNION GRAPH <http://example.org/testGraph2> { ?s ?p ?o } };