CREATE TABLE spki_keys (id INTEGER PRIMARY KEY, public_key VARCHAR(4096));
INSERT INTO spki_keys (id, public_key) VALUES (1, '-----BEGIN PUBLIC KEY-----\nMIIBIjANBgkqhkiG9w0BAQEFAAOCAQ8AMIIBCgKCAQ...');
INSERT INTO spki_keys (id, public_key) VALUES (2, '-----BEGIN PUBLIC KEY-----\nMIGfMA0GCSqGSIb3DQEBAQUAA4GNADCB...');
SELECT k.id, k.public_key FROM spki_keys k WHERE k.id = (SELECT MAX(id) FROM spki_keys);
SELECT k1.id, k1.public_key FROM spki_keys k1 JOIN spki_keys k2 ON k1.id <> k2.id WHERE LENGTH(k1.public_key) > LENGTH(k2.public_key);
SELECT k.id, k.public_key FROM spki_keys k WHERE k.public_key LIKE '%-----BEGIN PUBLIC KEY-----%' AND LENGTH(k.public_key) BETWEEN 200 AND 4096;
SELECT COUNT(*) FROM spki_keys WHERE public_key IS NOT NULL AND LENGTH(public_key) > 0;
INSERT INTO spki_keys (id, public_key) SELECT (SELECT COALESCE(MAX(id), 0) + 1 FROM spki_keys), k FROM (VALUES ('-----BEGIN PUBLIC KEY-----\nMII...'), ('-----BEGIN PUBLIC KEY-----\nMIIC...')) AS temp (k);
CREATE INDEX idx_public_key ON spki_keys (public_key);
DELETE FROM spki_keys WHERE id IN (SELECT id FROM spki_keys WHERE LENGTH(public_key) < 200);