CREATE TABLE test_group_sort (id INTEGER, group1 INTEGER, group2 INTEGER);
INSERT INTO test_group_sort (id, group1, group2) VALUES (1, 3, 4);
INSERT INTO test_group_sort (id, group1, group2) VALUES (2, 1, 2);
INSERT INTO test_group_sort (id, group1, group2) VALUES (3, 5, 1);
INSERT INTO test_group_sort (id, group1, group2) VALUES (4, 1, 3);
SELECT * FROM test_group_sort;
SELECT * FROM test_group_sort ORDER BY group1 ASC;
SELECT * FROM test_group_sort ORDER BY group2 DESC;
SELECT * FROM test_group_sort ORDER BY group1 ASC, group2 DESC;
SELECT id, group1, group2 FROM (SELECT * FROM test_group_sort) AS subquery ORDER BY group2 ASC, group1 ASC;
SELECT DISTINCT group1, group2 FROM test_group_sort ORDER BY group1 ASC;
CREATE TABLE test_data (key_value INTEGER, associated_value INTEGER);
INSERT INTO test_data (key_value, associated_value) VALUES (3, 10);
INSERT INTO test_data (key_value, associated_value) VALUES (1, 20);
INSERT INTO test_data (key_value, associated_value) VALUES (2, 15);
SELECT key_value, associated_value FROM test_data ORDER BY key_value ASC;
SELECT key_value, associated_value FROM test_data ORDER BY associated_value DESC, key_value ASC;
SELECT * FROM (SELECT * FROM test_data WHERE key_value > 1) AS subquery ORDER BY associated_value ASC;
CREATE TABLE test_nested (a INTEGER, b INTEGER, c INTEGER);
INSERT INTO test_nested (a, b, c) VALUES (1, 5, 7);
INSERT INTO test_nested (a, b, c) VALUES (2, 3, 8);
INSERT INTO test_nested (a, b, c) VALUES (3, 6, 2);
INSERT INTO test_nested (a, b, c) VALUES (4, 4, 1);
SELECT * FROM test_nested ORDER BY b ASC, c DESC;
SELECT a, b FROM (SELECT * FROM test_nested) AS nested_query ORDER BY a ASC;
SELECT * FROM (SELECT a, b FROM test_nested WHERE b < 6) AS subquery ORDER BY a DESC;