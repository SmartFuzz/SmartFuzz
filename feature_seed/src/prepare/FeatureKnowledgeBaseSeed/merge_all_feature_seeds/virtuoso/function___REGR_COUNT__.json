CREATE TABLE sales (id INT, revenue DECIMAL, cost DECIMAL);
INSERT INTO sales (id, revenue, cost) VALUES (1, 100.0, 50.0);
INSERT INTO sales (id, revenue, cost) VALUES (2, NULL, 25.0);
INSERT INTO sales (id, revenue, cost) VALUES (3, 200.0, NULL);
INSERT INTO sales (id, revenue, cost) VALUES (4, NULL, NULL);
INSERT INTO sales (id, revenue, cost) VALUES (5, 150.0, 75.0);
SELECT REGR_COUNT(revenue, cost) FROM sales;
SELECT REGR_COUNT(revenue, cost) FROM sales WHERE revenue IS NOT NULL;
SELECT REGR_COUNT(revenue, cost) FROM (SELECT revenue, cost FROM sales WHERE revenue > 100) AS filtered_sales;
CREATE TABLE additional_sales (id INT, profit DECIMAL);
INSERT INTO additional_sales (id, profit) VALUES (1, 30.0);
INSERT INTO additional_sales (id, profit) VALUES (2, 20.0);
SELECT a.id, REGR_COUNT(s.revenue, s.cost) FROM sales s JOIN additional_sales a ON s.id = a.id GROUP BY a.id;
SELECT REGR_COUNT(revenue, cost) + REGR_COUNT(cost, revenue) AS total_counts FROM sales;
SELECT REGR_COUNT(revenue, cost) OVER (PARTITION BY id) FROM sales;
SELECT REGR_COUNT(revenue, cost) FROM (SELECT id, revenue, cost FROM sales WHERE id < 4) AS subquery WHERE revenue IS NOT NULL AND cost IS NOT NULL;