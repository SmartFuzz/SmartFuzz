CREATE TABLE encryption_keys (key_name VARCHAR(255) NOT NULL PRIMARY KEY, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO encryption_keys (key_name) VALUES ('MyKey'), ('AnotherKey'), (NULL), (''), ('KeyWithVeryLongNameThatExceedsTheNormalLengthLimits');
SELECT key_name, xenc_key_exists(key_name) % 2 AS key_check FROM encryption_keys WHERE key_name IS NOT NULL OR xenc_key_exists('RandomKey') = 0;
SELECT key_name, (SELECT COUNT(*) FROM encryption_keys) % (SELECT COUNT(key_name) FROM encryption_keys WHERE key_name IS NOT NULL) AS mod_count FROM encryption_keys GROUP BY key_name HAVING mod_count >= 1;
SELECT key_name, xenc_key_exists(CONCAT(key_name, '_extra')) AS existence_check FROM encryption_keys WHERE (key_name IS NOT NULL AND xenc_key_exists(key_name)) OR xenc_key_exists('SomeKey') IS NULL;
SELECT key_name, (xenc_key_exists(key_name) % 3) AS key_modulus FROM encryption_keys ORDER BY key_modulus DESC LIMIT 5;
SELECT key_name, xenc_key_exists(NULLIF(key_name, '')) AS key_null_check FROM encryption_keys WHERE key_name IS NOT NULL GROUP BY key_name HAVING xenc_key_exists(key_name) <> 1;
WITH key_counts AS (SELECT key_name, COUNT(*) AS cnt FROM encryption_keys GROUP BY key_name) SELECT key_name, cnt % 4 AS mod_count FROM key_counts WHERE xenc_key_exists(key_name) = 1;
SELECT key_name, xenc_key_exists('MyKey') AND (10 % 3 = 1) AS check_condition FROM encryption_keys WHERE xenc_key_exists(key_name) = 0;
ALTER TABLE encryption_keys ADD COLUMN user_id INT REFERENCES users(id);