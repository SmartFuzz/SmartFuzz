CREATE TABLE sequences_table (id INT PRIMARY KEY, seq_val INT);
INSERT INTO sequences_table (id, seq_val) VALUES (1, sequence_next('my_sequence'));
INSERT INTO sequences_table (id, seq_val) VALUES (2, sequence_next('my_sequence'));
SELECT id, seq_val, xpath_split('<root><child>Value1</child><child>Value2</child></root>', '/root/child') AS split_values FROM sequences_table;
SELECT id, seq_val FROM sequences_table WHERE seq_val = (SELECT MAX(seq_val) FROM sequences_table) OR seq_val IS NULL;
SELECT id, seq_val, sequence_next('my_sequence') AS new_seq WHERE xpath_split('<root><child>Value1</child><child>Value2</child></root>', '/root/child') IS NOT NULL;
SELECT seq_val, COUNT(*) FROM sequences_table GROUP BY seq_val HAVING COUNT(*) > 1;
WITH ranked_sequences AS (SELECT id, seq_val, ROW_NUMBER() OVER (ORDER BY seq_val) AS rank FROM sequences_table) SELECT rank, seq_val FROM ranked_sequences WHERE seq_val IS NOT NULL;
CREATE TABLE xml_data (data XML);
INSERT INTO xml_data (data) VALUES ('<root><child>Test</child></root>');
SELECT xpath_split(data, '/root/child') AS split_xml FROM xml_data WHERE data IS NOT NULL;
INSERT INTO sequences_table (id, seq_val) VALUES (3, sequence_next('my_sequence') + CAST(NULL AS INT));
SELECT seq_val, xpath_split('<root><child>Value1</child></root>', '/root/child') FROM sequences_table WHERE seq_val - 1 = 0;
SELECT id, seq_val FROM sequences_table WHERE seq_val < (SELECT MIN(seq_val) FROM sequences_table WHERE seq_val IS NOT NULL) OR seq_val IS NULL;