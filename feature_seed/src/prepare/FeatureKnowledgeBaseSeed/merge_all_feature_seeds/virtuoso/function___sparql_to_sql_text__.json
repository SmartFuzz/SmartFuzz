CREATE TABLE example_data (s VARCHAR, p VARCHAR, o VARCHAR);
INSERT INTO example_data VALUES ('subject1', 'predicate1', 'object1');
INSERT INTO example_data VALUES ('subject2', 'predicate2', 'object2');
SELECT sparql_to_sql_text('SELECT ?s ?p ?o WHERE {?s ?p ?o}');
SELECT sparql_to_sql_text('SELECT ?s WHERE { ?s ?p ?o . FILTER(?o = "object1") }');
SELECT sparql_to_sql_text('SELECT ?s ?o WHERE { ?s ?p ?o . ?p ?p2 ?o2 }');
SELECT sparql_to_sql_text('SELECT ?s WHERE { { ?s ?p ?o } UNION { ?s ?p2 ?o2 } }');
SELECT sparql_to_sql_text('SELECT ?s ?p ?o WHERE { {?s ?p ?o} FILTER(?p IN ("predicate1", "predicate2")) }');
SELECT sparql_to_sql_text('SELECT ?s WHERE { ?s ?p ?o . GRAPH <http://example.org/graph> { ?s ?p2 ?o2 } }');
SELECT sparql_to_sql_text('SELECT ?s WHERE { ?s ?p ?o . OPTIONAL { ?s ?p2 ?o2 } }');
SELECT sparql_to_sql_text('SELECT ?s WHERE { ?s ?p ?o . FILTER(STR(?s) = "subject1") }');
SELECT sparql_to_sql_text('SELECT ?s WHERE { ?s ?p ?o . BIND(CONCAT(?s, "_suffix") AS ?new_s) }');
SELECT sparql_to_sql_text('SELECT (COUNT(?s) AS ?count) WHERE { ?s ?p ?o } GROUP BY ?p HAVING (?count > 1)');