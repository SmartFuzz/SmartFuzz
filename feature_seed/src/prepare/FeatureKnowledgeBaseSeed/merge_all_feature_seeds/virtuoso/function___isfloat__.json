CREATE TABLE TestFloats (id INT PRIMARY KEY, value FLOAT);
INSERT INTO TestFloats (id, value) VALUES (1, 0.0);
INSERT INTO TestFloats (id, value) VALUES (2, 1.5);
INSERT INTO TestFloats (id, value) VALUES (3, -3.14);
INSERT INTO TestFloats (id, value) VALUES (4, NULL);
INSERT INTO TestFloats (id, value) VALUES (5, 1234567890.123456);
INSERT INTO TestFloats (id, value) VALUES (6, 'text');
INSERT INTO TestFloats (id, value) VALUES (7, 1.0e10);
INSERT INTO TestFloats (id, value) VALUES (8, '1.5');
SELECT id, value, isfloat(value) FROM TestFloats WHERE value IS NOT NULL;
SELECT id, value FROM TestFloats WHERE isfloat(value) = 1;
SELECT id, value FROM TestFloats WHERE isfloat(value) = 0 AND value IS NOT NULL;
SELECT t1.id, t1.value, isfloat(t1.value) AS is_float, t2.value AS related_value FROM TestFloats t1 INNER JOIN TestFloats t2 ON t1.id = t2.id WHERE isfloat(t2.value) = 1;
SELECT COUNT(*) FROM TestFloats WHERE isfloat(value) = 1 AND value > 0;
CREATE TABLE RelatedData (id INT PRIMARY KEY, related_value FLOAT);
INSERT INTO RelatedData (id, related_value) VALUES (1, 2.5);
INSERT INTO RelatedData (id, related_value) VALUES (2, 3.5);
SELECT t1.id, t1.value, r.related_value FROM TestFloats t1 LEFT JOIN RelatedData r ON t1.id = r.id WHERE isfloat(t1.value) = 1;
WITH FloatCheck AS (SELECT id, value, isfloat(value) as is_float FROM TestFloats) SELECT * FROM FloatCheck WHERE is_float = 1;
SELECT AVG(value) FROM TestFloats WHERE isfloat(value) = 1;