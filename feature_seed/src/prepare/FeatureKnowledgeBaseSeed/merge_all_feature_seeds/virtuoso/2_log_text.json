CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(50), data TEXT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (name, data) VALUES ('Sample', 'Test data 1'), ('Example', NULL), ('Edge', '');
CREATE PROCEDURE log_test () { log_text('INSERT INTO test_table (name, data) VALUES (?, ?)', 'Test One', 'Sample Data');
log_enable(0);
SELECT * FROM test_table WHERE name ILIKE 'Sample%';
log_enable(1);
};
SELECT id, name, log_text('SELECT COUNT(*) FROM test_table WHERE name ILIKE ?', id) AS name_count FROM test_table GROUP BY id, name HAVING COUNT(*) > 0;
SELECT name FROM test_table WHERE ILIKE(name, 'e%') AND created_at > (SELECT MIN(created_at) FROM test_table);
CREATE TABLE temp_table (temp_id INTEGER NOT NULL CHECK (temp_id > 0), temp_name VARCHAR(100));
INSERT INTO temp_table (temp_id, temp_name) VALUES (1, 'Temp A'), (2, 'Temp B'), (3, NULL);
SELECT tt.temp_name FROM temp_table tt JOIN test_table t ON tt.temp_id = t.id WHERE tt.temp_name ILIKE 'Temp%' AND t.data IS NOT NULL;
CREATE TABLE complex_table (c_id INTEGER, c_value VARCHAR(40), UNIQUE (c_value));
INSERT INTO complex_table (c_id, c_value) VALUES (1, 'Comp A'), (2, 'Comp B'), (3, NULL);
CREATE OR REPLACE PROCEDURE complex_logging() { log_text('SELECT c_value FROM complex_table WHERE c_value ILIKE ? AND c_id < ?', 'Comp%', 3);
SELECT log_text('SELECT ILIKE(name, ?)', 'C%');
};