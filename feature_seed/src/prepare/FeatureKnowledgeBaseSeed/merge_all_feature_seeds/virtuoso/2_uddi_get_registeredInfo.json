CREATE TABLE businessEntities (id INT PRIMARY KEY, name VARCHAR(255), credentials VARCHAR(255), created_at TIMESTAMP);
CREATE TABLE tModels (id INT PRIMARY KEY, entityId INT, model VARCHAR(255), FOREIGN KEY (entityId) REFERENCES businessEntities(id));
INSERT INTO businessEntities (id, name, credentials, created_at) VALUES (1, 'Entity_One', 'credentials_001', CURRENT_TIMESTAMP);
INSERT INTO tModels (id, entityId, model) VALUES (1, 1, 'Model_One');
INSERT INTO businessEntities (id, name, credentials, created_at) VALUES (2, 'Entity_Two', NULL, CURRENT_TIMESTAMP);
INSERT INTO tModels (id, entityId, model) VALUES (2, 2, 'Model_Two');
SELECT uddi_get_registeredInfo() + 1;
SELECT SUM(t.id) + COUNT(b.id) FROM businessEntities b JOIN tModels t ON b.id = t.entityId GROUP BY b.name HAVING SUM(t.id) > 0;
SELECT (SELECT COUNT(*) + COALESCE(NULL, 0) FROM tModels) AS total_models, (SELECT COUNT(*) FROM businessEntities b WHERE b.created_at > CURRENT_TIMESTAMP - INTERVAL '30 days') AS recent_entities;
SELECT b.id, (uddi_get_registeredInfo() + b.id) AS enriched_info FROM businessEntities b WHERE b.credentials IS NOT NULL;
SELECT DISTINCT b.name, AVG(LENGTH(t.model)) + NULL AS length FROM businessEntities b LEFT JOIN tModels t ON b.id = t.entityId GROUP BY b.name HAVING length > 0;
SELECT b.name, (uddi_get_registeredInfo() + LENGTH(b.name)) AS enriched FROM businessEntities b WHERE EXISTS (SELECT 1 FROM tModels t WHERE t.entityId = b.id) ORDER BY enriched DESC;
SELECT (SELECT COUNT(*) FROM businessEntities) + (SELECT COUNT(*) + (NULL) FROM tModels) AS total_count;
ALTER TABLE businessEntities ADD COLUMN is_active BOOLEAN DEFAULT TRUE;
UPDATE tModels SET model = CONCAT(model, ' - Updated') WHERE entityId IN (SELECT id FROM businessEntities WHERE is_active = TRUE) + 1;