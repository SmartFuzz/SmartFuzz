CREATE TABLE geometries (id INT PRIMARY KEY, geom GEOMETRY);
INSERT INTO geometries (id, geom) VALUES (1, st_point(10, 20));
INSERT INTO geometries (id, geom) VALUES (2, st_point(-10, -20));
INSERT INTO geometries (id, geom) VALUES (3, st_point(0, 0));
INSERT INTO geometries (id, geom) VALUES (4, st_point(100, 200));
SELECT st_y(geom) FROM geometries WHERE id = 1;
SELECT st_y(geom) FROM geometries WHERE id = 2;
SELECT st_y(geom) FROM geometries WHERE id = 3;
SELECT st_y(geom) FROM geometries WHERE id = 4;
SELECT st_y(st_point(0, 0)) AS y_coordinate;
SELECT DISTINCT (bif:st_y(geom)) FROM geometries;
SELECT g1.id, g1.geom, st_y(g1.geom) AS y1, st_y(g2.geom) AS y2 FROM geometries g1 JOIN geometries g2 ON g1.id != g2.id WHERE g1.id = 1;
SELECT g1.id, st_y(g1.geom) FROM (SELECT * FROM geometries WHERE id > 0) g1;
SELECT (SELECT st_y(geom) FROM geometries WHERE id = 1) AS y1, (SELECT st_y(geom) FROM geometries WHERE id = 2) AS y2;
DELETE FROM geometries WHERE id = 1;
SELECT st_y(geom) FROM geometries ORDER BY st_y(geom);
SELECT avg(st_y(geom)) AS average_y FROM geometries WHERE st_y(geom) > -100 AND st_y(geom) < 100;