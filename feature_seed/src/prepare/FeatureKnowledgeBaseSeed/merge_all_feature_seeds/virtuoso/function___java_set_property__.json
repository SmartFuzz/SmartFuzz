CREATE CLASS TestClass AS (property1 STRING, property2 INT);
INSERT INTO TestClass VALUES ('initialValue', 42);
JAVA SET CLASS TestClass;
JAVA SET PROPERTY 'property1' TO 'newValue';
SELECT * FROM TestClass WHERE property1 = 'newValue';
JAVA SET CLASS TestClass;
JAVA SET PROPERTY 'property2' TO 100;
SELECT * FROM TestClass WHERE property2 = 100;
INSERT INTO TestClass VALUES ('anotherValue', 10);
JAVA SET CLASS TestClass;
JAVA SET PROPERTY 'property1' TO 'updatedValue' WHERE property2 = 10;
SELECT * FROM TestClass WHERE property1 = 'updatedValue' AND property2 = 10;
CREATE CLASS AnotherClass AS (propertyA STRING, propertyB FLOAT);
JAVA SET CLASS AnotherClass;
JAVA SET PROPERTY 'propertyA' TO 'staticValue';
SELECT * FROM AnotherClass WHERE propertyA = 'staticValue';
JAVA SET CLASS TestClass;
JAVA SET PROPERTY 'property1' TO 'finalValue' WHERE property2 = 42 AND property1 = 'initialValue';
SELECT * FROM TestClass WHERE property1 = 'finalValue' AND property2 = 42;