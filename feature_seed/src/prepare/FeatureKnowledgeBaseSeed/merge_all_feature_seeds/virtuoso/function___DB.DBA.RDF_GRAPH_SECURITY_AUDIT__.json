CREATE GRAPH <http://example.org/graph1>;
CREATE GRAPH <http://example.org/graph2>;
CREATE USER user1 IDENTIFIED BY 'password1';
CREATE USER user2 IDENTIFIED BY 'password2';
GRANT READ ON <http://example.org/graph1> TO user1;
GRANT WRITE ON <http://example.org/graph2> TO user2;
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/subject1> <http://example.org/predicate> <http://example.org/object1> } };
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/subject2> <http://example.org/predicate> <http://example.org/object2> } };
DB.DBA.RDF_GRAPH_SECURITY_AUDIT(1);
SELECT * FROM DB.DBA.RDF_GRAPH_SECURITY_AUDIT(1) WHERE user_id = 1;
SELECT user_name, graph_iri FROM DB.DBA.RDF_GRAPH_SECURITY_AUDIT(1) WHERE severity = 'ERROR';
CREATE VIEW security_audit_view AS SELECT user_name, message FROM DB.DBA.RDF_GRAPH_SECURITY_AUDIT(1) WHERE graph_iri IS NOT NULL;
SELECT * FROM security_audit_view WHERE user_name IN (SELECT user_name FROM users WHERE user_id > 0);
SELECT * FROM DB.DBA.RDF_GRAPH_SECURITY_AUDIT(1) ORDER BY severity DESC LIMIT 5;
DELETE FROM <http://example.org/graph1> WHERE <http://example.org/subject1> <http://example.org/predicate> <http://example.org/object1>;
DB.DBA.RDF_GRAPH_SECURITY_AUDIT(1) AND (SELECT COUNT(*) FROM <http://example.org/graph1>) > 0;