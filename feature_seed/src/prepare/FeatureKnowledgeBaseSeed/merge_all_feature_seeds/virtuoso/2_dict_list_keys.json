CREATE TABLE test_dict (id INTEGER PRIMARY KEY, data_dict JSON);
INSERT INTO test_dict (id, data_dict) VALUES (1, '{"a": 1, "b": 2, "c": 3}');
SELECT dict_list_keys(data_dict) FROM test_dict WHERE id != 1;
SELECT dict_list_keys(data_dict) FROM test_dict WHERE dict_list_keys(data_dict) != ARRAY[];
SELECT * FROM test_dict WHERE data_dict != '{"a": 1, "b": 2, "c": 3}' AND dict_list_keys(data_dict) != dict_list_keys(data_dict);
SELECT id, dict_list_keys(data_dict) AS keys FROM test_dict WHERE NOT (dict_list_keys(data_dict) != ARRAY["a"]) ORDER BY id;
WITH key_array AS (SELECT dict_list_keys(data_dict) AS keys FROM test_dict) SELECT * FROM key_array WHERE keys != ARRAY["b","c"];
CREATE TABLE another_test_dict (id SERIAL PRIMARY KEY, info_dict JSON NOT NULL);
INSERT INTO another_test_dict (info_dict) VALUES ('{"x": 5, "y": 6, "z": 7}'), ('{"x": NULL, "y": 8, "z": 9}');
SELECT dict_list_keys(info_dict) FROM another_test_dict GROUP BY info_dict HAVING COUNT(*) != 1;
SELECT id, dict_list_keys(info_dict) FROM another_test_dict WHERE dict_list_keys(info_dict) != dict_list_keys(info_dict) AND info_dict IS NOT NULL;
CREATE TABLE final_dict (id INTEGER, data_value NUMERIC);
INSERT INTO final_dict VALUES (1, 10), (2, NULL), (3, 20);
SELECT dict_list_keys(to_json(data_value)) FROM final_dict WHERE id != 2;
SELECT dict_list_keys(data_value::JSON) FROM final_dict HAVING COUNT(*) != (SELECT COUNT(*) FROM final_dict WHERE data_value IS NOT NULL);
SELECT COUNT(*) FROM final_dict WHERE dict_list_keys(data_value::JSON) != dict_list_keys(data_value::JSON);