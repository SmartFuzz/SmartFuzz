CREATE TABLE test_table (id INT, data VARCHAR(255));
INSERT INTO test_table (id, data) VALUES (1, 'test data');
INSERT INTO test_table (id, data) VALUES (2, 'sample text');
SELECT md5(data) FROM test_table WHERE id = 1;
SELECT md5(data) AS hash_value FROM test_table WHERE id = 2;
SELECT md5(CONCAT(data, 'additional string')) FROM test_table WHERE id = 1;
SELECT md5('') AS empty_string_hash;
SELECT md5(REPLACE(data, 'text', 'string')) FROM test_table WHERE id = 2;
SELECT DISTINCT md5(data) FROM test_table;
SELECT md5('long_string_1234567890_abcdefghijklmnopqrstuvwxyz');
SELECT md5((SELECT data FROM test_table WHERE id = 1)) AS subquery_hash;
SELECT md5(CONCAT((SELECT data FROM test_table WHERE id = 1), (SELECT data FROM test_table WHERE id = 2))) AS combined_hash;
SELECT md5('x' || LPAD(id::VARCHAR, 10, '0')) FROM test_table;
SELECT md5((SELECT GROUP_CONCAT(data) FROM test_table)) AS concatenated_hash;
SELECT md5(CONCAT('prefix_', data, '_suffix')) FROM test_table;
WITH md5_values AS (SELECT md5(data) AS hash_value FROM test_table) SELECT COUNT(*) FROM md5_values WHERE hash_value IS NOT NULL;