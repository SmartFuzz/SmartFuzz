CREATE TABLE local_table (id INT, name VARCHAR(255));
CREATE TABLE remote_table (id INT, name VARCHAR(255));
DECLARE vd_remote_data_source('my_remote_dsn');
SELECT vd_remote_table('local_table', 'remote_table', 'my_remote_dsn');
SELECT vd_remote_table('local_table', NULL, 'my_remote_dsn');
CREATE TABLE another_local_table (id INT, data VARCHAR(255));
SELECT vd_remote_table('another_local_table', 'another_remote_table', 'my_remote_dsn');
CREATE TABLE complex_local_table (id INT, name VARCHAR(255), remote_data_id INT);
INSERT INTO complex_local_table SELECT id, name, vd_remote_table('local_table', 'remote_table', 'my_remote_dsn') FROM local_table;
SELECT l.id, l.name, r.name FROM local_table l INNER JOIN vd_remote_table('local_table', 'remote_table', 'my_remote_dsn') r ON l.id = r.id;
SELECT * FROM vd_remote_table('local_table', 'remote_table', 'my_remote_dsn') WHERE id IN (SELECT id FROM another_local_table WHERE data = 'sample');
SELECT COUNT(*) FROM vd_remote_table('local_table', 'remote_table', 'my_remote_dsn') WHERE id > (SELECT AVG(id) FROM local_table);