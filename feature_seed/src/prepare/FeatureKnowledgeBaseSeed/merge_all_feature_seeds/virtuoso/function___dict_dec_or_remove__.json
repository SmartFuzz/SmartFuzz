CREATE TABLE test_dict (key VARCHAR(255) PRIMARY KEY, value INT);
INSERT INTO test_dict (key, value) VALUES ('counter1', 5);
INSERT INTO test_dict (key, value) VALUES ('counter2', 10);
UPDATE test_dict SET value = CASE WHEN value - 3 > 0 THEN value - 3 ELSE NULL END WHERE key = 'counter1';
SELECT * FROM test_dict WHERE key = 'counter1';
UPDATE test_dict SET value = CASE WHEN value - 10 > 0 THEN value - 10 ELSE NULL END WHERE key = 'counter2';
SELECT * FROM test_dict WHERE key = 'counter2';
UPDATE test_dict SET value = CASE WHEN value - 6 <= 0 THEN NULL ELSE value - 6 END WHERE key = 'counter1';
SELECT * FROM test_dict;
DELETE FROM test_dict WHERE key = 'counter1' AND value IS NULL;
SELECT * FROM test_dict;
UPDATE test_dict SET value = -1 WHERE key = 'counter2';
UPDATE test_dict SET value = CASE WHEN value < 0 THEN NULL ELSE value END WHERE key = 'counter2';
UPDATE test_dict SET value = CASE WHEN value NOT BETWEEN 0 AND 10 THEN NULL ELSE value END WHERE key = 'counter2';
SELECT * FROM test_dict;
UPDATE test_dict SET value = value - 2 WHERE key = 'counter3';
INSERT INTO test_dict (key, value) VALUES ('counter3', 7);
UPDATE test_dict SET value = CASE WHEN value < 0 THEN NULL ELSE value END WHERE key = 'counter3';
SELECT * FROM test_dict;
DELETE FROM test_dict WHERE key = 'nonexistent_key';
SELECT COUNT(*) FROM test_dict WHERE key = 'counter3';