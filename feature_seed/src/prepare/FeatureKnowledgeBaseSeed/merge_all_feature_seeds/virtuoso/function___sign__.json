CREATE TABLE numbers (id INT, value FLOAT);
INSERT INTO numbers (id, value) VALUES (1, -10.5);
INSERT INTO numbers (id, value) VALUES (2, 0);
INSERT INTO numbers (id, value) VALUES (3, 15.0);
INSERT INTO numbers (id, value) VALUES (4, 0.1);
INSERT INTO numbers (id, value) VALUES (5, -0.1);
SELECT id, value, sign(value) AS sign_value FROM numbers;
SELECT id, value, sign(value) AS sign_value FROM numbers WHERE sign(value) = 1;
SELECT id, value, sign(value) AS sign_value FROM numbers WHERE sign(value) IN (SELECT sign(value) FROM numbers WHERE value > 0);
SELECT n.id, n.value, s.sign_value FROM numbers n JOIN (SELECT id, value, sign(value) AS sign_value FROM numbers) s ON n.id = s.id WHERE s.sign_value = -1;
SELECT a.id, a.value AS positive_value, b.value AS negative_value FROM numbers a JOIN numbers b ON sign(a.value) = 1 AND sign(b.value) = -1;
SELECT value, sign(value) AS sign_value FROM (SELECT value FROM numbers WHERE value IS NOT NULL) AS filtered_values;
SELECT n.id, sign(n.value) AS sign_value, (SELECT COUNT(*) FROM numbers WHERE sign(value) = -1) AS negative_count FROM numbers n;