CREATE TABLE test_data (id INT PRIMARY KEY, value VARCHAR(50), xml_data XML);
INSERT INTO test_data (id, value, xml_data) VALUES (1, 'A', '<item><value>10</value></item>'), (2, NULL, '<item><value>20</value></item>'), (3, 'B', '<item><value>30</value></item>');
SELECT DB.DBA.VECTOR_OR_NULL_AGG((SELECT value FROM test_data WHERE value IS NOT NULL ORDER BY value)) AS vector_result;
SELECT DB.DBA.VECTOR_OR_NULL_AGG((SELECT xpath_string('//value', xml_data) FROM test_data WHERE value = 'A')) AS vector_from_xml;
SELECT DB.DBA.VECTOR_OR_NULL_AGG((SELECT DISTINCT value FROM test_data WHERE value IS NOT NULL)) AS unique_vector_result;
SELECT DB.DBA.VECTOR_OR_NULL_AGG(value) FROM (SELECT * FROM test_data WHERE xml_data IS NOT NULL UNION ALL SELECT NULL AS value) AS subquery;
SELECT DB.DBA.VECTOR_OR_NULL_AGG((SELECT value FROM test_data WHERE id IN (1, 2) ORDER BY value)) AS vector_edge_case;
SELECT DB.DBA.VECTOR_OR_NULL_AGG((SELECT xpath_string('//value', xml_data) FROM test_data WHERE xml_data IS NOT NULL AND xpath_string('//value', xml_data)::int > 15 GROUP BY xml_data) ORDER BY xml_data) AS filtered_vector;
SELECT DB.DBA.VECTOR_OR_NULL_AGG(value) FROM test_data GROUP BY value HAVING COUNT(*) > 1;
SELECT DB.DBA.VECTOR_OR_NULL_AGG((SELECT xpath_string('//value', xml_data) FROM test_data WHERE xpath_string('//value', xml_data) IS NOT NULL AND LENGTH(xpath_string('//value', xml_data)) < 10)) AS small_vector;