CREATE TABLE key_mapping_test (id INT PRIMARY KEY, value VARCHAR(255), mapping_key VARCHAR(50));
INSERT INTO key_mapping_test (id, value, mapping_key) VALUES (1, 'Test Value', NULL), (2, NULL, 'Key 2'), (3, 'Another Value', 'Key 3');
SELECT id, value FROM key_mapping_test WHERE EXISTS (SELECT 1 FROM key_mapping_test WHERE mapping_key IS NULL AND id = key_mapping_test.id);
SELECT EXISTS (SELECT 1 FROM key_mapping_test WHERE LENGTH(value) > 10);
SELECT id, COUNT(*) OVER (PARTITION BY value) AS mapping_count FROM key_mapping_test WHERE EXISTS (SELECT 1 FROM key_mapping_test WHERE value IS NOT NULL AND mapping_key = 'Key 2');
SELECT id, value, (SELECT COUNT(*) FROM key_mapping_test WHERE mapping_key = key_mapping_test.mapping_key) AS key_count FROM key_mapping_test WHERE EXISTS (SELECT 1 FROM key_mapping_test WHERE id = 1) HAVING key_count > 1;
SELECT id, value FROM key_mapping_test WHERE EXISTS (SELECT 1 FROM key_mapping_test t WHERE t.mapping_key IS NOT NULL AND t.value = key_mapping_test.value) OR value IS NULL;
CREATE TABLE secondary_test (sec_id INT, sec_value VARCHAR(255) NOT NULL DEFAULT 'default');
INSERT INTO secondary_test (sec_id, sec_value) VALUES (1, 'Relational Test'), (2, NULL), (3, 'Check Value');
SELECT sec_id, sec_value FROM secondary_test WHERE EXISTS (SELECT 1 FROM key_mapping_test WHERE id = sec_id) AND (sec_value = 'default' OR sec_value IS NULL);
SELECT COUNT(*) AS total_mapping FROM (SELECT value, EXISTS (SELECT 1 FROM key_mapping_test WHERE mapping_key = value) AS exists_mapping FROM key_mapping_test) AS subquery GROUP BY value HAVING total_mapping > 0;