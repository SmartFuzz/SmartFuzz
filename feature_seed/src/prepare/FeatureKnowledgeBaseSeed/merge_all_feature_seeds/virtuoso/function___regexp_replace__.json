CREATE TABLE test_strings (id INT, source_string VARCHAR);
INSERT INTO test_strings VALUES (1, 'This is    a test.'), (2, 'Multiple   spaces    here.'), (3, 'Single space here.');
SELECT REGEXP_REPLACE(source_string, '( ){2,}', ' ') AS cleaned_string FROM test_strings;
SELECT REGEXP_REPLACE(source_string, '(\s+)', ' ') AS cleaned_string FROM test_strings WHERE id = 1;
SELECT REGEXP_REPLACE(source_string, '([a-zA-Z]+)(\s+)([a-zA-Z]+)', '$1 $3') AS reformatted_string FROM test_strings;
SELECT id, REGEXP_REPLACE(source_string, '( ){2,}', ' ') AS cleaned_string FROM test_strings WHERE source_string LIKE '%  %';
SELECT id, REGEXP_REPLACE(source_string, '( ){2,}', ' ') AS cleaned FROM (SELECT * FROM test_strings) AS subquery;
SELECT t1.source_string, REGEXP_REPLACE(t2.source_string, '( ){2,}', ' ') AS cleaned_string FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.id = t2.id WHERE t1.id = 2;
CREATE TABLE additional_strings (id INT, source_string VARCHAR);
INSERT INTO additional_strings VALUES (1, 'This is    another test.'), (2, 'Another     example   here.');
SELECT a.id, REGEXP_REPLACE(a.source_string, '( ){2,}', ' ') AS cleaned_string, b.source_string AS comparison_string FROM test_strings AS a JOIN additional_strings AS b ON a.id = b.id;
SELECT REGEXP_REPLACE(t.source_string, '(\s+)', ' ') AS cleaned_string FROM (SELECT source_string FROM test_strings UNION SELECT source_string FROM additional_strings) AS t;
SELECT id, REGEXP_REPLACE(source_string, '( ){2,}', ' ') AS cleaned_string FROM test_strings WHERE LENGTH(source_string) > 15;
SELECT REGEXP_REPLACE(source_string, '\s{2,}', ' ') AS cleaned_string, LENGTH(source_string) AS original_length FROM test_strings;