CREATE TABLE websites (id INT PRIMARY KEY, url VARCHAR(255), path VARCHAR(255), status INT);
CREATE TABLE retrieval_logs (log_id INT PRIMARY KEY, website_id INT, retrieval_time TIMESTAMP, FOREIGN KEY (website_id) REFERENCES websites(id));
