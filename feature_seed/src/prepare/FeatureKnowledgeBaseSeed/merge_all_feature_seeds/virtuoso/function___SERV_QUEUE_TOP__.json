SELECT url FROM websites WHERE status = 0 AND id IN (SELECT website_id FROM retrieval_logs WHERE retrieval_time > NOW() - INTERVAL '1 DAY');
SELECT w.url, l.retrieval_time FROM websites w JOIN retrieval_logs l ON w.id = l.website_id WHERE l.retrieval_time < NOW() - INTERVAL '1 HOUR';
DELETE FROM retrieval_logs WHERE retrieval_time < NOW() - INTERVAL '30 DAY';
SELECT COUNT(*) FROM websites WHERE status = 0;
