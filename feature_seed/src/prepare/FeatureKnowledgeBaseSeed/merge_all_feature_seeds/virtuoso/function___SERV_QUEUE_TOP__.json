WITH recent_retrievals AS (SELECT website_id FROM retrieval_logs WHERE retrieval_time > NOW() - INTERVAL '1 HOUR') SELECT w.url FROM websites w WHERE w.id IN (SELECT website_id FROM recent_retrievals);
CREATE INDEX idx_website_status ON websites(status);