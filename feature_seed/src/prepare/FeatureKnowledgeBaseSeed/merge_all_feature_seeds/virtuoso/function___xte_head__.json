CREATE TABLE test_xml (id INT PRIMARY KEY, xml_data XML);
INSERT INTO test_xml (id, xml_data) VALUES (1, xte_head('example', 'attr1', 'value1', 'attr2', 'value2'));
INSERT INTO test_xml (id, xml_data) VALUES (2, xte_head('example', 'attr1', 'value1', 'attr1', 'value2'));
INSERT INTO test_xml (id, xml_data) VALUES (3, xte_head('test', 'attrA', 'valueA', 'attrB', 'valueB', 'attrC', 'valueC'));
SELECT xml_data FROM test_xml WHERE xml_data = xte_head('example', 'attr1', 'value1');
SELECT xml_data FROM test_xml WHERE xml_data = xte_head('test', 'attrA', 'valueA', 'attrB', 'valueB');
SELECT xml_data FROM test_xml WHERE xml_data = xte_head('nested', 'outerAttr', 'outerValue', 'innerAttr', 'innerValue', 'duplicateAttr', 'firstValue', 'duplicateAttr', 'lastValue');
SELECT xml_data FROM test_xml WHERE id IN (SELECT id FROM test_xml WHERE xml_data LIKE xte_head('example', 'attr1', 'value%'));
SELECT xml_data FROM test_xml t1 JOIN test_xml t2 ON t1.id = t2.id WHERE t1.xml_data = xte_head('join', 'attrJoin', 'joinValue1') AND t2.xml_data = xte_head('join', 'attrJoin', 'joinValue2');
DELETE FROM test_xml WHERE xml_data = xte_head('example', 'attr1', 'value1');