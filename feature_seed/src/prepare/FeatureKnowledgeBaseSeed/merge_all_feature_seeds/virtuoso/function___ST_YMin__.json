CREATE GRAPH <http://geo-api-demo/>;
INSERT DATA { GRAPH <http://geo-api-demo/> { <point2d> <shape> "POINT(1 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <point4d> <shape> "POINTZM(0 1 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <box1> <shape> "BOX(0 0, 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <linestring> <shape> "LINESTRING(10 21, 12 23, 10 25)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <polygon1> <shape> "POLYGON((1 3,2 4,1 5,0 4,1 3))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <polygon2> <shape> "POLYGON((1.5 3.5,2.5 4.5,1.5 5.5,0.5 4.5,1.5 3.5))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <polygon3> <shape> "POLYGON((1 3,2 4,1 5,0 4,1 3),(1 3.5,1.5 4,1 4.5,0.5 4,1 3.5))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <multipolygon> <shape> "MULTIPOLYGON(((1 3,2 4,1 5,0 4,1 3)),((1 2,2 1,1 0,0 1,1 2)))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
INSERT DATA { GRAPH <http://geo-api-demo/> { <collection> <shape> "GEOMETRYCOLLECTION(POINT(0 0),MULTILINESTRING((1 5,0 1,4 0,5 4),(1 5,1 0,4 0,4 5)),MULTIPOLYGON(((1 3,2 4,1 5,0 4,1 3)),((1 2,2 1,1 0,0 1,1 2))))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . } };
SELECT ?s, bif:st_ymin(?o) as ?ymin FROM <http://geo-api-demo/> WHERE { ?s ?p ?o . };
SELECT ?s, bif:st_ymin(?o) as ?ymin FROM <http://geo-api-demo/> WHERE { ?s a <http://www.openlinksw.com/schemas/virtrdf#Geometry> . ?s ?p ?o . };
SELECT ?s, bif:st_ymin(?o) as ?ymin FROM <http://geo-api-demo/> WHERE { SELECT ?s ?o WHERE { ?s ?p ?o FILTER (bif:st_ymin(?o) > 0) } };
SELECT ?s, bif:st_ymin(?o) as ?ymin FROM <http://geo-api-demo/> WHERE { ?s ?p ?o FILTER (bif:st_ymin(?o) < 5) } GROUP BY ?s;