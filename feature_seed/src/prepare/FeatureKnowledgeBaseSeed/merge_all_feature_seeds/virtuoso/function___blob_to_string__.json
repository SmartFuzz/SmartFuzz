CREATE TABLE Categories (ID INT PRIMARY KEY, Description LONG VARBINARY);
INSERT INTO Categories (ID, Description) VALUES (1, CAST('Soft drinks, coffees, teas, beers, and ales' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (2, CAST('Sweet and savory sauces, relishes, spreads, and seasonings' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (3, CAST('Desserts, candies, and sweet breads' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (4, CAST('Cheeses' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (5, CAST('Breads, crackers, pasta, and cereal' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (6, CAST('Prepared meats' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (7, CAST('Dried fruit and bean curd' AS LONG VARBINARY));
INSERT INTO Categories (ID, Description) VALUES (8, CAST('Seaweed and fish' AS LONG VARBINARY));
SELECT blob_to_string(Description) FROM Categories WHERE ID = 1;
SELECT blob_to_string(Description) FROM Categories WHERE ID IN (2, 3);
SELECT blob_to_string(Description) FROM Categories WHERE ID IN (SELECT ID FROM Categories WHERE ID > 4);
SELECT b.ID, blob_to_string(b.Description) FROM Categories AS b JOIN (SELECT ID FROM Categories WHERE ID <= 4) AS a ON a.ID = b.ID;
SELECT CONCAT('Category: ', blob_to_string(Description)) AS FullDescription FROM Categories WHERE ID = 5;
SELECT DISTINCT blob_to_string(Description) FROM Categories;
SELECT COUNT(*) FROM (SELECT DISTINCT blob_to_string(Description) FROM Categories) AS distinct_descriptions;