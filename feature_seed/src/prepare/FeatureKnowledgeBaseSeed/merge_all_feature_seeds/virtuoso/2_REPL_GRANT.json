CREATE TABLE publications (id SERIAL PRIMARY KEY, name VARCHAR(255), data JSON);
INSERT INTO publications (name, data) VALUES ('table_publication', '{"key1":"value1", "key2":[1, 2, 3]}');
CREATE TABLE subscriptions (id SERIAL PRIMARY KEY, publication_id INT REFERENCES publications(id), account_name VARCHAR(255));
INSERT INTO subscriptions (publication_id, account_name) VALUES (1, 'demo');
SELECT REPL_GRANT('table_publication', (SELECT account_name FROM subscriptions WHERE publication_id = 1));
SELECT name, JSON_ARRAY_LENGTH(data) AS key_count FROM publications WHERE JSON_ARRAY_LENGTH(data) > 0;
SELECT pub.name, sub.account_name FROM publications pub JOIN subscriptions sub ON pub.id = sub.publication_id WHERE JSON_ARRAY_LENGTH(pub.data) > 0;
SELECT account_name, COUNT(*) OVER (PARTITION BY account_name) AS total_subscriptions FROM subscriptions GROUP BY account_name HAVING total_subscriptions > 1;
SELECT REPL_GRANT('table_publication', (SELECT NULLIF(account_name, '') FROM subscriptions WHERE publication_id = 1));
SELECT pub.name FROM publications pub WHERE EXISTS (SELECT 1 FROM subscriptions sub WHERE sub.publication_id = pub.id AND sub.account_name = 'demo') OR NOT EXISTS (SELECT 1 FROM subscriptions sub WHERE sub.publication_id = pub.id);
SELECT name, REPL_GRANT('table_publication', (SELECT account_name FROM subscriptions WHERE account_name IS NULL)) FROM publications WHERE id = (SELECT MAX(id) FROM publications);
INSERT INTO subscriptions (publication_id, account_name) VALUES (1, CAST(NULL AS VARCHAR));
SELECT REPL_GRANT('table_publication', (SELECT account_name FROM subscriptions WHERE account_name = 'N/A') LIMIT 1);