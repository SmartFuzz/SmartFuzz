CREATE TABLE Orders (OrderID INT, ShippedDate DATETIME);
INSERT INTO Orders (OrderID, ShippedDate) VALUES (1, '1996-06-04 12:30:00'), (2, '1996-06-05 15:45:30'), (3, '1996-06-06 18:20:20');
SELECT datestring(ShippedDate) FROM Orders WHERE OrderID = 1;
SELECT left(datestring(ShippedDate), 10) FROM Orders WHERE ShippedDate > stringdate('1996.06.01');
SELECT OrderID, datestring(ShippedDate) AS FormattedDate FROM Orders WHERE ShippedDate BETWEEN '1996-06-04' AND '1996-06-06';
SELECT OrderID, datestring(ShippedDate) AS FormattedDate FROM Orders WHERE OrderID IN (SELECT OrderID FROM Orders WHERE ShippedDate < '1996-06-05');
SELECT datestring_gmt(ShippedDate) FROM Orders WHERE ShippedDate IS NOT NULL;
SELECT datestring(now()) AS CurrentTime;
SELECT left(datestring(now()), 10) AS CurrentDate;
SELECT OrderID, datestring(ShippedDate) FROM Orders ORDER BY ShippedDate DESC LIMIT 2;
SELECT COUNT(*) FROM Orders WHERE datestring(ShippedDate) LIKE '1996-06%';
SELECT DISTINCT datestring(GREATEST(ShippedDate, '1996-06-03 00:00:00')) AS LatestShipping FROM Orders;