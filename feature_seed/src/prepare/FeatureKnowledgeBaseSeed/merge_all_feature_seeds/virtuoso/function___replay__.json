CREATE TABLE transactions (id INT PRIMARY KEY, log_message TEXT, timestamp TIMESTAMP);
INSERT INTO transactions VALUES (1, 'Transaction started', NOW());
CREATE TABLE backups (id INT PRIMARY KEY, backup_file TEXT, created_at TIMESTAMP);
INSERT INTO backups VALUES (1, 'bak.log', NOW());
INSERT INTO backups VALUES (2, 'new.log', NOW());
REPLAY ('bak.log');
INSERT INTO transactions VALUES (2, 'Transaction finished', NOW());
REPLAY ('new.log');
SELECT * FROM transactions WHERE id IN (SELECT id FROM backups WHERE created_at > NOW() - INTERVAL '1 DAY');
SELECT b.backup_file FROM backups b JOIN transactions t ON b.id = t.id WHERE t.timestamp < NOW() - INTERVAL '2 HOURS';
REPLAY ('new2.log');
SELECT COUNT(*) FROM transactions WHERE id > (SELECT MAX(id) FROM transactions WHERE DATEDIFF(NOW(), timestamp) < 1);
CREATE INDEX idx_log_message ON transactions(log_message);
SELECT DISTINCT log_message FROM transactions WHERE log_message LIKE '%Transaction%';
REPLAY ('bak.log');
REPLAY ('new.log');
CREATE TABLE temp_logs (id SERIAL PRIMARY KEY, log_details TEXT);
INSERT INTO temp_logs (log_details) SELECT log_message FROM transactions WHERE timestamp > NOW() - INTERVAL '30 DAYS';
DROP TABLE IF EXISTS temp_logs;