CREATE TABLE Products (ID INT PRIMARY KEY, Description LONG VARCHAR, Price DECIMAL(10, 2), CreationDate TIMESTAMP);
INSERT INTO Products (ID, Description, Price, CreationDate) VALUES (1, 'Test Product 1', 10.00, '2023-01-01 00:00:00');
INSERT INTO Products (ID, Description, Price, CreationDate) VALUES (2, 'Test Product 2', NULL, '2023-01-01 00:00:00');
INSERT INTO Products (ID, Description, Price, CreationDate) VALUES (3, 'Test Product 3', 5.00, '2023-01-01 00:00:00');
SELECT blob_to_string(Description) FROM (SELECT Description FROM Products WHERE Price / 2 < 3) AS filtered;
SELECT blob_to_string(Description) FROM Products WHERE Price IS NOT NULL AND (Price / NULLIF(Price, 0)) > 1;
SELECT COUNT(*) FROM Products WHERE blob_to_string(Description) LIKE '%Product%' GROUP BY CreationDate HAVING COUNT(*) > 1;
SELECT blob_to_string(Description), (SELECT AVG(Price) / NULLIF(AVG(Price), 0) FROM Products) AS avg_price_ratio FROM Products;
SELECT ID, blob_to_string(Description) FROM Products WHERE id IN (SELECT ID / 2 FROM Products) ORDER BY CreationDate;
SELECT AVG(Price) AS avg_price, blob_to_string(Description) FROM Products GROUP BY blob_to_string(Description) HAVING avg_price > 10;