SELECT TOP 10 * FROM article ORDER BY pub_date DESC;
SELECT TOP 5 PERCENT id, title FROM article ORDER BY pub_date ASC;
SELECT TOP 3 id, title FROM (SELECT id, title FROM article WHERE pub_date >= '2023-03-01') AS subquery ORDER BY pub_date DESC;
SELECT a.id, a.title FROM article AS a JOIN (SELECT TOP 5 id FROM article ORDER BY pub_date DESC) AS top_articles ON a.id = top_articles.id;
SELECT id, title FROM article WHERE id IN (SELECT TOP 5 id FROM article ORDER BY pub_date DESC) ORDER BY pub_date ASC;
SELECT TOP 2 * FROM (SELECT id, title FROM article WHERE title LIKE 'Article%') AS filtered_articles ORDER BY pub_date DESC;
SELECT TOP 100 PERCENT id, title FROM article ORDER BY pub_date ASC;
SELECT COUNT(*) FROM (SELECT TOP 10 * FROM article ORDER BY pub_date DESC) AS temp;
SELECT TOP 1 title FROM (SELECT TOP 5 title FROM article ORDER BY pub_date DESC) AS recent_titles ORDER BY title ASC;