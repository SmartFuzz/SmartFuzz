CREATE TABLE test_data (id INT PRIMARY KEY, data TEXT, geo GEOMETRY);
INSERT INTO test_data (id, data, geo) VALUES (1, 'sample data', ST_GeomFromText('POINT(1 1)')), (2, 'another example', ST_GeomFromText('POINT(2 2)'));
SELECT id, encrypt(data, 'kaes') as encrypted_data FROM test_data WHERE bif:st_overlaps(geo, ST_GeomFromText('POLYGON((0 0, 0 3, 3 3, 3 0, 0 0))')) = TRUE;
SELECT id, encrypt(data, 'kaes') as encrypted_data FROM test_data WHERE bif:st_overlaps(geo, ST_GeomFromText('POLYGON((2 2, 2 4, 4 4, 4 2, 2 2))')) AND data IS NOT NULL;
SELECT COUNT(*) FROM (SELECT id, encrypt(data, 'kaes') AS encrypted_data FROM test_data WHERE data IS NOT NULL) AS encrypted_data_count;
SELECT id, COUNT(*) OVER() AS total_count FROM test_data WHERE encrypt(data, 'kaes') IS NOT NULL GROUP BY id HAVING COUNT(*) > 1;
UPDATE test_data SET data = encrypt(data, 'kaes') WHERE id IN (SELECT id FROM test_data WHERE bif:st_overlaps(geo, ST_GeomFromText('POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))')));
SELECT id, encrypt(NULLIF(data, ''), 'kaes') AS encrypted_data FROM test_data WHERE data IS NOT NULL OR bif:st_overlaps(geo, ST_GeomFromText('POLYGON((1 1, 1 3, 3 3, 3 1, 1 1))'));
SELECT id FROM test_data WHERE bif:st_overlaps(geo, ST_GeomFromText('POLYGON((1 1, 1 2, 2 2, 2 1, 1 1))')) AND data = encrypt(data, 'kaes') LIMIT 1;
INSERT INTO test_data (id, data, geo) VALUES (3, '', ST_GeomFromText('POINT(3 3)'));