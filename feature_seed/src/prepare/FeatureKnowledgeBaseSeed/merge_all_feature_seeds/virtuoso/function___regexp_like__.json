CREATE TABLE demo.demo.customers (postalcode VARCHAR2(20));
INSERT INTO demo.demo.customers (postalcode) VALUES ('WA1 1DP');
INSERT INTO demo.demo.customers (postalcode) VALUES ('S-958 22');
INSERT INTO demo.demo.customers (postalcode) VALUES ('T2F 8M4');
INSERT INTO demo.demo.customers (postalcode) VALUES ('EC2 5NT');
INSERT INTO demo.demo.customers (postalcode) VALUES ('05432-043');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '^[A-Z]{2}[0-9]{1} [0-9]{2}[A-Z]{2}$');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '^[A-Z]{2}[0-9]{1,2}[0-9A-Z]? [0-9]{1,2}[A-Z]{2}$');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '\d{5}(-\d{4})?');
SELECT DISTINCT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '^[A-Z]{1,2}\d{1,2}[A-Z]? \d[A-Z]{2}$');
SELECT c1.postalcode FROM demo.demo.customers c1 INNER JOIN demo.demo.customers c2 ON c1.postalcode != c2.postalcode WHERE REGEXP_LIKE(c1.postalcode, '^[A-Z]{2}');
SELECT postalcode FROM (SELECT postalcode FROM demo.demo.customers WHERE postalcode IS NOT NULL) WHERE REGEXP_LIKE(postalcode, '[^[:digit:]]');
SELECT COUNT(*) FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '^[A-Z0-9]{3,5}[-\s]?[A-Z0-9]{3,5}$');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '^[0-9]{5}$') OR REGEXP_LIKE(postalcode, '^\d{5}-\d{4}$');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '(?i)^[a-z]*$');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '\s');
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '^[A-Z]{1}[0-9]{1}[A-Z]{1} \d{1}[A-Z]{2}$') AND LENGTH(postalcode) = 7;
SELECT postalcode FROM demo.demo.customers WHERE REGEXP_LIKE(postalcode, '(.{5})') AND LENGTH(postalcode) = 6;