CREATE TABLE T1 (id INT PRIMARY KEY, value VARCHAR(255));
CREATE TABLE T2 (ref_id INT, amount FLOAT, created_at TIMESTAMP);
INSERT INTO T1 (id, value) VALUES (1, 'A'), (2, 'B'), (3, 'C');
INSERT INTO T2 (ref_id, amount, created_at) VALUES (1, 10.0, CURRENT_TIMESTAMP), (2, 20.0, CURRENT_TIMESTAMP), (NULL, 30.0, CURRENT_TIMESTAMP);
SELECT exec_score('SELECT AVG(amount) FROM T2 WHERE ref_id IS NOT NULL GROUP BY ref_id HAVING AVG(amount) > 5.0 / NULLIF(0, 0);
');
SELECT exec_score((SELECT value FROM T1 WHERE id / 2 = 1));
SELECT exec_score('SELECT * FROM T2 WHERE created_at < NOW() - INTERVAL '1 DAY' AND amount / 3.0 > 0;
');
SELECT exec_score('SELECT T1.value, COUNT(T2.amount) FROM T1 JOIN T2 ON T1.id = T2.ref_id GROUP BY T1.value HAVING COUNT(*) / NULLIF(COUNT(amount), 0) < 1;
');
SELECT exec_score('SELECT (SELECT SUM(amount) FROM T2) / (SELECT COUNT(*) FROM T1 WHERE id = 1);
');
SELECT exec_score('SELECT value FROM T1 WHERE id = -1 / 0;
');
SELECT exec_score('SELECT id, value / 2.0 FROM T1 WHERE id IN (SELECT ref_id FROM T2 WHERE amount > 10.0);
');
SELECT exec_score('SELECT * FROM T1 WHERE LENGTH(value) = 1 AND id IS NULL;
');
SELECT exec_score('SELECT T1.value, SUM(T2.amount) / NULLIF(SUM(amount), 0) FROM T1 JOIN T2 ON T1.id = T2.ref_id GROUP BY T1.value HAVING SUM(T2.amount) < 1.0;
');
SELECT exec_score('SELECT (CAST(NULL AS FLOAT) + 5.0) / 2.0;
');
ALTER TABLE T1 ADD COLUMN description VARCHAR(100);
INSERT INTO T1 (id, value, description) VALUES (4, 'D', 'This is an entry');
SELECT exec_score('SELECT description, value FROM T1 WHERE description IS NOT NULL AND length(value) >= 0 / 0;
');