CREATE TABLE keys (id INT PRIMARY KEY, key_data VARCHAR);
INSERT INTO keys (id, key_data) VALUES (1, 'ServerPrivate.pfx'), (2, 'ServerPublic.pem');
SELECT xenc_key_serialize('ServerPrivate.pfx', 1) AS private_key, xenc_key_serialize('ServerPublic.pem', 0) AS public_key FROM keys WHERE id = 1;
SELECT xenc_key_serialize('ServerPrivate.pfx', 1) FROM (SELECT * FROM keys WHERE id = 1) AS subquery;
SELECT COUNT(*) FROM keys WHERE key_data LIKE '%.pfx';
SELECT xenc_key_serialize(key_data, CASE WHEN id = 1 THEN 1 ELSE 0 END) FROM keys;
SELECT DISTINCT xenc_key_serialize('ServerPrivate.pfx', 1) FROM keys WHERE id IN (SELECT id FROM keys WHERE key_data LIKE '%.pem');
WITH key_selection AS (SELECT key_data FROM keys WHERE id = 2) SELECT xenc_key_serialize((SELECT key_data FROM key_selection), 0);
SELECT xenc_key_serialize('NonExistentFile.key', 1) AS key_data WHERE NOT EXISTS (SELECT * FROM keys WHERE key_data = 'NonExistentFile.key');
SELECT xenc_key_serialize('ServerPrivate.pfx', 1) FROM keys ORDER BY id DESC LIMIT 1;