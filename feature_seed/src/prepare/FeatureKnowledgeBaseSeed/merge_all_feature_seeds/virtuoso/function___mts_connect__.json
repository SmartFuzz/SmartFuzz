CREATE TABLE test_table (id INT PRIMARY KEY, description VARCHAR(255));
INSERT INTO test_table (id, description) VALUES (1, 'Test description 1');
INSERT INTO test_table (id, description) VALUES (2, 'Test description 2');
INSERT INTO test_table (id, description) VALUES (3, 'Test description 3');
SELECT * FROM test_table WHERE id = 1;
SELECT * FROM test_table WHERE description LIKE 'Test%';
SELECT (SELECT COUNT(*) FROM test_table) AS total_count;
SELECT id, (SELECT COUNT(*) FROM test_table WHERE id = test_table.id) FROM test_table;
SELECT t1.id, t2.description FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.id < 3;
SELECT t1.id, (SELECT COUNT(*) FROM test_table WHERE id = t1.id) AS count FROM test_table t1 WHERE id IN (SELECT id FROM test_table WHERE description LIKE 'Test%');
CREATE TABLE test_table_2 (id INT PRIMARY KEY, ref_id INT, FOREIGN KEY (ref_id) REFERENCES test_table(id));
INSERT INTO test_table_2 (id, ref_id) VALUES (1, 1);
INSERT INTO test_table_2 (id, ref_id) VALUES (2, 2);
INSERT INTO test_table_2 (id, ref_id) VALUES (3, 3);
SELECT t1.id, t2.description FROM test_table_2 t1 JOIN test_table t2 ON t1.ref_id = t2.id WHERE t1.id IN (SELECT id FROM test_table WHERE id < 3);
SELECT COUNT(*) FROM test_table WHERE description IS NOT NULL;
SELECT DISTINCT description FROM test_table WHERE description IS NOT NULL;