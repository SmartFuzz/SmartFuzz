CREATE TABLE test_data (id INT PRIMARY KEY, name VARCHAR(50), info XML, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_data (id, name, info) VALUES (1, 'Sample', '<root><value>100</value></root>');
INSERT INTO test_data (id, name, info) VALUES (2, 'Another Sample', '<root><value>200</value></root>');
SELECT DB.DBA.SPARQL_REXEC_TO_ARRAY(SELECT xpath_integer(info, '/root/value') FROM test_data WHERE id = 1) AS results;
SELECT DB.DBA.SPARQL_REXEC_TO_ARRAY((SELECT xpath_integer(info, '/root/value') FROM test_data WHERE name IS NOT NULL GROUP BY name HAVING COUNT(*) > 0)) AS array_result;
SELECT x.val FROM (SELECT DB.DBA.SPARQL_REXEC_TO_ARRAY((SELECT xpath_integer(info, '/root/value') FROM test_data WHERE id > 0)) AS vals) x(val);
SELECT COUNT(*) FROM (SELECT DB.DBA.SPARQL_REXEC_TO_ARRAY(SELECT xpath_integer(info, '/root/value') FROM test_data WHERE created_at IS NULL OR created_at < NOW() - INTERVAL '1 DAY') AS vals) temp;
CREATE TABLE temp_data (value INT);
INSERT INTO temp_data (value) VALUES (NULL), (50), (100);
SELECT DB.DBA.SPARQL_REXEC_TO_ARRAY(SELECT x.value FROM (SELECT xpath_integer('<root><value>200</value></root>', '/root/value') AS value) x WHERE value IS NOT NULL) AS values_array;
SELECT * FROM test_data JOIN temp_data ON xpath_integer(info, '/root/value') = temp_data.value;