CREATE TYPE SER_UDT AS (A INTEGER, B VARCHAR(100));
CREATE TABLE udt_instance_table (id INTEGER PRIMARY KEY, instance SER_UDT);
INSERT INTO udt_instance_table (id, instance) VALUES (1, new SER_UDT(42, 'Test'));
INSERT INTO udt_instance_table (id, instance) VALUES (2, new SER_UDT(100, 'Another Test'));
SELECT udt_get(instance, 'A') FROM udt_instance_table WHERE id = 1;
SELECT udt_get(instance, 'B') FROM udt_instance_table WHERE id = 2;
SELECT (SELECT udt_get(instance, 'A') FROM udt_instance_table WHERE id = 1) AS A_val;
SELECT (SELECT udt_get(instance, 'B') FROM udt_instance_table WHERE id = 2) AS B_val;
SELECT udt_get(instance, 'A') FROM udt_instance_table WHERE id = (SELECT MAX(id) FROM udt_instance_table);
SELECT udt_get(instance, 'A') FROM udt_instance_table WHERE id IN (1, 2);