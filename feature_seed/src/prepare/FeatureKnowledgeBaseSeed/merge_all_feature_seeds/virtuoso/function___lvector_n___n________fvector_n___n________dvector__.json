CREATE TABLE test_lvector (value LONG);
INSERT INTO test_lvector (value) VALUES (0);
INSERT INTO test_lvector (value) VALUES (1);
INSERT INTO test_lvector (value) VALUES (9223372036854775807);
INSERT INTO test_lvector (value) VALUES (-9223372036854775808);
SELECT lvector(value) FROM test_lvector;
CREATE TABLE test_fvector (value FLOAT);
INSERT INTO test_fvector (value) VALUES (0.0);
INSERT INTO test_fvector (value) VALUES (1.1);
INSERT INTO test_fvector (value) VALUES (3.4028235E38);
INSERT INTO test_fvector (value) VALUES (-3.4028235E38);
SELECT fvector(value) FROM test_fvector;
CREATE TABLE test_dvector (value DOUBLE);
INSERT INTO test_dvector (value) VALUES (0.0);
INSERT INTO test_dvector (value) VALUES (1.1);
INSERT INTO test_dvector (value) VALUES (1.7976931348623157E308);
INSERT INTO test_dvector (value) VALUES (-1.7976931348623157E308);
SELECT dvector(value) FROM test_dvector;
SELECT lvector(value) FROM test_lvector WHERE value > (SELECT AVG(value) FROM test_lvector);
SELECT fvector(value) FROM test_fvector WHERE value IN (SELECT DISTINCT value FROM test_fvector WHERE value < 2.0);
SELECT dvector(value) FROM test_dvector WHERE value BETWEEN (SELECT MIN(value) FROM test_dvector) AND (SELECT MAX(value) FROM test_dvector);
INSERT INTO test_lvector (value) SELECT value FROM (SELECT value FROM test_fvector) AS derived_table;
SELECT lvector(l.value) FROM test_lvector l JOIN test_fvector f ON l.value = CAST(f.value AS LONG);