CREATE GRAPH <http://example.org/graph1>;
CREATE GRAPH <http://example.org/graph2>;
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/node1> <http://example.org/property> <http://example.org/value1> . }};
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/node2> <http://example.org/property> <http://example.org/value2> . }};
SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . }};
SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/graph2> { ?s ?p ?o . }};
SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s <http://example.org/property> ?o . }} UNION SELECT ?s WHERE { GRAPH <http://example.org/graph2> { ?s <http://example.org/property> ?o . }};
SELECT ?s WHERE { ?s <http://example.org/property> ?o . FILTER(?o = <http://example.org/value1>) } INTERSECT SELECT ?s WHERE { ?s <http://example.org/property> ?o . FILTER(?o = <http://example.org/value2>) };
CALL DB.DBA.RDF_SUO_DIFF_TTL('<http://example.org/graph1>', '<http://example.org/graph2>') AS ?diff;
INSERT { GRAPH <http://example.org/graph_diff> { ?node <http://example.org/diffProperty> ?diff . }} WHERE { CALL DB.DBA.RDF_SUO_DIFF_TTL('<http://example.org/graph1>', '<http://example.org/graph2>') AS ?diff . BIND(<http://example.org/node1> AS ?node) . };
SELECT ?a ?b WHERE { { SELECT ?x ?y WHERE { GRAPH <http://example.org/graph1> { ?x ?y ?z . }} } UNION { SELECT ?x ?y WHERE { GRAPH <http://example.org/graph2> { ?x ?y ?z . }} } } GROUP BY ?a ?b;