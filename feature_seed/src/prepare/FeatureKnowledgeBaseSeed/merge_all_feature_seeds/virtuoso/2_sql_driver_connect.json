CREATE TABLE test_scores (id INT, content TEXT, score FLOAT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_scores (id, content, score) VALUES (1, 'Sample text for testing', 0.75), (2, NULL, 1.5), (3, 'Another sample', NULL), (4, '', 0.1);
SELECT id, content, bif:score(content) AS score FROM test_scores WHERE score IS NULL OR content IS NOT NULL;
SELECT id, score FROM (SELECT id, bif:score(content) AS score FROM test_scores WHERE content IS NOT NULL) AS subquery HAVING score > 0.5;
SELECT A.id, A.content, A.score FROM test_scores AS A JOIN (SELECT id, score FROM test_scores WHERE score IS NOT NULL) AS B ON A.id = B.id WHERE A.score < 1.0;
SELECT A.id, A.content, bif:score(A.content) FROM test_scores AS A LEFT JOIN test_scores AS B ON A.id = B.id WHERE A.created_at IS NOT NULL AND A.score IS NOT NULL;
SELECT A.id, bif:score(A.content) AS score FROM test_scores AS A JOIN test_scores AS B ON A.id = B.id AND A.score > B.score ORDER BY score DESC;
CREATE TABLE complex_scores (user_id INT, details VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO complex_scores (user_id, details) VALUES (1, 'Test detail 1'), (2, 'Test detail 2'), (3, NULL), (4, '');
SELECT c.user_id, bif:score(c.details) AS score FROM complex_scores AS c WHERE c.details IS NOT NULL OR c.user_id IS NULL;
SELECT c.user_id, AVG(bif:score(c.details)) FROM complex_scores AS c GROUP BY c.user_id HAVING AVG(bif:score(c.details)) IS NOT NULL;
SELECT A.id, bif:score(A.content) FROM test_scores AS A WHERE EXISTS (SELECT 1 FROM complex_scores AS C WHERE A.id = C.user_id AND C.details IS NOT NULL);
SELECT A.id, bif:score(A.content) FROM test_scores AS A WHERE A.created_at < '1970-01-01' OR A.content = '';
SELECT bif:score(NULLIF(A.content, '')) AS score FROM test_scores AS A WHERE A.id > 0;
SELECT bif:score(CAST(NULL AS TEXT)) AS score, bif:score(CAST(123 AS VARCHAR)) AS text_score FROM test_scores LIMIT 10;