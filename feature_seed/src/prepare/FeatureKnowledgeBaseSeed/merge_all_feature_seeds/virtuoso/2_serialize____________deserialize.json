CREATE TABLE test_data (id INTEGER PRIMARY KEY, data ARRAY, value STRING);
INSERT INTO test_data (id, data, value) VALUES (1, ARRAY[1, 2, 3], 'Test'), (2, ARRAY['A', 'B', NULL], 'Sample');
SELECT id, serialize(data) AS serialized_data FROM test_data WHERE id = 1 OR id = 2;
SELECT id, value FROM test_data WHERE serialize(data) IS NOT NULL OR serialize(ARRAY[]) = '0';
SELECT id, deserialize(serialize(data)) AS deserialized_data FROM test_data WHERE id IN (SELECT id FROM test_data WHERE value LIKE 'T%');
SELECT id, COUNT(*) OVER (PARTITION BY value) AS count FROM test_data WHERE serialize(data) IS NOT NULL OR value IS NULL;
SELECT id, value FROM test_data WHERE (serialize(data) = '' OR serialize(data) IS NULL) AND NOT (id > 3 OR id < 1);
CREATE TABLE more_data (key_id INTEGER, more ARRAY, FOREIGN KEY (key_id) REFERENCES test_data(id));
INSERT INTO more_data (key_id, more) SELECT id, ARRAY[serialize(data), value] FROM test_data WHERE value IS NOT NULL OR data IS NOT NULL;
SELECT COUNT(*) FROM more_data WHERE key_id = (SELECT id FROM test_data WHERE value IS NOT NULL) OR serialize(more) IS NOT NULL;