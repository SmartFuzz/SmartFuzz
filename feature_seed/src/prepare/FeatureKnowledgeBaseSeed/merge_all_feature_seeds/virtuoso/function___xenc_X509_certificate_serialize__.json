CREATE TABLE user_certificates (id INTEGER PRIMARY KEY, user_id INTEGER, certificate_data VARCHAR);
INSERT INTO user_certificates (user_id, certificate_data) VALUES (1, 'dummy_certificate_data_1');
INSERT INTO user_certificates (user_id, certificate_data) VALUES (2, 'dummy_certificate_data_2');
DECLARE x509 VARCHAR;
SET x509 = xenc_X509_certificate_serialize((SELECT certificate_data FROM user_certificates WHERE user_id = 1));
DECLARE x509_2 VARCHAR;
SET x509_2 = xenc_X509_certificate_serialize((SELECT certificate_data FROM user_certificates WHERE user_id = (SELECT MAX(user_id) FROM user_certificates)));
DECLARE nonexistent_x509 VARCHAR;
SET nonexistent_x509 = xenc_X509_certificate_serialize((SELECT certificate_data FROM user_certificates WHERE user_id = 3));
DECLARE empty_x509 VARCHAR;
SET empty_x509 = xenc_X509_certificate_serialize((SELECT certificate_data FROM user_certificates WHERE user_id = (SELECT MIN(user_id) FROM user_certificates WHERE user_id > 2)));
DECLARE x509_multi VARCHAR;
SET x509_multi = xenc_X509_certificate_serialize((SELECT GROUP_CONCAT(certificate_data) FROM user_certificates WHERE user_id IN (1, 2)));
SELECT xenc_X509_certificate_serialize(certificate_data) FROM user_certificates WHERE user_id IN (SELECT DISTINCT user_id FROM user_certificates WHERE certificate_data IS NOT NULL);
SELECT (SELECT xenc_X509_certificate_serialize(certificate_data) FROM user_certificates WHERE user_id = 1) AS First_Export, (SELECT xenc_X509_certificate_serialize(certificate_data) FROM user_certificates WHERE user_id = 2) AS Second_Export;