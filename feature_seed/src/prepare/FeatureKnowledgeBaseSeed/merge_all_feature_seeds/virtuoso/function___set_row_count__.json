CREATE TABLE t1 (id INTEGER PRIMARY KEY, value VARCHAR);
CREATE TABLE t2 (id INTEGER PRIMARY KEY, t1_id INTEGER, FOREIGN KEY (t1_id) REFERENCES t1 (id));
INSERT INTO t1 VALUES (1, 'A');
INSERT INTO t1 VALUES (2, 'B');
INSERT INTO t2 VALUES (1, 1);
INSERT INTO t2 VALUES (2, 1);
CREATE TRIGGER insert_t1 INSTEAD OF INSERT ON t1 AS BEGIN INSERT INTO t2 (t1_id) VALUES (new.id);
SET_ROW_COUNT(row_count(), 1);
END;
CREATE PROCEDURE test_insert_t1 AS BEGIN INSERT INTO t1 (id, value) VALUES (3, 'C');
RETURN ROW_COUNT();
END;
CREATE TRIGGER update_t1 INSTEAD OF UPDATE ON t1 AS BEGIN UPDATE t2 SET t1_id = new.id WHERE t1_id = old.id;
SET_ROW_COUNT(row_count(), 1);
END;
CREATE PROCEDURE test_update_t1 AS BEGIN UPDATE t1 SET value = 'Updated' WHERE id = 1;
RETURN ROW_COUNT();
END;
CREATE TABLE t3 (id INTEGER PRIMARY KEY, t2_id INTEGER, FOREIGN KEY (t2_id) REFERENCES t2 (id));
CREATE TRIGGER delete_t2 INSTEAD OF DELETE ON t2 AS BEGIN DELETE FROM t3 WHERE t2_id = old.id;
DELETE FROM t2 WHERE id = old.id;
SET_ROW_COUNT(row_count(), 1);
END;
CREATE PROCEDURE test_delete_t2 AS BEGIN DELETE FROM t2 WHERE id = 1;
RETURN ROW_COUNT();
END;
CREATE TRIGGER insert_t2 AFTER INSERT ON t2 AS BEGIN SET_ROW_COUNT(row_count(), 1);
END;
CREATE PROCEDURE test_complex_insert AS BEGIN INSERT INTO t1 (id, value) SELECT id, 'D' FROM (SELECT 4 AS id) AS sub;
RETURN ROW_COUNT();
END;
CREATE PROCEDURE test_nested_logic AS BEGIN IF (SELECT COUNT(*) FROM t1) = 2 THEN INSERT INTO t1 (id, value) VALUES (5, 'E');
END IF;
RETURN ROW_COUNT();
END;
CREATE TABLE t4 (id INTEGER PRIMARY KEY, value VARCHAR);
CREATE VIEW v1 AS SELECT id, value FROM t1 WHERE id > 1;
CREATE PROCEDURE test_view_logic AS BEGIN INSERT INTO t4 (id, value) SELECT id, value FROM v1;
RETURN ROW_COUNT();
END;