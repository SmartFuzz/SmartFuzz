CREATE TABLE test_graphs (id INT PRIMARY KEY, graph_uri VARCHAR(255) NOT NULL, data_type VARCHAR(50));
INSERT INTO test_graphs (id, graph_uri, data_type) VALUES (1, 'http://example.org/graph1', 'string');
INSERT INTO test_graphs (id, graph_uri, data_type) VALUES (2, 'http://example.org/graph2', NULL);
INSERT INTO test_graphs (id, graph_uri, data_type) VALUES (3, 'http://example.org/graph3', 'int');
SELECT DB.DBA.RDF_REPL_GRAPH_DEL((SELECT graph_uri FROM test_graphs WHERE id = 1 AND data_type SIMILAR TO 's.*'));
SELECT DB.DBA.RDF_REPL_GRAPH_DEL('http://example.org/graph' || (SELECT MAX(id) FROM test_graphs) SIMILAR TO 'http://example.org/graph[0-9]+');
SELECT DB.DBA.RDF_REPL_GRAPH_DEL(COALESCE(NULLIF((SELECT graph_uri FROM test_graphs WHERE id = 2), ''), 'http://default.org'));
DELETE FROM test_graphs WHERE graph_uri SIMILAR TO 'http://example.org/graph%' AND data_type IS NOT NULL;
SELECT DB.DBA.RDF_REPL_GRAPH_DEL((SELECT graph_uri FROM test_graphs WHERE id > 0 ORDER BY id DESC LIMIT 1) SIMILAR TO 'http://example.org/graph[0-9]+');
SELECT DB.DBA.RDF_REPL_GRAPH_DEL((SELECT graph_uri FROM test_graphs WHERE data_type SIMILAR TO 'string' AND LENGTH(graph_uri) > 10) LIMIT 1);