CREATE TABLE ftp_test (id INT, status VARCHAR(20));
INSERT INTO ftp_test (id, status) VALUES (1, 'success');
INSERT INTO ftp_test (id, status) VALUES (2, 'failure');
SELECT ftp_get('ftp.openlinksw.com', 'user_name', 'password', 'virtuoso30.tar.gz', 'virtuoso30.tar.gz') AS download_status FROM ftp_test WHERE id = 1;
INSERT INTO ftp_test (id, status) SELECT id, 'success' FROM (SELECT 3 AS id) AS tmp;
INSERT INTO ftp_test (id, status) SELECT id, 'failure' FROM (SELECT 4 AS id) AS tmp WHERE id NOT IN (SELECT id FROM ftp_test);
WITH ftp_operations AS (SELECT ftp_get('ftp.openlinksw.com', 'user_name', 'password', 'virtuoso30.tar.gz', 'virtuoso30.tar.gz') AS download_status) SELECT * FROM ftp_operations WHERE download_status IS NOT NULL;
SELECT ftp_get('ftp.openlinksw.com', 'user_name', 'password', 'file_not_exist.tar.gz', 'file_not_exist.tar.gz') AS download_error FROM ftp_test WHERE id = 2;
SELECT CASE WHEN ftp_get('ftp.openlinksw.com', 'user_name', 'password', 'large_file.tar.gz', 'large_file.tar.gz') THEN 'file downloaded' ELSE 'download failed' END AS result;
SELECT ftp_get('ftp.openlinksw.com', user_name, password, 'multiple_files.tar.gz', 'multiple_files.tar.gz') FROM ftp_test INNER JOIN users ON ftp_test.id = users.id WHERE users.role = 'admin';
SELECT DISTINCT ftp_get(ftp.server_name, ftp.user_name, ftp.password, ftp.file_name, ftp.destination) FROM ftp_config ftp WHERE ftp.active = TRUE;