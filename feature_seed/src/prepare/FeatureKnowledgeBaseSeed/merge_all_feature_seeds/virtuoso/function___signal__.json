CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100));
CREATE PROCEDURE test_procedure() BEGIN DECLARE EXIT HANDLER FOR SQLEXCEPTION SIGNAL SQLSTATE '45000' SET @err_msg = 'An error occurred';
END;
INSERT INTO test_table (id, name) VALUES (1, 'Test');
CREATE PROCEDURE signal_test() BEGIN DECLARE CONTINUE HANDLER FOR SQLEXCEPTION BEGIN SIGNAL SQLSTATE '45000' SET @error_message = 'Signal raised in signal_test';
END;
SIGNAL SQLSTATE '45000' SET @error_message = 'Direct signal in procedure';
END;
CALL signal_test();
CREATE TABLE another_table (id INT PRIMARY KEY, test_table_id INT, FOREIGN KEY (test_table_id) REFERENCES test_table(id));
CREATE PROCEDURE nested_signal_procedure() BEGIN DECLARE CONTINUE HANDLER FOR SQLEXCEPTION BEGIN SIGNAL SQLSTATE '45001' SET @nested_error_message = 'Nested procedure signal';
END;
CALL intermediate_procedure();
END;
CREATE PROCEDURE intermediate_procedure() BEGIN SIGNAL SQLSTATE '45002' SET @intermediate_error_message = 'Intermediate procedure signal';
END;
CREATE PROCEDURE main_procedure() BEGIN DECLARE CONTINUE HANDLER FOR SQLEXCEPTION BEGIN SIGNAL SQLSTATE '45003' SET @main_error_message = 'Main procedure signal';
END;
CALL nested_signal_procedure();
END;
CALL main_procedure();
SELECT * FROM test_table WHERE id = (SELECT MAX(id) FROM test_table) OR SIGNAL SQLSTATE '45004' SET @signal_message = 'Error in subquery';