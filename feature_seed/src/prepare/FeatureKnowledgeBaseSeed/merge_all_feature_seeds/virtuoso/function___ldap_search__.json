CREATE TABLE ldap_entries (dn VARCHAR(255), mail VARCHAR(255), cn VARCHAR(255), o VARCHAR(255), l VARCHAR(255), givenName VARCHAR(255), surname VARCHAR(255));
INSERT INTO ldap_entries VALUES ('cn=John Atanasov,mail=hellraisor@hotmail.com,c=US,o=hotmail.com', 'hellraisor@hotmail.com', 'John Atanasov', 'hotmail.com', 'SOFIA', 'John', 'Atanasov');
SELECT * FROM ldap_entries WHERE cn LIKE 'SomeBody%';
SELECT dn, mail FROM ldap_entries WHERE o = 'hotmail.com' AND cn LIKE 'John%';
SELECT l, givenName FROM ldap_entries WHERE dn IN (SELECT dn FROM ldap_entries WHERE mail IS NOT NULL);
SELECT e1.cn, e2.mail FROM ldap_entries e1 JOIN ldap_entries e2 ON e1.o = e2.o WHERE e1.mail <> e2.mail;
SELECT DISTINCT o FROM ldap_entries WHERE result IN (SELECT 'Success' FROM ldap_entries LIMIT 1);
SELECT e.dn FROM ldap_entries e WHERE e.surname IS NOT NULL AND e.mail IN (SELECT mail FROM ldap_entries WHERE cn = 'John Atanasov');
CREATE INDEX idx_cn ON ldap_entries(cn);
SELECT * FROM ldap_entries WHERE cn LIKE (SELECT CONCAT('John', '%'));