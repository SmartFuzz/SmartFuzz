CREATE TABLE test_table (id INT, value1 INT, value2 INT);
INSERT INTO test_table (id, value1, value2) VALUES (1, 18, 6);
INSERT INTO test_table (id, value1, value2) VALUES (2, -18, -6);
INSERT INTO test_table (id, value1, value2) VALUES (3, -18, 6);
SELECT bit_xor(value1, value2) FROM test_table WHERE id = 1;
SELECT bit_xor(value1, value2) FROM test_table WHERE id = 2;
SELECT bit_xor(value1, value2) FROM test_table WHERE id = 3;
SELECT id, bit_xor(value1) AS xor_value FROM test_table GROUP BY id;
SELECT id, (SELECT bit_xor(value1, value2) FROM test_table WHERE id = 1) AS bit_xor_result FROM test_table;
WITH xor_values AS (SELECT bit_xor(value1, value2) AS xor_result FROM test_table) SELECT * FROM xor_values;
SELECT a.id, bit_xor(a.value1) AS xor_result FROM test_table a JOIN test_table b ON a.id != b.id GROUP BY a.id;
SELECT a.id, bit_xor(a.value1, b.value2) FROM test_table a JOIN test_table b ON a.id = b.id WHERE a.value1 > 0;
SELECT bit_xor(b.value1, CASE WHEN b.value2 < 0 THEN 0 ELSE b.value2 END) FROM test_table b;
SELECT COUNT(*), bit_xor(value1) FROM test_table GROUP BY value1 HAVING COUNT(*) > 1;