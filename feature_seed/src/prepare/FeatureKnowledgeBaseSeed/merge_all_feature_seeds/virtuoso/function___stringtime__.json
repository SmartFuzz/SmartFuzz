CREATE TABLE time_test (id INT PRIMARY KEY, time_string VARCHAR(50));
INSERT INTO time_test (id, time_string) VALUES (1, '12:30:00');
INSERT INTO time_test (id, time_string) VALUES (2, '00:00:00');
INSERT INTO time_test (id, time_string) VALUES (3, '23:59:59');
INSERT INTO time_test (id, time_string) VALUES (4, '25:00:00');
INSERT INTO time_test (id, time_string) VALUES (5, '12:60:00');
INSERT INTO time_test (id, time_string) VALUES (6, '12:30:60');
INSERT INTO time_test (id, time_string) VALUES (7, 'invalid_time');
SELECT stringtime(time_string) AS converted_time FROM time_test WHERE id IN (1, 2, 3);
SELECT stringtime(time_string) AS converted_time FROM time_test WHERE time_string LIKE '12:%';
SELECT tt.id, stringtime(tt.time_string) AS converted_time FROM time_test tt WHERE tt.id IN (SELECT id FROM time_test WHERE time_string LIKE '23:%');
CREATE TABLE additional_time_test (id INT PRIMARY KEY, additional_time_string VARCHAR(50));
INSERT INTO additional_time_test (id, additional_time_string) VALUES (1, '09:15:30');
INSERT INTO additional_time_test (id, additional_time_string) VALUES (2, 'invalid_input');
SELECT at.id, stringtime(at.additional_time_string) AS converted_additional_time, tt.converted_time FROM additional_time_test at JOIN (SELECT id, stringtime(time_string) AS converted_time FROM time_test) tt ON at.id = tt.id WHERE at.additional_time_string IS NOT NULL;
SELECT COUNT(*) FROM time_test WHERE stringtime(time_string) IS NULL;
SELECT MAX(stringtime(time_string)) AS latest_time FROM time_test;
SELECT MIN(stringtime(time_string)) AS earliest_time FROM time_test WHERE stringtime(time_string) IS NOT NULL;