CREATE TABLE test_numbers (id NUMERIC(10, 2));
INSERT INTO test_numbers (id) VALUES (12345.67);
INSERT INTO test_numbers (id) VALUES (0.00);
INSERT INTO test_numbers (id) VALUES (-100.99);
INSERT INTO test_numbers (id) VALUES (9999999999.99);
INSERT INTO test_numbers (id) VALUES (NULL);
SELECT * FROM test_numbers WHERE id < NUMERIC(5000.00);
SELECT * FROM test_numbers WHERE id BETWEEN NUMERIC(-200.00) AND NUMERIC(1000.00);
SELECT (SELECT MIN(id) FROM test_numbers) AS min_value FROM test_numbers;
SELECT id, (id * NUMERIC(1.10, 2)) AS increased_value FROM test_numbers;
WITH temp AS (SELECT id FROM test_numbers WHERE id IS NOT NULL) SELECT AVG(id) AS average_value FROM temp;
SELECT a.id, b.id FROM test_numbers a JOIN test_numbers b ON a.id > b.id;
INSERT INTO test_numbers (id) SELECT NUMERIC(5, 2) FROM (SELECT 10.00 AS num) AS temp;
SELECT id FROM test_numbers WHERE id IN (SELECT id FROM test_numbers WHERE id < NUMERIC(1000.00));
UPDATE test_numbers SET id = NUMERIC(1234.56) WHERE id IS NULL;