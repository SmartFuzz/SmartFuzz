CREATE TABLE sales (id INT PRIMARY KEY, amount DECIMAL(10, 2), region VARCHAR(50), date_sale DATE);
INSERT INTO sales (id, amount, region, date_sale) VALUES (1, 150.50, 'North', '2023-01-15'), (2, 200.00, 'South', '2023-01-20'), (3, NULL, 'East', '2023-01-25'), (4, 300.75, 'West', '2023-02-05'), (5, 50.00, 'North', '2023-02-15');
SELECT REGR_R2(amount, id) AS r_squared FROM sales WHERE region BETWEEN 'North' AND 'East' GROUP BY region HAVING NULLIF(COUNT(*) , 0) IS NOT NULL;
SELECT REGR_R2(SUM(amount), COUNT(id)) AS r_squared, region FROM sales WHERE amount BETWEEN 100 AND 400 GROUP BY region HAVING COUNT(id) > 1;
SELECT region, REGR_R2(amount, date_sale) OVER (PARTITION BY region) AS r_squared FROM sales WHERE date_sale BETWEEN '2023-01-01' AND '2023-03-01' AND amount + 0 IS NOT NULL;
SELECT region, REGR_R2(amount, id) AS r_squared FROM sales WHERE region IS NOT NULL GROUP BY region HAVING COUNT(*) > 2 ORDER BY r_squared DESC;
INSERT INTO sales (id, amount, region, date_sale) VALUES (6, -10.00, 'South', '2023-03-01');
CREATE TABLE temp_sales AS SELECT * FROM sales WHERE amount IS NOT NULL;
INSERT INTO temp_sales (id, amount, region, date_sale) SELECT id, amount, region, date_sale FROM sales WHERE region BETWEEN 'North' AND 'West';
SELECT REGR_R2(COALESCE(amount, 0), CAST(id AS FLOAT)) AS r_squared FROM sales WHERE amount IS NOT NULL AND region NOT BETWEEN 'East' AND 'West';