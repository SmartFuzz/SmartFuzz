CREATE TABLE test_files (id INT PRIMARY KEY, file_name VARCHAR(255), file_size INT, created_at TIMESTAMP);
INSERT INTO test_files (id, file_name, file_size, created_at) VALUES (1, 'test_file_1.txt', 1024, NOW()), (2, NULL, NULL, NOW()), (3, 'test_file_2.txt', -2048, NOW()), (4, 'test_file_3.txt', 0, NOW());
SELECT file_name, file_delete(file_name) AS delete_status FROM test_files WHERE file_size BETWEEN (SELECT MIN(file_size) FROM test_files WHERE file_size IS NOT NULL) AND (SELECT MAX(file_size) FROM test_files) AND file_name IS NOT NULL;
SELECT file_name FROM test_files WHERE file_delete(file_name) IS NULL OR file_name BETWEEN 'a' AND 'z';
SELECT COUNT(*) FROM (SELECT id, file_name, file_size FROM test_files WHERE file_size < 0 ORDER BY file_size) AS subquery HAVING COUNT(*) > 1;
SELECT file_name, file_delete(file_name), file_size FROM test_files WHERE file_size BETWEEN -1000 AND 1000 AND created_at > NOW() - INTERVAL '1 DAY';
SELECT DISTINCT file_name, file_delete(file_name) FROM test_files WHERE file_name IS NOT NULL AND file_size > (SELECT AVG(file_size) FROM test_files WHERE file_size IS NOT NULL) OR file_name BETWEEN 'test_file_1.txt' AND 'test_file_3.txt';
SELECT AVG(file_size) OVER (PARTITION BY file_name) AS avg_size, file_delete(file_name) FROM test_files WHERE file_size IS NOT NULL AND file_size BETWEEN 1 AND 10000;
CREATE TEMPORARY TABLE temp_files AS SELECT * FROM test_files WHERE file_size IS NOT NULL;
SELECT file_delete(file_name) FROM temp_files WHERE file_name IS NULL OR file_size BETWEEN (SELECT MIN(file_size) FROM temp_files) AND (SELECT MAX(file_size) FROM temp_files);