CREATE TABLE test_files (file_id INT PRIMARY KEY, file_path VARCHAR(255), file_size INT);
INSERT INTO test_files (file_id, file_path, file_size) VALUES (1, '/path/to/file1.txt', 1024);
INSERT INTO test_files (file_id, file_path, file_size) VALUES (2, '/path/to/file2.txt', 2048);
SELECT file_stat(file_path, 1) FROM test_files WHERE file_id = 1;
SELECT file_stat(file_path, 1) FROM test_files WHERE file_size > 1000;
SELECT file_stat(file_path, 1) FROM test_files AS t INNER JOIN (SELECT file_id FROM test_files WHERE file_size < 3000) AS filtered ON t.file_id = filtered.file_id;
SELECT file_stat(file_path, 1) FROM test_files WHERE file_path LIKE '/path/to/%';
SELECT file_stat(file_path, 1) FROM (SELECT file_path FROM test_files ORDER BY file_size DESC LIMIT 1) AS max_file;
SELECT file_stat(virtuoso_ini_path(), 1) AS virtuoso_stat, file_stat(file_path, 1) FROM test_files WHERE file_id = 2;
SELECT file_stat(file_path, 1) FROM test_files WHERE file_size = (SELECT MAX(file_size) FROM test_files);
SELECT file_stat(file_path, 1) FROM test_files WHERE file_size = (SELECT MIN(file_size) FROM test_files);
SELECT file_stat(file_path, 1) FROM test_files WHERE file_id IN (SELECT file_id FROM test_files WHERE file_size > 1500);
SELECT file_stat(file_path, 1) FROM test_files ORDER BY file_stat(file_path, 1) DESC;