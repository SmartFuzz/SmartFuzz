CREATE TABLE xml_stylesheets (id INT PRIMARY KEY, name VARCHAR(255), content TEXT);
INSERT INTO xml_stylesheets (id, name, content) VALUES (1, 'style1', '<xsl:stylesheet version="1.0"><xsl:template match="/">Hello World</xsl:template></xsl:stylesheet>');
INSERT INTO xml_stylesheets (id, name, content) VALUES (2, 'style2', '<xsl:stylesheet version="1.0"><xsl:template match="/"><xsl:value-of select="title"/></xsl:template></xsl:stylesheet>');
CREATE PROCEDURE xslt_view (in v varchar, in xst varchar) { DECLARE str, r varchar;
xslt_sheet(xst, xml_tree_doc(xml_tree(file_to_string(xst))));
str := xml_view_string(v);
r := xslt(xst, xml_tree_doc(xml_tree(str)));
DECLARE str any;
str := string_output();
http_value(r, 0, str);
string_to_file('xslt.out', string_output_string(str), 0);
};
SELECT id, name FROM xml_stylesheets WHERE content ILIKE '%<xsl:template%';
SELECT s1.id, s2.name FROM xml_stylesheets s1 JOIN xml_stylesheets s2 ON s1.id <> s2.id WHERE s1.content LIKE '%<xsl:template%' AND s2.content LIKE '%<xsl:value-of%';
SELECT id, content FROM xml_stylesheets WHERE LENGTH(content) < 500;
CREATE TABLE xml_inputs (id INT PRIMARY KEY, inputData TEXT);
INSERT INTO xml_inputs (id, inputData) VALUES (1, '<document><title>Sample Title</title></document>');
CREATE TABLE output_results (id INT PRIMARY KEY, resultData TEXT);
INSERT INTO output_results (id, resultData) VALUES (1, 'Output from first transformation');
CREATE PROCEDURE process_multiple_stylesheets (in doc varchar) { DECLARE str any;
DECLARE r varchar;
DECLARE stylesheet_id INT;
DECLARE stylesheet_cursor CURSOR FOR SELECT id FROM xml_stylesheets;
OPEN stylesheet_cursor;
LOOP FETCH stylesheet_cursor INTO stylesheet_id;
EXIT WHEN NOT FOUND;
r := xslt((SELECT content FROM xml_stylesheets WHERE id = stylesheet_id), xml_tree_doc(xml_tree(doc)));
INSERT INTO output_results (id, resultData) VALUES (stylesheet_id, r);
END LOOP;
CLOSE stylesheet_cursor;
};
SELECT COUNT(*) FROM output_results WHERE resultData IS NOT NULL;