CREATE TABLE SYS_SCHEDULED_EVENTS (ID INT PRIMARY KEY, SUBSCRIPTION_NAME VARCHAR(255), STATUS VARCHAR(50));
INSERT INTO SYS_SCHEDULED_EVENTS (ID, SUBSCRIPTION_NAME, STATUS) VALUES (1, 'Subscription_A', 'Pending');
INSERT INTO SYS_SCHEDULED_EVENTS (ID, SUBSCRIPTION_NAME, STATUS) VALUES (2, 'Subscription_B', 'Pending');
INSERT INTO SYS_SCHEDULED_EVENTS (ID, SUBSCRIPTION_NAME, STATUS) VALUES (3, 'Subscription_C', 'Synchronized');
SELECT * FROM SYS_SCHEDULED_EVENTS WHERE STATUS = 'Pending';
DELETE FROM SYS_SCHEDULED_EVENTS WHERE ID = 1;
SELECT COUNT(*) FROM SYS_SCHEDULED_EVENTS WHERE STATUS = 'Pending';
SELECT SUBSCRIPTION_NAME FROM SYS_SCHEDULED_EVENTS WHERE STATUS IN (SELECT DISTINCT STATUS FROM SYS_SCHEDULED_EVENTS);
CREATE TABLE JOB_LOG (JOB_ID INT PRIMARY KEY, JOB_NAME VARCHAR(255), JOB_STATUS VARCHAR(50), JOB_TIMESTAMP TIMESTAMP);
INSERT INTO JOB_LOG (JOB_ID, JOB_NAME, JOB_STATUS, JOB_TIMESTAMP) VALUES (1, 'Sync_Job_1', 'Started', CURRENT_TIMESTAMP);
SELECT JOB_NAME, JOB_STATUS FROM JOB_LOG WHERE JOB_TIMESTAMP > (CURRENT_TIMESTAMP - INTERVAL '1 DAY') AND JOB_STATUS = 'Started';
UPDATE SYS_SCHEDULED_EVENTS SET STATUS = 'Synchronized' WHERE ID = 2;
SELECT E.SUBSCRIPTION_NAME, L.JOB_STATUS FROM SYS_SCHEDULED_EVENTS E JOIN JOB_LOG L ON E.ID = L.JOB_ID WHERE E.STATUS = 'Synchronized';
CALL DB.DBA.REPL_SCHED_INIT();
SELECT SUBSCRIPTION_NAME FROM SYS_SCHEDULED_EVENTS WHERE STATUS = 'Synchronized' AND ID IN (SELECT JOB_ID FROM JOB_LOG WHERE JOB_STATUS = 'Completed');