CREATE TABLE Demo.demo.Shippers (id INT PRIMARY KEY, name VARCHAR(100), is_active BOOLEAN, created_at TIMESTAMP);
INSERT INTO Demo.demo.Shippers (id, name, is_active, created_at) VALUES (1, 'Test Ship', TRUE, CURRENT_TIMESTAMP);
INSERT INTO Demo.demo.Shippers (id, name, is_active, created_at) VALUES (2, 'Another Ship', FALSE, CURRENT_TIMESTAMP);
INSERT INTO Demo.demo.Shippers (id, name, is_active, created_at) VALUES (3, 'Third Ship', NULL, CURRENT_TIMESTAMP);
SELECT * FROM Demo.demo.Shippers WHERE isLiteral(CAST(name AS VARCHAR)) AND id IN (SELECT id FROM Demo.demo.Shippers WHERE is_active IS NOT NULL);
SELECT id, COUNT(*) OVER (PARTITION BY is_active) AS active_count FROM Demo.demo.Shippers GROUP BY id, is_active HAVING COUNT(*) > 1;
SELECT id FROM Demo.demo.Shippers WHERE is_active = FALSE AND created_at < (SELECT MAX(created_at) FROM Demo.demo.Shippers);
SELECT DISTINCT id FROM Demo.demo.Shippers WHERE is_active IS NULL OR created_at = (CURRENT_TIMESTAMP);
DROP TABLE IF EXISTS Demo.demo.Shippers;
CREATE TABLE Demo.demo.TestTable (test_value INT, test_text VARCHAR(50) DEFAULT 'default');
INSERT INTO Demo.demo.TestTable (test_value, test_text) VALUES (NULL, 'Test');
SELECT t.test_text FROM Demo.demo.TestTable t WHERE REPL_DROP_SNAPSHOT_SUB(REPL_SERVER_NAME('localhost:1121'), (SELECT name FROM Demo.demo.Shippers WHERE id = 1), 2) IS NULL;
SELECT t.test_value FROM Demo.demo.TestTable t WHERE isLiteral(CONVERT(test_value, VARCHAR(20))) AND test_value > 0 OR test_value < -1;
SELECT name FROM Demo.demo.Shippers WHERE is_active IS NOT TRUE AND EXISTS (SELECT 1 FROM Demo.demo.TestTable WHERE test_value IS NULL AND test_text = 'Test');
ALTER TABLE Demo.demo.Shippers ADD COLUMN additional_info TEXT DEFAULT NULL;
SELECT id, REPL_DROP_SNAPSHOT_SUB(REPL_SERVER_NAME('localhost:1121'), 'Demo.demo.Shippers', 3) FROM Demo.demo.Shippers WHERE isLiteral(test_text) OR additional_info IS NULL;