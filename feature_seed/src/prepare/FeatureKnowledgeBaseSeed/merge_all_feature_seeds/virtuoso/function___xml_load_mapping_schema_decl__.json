CREATE TABLE Demo.demo.Categories (CategoryID INTEGER PRIMARY KEY, Description STRING);
CREATE TABLE Demo.demo.Products (ProductID INTEGER PRIMARY KEY, ProductName STRING, CategoryID INTEGER);
INSERT INTO Demo.demo.Categories (CategoryID, Description) VALUES (1, 'Electronics');
INSERT INTO Demo.demo.Categories (CategoryID, Description) VALUES (2, 'Books');
INSERT INTO Demo.demo.Products (ProductID, ProductName, CategoryID) VALUES (1, 'Smartphone', 1);
INSERT INTO Demo.demo.Products (ProductID, ProductName, CategoryID) VALUES (2, 'Laptop', 1);
INSERT INTO Demo.demo.Products (ProductID, ProductName, CategoryID) VALUES (3, 'Novels', 2);
SELECT C.CategoryID, C.Description, P.ProductName FROM Demo.demo.Categories C JOIN Demo.demo.Products P ON C.CategoryID = P.CategoryID;
SELECT C.CategoryID, C.Description, (SELECT COUNT(*) FROM Demo.demo.Products P WHERE P.CategoryID = C.CategoryID) AS ProductCount FROM Demo.demo.Categories C;
SELECT DISTINCT C.CategoryID FROM Demo.demo.Categories C LEFT JOIN Demo.demo.Products P ON C.CategoryID = P.CategoryID WHERE P.ProductName IS NULL;