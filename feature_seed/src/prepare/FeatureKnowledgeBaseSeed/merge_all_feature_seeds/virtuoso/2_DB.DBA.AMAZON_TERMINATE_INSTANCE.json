CREATE TABLE instance_data (id INT PRIMARY KEY, access_key VARCHAR(255), sec_token VARCHAR(255), instance_name VARCHAR(255) NOT NULL);
INSERT INTO instance_data (id, access_key, sec_token, instance_name) VALUES (1, 'AKIAJI7ZL427TI5EDF5A', 'CGI/UMaXf2LRUctaj/HGJ57UNy/t7fNCshh8wpJg', 'my_instance_of_linux');
SELECT DB.DBA.AMAZON_TERMINATE_INSTANCE(CONCAT('AKIA', 'JI7ZL427', 'TI5EDF5A'), instance_name, sec_token) + (SELECT COUNT(*) FROM instance_data WHERE instance_name = 'my_instance_of_linux') AS result FROM instance_data;
CREATE TABLE additional_data (value INT, description VARCHAR(100));
INSERT INTO additional_data (value, description) VALUES (1, 'First entry'), (2, 'Second entry');
SELECT value + (SELECT MAX(value) FROM additional_data) AS calculated_value FROM additional_data;
SELECT DB.DBA.AMAZON_TERMINATE_INSTANCE((SELECT access_key FROM instance_data WHERE id = 1) + 'suffix', (SELECT instance_name FROM instance_data WHERE id = 1), (SELECT sec_token FROM instance_data WHERE id = 1)) AS termination_output FROM instance_data;
CREATE TABLE error_test (input_value VARCHAR(10), nullable_value INT NULL);
INSERT INTO error_test (input_value, nullable_value) VALUES ('', NULL), (NULL, 100);
SELECT DB.DBA.AMAZON_TERMINATE_INSTANCE('AKIAJI7ZL427TI5EDF5A', (SELECT input_value FROM error_test WHERE nullable_value IS NULL), 'CGI/UMaXf2LRUctaj/HGJ57UNy/t7fNCshh8wpJg') + (SELECT COUNT(*) FROM error_test WHERE input_value LIKE '') AS result;
SELECT (SELECT COUNT(*) FROM instance_data) + (SELECT COUNT(*) FROM additional_data) AS total_count, DB.DBA.AMAZON_TERMINATE_INSTANCE('AKIAJI7ZL427TI5EDF5A', 'my_instance_of_linux', 'CGI/UMaXf2LRUctaj/HGJ57UNy/t7fNCshh8wpJg') AS termination_status;