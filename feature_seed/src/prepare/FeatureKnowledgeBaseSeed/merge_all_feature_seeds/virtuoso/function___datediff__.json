CREATE TABLE Orders (OrderID INT, OrderDate DATE, ShippedDate DATE);
INSERT INTO Orders (OrderID, OrderDate, ShippedDate) VALUES (1, stringdate('1996.10.10'), stringdate('1996.10.12'));
INSERT INTO Orders (OrderID, OrderDate, ShippedDate) VALUES (2, stringdate('1996.10.10'), stringdate('1996.10.11'));
INSERT INTO Orders (OrderID, OrderDate, ShippedDate) VALUES (3, stringdate('1996.10.11'), stringdate('1996.10.13'));
INSERT INTO Orders (OrderID, OrderDate, ShippedDate) VALUES (4, stringdate('1996.10.09'), stringdate(null));
SELECT datediff('day', '1996.10.10', '1996.10.12') AS DaysDifference;
SELECT datediff('hour', stringdate('2023.01.01 12:00:00'), stringdate('2023.01.02 12:00:00')) AS HoursDifference;
SELECT COUNT(*), avg(datediff('day', OrderDate, ShippedDate)) AS AvgProcessingTime FROM Orders WHERE ShippedDate IS NOT NULL;
SELECT OrderID FROM Orders WHERE datediff('day', OrderDate, ShippedDate) > 1;
SELECT * FROM Orders WHERE datediff('day', OrderDate, ShippedDate) IN (SELECT DISTINCT datediff('day', '1996.10.10', ShippedDate) FROM Orders WHERE ShippedDate IS NOT NULL);
SELECT ord.OrderID, datediff('day', ord.OrderDate, ord.ShippedDate) AS ProcessingTime FROM Orders ord JOIN Customers cust ON ord.OrderID = cust.CustomerID WHERE cust.CustomerID IS NOT NULL;
SELECT SUM(datediff('day', OrderDate, ShippedDate)) AS TotalDays FROM (SELECT * FROM Orders WHERE ShippedDate IS NOT NULL) AS sub;
SELECT DISTINCT OrderID, datediff('hour', '2023.01.01', OrderDate) FROM Orders WHERE OrderDate >= '2023.01.01' ORDER BY OrderID DESC;