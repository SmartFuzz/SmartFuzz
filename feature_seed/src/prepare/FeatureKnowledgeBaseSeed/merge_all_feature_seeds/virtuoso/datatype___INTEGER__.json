CREATE TABLE test_integers (id INTEGER PRIMARY KEY, value INTEGER);
INSERT INTO test_integers (id, value) VALUES (1, 2147483647);
INSERT INTO test_integers (id, value) VALUES (2, -2147483648);
INSERT INTO test_integers (id, value) VALUES (3, 0);
INSERT INTO test_integers (id, value) VALUES (4, 100);
INSERT INTO test_integers (id, value) VALUES (5, -100);
SELECT * FROM test_integers WHERE value = (SELECT MAX(value) FROM test_integers);
SELECT * FROM test_integers WHERE value IN (SELECT value FROM test_integers WHERE value BETWEEN -50 AND 50);
SELECT a.id, a.value, (SELECT COUNT(*) FROM test_integers WHERE value > a.value) AS greater_count FROM test_integers a;
CREATE TABLE additional_info (id INTEGER, info VARCHAR(100));
INSERT INTO additional_info (id, info) VALUES (1, 'Positive integer'), (2, 'Negative integer'), (3, 'Zero');
SELECT t.id, t.value, a.info FROM test_integers t JOIN additional_info a ON t.id = a.id WHERE t.value != 0;
UPDATE test_integers SET value = value + 1 WHERE value < 10;
DELETE FROM test_integers WHERE value < -50;
SELECT COUNT(*) FROM test_integers WHERE id IN (SELECT id FROM additional_info WHERE info LIKE '%integer');
SELECT AVG(value) AS average_value FROM test_integers WHERE value > -100;
CREATE TABLE combined_data (id INTEGER, value1 INTEGER, value2 INTEGER, FOREIGN KEY(id) REFERENCES test_integers(id));
INSERT INTO combined_data (id, value1, value2) VALUES (1, 10, 20), (2, -10, 30), (3, 0, 0);
SELECT t.value1 + t.value2 AS sum_values FROM combined_data t WHERE id IN (SELECT id FROM test_integers WHERE value >= 0);
SELECT * FROM test_integers WHERE EXISTS (SELECT 1 FROM additional_info WHERE additional_info.id = test_integers.id AND info = 'Positive integer') ORDER BY value DESC;