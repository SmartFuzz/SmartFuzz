CREATE TABLE acl_rules (id INTEGER PRIMARY KEY, rule_name VARCHAR(255), condition VARCHAR(255), action VARCHAR(255));
INSERT INTO acl_rules (rule_name, condition, action) VALUES ('Allow-Admin', 'user_role = ''admin''', 'ALLOW');
INSERT INTO acl_rules (rule_name, condition, action) VALUES ('Deny-User', 'user_role = ''user'' AND resource_access = ''restricted''', 'DENY');
INSERT INTO acl_rules (rule_name, condition, action) VALUES ('Conditional-Allow', 'user_role = ''guest'' AND resource_access = ''public''', 'ALLOW');
SELECT * FROM acl_rules WHERE condition LIKE '%user_role%';
SELECT COUNT(*) FROM acl_rules WHERE action = 'DENY';
SELECT rule_name FROM acl_rules WHERE id IN (SELECT id FROM acl_rules WHERE action = 'ALLOW') ORDER BY rule_name DESC;
CREATE INDEX idx_condition ON acl_rules(condition);
SELECT DISTINCT action FROM acl_rules WHERE condition IN (SELECT condition FROM acl_rules WHERE action = 'DENY');
DELETE FROM acl_rules WHERE id = (SELECT id FROM acl_rules WHERE rule_name = 'Allow-Admin' LIMIT 1);
UPDATE acl_rules SET action = 'DENY' WHERE condition = 'user_role = ''user'' AND resource_access = ''restricted''';
SELECT * FROM acl_rules WHERE EXISTS (SELECT 1 FROM acl_rules AS sub WHERE sub.action = 'ALLOW' AND sub.rule_name = acl_rules.rule_name);
SELECT rule_name, (SELECT COUNT(*) FROM acl_rules) AS total_rules FROM acl_rules GROUP BY rule_name HAVING COUNT(*) > 1;