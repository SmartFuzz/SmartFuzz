CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'A'), (2, 'B'), (3, 'C'), (4, '');
SELECT id, ascii(name) AS ascii_value FROM test_table WHERE ascii(name) < 65;
SELECT id, (SELECT COUNT(*) FROM test_table t2 WHERE t2.id < test_table.id) AS sub_count FROM test_table;
SELECT id, name FROM test_table WHERE ascii(name) < (SELECT MAX(ascii(name)) FROM test_table WHERE name IS NOT NULL);
SELECT t1.id, ascii(t1.name) AS ascii_value FROM test_table t1 JOIN test_table t2 ON ascii(t1.name) < ascii(t2.name) WHERE t1.id <> t2.id;
SELECT COUNT(*) FROM test_table WHERE ascii(name) < 66 HAVING COUNT(*) > 0;
SELECT id, name FROM test_table WHERE ascii(name) < 65 ORDER BY ascii(name) ASC;
CREATE TABLE test_table2 (col1 INT NOT NULL, col2 VARCHAR(5) UNIQUE);
INSERT INTO test_table2 (col1, col2) VALUES (1, 'A'), (2, 'B'), (3, '');
SELECT t1.id, (SELECT COUNT(*) FROM test_table2 t2 WHERE ascii(t2.col2) < ascii(t1.name)) AS less_count FROM test_table t1;
ALTER TABLE test_table ADD COLUMN description VARCHAR(255);
UPDATE test_table SET description = 'Character Description' WHERE id = 1;
SELECT id, ascii(name), description FROM test_table WHERE description IS NOT NULL;
SELECT COUNT(*), ascii(name) AS ascii_name FROM test_table GROUP BY ascii_name HAVING ascii_name < 66;
CREATE TEMPORARY TABLE temp_table AS SELECT id, ascii(name) AS ascii_value FROM test_table WHERE name IS NOT NULL;
SELECT * FROM temp_table WHERE ascii_value < (SELECT ascii('C') FROM temp_table WHERE id = 2);
DROP TABLE IF EXISTS test_table2;