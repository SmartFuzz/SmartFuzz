CREATE TABLE test_numbers (id INTEGER PRIMARY KEY, num_value FLOAT);
INSERT INTO test_numbers (id, num_value) VALUES (1, 0);
INSERT INTO test_numbers (id, num_value) VALUES (2, 1.5);
INSERT INTO test_numbers (id, num_value) VALUES (3, 2.0);
INSERT INTO test_numbers (id, num_value) VALUES (4, -1);
INSERT INTO test_numbers (id, num_value) VALUES (5, -3.14);
INSERT INTO test_numbers (id, num_value) VALUES (6, NULL);
INSERT INTO test_numbers (id, num_value) VALUES (7, 'text');
CREATE TABLE test_results (result_id INTEGER PRIMARY KEY, is_numeric_result INTEGER);
INSERT INTO test_results (result_id, is_numeric_result) SELECT id, CASE WHEN isnumeric(num_value) THEN 1 ELSE 0 END FROM test_numbers;
SELECT result_id, is_numeric_result FROM test_results WHERE is_numeric_result = 1;
SELECT n.id, n.num_value, r.is_numeric_result FROM test_numbers n JOIN test_results r ON n.id = r.result_id WHERE r.is_numeric_result = 0;
INSERT INTO test_numbers (id, num_value) SELECT 8, CAST('42' AS FLOAT) WHERE isnumeric('42') = 1;
INSERT INTO test_numbers (id, num_value) SELECT 9, CAST('(1.2 + 3.4)' AS FLOAT) WHERE isnumeric('(1.2 + 3.4)') = 1;
SELECT COUNT(id) AS total_numeric FROM test_numbers WHERE isnumeric(num_value) = 1 GROUP BY round(num_value);
SELECT (SELECT COUNT(*) FROM test_numbers WHERE isnumeric(num_value) = 1) AS numeric_count, (SELECT COUNT(*) FROM test_numbers) AS total_count;
SELECT EXISTS (SELECT 1 FROM test_numbers WHERE isnumeric(num_value) = 0) AS non_numeric_exists;