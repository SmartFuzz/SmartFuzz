CREATE TABLE businessEntity (id INT PRIMARY KEY, name VARCHAR(255), description TEXT, address VARCHAR(255));
INSERT INTO businessEntity (id, name, description, address) VALUES (1, 'Business A', 'First Business', '123 Main St');
INSERT INTO businessEntity (id, name, description, address) VALUES (2, 'Business B', 'Second Business', '456 Elm St');
INSERT INTO businessEntity (id, name, description, address) VALUES (3, 'Business C', 'Third Business', '789 Oak St');
SELECT * FROM businessEntity WHERE id = 1;
SELECT * FROM businessEntity WHERE id IN (SELECT id FROM businessEntity WHERE address LIKE '%Main%');
SELECT * FROM businessEntity WHERE id = (SELECT MIN(id) FROM businessEntity);
SELECT e1.name FROM businessEntity e1 JOIN businessEntity e2 ON e1.id != e2.id WHERE e1.name LIKE 'Business%';
SELECT e1.name, e2.name FROM businessEntity e1 JOIN businessEntity e2 ON e1.id = e2.id - 1;
SELECT name, description FROM businessEntity WHERE id IN (SELECT id FROM businessEntity WHERE address IS NOT NULL);
CREATE TABLE businessDetails (business_id INT, detail TEXT, FOREIGN KEY (business_id) REFERENCES businessEntity(id));
INSERT INTO businessDetails (business_id, detail) VALUES (1, 'Detail for Business A');
INSERT INTO businessDetails (business_id, detail) VALUES (2, 'Detail for Business B');
SELECT b.name, d.detail FROM businessEntity b LEFT JOIN businessDetails d ON b.id = d.business_id WHERE b.id IN (1, 2);