CREATE TABLE test_table (id INT, name VARCHAR(255), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP, value DECIMAL(10, 2));
INSERT INTO test_table (id, name, value) VALUES (1, 'A', 10.00);
INSERT INTO test_table (id, name, value) VALUES (2, 'B', NULL);
INSERT INTO test_table (id, name, value) VALUES (3, 'C', -5.00);
INSERT INTO test_table (id, name, value) VALUES (4, '', 0.00);
INSERT INTO test_table (id, name, value) VALUES (5, 'D', 9999999999.99);
SELECT id || name AS identifier FROM test_table WHERE value IS NOT NULL;
SELECT id, name, ||value AS formatted_value FROM test_table WHERE value > 0;
SELECT id, COUNT(*) FROM test_table GROUP BY id HAVING COUNT(*) > 1;
SELECT id, name FROM test_table WHERE name LIKE '%' || (SELECT name FROM test_table WHERE id = 1) || '%';
SELECT id, name || ' created on ' || CAST(created_at AS VARCHAR) FROM test_table WHERE value < 0;
CREATE TABLE secondary_table (sec_id INT, ref_id INT, FOREIGN KEY (ref_id) REFERENCES test_table(id));
INSERT INTO secondary_table (sec_id, ref_id) VALUES (1, (SELECT id FROM test_table WHERE name = 'A' LIMIT 1));
SELECT a.id, b.sec_id FROM test_table a JOIN secondary_table b ON a.id = b.ref_id WHERE b.sec_id IS NOT NULL;
SELECT id, AVG(value) OVER (PARTITION BY id) AS avg_value FROM test_table GROUP BY id;
SELECT id, name FROM test_table WHERE value IS NULL || (SELECT value FROM test_table WHERE id = 2);
CALL VAD_LOAD_SQL_FILE ('./conductor/test_setup.sql', 1, 'setup_report_' || current_timestamp, 0);