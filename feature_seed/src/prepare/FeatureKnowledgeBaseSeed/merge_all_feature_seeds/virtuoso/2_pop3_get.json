SELECT MSG_UIDL, LENGTH(MSG_TEXT), (CASE WHEN MSG_TEXT IS NULL THEN 'NULL' ELSE 'NOT NULL' END) AS Text_Status FROM POP_MESSAGES WHERE MSG_TEXT IS NULL OR MSG_TEXT = '';
SELECT AVG(LENGTH(MSG_TEXT)) AS AvgLength FROM POP_MESSAGES WHERE MSG_TEXT IS NOT NULL;
CREATE TABLE TEMP_MSG AS SELECT MSG_UIDL, LENGTH(MSG_TEXT) AS TEXT_LENGTH FROM POP_MESSAGES WHERE LENGTH(MSG_TEXT) < 500;
