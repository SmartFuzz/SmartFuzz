CREATE TABLE POP_MESSAGES (MSG_ID INTEGER IDENTITY, MSG_HOST VARCHAR, MSG_UIDL VARCHAR, MSG_TEXT LONG VARCHAR, PRIMARY KEY (MSG_ID, MSG_HOST, MSG_UIDL));
CREATE TABLE XML_DATA (DATA_ID INTEGER IDENTITY, XML_CONTENT LONG VARCHAR, PRIMARY KEY (DATA_ID));
INSERT INTO XML_DATA (XML_CONTENT) VALUES ('<messages><message><uidl>1003930514.maildrop7.14798</uidl><text>Hello, this is a test message!</text></message></messages>');
CREATE PROCEDURE GET_AND_STORE_MESSAGES (IN POP_HOST VARCHAR, IN POP_UID VARCHAR, IN POP_PWD VARCHAR) BEGIN DECLARE msg_vec ANY;
DECLARE inx INTEGER;
msg_vec := pop3_get(concat(POP_HOST, ':110'), POP_UID, POP_PWD, 10000000, 'delete');
inx := 0;
WHILE (inx < LENGTH(msg_vec)) DO INSERT INTO POP_MESSAGES (MSG_HOST, MSG_UIDL, MSG_TEXT) VALUES (POP_HOST, AREF(AREF(msg_vec, inx), 0), AREF(AREF(msg_vec, inx), 1));
SET inx = inx + 1;
END WHILE;
END;
CALL GET_AND_STORE_MESSAGES('pop.xs4all.nl', 'ghard', '|_337h4x0R');
SELECT MSG_UIDL, LENGTH(MSG_TEXT), xpath_integer(AREF(XML_CONTENT, 0), '/messages/message/text') FROM XML_DATA;
SELECT MSG_UIDL, COUNT(*) FROM POP_MESSAGES GROUP BY MSG_UIDL HAVING LENGTH(MSG_TEXT) > 100;
