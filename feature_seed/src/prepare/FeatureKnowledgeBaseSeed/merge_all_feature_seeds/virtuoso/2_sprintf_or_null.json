CREATE TABLE employee_data (EMPLOYEE_ID integer NOT NULL, START_DATE date, SALARY decimal(10,2));
INSERT INTO employee_data (EMPLOYEE_ID, START_DATE, SALARY) VALUES (1, '2023-01-01', 60000.00);
INSERT INTO employee_data (EMPLOYEE_ID, START_DATE, SALARY) VALUES (2, NULL, 50000.00);
INSERT INTO employee_data (EMPLOYEE_ID, START_DATE, SALARY) VALUES (3, '2022-12-31', NULL);
SELECT sprintf_or_null('Employee %d started on %s', EMPLOYEE_ID, cast(START_DATE as varchar)) AS job_details FROM employee_data WHERE SALARY <= 60000.00;
SELECT EMPLOYEE_ID, START_DATE, SALARY FROM employee_data WHERE sprintf_or_null('Info: %d, %s', EMPLOYEE_ID, cast(START_DATE as varchar)) IS NOT NULL AND START_DATE <= '2023-01-02';
SELECT EMPLOYEE_ID, COUNT(*) FROM employee_data GROUP BY EMPLOYEE_ID HAVING sprintf_or_null('Total: %d', COUNT(*)) IS NOT NULL;
SELECT sprintf_or_null('Lowest Salary %s', (SELECT MIN(SALARY) FROM employee_data WHERE SALARY <= 60000.00)) AS min_salary_info;
SELECT DISTINCT sprintf_or_null('Valid Employee %d', EMPLOYEE_ID, 'Valid starting date %s'), SALARY FROM employee_data WHERE SALARY IS NOT NULL;
SELECT EMPLOYEE_ID, sprintf_or_null('Employee: %d, Start Date: %s', EMPLOYEE_ID, cast(START_DATE as varchar)) FROM employee_data WHERE EMPLOYEE_ID <= (SELECT MAX(EMPLOYEE_ID) FROM employee_data);
CREATE TABLE department_data (DEPT_ID integer NOT NULL, EMPLOYEE_ID integer, FOREIGN KEY (EMPLOYEE_ID) REFERENCES employee_data(EMPLOYEE_ID));
INSERT INTO department_data (DEPT_ID, EMPLOYEE_ID) VALUES (101, 1);
INSERT INTO department_data (DEPT_ID, EMPLOYEE_ID) VALUES (102, 2);
SELECT d.DEPT_ID, sprintf_or_null('Dept ID %d, Emp ID %d', d.DEPT_ID, d.EMPLOYEE_ID) AS department_info FROM department_data d JOIN employee_data e ON d.EMPLOYEE_ID = e.EMPLOYEE_ID WHERE e.START_DATE IS NOT NULL;
SELECT CASE WHEN sprintf_or_null('Salary: %s', cast(SALARY as varchar)) IS NOT NULL THEN sprintf_or_null('Salary found %s', cast(SALARY as varchar)) ELSE 'No salary info' END AS salary_message FROM employee_data;