CREATE TABLE dict_test (key VARCHAR(255), value INT);
INSERT INTO dict_test (key, value) VALUES ('a', 1);
INSERT INTO dict_test (key, value) VALUES ('b', 2);
INSERT INTO dict_test (key, value) VALUES ('c', 3);
DECLARE dict, dkey, dvalue ANY;
SET dict = dict_new(10);
dict_put(dict, 'a', 1);
dict_put(dict, 'b', 2);
dict_put(dict, 'c', 3);
dict_iter_rewind(dict);
WHILE dict_iter_next(dict, dkey, dvalue) DO SELECT CONCAT('key is ', dkey, ', corresponding value is ', dvalue);
END WHILE;
dict_iter_rewind(dict);
dict_put(dict, 'd', 4);
DECLARE output_key ANY, output_value ANY;
dict_iter_rewind(dict);
WHILE dict_iter_next(dict, output_key, output_value) DO SELECT CONCAT('Iterated key: ', output_key, ' with value: ', output_value);
END WHILE;
dict_iter_rewind(dict);
SET dict = dict_new(2);
dict_put(dict, 'x', 10);
dict_put(dict, 'y', 20);
dict_iter_rewind(dict);
WHILE dict_iter_next(dict, output_key, output_value) DO SELECT CONCAT('Key: ', output_key, ' has Value: ', output_value);
END WHILE;
dict_iter_rewind(dict);
SET dict = dict_new(0);
dict_iter_rewind(dict);
DECLARE key_check, value_check ANY;
IF dict_iter_next(dict, key_check, value_check) = 0 THEN SELECT 'Iterator is at the end of the dictionary';
END IF;