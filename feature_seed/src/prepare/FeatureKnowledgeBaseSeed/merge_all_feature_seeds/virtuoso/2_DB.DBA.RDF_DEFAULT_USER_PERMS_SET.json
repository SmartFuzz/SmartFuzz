CREATE TABLE users (uname VARCHAR(50) NOT NULL, perms INT, other_info VARCHAR(100));
INSERT INTO users (uname, perms, other_info) VALUES ('demo', 7, 'user demo');
INSERT INTO users (uname, perms) VALUES ('admin', 15);
DB.DBA.RDF_DEFAULT_USER_PERMS_SET('guest', 0, 1);
DB.DBA.RDF_DEFAULT_USER_PERMS_SET('demo', 3 * (1 + 2), 0);
SELECT DB.DBA.RDF_DEFAULT_USER_PERMS_SET(uname, 7 * perms, 1) FROM users WHERE perms IS NOT NULL;
SELECT uname, perms * 2 AS double_perms FROM users WHERE perms IS NOT NULL GROUP BY uname, perms HAVING double_perms > 10;
SELECT (SELECT DB.DBA.RDF_DEFAULT_USER_PERMS_SET(u.uname, 4, 0) FROM users u WHERE u.uname = 'admin') * 3 AS admin_perms FROM users;
SELECT uname, (perms * NULL) AS null_perms FROM users WHERE perms IS NULL;
SELECT uname, (perms * 2) AS standard_perms, (SELECT perms FROM users u2 WHERE u2.uname = 'demo' LIMIT 1) AS demo_perms FROM users WHERE uname IS NOT NULL;
DB.DBA.RDF_DEFAULT_USER_PERMS_SET('test_user', CAST('4' AS INT), 0);
SELECT uname, perms * (SELECT COUNT(*) FROM users) AS multiplied_perms FROM users;
SELECT uname, DB.DBA.RDF_DEFAULT_USER_PERMS_SET(uname, (NULLIF(perms, 0) * 5), 0) FROM users WHERE uname IS NOT NULL;
CREATE TABLE permissions (uname VARCHAR(50), perm_key VARCHAR(50), perm_value INT DEFAULT 0);
INSERT INTO permissions (uname, perm_key, perm_value) VALUES ('demo', 'read', 1), ('admin', 'write', 1), ('demo', 'delete', 0);
SELECT DB.DBA.RDF_DEFAULT_USER_PERMS_SET(uname, SUM(perm_value), 0) FROM permissions GROUP BY uname HAVING SUM(perm_value) > 0;
SELECT uname, (SELECT COUNT(*) FROM permissions WHERE perm_value = 1) * perms AS total_perms FROM users;
CREATE TEMPORARY TABLE temp_users AS SELECT uname, perms FROM users WHERE perms IS NOT NULL;
SELECT uname, DB.DBA.RDF_DEFAULT_USER_PERMS_SET(uname, 1 * 2 * perms, 0) FROM temp_users;