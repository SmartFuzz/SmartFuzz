CREATE TABLE test_collection (id INT, path VARCHAR(255));
INSERT INTO test_collection (id, path) VALUES (1, '/DAV/collection1/');
INSERT INTO test_collection (id, path) VALUES (2, '/DAV/collection2/');
INSERT INTO test_collection (id, path) VALUES (3, '/DAV/collection3/');
SELECT DB.DBA.DAV_SEARCH_ID('/DAV/collection1/','c');
SELECT DB.DBA.DAV_SEARCH_PATH(1,'c');
SELECT * FROM test_collection WHERE id = (SELECT MAX(id) FROM test_collection);
SELECT DB.DBA.DAV_SEARCH_ID('/DAV/collection3/', 'R');
SELECT DB.DBA.DAV_SEARCH_PATH(2, 'P');
SELECT DB.DBA.DAV_SEARCH_ID('/DAV/', 'R') UNION SELECT DB.DBA.DAV_SEARCH_ID('/DAV/collection2/', 'C');
SELECT DB.DBA.DAV_DIR_LIST('/DAV/collection1/');
SELECT DB.DBA.DAV_DIR_LIST((SELECT path FROM test_collection WHERE id = 3));
SELECT CASE WHEN DB.DBA.DAV_SEARCH_ID('/DAV/collection1/', 'R') IS NOT NULL THEN 'Exists' ELSE 'Does not exist' END AS resource_status;
SELECT COUNT(*) FROM (SELECT DB.DBA.DAV_SEARCH_ID(path, 'c') FROM test_collection) AS temp;
SELECT DB.DBA.DAV_SEARCH_PATH((SELECT MIN(id) FROM test_collection), 'c') AS path_info;
SELECT DISTINCT DB.DBA.DAV_SEARCH_ID('/DAV/collection%', 'c') FROM test_collection WHERE path LIKE '/DAV/collection%';