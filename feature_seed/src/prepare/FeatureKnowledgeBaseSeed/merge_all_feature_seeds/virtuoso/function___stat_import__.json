CREATE TABLE test_statistics (id INT PRIMARY KEY, stat_data BLOB);
INSERT INTO test_statistics (id, stat_data) VALUES (1, string_to_file('stat.dv', serialize(stat_export()), -2));
CREATE TABLE nested_test (id INT, stat_id INT, FOREIGN KEY (stat_id) REFERENCES test_statistics(id));
INSERT INTO nested_test (id, stat_id) VALUES (1, 1);
SELECT * FROM nested_test WHERE stat_id IN (SELECT id FROM test_statistics WHERE id = 1);
SELECT * FROM test_statistics WHERE id = (SELECT MAX(id) FROM test_statistics);
SELECT * FROM test_statistics WHERE EXISTS (SELECT 1 FROM nested_test WHERE stat_id = test_statistics.id);
CREATE TABLE multi_join_test (id INT, stat1_id INT, stat2_id INT, FOREIGN KEY (stat1_id) REFERENCES test_statistics(id), FOREIGN KEY (stat2_id) REFERENCES test_statistics(id));
INSERT INTO multi_join_test (id, stat1_id, stat2_id) VALUES (1, 1, 1);
SELECT a.id, b.stat_data FROM multi_join_test a JOIN test_statistics b ON a.stat1_id = b.id WHERE a.stat2_id = 1;
SELECT a.id, (SELECT COUNT(*) FROM multi_join_test WHERE stat1_id = a.stat_id) AS count FROM test_statistics a;
INSERT INTO test_statistics (id, stat_data) VALUES (2, string_to_file('stat2.dv', serialize(stat_export()), -2));
INSERT INTO test_statistics (id, stat_data) VALUES (3, string_to_file('stat3.dv', serialize(stat_export()), -2));
SELECT * FROM test_statistics WHERE stat_data IS NOT NULL AND id IN (SELECT stat1_id FROM multi_join_test WHERE id = 1);
INSERT INTO test_statistics (id, stat_data) VALUES (4, string_to_file('stat4.dv', serialize(stat_export()), -2));
SELECT id, stat_data FROM test_statistics WHERE id = (SELECT id FROM test_statistics ORDER BY id DESC LIMIT 1);
SELECT stat_id, COUNT(*) FROM nested_test GROUP BY stat_id HAVING COUNT(*) > 1;
DELETE FROM test_statistics WHERE id = 1 RETURNING *;
SELECT * FROM test_statistics WHERE id NOT IN (SELECT stat_id FROM nested_test);