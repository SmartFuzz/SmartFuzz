CREATE TABLE test_ini_path (id INT, path VARCHAR(255));
INSERT INTO test_ini_path VALUES (1, virtuoso_ini_path());
SELECT * FROM test_ini_path WHERE path = virtuoso_ini_path();
SELECT COUNT(*) FROM test_ini_path WHERE path LIKE virtuoso_ini_path() || '%';
SELECT (SELECT path FROM test_ini_path WHERE id = 1) AS ini_file_path, virtuoso_ini_path();
CREATE TABLE test_paths (id INT, config_path VARCHAR(255) UNIQUE);
INSERT INTO test_paths VALUES (1, virtuoso_ini_path());
SELECT a.id, a.config_path FROM test_paths a JOIN test_ini_path b ON a.id = b.id WHERE a.config_path = virtuoso_ini_path();
WITH config AS (SELECT virtuoso_ini_path() AS full_path) SELECT full_path FROM config;
SELECT DISTINCT path FROM test_ini_path WHERE path IS NOT NULL AND path = virtuoso_ini_path();