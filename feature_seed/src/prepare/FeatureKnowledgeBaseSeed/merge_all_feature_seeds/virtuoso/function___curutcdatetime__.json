CREATE TABLE test_datetime (id INT, event_time DATETIME);
INSERT INTO test_datetime (id, event_time) VALUES (1, curutcdatetime());
INSERT INTO test_datetime (id, event_time) VALUES (2, curutcdatetime(500));
SELECT id, event_time FROM test_datetime WHERE event_time > curutcdatetime();
SELECT id, event_time FROM test_datetime WHERE event_time < curutcdatetime(1000);
SELECT id, event_time FROM test_datetime ORDER BY event_time DESC;
SELECT id, event_time FROM test_datetime WHERE event_time BETWEEN curutcdatetime(300) AND curutcdatetime(700);
SELECT (SELECT COUNT(*) FROM test_datetime) AS total_events, curutcdatetime() AS current_time;
SELECT id, event_time FROM test_datetime WHERE EXISTS (SELECT * FROM test_datetime WHERE event_time < curutcdatetime(300));
SELECT id, event_time FROM test_datetime AS dt1 WHERE dt1.event_time IN (SELECT event_time FROM test_datetime AS dt2 WHERE dt2.id < 5);
SELECT id, curutcdatetime(250) AS adjusted_time FROM test_datetime JOIN (SELECT id FROM test_datetime WHERE id IN (SELECT id FROM test_datetime WHERE event_time < curutcdatetime(100))) AS subquery ON test_datetime.id = subquery.id;
SELECT id, curutcdatetime() AS current_utc_time FROM test_datetime WHERE id NOT IN (SELECT id FROM test_datetime WHERE event_time > curutcdatetime(600));