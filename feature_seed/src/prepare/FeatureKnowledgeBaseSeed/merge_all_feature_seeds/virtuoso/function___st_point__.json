CREATE TABLE Cities (id INTEGER PRIMARY KEY, name VARCHAR, geometry VARCHAR);
INSERT INTO Cities (name, geometry) VALUES ('CityA', 'POINT(0 52)');
INSERT INTO Cities (name, geometry) VALUES ('CityB', 'POINT(1 53)');
INSERT INTO Cities (name, geometry) VALUES ('CityC', 'POINT(2 54)');
SELECT st_point(0, 52) AS point_geometry;
SELECT st_point(-180, 90) AS westmost_point;
SELECT st_point(180, -90) AS eastmost_point;
SELECT * FROM Cities WHERE st_intersects(geometry, st_point(0, 52));
SELECT a.name, b.name FROM Cities AS a, Cities AS b WHERE a.id <> b.id AND st_distance(a.geometry, b.geometry) < 100;
SELECT name, (bif:st_distance(geometry, st_point(0, 52))) AS distance FROM Cities ORDER BY distance LIMIT 5;
SELECT name FROM Cities WHERE st_intersects(geometry, st_point(0, 52)) OR st_intersects(geometry, st_point(1, 53));
SELECT name, ST_AsText(geometry), (SELECT COUNT(*) FROM Cities AS c2 WHERE st_distance(c2.geometry, Cities.geometry) < 100) AS nearby_count FROM Cities;
SELECT name FROM Cities WHERE geometry IS NOT NULL AND st_within(geometry, st_makeenvelope(-1, 51, 1, 53));
SELECT name FROM Cities WHERE geometry IS NOT NULL AND st_contains(st_point(0, 52), geometry);
SELECT (SELECT COUNT(*) FROM Cities) AS total_cities, st_point(0, 52) AS reference_point;
SELECT DISTINCT geometry FROM Cities WHERE st_dwithin(geometry, st_point(0, 52), 200);
SELECT name FROM Cities WHERE st_intersects(geometry, (SELECT st_point(0, 52)));