CREATE TABLE geometries (id INT PRIMARY KEY, shape GEOMETRY, description VARCHAR(255));
INSERT INTO geometries (id, shape, description) VALUES (1, 'POINT(1 2)'^^<http://www.openlinksw.com/schemas/virtrdf#Geometry>, 'A point shape');
INSERT INTO geometries (id, shape, description) VALUES (2, 'BOX(1 1, 4 4)'^^<http://www.openlinksw.com/schemas/virtrdf#Geometry>, 'A bounding box');
INSERT INTO geometries (id, shape, description) VALUES (3, 'POLYGON((2 2, 3 5, 5 3, 2 2))'^^<http://www.openlinksw.com/schemas/virtrdf#Geometry>, 'A polygon shape');
INSERT INTO geometries (id, shape, description) VALUES (4, NULL, 'A null geometry');
SELECT id, bif:ST_XMin(shape) as xmin FROM geometries WHERE bif:ST_XMin(shape) IS NOT NULL;
SELECT COUNT(*), bif:ST_XMin(shape) FROM geometries GROUP BY bif:ST_XMin(shape);
SELECT g1.id, g2.id, bif:ST_XMin(g1.shape) FROM geometries g1 JOIN geometries g2 ON bif:ST_XMin(g1.shape) > bif:ST_XMin(g2.shape);
SELECT id, bif:ST_XMin(NULLIF(shape, NULL)) as xmin FROM geometries WHERE isLiteral(shape);
SELECT g1.id, bif:ST_XMin(g1.shape) FROM geometries g1 WHERE bif:ST_XMin(g1.shape) IS NOT NULL AND g1.shape IS NOT NULL AND isLiteral(g1.shape);
SELECT id, bif:ST_XMin(COALESCE(shape, 'POINT(0 0)'^^<http://www.openlinksw.com/schemas/virtrdf#Geometry>)) as xmin FROM geometries;
SELECT g.id, bif:ST_XMin(g.shape) as xmin FROM (SELECT DISTINCT id, shape FROM geometries) g WHERE isLiteral(g.shape);
CREATE TABLE temp_geometries AS SELECT * FROM geometries WHERE shape IS NOT NULL;
ALTER TABLE temp_geometries ADD COLUMN area FLOAT;
UPDATE temp_geometries SET area = (bif:ST_XMin(shape) * bif:ST_XMin(shape));