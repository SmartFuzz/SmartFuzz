CREATE TABLE test_data (value FLOAT);
INSERT INTO test_data (value) VALUES (1), (2), (3), (4);
SELECT STDDEV(value) FROM test_data;
INSERT INTO test_data (value) VALUES (5);
SELECT STDDEV(value) FROM test_data;
CREATE TABLE more_data (id INT, value FLOAT);
INSERT INTO more_data (id, value) VALUES (1, 1), (1, 2), (2, 3), (2, 4);
SELECT id, STDDEV(value) FROM more_data GROUP BY id;
SELECT AVG(STDDEV(value)) FROM (SELECT id, value FROM more_data GROUP BY id) AS subquery;
CREATE TABLE empty_data (value FLOAT);
SELECT STDDEV(value) FROM empty_data;
CREATE TABLE edge_cases (group_id INT, val FLOAT);
INSERT INTO edge_cases (group_id, val) VALUES (1, NULL), (1, 2), (2, 5);
SELECT group_id, STDDEV(val) FROM edge_cases GROUP BY group_id;
SELECT STDDEV(val) FROM edge_cases WHERE val IS NOT NULL;
CREATE TABLE nested_test (grp INT, num FLOAT);
INSERT INTO nested_test (grp, num) VALUES (1, 10), (1, 20), (2, 30), (2, 40);
SELECT grp, STDDEV(num) FROM (SELECT * FROM nested_test WHERE grp = 1) AS filtered GROUP BY grp;
CREATE TABLE cross_join_test (a INT, b FLOAT);
INSERT INTO cross_join_test (a, b) VALUES (1, 1.0), (2, 2.0), (3, 3.0);
SELECT AVG(STDDEV(b)) FROM (SELECT a, b FROM cross_join_test) AS join_result;
SELECT DISTINCT STDDEV(value) FROM test_data HAVING STDDEV(value) IS NOT NULL;