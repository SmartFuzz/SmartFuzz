CREATE TABLE test_strings (id INTEGER, value VARCHAR);
INSERT INTO test_strings (id, value) VALUES (1, 'Abacus');
INSERT INTO test_strings (id, value) VALUES (2, 'babaab');
SELECT position('b', (SELECT value FROM test_strings WHERE id = 1));
SELECT position(2, vector('Primero', null, 2, 3.333));
SELECT position('a', (SELECT value FROM test_strings WHERE id = 2), 1, 2);
SELECT position('b', (SELECT value FROM test_strings.value FROM test_strings WHERE id = 1) || 'Final');
SELECT position('a', vector(1, 'b', NULL, 3.3, 'a', 'a'), 1, 1);
SELECT position('c', (SELECT value FROM test_strings WHERE id = 1), 0, 1);
SELECT position(NULL, vector(NULL, 1, 2, 3), 1, 1);
SELECT position('z', (SELECT value FROM test_strings WHERE id = 1), 1);
CREATE TABLE empty_test (value VARCHAR);
SELECT position('x', (SELECT value FROM empty_test), 1);
SELECT position('1', vector('1', '2', '3'), 1, 1);
SELECT position('b', vector('b', 'a', 'b', 'a', 'b'), 1, 1);
SELECT position('a', vector(1, 2, 'a', 'b', 'a'), 1, 1);
SELECT position('c', 'abcabcabc', 1, 3);