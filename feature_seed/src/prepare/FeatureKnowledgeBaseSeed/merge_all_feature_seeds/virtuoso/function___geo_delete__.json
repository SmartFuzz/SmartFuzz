CREATE TABLE geo_table (id INT PRIMARY KEY, geom GEOMETRY);
INSERT INTO geo_table (id, geom) VALUES (1, GeomFromText('POINT(1 2)', 4326));
INSERT INTO geo_table (id, geom) VALUES (2, GeomFromText('POINT(3 4)', 4326));
INSERT INTO geo_table (id, geom) VALUES (3, GeomFromText('POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))', 4326));
DELETE FROM geo_table WHERE id = 1;
SELECT * FROM geo_table WHERE id = 2;
DELETE FROM geo_table WHERE geom = GeomFromText('POINT(3 4)', 4326);
INSERT INTO geo_table (id, geom) VALUES (4, GeomFromText('POINT(1 2)', 4326));
SELECT * FROM geo_table WHERE id IN (SELECT id FROM geo_table WHERE geom IS NOT NULL);
geo_delete('geo_table', GeomFromText('POINT(1 2)', 4326));
geo_delete('geo_table', (SELECT geom FROM geo_table WHERE id = 2));
CREATE TABLE another_geo_table (id INT, reference_geom GEOMETRY, FOREIGN KEY (id) REFERENCES geo_table(id));
INSERT INTO another_geo_table (id, reference_geom) SELECT id, geom FROM geo_table;
geo_delete('another_geo_table', (SELECT reference_geom FROM another_geo_table WHERE id = 1));
SELECT * FROM geo_table WHERE id NOT IN (SELECT id FROM another_geo_table);
geo_delete('geo_table', GeomFromText('POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))', 4326));
SELECT COUNT(*) FROM geo_table WHERE ST_Contains(geom, GeomFromText('POINT(2 3)', 4326));