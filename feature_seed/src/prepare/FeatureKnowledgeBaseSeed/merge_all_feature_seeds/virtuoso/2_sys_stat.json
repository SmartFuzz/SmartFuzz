CREATE TABLE test_stats (id INT PRIMARY KEY, name VARCHAR(255), value INT);
INSERT INTO test_stats (id, name, value) VALUES (1, 'test1', 10), (2, 'test2', NULL), (3, 'test3', 20);
SELECT id, sys_stat(CONCAT(name, ' - ', COALESCE(CAST(value AS VARCHAR), 'NULL'))) AS stat FROM test_stats WHERE value IS NOT NULL;
SELECT id, name FROM test_stats WHERE value SIMILAR TO '[1-9][0-9]*';
SELECT id, name, value FROM test_stats WHERE value < (SELECT AVG(value) FROM test_stats) * 1.2;
SELECT id, sys_stat('st_dbms_name') AS db_name FROM test_stats WHERE value IS NULL GROUP BY id HAVING db_name SIMILAR TO 'OpenLink%';
SELECT id, name FROM test_stats WHERE name SIMILAR TO 'test%' AND value IS NOT NULL ORDER BY sys_stat('st_dbms_ver');
SELECT id, sys_stat(CONCAT(CAST(id AS VARCHAR), ' - ', name)) FROM test_stats WHERE name SIMILAR TO 'test1' OR id IN (SELECT id FROM test_stats WHERE value = 10);
WITH ranked AS (SELECT id, name, value, ROW_NUMBER() OVER (ORDER BY value) AS rnk FROM test_stats) SELECT id, sys_stat(CONCAT('Rank: ', rnk)) FROM ranked WHERE rnk <= 2;
DROP TABLE IF EXISTS test_stats;