CREATE TABLE geo_points (id INT PRIMARY KEY, location VARCHAR(255), coordinates GEOGRAPHY);
INSERT INTO geo_points (id, location, coordinates) VALUES (1, 'CityA', st_point(0, 52));
INSERT INTO geo_points (id, location, coordinates) VALUES (2, 'CityB', st_point(1, 53));
INSERT INTO geo_points (id, location, coordinates) VALUES (3, 'CityC', st_point(2, 51));
SELECT location, st_point(X, Y) FROM (SELECT 0 AS X, 52 AS Y) AS temp;
SELECT location, st_point(NULL, 51) AS geo_point FROM geo_points WHERE id = 1;
SELECT location, bif:st_distance(coordinates, st_point(0, 52)) AS distance FROM geo_points HAVING distance < 100;
SELECT g1.location, g2.location FROM geo_points g1 JOIN geo_points g2 ON bif:st_intersects(g1.coordinates, st_point(1, 53)) WHERE g1.id <> g2.id;
SELECT location, COUNT(*) FROM (SELECT location, bif:st_distance(coordinates, st_point(0, 52)) AS dist FROM geo_points) AS distances GROUP BY location HAVING dist < (SELECT MAX(dist) FROM (SELECT bif:st_distance(coordinates, st_point(0, 50)) AS dist FROM geo_points) AS subquery);
SELECT g.location FROM (SELECT location, st_point(0, 52) AS geo FROM geo_points) AS g WHERE g.geo IS NOT NULL ORDER BY g.geo;