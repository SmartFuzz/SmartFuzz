CREATE TABLE spatial_data (id INT PRIMARY KEY, geom BLOB);
INSERT INTO spatial_data (id, geom) VALUES (1, bif:st_geomfromtext('POLYGON((0 0, 5 0, 5 5, 0 5, 0 0))')),;
INSERT INTO spatial_data (id, geom) VALUES (2, bif:st_geomfromtext('POLYGON((3 3, 7 3, 7 7, 3 7, 3 3))'));
INSERT INTO spatial_data (id, geom) VALUES (3, bif:st_geomfromtext('POLYGON((8 8, 10 8, 10 10, 8 10, 8 8))'));
SELECT a.id, b.id FROM spatial_data AS a, spatial_data AS b WHERE bif:st_overlaps(a.geom, b.geom) AND a.id <> b.id;
SELECT COUNT(*) FROM spatial_data AS a WHERE EXISTS (SELECT 1 FROM spatial_data AS b WHERE bif:st_overlaps(a.geom, b.geom) AND a.id <> b.id);
SELECT a.id FROM spatial_data AS a WHERE bif:st_overlaps(a.geom, bif:st_geomfromtext('POLYGON((2 2, 6 2, 6 6, 2 6, 2 2))'));
CREATE TABLE more_data (id INT PRIMARY KEY, geom BLOB);
INSERT INTO more_data (id, geom) VALUES (1, bif:st_geomfromtext('POLYGON((1 1, 4 1, 4 4, 1 4, 1 1))'));
SELECT a.id, b.id FROM spatial_data AS a JOIN more_data AS b ON bif:st_overlaps(a.geom, b.geom) WHERE a.id < 3;
SELECT a.id FROM spatial_data AS a WHERE (bif:st_overlaps(a.geom, bif:st_geomfromtext('POLYGON((0 0, 10 0, 10 10, 0 10, 0 0))'))) AND a.id NOT IN (SELECT b.id FROM more_data AS b);