CREATE TABLE test_table (id INTEGER PRIMARY KEY, value VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'example1'), (2, 'example2');
CREATE FUNCTION test_func_1(value VARCHAR(255)) RETURNS INTEGER AS 'RETURN LENGTH(value);
';
CREATE FUNCTION test_func_2(id INTEGER) RETURNS VARCHAR(255) AS 'RETURN (SELECT value FROM test_table WHERE id = id);
';
SELECT sinv_create_inverse('test_func_1') AS inverse_func;
SELECT sinv_create_inverse('test_func_2') AS inverse_func;
SELECT id, sinv_create_inverse('test_func_1')(value) FROM test_table;
SELECT t.id, t.value, sinv_create_inverse('test_func_2')(t.id) FROM test_table t WHERE t.value IS NOT NULL;
CREATE TABLE another_table (ref_id INTEGER, FOREIGN KEY(ref_id) REFERENCES test_table(id));
INSERT INTO another_table (ref_id) VALUES (1), (2);
SELECT a.ref_id, sinv_create_inverse('test_func_1')(t.value) FROM another_table a JOIN test_table t ON a.ref_id = t.id;
WITH temp AS (SELECT id FROM test_table WHERE value LIKE 'example%') SELECT sinv_create_inverse('test_func_1')(value) FROM test_table WHERE id IN (SELECT id FROM temp);
SELECT sinv_create_inverse('test_func_2')(t.id) AS inverse_value FROM (SELECT * FROM test_table WHERE id > 0) AS t;