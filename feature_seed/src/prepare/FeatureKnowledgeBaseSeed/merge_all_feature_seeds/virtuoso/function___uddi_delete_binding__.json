DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM bindingTemplate WHERE serviceKey = 'service1' AND status = 'inactive');
DELETE FROM bindingTemplate WHERE bindingKey = (SELECT TOP 1 bindingKey FROM bindingTemplate ORDER BY createdDate DESC);
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM bindingTemplate bt JOIN service s ON bt.serviceKey = s.serviceKey WHERE s.serviceType = 'type1');
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM bindingTemplate WHERE bindingKey LIKE 'temp_%');
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM (SELECT bindingKey, ROW_NUMBER() OVER (PARTITION BY serviceKey ORDER BY createdDate) AS rn FROM bindingTemplate) AS subquery WHERE rn > 5);
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bt.bindingKey FROM bindingTemplate bt LEFT JOIN wsdl w ON bt.wsdlKey = w.wsdlKey WHERE w.wsdlVersion < '1.1' AND bt.status = 'active');
DELETE FROM bindingTemplate WHERE bindingKey = (SELECT MAX(bindingKey) FROM bindingTemplate WHERE serviceKey = (SELECT serviceKey FROM services WHERE name = 'serviceA'));
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM bindingTemplate WHERE serviceKey NOT IN (SELECT serviceKey FROM services WHERE createdDate >= DATEADD(month, -6, GETDATE()));
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM bindingTemplate WHERE EXISTS (SELECT 1 FROM services s WHERE s.serviceKey = bindingTemplate.serviceKey AND s.status = 'inactive'));
DELETE FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM bindingTemplate WHERE bindingKey IN (SELECT bindingKey FROM (SELECT bindingKey, COUNT(*) AS cnt FROM bindingTemplate GROUP BY bindingKey HAVING COUNT(*) > 1) AS duplicates));