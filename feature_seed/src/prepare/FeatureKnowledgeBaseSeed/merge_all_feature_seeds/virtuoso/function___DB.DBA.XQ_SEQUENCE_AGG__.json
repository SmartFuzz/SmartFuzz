CREATE TABLE test_table (id INTEGER, value INTEGER);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 30);
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM test_table;
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM test_table WHERE id > 1;
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value > 15);
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM (SELECT value FROM test_table WHERE id < 3) AS subquery;
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM test_table GROUP BY id;
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM (SELECT id, SUM(value) AS total_value FROM test_table GROUP BY id) AS aggregated;
CREATE TABLE another_table (id INTEGER, test_id INTEGER);
INSERT INTO another_table VALUES (1, 1), (2, 1), (3, 2);
SELECT DB.DBA.XQ_SEQUENCE_AGG(t.value) FROM test_table t JOIN another_table a ON t.id = a.test_id WHERE a.id = 1;
SELECT DB.DBA.XQ_SEQUENCE_AGG(t.value) FROM test_table t LEFT JOIN another_table a ON t.id = a.test_id GROUP BY a.id;
SELECT DB.DBA.XQ_SEQUENCE_AGG(t.value) FROM (SELECT t.value, a.id AS join_id FROM test_table t JOIN another_table a ON t.id = a.test_id) AS complex_query;
SELECT DB.DBA.XQ_SEQUENCE_AGG(value) FROM (SELECT DISTINCT value FROM test_table) AS unique_values;