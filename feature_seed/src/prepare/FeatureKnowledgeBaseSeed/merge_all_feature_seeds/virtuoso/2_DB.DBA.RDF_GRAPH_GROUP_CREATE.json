CREATE TABLE TestGraphGroups (id INT PRIMARY KEY, groupName VARCHAR(255) NOT NULL, memberPattern VARCHAR, comment VARCHAR);
INSERT INTO TestGraphGroups (id, groupName, memberPattern, comment) VALUES (1, 'Group1', NULL, 'First group entry');
INSERT INTO TestGraphGroups (id, groupName, memberPattern, comment) VALUES (2, 'Group2', 'pattern1', 'Second group entry');
INSERT INTO TestGraphGroups (id, groupName, memberPattern, comment) VALUES (3, 'Group3', 'pattern2', NULL);
DB.DBA.RDF_GRAPH_GROUP_CREATE(NEW TestGraphGroups('Group4', NULL, NULL), 1);
SELECT * FROM TestGraphGroups WHERE groupName = NEW TestGraphGroups('Group5', NULL, NULL).groupName;
WITH GroupStats AS (SELECT groupName, COUNT(*) AS total FROM TestGraphGroups GROUP BY groupName HAVING COUNT(*) > 0) SELECT * FROM GroupStats;
SELECT groupName, NEW TestGraphGroups(groupName, memberPattern, comment) AS newGraph FROM TestGraphGroups WHERE id < 3;
SELECT groupName, COUNT(*) OVER(PARTITION BY memberPattern) FROM TestGraphGroups WHERE memberPattern IS NOT NULL ORDER BY groupName;
DB.DBA.RDF_GRAPH_GROUP_CREATE(NEW TestGraphGroups('Group6', 'pattern3', 'Test comment'), (SELECT id FROM TestGraphGroups WHERE groupName = 'Group1'));
CREATE TABLE Test_Complex (col1 VARCHAR, col2 INT NOT NULL DEFAULT 0, col3 TIMESTAMP, UNIQUE(col1, col2));
INSERT INTO Test_Complex (col1, col2, col3) VALUES (NULL, 1, CURRENT_TIMESTAMP);
INSERT INTO Test_Complex (col1, col2) VALUES ('BoundaryCase', CAST(2147483647 AS INT));
INSERT INTO Test_Complex (col1, col2) VALUES ('ExtremePrecision', 1234567890123456789);
SELECT groupName, NEW TestGraphGroups(groupName, memberPattern) AS newGraph FROM TestGraphGroups WHERE col2 <> (SELECT MAX(col2) FROM Test_Complex) AND col1 IS NOT NULL;
DB.DBA.RDF_GRAPH_GROUP_CREATE(NEW TestGraphGroups('DropGroup', 'patternDrop', 'Drop Case'), 1);
DROP TABLE IF EXISTS TestGraphGroups;
CREATE TABLE MultiJoinTest (id INT, graphId INT, value VARCHAR);
INSERT INTO MultiJoinTest (id, graphId, value) VALUES (1, 1, 'Value1'), (2, 1, 'Value2'), (3, 2, 'Value3');
SELECT mg.groupName, COUNT(mt.value) FROM TestGraphGroups mg JOIN MultiJoinTest mt ON mg.id = mt.graphId WHERE mt.value IS NOT NULL GROUP BY mg.groupName HAVING COUNT(mt.value) > 1;