CREATE TABLE TestFreeText (ID INTEGER PRIMARY KEY, TextContent NVARCHAR(255));
CREATE FREE TEXT TRIGGER MyTrigger ON TestFreeText FOR INSERT;
INSERT INTO TestFreeText (TextContent) VALUES ('Sample text for testing');
DROP FREE TEXT TRIGGER MyTrigger;
CREATE TABLE AnotherTest (ID INTEGER PRIMARY KEY, Description NVARCHAR(255));
INSERT INTO AnotherTest (Description) VALUES ('Another test description');
CREATE FREE TEXT TRIGGER AnotherTrigger ON AnotherTest FOR UPDATE;
DROP FREE TEXT TRIGGER AnotherTrigger;
DELETE FROM TestFreeText WHERE ID = (SELECT MAX(ID) FROM TestFreeText);
DROP TABLE TestFreeText;
DROP TABLE AnotherTest;