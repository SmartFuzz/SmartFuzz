CREATE TABLE test_data (id INT PRIMARY KEY, value NUMERIC, category VARCHAR(50));
INSERT INTO test_data (id, value, category) VALUES (1, 100.5, 'A'), (2, NULL, 'B'), (3, 200.1, 'C'), (4, 300.7, 'A'), (5, 400.0, 'B');
SELECT category, STDDEV_SAMP(COALESCE(value, 0)) AS sample_stddev FROM test_data GROUP BY category HAVING category LIKE 'A%' AND STDDEV_SAMP(value) > 0;
SELECT category, STDDEV_SAMP(NULLIF(value, 0)) AS sample_stddev FROM test_data WHERE category LIKE 'A%' OR category LIKE 'B%' GROUP BY category HAVING sample_stddev IS NOT NULL;
CREATE TABLE additional_data (id INT PRIMARY KEY, amount NUMERIC, tag VARCHAR(50));
INSERT INTO additional_data (id, amount, tag) VALUES (1, 10.1, 'X'), (2, 20.2, 'Y'), (3, 30.3, 'X'), (4, 40.4, 'Z');
SELECT a.category, STDDEV_SAMP(a.value) AS stddev, (SELECT COUNT(*) FROM additional_data b WHERE b.tag LIKE '%' || a.category || '%') AS related_count FROM test_data a WHERE value IS NOT NULL GROUP BY a.category HAVING stddev < 150 AND related_count > 0;
SELECT id, (STDDEV_SAMP(value)::VARCHAR || ' ' || category) AS stddev_with_category FROM (SELECT id, value, category FROM test_data WHERE category LIKE '%B%') AS filtered WHERE stddev_with_category IS NOT NULL ORDER BY id;
SELECT STDDEV_SAMP(NULLIF(value, 200.1)) AS stddev_value FROM test_data WHERE category LIKE 'C%' OR category LIKE 'Z%';
SELECT category, (STDDEV_SAMP(CASE WHEN value IS NULL THEN 0 ELSE value END) * 100) AS adjusted_stddev FROM test_data GROUP BY category ORDER BY adjusted_stddev DESC;