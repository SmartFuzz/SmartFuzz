CREATE TABLE test_data (id INT PRIMARY KEY, value NUMERIC, term_uri VARCHAR(255));
INSERT INTO test_data (id, value, term_uri) VALUES (1, 10.5, 'http://example.org/term1'), (2, NULL, 'http://example.org/term2'), (3, 20.8, 'http://example.org/term1'), (4, 30.1, NULL);
SELECT VAR(value) AS variance_val FROM (SELECT value FROM test_data WHERE NULLIF(value, 0) IS NOT NULL) AS subquery1 GROUP BY term_uri HAVING sameTerm(term_uri, 'http://example.org/term1');
SELECT term_uri, VAR(value) AS variance_val FROM test_data GROUP BY term_uri HAVING VAR(value) > 0;
SELECT term_uri, VAR(value) AS variance_val FROM test_data WHERE sameTerm(term_uri, 'http://example.org/term2') OR (NULLIF(value, 0) IS NULL) GROUP BY term_uri HAVING variance_val < 15;
SELECT term_uri, COUNT(*) AS cnt FROM test_data WHERE VAR(value) IS NOT NULL GROUP BY term_uri HAVING sameTerm(term_uri, (SELECT term_uri FROM test_data WHERE id = 1));
CREATE TABLE edge_cases (case_id INT PRIMARY KEY, case_value VARCHAR(100));
INSERT INTO edge_cases (case_id, case_value) VALUES (1, 'NaN'), (2, 'Infinity'), (3, NULL), (4, '0'), (5, '');
SELECT VAR(CAST(case_value AS NUMERIC)) AS variance_edge FROM edge_cases WHERE case_value IS NOT NULL OR case_value <> '';
SELECT VAR(CAST(NULLIF(value, 0) AS NUMERIC)) AS variance_val FROM test_data WHERE sameTerm(term_uri, 'http://example.org/term1');