CREATE TABLE geoshapes (id SERIAL PRIMARY KEY, shape GEOMETRY, value DOUBLE PRECISION);
INSERT INTO geoshapes (shape, value) VALUES (ST_GeomFromText('POINT(1 3)'), 10.5), (ST_GeomFromText('BOX(0 0, 2 3)'), 15), (ST_GeomFromText('POLYGON((1 1, 2 1, 2 2, 1 2, 1 1))'), 5);
SELECT id, bif:st_ymax(shape) - 3 AS adjusted_ymax FROM geoshapes WHERE bif:st_ymax(shape) IS NOT NULL;
SELECT id, bif:st_ymax(shape) - bif:st_ymax(ST_GeomFromText('POINT(2 2)')) AS y_difference FROM geoshapes;
SELECT id, bif:st_ymax(shape) AS ymax FROM geoshapes WHERE value > 12 HAVING ymax < 10;
SELECT g1.id, g2.id, bif:st_ymax(g1.shape) - bif:st_ymax(g2.shape) AS y_diff FROM geoshapes g1 JOIN geoshapes g2 ON g1.value = g2.value;
WITH geo_data AS (SELECT id, bif:st_ymax(shape) AS max_y FROM geoshapes) SELECT MAX(max_y) - MIN(max_y) AS ymax_range FROM geo_data;
SELECT id, bif:st_ymax(shape) - (CASE WHEN value IS NULL THEN 0 ELSE value END) AS adjusted_ymax FROM geoshapes WHERE shape IS NOT NULL ORDER BY adjusted_ymax ASC;
SELECT id, bif:st_ymax(SHAPE) - bif:st_ymax(ST_GeomFromText('LINESTRING(0 0,3 5)')) AS height_difference FROM geoshapes WHERE bif:st_ymax(shape) IS NOT NULL ORDER BY height_difference DESC LIMIT 5;
CREATE TABLE temp_geoshapes AS SELECT *, bif:st_ymax(shape) AS y_boundary FROM geoshapes;
SELECT t1.id, bif:st_ymax(t1.shape) - bif:st_ymax(t2.shape) AS height_diff FROM temp_geoshapes t1 JOIN temp_geoshapes t2 ON t1.id <> t2.id WHERE t1.shape IS NOT NULL AND t2.shape IS NOT NULL;