CREATE TABLE foaf_person (id INT PRIMARY KEY, nick VARCHAR(100), interest VARCHAR(255));
INSERT INTO foaf_person (id, nick, interest) VALUES (1, 'dr. Jones', 'http://purl.org/rss/1.0/');
INSERT INTO foaf_person (id, nick, interest) VALUES (2, 'alice', 'http://example.org/hiking');
INSERT INTO foaf_person (id, nick, interest) VALUES (3, 'bob', 'http://example.org/cooking');
SELECT (sql:SAMPLE(?nick)), (sql:SAMPLE(?interest)) WHERE { ?p a foaf:Person . ?p foaf:nick ?nick . ?p foaf:interest ?interest . };
SELECT (sql:SAMPLE(?nick)) FROM foaf_person WHERE interest IS NOT NULL;
SELECT (sql:SAMPLE(?nick)), (sql:SAMPLE(?interest)) FROM foaf_person WHERE id IN (SELECT id FROM foaf_person WHERE interest LIKE '%http%');
SELECT (sql:SAMPLE(?nick)) FROM (SELECT nick, interest FROM foaf_person WHERE id < 3) AS temp WHERE temp.interest IS NOT NULL;
SELECT (sql:SAMPLE(?nick)) FROM foaf_person WHERE id = (SELECT MAX(id) FROM foaf_person);
SELECT (sql:SAMPLE(?nick)), (sql:SAMPLE(?interest)) FROM foaf_person WHERE nick IN (SELECT nick FROM foaf_person WHERE id < 3) GROUP BY interest;