CREATE TABLE test_status (id INT, status VARCHAR(255));
INSERT INTO test_status (id, status) VALUES (1, 'active');
INSERT INTO test_status (id, status) VALUES (2, 'inactive');
SELECT * FROM test_status WHERE status = 'active';
SELECT * FROM test_status WHERE id IN (SELECT id FROM test_status WHERE status = 'inactive');
SELECT (SELECT COUNT(*) FROM test_status WHERE status = 'active') AS active_count, (SELECT COUNT(*) FROM test_status WHERE status = 'inactive') AS inactive_count;
CREATE VIEW active_status AS SELECT * FROM test_status WHERE status = 'active';
SELECT * FROM active_status WHERE id < (SELECT MAX(id) FROM test_status);
DELETE FROM test_status WHERE id = (SELECT MIN(id) FROM test_status WHERE status = 'inactive');
SELECT t1.id, t2.status FROM test_status t1 JOIN test_status t2 ON t1.id <> t2.id;
SELECT MAX(id) FROM test_status WHERE status = (SELECT DISTINCT status FROM test_status WHERE id = 1);
STATUS('rhck');
SELECT status FROM test_status WHERE EXISTS (SELECT 1 FROM test_status WHERE id = 1);