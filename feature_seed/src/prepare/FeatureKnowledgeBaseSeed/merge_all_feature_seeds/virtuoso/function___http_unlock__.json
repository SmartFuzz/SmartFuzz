CREATE TABLE test_users (id INT PRIMARY KEY, username VARCHAR(50), password VARCHAR(50));
INSERT INTO test_users (id, username, password) VALUES (1, 'admin', 'password');
INSERT INTO test_users (id, username, password) VALUES (2, 'user', 'password123');
SELECT COUNT(*) FROM test_users WHERE password = 'password' AND username = 'admin';
SELECT * FROM test_users WHERE id IN (SELECT id FROM test_users WHERE username = 'admin');
SELECT username FROM test_users WHERE password = (SELECT password FROM test_users WHERE username = 'user');
CREATE PROCEDURE test_http_unlock AS BEGIN http_unlock('password');
END;
CALL test_http_unlock();
SELECT EXISTS(SELECT 1 FROM test_users WHERE password = 'password') AS is_valid;
SELECT * FROM test_users WHERE username = 'admin' OR EXISTS(SELECT 1 FROM test_users WHERE username = 'user' AND password = 'wrongpassword');
CREATE VIEW valid_users AS SELECT username FROM test_users WHERE password = 'password';
SELECT * FROM valid_users WHERE username LIKE 'ad%';
http_unlock('');
http_unlock('password123');
http_unlock('password' || 'extra');
http_unlock(CONCAT('pass', 'word'));