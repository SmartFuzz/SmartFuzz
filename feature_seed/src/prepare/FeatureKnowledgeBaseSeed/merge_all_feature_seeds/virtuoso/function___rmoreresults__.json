CREATE TABLE employees (id INTEGER PRIMARY KEY, name VARCHAR(100), department_id INTEGER);
CREATE TABLE departments (id INTEGER PRIMARY KEY, name VARCHAR(100));
INSERT INTO departments (id, name) VALUES (1, 'HR'), (2, 'Engineering'), (3, 'Sales');
INSERT INTO employees (id, name, department_id) VALUES (1, 'Alice', 1), (2, 'Bob', 2), (3, 'Charlie', 3), (4, 'David', 1);
SELECT * FROM employees WHERE id = 1;
SELECT * FROM employees WHERE department_id IN (SELECT id FROM departments WHERE name = 'Engineering');
SELECT e.name FROM employees e INNER JOIN departments d ON e.department_id = d.id WHERE d.name = 'Sales';
SELECT name FROM employees WHERE department_id = (SELECT id FROM departments WHERE name = 'HR') ORDER BY name;
SELECT e.name FROM employees e WHERE e.department_id = (SELECT d.id FROM departments d WHERE d.name = 'Engineering') AND e.name LIKE 'A%';
SELECT e.name, d.name FROM employees e LEFT JOIN departments d ON e.department_id = d.id WHERE d.name IS NULL;
SELECT e.name FROM employees e WHERE e.department_id = (SELECT d.id FROM departments d WHERE d.name = 'HR') AND e.id > 1;
SELECT COUNT(*) FROM employees WHERE department_id = (SELECT id FROM departments WHERE name = 'Sales');
SELECT e1.name FROM employees e1 WHERE e1.id IN (SELECT e2.id FROM employees e2 WHERE e2.department_id = (SELECT id FROM departments WHERE name = 'HR')) ORDER BY e1.name DESC;
CREATE TABLE project_assignments (employee_id INTEGER, project_id INTEGER, PRIMARY KEY (employee_id, project_id));
INSERT INTO project_assignments (employee_id, project_id) VALUES (1, 101), (2, 102), (3, 101), (4, 103);
SELECT e.name FROM employees e WHERE e.id IN (SELECT pa.employee_id FROM project_assignments pa WHERE pa.project_id IN (SELECT p.id FROM projects p WHERE p.budget > 10000));
CREATE TABLE projects (id INTEGER PRIMARY KEY, name VARCHAR(100), budget INTEGER);
INSERT INTO projects (id, name, budget) VALUES (101, 'Project A', 15000), (102, 'Project B', 2000), (103, 'Project C', 5000);