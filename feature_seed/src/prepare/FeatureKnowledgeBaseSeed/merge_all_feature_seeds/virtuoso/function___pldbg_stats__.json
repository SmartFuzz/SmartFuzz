CREATE PROCEDURE test_procedure AS BEGIN END;
CALL pldbg_stats(NULL, FALSE);
CALL pldbg_stats('test_procedure', TRUE);
CREATE TABLE coverage_stats (line_number INT, execution_count INT);
INSERT INTO coverage_stats VALUES (1, 10), (2, 5), (3, 20);
SELECT * FROM coverage_stats WHERE line_number > 0;
SELECT line_number, execution_count FROM coverage_stats WHERE execution_count = (SELECT MAX(execution_count) FROM coverage_stats);
SELECT a.line_number, b.execution_count FROM coverage_stats a JOIN coverage_stats b ON a.line_number = b.line_number WHERE a.execution_count > 0;
CALL pldbg_stats('nonexistent_procedure', FALSE);
CALL pldbg_stats('test_procedure', NULL);
CREATE TEMPORARY TABLE temp_coverage AS SELECT * FROM coverage_stats WHERE execution_count > 5;
DELETE FROM coverage_stats WHERE execution_count < 5;
SELECT COUNT(*) FROM coverage_stats WHERE line_number IS NOT NULL;
SELECT AVG(execution_count) FROM coverage_stats GROUP BY line_number HAVING AVG(execution_count) > 2;
DROP TABLE IF EXISTS temp_coverage;