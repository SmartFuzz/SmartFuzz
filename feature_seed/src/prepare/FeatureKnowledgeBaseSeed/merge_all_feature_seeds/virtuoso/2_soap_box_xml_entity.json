CREATE TABLE xml_data (id SERIAL PRIMARY KEY, xml_content XML, val INT, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO xml_data (xml_content, val) VALUES ('<root><value>42</value></root>', 42);
SELECT soap_box_xml_entity(xml_content, 'INT') AS converted_value FROM xml_data WHERE val = (SELECT MAX(val) FROM xml_data);
SELECT NEW my_custom_type(soap_box_xml_entity(xml_content, 'VARCHAR')) AS custom_instance FROM xml_data WHERE created_at > NOW() - INTERVAL '1 DAY';
SELECT val, COUNT(*) OVER (PARTITION BY soap_box_xml_entity(xml_content, 'INT')) AS count_per_value FROM xml_data GROUP BY val HAVING COUNT(*) > 1;
SELECT NEW my_custom_type(soap_box_xml_entity(xml_content, 'FLOAT') + 0.1) AS adjusted_value FROM xml_data WHERE xml_content IS NOT NULL;
INSERT INTO xml_data (xml_content, val) VALUES ('<root><value></value></root>', NULL);
SELECT soap_box_xml_entity(xml_content, 'DATE') AS date_value FROM xml_data WHERE xml_content IS NOT NULL AND val IS NOT NULL ORDER BY date_value;
UPDATE xml_data SET val = NEW my_custom_type(soap_box_xml_entity(xml_content, 'INT')) WHERE id = (SELECT MIN(id) FROM xml_data);
DROP TABLE IF EXISTS temp_xml_data;
CREATE TEMPORARY TABLE temp_xml_data AS SELECT NEW my_custom_type(soap_box_xml_entity(xml_content, 'VARCHAR')) AS custom_value FROM xml_data WHERE val IS NOT NULL;