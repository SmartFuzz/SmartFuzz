CREATE TABLE csv.tutorial.contacts (Id INTEGER NOT NULL, Fname VARCHAR(20), Sname VARCHAR(20), Age INTEGER CONSTRAINT demo_table_pk PRIMARY KEY (Id));
INSERT INTO csv.tutorial.contacts (Id, Fname, Sname, Age) VALUES (0, 'John', 'Smith', 48), (1, 'Anna', 'Clarks', 62), (2, 'Rojer', 'Danrette', 27), (3, 'Kate', 'Sigton', 56), (4, 'Tim', 'Craft', NULL);
SELECT *, bif:sha1(CONCAT(Fname, Sname, CAST(Age AS VARCHAR))) AS hash_value FROM csv.tutorial.contacts WHERE Age IS NOT NULL;
SELECT Id, Fname, Sname, Age, bif:sha1(Fname || '-' || Sname || '-' || Age) AS unique_hash FROM csv.tutorial.contacts HAVING Age > 30 AND bif:sha1(Fname || '-' || Sname) IS NOT NULL;
WITH temp_hashes AS (SELECT Id, bif:sha1(CONCAT(Id, Fname, Sname)) AS combined_hash FROM csv.tutorial.contacts) SELECT contacts.*, temp_hashes.combined_hash FROM csv.tutorial.contacts JOIN temp_hashes ON contacts.Id = temp_hashes.Id;
SELECT Age, COUNT(*) FROM csv.tutorial.contacts GROUP BY Age HAVING COUNT(*) > 1 AND bif:sha1(CAST(Age AS VARCHAR)) IS NOT NULL;
CREATE TABLE csv.tutorial.additional_contacts (Id INTEGER PRIMARY KEY, Fname VARCHAR(20), Sname VARCHAR(20));
INSERT INTO csv.tutorial.additional_contacts SELECT Id, Fname, Sname FROM csv.tutorial.contacts WHERE Fname IS NOT NULL;
SELECT A.Id, A.Fname, bif:sha1(CONCAT(A.Fname, ' ', COALESCE(B.Sname, 'N/A'))) AS combined_hash FROM csv.tutorial.additional_contacts A LEFT JOIN csv.tutorial.contacts B ON A.Id = B.Id;
CREATE TABLE csv.tutorial.testing (Id INTEGER PRIMARY KEY, Info VARCHAR(255));
INSERT INTO csv.tutorial.testing (Id, Info) VALUES (1, 'Data'), (2, NULL), (3, 'More Data'), (4, 'Extreme Info ' || REPEAT('A', 250));
SELECT bif:sha1(COALESCE(Info, 'Empty Value'), CAST(Id AS VARCHAR)) AS combined FROM csv.tutorial.testing WHERE Id > 0 AND LENGTH(Info) > 0;