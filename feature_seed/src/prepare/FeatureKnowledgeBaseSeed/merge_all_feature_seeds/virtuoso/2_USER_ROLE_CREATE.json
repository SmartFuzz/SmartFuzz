CREATE TABLE roles (id INT PRIMARY KEY, role_name VARCHAR(255) NOT NULL UNIQUE);
CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(255) NOT NULL, role_id INT, FOREIGN KEY (role_id) REFERENCES roles(id));
INSERT INTO roles (id, role_name) VALUES (1, 'admin'), (2, 'user'), (3, 'guest');
INSERT INTO users (id, username, role_id) VALUES (1, 'alice', 1), (2, 'bob', 2), (3, 'charlie', NULL);
SELECT USER_ROLE_CREATE('manager') WHERE EXISTS (SELECT 1 FROM roles WHERE role_name = 'manager' AND NOT EXISTS (SELECT 1 FROM roles r WHERE r.role_name = roles.role_name));
SELECT role_name FROM roles WHERE EXISTS (SELECT * FROM users WHERE users.role_id = roles.id AND username LIKE 'a%');
SELECT role_name FROM roles WHERE EXISTS (SELECT 1 FROM users WHERE role_id IS NULL) GROUP BY role_name HAVING COUNT(*) > 0;
SELECT COUNT(*) FROM users WHERE EXISTS (SELECT * FROM roles WHERE id = role_id UNION SELECT 0) HAVING COUNT(*) = 0;
CREATE TABLE permissions (id INT PRIMARY KEY, permission_name VARCHAR(255) NOT NULL UNIQUE);
INSERT INTO permissions (id, permission_name) VALUES (1, 'read'), (2, 'write'), (3, 'delete');
SELECT EXISTS (SELECT 1 FROM users u JOIN roles r ON u.role_id = r.id WHERE r.role_name = (SELECT role_name FROM roles WHERE id = 1));
SELECT role_name FROM roles WHERE EXISTS (SELECT 1 FROM users WHERE role_id = roles.id AND (SELECT COUNT(*) FROM users WHERE role_id IS NOT NULL) < 5);
CREATE TABLE temp_roles AS SELECT * FROM roles WHERE EXISTS (SELECT 1 FROM users WHERE users.role_id = roles.id);
ALTER TABLE users ADD CONSTRAINT chk_role CHECK (role_id IS NULL OR role_id IN (SELECT id FROM roles));
SELECT role_name FROM roles WHERE EXISTS (SELECT * FROM users WHERE role_id = NULL OR role_id = 3) ORDER BY role_name DESC;