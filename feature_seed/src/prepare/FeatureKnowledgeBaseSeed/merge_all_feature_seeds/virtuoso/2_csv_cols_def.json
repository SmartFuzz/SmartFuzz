CREATE TABLE test_csv_data (id INT, csv_file VARCHAR, geometry GEOMETRY);
INSERT INTO test_csv_data (id, csv_file, geometry) VALUES (1, 'tmp/MyContacts.csv', bif:st_point(10, 20));
SELECT csv_cols_def(csv_file), bif:st_distance(geometry, bif:st_point(10, 10)) AS distance FROM test_csv_data WHERE id = 1;
SELECT id, csv_cols_def(csv_file) AS columns, bif:st_distance(geometry, bif:st_point(30, 40)) AS distance FROM test_csv_data GROUP BY id HAVING distance < 50;
SELECT id, csv_cols_def(csv_file), COUNT(*) OVER (PARTITION BY csv_cols_def(csv_file)) AS col_count FROM test_csv_data WHERE bif:st_distance(geometry, bif:st_point(10, 20)) IS NOT NULL;
CREATE TABLE geo_data (location GEOMETRY, description VARCHAR);
INSERT INTO geo_data (location, description) VALUES (bif:st_point(0, 0), 'Point at origin'), (bif:st_point(NULL, NULL), 'Null location');
SELECT g.description, csv_cols_def('file_path') AS file_columns FROM geo_data g JOIN test_csv_data t ON bif:st_distance(g.location, t.geometry) < 100 WHERE g.location IS NOT NULL;
SELECT csv_cols_def(t.csv_file) AS file_columns, bif:st_distance(g.location, bif:st_point(15, 25)) AS distance FROM geo_data g CROSS JOIN test_csv_data t WHERE distance IS NOT NULL AND g.description LIKE '%origin%';
SELECT id, csv_cols_def(csv_file), bif:st_distance(geometry, bif:st_point(5, 5)) AS distance FROM test_csv_data ORDER BY distance DESC;