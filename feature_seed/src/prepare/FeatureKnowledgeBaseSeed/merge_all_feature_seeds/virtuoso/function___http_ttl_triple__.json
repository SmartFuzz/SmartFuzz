CREATE GRAPH <http://example.com/graph1>;
INSERT DATA { GRAPH <http://example.com/graph1> { <http://example.com/subj1> <http://example.com/pred1> <http://example.com/obj1> }};
INSERT DATA { GRAPH <http://example.com/graph1> { <http://example.com/subj2> <http://example.com/pred2> <http://example.com/obj2> }};
CREATE PROCEDURE test_http_ttl_triple INOUT ses any BEGIN SET ses = string_output();
http_ttl_triple(env, '<http://example.com/subj1>', '<http://example.com/pred1>', '<http://example.com/obj1>', ses);
http(' .', ses);
END;
CREATE PROCEDURE test_http_ttl_multiple_triples INOUT ses any BEGIN DECLARE triples any;
SET triples = vector (dict_new(3));
triples[0] := vector('<http://example.com/subj1>', '<http://example.com/pred1>', '<http://example.com/obj1>');
triples[1] := vector('<http://example.com/subj2>', '<http://example.com/pred2>', '<http://example.com/obj2>');
triples[2] := vector('<http://example.com/subj3>', '<http://example.com/pred3>', '<http://example.com/obj3>');
FOR i IN 0..length(triples)-1 DO http_ttl_triple(env, triples[i][0], triples[i][1], triples[i][2], ses);
END;
http(' .', ses);
END;
SELECT * FROM (SELECT ?s ?p ?o { GRAPH <http://example.com/graph1> { ?s ?p ?o } } ORDER BY ?s) AS sub LIMIT 10;
CREATE GRAPH <http://example.com/graph2>;
INSERT DATA { GRAPH <http://example.com/graph2> { <http://example.com/subj4> <http://example.com/pred4> <http://example.com/obj4> }};
CREATE PROCEDURE dump_graph2_as_ttl(IN srcgraph VARCHAR, OUT ses any) BEGIN SET ses = string_output();
FOR (SELECT * FROM ( SELECT ?s ?p ?o { GRAPH <http://example.com/graph2> { ?s ?p ?o } } ) AS sub OPTION (LOOP)) DO http_ttl_triple(env, ?s, ?p, ?o, ses);
END;
http(' .', ses);
END;
CREATE PROCEDURE dump_with_length_limit(IN srcgraph VARCHAR, IN out_file VARCHAR, INOUT ses any) BEGIN DECLARE file_len INTEGER;
SET file_len = 0;
http_ttl_triple(env, '<http://example.com/subj5>', '<http://example.com/pred5>', '<http://example.com/obj5>', ses);
IF length(ses) > 100 THEN http(' .', ses);
END IF;
END;