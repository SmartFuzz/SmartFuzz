CREATE TABLE "Demo"."demo"."Employees" ("FirstName" VARCHAR(50), "LastName" VARCHAR(50), "Title" VARCHAR(50));
INSERT INTO "Demo"."demo"."Employees" ("FirstName", "LastName", "Title") VALUES ('Nancy', 'Davolio', 'Sales Representative');
