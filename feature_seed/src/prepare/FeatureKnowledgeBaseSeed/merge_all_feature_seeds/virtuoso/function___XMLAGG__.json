SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', "FirstName", ' ', "LastName"))) FROM "Demo"."demo"."Employees" WHERE "Title" = 'Sales Representative';
SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', "FirstName", ' ', "LastName"))) FROM (SELECT "FirstName", "LastName" FROM "Demo"."demo"."Employees" WHERE "Title"= 'Sales Representative' ORDER BY "FirstName", "LastName") as subq;
SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', full_name))) FROM (SELECT CONCAT("FirstName", ' ', "LastName") as full_name FROM "Demo"."demo"."Employees" WHERE "Title"= 'Sales Representative' ORDER BY full_name) as subq;
SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', "FirstName"))) FROM (SELECT "FirstName" FROM "Demo"."demo"."Employees" WHERE "Title"= 'Sales Representative' ORDER BY "FirstName") as subq WHERE EXISTS (SELECT 1 FROM "Demo"."demo"."Employees" WHERE "Title"='Sales Representative');
SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', "FirstName"))) FROM "Demo"."demo"."Employees" WHERE "Title" = 'Sales Representative' GROUP BY "Title";
SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', CONCAT("FirstName", ' ', "LastName")))) FROM "Demo"."demo"."Employees" WHERE "Title" = 'Sales Representative' HAVING COUNT(*) > 2;
SELECT XMLELEMENT ('Emp', XMLATTRIBUTES ('Sales Representative' as "Title"), XMLAGG (XMLELEMENT ('Name', "FirstName"))) FROM (SELECT DISTINCT "FirstName" FROM "Demo"."demo"."Employees" WHERE "Title"= 'Sales Representative') as subq;