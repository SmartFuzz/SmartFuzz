CREATE TABLE test_strings (id INT, str VARCHAR(255));
INSERT INTO test_strings (id, str) VALUES (1, 'Hello World!');
INSERT INTO test_strings (id, str) VALUES (2, 'Virtuoso Database');
INSERT INTO test_strings (id, str) VALUES (3, 'Fuzz Testing');
SELECT substring(str, 1, 5) FROM test_strings WHERE id = 1;
SELECT substring(str, 8, 5) FROM test_strings WHERE id = 1;
SELECT substring(str, 1, 50) FROM test_strings WHERE id = 2;
SELECT substring(str, -1, 5) FROM test_strings WHERE id = 3;
SELECT id, substring(str, 1, 4) AS first_part FROM test_strings WHERE str IS NOT NULL;
SELECT id, substring(str, 1, LENGTH(str)) AS full_string FROM test_strings;
SELECT id, substring(str, 1, LENGTH(str) - 1) AS all_but_last FROM test_strings;
SELECT t1.id, substring(t2.str, 1, 3) FROM test_strings t1 JOIN test_strings t2 ON t1.id = t2.id WHERE t1.id = 2;
SELECT substring(str, 2, 3) FROM (SELECT DISTINCT str FROM test_strings) AS unique_strings;
SELECT id FROM test_strings WHERE substring(str, 1, 5) IN (SELECT substring(str, 1, 5) FROM test_strings WHERE id < 3);
SELECT id, substring(str, 1, 5) AS sub_str FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE str LIKE 'V%');
DELETE FROM test_strings WHERE id = 1;
SELECT substring(str, 5, 5) FROM test_strings WHERE id = 2;
SELECT COUNT(substring(str, 1, 3)) FROM test_strings;