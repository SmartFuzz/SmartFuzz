CREATE TABLE test_strings (id INT, value VARCHAR(100));
INSERT INTO test_strings (id, value) VALUES (1, '   Hello World!'), (2, '!!!Edge Case!!!');
SELECT id, ltrim(value, ' ') != 'Hello World!' AS is_not_equal FROM test_strings WHERE value IS NOT NULL;
SELECT id, ltrim(value, '!') != ltrim(value, ' ') AS comparison FROM test_strings;
CREATE TABLE users (user_id INT PRIMARY KEY, username VARCHAR(50), status VARCHAR(20));
INSERT INTO users (user_id, username, status) VALUES (1, 'user_one', 'active'), (2, 'user_two', 'inactive'), (3, '   user_three   ', NULL);
SELECT u.user_id, ltrim(u.username) != 'user_four' AS is_different FROM users u WHERE u.status IS NULL;
SELECT u.user_id, COUNT(*) FROM users u JOIN test_strings s ON ltrim(s.value, '!') != '' GROUP BY u.user_id HAVING COUNT(*) != 0;
SELECT DISTINCT u.user_id FROM users u WHERE ltrim(u.username) != 'user_one' AND EXISTS (SELECT 1 FROM test_strings s WHERE s.value IS NOT NULL);
CREATE TABLE temp_data (data_id INT, description VARCHAR(200));
INSERT INTO temp_data (data_id, description) VALUES (1, ''), (2, NULL), (3, 'Ltrim test!');
SELECT data_id, ltrim(description) != '' AS is_not_empty FROM temp_data WHERE description IS NOT NULL;
SELECT COUNT(*) FROM (SELECT data_id, ltrim(description) FROM temp_data WHERE ltrim(description, ' ') != '') AS temp;
SELECT COUNT(*) OVER (PARTITION BY ltrim(username) = 'user_one') AS partition_count FROM users;