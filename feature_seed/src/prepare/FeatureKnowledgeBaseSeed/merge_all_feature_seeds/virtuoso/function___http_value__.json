CREATE TABLE test_table (id INT, content VARCHAR(255));
INSERT INTO test_table VALUES (1, '<b>test</b>'), (2, 'foo & bar');
SELECT http_value(id, content) FROM test_table WHERE id = 1;
SELECT http_value(12, '<li>Sample Item</li>') AS list_item;
SELECT http_value('% <b>') AS escaped_value;
SELECT http_value('foo & bar') AS escaped_content FROM test_table WHERE id = 2;
SELECT (SELECT http_value(content) FROM test_table WHERE id = 1) AS inner_value;
SELECT t.id, http_value(t.content) FROM test_table t WHERE t.id IN (SELECT id FROM test_table WHERE content LIKE '%<b>%');
SELECT t1.id, http_value(t2.content) FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.content LIKE '%&%';
SELECT COUNT(*) FROM (SELECT http_value(content) FROM test_table) AS subquery;
SELECT http_value('Sample text with special char %') AS http_encoded;
SELECT http_value('More <b>important</b> text') AS bold_text;