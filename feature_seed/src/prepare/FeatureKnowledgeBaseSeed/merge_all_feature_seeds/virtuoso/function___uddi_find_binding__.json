CREATE TABLE bindingTemplate (id INT PRIMARY KEY, bindingDetail VARCHAR(255), criteria VARCHAR(255));
INSERT INTO bindingTemplate (id, bindingDetail, criteria) VALUES (1, 'Binding Detail 1', 'Criteria A');
INSERT INTO bindingTemplate (id, bindingDetail, criteria) VALUES (2, 'Binding Detail 2', 'Criteria B');
INSERT INTO bindingTemplate (id, bindingDetail, criteria) VALUES (3, 'Binding Detail 3', 'Criteria A');
SELECT * FROM bindingTemplate WHERE criteria = 'Criteria A';
SELECT * FROM bindingTemplate WHERE criteria IN ('Criteria A', 'Criteria B');
SELECT * FROM bindingTemplate WHERE id = (SELECT MIN(id) FROM bindingTemplate WHERE criteria = 'Criteria A');
SELECT * FROM bindingTemplate WHERE id IN (SELECT id FROM bindingTemplate WHERE criteria = 'Criteria A' OR criteria = 'Criteria B');
SELECT COUNT(*) FROM bindingTemplate WHERE criteria = 'Criteria C';
SELECT b1.* FROM bindingTemplate b1 JOIN bindingTemplate b2 ON b1.criteria = b2.criteria WHERE b1.id <> b2.id;
CREATE TABLE bindingDetails (id INT PRIMARY KEY, bindingID INT, additionalInfo VARCHAR(255), FOREIGN KEY (bindingID) REFERENCES bindingTemplate(id));
INSERT INTO bindingDetails (id, bindingID, additionalInfo) VALUES (1, 1, 'Additional Info 1');
INSERT INTO bindingDetails (id, bindingID, additionalInfo) VALUES (2, 2, 'Additional Info 2');
SELECT bd.additionalInfo FROM bindingDetails bd JOIN bindingTemplate bt ON bd.bindingID = bt.id WHERE bt.criteria = 'Criteria A';
SELECT bt.id, GROUP_CONCAT(bd.additionalInfo) FROM bindingTemplate bt LEFT JOIN bindingDetails bd ON bt.id = bd.bindingID GROUP BY bt.id;
SELECT COUNT(*) FROM bindingTemplate WHERE criteria LIKE 'Criteria%';
SELECT * FROM bindingTemplate WHERE bindingDetail LIKE '%Binding%';