CREATE TABLE lc_basic (id UInt16, strings LowCardinality(String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO lc_basic VALUES (1, 'apple'), (2, 'banana'), (3, 'apple'), (4, 'orange'), (5, 'banana');
SELECT id, count() FROM lc_basic GROUP BY strings ORDER BY count() DESC;
CREATE TABLE lc_large (id UInt16, strings LowCardinality(String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO lc_large SELECT number, concat('string_', toString(number)) FROM numbers(100000);
CREATE TABLE lc_nested (id UInt16, strings LowCardinality(String), parent_id UInt16) ENGINE = MergeTree() ORDER BY id;
INSERT INTO lc_nested VALUES (1, 'parent_1', 0), (2, 'child_1', 1), (3, 'child_2', 1), (4, 'parent_2', 0);
SELECT parent.id, parent.strings FROM lc_nested AS parent JOIN lc_nested AS child ON parent.id = child.parent_id WHERE child.strings = 'child_1';
CREATE TABLE lc_combined (id UInt16, strings LowCardinality(String), value Float32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO lc_combined VALUES (1, 'value_a', 2.0), (2, 'value_b', 3.5), (3, 'value_a', 5.1), (4, 'value_c', 4.2);
SELECT strings, SUM(value) FROM lc_combined GROUP BY strings HAVING SUM(value) > 4.0;
CREATE TABLE lc_subquery (id UInt16, strings LowCardinality(String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO lc_subquery VALUES (1, 'cat'), (2, 'dog'), (3, 'fish');
SELECT * FROM lc_subquery WHERE strings IN (SELECT strings FROM lc_subquery WHERE id >= 2);