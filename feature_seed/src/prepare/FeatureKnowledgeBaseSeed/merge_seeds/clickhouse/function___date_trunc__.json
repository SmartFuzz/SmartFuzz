CREATE TABLE example_dates (event_time DateTime64(3), event_name String);
INSERT INTO example_dates VALUES (now(), 'event1'), (now() - INTERVAL 12 HOUR, 'event2'), (now() - INTERVAL 1 DAY, 'event3');
SELECT event_name, date_trunc('day', event_time) AS truncated_date FROM example_dates;
SELECT event_name, date_trunc('minute', event_time) AS truncated_minute FROM example_dates WHERE event_time > now() - INTERVAL 1 DAY;
SELECT event_name, date_trunc('hour', event_time) AS truncated_hour FROM example_dates WHERE event_name = 'event1';
CREATE TABLE timezone_test (record_time DateTime64(3) DEFAULT now(), description String);
INSERT INTO timezone_test VALUES (now(), 'record1'), (now() - INTERVAL 1 HOUR, 'record2');
SELECT description, date_trunc('quarter', record_time, 'Asia/Istanbul') AS truncated_quarter FROM timezone_test;
SELECT a.event_name, date_trunc('week', a.event_time) AS truncated_week FROM example_dates a JOIN timezone_test b ON a.event_time > b.record_time;
SELECT date_trunc('year', now() - INTERVAL 3 MONTH) AS start_of_year, date_trunc('year', now()) AS start_of_current_year;
SELECT date_trunc('nanosecond', now() + INTERVAL 1 NANOSECOND) AS next_nanosecond;