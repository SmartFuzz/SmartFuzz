CREATE TABLE test_log10 (value Float64);
INSERT INTO test_log10 VALUES (1), (10), (100), (1000), (0.1), (0.01), (-1), (-10);
SELECT log10(value) FROM test_log10 WHERE value > 0;
SELECT value, log10(value) FROM test_log10 ORDER BY value ASC;
SELECT AVG(log10(value)) AS avg_log10 FROM test_log10 WHERE value > 0;
CREATE TABLE additional_data (id UInt32, value Float64);
INSERT INTO additional_data VALUES (1, 10), (2, 100), (3, 1000);
SELECT a.value, log10(a.value) FROM test_log10 AS a JOIN additional_data AS b ON a.value = b.value;
SELECT log10(x) FROM (SELECT value AS x FROM test_log10) AS subquery WHERE x > 0;
SELECT DISTINCT log10(value + 1) FROM test_log10 WHERE value > 0;
SELECT id, log10(value) AS log_value FROM additional_data WHERE log_value > 1;