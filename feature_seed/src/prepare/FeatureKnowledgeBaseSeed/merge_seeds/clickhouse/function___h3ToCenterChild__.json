CREATE TABLE h3_data (h3_index UInt64, resolution UInt8) ENGINE = MergeTree() ORDER BY h3_index;
INSERT INTO h3_data VALUES (577023702256844799, 1), (577023702255300000, 1), (577023702256844799, 0);
SELECT h3ToCenterChild(h3_index, resolution) AS center_child FROM h3_data WHERE resolution = 1;
SELECT h3ToCenterChild(577023702256844799, 0) AS center_child;
SELECT h3ToCenterChild(577023702256844799, 15) AS center_child;
SELECT h3ToCenterChild(h3_index, resolution) FROM (SELECT h3_index, resolution FROM h3_data WHERE resolution BETWEEN 0 AND 15) AS subquery;
SELECT t1.h3_index, t2.center_child FROM h3_data AS t1 JOIN (SELECT h3ToCenterChild(h3_index, resolution) AS center_child FROM h3_data) AS t2 ON t1.h3_index = t2.center_child WHERE t1.resolution = 1;
SELECT h3ToCenterChild(0, 1) AS center_child;
SELECT h3ToCenterChild(577023702256844799, 1) AS center_child;
SELECT h3ToCenterChild(577023702256844799, 2) AS center_child;
WITH (SELECT h3_index FROM h3_data WHERE resolution = 1 LIMIT 1) AS idx SELECT h3ToCenterChild(idx, 1) AS center_child;
CREATE TABLE h3_test (id UInt32, h3_index UInt64, resolution UInt8) ENGINE = MergeTree() ORDER BY id;
INSERT INTO h3_test VALUES (1, 577023702256844799, 1), (2, 0, 15), (3, 123456789012345678, 5);
SELECT id, h3_index, resolution, h3ToCenterChild(h3_index, resolution) AS center_child FROM h3_test WHERE h3_index != 0;