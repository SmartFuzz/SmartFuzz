CREATE TABLE test_lessOrEquals (id UInt32, value UInt32);
INSERT INTO test_lessOrEquals VALUES (1, 10), (2, 20), (3, 30);
SELECT * FROM test_lessOrEquals WHERE value <= 20;
SELECT * FROM test_lessOrEquals WHERE value <= (SELECT max(value) FROM test_lessOrEquals WHERE id < 3);
CREATE TABLE test_composite (id UInt32, category String, amount Float32);
INSERT INTO test_composite VALUES (1, 'A', 15.5), (2, 'B', 25.0), (3, 'A', 10.0);
SELECT * FROM test_composite WHERE amount <= (SELECT avg(amount) FROM test_composite WHERE category = 'A');
SELECT a.id FROM test_lessOrEquals a JOIN test_composite b ON a.id = b.id WHERE b.amount <= 20;
SELECT (SELECT count(*) FROM test_composite WHERE category = 'A') AS countA, (SELECT count(*) FROM test_composite WHERE category = 'B') AS countB WHERE countA <= countB;
CREATE TABLE test_join (id UInt32, value1 UInt32, value2 UInt32);
INSERT INTO test_join VALUES (1, 10, 15), (2, 20, 5);
SELECT * FROM test_join WHERE value1 <= value2;
SELECT * FROM test_join WHERE value1 <= (SELECT value1 FROM test_join WHERE id = 2);
CREATE TABLE threshold_test (id UInt32, threshold Float32);
INSERT INTO threshold_test VALUES (1, 5.0), (2, 7.5);
SELECT id FROM threshold_test WHERE threshold <= (SELECT max(threshold) FROM threshold_test WHERE id = 1);