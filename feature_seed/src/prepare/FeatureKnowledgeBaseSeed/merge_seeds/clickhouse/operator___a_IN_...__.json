CREATE TABLE test_in (id UInt32, value String);
INSERT INTO test_in VALUES (1, 'apple'), (2, 'banana'), (3, 'cherry'), (4, 'date');
SELECT * FROM test_in WHERE value IN ('apple', 'cherry');
SELECT * FROM test_in WHERE id IN (SELECT id FROM test_in WHERE value LIKE 'b%');
CREATE TABLE test_in2 (id UInt32, category String);
INSERT INTO test_in2 VALUES (1, 'fruit'), (2, 'vegetable'), (3, 'grain');
SELECT t1.value FROM test_in t1 JOIN test_in2 t2 ON t1.id = t2.id WHERE t1.value IN ('apple', 'banana') AND t2.category = 'fruit';
SELECT count(*) FROM test_in WHERE id IN (SELECT id FROM test_in2);
SELECT value FROM test_in WHERE value IN ('fig', 'grape') UNION SELECT value FROM test_in WHERE value IN ('banana');
CREATE TABLE test_in3 (id UInt32, user_id UInt32, score Float32);
INSERT INTO test_in3 VALUES (1, 1, 10.5), (2, 2, 8.0), (3, 1, 9.5), (4, 3, 7.0);
SELECT * FROM test_in3 WHERE user_id IN (SELECT user_id FROM test_in3 WHERE score > 9.0) AND score IN (8.0, 10.5);
SELECT id FROM test_in WHERE id IN (1, 2, 3, 4, 5);