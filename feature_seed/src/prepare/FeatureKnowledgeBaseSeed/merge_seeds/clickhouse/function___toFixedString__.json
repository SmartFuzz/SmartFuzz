CREATE TABLE test_fixed_string (id UInt32, str_value String);
INSERT INTO test_fixed_string VALUES (1, 'foo');
INSERT INTO test_fixed_string VALUES (2, 'bar');
INSERT INTO test_fixed_string VALUES (3, 'longer than fixed');
SELECT toFixedString(str_value, 8) AS fixed_str FROM test_fixed_string;
SELECT id, toFixedString(str_value, 5) AS fixed_str FROM test_fixed_string WHERE id = 1;
SELECT id, toFixedString(str_value, 10) AS fixed_str FROM (SELECT str_value, id FROM test_fixed_string WHERE id IN (1, 2));
CREATE TABLE test_join (id UInt32, fk UInt32);
INSERT INTO test_join VALUES (1, 1), (2, 2);
SELECT j.id, toFixedString(t.str_value, 8) AS fixed_str FROM test_join j JOIN test_fixed_string t ON j.fk = t.id;
WITH (SELECT toFixedString('testing', 12)) AS fixed_value SELECT fixed_value AS padded_value;
SELECT toFixedString(str_value, 4) AS fixed_str FROM (SELECT str_value FROM test_fixed_string) AS subquery WHERE str_value IS NOT NULL;
CREATE TABLE test_limit (str_value String) ENGINE = MergeTree() PRIMARY KEY str_value ORDER BY str_value;
INSERT INTO test_limit VALUES ('short'), ('much longer string'), ('exactly8');
SELECT toFixedString(str_value, 8) AS fixed_str FROM test_limit WHERE LENGTH(str_value) <= 8 ORDER BY str_value;
SELECT id, toFixedString(str_value, 8) AS fixed_str FROM test_fixed_string GROUP BY id, str_value;