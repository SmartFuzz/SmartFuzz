CREATE TABLE test_array (arr1 Array(Int32)) ENGINE = Memory;
INSERT INTO test_array VALUES ([1, null, 3, 11, 12, null, null, 5, 6, 14, null, null]);
SELECT arrayReverseFill(x -> not isNull(x), arr1) AS res FROM test_array;
SELECT arrayReverseFill(x -> x < 10, arr1) AS res FROM test_array;
CREATE TABLE test_data (id Int32, value Array(Int32)) ENGINE = Memory;
INSERT INTO test_data VALUES (1, [null, 2, null, 4, null]), (2, [10, null, null, 3, null]);
SELECT id, arrayReverseFill(x -> not isNull(x), value) AS filled_values FROM test_data;
CREATE TABLE nested_test (id Int32, arr1 Array(Int32), arr2 Array(Int32)) ENGINE = Memory;
INSERT INTO nested_test VALUES (1, [1, 2, null, 4], [null, 3, null, 5]);
SELECT id, arrayReverseFill(x -> not isNull(x), arr1) AS filled_arr1, arrayReverseFill(x -> not isNull(x), arr2) AS filled_arr2 FROM nested_test;
SELECT id, arrayReverseFill(x -> x < 5, arr1) AS res FROM nested_test WHERE id = 1;
SELECT id, arrayReverseFill(x -> x = 3, arr2) AS res FROM nested_test WHERE id = 1;
CREATE TABLE complex_test (x Int32, y Array(Int32), z Array(Int32)) ENGINE = Memory;
INSERT INTO complex_test VALUES (1, [1, null, 3], [null, null, 4]), (2, [null, 5, 6], [7, null, null]);
SELECT x, arrayReverseFill(x -> not isNull(x), y) AS filled_y FROM complex_test;
SELECT x, arrayReverseFill(x -> x > 3, z) AS filled_z FROM complex_test WHERE x = 2;
SELECT (SELECT arrayReverseFill(x -> not isNull(x), y) FROM complex_test WHERE x = 1) AS filled_values;