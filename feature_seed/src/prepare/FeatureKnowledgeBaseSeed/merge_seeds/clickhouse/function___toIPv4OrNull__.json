CREATE TABLE ip_addresses (ip STRING);
INSERT INTO ip_addresses VALUES ('192.168.1.1'), ('256.300.1.1'), ('192.168.1.256'), ('10.0.0.1'), ('invalid_ip'), ('172.16.254.1');
SELECT ip, toIPv4OrNull(ip) AS result FROM ip_addresses;
SELECT COUNT(*) FROM ip_addresses WHERE toIPv4OrNull(ip) IS NULL;
WITH 'fe80:2030:31:24' AS invalid_input SELECT toIPv4OrNull(invalid_input) AS result;
SELECT ip, toIPv4OrNull(ip) AS result FROM ip_addresses WHERE result IS NOT NULL;
SELECT ip, toIPv4OrNull(ip) AS result FROM ip_addresses ORDER BY result DESC;
SELECT DISTINCT toIPv4OrNull(ip) FROM ip_addresses;
WITH (SELECT ip FROM ip_addresses WHERE toIPv4OrNull(ip) IS NOT NULL) AS valid_ips SELECT COUNT(*) FROM valid_ips;
SELECT ip, (SELECT toIPv4OrNull(ip) FROM ip_addresses WHERE ip = '10.0.0.1') AS single_result FROM ip_addresses;