CREATE TABLE regions (id UInt32, name String);
INSERT INTO regions VALUES (1, 'Region A'), (2, 'Region B'), (3, 'Region C'), (4, 'Region D');
CREATE TABLE region_lookup (region_id UInt32, parent_region_id UInt32);
INSERT INTO region_lookup VALUES (1, 1), (2, 1), (3, 2), (4, 3);
SELECT regionToName(n1.id, 'en') || (regionIn(n1.id, n2.id) ? ' is in ' : ' is not in ') || regionToName(n2.id, 'en') FROM regions AS n1 CROSS JOIN regions AS n2;
SELECT n1.id, n2.id, regionIn(n1.id, n2.id) AS is_in FROM regions AS n1 JOIN region_lookup AS n2 ON n1.id = n2.region_id;
SELECT n1.id, n2.id, regionIn(n1.id, n2.region_id) AS is_in FROM regions AS n1 JOIN region_lookup AS n2 ON n1.id = n2.region_id WHERE n2.parent_region_id = 1;
SELECT regionToName(n1.id, 'en') || ' is ' || (regionIn(n1.id, n2.id) ? 'in' : 'not in') || ' region ' || regionToName(n2.id, 'en') FROM (SELECT id FROM regions WHERE id <= 3) AS n1 CROSS JOIN (SELECT id FROM regions WHERE id <= 4) AS n2;
SELECT regionToName(lhs.id, 'en') AS lhs_name, regionToName(rhs.id, 'en') AS rhs_name, regionIn(lhs.id, rhs.id) AS belongs FROM (SELECT * FROM regions) AS lhs CROSS JOIN (SELECT * FROM regions) AS rhs WHERE lhs.id < rhs.id;
SELECT regionToName(n1.id, 'en') || (regionIn(n1.id, region_lookup.parent_region_id) ? ' belongs to ' : ' does not belong to ') || regionToName(region_lookup.parent_region_id, 'en') FROM regions AS n1 JOIN region_lookup ON n1.id = region_lookup.region_id WHERE region_lookup.region_id IN (1, 2);