CREATE TABLE test_dates (date_col Date, date_time_col DateTime, date_time_string_col String);
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
SELECT addHours(date_col, 12) AS add_hours_date FROM test_dates;
SELECT addHours(date_time_col, 5) AS add_hours_date_time FROM test_dates;
SELECT addHours(date_time_string_col, 24) AS add_hours_date_time_string FROM test_dates;
WITH toDate('2024-01-01') AS date, toDateTime('2024-01-01 00:00:00') AS date_time, '2024-01-01 00:00:00' AS date_time_string SELECT addHours(date, 0) AS add_hours_date_zero, addHours(date_time, -12) AS add_hours_date_time_negative FROM test_dates;
WITH (SELECT toDate('2024-01-01') AS subquery_date) AS subquery SELECT addHours(subquery_date, 72) AS add_hours_subquery_date FROM test_dates;
WITH date_time_col AS (SELECT date_time_col FROM test_dates) SELECT addHours(date_time_col, 48) AS add_hours_nested FROM date_time_col;
CREATE TABLE date_test (test_date Date);
INSERT INTO date_test VALUES (toDate('2024-01-01'));
SELECT addHours((SELECT test_date FROM date_test), 36) AS add_hours_from_subselect;
WITH (SELECT date_time_col FROM test_dates LIMIT 1) AS retrieved_time SELECT addHours(retrieved_time, 150) AS add_hours_retrieved_time;