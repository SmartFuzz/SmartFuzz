SELECT emptyArrayFloat32();
CREATE TABLE test_empty_array (id UInt32, arr Array(Float32));
INSERT INTO test_empty_array VALUES (1, emptyArrayFloat32());
SELECT id, arr FROM test_empty_array WHERE arr = emptyArrayFloat32();
SELECT id, (arr = emptyArrayFloat32()) AS is_empty FROM test_empty_array;
CREATE TABLE another_table (id UInt32);
INSERT INTO another_table VALUES (1), (2), (3);
SELECT t.id, emptyArrayFloat32() AS empty_arr FROM another_table AS t JOIN test_empty_array AS ea ON t.id = ea.id;
SELECT emptyArrayFloat32() AS empty_arr UNION ALL SELECT emptyArrayFloat32();
WITH empty_arr AS (SELECT emptyArrayFloat32()) SELECT COUNT(*) FROM empty_arr;
SELECT id FROM test_empty_array WHERE arr IS NOT DISTINCT FROM emptyArrayFloat32();
SELECT id, arrayLength(arr) AS length FROM test_empty_array HAVING length = 0;
SELECT arrayReduce('max', emptyArrayFloat32()) AS max_value;
CREATE TABLE complex_table (id UInt32, arr Array(Float32));
INSERT INTO complex_table VALUES (1, emptyArrayFloat32()), (2, [1.0, 2.0]);
SELECT ct.id, emptyArrayFloat32() AS empty_arr FROM complex_table AS ct WHERE arrayLength(ct.arr) = 0;