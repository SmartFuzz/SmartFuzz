CREATE TABLE test_dates (id UInt32, event_time DateTime);
INSERT INTO test_dates VALUES (1, toDateTime('2023-01-15 00:00:00'));
INSERT INTO test_dates VALUES (2, toDateTime('2023-04-21 10:20:30'));
INSERT INTO test_dates VALUES (3, toDateTime('2023-07-10 15:45:00'));
INSERT INTO test_dates VALUES (4, toDateTime('2023-10-05 17:30:00'));
INSERT INTO test_dates VALUES (5, toDateTime('2023-12-31 23:59:59'));
SELECT id, toQuarter(event_time) AS quarter FROM test_dates WHERE event_time >= toDateTime('2023-01-01 00:00:00') AND event_time < toDateTime('2024-01-01 00:00:00');
SELECT id, toQuarter(event_time) AS quarter FROM test_dates WHERE event_time IN (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-04-21 10:20:30'), toDateTime('2023-10-05 17:30:00'));
SELECT t1.id, t2.quarter FROM (SELECT id, toQuarter(event_time) AS quarter FROM test_dates) AS t2 JOIN (SELECT DISTINCT id FROM test_dates WHERE id % 2 = 1) AS t1 ON t1.id = t2.id;
SELECT count(*) AS total_events, toQuarter(event_time) AS quarter FROM test_dates GROUP BY quarter ORDER BY quarter;
SELECT toQuarter(max(event_time)) AS max_quarter, toQuarter(min(event_time)) AS min_quarter FROM test_dates;