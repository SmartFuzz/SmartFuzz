CREATE TABLE hexagons (index UInt64);
INSERT INTO hexagons VALUES (590080540275638271), (590103561300344831);
SELECT h3Distance(index, 590103561300344831) as distance FROM hexagons WHERE index = 590080540275638271;
SELECT h3Distance(590080540275638271, index) as distance FROM hexagons;
SELECT a.distance FROM (SELECT h3Distance(590080540275638271, 590103561300344831) as distance) AS a;
SELECT h3Distance(start.index, end.index) as distance FROM (SELECT index FROM hexagons WHERE index < 590103561300344831) as start, (SELECT index FROM hexagons WHERE index > 590080540275638271) as end;
SELECT SUM(distance) as total_distance FROM (SELECT h3Distance(index, 590103561300344831) as distance FROM hexagons) AS distances;
CREATE TABLE hexagon_table (start UInt64, end UInt64, distance Int64);
INSERT INTO hexagon_table SELECT index, 590103561300344831, h3Distance(index, 590103561300344831) FROM hexagons;
SELECT AVG(distance) as average_distance FROM hexagon_table WHERE distance >= 0;
WITH (SELECT h3Distance(590080540275638271, 590103561300344831)) AS d SELECT d, d + 5 as increased_distance;
SELECT h3Distance(start.index, end.index) as d FROM (SELECT index FROM hexagons WHERE index < 590103561300344831) AS start JOIN (SELECT index FROM hexagons WHERE index > 590080540275638271) AS end ON start.index != end.index;