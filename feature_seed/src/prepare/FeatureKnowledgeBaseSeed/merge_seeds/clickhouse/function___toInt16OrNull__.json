CREATE TABLE test_conversion (input String);
INSERT INTO test_conversion VALUES ('-16'), ('16'), ('abc'), ('0'), ('32767'), ('-32768'), ('32768'), ('-32769'), ('3.14'), ('NaN'), ('Inf'), ('0xc0fe');
SELECT toInt16OrNull(input) FROM test_conversion;
SELECT toInt16OrNull('-16') AS result1, toInt16OrNull('abc') AS result2, toInt16OrNull('16.5') AS result3 FROM test_conversion WHERE result1 IS NOT NULL;
SELECT toInt16OrNull(CONCAT('1', '6')), toInt16OrNull('3.14'), toInt16OrNull(CAST(123.456 AS String)) FROM test_conversion WHERE toInt16OrNull(input) IS NULL;
SELECT input, toInt16OrNull(input) AS converted FROM test_conversion WHERE input IN ('-32768', '32767', 'abc') ORDER BY input;
WITH (SELECT toInt16OrNull('32767')) AS upper, (SELECT toInt16OrNull('-32768')) AS lower SELECT upper, lower;
SELECT id, name, toInt16OrNull(value) FROM (SELECT 1 AS id, 'test1' AS name, '123' AS value UNION ALL SELECT 2, 'test2', '30000' UNION ALL SELECT 3, 'test3', 'abc') AS subquery WHERE toInt16OrNull(value) IS NOT NULL;
CREATE TABLE test_values (value String);
INSERT INTO test_values VALUES ('-32768'), ('32767'), ('32768'), ('NaN'), ('abc');
SELECT toInt16OrNull(value) AS val FROM test_values WHERE value LIKE '%0%' OR value LIKE 'abc';
SELECT AVG(toInt16OrNull(value)) FROM (SELECT '100' AS value UNION ALL SELECT '200' UNION ALL SELECT 'abc' UNION ALL SELECT '-50') AS temp WHERE toInt16OrNull(value) IS NOT NULL;