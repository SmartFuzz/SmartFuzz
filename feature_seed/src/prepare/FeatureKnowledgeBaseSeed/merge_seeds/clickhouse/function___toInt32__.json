CREATE TABLE test_values (value String);
INSERT INTO test_values VALUES ('-2147483649'), ('2147483648'), ('-32'), ('-32.32'), ('32.99'), ('0'), ('Inf'), ('NaN');
SELECT toInt32(value) FROM test_values;
SELECT toInt32(value) FROM (SELECT value FROM test_values WHERE value LIKE '-%');
SELECT a.value, toInt32(a.value) AS converted_value FROM test_values AS a JOIN test_values AS b ON a.value = b.value WHERE a.value != b.value;
SELECT DISTINCT toInt32(value) FROM (SELECT value FROM test_values UNION ALL SELECT '-32.99' AS value) AS sub;
SELECT toInt32(toString(value)) FROM (SELECT value FROM test_values) WHERE value NOT LIKE 'Inf' AND value NOT LIKE 'NaN';
SELECT toInt32(-32) + toInt32('32.99') AS result;
SELECT toInt32(CAST(value AS Float64)) FROM test_values WHERE value NOT IN ('Nan', 'Inf');
SELECT a.value, b.value, toInt32(a.value) + toInt32(b.value) AS sum FROM test_values AS a, test_values AS b WHERE a.value != b;