CREATE TABLE test_uuids (id UInt32, uuid UUID) ENGINE = Memory;
INSERT INTO test_uuids SELECT number, generateUUIDv7() FROM numbers(10);
SELECT * FROM test_uuids;
CREATE TABLE timestamps (timestamp UInt64, uuid UUID) ENGINE = Memory;
INSERT INTO timestamps SELECT toUnixTimestamp(now()) * 1000, generateUUIDv7() FROM numbers(5);
SELECT timestamp, uuid FROM timestamps ORDER BY timestamp DESC;
SELECT generateUUIDv7() AS uuid_value, generateUUIDv7(1) AS uuid_value_1, generateUUIDv7(2) AS uuid_value_2;
CREATE TABLE uuid_batch (batch_id UInt32, uuid UUID) ENGINE = MergeTree() ORDER BY batch_id;
INSERT INTO uuid_batch SELECT number, generateUUIDv7() FROM numbers(10000);
SELECT batch_id, count(uuid) FROM uuid_batch GROUP BY batch_id;
CREATE TABLE complex_uuids (id UInt32, uuid UUID, ref_id UInt32) ENGINE = Memory;
INSERT INTO complex_uuids SELECT number, generateUUIDv7(), number % 10 FROM numbers(50);
WITH (SELECT count(*) FROM complex_uuids) AS total, generateUUIDv7() AS new_uuid SELECT total, new_uuid;
CREATE TABLE nested_uuids (id UInt32, uuid UUID, generated_at DateTime) ENGINE = Memory;
INSERT INTO nested_uuids SELECT number, generateUUIDv7(), now() FROM numbers(10);
SELECT uuid, (SELECT count(*) FROM nested_uuids WHERE generated_at >= now() - INTERVAL 1 HOUR) AS recent_count FROM nested_uuids;
SELECT a.uuid AS uuid_a, b.uuid AS uuid_b FROM (SELECT generateUUIDv7() AS uuid, number FROM numbers(5)) AS a JOIN (SELECT generateUUIDv7() AS uuid, number FROM numbers(5)) AS b ON a.number = b.number;
CREATE TABLE uuid_test (uuid UUID) ENGINE = Memory;
INSERT INTO uuid_test SELECT generateUUIDv7() FROM numbers(20);
SELECT uuid FROM uuid_test WHERE uuid >= generateUUIDv7();