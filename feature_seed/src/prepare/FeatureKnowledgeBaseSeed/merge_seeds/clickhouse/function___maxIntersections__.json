CREATE TABLE my_events (start UInt32, end UInt32) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO my_events VALUES (1, 3), (1, 6), (2, 5), (3, 7), (0, 0);
SELECT maxIntersections(start, end) FROM my_events;
CREATE TABLE additional_events (start UInt32, end UInt32) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO additional_events VALUES (1, 4), (2, 6), (3, 8), (0, 0);
SELECT maxIntersections(start, end) AS max_int FROM my_events UNION ALL SELECT maxIntersections(start, end) FROM additional_events;
CREATE TABLE complex_events (user_id UInt32, start UInt32, end UInt32) ENGINE = MergeTree() ORDER BY user_id;
INSERT INTO complex_events VALUES (1, 1, 5), (1, 2, 3), (2, 4, 7), (2, 5, 6);
SELECT user_id, maxIntersections(start, end) FROM complex_events GROUP BY user_id;
WITH (SELECT maxIntersections(start, end) FROM my_events) AS max1, (SELECT maxIntersections(start, end) FROM additional_events) AS max2 SELECT max1 + max2 AS total_intersections;
CREATE TABLE another_events (start Nullable(UInt32), end Nullable(UInt32)) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO another_events VALUES (1, 3), (NULL, 4), (2, NULL), (0, 0);
SELECT maxIntersections(start, end) FROM another_events WHERE start IS NOT NULL;
CREATE TABLE event_pairs AS SELECT e1.start, e1.end FROM my_events AS e1 JOIN additional_events AS e2 ON e1.start < e2.end AND e1.end > e2.start;
SELECT maxIntersections(start, end) FROM event_pairs;