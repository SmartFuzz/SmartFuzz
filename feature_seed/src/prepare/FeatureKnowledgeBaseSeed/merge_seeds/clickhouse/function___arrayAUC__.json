CREATE TABLE scores_labels (id Int32, arr_scores Array(Float64), arr_labels Array(Int32));
INSERT INTO scores_labels VALUES (1, [0.1, 0.4, 0.35, 0.8], [0, 0, 1, 1]), (2, [0.9, 0.85, 0.95, 0.99], [1, 1, 1, 1]), (3, [0.2, 0.3, 0.5, 0.4], [0, 1, 0, 0]);
SELECT arrayAUC(arr_scores, arr_labels) FROM scores_labels WHERE id = 1;
SELECT arrayAUC(arr_scores, arr_labels, false) FROM scores_labels WHERE id = 2;
SELECT id, arrayAUC(arr_scores, arr_labels) AS auc FROM scores_labels;
SELECT arrayAUC(arr_scores, arr_labels) FROM (SELECT arr_scores, arr_labels FROM scores_labels WHERE id = 3);
CREATE TABLE additional_scores (score_id Int32, additional_scores Array(Float64), additional_labels Array(Int32));
INSERT INTO additional_scores VALUES (1, [0.6, 0.7, 0.65, 0.85], [1, 1, 0, 0]);
SELECT s.id, arrayAUC(s.arr_scores, s.arr_labels) AS auc, a.additional_scores FROM scores_labels s JOIN additional_scores a ON s.id = a.score_id;
SELECT s.id, arrayAUC([0.1, 0.4, 0.35, 0.8, 0.9], [0, 0, 1, 1, 1]) FROM scores_labels s WHERE arr_labels[1] = 0;
SELECT arrayAUC([0.0, 1.0], [0, 1]) AS single_element_test;