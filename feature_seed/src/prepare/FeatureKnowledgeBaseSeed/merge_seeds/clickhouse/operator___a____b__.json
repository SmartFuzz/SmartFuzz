CREATE TABLE test_table (a INT, b INT);
INSERT INTO test_table VALUES (5, 3), (2, 2), (3, 5), (10, 10);
SELECT a, b FROM test_table WHERE a >= b;
SELECT a, b FROM test_table WHERE a >= (SELECT AVG(b) FROM test_table);
SELECT t1.a, t2.b FROM test_table AS t1 JOIN test_table AS t2 ON t1.a >= t2.b;
SELECT COUNT(*) FROM test_table WHERE a >= (SELECT MAX(b) FROM test_table WHERE b < 5);
CREATE TABLE another_table (c INT, d INT);
INSERT INTO another_table VALUES (1, 10), (2, 2), (3, 5), (4, 4);
SELECT a, d FROM test_table JOIN another_table ON test_table.a >= another_table.d WHERE another_table.c = 2;
SELECT a FROM (SELECT a FROM test_table) AS sub_query WHERE a >= 2;
SELECT a, MAX(b) FROM test_table WHERE a >= b GROUP BY a;
SELECT a FROM test_table WHERE a >= (SELECT MIN(b) FROM (SELECT b FROM test_table) AS inner_query);