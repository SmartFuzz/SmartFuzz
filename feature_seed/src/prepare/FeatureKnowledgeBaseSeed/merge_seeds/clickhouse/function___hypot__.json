CREATE TABLE triangles (id UInt64, cathetus1 Float64, cathetus2 Float64);
INSERT INTO triangles VALUES (1, 3, 4), (2, 5, 12), (3, 8, 15);
SELECT id, hypot(cathetus1, cathetus2) AS hypotenuse_length FROM triangles;
SELECT hypot(0, 0) AS hypotenuse_zero;
SELECT hypot(1e-10, 1e-10) AS hypotenuse_small_values;
SELECT hypot(1e+10, 1e+10) AS hypotenuse_large_values;
SELECT hypot(cathetus1, 0) AS hypotenuse_with_zero FROM triangles;
SELECT hypot(0, cathetus2) AS hypotenuse_with_zero_2 FROM triangles;
CREATE TABLE results AS SELECT id, hypot(cathetus1, cathetus2) AS hypotenuse_length FROM triangles;
SELECT AVG(hypot(cathetus1, cathetus2)) AS average_hypotenuse FROM triangles;
SELECT id, hypot(cathetus1 + 1, cathetus2 + 1) AS hypotenuse_offset FROM triangles;
WITH (SELECT hypot(1, 1) AS hypotenuse) AS h SELECT hypotenuse + 5 AS hypotenuse_adjusted;
SELECT t.id, hypot(t.cathetus1, t.cathetus2) AS hypotenuse_length, r.hypotenuse_length AS stored_hypotenuse FROM triangles t JOIN results r ON t.id = r.id;
SELECT hypot(COALESCE(cathetus1, 1), COALESCE(cathetus2, 1)) AS hypotenuse_non_null FROM triangles;
SELECT hypot(ROUND(cathetus1), ROUND(cathetus2)) AS hypotenuse_rounded FROM triangles;