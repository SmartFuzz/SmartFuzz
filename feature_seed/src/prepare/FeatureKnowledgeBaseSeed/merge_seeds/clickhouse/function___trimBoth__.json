CREATE TABLE test_strings (id UInt32, input_string String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_strings VALUES (1, '     ClickHouse is awesome!     '), (2, '   Fuzz testing is essential.   '), (3, '     '), (4, 'NoWhitespace'), (5, 'Leading and trailing spaces     '), (6, '     Leading space only'), (7, 'Trailing space only     '), (8, '   Multiple   spaces   in  between   ');
SELECT trimBoth(input_string) FROM test_strings WHERE id = 1;
SELECT id, trimBoth(input_string) AS trimmed_input FROM test_strings;
SELECT trimBoth(CONCAT('    ', input_string, '    ')) FROM test_strings;
SELECT trimBoth(SUBSTR(input_string, 2, 20)) FROM test_strings;
SELECT trimBoth(CAST(input_string AS String)) FROM test_strings WHERE id = 2;
SELECT trimBoth(input_string || '   ') FROM test_strings WHERE id IN (1, 2);
WITH (SELECT trimBoth(input_string) FROM test_strings WHERE id = 3) AS trimmed_string SELECT trimmed_string;
SELECT COUNT(*) FROM test_strings WHERE trimBoth(input_string) = '';
SELECT DISTINCT trimBoth(input_string) FROM test_strings;
SELECT id FROM test_strings WHERE trimBoth(input_string) = trimBoth('   Leading and trailing spaces     ');
SELECT trimBoth(input_string), COUNT(*) FROM test_strings GROUP BY trimBoth(input_string) HAVING COUNT(*) > 1;
CREATE TABLE trimmed_results AS SELECT id, trimBoth(input_string) AS trimmed_input FROM test_strings;
SELECT * FROM trimmed_results WHERE trimmed_input LIKE '%spaces%';