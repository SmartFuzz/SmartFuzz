CREATE TABLE test_table1 (column1 String, column2 UInt32, column3 Array(String));
INSERT INTO test_table1 VALUES ('value1', 1, ['a', 'b']), ('value2', 2, ['c', 'd']);
SELECT structureToProtobufSchema('column1 String, column2 UInt32, column3 Array(String)') FORMAT RawBLOB;
CREATE TABLE test_table2 (column1 Nullable(String), column2 Tuple(element1 UInt32, element2 Array(String)), column3 Map(String, String));
INSERT INTO test_table2 VALUES (NULL, (1, ['a', 'b']), {'key1': 'value1'}), ('value2', (2, ['c']), {'key2': 'value2'});
SELECT structureToProtobufSchema('column1 Nullable(String), column2 Tuple(element1 UInt32, element2 Array(String)), column3 Map(String, String)') FORMAT RawBLOB;
SELECT structureToProtobufSchema('column1 String, column2 UInt32, column3 Array(String)', 'MyRootMessage') FORMAT RawBLOB;
WITH (SELECT COUNT(*) FROM test_table1) AS count FROM test_table1 WHERE count > 1;
SELECT structureToProtobufSchema('column1 String, column2 UInt32, column3 Array(String)', 'Message') FORMAT RawBLOB;
CREATE TABLE test_table3 AS test_table1 ENGINE = MergeTree() ORDER BY column2;
INSERT INTO test_table3 SELECT 'value3', 3, ['e'] UNION ALL SELECT 'value4', 4, ['f'];
SELECT structureToProtobufSchema('column1 String, column2 UInt32', 'CustomRoot') FORMAT RawBLOB;
CREATE TABLE test_table4 (id UInt32, settings JSON);
INSERT INTO test_table4 VALUES (1, '{"column1": "value1"}'), (2, '{"column2": "value2"}');
SELECT structureToProtobufSchema('id UInt32, settings JSON') FORMAT RawBLOB;