CREATE TABLE test_bit_operations (number Int32);
INSERT INTO test_bit_operations VALUES (43);
SELECT bitTestAll(number, 0, 1, 3, 5) FROM test_bit_operations;
INSERT INTO test_bit_operations VALUES (255);
SELECT bitTestAll(number, 0, 2, 4) FROM test_bit_operations;
SELECT bitTestAll(number, 0, 1, 3, 5, 6) FROM test_bit_operations WHERE number = 255;
WITH (SELECT number FROM test_bit_operations WHERE number >= 0) AS nums SELECT bitTestAll(nums, 0, 1, 3) FROM test_bit_operations;
CREATE TABLE secondary_table (num Int32);
INSERT INTO secondary_table VALUES (15), (43), (255);
SELECT bitTestAll(test_bit_operations.number, 0, 1) FROM test_bit_operations JOIN secondary_table ON test_bit_operations.number = secondary_table.num;
SELECT bitTestAll(number, 1, 3) FROM (SELECT number FROM test_bit_operations WHERE number < 100);
SELECT bitTestAll(0, 0, 1, 2, 3, 4);
SELECT bitTestAll(255, 0, 1, 2, 3, 4, 5, 6, 7);
SELECT bitTestAll(0, 7) FROM (SELECT 0 AS bit_value) AS inner_query;