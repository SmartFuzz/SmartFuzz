CREATE TABLE haystack_table (id UInt32, text String);
INSERT INTO haystack_table VALUES (1, 'example'), (2, 'sample'), (3, 'temple'), (4, 'simple');
SELECT multiFuzzyMatchAnyIndex(text, 1, ['examp', 'templ']) FROM haystack_table;
SELECT * FROM haystack_table WHERE id IN (SELECT id FROM haystack_table WHERE multiFuzzyMatchAnyIndex(text, 2, ['exmp', 'sampl']));
CREATE TABLE patterns_table (pattern String);
INSERT INTO patterns_table VALUES ('exampl'), ('simle'), ('temple');
SELECT id, text FROM haystack_table WHERE multiFuzzyMatchAnyIndex(text, 1, (SELECT groupArray(pattern) FROM patterns_table));
SELECT id FROM haystack_table WHERE text LIKE '%simple%' AND multiFuzzyMatchAnyIndex(text, 1, ['sampl', 'temple']);
WITH (SELECT groupArray(pattern) FROM patterns_table) AS patterns_array SELECT id FROM haystack_table WHERE multiFuzzyMatchAnyIndex(text, 2, patterns_array);
CREATE TABLE join_table (id UInt32, description String);
INSERT INTO join_table VALUES (1, 'This is an example'), (2, 'A simple test case'), (3, 'Another sample entry');
SELECT h.id FROM haystack_table h JOIN join_table j ON multiFuzzyMatchAnyIndex(h.text, 1, ['exapmle', 'simle']) WHERE j.description LIKE '%sample%';
SELECT pattern FROM patterns_table WHERE multiFuzzyMatchAnyIndex('exampl', 1, ['example', 'simple', 'temple']);