CREATE TABLE test_uuids (id FixedString(16));
INSERT INTO test_uuids VALUES (toFixedString('a/<@];
!~p{jTj={)', 16);
INSERT INTO test_uuids VALUES (toFixedString('@</a;
]~!p{jTj={)', 16);
INSERT INTO test_uuids VALUES (toFixedString(char(0x612f3c40, 0x5d3b, 0x217e, 0x707b, 0x6a546a3d7b29), 16);
SELECT UUIDNumToString(id) AS uuid FROM test_uuids;
SELECT UUIDNumToString(id, 1) AS uuid_big_endian, UUIDNumToString(id, 2) AS uuid_microsoft FROM test_uuids;
SELECT CASE WHEN UUIDNumToString(id) IS NOT NULL THEN 'Valid UUID' ELSE 'Invalid UUID' END AS uuid_status FROM test_uuids;
WITH (SELECT toFixedString('a/<@];
!~p{jTj={)', 16) AS binary_uuid SELECT UUIDNumToString(binary_uuid) AS uuid FROM test_uuids;
WITH (SELECT toFixedString('@</a;
]~!p{jTj={)', 16) AS binary_uuid SELECT UUIDNumToString(binary_uuid, 2) AS uuid FROM test_uuids;
CREATE TABLE valid_uuid_test AS SELECT UUIDNumToString(id) AS valid_uuid FROM test_uuids WHERE UUIDNumToString(id) IS NOT NULL;
CREATE TABLE combined_test AS SELECT t1.id, UUIDNumToString(t1.id) AS uuid_big_endian, UUIDNumToString(t1.id, 2) AS uuid_microsoft FROM test_uuids AS t1 INNER JOIN (SELECT toFixedString('a/<@];
!~p{jTj={)', 16) AS id) AS t2 ON t1.id = t2.id;
CREATE TABLE nested_test AS SELECT id, (SELECT UUIDNumToString(id) FROM test_uuids WHERE id = t.id) AS uuid FROM (SELECT id FROM test_uuids) AS t;
SELECT t.id, UUIDNumToString(t.id) AS uuid FROM (SELECT id FROM test_uuids) AS t WHERE UUIDNumToString(t.id) LIKE '612f3c40%';
SELECT COUNT(*) FROM test_uuids WHERE UUIDNumToString(id, 1) IS NOT NULL;
SELECT id, UUIDNumToString(id, 1) AS uuid_before, UUIDNumToString(id, 2) AS uuid_after FROM test_uuids WHERE id IN (SELECT id FROM (SELECT id FROM test_uuids WHERE UUIDNumToString(id, 2) IS NOT NULL));