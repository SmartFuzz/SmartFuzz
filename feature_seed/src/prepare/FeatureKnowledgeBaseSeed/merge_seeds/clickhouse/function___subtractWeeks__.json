CREATE TABLE test_dates (id UInt32, event_date Date);
INSERT INTO test_dates VALUES (1, toDate('2024-01-01')), (2, toDate('2024-12-31')), (3, toDate('2024-06-15'));
SELECT id, subtractWeeks(event_date, 1) AS one_week_prior FROM test_dates;
SELECT id, subtractWeeks(event_date, 52) AS one_year_prior FROM test_dates WHERE id = 1;
WITH toDate('2024-01-01') AS sample_date SELECT sample_date AS original_date, subtractWeeks(sample_date, 1) AS one_week_prior, subtractWeeks(sample_date, 0) AS same_day FROM dual;
CREATE TABLE test_date_time (id UInt32, created_at DateTime);
INSERT INTO test_date_time VALUES (1, toDateTime('2024-01-01 12:00:00')), (2, toDateTime('2024-01-08 16:30:00'));
SELECT id, subtractWeeks(created_at, 2) AS two_weeks_prior FROM test_date_time;
WITH toDateTime('2024-01-10 10:15:00') AS sample_date_time SELECT sample_date_time AS original, subtractWeeks(sample_date_time, 4) AS four_weeks_prior;
CREATE TABLE test_date_string (id UInt32, event_date_string String);
INSERT INTO test_date_string VALUES (1, '2024-01-01 00:00:00'), (2, '2024-02-01 00:00:00');
SELECT id, subtractWeeks(parseDateTimeBestEffort(event_date_string), 3) AS three_weeks_prior FROM test_date_string;
SELECT id, subtractWeeks(toDateTime('2024-01-01 12:00:00'), num) AS adjusted_date FROM test_date_time CROSS JOIN (SELECT 3 AS num) AS numbers;
SELECT t.id, subtractWeeks(t.event_date, 1) AS subtracted_date FROM test_dates t INNER JOIN (SELECT 1 AS id) AS temp ON t.id = temp.id;
WITH (SELECT toDate('2024-01-01')) AS start_date SELECT subtractWeeks(start_date, 1) AS one_week_prior;
SELECT subtractWeeks(now(), 1) AS last_week;
CREATE TABLE combined_dates AS SELECT id, subtractWeeks(event_date, 1) AS subtracted FROM (SELECT 1 AS id, toDate('2024-01-01') AS event_date UNION ALL SELECT 2, toDate('2024-02-01')) AS t;