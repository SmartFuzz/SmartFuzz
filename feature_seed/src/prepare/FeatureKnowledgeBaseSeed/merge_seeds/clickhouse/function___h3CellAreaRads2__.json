CREATE TABLE h3_cells (index UInt64);
INSERT INTO h3_cells VALUES (579205133326352383), (0), (18446744073709551615);
SELECT index, h3CellAreaRads2(index) AS area FROM h3_cells;
SELECT h3CellAreaRads2((SELECT index FROM h3_cells WHERE index = 579205133326352383)) AS area;
CREATE TABLE h3_cells_1 (index UInt64);
INSERT INTO h3_cells_1 SELECT index FROM h3_cells;
SELECT a.index, h3CellAreaRads2(a.index) AS area FROM h3_cells a JOIN h3_cells_1 b ON a.index = b.index;
SELECT h3CellAreaRads2(index) + 1 AS area_plus_one FROM h3_cells;
SELECT SUM(h3CellAreaRads2(index)) AS total_area FROM h3_cells;
WITH (SELECT h3CellAreaRads2(579205133326352383) * 2 AS area_doubled) AS t SELECT area_doubled FROM t;
CREATE TABLE h3_area_results AS SELECT h3CellAreaRads2(index) AS area FROM h3_cells GROUP BY index;