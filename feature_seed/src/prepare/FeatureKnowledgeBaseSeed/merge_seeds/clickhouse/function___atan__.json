CREATE TABLE test_atan (value Float32);
INSERT INTO test_atan VALUES (0), (1), (-1), (1.0), (-1.0), (3.14159), (-3.14159), (1.5), (2.5);
SELECT atan(value) FROM test_atan;
SELECT value, atan(value) AS arc_tangent FROM test_atan;
CREATE TABLE test_complex (a Float32, b Float32);
INSERT INTO test_complex VALUES (1, 2), (3, 4), (5, 6);
SELECT a, b, atan(a) + atan(b) AS sum_arc_tangent FROM test_complex;
SELECT t1.value, t2.b, atan(t1.value) FROM test_atan AS t1 JOIN test_complex AS t2 ON t1.value < t2.a;
SELECT atan((SELECT MAX(value) FROM test_atan)) AS max_atan;
SELECT AVG(atan(value)) AS average_atan FROM test_atan;
SELECT t1.value, t2.b, atan(t1.value) AS arc_tangent FROM test_atan AS t1 LEFT JOIN test_complex AS t2 ON t1.value = t2.a WHERE t2.b IS NOT NULL;