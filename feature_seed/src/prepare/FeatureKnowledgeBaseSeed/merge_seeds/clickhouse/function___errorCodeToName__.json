CREATE TABLE error_codes (code UInt32, error_name LowCardinality(String));
INSERT INTO error_codes VALUES (1, 'UNSUPPORTED_METHOD'), (2, 'UNKNOWN_ERROR'), (3, 'OUT_OF_MEMORY');
SELECT errorCodeToName(code) FROM error_codes WHERE code BETWEEN 1 AND 3;
SELECT code, errorCodeToName(code) AS error_description FROM error_codes WHERE error_name LIKE 'UNSUP%';
SELECT errorCodeToName(1) AS method_error, errorCodeToName(2) AS unknown_error FROM (SELECT 1 AS code UNION ALL SELECT 2);
SELECT ec.code, ec.error_name FROM error_codes ec JOIN (SELECT errorCodeToName(1) AS method_error) AS errors ON ec.error_name = method_error;
CREATE TABLE additional_errors (code UInt32, description String, severity String);
INSERT INTO additional_errors VALUES (4, 'NETWORK_ERROR', 'HIGH'), (5, 'TIMEOUT', 'MEDIUM');
SELECT a.code, errorCodeToName(a.code) AS error_description, b.severity FROM error_codes a JOIN additional_errors b ON a.code = b.code WHERE a.code IN (1, 4);
WITH (SELECT errorCodeToName(1)) AS method_error SELECT method_error, errorCodeToName(5) AS timeout_error;
SELECT errorCodeToName(code) FROM error_codes WHERE code > 3 UNION ALL SELECT errorCodeToName(1);