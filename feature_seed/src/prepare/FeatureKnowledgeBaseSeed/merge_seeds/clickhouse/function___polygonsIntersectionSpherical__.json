CREATE TABLE polygon_data (id UInt32, coordinates Array(Array(Float64)));
INSERT INTO polygon_data VALUES (1, [[(4.3613577, 50.8651821), (4.349556, 50.8535879), (4.3602419, 50.8435626), (4.3830299, 50.8428851), (4.3904543, 50.8564867), (4.3613148, 50.8651279)]]);
INSERT INTO polygon_data VALUES (2, [[(4.346693, 50.858306), (4.367945, 50.852455), (4.366227, 50.840809), (4.344961, 50.833264), (4.338074, 50.848677), (4.346693, 50.858306)]]);
SELECT wkt(arrayMap(a -> arrayMap(b -> arrayMap(c -> (round(c.1, 6), round(c.2, 6)), b), a), polygonsIntersectionSpherical((SELECT coordinates FROM polygon_data WHERE id = 1), (SELECT coordinates FROM polygon_data WHERE id = 2)));
CREATE TABLE polygon_test (poly Array(Array(Float64)));
INSERT INTO polygon_test VALUES ([[[4.3613577, 50.8651821], [4.349556, 50.8535879], [4.3602419, 50.8435626], [4.3830299, 50.8428851], [4.3904543, 50.8564867], [4.3613148, 50.8651279]]]), ([[[4.346693, 50.858306], [4.367945, 50.852455], [4.366227, 50.840809], [4.344961, 50.833264], [4.338074, 50.848677], [4.346693, 50.858306]]]);
SELECT wkt(polygonsIntersectionSpherical(p1.poly, p2.poly)) FROM (SELECT poly FROM polygon_test p1) AS p1, (SELECT poly FROM polygon_test p2 WHERE p2.poly != p1.poly) AS p2;
CREATE TABLE intersection_result (result String);
INSERT INTO intersection_result SELECT wkt(polygonsIntersectionSpherical(p1.poly, p2.poly)) FROM (SELECT poly FROM polygon_test p1) AS p1, (SELECT poly FROM polygon_test p2) AS p2 WHERE p1.poly != p2.poly;
SELECT result FROM intersection_result WHERE result IS NOT NULL;
SELECT COUNT(*) AS intersection_count FROM intersection_result;