CREATE TABLE decimals_test (id Int32, val Decimal32(4));
INSERT INTO decimals_test VALUES (1, toDecimal32(99999.9999, 4));
INSERT INTO decimals_test VALUES (2, toDecimal32(-99999.9999, 4));
INSERT INTO decimals_test VALUES (3, toDecimal32(100000.0000, 4));
SELECT id, val FROM decimals_test WHERE val < toDecimal32(100000.0000, 4);
SELECT id, val / 3 as divided_value FROM decimals_test WHERE val > 0;
CREATE TABLE decimals_operations (a Decimal32(6), b Decimal32(6));
INSERT INTO decimals_operations VALUES (toDecimal32(1234.5678, 4), toDecimal32(8765.4321, 4));
SELECT a + b AS sum, a - b AS difference, a * b AS product FROM decimals_operations;
SELECT a, b, multiply(a, 2) AS multiplied_value FROM decimals_operations;
SELECT toDecimal32(4.2, 2) AS x, x * x AS square FROM decimals_operations;
SET decimal_check_overflow = 0;
SELECT toDecimal32(4.2, 4) AS x, 6 * x AS overflowed_product FROM decimals_operations;
CREATE TABLE overflow_tests (val Decimal64(10));
INSERT INTO overflow_tests VALUES (toDecimal64(1e20, 2));
SELECT val * 2 AS multiplied_val FROM overflow_tests;
SELECT val / 0.3333 AS divided_val FROM overflow_tests;
CREATE TABLE complex_test AS SELECT id, val / 2 as half_value FROM decimals_test WHERE val > 2;
CREATE TABLE joins_test (id Int32, val Decimal32(4));
INSERT INTO joins_test VALUES (1, toDecimal32(1000.0000, 4)), (2, toDecimal32(2000.0000, 4));
SELECT a.id, b.val FROM decimals_test AS a JOIN joins_test AS b ON a.id = b.id WHERE a.val > 1;
SELECT val, (SELECT AVG(val) FROM joins_test) AS avg_val FROM joins_test WHERE val >= 1500;
SELECT (SELECT COUNT(*) FROM overflow_tests) AS overflow_count, (SELECT SUM(val) FROM overflow_tests) AS total_val;