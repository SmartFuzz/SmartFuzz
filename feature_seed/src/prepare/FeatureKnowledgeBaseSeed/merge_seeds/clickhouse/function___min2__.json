CREATE TABLE test_min2 (a Float64, b Float64);
INSERT INTO test_min2 VALUES (-1, 2), (3, -4), (0, 0), (1.5, 1.5), (NULL, 5);
SELECT min2(a, b) FROM test_min2;
SELECT min2(min2(a, b), 10) FROM test_min2;
SELECT min2(a, (SELECT AVG(b) FROM test_min2)) FROM test_min2;
SELECT min2((SELECT MAX(a) FROM test_min2), (SELECT MIN(b) FROM test_min2));
WITH (SELECT AVG(a) FROM test_min2) AS avg_a, (SELECT MIN(b) FROM test_min2) AS min_b SELECT min2(avg_a, min_b);
CREATE TABLE test_values (val Float64);
INSERT INTO test_values VALUES (NULL), (1), (-1), (2.5), (0.5);
SELECT min2((SELECT MIN(val) FROM test_values), (SELECT MAX(val) FROM test_values)) AS range_min;
SELECT min2(a + 1, b + 1) FROM test_min2;
SELECT min2(a, (SELECT MAX(b) FROM test_min2 WHERE a > 0)) FROM test_min2;
CREATE TABLE test_join (id UInt64, min_val Float64);
INSERT INTO test_join VALUES (1, -5), (2, 3), (3, 0);
SELECT j.id, min2(j.min_val, (SELECT MIN(a) FROM test_min2)) AS smallest_value FROM test_join j;
SELECT min2(1.79e308, -1.79e308) AS extreme_values;