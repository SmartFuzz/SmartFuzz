CREATE TABLE test_data (value Int64);
INSERT INTO test_data VALUES (0), (1), (2), (3), (42), (-1), (-42), (9223372036854775807), (-9223372036854775808);
SELECT value, intHash64(value) FROM test_data ORDER BY value;
SELECT intHash64(value) AS hash FROM (SELECT value FROM test_data) AS subquery WHERE hash IS NOT NULL;
CREATE TABLE hash_results AS SELECT intHash64(value) AS hash FROM test_data;
SELECT hash.value, hr.hash FROM test_data AS hash JOIN hash_results AS hr ON hash.value = hr.hash;
SELECT intHash64(100 * rand() % 100) FROM numbers(100);
WITH (SELECT intHash64(value) FROM test_data WHERE value IN (0, 1, -1)) AS hashes SELECT DISTINCT hashes;
SELECT intHash64(value) AS hash FROM (SELECT value FROM test_data WHERE value < 100) UNION SELECT intHash64(value) FROM (SELECT value FROM test_data WHERE value >= 100) ORDER BY hash;
CREATE TABLE temp_hash (hash UInt64);
INSERT INTO temp_hash SELECT intHash64(value) FROM test_data;
SELECT count(*) FROM temp_hash WHERE hash % 10 = 0;