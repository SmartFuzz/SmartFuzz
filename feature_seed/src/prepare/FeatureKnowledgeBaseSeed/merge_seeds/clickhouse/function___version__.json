SELECT version();
CREATE TABLE test_versions (id UInt32, version_info String);
INSERT INTO test_versions VALUES (1, version()), (2, version()), (3, version());
SELECT id, version_info FROM test_versions WHERE id < 3;
WITH (SELECT version()) AS current_version SELECT id, current_version FROM test_versions;
CREATE TABLE test_distributed_versions AS SELECT version() GROUP BY id;
CREATE TABLE local_test_versions (data String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO local_test_versions VALUES ('First Version'), ('Second Version');
SELECT version() AS clickhouse_version, data FROM local_test_versions WHERE data LIKE '%Version%';
SELECT id, version() FROM test_versions WHERE version_info = (SELECT version() FROM test_versions WHERE id = 1);
SELECT version() AS current_version, (SELECT COUNT(*) FROM local_test_versions) AS number_of_entries FROM test_versions;
SELECT version() AS current_version, a.id FROM test_versions AS a JOIN local_test_versions AS b ON a.id = b.id WHERE a.id > 1;
SELECT version() AS current_version, (SELECT version() FROM test_versions ORDER BY id LIMIT 1) AS first_version FROM test_versions;