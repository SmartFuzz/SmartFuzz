CREATE TABLE any_last_test_1 (value Nullable(Int32)) ENGINE=Log;
INSERT INTO any_last_test_1 (value) VALUES (10), (NULL), (20), (30), (NULL), (40);
SELECT anyLast(value) FROM any_last_test_1;
CREATE TABLE any_last_test_2 (value Nullable(Int32), category String) ENGINE=Log;
INSERT INTO any_last_test_2 (value, category) VALUES (10, 'A'), (NULL, 'A'), (20, 'A'), (30, 'B'), (NULL, 'B'), (40, 'B');
SELECT category, anyLast(value) FROM any_last_test_2 GROUP BY category;
CREATE TABLE any_last_test_3 (data Nullable(Int32)) ENGINE=Log;
INSERT INTO any_last_test_3 (data) VALUES (1), (NULL), (3), (NULL), (5);
SELECT anyLast(data) FROM any_last_test_3 WHERE data > 2;
CREATE TABLE any_last_test_4 (id Int32, value Nullable(Int32)) ENGINE=Log;
INSERT INTO any_last_test_4 (id, value) VALUES (1, 100), (1, NULL), (2, 200), (2, NULL), (3, 300);
SELECT id, anyLast(value) FROM any_last_test_4 GROUP BY id;
CREATE TABLE any_last_test_nested AS (SELECT city, count(*) as count FROM any_last_nulls GROUP BY city) ENGINE=Log;
INSERT INTO any_last_test_nested (city, count) VALUES ('Amsterdam', 1), (NULL, 0), ('New York', 2), ('Tokyo', 1), ('Valencia', 1);
SELECT anyLast(count) FROM any_last_test_nested WHERE city IS NOT NULL;
CREATE TABLE any_last_test_join_1 (id Int32, value1 Nullable(Int32)) ENGINE=Log;
INSERT INTO any_last_test_join_1 (id, value1) VALUES (1, 10), (1, NULL), (2, 20), (2, 30), (3, NULL);
CREATE TABLE any_last_test_join_2 (id Int32, value2 Nullable(Int32)) ENGINE=Log;
INSERT INTO any_last_test_join_2 (id, value2) VALUES (1, 100), (1, NULL), (2, 200), (3, 300);
SELECT a.id, anyLast(a.value1) as last_value1, anyLast(b.value2) as last_value2 FROM any_last_test_join_1 a JOIN any_last_test_join_2 b ON a.id = b.id GROUP BY a.id;