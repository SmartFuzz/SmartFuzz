CREATE TABLE domain_table (id Int32, domain_column Domain('MyDomain', String)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO domain_table (id, domain_column) VALUES (1, 'example_value');
INSERT INTO domain_table (id, domain_column) VALUES (2, 'another_value');
SELECT * FROM domain_table;
SELECT id, domain_column FROM domain_table WHERE id BETWEEN 1 AND 2;
CREATE TABLE other_table (ref Int32, domain_column Domain('MyDomain', String)) ENGINE = MergeTree() ORDER BY ref;
INSERT INTO other_table (ref, domain_column) VALUES (1, 'example_value'), (2, 'another_value');
SELECT a.id, a.domain_column, b.ref FROM domain_table a JOIN other_table b ON a.domain_column = b.domain_column;
SELECT COUNT(*) FROM domain_table WHERE domain_column IN ('example_value', 'another_value');
SELECT DISTINCT domain_column FROM domain_table WHERE id < 2;
CREATE TABLE filtered_table AS SELECT * FROM domain_table WHERE domain_column LIKE 'example%';
ALTER TABLE domain_table ADD COLUMN extra_column Int32;
SELECT domain_column, COUNT(*) FROM domain_table GROUP BY domain_column;
INSERT INTO domain_table (id, domain_column) VALUES (3, 'example_value') ON CONFLICT DO NOTHING;
SELECT domain_column, AVG(id) FROM domain_table GROUP BY domain_column HAVING AVG(id) > 1;
INSERT INTO domain_table (id, domain_column) VALUES (NULL, 'invalid_value');
SELECT SUM(id) AS total FROM domain_table WHERE domain_column IS NOT NULL;