CREATE TABLE ngram_test (text String);
INSERT INTO ngram_test VALUES ('ClickHouse');
INSERT INTO ngram_test VALUES ('Database testing');
INSERT INTO ngram_test VALUES ('');
INSERT INTO ngram_test VALUES ('A');
INSERT INTO ngram_test VALUES ('AB');
SELECT ngrams(text, 3) FROM ngram_test;
SELECT ngrams(text, 1) AS uni_grams FROM ngram_test;
SELECT ngrams(text, 2) AS bi_grams FROM ngram_test;
SELECT ngrams(text, 5) AS five_grams FROM ngram_test WHERE text != '';
SELECT ngrams('abc', 4) AS four_grams;
SELECT DISTINCT ngrams(text, 2) FROM ngram_test;
SELECT t1.text, ngrams(t1.text, 3) FROM ngram_test AS t1 JOIN (SELECT text FROM ngram_test WHERE text != '') AS t2 ON t1.text != t2.text;
CREATE TABLE ngram_test_large (text String);
INSERT INTO ngram_test_large VALUES (repeat('A', 1000));
SELECT ngrams(text, 5) FROM ngram_test_large;
SELECT ngrams((SELECT text FROM ngram_test LIMIT 1), 2) AS subquery_bi_grams;
WITH (SELECT text FROM ngram_test LIMIT 1) AS sub_text SELECT ngrams(sub_text, 2) AS sub_grams;
SELECT ngrams(text, 3) FROM ngram_test WHERE length(text) >= 3;