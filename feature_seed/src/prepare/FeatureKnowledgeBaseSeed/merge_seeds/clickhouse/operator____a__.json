CREATE TABLE test_negation (id Int32, value Float64);
INSERT INTO test_negation VALUES (1, 10.5), (2, -3.7), (3, 0.0);
SELECT id, -value AS negated_value FROM test_negation;
CREATE TABLE test_join (id Int32, ref_id Int32, score Float64);
INSERT INTO test_join VALUES (1, 1, 15.5), (2, 1, -22.3), (3, 2, 8.1);
SELECT tj.id, -tj.score AS negated_score FROM test_join tj JOIN test_negation tn ON tj.ref_id = tn.id WHERE tn.value < 0;
SELECT id, -SUM(value) AS total_negation FROM test_negation GROUP BY id HAVING total_negation < -10;
CREATE TABLE nested_test (a Int32, b Int32);
INSERT INTO nested_test VALUES (1, 100), (2, -200), (3, 300);
SELECT a, -SUM(b) AS negated_sum FROM (SELECT * FROM nested_test) AS nested GROUP BY a;
SELECT tn.id, (SELECT -AVG(value) FROM test_negation WHERE value > 0) AS avg_negation FROM test_negation tn WHERE tn.value < 0;
SELECT tn.id, -min(tj.score) AS min_negated_score FROM test_join tj JOIN test_negation tn ON tj.ref_id = tn.id GROUP BY tn.id HAVING min_negated_score < -20;