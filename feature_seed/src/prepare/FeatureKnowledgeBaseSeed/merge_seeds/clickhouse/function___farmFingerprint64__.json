CREATE TABLE test_table (id Int32, data String);
INSERT INTO test_table VALUES (1, 'test1'), (2, 'test2'), (3, 'test3');
SELECT farmFingerprint64(data) FROM test_table;
SELECT id, farmFingerprint64(data) AS fingerprint FROM test_table WHERE id < 3;
CREATE TABLE another_table (pk Int32, ref_id Int32);
INSERT INTO another_table VALUES (1, 1), (2, 1), (3, 2);
SELECT t.id, farmFingerprint64(t.data), a.ref_id FROM test_table t JOIN another_table a ON t.id = a.ref_id;
SELECT farmFingerprint64(concat(data, toString(id))) FROM test_table WHERE id IN (SELECT ref_id FROM another_table);
CREATE TABLE complex_table (user_id Int32, session_id String) ENGINE = MergeTree() ORDER BY user_id;
INSERT INTO complex_table VALUES (1, 'session1'), (2, 'session2'), (3, 'session3');
SELECT farmFingerprint64(session_id) FROM complex_table WHERE user_id IN (SELECT id FROM test_table WHERE id > 1);
WITH (SELECT count(*) FROM test_table) AS total FROM test_table WHERE farmFingerprint64(data) IS NOT NULL HAVING total > 0;