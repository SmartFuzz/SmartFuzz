CREATE TABLE decimals (a Decimal64(10), b Decimal64(10));
INSERT INTO decimals VALUES (toDecimal64(-12.647, 3), toDecimal64(2.1239, 4));
SELECT multiplyDecimal(a, b) FROM decimals;
CREATE TABLE test_scale (x Decimal64(9), y Decimal64(9));
INSERT INTO test_scale VALUES (toDecimal64(-12.647987876, 9), toDecimal64(123.967645643, 9));
SELECT multiplyDecimal(x, y) FROM test_scale;
SELECT multiplyDecimal(a, b, 5) AS result FROM (SELECT toDecimal64(-12.647, 3) AS a, toDecimal64(2.1239, 4) AS b);
SELECT multiplyDecimal(a, b) FROM (SELECT toDecimal64(a, 3) AS a, toDecimal64(b, 4) AS b FROM (SELECT -12.647 AS a, 2.1239 AS b) AS subquery);
CREATE TABLE nested_multiplication (a Decimal128(10), b Decimal128(10));
INSERT INTO nested_multiplication VALUES (toDecimal128(1.234567891234567891), toDecimal128(2.345678912345678912));
SELECT multiplyDecimal(a, multiplyDecimal(b, toDecimal128(3.0, 0))) FROM nested_multiplication;
SELECT multiplyDecimal((SELECT toDecimal64(-12.647, 3)), (SELECT toDecimal64(2.1239, 4)));
CREATE TABLE join_example (id Int32, value1 Decimal64(10), value2 Decimal64(10));
INSERT INTO join_example VALUES (1, toDecimal64(3.5, 1), toDecimal64(2.0, 1)), (2, toDecimal64(-1.1, 2), toDecimal64(0.3, 1));
SELECT id, multiplyDecimal(value1, value2) AS product FROM join_example WHERE product > toDecimal64(0, 0);
SELECT multiplyDecimal(toDecimal64(1.1, 2), toDecimal64(1.1, 2), 3) + multiplyDecimal(toDecimal64(2.2, 1), toDecimal64(3.3, 1), 2) AS total_product;