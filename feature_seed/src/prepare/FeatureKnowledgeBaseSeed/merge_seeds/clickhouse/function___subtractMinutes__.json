CREATE TABLE test_dates (event_date DateTime);
INSERT INTO test_dates VALUES (toDateTime('2024-01-01 12:00:00'));
SELECT subtractMinutes(event_date, 30) AS time_subtracted FROM test_dates;
SELECT event_date, subtractMinutes(event_date, num) AS time_subtracted FROM test_dates, (SELECT 45 AS num);
WITH toDateTime('2024-01-01 00:00:00') AS dt SELECT subtractMinutes(dt, 60) AS result;
WITH toDate('2023-12-31') AS d, 90 AS num SELECT subtractMinutes(d, num) AS result;
CREATE TABLE event_table (event_time DateTime, num_minutes UInt32);
INSERT INTO event_table VALUES (toDateTime('2024-01-01 12:15:30'), 15);
SELECT event_time, subtractMinutes(event_time, num_minutes) AS adjusted_time FROM event_table;
WITH '2024-01-01 12:00:00' AS dt_string SELECT subtractMinutes(dt_string, 30) AS result;
CREATE TABLE complex_test (start_time DateTime, duration Int32);
INSERT INTO complex_test VALUES (toDateTime('2024-01-01 13:00:00'), 120);
SELECT start_time, subtractMinutes(start_time, duration) AS end_time FROM complex_test;
WITH (SELECT toDateTime('2024-01-01 10:00:00') AS t1, toDateTime('2024-01-01 09:00:00') AS t2) AS times SELECT subtractMinutes(t1, 15) AS subtracted_time_1, subtractMinutes(t2, 30) AS subtracted_time_2;
CREATE TABLE dates_input (date_str String);
INSERT INTO dates_input VALUES ('2024-01-01 14:00:00'), ('2024-01-01 14:45:00');
SELECT date_str, subtractMinutes(date_str, 20) AS modified_date FROM dates_input;