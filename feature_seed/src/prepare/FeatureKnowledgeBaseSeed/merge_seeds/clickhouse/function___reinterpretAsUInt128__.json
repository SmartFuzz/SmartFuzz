CREATE TABLE test_table_float (value Float64);
INSERT INTO test_table_float VALUES (257.5), (128.75), (0.0), (-3.75);
SELECT value, toTypeName(value), reinterpretAsUInt128(value) AS res, toTypeName(res) FROM test_table_float;
CREATE TABLE test_table_int (value Int32);
INSERT INTO test_table_int VALUES (257), (-128), (0), (2147483648);
SELECT value, toTypeName(value), reinterpretAsUInt128(value) AS res, toTypeName(res) FROM test_table_int;
CREATE TABLE test_table_string (value String);
INSERT INTO test_table_string VALUES ('Hello'), ('World'), (''), ('1234567890');
SELECT value, toTypeName(value), reinterpretAsUInt128(value) AS res, toTypeName(res) FROM test_table_string;
CREATE TABLE test_table_uuid (value UUID);
INSERT INTO test_table_uuid VALUES (generateUUIDv4()), (generateUUIDv4());
SELECT value, toTypeName(value), reinterpretAsUInt128(value) AS res, toTypeName(res) FROM test_table_uuid;
CREATE TABLE combined_test AS SELECT test_table_float.value AS float_value, test_table_int.value AS int_value FROM test_table_float CROSS JOIN test_table_int;
SELECT float_value, toTypeName(float_value), reinterpretAsUInt128(float_value) AS float_res, toTypeName(float_res), int_value, toTypeName(int_value), reinterpretAsUInt128(int_value) AS int_res, toTypeName(int_res) FROM combined_test;
CREATE TABLE nested_test (x UInt64);
INSERT INTO nested_test VALUES (257), (65537), (4294967296);
SELECT reinterpretAsUInt128((SELECT x FROM nested_test WHERE x > 256)) AS res FROM nested_test;
SELECT x, reinterpretAsUInt128(toFloat64(x)) AS float_res FROM nested_test;