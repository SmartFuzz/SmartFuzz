CREATE TABLE test_modulo (a FLOAT, b FLOAT);
INSERT INTO test_modulo VALUES (5, 2), (5.5, 2.1), (0, 3), (-5, 2), (-5.5, -2.1), (10, 0), (-1, -1);
SELECT a, b, modulo(a, b) AS result FROM test_modulo WHERE b != 0;
SELECT a, b, a % b AS result FROM test_modulo WHERE b != 0;
SELECT a, b, modulo(a, b) AS result FROM test_modulo WHERE b > 0;
SELECT a, b, modulo(a, b) AS result FROM test_modulo WHERE a < 0 AND b < 0;
SELECT a, b, modulo(a, b) AS result FROM test_modulo WHERE a = 0 OR b = 1;
SELECT nested_result.a, nested_result.b, modulo(nested_result.a, nested_result.b) AS result FROM (SELECT a, b FROM test_modulo WHERE b != 0) AS nested_result;
SELECT m.a, m.b, m.result, t.extra_value FROM (SELECT a, b, modulo(a, b) AS result FROM test_modulo WHERE b != 0) AS m JOIN (SELECT 1 AS extra_value) AS t ON m.result > 0;
SELECT IF(b = 0, 'Error: Division by zero', modulo(a, b)) AS result FROM test_modulo;