CREATE TABLE test_arrays (id UInt32, values Array(Int32));
INSERT INTO test_arrays VALUES (1, [10, 20, 30]), (2, [40, 50, 60]), (3, [70, 80, 90]);
SELECT arrayElement(values, 1) AS first_element FROM test_arrays;
SELECT values[2] AS second_element FROM test_arrays WHERE id = 1;
SELECT arrayElement(values, -1) AS last_element FROM test_arrays;
SELECT values[-2] AS second_to_last_element FROM test_arrays WHERE id = 2;
SELECT arrayElement(values, 5) AS out_of_bounds_value FROM test_arrays;
SELECT values[0] AS zero_index_value FROM test_arrays WHERE id = 1;
CREATE TABLE another_table (id UInt32, value Int32);
INSERT INTO another_table VALUES (1, 100), (2, 200);
SELECT t.id, arrayElement(t.values, a.value) AS selected_element FROM test_arrays AS t JOIN another_table AS a ON t.id = a.id;
SELECT arrayElement(values, a.value) AS element FROM test_arrays AS t JOIN another_table AS a ON t.id = a.id WHERE a.value != 0;
SELECT a.id, arrayElement(t.values, -a.value) AS reverse_element FROM another_table AS a JOIN test_arrays AS t ON a.id = t.id WHERE a.value <= 2;
SELECT arrayElement(values, -5) AS handled_negative_out_of_bounds FROM test_arrays;
SELECT arrayElement(values, 0) AS zero_index_error FROM test_arrays WHERE id = 3;