CREATE DATABASE test_db;
USE test_db;
CREATE TABLE test_table (id Int32, name String);
INSERT INTO test_table VALUES (1, 'test1'), (2, 'test2');
SELECT currentSchemas(true);
SELECT (SELECT currentSchemas(true) FROM test_table) AS schema_name;
WITH (SELECT count(*) FROM test_table) AS total_count SELECT currentSchemas(true), total_count;
SELECT currentSchemas(true) AS current_schema, name FROM test_table WHERE id = (SELECT max(id) FROM test_table);
ARRAY JOIN (SELECT currentSchemas(true) AS schema_array) SELECT * FROM schema_array;
SELECT currentSchemas(true) WHERE EXISTS (SELECT * FROM test_table WHERE id = 1);
CREATE TABLE test_table2 (id Int32, description String);
INSERT INTO test_table2 VALUES (1, 'description1'), (2, 'description2');
SELECT currentSchemas(true), (SELECT description FROM test_table2 WHERE id = 1) AS desc FROM test_table WHERE id < 3;