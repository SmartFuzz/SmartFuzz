CREATE TABLE test_table (input_value String);
INSERT INTO test_table VALUES ('-32769'), ('-32768'), ('32767'), ('32768'), ('16.9'), ('-16.16'), ('-16'), ('0'), ('NaN'), ('Inf'), ('-Inf'), ('0xc0fe');
SELECT toInt16(input_value) FROM test_table;
CREATE TABLE test_table_float (input_value Float32);
INSERT INTO test_table_float VALUES (16.9), (-32769.1), (32767.5), (32768.2), (-16.16), (0.0);
SELECT toInt16(input_value) AS converted FROM test_table_float WHERE input_value < 0;
CREATE TABLE table_A (id Int32, float_value Float64);
INSERT INTO table_A (id, float_value) VALUES (1, 16.5), (2, -16.2), (3, 32767.9), (4, -32768.1);
SELECT id, toInt16(float_value) FROM table_A WHERE id > 2;
CREATE TABLE table_B (num String);
INSERT INTO table_B VALUES ('100'), ('-100'), ('32768'), ('-32768'), ('123.456');
SELECT num, toInt16(num) AS int_value FROM table_B;
SELECT toInt16((-16.2 + 10.2)) AS rounded_value;
SELECT toInt16(AVG(float_value)) AS avg_value FROM table_A;
CREATE TABLE nested_table (value Float64);
INSERT INTO nested_table VALUES (164.8), (-200.3), (NaN), (Inf);
SELECT toInt16(value) FROM nested_table WHERE value IS NOT NULL;
CREATE TABLE join_table_1 (val1 Float32);
CREATE TABLE join_table_2 (val2 Float32);
INSERT INTO join_table_1 VALUES (100.1), (-32769.9);
INSERT INTO join_table_2 VALUES (-32768.1), (32767.0);
SELECT toInt16(val1) + toInt16(val2) AS sum_value FROM join_table_1 JOIN join_table_2 ON (true);