CREATE TABLE test_dates (date Date) ENGINE = MergeTree() ORDER BY date;
INSERT INTO test_dates VALUES (toDate('2023-01-01'));
SELECT date_add(YEAR, 1, date) FROM test_dates;
SELECT date_add(MONTH, 6, date) FROM test_dates WHERE date = toDate('2023-01-01');
SELECT date_add(DAY, 30, date) FROM test_dates WHERE date BETWEEN toDate('2023-01-01') AND toDate('2023-12-31');
SELECT date_add(HOUR, 12, toDateTime('2023-01-01 00:00:00'));
SELECT date_add(SECOND, 60, toDateTime('2023-01-01 00:00:00')) AS new_time;
SELECT date_add(DAY, -1, date) FROM test_dates WHERE date = toDate('2023-01-01');
CREATE TABLE another_dates (event_time DateTime) ENGINE = MergeTree() ORDER BY event_time;
INSERT INTO another_dates VALUES (toDateTime('2023-01-01 10:00:00'));
SELECT date_add(MONTH, 2, event_time) FROM another_dates;
CREATE TABLE combined_test AS SELECT date_add(YEAR, 2, date) AS future_date FROM test_dates;
SELECT date_add(DAY, 15, (SELECT MAX(date) FROM test_dates)) AS max_date_plus_fifteen;
SELECT date_add(QUARTER, 1, date_add(YEAR, 1, toDate('2023-01-01'))) FROM test_dates;
SELECT date_add(YEAR, CAST((SELECT COUNT() FROM test_dates) AS Int32), date) FROM test_dates;
SELECT date_add(MONTH, 6, (SELECT MIN(event_time) FROM another_dates)) AS min_event_plus_six_months;