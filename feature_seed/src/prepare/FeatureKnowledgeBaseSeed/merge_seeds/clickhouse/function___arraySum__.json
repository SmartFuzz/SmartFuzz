CREATE TABLE test_arraySum (arr Array(Int32));
INSERT INTO test_arraySum VALUES ([1, 2, 3]), ([4, 5, 6]), ([7, 8, 9]);
SELECT arraySum(arr) AS total_sum FROM test_arraySum;
SELECT arraySum(x -> x * 2, arr) AS doubled_sum FROM test_arraySum;
SELECT arraySum(arr) AS total_sum FROM test_arraySum WHERE total_sum > 10;
SELECT arraySum(arr) FROM (SELECT arr FROM test_arraySum WHERE arr = [4, 5, 6]);
SELECT a.id, arraySum(a.arr) AS total_sum FROM (SELECT number AS id, [number, number + 1, number + 2] AS arr FROM numbers(10)) AS a GROUP BY a.id;
SELECT arraySum(x -> x + 1, arr) FROM test_arraySum WHERE arr[1] > 2;
CREATE TABLE nested_test (id Int32, arr Array(Int32));
INSERT INTO nested_test VALUES (1, [10, 20]), (2, [30, 40]), (3, [50, 60]);
SELECT t.id, arraySum(t.arr) AS array_sum FROM nested_test AS t WHERE t.id IN (SELECT id FROM nested_test WHERE arraySum(arr) > 50);
SELECT arraySum((SELECT arr FROM test_arraySum WHERE arr[1] < 5)) AS filtered_sum;
SELECT arraySum(x -> x * x, arr) FROM (SELECT arr FROM test_arraySum WHERE arraySum(arr) < 30);