CREATE TABLE test_dates (year UInt32, month UInt32, day UInt32, date Date32);
INSERT INTO test_dates VALUES (2024, 1, 1), (2024, 12, 31), (2023, 7, 15), (2023, 2, 29), (2022, 1, 100), (2022, 0, 1), (2020, 2, 29);
SELECT makeDate32(year, month, day) AS computed_date FROM test_dates;
SELECT year, month, day, makeDate32(year, month, day) AS created_date FROM test_dates WHERE month IS NOT NULL;
SELECT makeDate32(year, 100) AS created_date FROM test_dates WHERE year IS NOT NULL;
SELECT makeDate32(year, 1, 1) AS start_of_year, makeDate32(year, 12, 31) AS end_of_year FROM test_dates WHERE year = 2024;
WITH (SELECT 2025) AS y, (SELECT 3) AS m, (SELECT 15) AS d SELECT makeDate32(y, m, d) AS specific_date;
SELECT makeDate32(year, day) AS day_of_year_date FROM (SELECT year, day FROM test_dates) WHERE day BETWEEN 1 AND 365;
SELECT makeDate32(year, 0, 1) AS invalid_date FROM test_dates WHERE year = 2022;
SELECT makeDate32(year, month, day) AS valid_date FROM test_dates WHERE day BETWEEN 1 AND 31;
SELECT count(*) FROM test_dates WHERE makeDate32(year, month, day) IS NOT NULL;
CREATE TABLE valid_dates AS SELECT year, month, day, makeDate32(year, month, day) AS created_date FROM test_dates HAVING created_date IS NOT NULL;
SELECT DISTINCT makeDate32(year, 1, 1) FROM test_dates ORDER BY year ASC;
SELECT makeDate32(year, month, day) FROM test_dates WHERE makeDate32(year, month, day) < now();