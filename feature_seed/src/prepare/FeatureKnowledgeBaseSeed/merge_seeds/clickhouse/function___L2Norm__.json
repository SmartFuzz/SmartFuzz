CREATE TABLE vectors (id UInt32, vec Array(Float32));
INSERT INTO vectors VALUES (1, [1.0, 2.0]), (2, [3.0, 4.0]), (3, [0.0]), (4, []);
SELECT L2Norm(vec) FROM vectors WHERE id = 1;
SELECT L2Norm(vec) FROM vectors WHERE id = 2;
SELECT L2Norm(vec) FROM vectors WHERE id = 3;
SELECT L2Norm(vec) FROM vectors WHERE id = 4;
SELECT id, L2Norm(vec) AS norm_value FROM vectors;
SELECT id, L2Norm(vec) AS norm_value FROM vectors WHERE L2Norm(vec) > 0;
SELECT t.id, L2Norm(t.vec) AS norm_value FROM vectors AS t WHERE t.id IN (SELECT id FROM vectors WHERE vec != []);
SELECT L2Norm(arrayJoin(vec)) FROM vectors;
SELECT t1.id, L2Norm(t1.vec) FROM (SELECT id, vec FROM vectors) AS t1 WHERE L2Norm(t1.vec) < 5;