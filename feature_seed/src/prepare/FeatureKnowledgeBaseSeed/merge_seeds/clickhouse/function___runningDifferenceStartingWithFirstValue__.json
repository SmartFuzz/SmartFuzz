CREATE TABLE test_table (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 10.0), (2, 15.0), (3, 20.0);
SELECT id, runningDifferenceStartingWithFirstValue(value) OVER (ORDER BY id) AS running_diff FROM test_table;
CREATE TABLE test_table_2 (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table_2 VALUES (1, 30.0), (2, 25.0), (3, 35.0);
SELECT a.id, runningDifferenceStartingWithFirstValue(a.value) AS running_diff, b.value AS second_value FROM test_table a JOIN test_table_2 b ON a.id = b.id;
CREATE TABLE nested_table (id UInt32, group_id UInt32, value Float64) ENGINE = MergeTree() ORDER BY (group_id, id);
INSERT INTO nested_table VALUES (1, 1, 5.0), (2, 1, 8.0), (3, 1, 12.0), (1, 2, 6.0), (2, 2, 10.0);
SELECT group_id, runningDifferenceStartingWithFirstValue(value) OVER (PARTITION BY group_id ORDER BY id) AS running_diff FROM nested_table;
SELECT id, runningDifferenceStartingWithFirstValue(value) AS running_diff FROM (SELECT id, value FROM test_table WHERE id <= 2) ORDER BY id;
SELECT runningDifferenceStartingWithFirstValue(value) AS running_diff FROM (SELECT DISTINCT value FROM test_table) ORDER BY value;
SELECT id, COUNT(*) AS count, runningDifferenceStartingWithFirstValue(count) OVER (ORDER BY id) AS running_diff FROM (SELECT id FROM test_table GROUP BY id) GROUP BY id ORDER BY id;