CREATE TABLE test_connection (id UInt64, name String);
INSERT INTO test_connection VALUES (1, 'first'), (2, 'second');
SELECT connectionId();
SELECT connectionId() AS conn_id FROM test_connection WHERE id = 1;
SELECT connectionId() FROM (SELECT id FROM test_connection) AS subquery;
SELECT connectionId() + 10 AS new_conn_id FROM system.one;
CREATE TABLE temp_data (num UInt64);
INSERT INTO temp_data VALUES (1), (2), (3);
SELECT connectionId(), id FROM temp_data JOIN test_connection ON temp_data.num = test_connection.id;
WITH (SELECT COUNT(*) FROM test_connection) AS count FROM system.one WHERE connectionId() > 0;
SELECT connectionId() AS conn_id, COUNT(*) FROM test_connection GROUP BY conn_id;
SELECT connectionId() + CAST(AVG(id) AS UInt64) FROM test_connection;
SELECT connectionId() FROM (SELECT id FROM test_connection) AS a CROSS JOIN (SELECT 1 as dummy) AS b;
CREATE TABLE another_test (value UInt64) ENGINE = MergeTree() ORDER BY value;
INSERT INTO another_test VALUES (100), (200), (300);
SELECT connectionId(), value FROM another_test GROUP BY value HAVING connectionId() < 100;