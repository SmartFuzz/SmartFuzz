CREATE TABLE test_dates (id UInt32, event_time DateTime) ENGINE = Memory;
INSERT INTO test_dates VALUES (1, toDateTime('2023-01-15 12:00:00')), (2, toDateTime('2023-02-25 08:30:00')), (3, toDateTime('2023-04-05 15:45:00')), (4, toDateTime('2023-12-31 23:59:59'));
SELECT id, toMonth(event_time) AS month FROM test_dates;
SELECT id, toMonth(event_time) AS month FROM test_dates WHERE month = 4;
SELECT COUNT(*) FROM (SELECT toMonth(event_time) AS month FROM test_dates) AS subquery WHERE month = 2;
CREATE TABLE another_table (value DateTime) ENGINE = Memory;
INSERT INTO another_table VALUES (toDateTime('2023-03-01 00:00:00')), (toDateTime('2023-03-15 00:00:00'));
SELECT t1.id, toMonth(t1.event_time) AS month_date, t2.value, toMonth(t2.value) AS month_time FROM test_dates AS t1 JOIN another_table AS t2 ON toMonth(t1.event_time) = toMonth(t2.value);
SELECT SUM(CASE WHEN toMonth(event_time) = 12 THEN 1 ELSE 0 END) AS December_events FROM test_dates;
SELECT DISTINCT toMonth(toDateTime('2023-11-12 17:12:00')) AS month_value;
SELECT event_time, toMonth(event_time) AS month FROM test_dates WHERE event_time BETWEEN '2023-01-01 00:00:00' AND '2023-12-31 23:59:59';