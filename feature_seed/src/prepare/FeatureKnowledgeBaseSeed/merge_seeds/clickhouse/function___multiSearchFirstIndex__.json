CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('Hello World'), ('Goodbye World'), ('Hello again'), ('Search me here'), ('No matches here');
SELECT multiSearchFirstIndex(haystack, ['World','Hello']) FROM test_strings;
CREATE TABLE test_case_insensitive (haystack String);
INSERT INTO test_case_insensitive VALUES ('hello world'), ('HELLO Universe'), ('earth', 'hello'), ('goodbye HELLO there');
SELECT multiSearchFirstIndexCaseInsensitive(haystack, ['WORLD', 'hello']) FROM test_case_insensitive;
CREATE TABLE utf8_test (haystack String);
INSERT INTO utf8_test VALUES ('Привет мир'), ('Hello World'), ('世界你好'), ('Hola mundo');
SELECT multiSearchFirstIndexUTF8(haystack, ['世界', 'Hello']) FROM utf8_test;
CREATE TABLE complex_search (haystack String);
INSERT INTO complex_search VALUES ('Quick brown fox jumps'), ('Lazy dog'), ('Hello World'), ('World of testing');
SELECT multiSearchFirstIndex(haystack, (SELECT arrayJoin(['World', 'Lazy'])) FROM complex_search) FROM complex_search;
SELECT multiSearchFirstIndexCaseInsensitive(haystack, ['hello', 'testing']) FROM complex_search;
SELECT multiSearchFirstIndex(haystack, ['Nonexistent', 'Quick']) FROM complex_search;
SELECT multiSearchFirstIndexUTF8(arrayJoin(haystack), ['привет', 'mir']) FROM utf8_test;