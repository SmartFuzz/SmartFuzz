DROP TABLE IF EXISTS test_series;
CREATE TABLE test_series (i UInt32, x_value Float64, y_value Float64) ENGINE = Memory;
INSERT INTO test_series (i, x_value, y_value) VALUES (1, 5.0, -3.0), (2, -1.0, 2.0), (3, 0.0, 0.0), (4, 8.0, -5.0), (5, 4.5, 3.5);
SELECT corrStable(x_value, y_value) FROM test_series;
DROP TABLE IF EXISTS empty_series;
CREATE TABLE empty_series (i UInt32, x_value Float64, y_value Float64) ENGINE = Memory;
INSERT INTO empty_series (i, x_value, y_value) VALUES ();
SELECT corrStable(x_value, y_value) FROM empty_series;
DROP TABLE IF EXISTS negative_values;
CREATE TABLE negative_values (i UInt32, x_value Float64, y_value Float64) ENGINE = Memory;
INSERT INTO negative_values (i, x_value, y_value) VALUES (1, -5.6, -4.4), (2, -9.6, -3.0), (3, -1.3, -4.0);
SELECT corrStable(x_value, y_value) FROM negative_values;
DROP TABLE IF EXISTS multi_series;
CREATE TABLE multi_series (i UInt32, x_value Float64, y_value Float64) ENGINE = Memory;
INSERT INTO multi_series (i, x_value, y_value) VALUES (1, 5, 10), (2, 6, 12), (3, 7, 14), (4, 8, 16);
SELECT corrStable(x_value, y_value) FROM multi_series WHERE x_value > 5;
DROP TABLE IF EXISTS joined_series;
CREATE TABLE joined_series (i UInt32, val1 Float64, val2 Float64) ENGINE = Memory;
INSERT INTO joined_series (i, val1, val2) VALUES (1, 1.0, 5.0), (2, 2.0, 10.0), (3, 3.0, 15.0);
CREATE TABLE additional_series (j UInt32, val_x Float64, val_y Float64) ENGINE = Memory;
INSERT INTO additional_series (j, val_x, val_y) VALUES (1, 2.0, 4.0), (2, 3.0, 8.0);
SELECT corrStable(val1, val_y) FROM joined_series INNER JOIN additional_series ON joined_series.i = additional_series.j;
DROP TABLE IF EXISTS nested_query;
CREATE TABLE nested_query (i UInt32, x_value Float64, y_value Float64) ENGINE = Memory;
INSERT INTO nested_query (i, x_value, y_value) VALUES (1, 2.5, 1.2), (2, 4.0, 4.1), (3, 5.5, 5.7);
SELECT (SELECT corrStable(x_value, y_value) FROM nested_query) AS correlation_result;