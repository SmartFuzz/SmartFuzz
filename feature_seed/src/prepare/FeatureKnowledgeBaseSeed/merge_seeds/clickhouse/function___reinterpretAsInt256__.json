CREATE TABLE test_values (value String);
INSERT INTO test_values VALUES ('123'), ('456'), ('789'), ('-987'), ('0');
SELECT value, reinterpretAsInt256(toInt32(value)) AS reinterpreted_value FROM test_values;
CREATE TABLE int_test (id UInt32, num Float64);
INSERT INTO int_test VALUES (1, 1.1), (2, 2.2), (3, 3.3);
SELECT num, reinterpretAsInt256(num) AS reinterpreted_num FROM int_test WHERE id = 2;
CREATE TABLE uuid_test (uuid UUID);
INSERT INTO uuid_test VALUES (generateUUIDv4()), (generateUUIDv4());
SELECT uuid, reinterpretAsInt256(toString(uuid)) AS reinterpreted_uuid FROM uuid_test;
CREATE TABLE date_test (dt DateTime);
INSERT INTO date_test VALUES (now()), (now() - interval 1 day), (now() + interval 1 day);
SELECT dt, reinterpretAsInt256(toUnixTimestamp(dt)) AS reinterpreted_timestamp FROM date_test;
SELECT a.value AS original_value, b.reinterpreted_value FROM test_values a JOIN (SELECT reinterpretAsInt256(toInt32(value)) AS reinterpreted_value FROM test_values) b ON a.value = '123';
SELECT reinterpretAsInt256((SELECT count(*) FROM test_values) * 100) AS count_to_int256;