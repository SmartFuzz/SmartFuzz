CREATE TABLE test_strings (haystack String, needle String);
INSERT INTO test_strings VALUES ('abcde', 'ace');
INSERT INTO test_strings VALUES ('hello world', 'hllwr');
INSERT INTO test_strings VALUES ('abcdefg', 'xyz');
INSERT INTO test_strings VALUES ('sequence', 'qu');
INSERT INTO test_strings VALUES ('algorithm', 'gth');
INSERT INTO test_strings VALUES ('abcdef', 'abcdef');
INSERT INTO test_strings VALUES ('fuzzy', '');
INSERT INTO test_strings VALUES ('', 'nonempty');
INSERT INTO test_strings VALUES ('nonempty', '');
SELECT hasSubsequence(haystack, needle) FROM test_strings;
SELECT COUNT(*) FROM test_strings WHERE hasSubsequence(haystack, needle) = 1;
SELECT hasSubsequence(haystack, 'abc') AS is_subsequence FROM test_strings WHERE haystack LIKE '%abc%';
SELECT haystack, needle, hasSubsequence(haystack, needle) AS result FROM test_strings WHERE needle != '';
SELECT hasSubsequence(haystack, needle) FROM test_strings WHERE haystack LIKE '%abc%' AND needle LIKE '%a%';
CREATE TABLE nested_test AS SELECT haystack, needle, hasSubsequence(haystack, needle) AS result FROM test_strings;
SELECT t1.haystack, t1.needle, t1.result FROM nested_test t1 JOIN (SELECT DISTINCT haystack FROM test_strings) t2 ON t1.haystack = t2.haystack;
SELECT haystack, needle FROM test_strings WHERE hasSubsequence(haystack, needle) = 0 ORDER BY haystack ASC;
INSERT INTO test_strings VALUES ('testcase', 'test');
SELECT hasSubsequence(haystack, needle) FROM test_strings WHERE needle IN (SELECT needle FROM test_strings WHERE haystack = 'abcdefg');
WITH (SELECT count(*) FROM test_strings) AS total FROM test_strings WHERE hasSubsequence(haystack, needle) = 1;
SELECT haystack, needle FROM test_strings WHERE hasSubsequence(haystack, needle) = 1 AND haystack != needle ORDER BY haystack DESC;