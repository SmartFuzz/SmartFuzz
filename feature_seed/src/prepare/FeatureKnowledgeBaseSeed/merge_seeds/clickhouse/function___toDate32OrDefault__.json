CREATE TABLE test_dates (input String, default_date Date32);
INSERT INTO test_dates VALUES ('1930-01-01', toDate32('2020-01-01'));
INSERT INTO test_dates VALUES ('2099-12-31', toDate32('2020-01-01'));
INSERT INTO test_dates VALUES ('xx1930-01-01', toDate32('2020-01-01'));
INSERT INTO test_dates VALUES ('2023-12-31', toDate32('2020-01-01'));
SELECT toDate32OrDefault(input, default_date) AS converted_date FROM test_dates;
SELECT toDate32OrDefault('2000-07-15', toDate32('2020-01-01')) AS valid_conversion;
SELECT toDate32OrDefault('1969-12-31', toDate32('2020-01-01')) AS lower_limit_conversion;
SELECT toDate32OrDefault('2038-01-01', toDate32('2020-01-01')) AS upper_limit_conversion;
SELECT toDate32OrDefault('invalid_date', toDate32('2020-01-01')) AS default_value_conversion;
CREATE TABLE table1 (dateValue String);
INSERT INTO table1 VALUES ('1920-01-01'), ('invalid_date');
SELECT toDate32OrDefault(dateValue, toDate32('2000-01-01')) FROM table1;
SELECT toDate32OrDefault('1970-01-01', toDate32('2020-01-01')) AS valid_date, toDate32OrDefault('unknown', toDate32('2020-01-01')) AS default_case FROM table1;
SELECT (SELECT toDate32OrDefault('2001-01-01', toDate32('2020-01-01')) AS inner_conversion) AS result_in_subquery;
SELECT (SELECT toDate32OrDefault(dateValue, toDate32('2010-01-01')) FROM table1 WHERE dateValue != 'invalid_date') AS filtered_conversion;