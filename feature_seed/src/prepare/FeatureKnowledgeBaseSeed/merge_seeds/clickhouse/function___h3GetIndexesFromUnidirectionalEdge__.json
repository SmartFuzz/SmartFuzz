CREATE TABLE edges (id UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO edges VALUES (1248204388774707199);
SELECT h3GetIndexesFromUnidirectionalEdge(id) AS indexes FROM edges;
SELECT h3GetIndexesFromUnidirectionalEdge(0) AS indexes;
SELECT h3GetIndexesFromUnidirectionalEdge(18446744073709551615) AS indexes;
SELECT h3GetIndexesFromUnidirectionalEdge(-1) AS indexes;
SELECT *(SELECT h3GetIndexesFromUnidirectionalEdge(id) FROM edges) AS indexes;
SELECT DISTINCT h3GetIndexesFromUnidirectionalEdge(id) FROM edges WHERE id > 1000000000000000000;
WITH (SELECT * FROM edges) AS subquery SELECT h3GetIndexesFromUnidirectionalEdge(subquery.id) AS indexes FROM subquery;
CREATE TABLE test_edges (edge UInt64) ENGINE = MergeTree() ORDER BY edge;
INSERT INTO test_edges VALUES (1248204388774707199), (18446744073709551615), (0), (9999999999999999999);
SELECT edge, h3GetIndexesFromUnidirectionalEdge(edge) AS indexes FROM test_edges;
SELECT a.id, h3GetIndexesFromUnidirectionalEdge(b.edge) AS indexes FROM edges AS a JOIN test_edges AS b ON a.id = b.edge;
SELECT h3GetIndexesFromUnidirectionalEdge(CAST(NULL AS UInt64)) AS indexes;