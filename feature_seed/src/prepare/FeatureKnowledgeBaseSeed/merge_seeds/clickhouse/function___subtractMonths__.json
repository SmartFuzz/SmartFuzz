CREATE TABLE test_dates (date_col Date, date_time_col DateTime, date_str_col String);
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
SELECT subtractMonths(date_col, 1) AS subtract_months_with_date FROM test_dates;
SELECT subtractMonths(date_time_col, 2) AS subtract_months_with_date_time FROM test_dates;
SELECT subtractMonths(date_str_col, 3) AS subtract_months_with_date_time_string FROM test_dates;
SELECT subtractMonths(subtractMonths(date_col, 1), 1) AS double_subtract_months FROM test_dates;
SELECT subtractMonths(date_col, toUInt32(6)) AS subtract_months_dynamic FROM test_dates;
WITH (SELECT toDate('2025-05-01')) AS ref_date SELECT subtractMonths(ref_date, 6) AS compare_subtract_months;
WITH (SELECT date_col FROM test_dates) AS base SELECT subtractMonths(base.date_col, 12) AS subtract_months_nested FROM base;
CREATE TABLE temp_dates AS SELECT subtractMonths(date_col, 1) AS new_date FROM test_dates;
SELECT subtractMonths(new_date, 1) FROM temp_dates;
SELECT subtractMonths(toDate('2022-12-31'), 2) AS last_day_subtract_months;
SELECT subtractMonths(toDateTime('2024-02-29 23:59:59'), 1) AS leap_year_subtract_month;
SELECT subtractMonths(date_time_col, 1) FROM test_dates JOIN (SELECT DISTINCT date_col FROM test_dates) AS sub ON test_dates.date_col = sub.date_col;
SELECT subtractMonths(toDate('2020-02-29'), 1) AS subtract_leap_day;
SELECT subtractMonths(toDate('2023-01-31'), 1) AS end_of_month_subtract_month;