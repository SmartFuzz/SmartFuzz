CREATE TABLE ip_addresses (address String);
INSERT INTO ip_addresses VALUES ('127.0.0.1'), ('::1'), ('invalid_ip'), ('2001:0db8:85a3:0000:0000:8a2e:0370:7334'), ('256.256.256.256');
SELECT address, toIPv6OrZero(address) AS ipv6_conversion FROM ip_addresses;
WITH '192.168.1.1' AS valid_IPv4_string SELECT toIPv6OrZero(valid_IPv4_string) AS converted_ipv6;
WITH (SELECT address FROM ip_addresses WHERE address = 'invalid_ip') AS invalid_ip_query SELECT toIPv6OrZero((SELECT * FROM invalid_ip_query));
CREATE TABLE test_ips AS SELECT address, toIPv6OrZero(address) FROM ip_addresses;
SELECT a.address, b.address, toIPv6OrZero(a.address) AS ipv6_a, toIPv6OrZero(b.address) AS ipv6_b FROM ip_addresses a JOIN ip_addresses b ON a.address <> b.address;
SELECT COUNT(*) FROM (SELECT toIPv6OrZero(address) FROM ip_addresses) AS converted_ips WHERE converted_ips.ipv6_converted = '::';
WITH 'abc:def:ghi:jkl' AS malformed_ip SELECT toIPv6OrZero(malformed_ip) AS result;
SELECT toIPv6OrZero(NULL) AS null_case;