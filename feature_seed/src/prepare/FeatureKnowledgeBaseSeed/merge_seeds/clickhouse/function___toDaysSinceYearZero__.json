CREATE TABLE test_dates (event_date Date);
INSERT INTO test_dates VALUES (toDate('0000-01-01'));
INSERT INTO test_dates VALUES (toDate('2023-09-08'));
INSERT INTO test_dates VALUES (toDate('1969-12-31'));
INSERT INTO test_dates VALUES (toDate('2000-01-01'));
INSERT INTO test_dates VALUES (toDate('9999-12-31'));
SELECT toDaysSinceYearZero(event_date) FROM test_dates;
SELECT event_date, toDaysSinceYearZero(event_date) AS days_since_year_zero FROM test_dates ORDER BY event_date;
SELECT AVG(toDaysSinceYearZero(event_date)) FROM test_dates;
SELECT MAX(toDaysSinceYearZero(event_date)) AS max_days FROM test_dates WHERE event_date < toDate('2078-09-08');
CREATE TABLE test_dates_with_timezone (event_date DateTime64(3), tz String);
INSERT INTO test_dates_with_timezone VALUES (toDateTime64('2023-09-08 12:00:00', 3), 'UTC'), (toDateTime64('2000-01-01 01:00:00', 3), 'Europe/London');
SELECT tz, toDaysSinceYearZero(event_date) FROM test_dates_with_timezone;
WITH (SELECT toDaysSinceYearZero(toDate('2000-01-01')) + 1) AS days_since_2000 SELECT event_date, days_since_2000 FROM test_dates;
SELECT d.event_date, d.days_since_0 FROM (SELECT event_date, toDaysSinceYearZero(event_date) AS days_since_0 FROM test_dates) AS d WHERE d.days_since_0 > 7300;
CREATE TABLE date_range AS SELECT toDate('2023-01-01') + number AS event_date FROM numbers(365);
SELECT toDaysSinceYearZero(event_date) FROM date_range WHERE event_date BETWEEN toDate('2023-01-01') AND toDate('2023-12-31');