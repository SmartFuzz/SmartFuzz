CREATE TABLE test_dates (id Int32, event_date DateTime);
INSERT INTO test_dates VALUES (1, toDateTime('2024-01-01 12:00:00'));
INSERT INTO test_dates VALUES (2, toDateTime('2024-01-01 00:00:00'));
SELECT subtractSeconds(event_date, 3600) AS one_hour_earlier FROM test_dates;
WITH toDate('2024-01-01') AS date, toDateTime('2024-01-01 00:00:00') AS date_time, '2024-01-01 00:00:00' AS date_time_string SELECT subtractSeconds(date, 60) AS subtract_seconds_with_date, subtractSeconds(date_time, 60) AS subtract_seconds_with_date_time, subtractSeconds(date_time_string, 60) AS subtract_seconds_with_date_time_string;
WITH (SELECT MAX(event_date) FROM test_dates) AS max_date, (SELECT MIN(event_date) FROM test_dates) AS min_date SELECT subtractSeconds(max_date, 1800) AS thirty_minutes_before_max, subtractSeconds(min_date, 7200) AS two_hours_before_min;
CREATE TABLE events (id Int32, event_time DateTime, event_name String);
INSERT INTO events VALUES (1, toDateTime('2024-01-01 12:00:00'), 'New Year Celebration');
INSERT INTO events VALUES (2, toDateTime('2024-01-02 15:00:00'), 'Post New Year Workshop');
SELECT e.event_name, subtractSeconds(e.event_time, 86400) AS one_day_before FROM events e WHERE e.event_time > toDateTime('2024-01-01 00:00:00');
WITH (SELECT COUNT(*) FROM test_dates) AS total_events SELECT subtractSeconds(toDateTime('2024-01-01 00:00:00'), total_events) AS adjusted_time;
CREATE TABLE event_logs (event_id Int32, log_time DateTime);
INSERT INTO event_logs VALUES (1, toDateTime('2024-01-01 00:00:01'));
INSERT INTO event_logs VALUES (2, toDateTime('2024-01-01 00:00:02'));
SELECT el.event_id, subtractSeconds(el.log_time, 1) AS log_time_minus_one FROM event_logs el JOIN events ev ON el.event_id = ev.id WHERE ev.event_name = 'New Year Celebration';
CREATE TABLE date_test (date_field DateTime);
INSERT INTO date_test VALUES (toDateTime('2024-01-01 10:00:00'));
SELECT subtractSeconds(date_field, 120) AS two_minutes_before FROM date_test;