CREATE TABLE test_xor (val1 UInt8, val2 UInt8);
INSERT INTO test_xor VALUES (0, 0), (0, 1), (1, 0), (1, 1);
SELECT xor(val1, val2) FROM test_xor;
CREATE TABLE test_complex (a UInt8, b UInt8, c UInt8);
INSERT INTO test_complex VALUES (0, 1, 1), (1, 0, 1), (1, 1, 0);
SELECT xor(xor(a, b), c) FROM test_complex;
CREATE TABLE nullable_test (val1 Nullable(UInt8), val2 Nullable(UInt8));
INSERT INTO nullable_test VALUES (null, 1), (1, null), (null, null), (1, 1);
SELECT xor(val1, val2) FROM nullable_test;
CREATE TABLE nested_xor (id UInt8, check1 UInt8, check2 UInt8, check3 UInt8);
INSERT INTO nested_xor VALUES (1, 0, 1, 0), (2, 1, 1, 1), (3, 0, 0, 1);
SELECT id, xor(xor(check1, check2), check3) FROM nested_xor;
CREATE TABLE join_xor (a UInt8, b UInt8);
INSERT INTO join_xor VALUES (1, 0), (0, 1), (1, 1);
SELECT a, b, xor(a, b) FROM join_xor JOIN test_xor ON join_xor.a = test_xor.val1;
CREATE TABLE multi_join_xor (v1 UInt8, v2 UInt8, v3 UInt8);
INSERT INTO multi_join_xor VALUES (0, 1, 1), (1, 0, 1), (1, 1, 0);
SELECT xor(xor(v1, v2), v3) AS result FROM multi_join_xor WHERE result IS NOT NULL;