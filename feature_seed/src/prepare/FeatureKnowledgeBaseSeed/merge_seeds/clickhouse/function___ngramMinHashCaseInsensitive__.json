CREATE TABLE test_strings (input_string String);
INSERT INTO test_strings VALUES ('ClickHouse'), ('CLICKhouse'), ('CLICKHOUSE'), ('Clickhouse'), ('Cli'), ('H'), ('12345'), (' '), ('abc defghi jklmn opqr stu'), ('aaaaaa'), ('abcdefghijklmno');
SELECT ngramMinHashCaseInsensitive(input_string) AS hashes FROM test_strings;
SELECT ngramMinHashCaseInsensitive(input_string, 4) AS hashes FROM test_strings;
SELECT ngramMinHashCaseInsensitive(input_string, 1, 3) AS hashes FROM test_strings;
SELECT ngramMinHashCaseInsensitive(input_string, 25, 10) AS hashes FROM test_strings;
SELECT DISTINCT ngramMinHashCaseInsensitive(input_string) OVER () AS hash_results FROM test_strings;
SELECT COUNT(*) FROM (SELECT ngramMinHashCaseInsensitive(input_string) FROM test_strings) AS subquery;
CREATE TABLE reference_strings (ref_string String);
INSERT INTO reference_strings VALUES ('ClickHouse'), ('CLICKhouse');
SELECT a.input_string, b.ref_string FROM test_strings AS a JOIN reference_strings AS b ON ngramMinHashCaseInsensitive(a.input_string) = ngramMinHashCaseInsensitive(b.ref_string);
SELECT COUNT(*) FROM (SELECT ngramMinHashCaseInsensitive(input_string) AS hashes FROM test_strings WHERE input_string LIKE 'C%') AS subquery;
SELECT ngramMinHashCaseInsensitive(input_string, 3, 20) FROM (SELECT DISTINCT input_string FROM test_strings) AS unique_strings;