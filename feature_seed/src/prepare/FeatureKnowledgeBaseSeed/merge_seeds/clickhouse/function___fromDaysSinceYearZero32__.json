CREATE TABLE test_dates (days_since_year_zero UInt32);
INSERT INTO test_dates VALUES (0), (1), (365), (9999), (18262);
SELECT fromDaysSinceYearZero32(days_since_year_zero) FROM test_dates;
CREATE TABLE date_results AS SELECT fromDaysSinceYearZero32(days_since_year_zero) AS date_result FROM test_dates;
SELECT date_result FROM date_results WHERE date_result > '1970-01-01';
SELECT COUNT(*) FROM date_results WHERE date_result IS NOT NULL;
WITH (SELECT fromDaysSinceYearZero32(days_since_year_zero) FROM test_dates WHERE days_since_year_zero < 365) AS early_dates SELECT COUNT(*) FROM early_dates;
SELECT d1.date_result, d2.date_result FROM date_results AS d1 JOIN date_results AS d2 ON d1.date_result < d2.date_result;
SELECT d.date_result FROM (SELECT fromDaysSinceYearZero32(days_since_year_zero) AS date_result FROM test_dates WHERE days_since_year_zero BETWEEN 0 AND 18262) AS d WHERE d.date_result >= '2000-01-01' AND d.date_result <= '2020-01-01';
WITH (SELECT fromDaysSinceYearZero32(days_since_year_zero) AS date_result FROM test_dates) AS result SELECT MAX(date_result), MIN(date_result) FROM result;