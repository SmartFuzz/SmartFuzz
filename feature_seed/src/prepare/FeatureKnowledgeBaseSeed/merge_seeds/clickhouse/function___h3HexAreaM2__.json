CREATE TABLE hexagon_test (resolution UInt8);
INSERT INTO hexagon_test VALUES (0), (1), (5), (10), (15);
SELECT h3HexAreaM2(resolution) AS area FROM hexagon_test;
SELECT (SELECT h3HexAreaM2(13) * COUNT(*) FROM hexagon_test) AS total_area FROM hexagon_test;
SELECT resolution, h3HexAreaM2(resolution) AS area FROM hexagon_test WHERE resolution BETWEEN 0 AND 15;
WITH (SELECT h3HexAreaM2(0) AS min_area, h3HexAreaM2(15) AS max_area) AS bounds SELECT * FROM hexagon_test WHERE resolution = 0 OR resolution = 15;
SELECT t1.resolution, t2.area FROM hexagon_test t1 JOIN (SELECT resolution, h3HexAreaM2(resolution) AS area FROM hexagon_test) t2 ON t1.resolution = t2.resolution;
SELECT h3HexAreaM2(7) AS area_7, h3HexAreaM2(8) AS area_8, (h3HexAreaM2(7) + h3HexAreaM2(8)) / 2 AS avg_area;
SELECT SUM(h3HexAreaM2(resolution)) AS total_area FROM hexagon_test WHERE resolution < 15;
SELECT h3HexAreaM2(resolution) AS area FROM (SELECT DISTINCT resolution FROM hexagon_test) AS unique_resolutions WHERE resolution >= 0;