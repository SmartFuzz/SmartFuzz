CREATE TABLE test_table (id UInt32, name String, created_at DateTime);
INSERT INTO test_table VALUES (1, 'example1', toDateTime('2023-01-01 00:00:00')), (2, 'example2', toDateTime('2023-02-01 00:00:00'));
SELECT cityHash64(name, toDateTime('2023-03-01 00:00:00'), id) AS hash_value FROM test_table WHERE id < 3;
SELECT cityHash64(array(id, name), created_at) AS hash_value FROM test_table;
CREATE TABLE another_table (id UInt32, description String);
INSERT INTO another_table VALUES (1, 'sample description'), (2, 'another description');
SELECT cityHash64(t.name, a.description) AS combined_hash FROM test_table t JOIN another_table a ON t.id = a.id;
SELECT cityHash64(array('foo', 'bar', 'baz'), array(1, 2, 3)) AS multiple_array_hash;
SELECT cityHash64(id, name, created_at) FROM test_table WHERE created_at BETWEEN toDateTime('2023-01-01 00:00:00') AND toDateTime('2023-12-31 23:59:59');
SELECT groupBitXor(cityHash64(*)) FROM test_table;
SELECT cityHash64(array(name, created_at), 42) AS final_hash FROM test_table WHERE id = (SELECT MAX(id) FROM test_table);
CREATE TABLE test_tuple (data Tuple(UInt32, String));
INSERT INTO test_tuple VALUES (tuple(1, 'tuple1')), (tuple(2, 'tuple2'));
SELECT cityHash64(data) FROM test_tuple;
SELECT cityHash64(cityHash64(name, id), 'constant_value') AS nested_hash FROM test_table;