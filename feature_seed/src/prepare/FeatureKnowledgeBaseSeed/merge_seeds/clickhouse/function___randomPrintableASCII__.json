CREATE TABLE test_random (id UInt32, random_str String);
INSERT INTO test_random SELECT number, randomPrintableASCII(0) FROM system.numbers LIMIT 10;
INSERT INTO test_random SELECT number, randomPrintableASCII(1) FROM system.numbers LIMIT 10;
INSERT INTO test_random SELECT number, randomPrintableASCII(10) FROM system.numbers LIMIT 10;
INSERT INTO test_random SELECT number, randomPrintableASCII(50) FROM system.numbers LIMIT 10;
INSERT INTO test_random SELECT number, randomPrintableASCII(1000) FROM system.numbers LIMIT 10;
SELECT id, random_str, length(random_str) FROM test_random;
SELECT id, random_str FROM test_random WHERE length(random_str) = 10;
SELECT id, random_str FROM test_random WHERE random_str LIKE '%A%';
SELECT id, random_str FROM test_random WHERE length(random_str) > 5 AND length(random_str) < 50;
SELECT t.id, t.random_str, randomPrintableASCII(5) AS new_str FROM test_random t INNER JOIN system.numbers n ON t.id = n.number WHERE n.number < 10;
SELECT (SELECT COUNT(*) FROM test_random WHERE length(random_str) = 10) AS ten_length_count, (SELECT COUNT(*) FROM test_random WHERE length(random_str) = 50) AS fifty_length_count;
CREATE TABLE random_test AS SELECT randomPrintableASCII(30) AS rand_str FROM system.numbers LIMIT 100;
SELECT rand_str, length(rand_str) FROM random_test WHERE length(rand_str) < 20;