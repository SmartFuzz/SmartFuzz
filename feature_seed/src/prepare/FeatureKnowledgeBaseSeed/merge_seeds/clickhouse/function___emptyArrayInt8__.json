SELECT emptyArrayInt8();
CREATE TABLE test_table (id Int8, value Array(Int8));
INSERT INTO test_table VALUES (1, emptyArrayInt8()), (2, [1, 2, 3]), (3, emptyArrayInt8());
SELECT id, value FROM test_table WHERE value = emptyArrayInt8();
SELECT id, arrayJoin(value) as val FROM test_table WHERE value != emptyArrayInt8();
CREATE TABLE another_table (ref_id Int8, data Array(Int8));
INSERT INTO another_table VALUES (1, emptyArrayInt8()), (2, [4, 5]);
SELECT t.id, arrayJoin(t.value) AS val FROM test_table t LEFT JOIN another_table a ON t.id = a.ref_id WHERE a.data = emptyArrayInt8();
SELECT emptyArrayInt8() AS my_empty_array, (SELECT arraySum(value) FROM test_table) AS total FROM test_table LIMIT 1;
SELECT t.id, emptyArrayInt8() AS empty_array FROM test_table t WHERE NOT exists (SELECT 1 FROM another_table a WHERE a.ref_id = t.id);