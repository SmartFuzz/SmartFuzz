CREATE TABLE test_strings (id UInt32, original_string String);
INSERT INTO test_strings VALUES (1, 'TestString'), (2, 'AnotherExample'), (3, 'Base58Encode'), (4, ''), (5, 'A'), (6, '1'), (7, ' ');
SELECT base58Encode(original_string) FROM test_strings;
SELECT id, base58Encode(original_string) as encoded_string FROM test_strings WHERE id IN (1, 3);
SELECT id, base58Encode(concat(original_string, 'Suffix')) as encoded_suffix FROM test_strings;
WITH (SELECT original_string FROM test_strings WHERE id = 2) AS t AS subquery SELECT base58Encode(t);
SELECT a.id, base58Encode(CONCAT(a.original_string, b.additional_string)) FROM test_strings a JOIN (SELECT id, 'JoinString' as additional_string FROM test_strings LIMIT 3) b ON a.id = b.id;
CREATE TABLE additional_data (code String);
INSERT INTO additional_data VALUES ('12345'), ('HelloWorld'), ('Base58Test');
SELECT base58Encode(original_string) FROM test_strings UNION ALL SELECT base58Encode(code) FROM additional_data;
SELECT base58Encode(original_string) FROM test_strings WHERE original_string != '' ORDER BY id;
CREATE TABLE complex_test (data String DEFAULT 'Base58');
INSERT INTO complex_test VALUES ('CustomData'), ('MoreData');
SELECT base58Encode(data) FROM complex_test UNION SELECT base58Encode(original_string) FROM test_strings WHERE original_string LIKE 'A%' ORDER BY data;