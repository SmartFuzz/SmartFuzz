CREATE TABLE test_dates (event_date Date, event_date_time DateTime, event_date_time_string String) ENGINE = MergeTree() ORDER BY event_date;
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
WITH toDate('2024-01-01') AS date, toDateTime('2024-01-01 00:00:00') AS date_time, '2024-01-01 00:00:00' AS date_time_string SELECT addSeconds(date, 30) AS add_seconds_with_date, addSeconds(date_time, 30) AS add_seconds_with_date_time, addSeconds(date_time_string, 30) AS add_seconds_with_date_time_string;
WITH (SELECT event_date FROM test_dates LIMIT 1) AS date, (SELECT event_date_time FROM test_dates LIMIT 1) AS date_time SELECT addSeconds(date, 60) AS add_seconds_to_date, addSeconds(date_time, 60) AS add_seconds_to_date_time;
WITH toDate('2024-01-01') AS date, (SELECT max(event_date_time) FROM test_dates) AS max_date_time SELECT addSeconds(date, 86400) AS add_one_day_to_date, addSeconds(max_date_time, 86400) AS add_one_day_to_max_date_time;
SELECT arrayJoin([toDate('2024-01-01'), toDate('2024-01-02'), toDate('2024-01-03')]) AS date_array, addSeconds(date_array, 3600) AS add_one_hour_to_dates FROM system.one;
WITH '2024-01-01 00:00:00' AS date_time_string SELECT addSeconds(date_time_string, -3600) AS subtract_one_hour;
WITH toDateTime('2024-01-01 23:59:59') AS max_date_time SELECT addSeconds(max_date_time, 1) AS exceed_max_date_time;
SELECT date, event_date_time, event_date_time_string, addSeconds(event_date_time, 300) AS add_five_minutes FROM test_dates WHERE event_date = toDate('2024-01-01');
WITH toDateTime('2024-01-01 05:00:00') AS morning_time SELECT addSeconds(morning_time, 18000) AS add_five_hours;