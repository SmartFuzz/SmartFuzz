CREATE TABLE mww_ttest (sample_data FLOAT, sample_index Int32);
INSERT INTO mww_ttest VALUES (1.2, 0), (2.4, 0), (3.1, 0), (4.0, 1), (5.0, 1), (1.8, 1);
SELECT mannWhitneyUTest('two-sided')(sample_data, sample_index) FROM mww_ttest;
SELECT mannWhitneyUTest('greater')(sample_data, sample_index) FROM mww_ttest WHERE sample_index = 0;
SELECT mannWhitneyUTest('less')(sample_data, sample_index) FROM mww_ttest WHERE sample_index = 1;
CREATE TABLE sample_test (sample_data Decimal(10, 2), sample_index Int32);
INSERT INTO sample_test VALUES (1.50, 0), (2.75, 0), (3.50, 1), (4.25, 1), (2.00, 0), (5.00, 1);
SELECT mannWhitneyUTest('greater', 0)(sample_data, sample_index) FROM sample_test;
SELECT mannWhitneyUTest('two-sided', 1)(sample_data, sample_index) FROM sample_test;
CREATE TABLE complex_test AS SELECT sample_data, sample_index FROM mww_ttest GROUP BY sample_index;
INSERT INTO complex_test SELECT sample_data, sample_index FROM mww_ttest WHERE sample_index = 0;
SELECT mannWhitneyUTest('greater')(sample_data, sample_index) FROM complex_test t1 JOIN mww_ttest t2 ON t1.sample_index = t2.sample_index;
SELECT mannWhitneyUTest('two-sided')(sample_data, sample_index) FROM (SELECT sample_data, sample_index FROM mww_ttest WHERE sample_index IN (0, 1));
SELECT mannWhitneyUTest('less')(sample_data, sample_index) FROM (SELECT sample_data, sample_index FROM sample_test WHERE sample_data > 2.0) GROUP BY sample_index;
CREATE TABLE boundary_test (sample_data Float64, sample_index Int32);
INSERT INTO boundary_test VALUES (0.0, 0), (0.0, 1), (1.0, 0), (10.0, 1), (5.0, 0), (7.5, 1);
SELECT mannWhitneyUTest('greater')(sample_data, sample_index) FROM boundary_test;
SELECT mannWhitneyUTest('two-sided')(sample_data, sample_index) FROM boundary_test WHERE sample_data BETWEEN 0 AND 10;