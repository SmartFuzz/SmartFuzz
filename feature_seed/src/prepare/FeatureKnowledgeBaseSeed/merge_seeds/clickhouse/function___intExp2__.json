CREATE TABLE test_intExp2 (a UInt64);
INSERT INTO test_intExp2 VALUES (0), (1), (2), (3), (4), (5);
SELECT intExp2(a) FROM test_intExp2;
SELECT intExp2(a) + 1 AS result FROM test_intExp2;
CREATE TABLE test_intExp2_nested (b UInt64, c UInt64);
INSERT INTO test_intExp2_nested VALUES (0, 1), (1, 2), (2, 3);
SELECT intExp2(b) * intExp2(c) AS product FROM test_intExp2_nested;
SELECT a, intExp2(a) FROM test_intExp2 WHERE intExp2(a) > 5;
SELECT intExp2(a) FROM (SELECT a FROM test_intExp2 WHERE a < 6) AS subquery;
SELECT intExp2(a) FROM test_intExp2 ORDER BY intExp2(a) DESC;
WITH (SELECT max(a) FROM test_intExp2) AS max_value SELECT intExp2(max_value) AS int_exp2_max;