CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('abc=111, def=222, ghi=333');
INSERT INTO test_strings VALUES ('name="John Doe", age=30, city="New York"');
INSERT INTO test_strings VALUES ('key1=value1, key2=value2, key3=value3');
INSERT INTO test_strings VALUES ('empty_string=, non_empty=valid');
SELECT extractAllGroupsVertical(haystack, '([\w]+)=([\w]+)') FROM test_strings;
SELECT extractAllGroupsVertical(haystack, '([\w]+)="([^"]+)"') FROM test_strings;
SELECT extractAllGroupsVertical(haystack, '([a-z]+)=([0-9]+)') FROM test_strings WHERE haystack LIKE '%key=%';
WITH (SELECT haystack FROM test_strings WHERE haystack LIKE '%=%') AS valid_haystack SELECT extractAllGroupsVertical(valid_haystack, '([\w]+)=([\w]+)') FROM valid_haystack;
CREATE TABLE pattern_groups (pattern String);
INSERT INTO pattern_groups VALUES ('([\w]+)=([\w]+)');
INSERT INTO pattern_groups VALUES ('([a-z]+)=([0-9]+)');
SELECT extractAllGroupsVertical(haystack, pattern) FROM test_strings, pattern_groups;
SELECT extractAllGroupsVertical(haystack, '(\w+)=(\w+)') FROM (SELECT haystack FROM test_strings WHERE haystack != '') ORDER BY haystack;
SELECT extractAllGroupsVertical(haystack, '(.*?)=(.*?)') FROM test_strings WHERE haystack = 'key1=value1, key2=value2';