CREATE TABLE ipv6_test (ip_string String);
INSERT INTO ipv6_test VALUES ('2001:438:ffff::407d:1bc1'), ('127.0.0.1'), ('::1'), ('invalid-ip'), ('2607:f0d0:1002:51::4'), ('0:0:0:0:0:0:0:1');
SELECT ip_string, toIPv6(ip_string) AS ipv6_converted FROM ipv6_test;
WITH (SELECT COUNT(*) FROM ipv6_test) AS total FROM ipv6_test ORDER BY total;
SELECT ip_string, toIPv6(ip_string) FROM ipv6_test WHERE ip_string LIKE '2001:%';
SELECT ip_string, hex(toIPv6(ip_string)) FROM ipv6_test WHERE toIPv6(ip_string) IS NOT NULL;
SELECT DISTINCT toIPv6(CONCAT(ip_string, '::')) FROM ipv6_test;
SELECT toIPv6(ip_string) FROM ipv6_test WHERE toIPv6(ip_string) IS NOT NULL AND ip_string NOT LIKE 'invalid-%';
CREATE TEMPORARY TABLE valid_ipv6 AS SELECT ip_string FROM ipv6_test WHERE toIPv6(ip_string) IS NOT NULL;
SELECT COUNT(*) FROM valid_ipv6;
SELECT a.ip_string, b.ip_string, toIPv6(a.ip_string) AS a_ipv6, toIPv6(b.ip_string) AS b_ipv6 FROM ipv6_test AS a JOIN ipv6_test AS b ON a.ip_string != b.ip_string;
SELECT toIPv6(ip_string) AS ipv6_output FROM ipv6_test HAVING ipv6_output IS NOT NULL;
SELECT toIPv6(NULL) AS null_case;
SELECT ip_string, toIPv6(ip_string) AS ipv6_converted FROM ipv6_test WHERE LENGTH(ip_string) < 40;