CREATE TABLE test_floats (value Float64);
INSERT INTO test_floats VALUES (1.0), (2.5), (3.7), (Infinity), (-Infinity), (NaN);
SELECT value, ifNotFinite(value, 0) AS result FROM test_floats;
SELECT value, ifNotFinite(value, -1) AS fallback_value FROM test_floats WHERE result = -1;
CREATE TABLE fallback_test (id Int32, fallback Float64);
INSERT INTO fallback_test VALUES (1, 0.0), (2, 10.0);
SELECT t1.value, ifNotFinite(t1.value, t2.fallback) AS checked_value FROM test_floats t1 JOIN fallback_test t2 ON t1.value > 0;
SELECT AVG(ifNotFinite(value, 0)) AS average_value FROM test_floats;
WITH (SELECT value FROM test_floats WHERE value < 0) AS negative_vals SELECT ifNotFinite(value, 0) FROM negative_vals;
CREATE TABLE nested_table (id Int32, value Float64, fallback Float64);
INSERT INTO nested_table VALUES (1, Infinity, 100.0), (2, NaN, 200.0), (3, 3.5, 300.0);
SELECT id, ifNotFinite(value, fallback) AS checked_value FROM nested_table WHERE id IN (SELECT id FROM nested_table WHERE value IS NOT NULL);