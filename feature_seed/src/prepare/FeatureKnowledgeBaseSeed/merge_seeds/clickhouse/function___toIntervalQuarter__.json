CREATE TABLE test_dates (date Date) ENGINE = MergeTree() ORDER BY date;
INSERT INTO test_dates VALUES (toDate('2024-01-01')), (toDate('2024-04-01')), (toDate('2024-07-01'));
SELECT date, date + toIntervalQuarter(1) AS result FROM test_dates;
SELECT date, date + toIntervalQuarter(-1) AS result FROM test_dates WHERE date > toDate('2024-02-01');
WITH toIntervalQuarter(2) AS interval_q SELECT date, date + interval_q AS result FROM test_dates;
CREATE TABLE quarterly_data (quarter_start Date) ENGINE = MergeTree() ORDER BY quarter_start;
INSERT INTO quarterly_data VALUES (toDate('2024-01-01')), (toDate('2024-04-01')), (toDate('2024-07-01'));
SELECT q.quarter_start, q.quarter_start + toIntervalQuarter(1) AS next_quarter FROM quarterly_data q WHERE q.quarter_start < toDate('2024-07-01');
WITH (SELECT COUNT(*) FROM test_dates) AS total_records SELECT date, date + toIntervalQuarter(total_records) AS future_date FROM test_dates;
WITH (SELECT MIN(date) FROM test_dates) AS min_date, (SELECT MAX(date) FROM test_dates) AS max_date SELECT min_date, max_date + toIntervalQuarter(1) AS one_quarter_later;
SELECT date + toIntervalQuarter(toNumber('3')) AS three_quarters_later FROM test_dates;
SELECT date + toIntervalQuarter(CAST(1.0 AS Float64)) AS one_quarter_float FROM test_dates;
SELECT date + toIntervalQuarter(-toNumber('2')) AS two_quarters_back FROM test_dates WHERE date < toDate('2024-06-01');