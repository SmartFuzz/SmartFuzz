SELECT emptyArrayInt32();
CREATE TABLE test_table (id Int32, values Array(Int32));
INSERT INTO test_table VALUES (1, emptyArrayInt32()), (2, [1, 2, 3]), (3, emptyArrayInt32());
SELECT id, arrayJoin(values) AS value FROM test_table WHERE arrayLength(values) = 0;
SELECT id FROM test_table WHERE values = emptyArrayInt32();
CREATE TABLE another_table (id Int32, arr Array(Int32));
INSERT INTO another_table VALUES (1, [5, 6, 7]), (2, emptyArrayInt32()), (3, [8, 9]);
SELECT test_table.id FROM test_table JOIN another_table ON test_table.id = another_table.id WHERE test_table.values = emptyArrayInt32();
SELECT count() FROM test_table WHERE arrayLength(values) = 0;
SELECT arrayMap(x -> x + 1, emptyArrayInt32()) AS transformed_array;
SELECT emptyArrayInt32() AS empty_arr, emptyArrayInt32() AS another_empty_arr, emptyArrayInt32() + [1, 2] AS combined_array;