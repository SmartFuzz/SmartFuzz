CREATE TABLE test_ngram (id UInt32, text String) ENGINE = Memory;
INSERT INTO test_ngram VALUES (1, 'ClickHouse'), (2, 'Database'), (3, 'FuzzTesting');
SELECT ngramMinHashArg(text, 3, 6) FROM test_ngram WHERE id = 1;
SELECT ngramMinHashArg(text, 1, 3) FROM test_ngram WHERE id IN (1, 2);
SELECT ngramMinHashArg(text) FROM (SELECT text FROM test_ngram WHERE id = 3) AS subquery;
SELECT t1.id, ngramMinHashArg(t1.text, 4, 5) FROM test_ngram AS t1 JOIN test_ngram AS t2 ON t1.id < t2.id;
SELECT ngramMinHashArg(CONCAT(t1.text, ' ', t2.text), 2, 4) FROM test_ngram AS t1 JOIN test_ngram AS t2 ON t1.id = 2 AND t2.id = 3;
WITH (SELECT '*') AS wildcard_string SELECT ngramMinHashArg(wildcard_string, 5, 2);
SELECT ngramMinHashArg('NGramTestString', 6, 7) AS result;
SELECT ngramMinHashArg(text, ngramsize, hashnum) FROM test_ngram CROSS JOIN (SELECT 3 AS ngramsize, 4 AS hashnum) AS params;