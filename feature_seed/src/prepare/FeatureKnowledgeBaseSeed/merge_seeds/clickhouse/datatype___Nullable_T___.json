CREATE TABLE nullable_test (`id` UInt32, `val` Nullable(Int32)) ENGINE = MergeTree ORDER BY id;
INSERT INTO nullable_test VALUES (1, 10), (2, NULL), (3, 20);
SELECT id, val, val IS NULL AS is_null FROM nullable_test;
CREATE TABLE nullable_aggregate (`x` Int8, `y` Nullable(Int8)) ENGINE = MergeTree ORDER BY x;
INSERT INTO nullable_aggregate VALUES (1, NULL), (2, 3), (3, NULL), (4, 5);
SELECT x, SUM(y) AS sum_y FROM nullable_aggregate GROUP BY x;
CREATE TABLE multi_column (`a` Nullable(Int8), `b` Nullable(Int8)) ENGINE = MergeTree ORDER BY a;
INSERT INTO multi_column VALUES (NULL, NULL), (1, NULL), (NULL, 2);
SELECT a, b, a + b AS sum FROM multi_column;
SELECT (SELECT COUNT() FROM nullable_test WHERE val IS NOT NULL) AS count_non_null, (SELECT COUNT() FROM nullable_test) AS total_count;
CREATE TABLE nested_nulls (`arr` Array(Nullable(Int32))) ENGINE = MergeTree ORDER BY tuple();
INSERT INTO nested_nulls VALUES ([1, NULL, 2]), ([NULL, NULL]), ([3, 4]);
SELECT arrayJoin(arr) IS NULL AS is_element_null FROM nested_nulls;
CREATE TABLE complex_nullable (`id` UInt32, `number` Nullable(UInt32), `description` Nullable(String)) ENGINE = MergeTree ORDER BY id;
INSERT INTO complex_nullable VALUES (1, 100, 'First'), (2, NULL, 'Second'), (3, 300, NULL);
SELECT id, number, description, number + 50 AS calculated_value FROM complex_nullable WHERE description IS NOT NULL;
CREATE TABLE join_test (`left_id` UInt32, `value` Nullable(Int32)) ENGINE = MergeTree ORDER BY left_id;
INSERT INTO join_test VALUES (1, 1), (2, NULL), (3, 3);
CREATE TABLE right_test (`right_id` UInt32, `value2` Int32) ENGINE = MergeTree ORDER BY right_id;
INSERT INTO right_test VALUES (1, 10), (2, 20), (3, 30);
SELECT l.left_id, l.value, r.value2 FROM join_test AS l JOIN right_test AS r ON l.left_id = r.right_id WHERE l.value IS NOT NULL;