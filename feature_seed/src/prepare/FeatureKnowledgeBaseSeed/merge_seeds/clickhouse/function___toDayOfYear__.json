CREATE TABLE test_dates (event_date DateTime);
INSERT INTO test_dates VALUES (toDateTime('2023-01-01 00:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-02-28 23:59:59'));
INSERT INTO test_dates VALUES (toDateTime('2023-03-01 00:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-12-31 23:59:59'));
SELECT toDayOfYear(event_date) FROM test_dates;
SELECT toDayOfYear(toDateTime('2024-01-01 12:34:56')) AS day_of_year;
SELECT toDayOfYear(toDate('2023-02-29')) AS day_of_year;
-- testing non-leap date;
SELECT toDayOfYear(toDateTime64('2023-04-21 10:20:30', 3)) AS day_of_year;
SELECT t.event_date, toDayOfYear(t.event_date) FROM test_dates t WHERE toDayOfYear(t.event_date) > 100;
SELECT COUNT(*) FROM (SELECT toDayOfYear(event_date) AS day FROM test_dates GROUP BY day HAVING day = 365);
SELECT t1.event_date, t2.another_date, toDayOfYear(t1.event_date) AS day_of_year_event, toDayOfYear(t2.another_date) AS day_of_year_another FROM (SELECT toDateTime('2023-06-15 08:00:00') AS event_date) t1 JOIN (SELECT toDateTime('2023-02-15 15:30:00') AS another_date) t2;
CREATE TABLE leap_year_dates (leap_date DateTime);
INSERT INTO leap_year_dates VALUES (toDateTime('2024-02-29 00:00:00'));
SELECT toDayOfYear(leap_date) FROM leap_year_dates;
CREATE TABLE full_dates (id UInt32, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO full_dates VALUES (1, toDateTime('2023-07-04 12:00:00')), (2, toDateTime('2023-10-20 14:20:00'));
SELECT id, created_at, toDayOfYear(created_at) AS day_of_year FROM full_dates WHERE day_of_year BETWEEN 1 AND 100;