CREATE TABLE test_empty (arr Array(UInt8));
INSERT INTO test_empty VALUES ([]), ([1, 2, 3]), ([]);
SELECT empty(arr) FROM test_empty;
SELECT arr, empty(arr) FROM test_empty;
SELECT COUNT(*) FROM test_empty WHERE empty(arr) = 1;
SELECT arr, empty(arr) FROM test_empty WHERE arr = [];
SELECT empty(arr) AS is_empty FROM test_empty WHERE arr IN ([1, 2, 3], []);
CREATE TABLE test_nested (id Int32, arr Array(Int32));
INSERT INTO test_nested VALUES (1, []), (2, [10, 20]), (3, [30]);
SELECT id, empty(arr) AS is_empty FROM test_nested;
SELECT id FROM test_nested WHERE empty(arr) = 1;
CREATE TABLE test_join (id Int32, arr Array(Int32));
INSERT INTO test_join VALUES (1, []), (2, [5, 6]);
SELECT a.id, empty(a.arr) AS is_empty FROM test_empty AS a JOIN test_join AS b ON a.id = b.id;
SELECT empty([]) AS empty_array, empty([1, 2, 3]) AS non_empty_array;
WITH (SELECT empty(arr) FROM test_empty) AS is_arr_empty SELECT * FROM test_empty WHERE is_arr_empty = 1;
CREATE TABLE dynamic_test (id Int32, values Array(Int32));
INSERT INTO dynamic_test VALUES (1, []), (2, [1]);
SELECT id, empty(values) AS is_values_empty FROM dynamic_test;
SELECT id FROM dynamic_test WHERE empty(values);
SELECT sum(empty(arr)) FROM test_empty;