CREATE TABLE test_ips (ip_string String);
INSERT INTO test_ips VALUES ('2001:0db8:85a3:0000:0000:8a2e:0370:7334'), ('invalid_IPv6'), ('127.0.0.1'), ('2001:0db8:85a3:0000:0000:8a2e:0370:733g');
SELECT ip_string, toIPv6OrNull(ip_string) AS ipv6_result FROM test_ips;
WITH (SELECT ip_string FROM test_ips WHERE ip_string LIKE '%invalid%') AS invalid_ips SELECT toIPv6OrNull(ip_string) FROM invalid_ips;
CREATE TABLE valid_ips AS SELECT ip_string FROM test_ips WHERE toIPv6OrNull(ip_string) IS NOT NULL;
WITH (SELECT ip_string FROM test_ips) AS all_ips SELECT ip_string, toIPv6OrNull(ip_string) FROM all_ips WHERE ip_string NOT LIKE '%invalid%';
SELECT COUNT(*), toIPv6OrNull(ip_string) AS ipv6_result FROM test_ips GROUP BY ipv6_result;
WITH (SELECT ip_string FROM test_ips WHERE toIPv6OrNull(ip_string) IS NULL) AS bad_ips SELECT COUNT(*) AS invalid_count FROM bad_ips;
SELECT CASE WHEN toIPv6OrNull(ip_string) IS NULL THEN 'Invalid IPv6' ELSE 'Valid IPv6' END AS status FROM test_ips;
CREATE TABLE ip_validation AS SELECT ip_string, toIPv6OrNull(ip_string) AS ipv6_result FROM test_ips;
SELECT DISTINCT ipv6_result FROM ip_validation WHERE ipv6_result IS NOT NULL;
WITH (SELECT toIPv6OrNull(ip_string) AS ipv6_result FROM test_ips) AS results SELECT ip_string FROM test_ips JOIN results ON test_ips.ip_string = results.ip_string WHERE results.ipv6_result IS NOT NULL;