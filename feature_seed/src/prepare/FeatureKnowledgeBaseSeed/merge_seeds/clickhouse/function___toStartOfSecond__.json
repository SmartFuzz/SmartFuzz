CREATE TABLE test_time (event_time DateTime64(3)) ENGINE = Memory;
INSERT INTO test_time VALUES (toDateTime64('2020-01-01 10:20:30.999', 3), toDateTime64('2020-01-01 10:20:31.123', 3), toDateTime64('2020-01-01 10:20:30.456', 3);
SELECT toStartOfSecond(event_time) FROM test_time;
SELECT toStartOfSecond(event_time, 'UTC') FROM test_time;
WITH (SELECT toDateTime64('2020-01-01 10:20:30.999', 3)) AS dt64 SELECT toStartOfSecond(dt64);
WITH (SELECT toDateTime64('2020-01-01 10:20:30.999', 3) AS dt64) SELECT toStartOfSecond(dt64, 'Asia/Istanbul');
CREATE TABLE nested_test (id UInt32, created_at DateTime64(3)) ENGINE = Memory;
INSERT INTO nested_test VALUES (1, toDateTime64('2020-01-01 10:20:31.345', 3)), (2, toDateTime64('2020-01-01 10:20:32.678', 3));
SELECT nt.id, toStartOfSecond(nt.created_at) FROM nested_test nt WHERE nt.created_at < toDateTime64('2020-01-01 10:20:32', 3);
CREATE TABLE timezone_test (event_time DateTime64(3)) ENGINE = Memory;
INSERT INTO timezone_test VALUES (toDateTime64('2020-01-01 10:20:30.999', 3));
SELECT event_time, toStartOfSecond(event_time, 'Europe/London') FROM timezone_test;
WITH (SELECT toDateTime64('2020-01-01 10:20:30.999', 3) AS dt64) SELECT dt64, toStartOfSecond(dt64) AS rounded_time, toStartOfSecond(dt64, 'America/New_York') AS rounded_time_ny;
SELECT COUNT(*) FROM (SELECT toStartOfSecond(event_time) FROM test_time) AS unique_seconds;