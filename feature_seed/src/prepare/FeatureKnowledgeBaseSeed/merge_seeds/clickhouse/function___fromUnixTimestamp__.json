CREATE TABLE timestamps (ts INT);
INSERT INTO timestamps VALUES (0);
INSERT INTO timestamps VALUES (1609459200);
INSERT INTO timestamps VALUES (2147483647);
INSERT INTO timestamps VALUES (-2147483648);
SELECT fromUnixTimestamp(ts) AS date_time FROM timestamps;
SELECT fromUnixTimestamp(ts, '%Y-%m-%d %H:%i:%s') AS formatted_date_time FROM timestamps;
SELECT fromUnixTimestamp(423543535) FROM timestamps;
CREATE TABLE events (event_time INT, event_name String);
INSERT INTO events VALUES (1609459200, 'New Year 2021');
INSERT INTO events VALUES (1234567890, 'Mid Year 2009');
SELECT event_name, fromUnixTimestamp(event_time, '%Y-%m-%d %H:%i:%s') AS event_date_time FROM events WHERE event_time > 0;
SELECT fromUnixTimestamp(UNNEST(array(1609459200, 1234567890, 0))) AS date_time;
SELECT e.event_name FROM events e JOIN timestamps t ON fromUnixTimestamp(e.event_time) < fromUnixTimestamp(t.ts) WHERE e.event_time > 0;
SELECT fromUnixTimestamp(ts, '%Y-%m-%d') AS just_date, fromUnixTimestamp(ts, '%H:%i:%s') AS just_time FROM timestamps;
CREATE TABLE mixed_data (id UInt32, created_at Int32);
INSERT INTO mixed_data VALUES (1, 1609459200), (2, 1609545600), (3, 1234567890);
SELECT id, fromUnixTimestamp(created_at, '%Y-%m-%d %H:%i:%s') AS create_time FROM mixed_data;
SELECT fromUnixTimestamp(0) AS epoch_time, fromUnixTimestamp(UNIX_TIMESTAMP(NOW())) AS current_time;
SELECT count(*), fromUnixTimestamp(ts) AS timestamp FROM timestamps GROUP BY timestamp;
CREATE TABLE summary AS SELECT fromUnixTimestamp(ts) AS converted_time FROM timestamps;
SELECT * FROM summary WHERE converted_time > '1970-01-01 00:00:00';
CREATE TABLE complex_events AS SELECT e.event_name, fromUnixTimestamp(e.event_time) AS event_date FROM events e WHERE event_time > 0;
SELECT event_name FROM complex_events WHERE event_date > '2021-01-01 00:00:00';