CREATE TABLE points (id UInt32, coordinates Array(Array(Float64)));
INSERT INTO points VALUES (1, [[(0., 0.), (0., 5.), (5., 5.), (5., 0.), (2., 3.)]]);
INSERT INTO points VALUES (2, [[(1., 1.), (1., 4.), (4., 4.), (4., 1.), (2., 2.)]]);
CREATE TABLE result AS SELECT id, wkt(polygonConvexHullCartesian(coordinates)) AS hull FROM points;
SELECT hull FROM result WHERE id = 1;
SELECT wkt(polygonConvexHullCartesian((SELECT coordinates FROM points WHERE id = 2))) AS hull_subquery;
WITH [[[0, 0], [0, 5], [5, 5], [5, 0], [2, 3]]] AS poly_hull SELECT wkt(polygonConvexHullCartesian(poly_hull)) AS hull_fixed;
CREATE TABLE temp_polygons AS SELECT wkt(polygonConvexHullCartesian(coordinates)) AS hulls FROM points GROUP BY id;
SELECT DISTINCT hulls FROM temp_polygons WHERE hulls LIKE '%((1, 1)%';
WITH [[(0., 0.), (0., 10.), (10., 10.), (10., 0.), (5., 5.)]] AS large_hull SELECT wkt(polygonConvexHullCartesian(large_hull)) AS large_hull_result;