CREATE TABLE test_dates (date_string String);
INSERT INTO test_dates VALUES ('2022-12-30'), ('invalid-date'), ('2023-01-01'), (''), (NULL);
SELECT toDateOrNull(date_string) FROM test_dates;
SELECT toDateOrNull(date_string) AS converted_date FROM test_dates WHERE date_string IS NOT NULL;
SELECT COUNT(*), toDateOrNull(date_string) AS converted_date FROM test_dates GROUP BY converted_date;
WITH (SELECT date_string FROM test_dates WHERE date_string != '') AS valid_dates SELECT toDateOrNull(date_string) FROM valid_dates;
CREATE TABLE test_dates_joined (id UInt32, date_string String);
INSERT INTO test_dates_joined VALUES (1, '2022-12-30'), (2, 'invalid-date'), (3, '2023-01-01');
SELECT t1.id, toDateOrNull(t2.date_string) FROM (SELECT id FROM test_dates_joined WHERE id = 1) AS t1 JOIN test_dates_joined AS t2 ON t1.id = t2.id;
SELECT AVG(if(toDateOrNull(date_string) IS NULL, 0, 1)) AS valid_date_ratio FROM test_dates;
SELECT toDateOrNull(substring(date_string, 1, 10)) FROM (SELECT date_string FROM test_dates) AS subquery;