CREATE TABLE geo_data (id UInt32, latitude Float64, longitude Float64, h3_index UInt64);
INSERT INTO geo_data VALUES (1, 37.7749, -122.4194, h3_from_geo(37.7749, -122.4194, 9));
INSERT INTO geo_data VALUES (2, 34.0522, -118.2437, h3_from_geo(34.0522, -118.2437, 9));
INSERT INTO geo_data VALUES (3, 40.7128, -74.0060, h3_from_geo(40.7128, -74.0060, 9));
SELECT id, h3_index, latitude, longitude FROM geo_data WHERE h3_index = h3_from_geo(37.7749, -122.4194, 9);
SELECT id, h3_index FROM geo_data WHERE latitude BETWEEN 30 AND 40 AND longitude BETWEEN -125 AND -115;
CREATE TABLE geo_temp AS SELECT id, h3_index FROM geo_data WHERE h3_index IS NOT NULL;
SELECT COUNT(*) FROM geo_temp;
SELECT id, h3_index FROM geo_temp WHERE h3_index IN (SELECT h3_index FROM geo_data WHERE latitude < 35);
WITH (SELECT h3_from_geo(37.7749, -122.4194, 9)) AS h3_idx SELECT id FROM geo_data WHERE h3_index = h3_idx;
SELECT DISTINCT h3_index FROM geo_data GROUP BY h3_index HAVING COUNT(id) > 1;
SELECT g.id, h3_index, AVG(latitude) as avg_lat, AVG(longitude) as avg_lon FROM geo_data g JOIN geo_data h ON g.h3_index = h.h3_index GROUP BY g.id, h3_index ORDER BY avg_lat DESC;
CREATE TABLE h3_neighbors AS SELECT h3_index, h3_k_ring(h3_index, 1) AS h3_neighbors FROM geo_data;
SELECT g.id FROM geo_data g JOIN h3_neighbors h ON g.h3_index = h.h3_index WHERE g.latitude > 34;
SELECT g.id, h3_index FROM geo_data g WHERE h3_index IN (SELECT h3_index FROM h3_neighbors WHERE h3_index IS NOT NULL) AND latitude > 44;