CREATE TABLE kernel_info (version String);
INSERT INTO kernel_info VALUES (getOSKernelVersion());
SELECT version FROM kernel_info;
CREATE TABLE sample_data (id Int32, os_version String);
INSERT INTO sample_data VALUES (1, getOSKernelVersion());
SELECT id, os_version FROM sample_data WHERE os_version = (SELECT version FROM kernel_info);
SELECT getOSKernelVersion() AS current_version, (SELECT COUNT(*) FROM sample_data) AS version_count;
CREATE TABLE nested_query_example AS SELECT id, getOSKernelVersion() AS current_version FROM sample_data;
SELECT current_version FROM (SELECT getOSKernelVersion() AS current_version) AS derived;
WITH (SELECT getOSKernelVersion()) AS kernel_ver SELECT kernel_ver AS current_kversion;
CREATE TABLE join_example (id Int32, version String);
INSERT INTO join_example VALUES (1, getOSKernelVersion());
SELECT a.id, a.version, b.version FROM join_example AS a JOIN kernel_info AS b ON a.id = 1;