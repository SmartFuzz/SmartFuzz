CREATE TABLE test_erfc (value FLOAT);
INSERT INTO test_erfc VALUES (0), (1), (2), (10), (100), (1000);
SELECT value, erfc(value) FROM test_erfc;
SELECT value, erfc(CAST(value AS Float64)) FROM test_erfc;
CREATE TABLE test_values (id INT, value FLOAT);
INSERT INTO test_values VALUES (1, 0.5), (2, 1.5), (3, 10.5), (4, NULL);
SELECT t1.id, t1.value, erfc(t1.value) FROM test_values t1 WHERE t1.value IS NOT NULL;
SELECT t1.id, erfc(avg(t1.value)) FROM test_values t1 GROUP BY t1.id;
SELECT t1.id, t1.value, erfc(t1.value) AS erfc_value FROM test_values t1 JOIN (SELECT value FROM test_values WHERE id = 2) AS sub ON t1.id = sub.id;
SELECT erfc(t2.value) FROM (SELECT value FROM test_values WHERE id IN (1, 2)) AS t2;
SELECT erfc(value + (SELECT AVG(value) FROM test_values)) FROM test_values;