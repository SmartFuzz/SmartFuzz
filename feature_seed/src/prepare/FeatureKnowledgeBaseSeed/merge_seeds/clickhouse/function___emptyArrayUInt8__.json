CREATE TABLE test_table (id UInt32, values Array(UInt8));
INSERT INTO test_table VALUES (1, emptyArrayUInt8()), (2, [1, 2, 3]);
SELECT id, values FROM test_table WHERE values = emptyArrayUInt8();
SELECT id, arrayJoin(values) AS value FROM test_table WHERE value = emptyArrayUInt8();
CREATE TABLE another_table (id UInt32, name String);
INSERT INTO another_table VALUES (1, 'test1'), (2, 'test2');
SELECT a.id, a.values, b.name FROM test_table AS a JOIN another_table AS b ON a.id = b.id WHERE a.values = emptyArrayUInt8();
SELECT count() FROM test_table WHERE values = emptyArrayUInt8();
SELECT arrayConcat(values, emptyArrayUInt8()) FROM test_table;
SELECT id FROM test_table WHERE values != emptyArrayUInt8();
SELECT id, arrayMap(x -> x + 1, emptyArrayUInt8()) AS incremented FROM test_table WHERE id = 1;