CREATE TABLE test_dates (date_string String);
INSERT INTO test_dates VALUES ('2023-10-01 12:34:56');
INSERT INTO test_dates VALUES ('invalid_date');
INSERT INTO test_dates VALUES ('10/01/2023 12:34:56 PM');
INSERT INTO test_dates VALUES (NULL);
SELECT date_string, parseDateTimeBestEffortUSOrNull(date_string) AS parsed_date FROM test_dates;
CREATE TABLE test_results AS SELECT date_string, parseDateTimeBestEffortUSOrNull(date_string) AS parsed_date FROM test_dates;
SELECT COUNT(*) FROM test_dates WHERE parseDateTimeBestEffortUSOrNull(date_string) IS NULL;
CREATE TABLE more_test_dates (date_string String, category String);
INSERT INTO more_test_dates VALUES ('2023-10-01 12:34:56', 'valid'), ('2023-10-01 12:34:56 AM', 'valid'), ('invalid_data', 'invalid');
SELECT category, COUNT(*) FROM more_test_dates GROUP BY category HAVING parseDateTimeBestEffortUSOrNull(date_string) IS NULL;
SELECT parseDateTimeBestEffortUSOrNull(CONCAT(date_string, ' ExtraText')) FROM test_dates;
SELECT parseDateTimeBestEffortUSOrNull(date_string) AS parsed_date FROM (SELECT date_string FROM test_dates WHERE date_string IS NOT NULL) AS valid_dates_subquery;
SELECT COUNT(*) FROM (SELECT parseDateTimeBestEffortUSOrNull(date_string) AS parsed_date FROM test_dates) AS parsed_dates WHERE parsed_date IS NULL;
CREATE TABLE complex_test (id Int32, date_string String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO complex_test VALUES (1, '10/01/2023 12:34:56 PM'), (2, 'some_random_string'), (3, NULL);
SELECT id, parseDateTimeBestEffortUSOrNull(date_string) AS parsed_date FROM complex_test WHERE id IN (SELECT id FROM complex_test WHERE date_string IS NOT NULL);
CREATE TABLE join_test (id Int32, join_date String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO join_test VALUES (1, '10/02/2023'), (2, 'invalid_date');
SELECT ct.id, ct.join_date, parseDateTimeBestEffortUSOrNull(ct.join_date) AS parsed_join_date FROM complex_test ct JOIN join_test jt ON ct.id = jt.id;