CREATE TABLE test_table (id UInt32, timestamp DateTime, value Float64);
INSERT INTO test_table VALUES (1, CAST('2018-01-01 01:02:03' AS DateTime), 10.5);
INSERT INTO test_table VALUES (2, CAST('2022-12-31 12:34:56' AS DateTime), 20.3);
SELECT toColumnTypeName(value) FROM test_table;
SELECT toColumnTypeName(CAST(123 AS UInt32)) UNION SELECT toColumnTypeName(CAST('hello' AS String));
SELECT t.id, toColumnTypeName(t.timestamp) FROM test_table t WHERE t.value > 15;
SELECT toColumnTypeName(CAST(NULL AS UInt64)) AS null_type, toColumnTypeName(CAST(5.67 AS Float32)) AS float_type;
CREATE TABLE test_table2 (data String, number UInt8);
INSERT INTO test_table2 VALUES ('example', 1), ('test', 2);
SELECT t2.data, toColumnTypeName(t2.number) FROM test_table2 t2 WHERE t2.number = (SELECT MIN(number) FROM test_table2);
SELECT t.timestamp, toColumnTypeName(CAST(t.value AS Float64)) FROM test_table t JOIN test_table2 t2 ON t.id = t2.number WHERE t2.data = 'example';
SELECT toColumnTypeName(CAST('2023-01-01' AS Date)) AS date_type, toColumnTypeName(CAST('2023-01-01 10:10:10' AS DateTime)) AS datetime_type;
SELECT toColumnTypeName(CAST('123.456' AS Decimal(5, 3))) AS decimal_type FROM (SELECT toColumnTypeName(CAST(rand() AS UInt32)) AS rand_type);
SELECT toColumnTypeName(CAST(['element1', 'element2'] AS Array(String))) AS array_type FROM test_table;
SELECT toColumnTypeName(CAST((SELECT AVG(value) FROM test_table) AS Float64));
SELECT toColumnTypeName(CAST((SELECT toColumnTypeName(t.value) FROM test_table t WHERE t.id = 1) AS String));