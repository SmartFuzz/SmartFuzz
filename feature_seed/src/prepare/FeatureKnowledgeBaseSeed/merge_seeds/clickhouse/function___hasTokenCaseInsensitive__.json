CREATE TABLE test_strings (haystack String, token String) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO test_strings VALUES ('Hello World', 'hello');
INSERT INTO test_strings VALUES ('ClickHouse is great', 'CLICKHOUSE');
INSERT INTO test_strings VALUES ('Fuzzy Testing', 'fuzzy');
INSERT INTO test_strings VALUES ('Boundary Test!', 'test');
INSERT INTO test_strings VALUES ('Edge at Start:Start', 'start');
INSERT INTO test_strings VALUES ('Edge at End:End', 'end');
INSERT INTO test_strings VALUES ('Mixed CASE Testing', 'MiXeD');
INSERT INTO test_strings VALUES ('Non-alphanumeric separators &*^%$', 'separators');
SELECT hasTokenCaseInsensitive(haystack, token) FROM test_strings;
SELECT haystack, hasTokenCaseInsensitive(haystack, 'hello') AS result FROM test_strings WHERE result = 1;
SELECT 'Test 1' AS haystack, hasTokenCaseInsensitive(haystack, 'test') FROM (SELECT 'Test 1' AS haystack) AS subquery;
WITH (SELECT haystack FROM test_strings ORDER BY isempty(haystack) ASC LIMIT 1) AS min_haystack SELECT hasTokenCaseInsensitive(min_haystack, 'min') AS result;
SELECT t1.haystack, hasTokenCaseInsensitive(t1.haystack, t2.token) FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.haystack != t2.haystack;
SELECT hasTokenCaseInsensitive('Case Case Handling', 'CAS');
SELECT hasTokenCaseInsensitive(CONCAT('Join with ', 'Subquery Example'), 'example');
SELECT hasTokenCaseInsensitive(CONCAT('Special Chars: #$', 'Escape Test'), 'escape test');
SELECT hasTokenCaseInsensitive('No match against this string', 'match') AS result;