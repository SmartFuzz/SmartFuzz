CREATE TABLE test_decimal (value String);
INSERT INTO test_decimal VALUES ('99.67'), ('101.12345678901234567890'), ('1.15'), ('-100.0001'), ('99999999999999999999999999999999999999'), ('NaN'), ('Inf');
SELECT toDecimal128(value, 2) AS converted_value, toTypeName(converted_value) AS type FROM test_decimal WHERE value NOT IN ('NaN', 'Inf');
SELECT toDecimal128(value, 2) AS a, toTypeName(a) AS type_a FROM test_decimal WHERE value NOT LIKE '%NaN%' AND value NOT LIKE '%Inf%';
SELECT a, b FROM (SELECT toDecimal128('123.456', 3) AS a, toDecimal128('456.789', 3) AS b) AS subquery;
SELECT value, toDecimal128(value, 1) AS converted_value FROM (SELECT value FROM test_decimal) AS inner_query WHERE NOT value IN ('NaN', 'Inf');
CREATE TABLE test_result AS SELECT toDecimal128(value, 2) AS converted_value FROM test_decimal WHERE value NOT IN ('NaN', 'Inf');
SELECT COUNT(*) AS total_records, AVG(toDecimal128(value, 2)) AS avg_value FROM test_decimal WHERE value NOT IN ('NaN', 'Inf') GROUP BY value;
SELECT a + b AS sum FROM (SELECT toDecimal128('10.25', 2) AS a, toDecimal128('20.75', 2) AS b) AS combined;
SELECT (SELECT toDecimal128(value, 2) FROM test_decimal WHERE value NOT IN ('NaN', 'Inf')) AS decimal_values;