DROP TABLE IF EXISTS test;
CREATE TABLE test(a UInt32, b Float64, c Float64, d Float64) ENGINE = Memory;
INSERT INTO test(a, b, c, d) VALUES (1, 5.6, -4.4, 2.6), (2, -9.6, 3, 3.3), (3, -1.3, -4, 1.2), (4, 5.3, 9.7, 2.3), (5, 4.4, 0.037, 1.222), (6, -8.6, -7.8, 2.1233), (7, 5.1, 9.3, 8.1222), (8, 7.9, -3.6, 9.837), (9, -8.2, 0.62, 8.43555), (10, -3, 7.3, 6.762);
SELECT arrayMap(x -> round(x, 3), arrayJoin(covarPopMatrix(a, b, c, d))) AS covarPopMatrix FROM test;
CREATE TABLE test_empty(a UInt32, b Float64) ENGINE = Memory;
SELECT covarPopMatrix() FROM test_empty;
CREATE TABLE test_one_value(a UInt32, b Float64) ENGINE = Memory;
INSERT INTO test_one_value(a, b) VALUES (1, 5.0);
SELECT covarPopMatrix(b) FROM test_one_value;
CREATE TABLE test_negative_values(a UInt32, b Float64, c Float64) ENGINE = Memory;
INSERT INTO test_negative_values(a, b, c) VALUES (1, -10.0, -20.0), (2, -5.0, -15.0), (3, -7.5, -12.5);
SELECT covarPopMatrix(b, c) FROM test_negative_values;
CREATE TABLE test_multiple_columns(a UInt32, b Float64, c Float64, d Float64) ENGINE = Memory;
INSERT INTO test_multiple_columns(a, b, c, d) VALUES (1, 10.5, 20.3, 30.1), (2, 11.5, 21.3, 31.1);
SELECT arrayJoin(covarPopMatrix(b, c, d)) FROM test_multiple_columns;
CREATE TABLE test_join(a UInt32, b Float64) ENGINE = Memory;
INSERT INTO test_join(a, b) VALUES (1, 3.5), (2, 7.5);
CREATE TABLE test_join2(c UInt32, d Float64) ENGINE = Memory;
INSERT INTO test_join2(c, d) VALUES (1, 2.5), (2, 4.5);
SELECT covarPopMatrix(b, d) FROM test_join JOIN test_join2 ON test_join.a = test_join2.c;
CREATE TABLE test_complex(a UInt32, b Float64, c Float64, d Float64) ENGINE = Memory;
INSERT INTO test_complex(a, b, c, d) VALUES (1, 0.1, 0.2, 0.3), (2, 0.4, 0.5, 0.6), (3, 0.7, 0.8, 0.9);
SELECT covarPopMatrix(b, arrayJoin([c, d])) AS covar_result FROM test_complex;