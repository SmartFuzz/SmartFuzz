CREATE TABLE test_timezones (event_time DateTime, location String) ENGINE = MergeTree() ORDER BY event_time;
INSERT INTO test_timezones VALUES (toDateTime('2021-04-21 10:20:30', 'America/New_York'), 'America/New_York');
INSERT INTO test_timezones VALUES (toDateTime('2020-11-01 01:30:00', 'America/New_York'), 'America/New_York');
INSERT INTO test_timezones VALUES (toDateTime('2021-12-31 23:59:59', 'Europe/London'), 'Europe/London');
SELECT event_time, timeZoneOffset(event_time) AS Offset_in_seconds FROM test_timezones WHERE location = 'America/New_York';
SELECT location, timeZoneOffset(toDateTime('2021-07-01 12:00:00', location)) AS summer_offset FROM test_timezones GROUP BY location;
SELECT location, MIN(event_time) AS earliest_event, timeZoneOffset(MIN(event_time)) AS earliest_offset FROM test_timezones GROUP BY location;
SELECT event_time, timeZoneOffset(event_time) AS offset_seconds FROM test_timezones ORDER BY event_time DESC LIMIT 5;
SELECT t1.event_time, t2.location, timeZoneOffset(t1.event_time) AS offset_seconds FROM test_timezones t1 JOIN test_timezones t2 ON t1.location = t2.location WHERE t1.event_time > '2020-01-01 00:00:00';
SELECT AVG(timeZoneOffset(event_time)) AS average_offset FROM test_timezones WHERE location IN ('America/New_York', 'Europe/London');
SELECT DISTINCT location, COUNT(*) AS event_count, timeZoneOffset(toDateTime('2022-03-15 12:00:00', location)) AS fixed_time_offset FROM test_timezones GROUP BY location;
SELECT toDateTime('2021-06-15 10:00:00', 'America/New_York') AS ny_time, timeZoneOffset(ny_time) AS ny_offset, toDateTime('2021-06-15 10:00:00', 'Europe/London') AS london_time, timeZoneOffset(london_time) AS london_offset;
SELECT SUM(IF(location = 'America/New_York', timeZoneOffset(event_time), 0)) AS total_ny_offset, SUM(IF(location = 'Europe/London', timeZoneOffset(event_time), 0)) AS total_london_offset FROM test_timezones;