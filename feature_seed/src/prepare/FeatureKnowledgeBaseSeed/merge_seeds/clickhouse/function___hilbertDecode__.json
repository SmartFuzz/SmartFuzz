CREATE TABLE hilbert_test (id UInt64, value UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO hilbert_test VALUES (1, 0), (2, 2048), (3, 32767), (4, 65535);
SELECT hilbertDecode(2, 31);
SELECT hilbertDecode(1, 1);
SELECT hilbertDecode(2, 32768);
SELECT hilbertDecode(2, 0);
SELECT hilbertDecode(2, 1);
SELECT hilbertDecode(2, 65535);
SELECT hilbertDecode(2, hilbertEncode(1, 2));
SELECT untuple(hilbertDecode(2, code)) FROM hilbert_test WHERE id = 3;
SELECT hilbertDecode(1, hilbertEncode(id, value)) FROM hilbert_test;
CREATE TABLE hilbert_joins (a UInt32, b UInt32) ENGINE = MergeTree() ORDER BY a;
INSERT INTO hilbert_joins VALUES (10, 20), (30, 40), (50, 60);
SELECT hilbertDecode(2, hilbertEncode(a, b)) FROM hilbert_joins;
SELECT id, untuple(hilbertDecode(2, hilbertEncode(value, id))) FROM hilbert_test;
SELECT hilbertDecode(2, (SELECT MAX(value) FROM hilbert_test));
SELECT hilbertDecode(2, (SELECT SUM(value) FROM hilbert_test WHERE id < 3));