CREATE TABLE strings_table (haystack String);
INSERT INTO strings_table VALUES ('Hello World'), ('ClickHouse Database'), ('Fuzzy Testing'), ('LIKE Patterns'), ('Special % Characters'), ('Escaped \_ Underscore');
SELECT * FROM strings_table WHERE haystack LIKE 'Hello%';
SELECT * FROM strings_table WHERE haystack LIKE '%Database';
SELECT * FROM strings_table WHERE haystack LIKE '%Testing%';
SELECT * FROM strings_table WHERE haystack LIKE '%\_Underscore';
SELECT * FROM strings_table WHERE haystack LIKE '%Special \%%';
SELECT * FROM strings_table WHERE haystack LIKE '_lickHouse%';
SELECT * FROM strings_table WHERE haystack LIKE '%Characters\%';
SELECT haystack FROM strings_table WHERE haystack LIKE 'ClickHouse LIKE Patterns';
SELECT * FROM (SELECT haystack FROM strings_table WHERE haystack LIKE '%Fuzzy%') AS subquery;
CREATE TABLE other_strings (id Int32, value String);
INSERT INTO other_strings VALUES (1, 'Escape % Here'), (2, 'Nothing to see here'), (3, 'Look for _ this');
SELECT a.haystack FROM strings_table AS a JOIN other_strings AS b ON a.haystack LIKE CONCAT('%', b.value, '%');
SELECT * FROM strings_table WHERE haystack LIKE '%%' AND haystack LIKE 'Hello%';
SELECT haystack FROM strings_table WHERE haystack LIKE 'Fuzzy \\%';
SELECT * FROM strings_table WHERE haystack LIKE '%\靑';
SELECT * FROM strings_table WHERE haystack LIKE '%\%%' AND haystack LIKE '%\_';
SELECT COUNT(*) FROM strings_table WHERE haystack LIKE 'ClickHouse%';
SELECT haystack FROM strings_table WHERE haystack LIKE '%\_Special%' AND haystack LIKE 'Fuzzy %';