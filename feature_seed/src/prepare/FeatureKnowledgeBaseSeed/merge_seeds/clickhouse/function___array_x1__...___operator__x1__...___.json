CREATE TABLE test_array (id UInt32, value Int32);
INSERT INTO test_array VALUES (1, 10), (2, 20), (3, 30), (4, 40);
SELECT array(value) FROM test_array WHERE id = 1;
SELECT array(value) FROM test_array WHERE id IN (2, 3);
SELECT array(1, 2, 3) AS simple_array;
SELECT array(1, 2.5, 3, 4.0) AS mixed_array;
SELECT array('apple', 'banana', 'cherry') AS string_array;
SELECT array(1, 2, array(5, 6)) AS nested_array;
SELECT array(1, 2, concat('string_', toString(value)) ) FROM test_array;
WITH (SELECT array(value) FROM test_array) AS my_array SELECT * FROM my_array;
SELECT array(1, 2, NULL) AS with_nulls;
SELECT arrayIf(value > 15, value, 0) FROM test_array;
SELECT array(1.1, 2.2, 3.3) AS decimal_array;
SELECT arrayJoin(array(value)) FROM test_array;
SELECT (SELECT array(value) FROM test_array) AS subquery_array;
CREATE TABLE test_array2 (array_data Array(Int32));
INSERT INTO test_array2 VALUES (array(1, 2, 3)), (array(4, 5, 6));
SELECT arrayConcat(array(1, 2), array(3, 4)) AS concatenated_array;
SELECT arrayMap(x -> x * 2, array(1, 2, 3)) AS mapped_array;
SELECT arrayFilter(x -> x > 20, array(value)) FROM test_array;