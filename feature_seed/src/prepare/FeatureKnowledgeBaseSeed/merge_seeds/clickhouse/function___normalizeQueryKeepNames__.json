CREATE TABLE test_table (id UInt32, name String, value Float64);
INSERT INTO test_table VALUES (1, 'aComplexName123'), (2, 'simpleName'), (3, 'anotherComplexNameWithUUID123e4567-e89b-12d3-a456-426614174000');
SELECT normalizeQueryKeepNames('SELECT id, name FROM test_table WHERE name = ''simpleName'' AND value > 10.0;
');
SELECT normalizeQueryKeepNames('SELECT name, SUM(value) AS totalValue FROM test_table GROUP BY name HAVING totalValue > 5;
');
SELECT normalizeQueryKeepNames('SELECT id, value FROM (SELECT id, SUM(value) as total FROM test_table GROUP BY id) AS subquery WHERE total > 1;
');
SELECT normalizeQueryKeepNames('SELECT t.id, t.name FROM test_table t JOIN (SELECT name FROM test_table WHERE value < 5) AS subquery ON t.name = subquery.name;
');
SELECT normalizeQueryKeepNames('SELECT count(*) AS totalCount FROM (SELECT id, name FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value > 2.5));
');
SELECT normalizeQueryKeepNames('WITH max_value AS (SELECT MAX(value) FROM test_table) SELECT name FROM test_table WHERE value = (SELECT * FROM max_value);
');
SELECT normalizeQueryKeepNames('SELECT id, name, value FROM test_table WHERE name NOT LIKE ''%Complex%'' AND value < (SELECT AVG(value) FROM test_table);
');
SELECT normalizeQueryKeepNames('SELECT * FROM (SELECT id, name FROM test_table WHERE name LIKE ''%name%'') WHERE id < 3;
');