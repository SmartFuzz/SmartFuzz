CREATE TABLE student_ttest (sample_data FLOAT, sample_index INT);
INSERT INTO student_ttest VALUES (1.0, 0), (2.0, 0), (1.5, 1), (2.5, 1);
SELECT studentTTest(sample_data, sample_index) FROM student_ttest;
INSERT INTO student_ttest VALUES (1.0, 0), (2.0, 1), (3.0, 0), (2.5, 1), (4.0, 0), (5.0, 1);
SELECT studentTTest(sample_data, sample_index) FROM student_ttest;
INSERT INTO student_ttest VALUES (NULL, 0), (3.5, 1);
SELECT studentTTest(sample_data, sample_index) FROM student_ttest WHERE sample_data IS NOT NULL;
CREATE TABLE student_ttest_additional (sample_data FLOAT, sample_index INT);
INSERT INTO student_ttest_additional VALUES (1.2, 0), (2.1, 0), (3.3, 1), (4.4, 1);
SELECT studentTTest(a.sample_data, a.sample_index) FROM student_ttest a JOIN student_ttest_additional b ON a.sample_index = b.sample_index;
SELECT studentTTest(sample_data, sample_index) FROM (SELECT sample_data, sample_index FROM student_ttest WHERE sample_data > 1.0) AS filtered_samples;
SELECT studentTTest(sample_data, sample_index) FROM student_ttest HAVING sample_index = 1;
SELECT studentTTest(sample_data, sample_index) FROM (SELECT sample_data, sample_index FROM student_ttest ORDER BY sample_data DESC LIMIT 5) AS top_samples;
CREATE TABLE sample_stats (confidence_level FLOAT);
INSERT INTO sample_stats VALUES (0.95), (0.99);
SELECT studentTTest(sample_data, sample_index) FROM student_ttest, sample_stats WHERE confidence_level = 0.95;