CREATE TABLE dates_example (startdate DateTime, enddate DateTime);
INSERT INTO dates_example VALUES (toDateTime('2021-12-29 00:00:00'), toDateTime('2022-01-01 00:00:00'));
SELECT age('day', startdate, enddate) FROM dates_example;
INSERT INTO dates_example VALUES (toDateTime('2021-01-01 12:00:00'), toDateTime('2021-01-02 12:00:01'));
SELECT age('second', startdate, enddate) FROM dates_example;
SELECT age('month', toDateTime('2021-12-01 00:00:00'), toDateTime('2022-01-15 00:00:00')) AS month_age FROM dates_example;
CREATE TABLE timezones (us_eastern DateTime, us_pacific DateTime);
INSERT INTO timezones VALUES (toDateTime('2022-01-01 10:00:00', 'US/Eastern'), toDateTime('2022-01-01 07:00:00', 'US/Pacific'));
SELECT age('hour', us_eastern, us_pacific) FROM timezones;
SELECT startdate, enddate, age('week', startdate, enddate) AS week_difference FROM dates_example;
SELECT toDate('2022-01-01') AS e, toDate('2021-12-29') AS s, age('year', s, e) AS year_age, age('month', s, e) AS month_age FROM dates_example;
CREATE TABLE complex_example (startdate DateTime, enddate DateTime, id UInt32);
INSERT INTO complex_example VALUES (toDateTime('2021-06-01 00:00:00'), toDateTime('2021-06-15 00:00:00'), 1), (toDateTime('2021-06-01 12:00:00'), toDateTime('2021-07-01 12:00:00'), 2);
SELECT id, age('day', startdate, enddate) AS age_in_days FROM complex_example WHERE age('day', startdate, enddate) > 10;
SELECT id, age('year', startdate, enddate) AS age_in_years FROM complex_example WHERE id IN (SELECT id FROM complex_example WHERE age('year', startdate, enddate) < 1);
SELECT id, age('month', toDateTime('2021-11-01'), enddate) AS age_in_months FROM complex_example ORDER BY age_in_months DESC;