CREATE TABLE test_strings (haystack String, needle String);
INSERT INTO test_strings VALUES ('Hello World', 'hello');
INSERT INTO test_strings VALUES ('OpenAI is great', 'openai');
INSERT INTO test_strings VALUES ('Fuzzy Wuzzy was a bear', 'fuzzy');
INSERT INTO test_strings VALUES ('Quick brown fox jumps', 'Brown');
SELECT ngramSearchCaseInsensitive(haystack, needle) FROM test_strings;
SELECT ngramSearchCaseInsensitive('Case insensitive TESTING', 'test') AS match_score WHERE match_score > 0;
SELECT DISTINCT haystack FROM test_strings WHERE ngramSearchCaseInsensitive(haystack, 'Hello') > 0.5;
WITH (SELECT haystack FROM test_strings WHERE ngramSearchCaseInsensitive(haystack, 'great') > 0) AS filtered_haystack SELECT ngramSearchCaseInsensitive(filtered_haystack, 'great') FROM test_strings;
SELECT haystack, ngramSearchCaseInsensitive(haystack, 'test') AS score FROM test_strings WHERE score > 0.2 ORDER BY score DESC;
SELECT ngramSearchCaseInsensitive(haystack, 'nonexistent') FROM test_strings UNION SELECT ngramSearchCaseInsensitive('hello world', 'WORLD') FROM test_strings;
CREATE TABLE search_results AS SELECT haystack, ngramSearchCaseInsensitive(haystack, needle) AS score FROM test_strings WHERE score > 0.1;
SELECT haystack FROM search_results WHERE score = 1;