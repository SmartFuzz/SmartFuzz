CREATE TABLE test_table (id Int32, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'Alpha'), (2, 'Beta'), (3, 'Gamma');
SELECT * FROM s3('https://datasets-documentation.s3.eu-west-3.amazonaws.com/aapl_stock.csv', NOSIGN, 'CSVWithNames') LIMIT 5;
SELECT name FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name LIKE 'A%');
SELECT COUNT(*) FROM s3('https://datasets-documentation.s3.eu-west-3.amazonaws.com/aapl_stock.csv', NOSIGN, 'CSVWithNames') WHERE name IS NOT NULL;
CREATE TABLE another_table (value Float64) ENGINE = MergeTree() ORDER BY value;
INSERT INTO another_table VALUES (10.1), (20.5), (15.3);
SELECT a.name, AVG(b.value) FROM test_table AS a JOIN another_table AS b ON a.id = CAST(b.value AS Int32) GROUP BY a.name HAVING AVG(b.value) > 10;
WITH (SELECT COUNT(*) FROM s3('https://datasets-documentation.s3.eu-west-3.amazonaws.com/aapl_stock.csv', NOSIGN, 'CSVWithNames')) AS total_rows SELECT name, total_rows FROM test_table;
SELECT DISTINCT name FROM test_table WHERE id NOT IN (SELECT id FROM another_table WHERE value < 15);
SELECT name, (SELECT COUNT() FROM another_table) AS total_values FROM test_table ORDER BY total_values DESC;
SELECT s3.* FROM s3('https://datasets-documentation.s3.eu-west-3.amazonaws.com/aapl_stock.csv', NOSIGN, 'CSVWithNames') AS s3 JOIN test_table ON s3.name = test_table.name;