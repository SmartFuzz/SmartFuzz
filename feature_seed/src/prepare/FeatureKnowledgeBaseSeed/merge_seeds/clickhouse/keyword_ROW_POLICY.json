CREATE TABLE test_table (id UInt32, name String, age UInt8) ENGINE = MergeTree() ORDER BY id;
ALTER ROW POLICY FOR SELECT ON test_table ADD (age > 18) AS policy_1;
ALTER ROW POLICY FOR SELECT ON test_table ADD (name LIKE 'A%') AS policy_2;
ALTER ROW POLICY FOR SELECT ON test_table DELETE policy_1;
ALTER ROW POLICY FOR SELECT ON test_table ADD (id IN (SELECT id FROM another_table WHERE condition = true)) AS subquery_policy;
CREATE TABLE another_table (id UInt32, condition Boolean) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_table (id, condition) VALUES (1, true), (2, false);
ALTER ROW POLICY FOR SELECT ON test_table MODIFY (age < 30) AS modified_policy;
ALTER ROW POLICY FOR SELECT ON test_table ADD (exists(SELECT 1 FROM another_table WHERE another_table.id = test_table.id)) AS exists_policy;
ALTER ROW POLICY FOR SELECT ON test_table DROP IF EXISTS policy_2;