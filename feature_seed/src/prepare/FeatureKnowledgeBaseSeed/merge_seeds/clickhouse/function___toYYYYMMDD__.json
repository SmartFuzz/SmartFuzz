CREATE TABLE test_dates (event_date DateTime, event_name String);
INSERT INTO test_dates VALUES (now(), 'Event 1'), (toUnixTimestamp('2023-10-01 12:00:00'), 'Event 2'), (toUnixTimestamp('2022-01-01 00:00:00'), 'Event 3');
SELECT toYYYYMMDD(event_date) FROM test_dates;
SELECT toYYYYMMDD(event_date, 'UTC') FROM test_dates;
SELECT toYYYYMMDD(event_date, 'Europe/London') FROM test_dates;
SELECT toYYYYMMDD(event_date) AS formatted_date, event_name FROM test_dates WHERE toYYYYMMDD(event_date) = 20231001;
SELECT event_name, toYYYYMMDD(event_date, 'US/Eastern') AS event_date_formatted FROM test_dates WHERE event_date > toUnixTimestamp('2023-09-30 23:59:59');
SELECT AVG(toYYYYMMDD(event_date)) FROM test_dates GROUP BY toYYYYMMDD(event_date);
SELECT t.event_name FROM (SELECT toYYYYMMDD(event_date) AS date_val, event_name FROM test_dates) AS t WHERE date_val = 20221001;
CREATE TABLE date_ranges (start_date DateTime, end_date DateTime);
INSERT INTO date_ranges VALUES (toUnixTimestamp('2023-10-01 00:00:00'), toUnixTimestamp('2023-10-31 23:59:59'));
SELECT toYYYYMMDD(r.start_date) AS start_yyyymmdd, toYYYYMMDD(r.end_date) AS end_yyyymmdd FROM date_ranges r WHERE end_date > now();
SELECT toYYYYMMDD(DATE_ADD('day', 1, event_date)) AS next_day FROM test_dates;
SELECT DISTINCT toYYYYMMDD(event_date, 'Asia/Tokyo') FROM test_dates WHERE toYYYYMMDD(event_date) >= 20230101;
SELECT e.event_name, toYYYYMMDD(e.event_date) AS formatted_date FROM test_dates e INNER JOIN (SELECT DISTINCT event_name FROM test_dates WHERE event_date < now()) AS t ON e.event_name = t.event_name;