CREATE TABLE test_strings (id UInt32, content String);
INSERT INTO test_strings VALUES (1, 'Hello'), (2, 'World'), (3, 'ClickHouse'), (4, 'Test');
SELECT right(content, 2) FROM test_strings WHERE id = 1;
SELECT right(content, -2) FROM test_strings WHERE id = 2;
SELECT right(content, 5) FROM test_strings;
SELECT right(content, 0) FROM test_strings;
SELECT right(content, -10) FROM test_strings WHERE id = 3;
SELECT right(content, length(content) - 2) FROM test_strings;
SELECT right('A', 1) AS result FROM test_strings;
SELECT right('1234567890', 4) AS slice FROM test_strings;
SELECT right('1234567890', -1) AS slice_negative FROM test_strings WHERE id = 4;
SELECT right('ClickHouse', 8) AS full_string FROM (SELECT content FROM test_strings WHERE id = 3);
SELECT right(content, 2) FROM (SELECT content FROM test_strings WHERE id IN (1, 2));
SELECT right(content, CAST(length(content) AS Int32) - 1) AS substring FROM test_strings;
SELECT right(content || '!', 1) FROM test_strings;
SELECT right((SELECT content FROM test_strings WHERE id = 1), 1) AS subquery_test;