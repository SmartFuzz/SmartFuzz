CREATE TABLE ip_ranges (ipv4 IPv4, cidr UInt8);
INSERT INTO ip_ranges VALUES (toIPv4('192.168.1.1'), 24);
INSERT INTO ip_ranges VALUES (toIPv4('10.0.0.5'), 8);
INSERT INTO ip_ranges VALUES (toIPv4('172.16.5.10'), 12);
INSERT INTO ip_ranges VALUES (toIPv4('192.168.0.10'), 16);
SELECT IPv4CIDRToRange(ipv4, cidr) FROM ip_ranges WHERE cidr BETWEEN 8 AND 24;
SELECT IPv4CIDRToRange(toIPv4('0.0.0.0'), 0);
SELECT IPv4CIDRToRange(toIPv4('255.255.255.255'), 32);
SELECT IPv4CIDRToRange(toIPv4('192.168.5.25'), 16);
SELECT DISTINCT IPv4CIDRToRange(ipv4, cidr) FROM ip_ranges;
SELECT IPv4CIDRToRange(toIPv4('10.10.10.10'), 16) AS range, count(*) FROM ip_ranges GROUP BY range;
SELECT ipv4, IPv4CIDRToRange(ipv4, cidr) AS range FROM ip_ranges WHERE range IS NOT NULL;
WITH (SELECT IPv4CIDRToRange(toIPv4('192.168.1.1'), 24)) AS range SELECT * FROM ip_ranges WHERE cidr > 16 UNION ALL SELECT IPv4CIDRToRange(toIPv4('10.20.30.40'), 12);
CREATE TABLE subnet_info AS SELECT ipv4, IPv4CIDRToRange(ipv4, cidr) AS range FROM ip_ranges;
SELECT COUNT() FROM subnet_info WHERE range = ('192.168.0.0','192.168.255.255');