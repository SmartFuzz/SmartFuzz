CREATE TABLE test_conversion (input String);
INSERT INTO test_conversion VALUES ('256'), ('abc'), ('-1'), ('0'), ('1.5'), ('3.14'), ('0x1F'), ('NaN'), ('Inf'), ('-Inf'), ('128'), ('4294967296');
SELECT toUInt256OrZero(input) AS result FROM test_conversion;
SELECT input, toUInt256OrZero(input) AS result FROM test_conversion WHERE input != 'abc';
SELECT input, toUInt256OrZero(input) AS result FROM test_conversion WHERE toUInt256OrZero(input) < 1000;
SELECT **cols** FROM (SELECT input, toUInt256OrZero(input) AS converted_value FROM test_conversion) AS subquery WHERE converted_value = 0;
SELECT a.input, b.input, toUInt256OrZero(a.input + b.input) AS sum_result FROM test_conversion AS a JOIN test_conversion AS b ON a.input != b.input;
SELECT toUInt256OrZero(CAST(3.14 AS String)) AS float_conversion, toUInt256OrZero('0') AS zero_conversion, toUInt256OrZero('abc') AS string_conversion;
SELECT input, toUInt256OrZero(input) FROM test_conversion WHERE input IN ('256', '0x1F', '-1');
WITH (SELECT toUInt256OrZero('4294967295')) AS max_val SELECT toUInt256OrZero('1') + max_val AS overflow_test;
CREATE TABLE conversion_test (value String);
INSERT INTO conversion_test VALUES ('0xc0fe'), ('-300'), ('123456'), ('500000000000'), ('Hello World');
SELECT value, toUInt256OrZero(value) AS conversion_result FROM conversion_test;