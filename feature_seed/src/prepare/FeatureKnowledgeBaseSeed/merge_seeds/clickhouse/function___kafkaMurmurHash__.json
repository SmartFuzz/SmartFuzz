CREATE TABLE test_kafka (input String) ENGINE = Memory;
INSERT INTO test_kafka VALUES ('simpleString'), ('anotherTest'), (array('a', 'b', 'c'));
SELECT kafkaMurmurHash('testString') AS hash1 FROM test_kafka;
SELECT kafkaMurmurHash(array('foo', 'bar'), 'baz', 0) AS hash2 FROM test_kafka WHERE input = 'simpleString';
SELECT kafkaMurmurHash(input) AS hash3 FROM test_kafka WHERE input LIKE '%Test%';
CREATE TABLE test_join (id UInt32, value String) ENGINE = Memory;
INSERT INTO test_join VALUES (1, 'value1'), (2, 'value2');
SELECT tj.id, kafkaMurmurHash(tk.input) AS hash4 FROM test_kafka tk JOIN test_join tj ON kafkaMurmurHash(tk.input) = tj.id;
SELECT kafkaMurmurHash(array(tk.input), 'someString') AS hash5 FROM test_kafka tk WHERE length(tk.input) < 20;
CREATE TABLE nested_test (nested Array(String)) ENGINE = Memory;
INSERT INTO nested_test VALUES (['one', 'two']), (['three', 'four', 'five']);
SELECT kafkaMurmurHash(arrayJoin(nested) || 'additionalString') AS hash6 FROM nested_test;
SELECT kafkaMurmurHash(array('data1', 'data2', 'data3'), 99) AS hash7 FROM test_kafka WHERE input = 'anotherTest';
SELECT kafkaMurmurHash(input, toDateTime('2020-01-01 00:00:00')) AS hash8 FROM test_kafka;
SELECT kafkaMurmurHash('hashMe', length('hashMe')) AS hash9 FROM test_kafka WHERE input IN ('simpleString', 'anotherTest');
SELECT kafkaMurmurHash(array('nested1', array('nested2', 'nested3')), toUInt32(42)) AS hash10 FROM nested_test;