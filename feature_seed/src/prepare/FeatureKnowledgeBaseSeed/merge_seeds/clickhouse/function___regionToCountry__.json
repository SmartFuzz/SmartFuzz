CREATE TABLE regions (id UInt32, name String) ENGINE = Memory;
INSERT INTO regions VALUES (1, 'California'), (2, 'Texas'), (3, 'Ontario'), (4, 'Quebec');
CREATE TABLE countries (region_id UInt32, country_name String) ENGINE = Memory;
INSERT INTO countries VALUES (1, 'United States'), (2, 'United States'), (3, 'Canada'), (4, 'Canada');
SELECT regionToCountry(id) AS country_id, regionToName(id, 'en') AS region_name FROM regions WHERE id IN (1, 2, 3, 4);
SELECT r.name, regionToCountry(r.id) AS country_id FROM regions r JOIN countries c ON regionToCountry(r.id) = c.region_id;
SELECT r.name AS region_name, regionToCountry(r.id) AS country_id, regionToName(country_id, 'en') AS country_name FROM regions r LEFT JOIN countries c ON regionToCountry(r.id) = c.region_id;
SELECT COUNT(*) AS region_count, regionToCountry(r.id) AS country_id FROM regions r GROUP BY country_id HAVING region_count > 1;
WITH (SELECT regionToCountry(1) AS region_country_id) AS country_id_result SELECT * FROM countries WHERE region_id = (SELECT region_country_id);
SELECT regionToCountry(id) AS country_id, COUNT(*) FROM regions GROUP BY country_id HAVING country_id IS NOT NULL;
SELECT regionToCountry(999999) AS nonexistent_country_id, regionToName(nonexistent_country_id, 'en') AS country_name;