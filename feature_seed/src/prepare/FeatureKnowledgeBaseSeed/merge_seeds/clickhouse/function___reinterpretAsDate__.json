CREATE TABLE test_dates (date_value String);
INSERT INTO test_dates VALUES ('A'), ('B'), ('C'), ('D');
SELECT reinterpretAsDate(0) AS epoch_start, reinterpretAsDate(1) AS day_one FROM test_dates;
SELECT reinterpretAsDate(365) AS first_anniversary FROM test_dates;
SELECT reinterpretAsDate(18628) AS year_2020, reinterpretAsDate(18629) AS year_2021 FROM test_dates;
SELECT reinterpretAsDate(reinterpretAsDate(65)) AS double_conversion FROM test_dates;
SELECT reinterpretAsDate(CAST(1000 AS UInt32)) AS thousand_days FROM test_dates;
SELECT reinterpretAsDate(CAST('1000' AS String)) AS thousand_days_string FROM test_dates;
SELECT reinterpretAsDate(reinterpretAsDate('01970-01-01')) AS from_string_date FROM test_dates;
SELECT reinterpretAsDate(2147483647) AS max_int_days FROM test_dates;
SELECT reinterpretAsDate(CAST('2000-01-01' AS Date)) AS date_conversion FROM test_dates;
SELECT reinterpretAsDate(0.0) AS epoch_start_float FROM test_dates;
SELECT reinterpretAsDate(UNNEST(MAP(2, 'Test'))[1]) FROM test_dates;
SELECT reinterpretAsDate(SELECT count(*) FROM test_dates) AS count_days FROM test_dates;
WITH (SELECT 60) AS days FROM test_dates SELECT reinterpretAsDate(days) AS sixty_days_date;