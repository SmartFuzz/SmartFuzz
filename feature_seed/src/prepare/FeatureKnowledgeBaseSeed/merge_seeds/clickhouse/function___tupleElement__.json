CREATE TABLE test_tuples (id Int32, data Tuple(Int32, String, Float64));
INSERT INTO test_tuples VALUES (1, (1, 'one', 1.1)), (2, (2, 'two', 2.2)), (3, (3, 'three', 3.3));
SELECT tupleElement(data, 1) FROM test_tuples;
SELECT tupleElement(data, 2) FROM test_tuples;
SELECT tupleElement(data, 3) FROM test_tuples;
SELECT tupleElement(data, 1, 'default') FROM test_tuples WHERE id = 4;
SELECT tupleElement(data, '2') FROM test_tuples;
SELECT tupleElement(data, 'name_does_not_exist', 'default_value') FROM test_tuples;
WITH (SELECT (1, 'one', 1.1) AS t) AS subquery SELECT tupleElement(t, 1) FROM subquery;
SELECT t.id, tupleElement(t.data, 1) AS first_element FROM (SELECT id, data FROM test_tuples) AS t;
SELECT tupleElement(data, 1) AS id, tupleElement(data, 2) AS name, tupleElement(data, 3) AS value FROM test_tuples WHERE value > 2.0;
CREATE TABLE test_nested (id Int32, nested Tuple(Int32, Tuple(Int32, String)));
INSERT INTO test_nested VALUES (1, (1, (10, 'ten'))), (2, (2, (20, 'twenty')));
SELECT tupleElement(nested, 2, 'default') FROM test_nested;
SELECT tupleElement(tupleElement(nested, 2), 1) FROM test_nested;
SELECT tupleElement(tupleElement(nested, 2), 2, 'not_found') FROM test_nested WHERE id = 3;
WITH (SELECT id, data FROM test_tuples) AS t1, (SELECT 1 AS id, (1, 'default', 3.0) AS data) AS t2 SELECT tupleElement(t1.data, 1), tupleElement(t2.data, 2) FROM t1 JOIN t2 ON t1.id = t2.id;