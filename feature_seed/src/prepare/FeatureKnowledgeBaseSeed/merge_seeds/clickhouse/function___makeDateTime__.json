CREATE TABLE test_dates (datetime DateTime);
INSERT INTO test_dates VALUES (makeDateTime(2023, 1, 1, 0, 0, 0));
INSERT INTO test_dates VALUES (makeDateTime(2023, 12, 31, 23, 59, 59));
INSERT INTO test_dates VALUES (makeDateTime(0, 1, 1, 0, 0, 0));
INSERT INTO test_dates VALUES (makeDateTime(9999, 12, 31, 23, 59, 59));
INSERT INTO test_dates VALUES (makeDateTime(2023, 6, 30, 12, 0, 0));
SELECT makeDateTime(NULL, 1, 1, 0, 0, 0) AS DateTimeTest;
SELECT makeDateTime(2023, 2, 28, 17, 12, -1) AS DateTimeNegativeSecond;
SELECT makeDateTime(2023, 13, 1, 0, 0, 0) AS DateTimeInvalidMonth;
SELECT makeDateTime(2023, 2, 29, 0, 0, 0) AS DateTimeInvalidDate;
SELECT makeDateTime(2023, 1, 15, 10, 30, 45, 'UTC') AS DateTimeWithTimezone;
SELECT makeDateTime(2023, 1, 15, 10, 30, 45, 'America/New_York') AS DateTimeWithTimezone;
CREATE TABLE test_dates_join (id Int32, date_col DateTime);
INSERT INTO test_dates_join VALUES (1, makeDateTime(2023, 1, 1, 10, 0, 0));
INSERT INTO test_dates_join VALUES (2, makeDateTime(2023, 1, 2, 10, 0, 0));
SELECT a.id, a.date_col FROM test_dates_join AS a JOIN test_dates AS b ON a.date_col = b.datetime;
SELECT a.date_col, makeDateTime(a.year, a.month, a.day, 0, 0, 0) AS start_of_day FROM (SELECT 2023 AS year, 1 AS month, 1 AS day) AS a;