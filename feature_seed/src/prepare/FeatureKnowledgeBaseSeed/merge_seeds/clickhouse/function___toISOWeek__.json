CREATE TABLE dates_table (event_date Date);
INSERT INTO dates_table VALUES ('2024-10-01'), ('2024-10-02'), ('2024-10-08'), ('2024-10-09');
SELECT toISOWeek(event_date) AS iso_week FROM dates_table;
SELECT toISOWeek(toDate('2024/01/01')) AS iso_week_first_jan;
SELECT toISOWeek(toDateTime('2024-12-31 23:59:59')) AS iso_week_last_day;
SELECT toISOWeek(toDate('2024/10/07')) AS iso_week_start_of_week;
SELECT toISOWeek(toDateTime('2024-10-08 00:00:00')) AS iso_week_mid_week;
SELECT toISOWeek(toDate('2024-02-29')) AS iso_week_leap_year_date;
CREATE TABLE events_table (event_id UInt32, event_date Date);
INSERT INTO events_table VALUES (1, '2024-10-01'), (2, '2024-10-02'), (3, '2024-10-03');
SELECT event_id, toISOWeek(event_date) AS iso_week FROM events_table WHERE event_date >= '2024-10-01';
SELECT event_id, toISOWeek(toDateTime(event_date)) AS iso_week FROM events_table JOIN dates_table ON event_date = event_date;
SELECT toISOWeek(toDate('2024-03-01')) AS iso_week_march_first, toISOWeek(toDate('2024-03-31')) AS iso_week_march_last;
WITH (SELECT toISOWeek(toDate('2024-10-07'))) AS week_num SELECT week_num;
SELECT toISOWeek(toDate('2024-12-25')) AS iso_week_christmas UNION SELECT toISOWeek(toDate('2024-01-01')) AS iso_week_new_year;