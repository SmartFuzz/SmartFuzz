SELECT hiveHash('');
SELECT hiveHash('Hello, world!');
CREATE TABLE test_strings (text String);
INSERT INTO test_strings VALUES ('Sample string for testing.');
SELECT hiveHash(text) FROM test_strings;
CREATE TABLE hash_results (hash_value Int32);
INSERT INTO hash_results VALUES (hiveHash(''));
INSERT INTO hash_results VALUES (hiveHash('Test case 1'));
INSERT INTO hash_results VALUES (hiveHash('Another test case for hive hash'));
SELECT text, hiveHash(text) AS hash_value FROM test_strings;
CREATE TABLE complex_data (id Int32, value String);
INSERT INTO complex_data VALUES (1, 'Test A'), (2, 'Test B');
SELECT id, hiveHash(value) AS hash_value FROM complex_data WHERE id = 1;
SELECT hiveHash(CONCAT('User:', value)) AS combined_hash FROM complex_data;
SELECT hiveHash(value) AS hash_value FROM complex_data WHERE value LIKE 'Test%';
SELECT a.id, hiveHash(a.value) + hiveHash(b.value) AS combined_hash FROM complex_data a JOIN complex_data b ON a.id = b.id;
CREATE TABLE user_data (username String, hashed_value Int32);
INSERT INTO user_data VALUES ('user1', hiveHash('user1')), ('user2', hiveHash('user2'));
SELECT username, hashed_value FROM user_data WHERE hashed_value = hiveHash('user1');
WITH (SELECT hiveHash('static value') AS static_hash) AS t SELECT t.static_hash, hiveHash('dynamic input') FROM user_data;
SELECT hiveHash(unhex(hex('Sample string for Hive Hash')));