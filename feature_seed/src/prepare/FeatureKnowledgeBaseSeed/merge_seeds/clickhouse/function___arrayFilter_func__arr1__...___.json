CREATE TABLE example_table (id UInt64, arr Array(String));
INSERT INTO example_table VALUES (1, ['Hello', 'World', 'Test']), (2, ['abc World', 'Hello World', 'Goodbye']);
SELECT arrayFilter(x -> x LIKE '%World%', arr) AS res FROM example_table;
SELECT id, arrayFilter(x -> x LIKE '%World%', arr) AS res FROM example_table WHERE id = 1;
CREATE TABLE numbers_table (num UInt64);
INSERT INTO numbers_table VALUES (1), (2), (3);
SELECT arrayFilter(x -> x % 2 = 0, arrayMap(i -> i, arrayEnumerate((SELECT arr FROM example_table))) ) AS even_indices FROM example_table;
SELECT id, arrayFilter(x -> x LIKE '%abc%', arr) AS res FROM example_table WHERE id IN (SELECT id FROM example_table WHERE id = 2);
SELECT arrayFilter((i, x) -> x LIKE '%World%' AND i IN (SELECT number FROM numbers_table), arr) AS filtered_res FROM example_table;
CREATE TABLE filter_test (value Array(Int32));
INSERT INTO filter_test VALUES (['1', '2', '3']), (['4', '5', 'World']), (['Hello', 'World', '6']);
SELECT arrayFilter(x -> x LIKE '%World%', value) AS world_values FROM filter_test;
SELECT arrayFilter(x -> arrayExists(y -> y > 2, value), value) AS filtered_above_two FROM filter_test;
SELECT id, arrayFilter(x -> x LIKE '%World%', arr) AS filtered FROM (SELECT id, arr FROM example_table WHERE id < 3);
SELECT arrayFilter(x -> x IN ('Hello', 'abc World'), arr) AS filtered_arr FROM example_table WHERE id = 2;