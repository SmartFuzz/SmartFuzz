CREATE TABLE polygons_table (id UInt32, polygon Array(Array(Float64)));
INSERT INTO polygons_table VALUES (1, [[(50., 50.), (50., -50.), (-50., -50.), (-50., 50.), (50., 50.)]]), (2, [[(10., 10.), (10., 40.), (40., 40.), (40., 10.), (10., 10.)]]), (3, [[(-10., -10.), (-10., -40.), (-40., -40.), (-40., -10.), (-10., -10.)]]);
SELECT wkt(polygonsSymDifferenceSpherical(arraySort(polygon), [[(-20., -20.), (-20., 20.), (20., 20.), (20., -20.), (-20., -20.)]])) FROM polygons_table WHERE id IN (1, 2);
SELECT wkt(polygonsSymDifferenceSpherical(arraySort(polygon), [[(1., 1.), (1., 3.), (3., 3.), (3., 1.), (1., 1.)]])) FROM polygons_table WHERE id = 1;
SELECT wkt(polygonsSymDifferenceSpherical(pi(), [[(0., 0.), (1., 1.), (1., 0.), (0., 0.)]])) AS polygon_diff;
CREATE TABLE spatial_data AS SELECT id, wkt(polygonsSymDifferenceSpherical(polygon, [[(0., 0.), (5., 5.), (5., 0.), (0., 0.)]])) AS diff_polygon FROM polygons_table WHERE id < 3;
CREATE TABLE complex_data AS SELECT id, SUM(length(wkt(polygonsSymDifferenceSpherical(polygon, [[(2., 1.), (3., 1.), (3., 2.), (2., 2.), (2., 1.)]])))) AS total_length FROM polygons_table GROUP BY id;
WITH (SELECT arraySort(polygon) FROM polygons_table WHERE id = 3) as sorted_polygon SELECT wkt(polygonsSymDifferenceSpherical(sorted_polygon, [[(-30., -30.), (-30., 30.), (30., 30.), (30., -30.), (-30., -30.)]]));
SELECT wkt(polygonsSymDifferenceSpherical((SELECT arraySort(polygon) FROM polygons_table WHERE id = 1), (SELECT arraySort(polygon) FROM polygons_table WHERE id = 2)));
SELECT count(*) FROM polygons_table WHERE polygonsSymDifferenceSpherical(arraySort(polygon), [[(5., 5.), (5., 10.), (10., 10.), (10., 5.), (5., 5.)]]) IS NOT NULL;