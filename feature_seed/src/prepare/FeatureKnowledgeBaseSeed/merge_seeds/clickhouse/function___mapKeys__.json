CREATE TABLE test_map_keys (m Map(String, String)) ENGINE = Memory;
INSERT INTO test_map_keys VALUES ({'name':'Alice','age':'30'}), ({'city':'New York','country':'USA'}), ({'color':'blue','hobby':'painting'});
SELECT mapKeys(m) FROM test_map_keys;
CREATE TABLE test_nested_map (id Int32, m Map(String, Map(String, String))) ENGINE = Memory;
INSERT INTO test_nested_map VALUES (1, {'personal':{'name':'John','age':'25'}}, (2, {'company':{'title':'Developer','experience':'5 years'}}));
SELECT id, mapKeys(m) FROM test_nested_map WHERE id = 1;
CREATE TABLE map_subquery (m Map(Int32, String)) ENGINE = Memory;
INSERT INTO map_subquery VALUES ({1:'one',2:'two'}), ({3:'three',4:'four'});
SELECT (SELECT mapKeys(m) FROM map_subquery) AS keys_list;
CREATE TABLE join_maps (item_id Int32, attributes Map(String, Float64)) ENGINE = Memory;
INSERT INTO join_maps VALUES (1, {'price':15.5, 'weight':3.2}), (2, {'price':20.0, 'weight':4.5});
SELECT a.item_id, mapKeys(a.attributes) FROM join_maps AS a JOIN join_maps AS b ON a.item_id = b.item_id WHERE b.attributes['price'] > 15;
CREATE TABLE complex_map (id Int32, data Map(String, Array(Int32))) ENGINE = Memory;
INSERT INTO complex_map VALUES (1, {'scores':[10,20,30]}, (2, {'scores':[40,50]}));
SELECT id, mapKeys(data) FROM complex_map;
CREATE TABLE deep_nested_map (id Int32, m Map(String, Map(String, Map(String, String)))) ENGINE = Memory;
INSERT INTO deep_nested_map VALUES (1, {'data1':{'key1':'value1','key2':'value2'}, 'data2':{'key3':'value3'}});
SELECT id, mapKeys(m) FROM deep_nested_map WHERE id = 1;