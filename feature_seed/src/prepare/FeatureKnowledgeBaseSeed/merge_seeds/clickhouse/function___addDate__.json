CREATE TABLE test_dates (event_date DateTime);
INSERT INTO test_dates VALUES (toDateTime('2020-01-01 00:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2019-12-31 23:59:59'));
SELECT addDate(event_date, INTERVAL 1 DAY) FROM test_dates;
SELECT addDate(toDate('2023-01-01'), INTERVAL 1 MONTH);
SELECT addDate(toDateTime('2023-12-31 23:59:59'), INTERVAL 1 SECOND);
SELECT addDate(toDateTime('2023-01-01 00:00:00'), INTERVAL 5 YEAR + INTERVAL 2 MONTH);
SELECT event_date, addDate(event_date, INTERVAL 2 DAY) AS new_date FROM test_dates;
SELECT addDate(t.event_date, INTERVAL t.offset DAY) FROM (SELECT event_date, 30 AS offset FROM test_dates) t;
CREATE TABLE date_range (start_date DateTime, end_date DateTime);
INSERT INTO date_range VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-12-31 23:59:59'));
SELECT addDate(start_date, INTERVAL 1 YEAR) AS next_year FROM date_range;
SELECT addDate(start_date, INTERVAL (end_date - start_date) SECOND) AS full_duration FROM date_range;
SELECT addDate(toDate('2023-01-01'), INTERVAL -1 DAY);
SELECT addDate('2023-01-10', INTERVAL -10 DAY);
SELECT addDate('2023-01-10 00:00:00', INTERVAL -1 MONTH);