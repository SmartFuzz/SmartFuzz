CREATE TABLE test_values (value INT);
INSERT INTO test_values VALUES (1), (2), (3), (4), (5);
SELECT clamp(value, 2, 4) as clamped_value FROM test_values;
SELECT clamp(value, 0, 10) as clamped_value FROM test_values WHERE value < 5;
SELECT clamp(value, 3, 7) as clamped_value FROM (SELECT value FROM test_values WHERE value > 0) AS subquery;
SELECT t.value, clamp(t.value, r.min, r.max) as clamped_value FROM test_values t JOIN (SELECT 2 as min, 4 as max) r ON t.value <= r.max;
SELECT c.value, clamp(c.value, 2, 5) as clamped_value FROM (SELECT value FROM test_values) c WHERE c.value < 6;
SELECT clamp(AVG(value), 0, 10) as clamped_avg_value FROM test_values;
SELECT clamp(max_value, 1, 5) as clamped_from_subquery FROM (SELECT max(value) as max_value FROM test_values) subquery;
SELECT clamp(s.value, 1, 3) as clamped_value FROM (SELECT value FROM test_values WHERE value < 3 UNION SELECT 10) s;