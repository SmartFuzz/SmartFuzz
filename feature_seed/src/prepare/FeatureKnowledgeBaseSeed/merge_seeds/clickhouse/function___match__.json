CREATE TABLE test_strings (id Int32, haystack String, pattern String);
INSERT INTO test_strings VALUES (1, 'Hello World', 'World');
INSERT INTO test_strings VALUES (2, 'The quick brown fox', 'quick');
INSERT INTO test_strings VALUES (3, 'Regular expressions are cool', 'cool');
INSERT INTO test_strings VALUES (4, 'Unicode test: ¥ symbol', '¥');
INSERT INTO test_strings VALUES (5, 'Line break test
New line here', 'break.*line');
SELECT id FROM test_strings WHERE match(haystack, pattern);
SELECT id, haystack FROM test_strings WHERE match(haystack, '^(The|Hello)');
CREATE TABLE test_results AS SELECT id FROM test_strings WHERE match(haystack, pattern);
INSERT INTO test_results SELECT id FROM test_strings WHERE match(haystack, '^.*[a-z].*$') AND id > 1;
SELECT id, haystack FROM test_strings WHERE pattern IS NOT NULL AND match(haystack, pattern);
SELECT COUNT(*) FROM test_strings WHERE match(haystack, pattern) AND haystack != '';
SELECT COUNT(*) AS match_count FROM test_strings GROUP BY id HAVING match(haystack, pattern);
SELECT id FROM test_strings WHERE match(haystack, '(?s)line break test') AND (haystack LIKE '%test%');
SELECT id, haystack FROM test_strings WHERE NOT match(haystack, 'Invalid pattern\0');
SELECT id FROM test_strings WHERE match(haystack, 'notfound') UNION SELECT id FROM test_strings WHERE haystack IS NULL;
CREATE TABLE another_test (haystack String) ENGINE = MergeTree() ORDER BY (haystack);
INSERT INTO another_test VALUES ('Test 1'), ('Pattern matching 2'), ('Another pattern 3');
SELECT t.id FROM test_strings t JOIN another_test a ON match(t.haystack, 'pattern') WHERE a.haystack LIKE '%2%';
SELECT id, match(haystack, 'test|matching') AS matches FROM test_strings WHERE matches;