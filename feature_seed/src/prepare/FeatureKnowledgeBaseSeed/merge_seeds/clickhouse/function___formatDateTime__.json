CREATE TABLE test_dates (dt DateTime);
INSERT INTO test_dates VALUES (toDateTime('2018-01-02 22:33:44'));
SELECT formatDateTime(dt, '%Y-%m-%d %H:%M:%S') FROM test_dates;
CREATE TABLE timezones (timezone String);
INSERT INTO timezones VALUES ('Europe/Amsterdam'), ('Europe/Andorra'), ('UTC'), ('Europe/London');
SELECT t.timezone, formatDateTime(now(), '%Y-%m-%d %H:%M:%S', t.timezone) AS local_time FROM timezones t;
SELECT formatDateTime(toDateTime64('2020-12-31 23:59:59.999999', 6), '%f') AS fractional_seconds;
SELECT formatDateTime(toDate('2020-01-01'), '%y-%m-%d') AS year_month_day;
SELECT formatDateTime(toDateTime('2030-12-31 00:00:00'), '%d %M %Y') AS formatted_date;
SELECT dt, formatDateTime(dt, '%W') AS weekday_name FROM test_dates;
SELECT dt, formatDateTime(dt, '%p') AS am_pm FROM test_dates;
SELECT formatDateTime(now(), '%d/%m/%Y %H:%i') AS custom_format;
SELECT t1.dt, t2.timezone, formatDateTime(t1.dt, '%T', t2.timezone) AS formatted_time FROM test_dates t1 JOIN timezones t2 ON 1=1;
SELECT formatDateTime(toDateTime('2021-06-15 14:30:00'), '%e %c %Y %H:%M %p') AS formatted;
SELECT formatDateTime(dt, '%V') AS iso_week_number FROM test_dates;
SELECT t.dt, formatDateTime(t.dt, '%H:%i:%s') AS time_only, t2.timezone FROM test_dates t JOIN timezones t2 ON t.dt < now();