CREATE TABLE test_dates (dt DateTime);
INSERT INTO test_dates VALUES (toDateTime('1970-01-01 00:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-10-01 12:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2000-01-01 00:00:00'));
INSERT INTO test_dates VALUES (toDateTime('1993-10-05 05:20:36'));
INSERT INTO test_dates VALUES (toDateTime('2000-09-20 14:11:29'));
INSERT INTO test_dates VALUES (toDateTime('1900-01-01 00:00:00'));
SELECT dt, toRelativeSecondNum(dt) FROM test_dates;
SELECT dt, toRelativeSecondNum(dt) AS seconds_since_epoch FROM test_dates WHERE dt > '1990-01-01 00:00:00';
SELECT AVG(toRelativeSecondNum(dt)) AS avg_seconds FROM (SELECT dt FROM test_dates WHERE dt < '2020-01-01 00:00:00') AS sub;
SELECT COUNT(*) AS total_dates, SUM(toRelativeSecondNum(dt)) AS total_seconds FROM test_dates;
SELECT dt, CASE WHEN toRelativeSecondNum(dt) > 1000000000 THEN 'Recent' ELSE 'Old' END AS date_category FROM test_dates;
WITH (SELECT MAX(dt) AS max_dt FROM test_dates) AS max_date SELECT dt, toRelativeSecondNum(dt) FROM test_dates WHERE dt < max_date;
CREATE TABLE another_dates (event_time DateTime);
INSERT INTO another_dates VALUES (toDateTime('2023-10-05 10:10:10'));
SELECT a.event_time, toRelativeSecondNum(a.event_time) AS event_seconds, b.dt, toRelativeSecondNum(b.dt) AS dt_seconds FROM another_dates AS a JOIN test_dates AS b ON a.event_time > b.dt;
SELECT dt, toRelativeSecondNum(dt) - toRelativeSecondNum(toDateTime('2000-01-01 00:00:00')) AS seconds_from_2000 FROM test_dates WHERE dt IS NOT NULL;