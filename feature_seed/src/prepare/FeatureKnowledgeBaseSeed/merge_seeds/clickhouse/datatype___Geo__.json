CREATE TABLE geo_point (p Point) ENGINE = Memory();
INSERT INTO geo_point VALUES((-10, -10));
INSERT INTO geo_point VALUES((0, 0));
INSERT INTO geo_point VALUES((10, 10));
SELECT p, toTypeName(p) FROM geo_point;
CREATE TABLE geo_ring (r Ring) ENGINE = Memory();
INSERT INTO geo_ring VALUES([(0, 0), (10, 0), (10, 10), (0, 10)]);
INSERT INTO geo_ring VALUES([(5, 5), (15, 5), (15, 15), (5, 15)]);
INSERT INTO geo_ring VALUES([(20, 20), (25, 20), (25, 25), (20, 25)]);
SELECT r, toTypeName(r) FROM geo_ring;
CREATE TABLE geo_linestring (l LineString) ENGINE = Memory();
INSERT INTO geo_linestring VALUES([(0, 0), (10, 0), (10, 10)]);
INSERT INTO geo_linestring VALUES([(5, 5), (15, 5), (15, 15)]);
SELECT l, toTypeName(l) FROM geo_linestring;
CREATE TABLE geo_multilinestring (l MultiLineString) ENGINE = Memory();
INSERT INTO geo_multilinestring VALUES([[(0, 0), (10, 0)], [(5, 5), (15, 5)]]);
INSERT INTO geo_multilinestring VALUES([[(1, 1), (2, 2), (3, 3)], [(30, 30), (40, 40)]]);
SELECT l, toTypeName(l) FROM geo_multilinestring;
CREATE TABLE geo_polygon (pg Polygon) ENGINE = Memory();
INSERT INTO geo_polygon VALUES([[(10, 10), (20, 10), (20, 20), (10, 20)], [(12, 12), (18, 12), (18, 18), (12, 18)]]);
SELECT pg, toTypeName(pg) FROM geo_polygon;
CREATE TABLE geo_multipolygon (mpg MultiPolygon) ENGINE = Memory();
INSERT INTO geo_multipolygon VALUES([[[(0, 0), (10, 0), (10, 10), (0, 10)]], [[(20, 20), (30, 20), (30, 30), (20, 30)], [(22, 22), (28, 22), (28, 28), (22, 28)]]]);
SELECT mpg, toTypeName(mpg) FROM geo_multipolygon;
CREATE TABLE geo_combined AS geo_point;
INSERT INTO geo_combined SELECT p FROM geo_point WHERE toTypeName(p) = 'Point';
SELECT p FROM geo_combined WHERE p IN (SELECT p FROM geo_multilinestring);
SELECT r FROM geo_ring WHERE r = (SELECT r FROM geo_ring WHERE r[1] = (10, 0));