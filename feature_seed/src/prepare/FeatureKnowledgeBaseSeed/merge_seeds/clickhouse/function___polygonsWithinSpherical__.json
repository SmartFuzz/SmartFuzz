SELECT polygonsWithinSpherical([[[(4.3613577, 50.8651821), (4.349556, 50.8535879), (4.3602419, 50.8435626), (4.3830299, 50.8428851), (4.3904543, 50.8564867), (4.3613148, 50.8651279)]]], [[[(1.0, 1.0), (2.0, 1.0), (2.0, 2.0), (1.0, 2.0), (1.0, 1.0)]]]);
SELECT polygonsWithinSpherical(polygons1.coords, [[[(4.380000, 50.850000), (4.390000, 50.850000), (4.390000, 50.860000), (4.380000, 50.860000), (4.380000, 50.850000)]]]) FROM polygons1;
SELECT polygonsWithinSpherical([[[(3.0, 50.0), (4.0, 50.0), (4.0, 51.0), (3.0, 51.0), (3.0, 50.0)]]], [[[(4.0, 50.5), (5.0, 50.5), (5.0, 51.5), (4.0, 51.5), (4.0, 50.5)]]]);
