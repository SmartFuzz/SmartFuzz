CREATE TABLE polygons2 (coords Array(Array(Tuple(Float64, Float64)));
INSERT INTO polygons1 VALUES ([[[(4.3613577, 50.8651821), (4.349556, 50.8535879), (4.3602419, 50.8435626), (4.3830299, 50.8428851), (4.3904543, 50.8564867), (4.3613148, 50.8651279)]]]);
INSERT INTO polygons2 VALUES ([[[(4.346693, 50.858306), (4.367945, 50.852455), (4.366227, 50.840809), (4.344961, 50.833264), (4.338074, 50.848677), (4.346693, 50.858306)]]]);
SELECT polygonsWithinSpherical(polygons1.coords, polygons2.coords) FROM polygons1, polygons2;
