CREATE TABLE test_randNegativeBinomial (experiments UInt64, probability Float64);
INSERT INTO test_randNegativeBinomial VALUES (100, 0.75);
SELECT randNegativeBinomial(experiments, probability) FROM test_randNegativeBinomial;
CREATE TABLE complex_test (id UInt64, value Float64);
INSERT INTO complex_test VALUES (1, 0.1), (2, 0.5), (3, 0.9);
SELECT id, randNegativeBinomial(100, value) FROM complex_test WHERE value > 0.25;
SELECT randNegativeBinomial(0, 0.5) AS test_zero_experiments;
SELECT randNegativeBinomial(100, 0) AS test_zero_probability;
SELECT randNegativeBinomial(100, 1) AS test_one_probability;
SELECT randNegativeBinomial(100, 0.5) FROM numbers(10) UNION SELECT randNegativeBinomial(200, 0.7) FROM numbers(10);
SELECT randNegativeBinomial(experiments, probability) FROM (SELECT experiments, probability FROM test_randNegativeBinomial WHERE probability BETWEEN 0 AND 1);
CREATE TABLE rand_results AS SELECT randNegativeBinomial(100, 0.3) AS result FROM numbers(5);
SELECT AVG(result) FROM rand_results;
SELECT COUNT(*) FROM (SELECT DISTINCT randNegativeBinomial(25, 0.65) AS unique_values FROM numbers(100));
SELECT ti.id, ti.value, randNegativeBinomial(50, ti.value) AS rand_value FROM complex_test ti JOIN test_randNegativeBinomial tn ON tn.experiments = 100 WHERE tn.probability BETWEEN 0.1 AND 0.9;