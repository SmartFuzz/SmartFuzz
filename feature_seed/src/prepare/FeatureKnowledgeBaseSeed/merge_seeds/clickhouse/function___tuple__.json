CREATE TABLE test_tuples (id UInt32, name String, value Float32);
INSERT INTO test_tuples VALUES (1, 'test1', 10.5), (2, 'test2', 20.5), (3, 'test3', 30.5);
SELECT tuple(id, name) AS user_data FROM test_tuples;
SELECT tuple(value, name) AS value_name FROM test_tuples WHERE value > 15;
SELECT tuple(tuple(id, name), value) AS nested_tuple FROM test_tuples;
SELECT id, tuple(name, value) AS name_value FROM test_tuples WHERE id IN (SELECT id FROM test_tuples WHERE value < 25);
SELECT user_data, value FROM (SELECT tuple(id, name) AS user_data, value FROM test_tuples) WHERE value < 30;
CREATE TABLE another_table (info String, amount UInt64);
INSERT INTO another_table VALUES ('info1', 100), ('info2', 200);
SELECT a.info, tuple(t.id, t.name) AS tuple_data FROM another_table a JOIN test_tuples t ON a.amount > t.value;
SELECT name, tuple(count(*), avg(value)) AS stats FROM test_tuples GROUP BY name;
SELECT user_data FROM (SELECT id, tuple(name, value) AS user_data FROM test_tuples) WHERE user_data.1 = 'test2';
SELECT tuple(id, tuple(name, value)) AS complex_tuple FROM test_tuples WHERE value IN (SELECT amount FROM another_table);
SELECT tuple(id, name, value) FROM test_tuples WHERE tuple(value, name) IN (SELECT tuple(amount, info) FROM another_table);
CREATE TABLE test_empty (id UInt32);
INSERT INTO test_empty VALUES ();
SELECT tuple() AS empty_tuple FROM test_empty;
SELECT tuple(name) FROM test_tuples WHERE name NOT IN (SELECT name FROM test_tuples WHERE id > 2);