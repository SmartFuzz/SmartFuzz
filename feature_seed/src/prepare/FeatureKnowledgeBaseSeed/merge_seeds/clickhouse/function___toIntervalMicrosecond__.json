CREATE TABLE test_intervals (id UInt32, event_time DateTime);
INSERT INTO test_intervals VALUES (1, toDateTime('2024-06-15 10:00:00'));
SELECT event_time + toIntervalMicrosecond(1) AS new_time FROM test_intervals WHERE id = 1;
SELECT event_time + toIntervalMicrosecond(0) AS same_time FROM test_intervals WHERE id = 1;
SELECT event_time + toIntervalMicrosecond(-30) AS before_time FROM test_intervals WHERE id = 1;
WITH toDateTime('2024-06-15') AS date SELECT date + toIntervalMicrosecond(1000000) AS result;
WITH toDateTime('2024-06-15') AS date SELECT date + toIntervalMicrosecond(1000000) AS result, date + toIntervalMicrosecond(500000) AS result_half;
SELECT event_time + toIntervalMicrosecond(1E6) AS one_second FROM test_intervals WHERE event_time < toDateTime('2024-06-16');
CREATE TABLE temp_events AS SELECT event_time + toIntervalMicrosecond(30) AS adjusted_time FROM test_intervals;
SELECT adjusted_time FROM temp_events WHERE adjusted_time < toDateTime('2024-06-16 00:00:00');
WITH (SELECT COUNT(*) FROM test_intervals) AS count SELECT count, toIntervalMicrosecond(count) AS interval_count;
WITH (SELECT MIN(event_time) FROM test_intervals) AS min_time SELECT min_time + toIntervalMicrosecond(100) AS slightly_after_min;
WITH (SELECT MAX(event_time) FROM test_intervals) AS max_time SELECT max_time + toIntervalMicrosecond(100000) AS slightly_after_max;