CREATE TABLE test_table (id Nullable(UInt32), value Nullable(Int32));
INSERT INTO test_table VALUES (1, 10), (2, NULL), (3, 20), (NULL, 30);
SELECT id, value, value < 15 AS less_than_15 FROM test_table;
SELECT value, multiIf(value < 15, 'Below 15', value > 15, 'Above 15', 'Exactly 15') AS comparison FROM test_table;
SELECT id, value, NULL < value AS null_comparison FROM test_table;
SELECT id, value, value < NULL AS null_comparison_reverse FROM test_table;
SELECT id, value, NULL < NULL AS null_null_comparison FROM test_table;
SELECT NULL = value AS null_equals_result FROM test_table;
SELECT id, value, multiIf(NULL < value, 'Left is smaller', value > NULL, 'Right is smaller', 'Both are NULL') AS multiif_null FROM test_table;
SELECT id, value, multiIf(value IS NULL, 'Value is NULL', value = 20, 'Value is 20', 'Some other value') AS conditional_check FROM test_table ORDER BY id;
SELECT t1.id, t1.value, t2.value AS right_value FROM test_table AS t1 JOIN test_table AS t2 ON t1.value > t2.value;
SELECT id, multiIf(value < 10, 'Value is less than 10', value > 10, 'Value is greater than 10', NULL) AS value_comparison FROM test_table;
SELECT id, multiIf(value IS NULL, 'Value is NULL', value = right_value, 'Equal', 'Not Equal') AS equality_check FROM test_table CROSS JOIN (SELECT value AS right_value FROM test_table WHERE id = 2) AS right_table;