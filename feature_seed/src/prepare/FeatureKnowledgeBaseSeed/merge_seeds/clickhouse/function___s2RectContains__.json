CREATE TABLE s2_points (id UInt64, s2Point Low UInt64, s2Point High UInt64, s2PointTarget UInt64);
INSERT INTO s2_points VALUES (1, 5179062030687166815, 5177056748191934217, 5177914411069187297);
SELECT s2RectContains(s2PointLow, s2PointHi, s2Point) AS rectContains FROM s2_points;
SELECT id, s2RectContains(s2PointLow, s2PointHi, s2PointTarget) AS rectContains FROM (SELECT * FROM s2_points) WHERE s2PointTarget = 5177914411069187297;
WITH (5178000000000000000) AS examplePoint SELECT s2RectContains(5179050000000000000, 5177000000000000000, examplePoint) AS rectContains;
WITH (5179000000000000000) AS s2BoundaryLow, (5177000000000000000) AS s2BoundaryHigh SELECT s2RectContains(s2BoundaryLow, s2BoundaryHigh, 5178000000000000000) AS rectContains;
CREATE TABLE s2_test_results AS SELECT s2RectContains(s2PointLow, s2PointHi, s2Point) AS rectContains FROM s2_points;
SELECT COUNT(*) FROM s2_points WHERE s2RectContains(s2PointLow, s2PointHi, s2Point) = 1;
SELECT t1.*, s2RectContains(t1.s2PointLow, t1.s2PointHi, t2.s2Point) AS rectContains FROM s2_points AS t1 JOIN s2_points AS t2 ON t1.id <> t2.id;
