CREATE TABLE FixedStringTable (name FixedString(2));
INSERT INTO FixedStringTable VALUES ('a\0'), ('b\0'), ('c\0');
SELECT * FROM FixedStringTable WHERE name = 'b\0';
SELECT * FROM FixedStringTable WHERE name = 'b';
CREATE TABLE AnotherTable (id UInt32, description FixedString(4));
INSERT INTO AnotherTable VALUES (1, 'test'), (2, 'demo\0'), (3, 'data');
SELECT * FROM AnotherTable WHERE description = 'demo\0';
SELECT COUNT(*) FROM AnotherTable WHERE description = 'test\0';
SELECT name FROM FixedStringTable JOIN AnotherTable ON FixedStringTable.name = substr(AnotherTable.description, 1, 2);
SELECT SUM(id) FROM AnotherTable WHERE description LIKE 'de\0%';
CREATE TABLE JoinExample (key FixedString(3), value UInt32);
INSERT INTO JoinExample VALUES ('abc', 10), ('def', 20), ('ghi', 30);
SELECT a.value, b.value FROM JoinExample a JOIN JoinExample b ON a.key = 'abc';
SELECT value FROM JoinExample WHERE key = 'ghi\0';
SELECT key FROM JoinExample WHERE key = 'ghi';
CREATE TABLE ComplexTable (a FixedString(4), b UInt32);
INSERT INTO ComplexTable VALUES ('abcd', 100), ('efgh', 200), ('ijkl', 300);
SELECT a, MAX(b) FROM ComplexTable GROUP BY a HAVING a = 'abcd';
SELECT COUNT(*) FROM ComplexTable WHERE a LIKE 'abc\0\0';
SELECT a FROM ComplexTable WHERE a = 'xyz\0' UNION SELECT a FROM ComplexTable WHERE a = 'abcd';
CREATE TABLE FinalTable (id UInt64, code FixedString(3));
INSERT INTO FinalTable VALUES (1, 'USD'), (2, 'EUR\0'), (3, 'JPY\0');
SELECT id FROM FinalTable WHERE code = 'EUR';
SELECT id FROM FinalTable WHERE code = 'EUR\0';
SELECT code, COUNT(*) FROM FinalTable GROUP BY code HAVING code LIKE 'USD';
SELECT (SELECT COUNT(*) FROM FixedStringTable) + (SELECT COUNT(*) FROM AnotherTable);