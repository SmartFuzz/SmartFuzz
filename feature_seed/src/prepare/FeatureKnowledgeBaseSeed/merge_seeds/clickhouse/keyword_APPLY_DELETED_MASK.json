CREATE TABLE test_table (id UInt64, data String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 'some_data'), (2, 'more_data'), (3, 'delete_me');
ALTER TABLE test_table DELETE WHERE id = 3;
CREATE TABLE delete_mask (id UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO delete_mask VALUES (1), (2), (3);
APPLY DELETED MASK ON test_table;
SELECT * FROM test_table;
CREATE TABLE another_table (id UInt64, parent_id UInt64, info String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_table VALUES (1, 1, 'info1'), (2, 1, 'info2'), (3, 3, 'info3');
ALTER TABLE another_table DELETE WHERE parent_id = 3;
APPLY DELETED MASK ON another_table;
SELECT id, (SELECT COUNT(*) FROM another_table WHERE parent_id = id) AS child_count FROM test_table;
CREATE TABLE replicated_table (id UInt64, value String) ENGINE = ReplicatedMergeTree('/clickhouse/tables/replicated_table', '1') ORDER BY id;
INSERT INTO replicated_table VALUES (1, 'val1'), (2, 'val2');
ALTER TABLE replicated_table DELETE WHERE id = 1;
APPLY DELETED MASK ON replicated_table;
SELECT id, value FROM replicated_table WHERE id IN (SELECT parent_id FROM another_table WHERE info = 'info1');
CREATE TABLE complex_table (id UInt64, group_id UInt64, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO complex_table VALUES (1, 1, 'first'), (2, 1, 'second'), (3, 2, 'third');
ALTER TABLE complex_table DELETE WHERE name = 'third';
APPLY DELETED MASK ON complex_table;
SELECT DISTINCT group_id FROM complex_table WHERE id IN (SELECT id FROM complex_table WHERE group_id = 1);