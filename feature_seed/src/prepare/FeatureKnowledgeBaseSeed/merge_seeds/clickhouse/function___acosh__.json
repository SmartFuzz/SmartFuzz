CREATE TABLE test_acosh (value Float64);
INSERT INTO test_acosh VALUES (1.0), (2.0), (10.0), (100.0);
SELECT acosh(value) FROM test_acosh;
SELECT acosh(1.0) AS result_1, acosh(2.0) AS result_2 FROM test_acosh;
WITH (SELECT AVG(value) FROM test_acosh) AS avg_value SELECT acosh(avg_value) AS acosh_avg FROM test_acosh;
CREATE TABLE test_join (id Int32, value Float64);
INSERT INTO test_join VALUES (1, 1.0), (2, 3.0);
SELECT a.id, acosh(a.value) FROM test_acosh AS a JOIN test_join AS j ON a.value > j.value;
SELECT acosh(1 + (SELECT MAX(value) FROM test_acosh)) AS acosh_max;
SELECT acosh(2 * value) FROM test_acosh WHERE value > 1;