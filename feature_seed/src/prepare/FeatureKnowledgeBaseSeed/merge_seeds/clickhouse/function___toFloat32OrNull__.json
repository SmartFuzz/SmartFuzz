CREATE TABLE test_float_conversion (value String);
INSERT INTO test_float_conversion VALUES ('42.7'), ('0.0'), ('-8.5'), ('1e5'), ('abc'), ('NaN'), ('-Infinity'), ('Infinity'), ('256'), ('-256'), ('3.14');
SELECT toFloat32OrNull(value) FROM test_float_conversion;
SELECT value, toFloat32OrNull(value) AS converted_value FROM test_float_conversion WHERE converted_value IS NOT NULL;
SELECT (SELECT toFloat32OrNull(value) FROM test_float_conversion WHERE value LIKE '%e%') AS scientific_notation_float;
SELECT a.value AS original_value, toFloat32OrNull(a.value) AS float_conversion, b.value AS comparison_value FROM test_float_conversion AS a JOIN test_float_conversion AS b ON toFloat32OrNull(a.value) > toFloat32OrNull(b.value);
WITH (SELECT toFloat32OrNull('3.14')) AS pi_value SELECT pi_value, pi_value * 2 AS double_pi;
SELECT value, CASE WHEN toFloat32OrNull(value) IS NULL THEN 'Invalid' ELSE 'Valid' END AS validity FROM test_float_conversion;
SELECT SUM(toFloat32OrNull(value)) AS total_valid_float FROM test_float_conversion WHERE toFloat32OrNull(value) IS NOT NULL;
SELECT AVG(toFloat32OrNull(value)) AS average_float FROM (SELECT value FROM test_float_conversion WHERE value NOT LIKE 'abc' AND value NOT LIKE 'NaN' AND value NOT LIKE 'Infinity') AS filtered_values;