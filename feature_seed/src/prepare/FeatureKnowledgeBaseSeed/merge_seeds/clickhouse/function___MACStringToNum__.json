CREATE TABLE mac_addresses (id UInt32, mac_address String);
INSERT INTO mac_addresses VALUES (1, '00:0A:95:9D:68:16'), (2, '00:0A:95:9D:68:GG'), (3, 'invalid_mac'), (4, 'AC:AB:12:23:34:45');
SELECT id, MACStringToNum(mac_address) AS mac_num FROM mac_addresses;
CREATE TABLE valid_mac AS SELECT mac_address FROM mac_addresses WHERE MACStringToNum(mac_address) != 0;
SELECT id, mac_address, MACStringToNum(mac_address) AS mac_num FROM mac_addresses WHERE MACStringToNum(mac_address) <> 0 UNION SELECT id, mac_address, MACStringToNum(mac_address) AS mac_num FROM valid_mac;
SELECT COUNT(*) AS valid_macs FROM mac_addresses WHERE MACStringToNum(mac_address) != 0;
SELECT id, mac_address, MACStringToNum(mac_address) AS mac_num FROM mac_addresses WHERE mac_address LIKE '__:__:__:__:__:__' ORDER BY mac_num DESC;
CREATE TABLE mac_counts AS SELECT MACStringToNum(mac_address) AS mac_num, COUNT(*) AS count FROM mac_addresses GROUP BY mac_num;
SELECT t1.id, t1.mac_address FROM mac_addresses t1 JOIN mac_counts t2 ON MACStringToNum(t1.mac_address) = t2.mac_num WHERE t2.count > 1;
CREATE TABLE mac_statistics AS SELECT MACStringToNum(mac_address) AS mac_num, COUNT(*) AS occurrence FROM mac_addresses GROUP BY mac_num HAVING MACStringToNum(mac_address) <> 0;