CREATE TABLE mac_addresses (id UInt32, mac String);
INSERT INTO mac_addresses VALUES (1, '00:1A:2B:3C:4D:5E'), (2, 'FF:EE:DD:CC:BB:AA'), (3, 'invalid_mac_format'), (4, '01:02:03:04:05:06');
SELECT id, MACStringToOUI(mac) AS oui FROM mac_addresses;
SELECT id, MACStringToOUI(mac) AS oui FROM mac_addresses WHERE oui > 0;
SELECT id, MACStringToOUI(mac) AS oui FROM mac_addresses WHERE MACStringToOUI(mac) IN (SELECT MACStringToOUI(mac) FROM mac_addresses WHERE id < 3);
CREATE TABLE network_devices (device_id UInt32, mac String, location String);
INSERT INTO network_devices VALUES (1, '12:34:56:78:9A:BC', 'Server Room'), (2, '00:11:22:33:44:55', 'Office 1'), (3, '67:89:AB:CD:EF:00', 'Office 2');
SELECT nd.device_id, nd.location, MACStringToOUI(nd.mac) AS oui FROM network_devices nd JOIN mac_addresses ma ON MACStringToOUI(nd.mac) = MACStringToOUI(ma.mac) WHERE nd.device_id > 1;
SELECT M.id, MAX(MACStringToOUI(M.mac)) AS max_oui FROM mac_addresses M GROUP BY M.id HAVING max_oui > 0;
INSERT INTO mac_addresses SELECT id, mac FROM network_devices WHERE location = 'Server Room';
WITH mac_oui AS (SELECT id, MACStringToOUI(mac) AS oui FROM mac_addresses) SELECT id, oui FROM mac_oui WHERE oui = 0;