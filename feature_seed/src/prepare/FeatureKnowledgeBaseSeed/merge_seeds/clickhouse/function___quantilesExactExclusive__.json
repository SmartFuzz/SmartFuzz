CREATE TABLE num AS numbers(1000);
SELECT quantilesExactExclusive(0.25, 0.5, 0.75)(x) FROM (SELECT number AS x FROM num);
CREATE TABLE data1 AS SELECT number % 10 AS group_id, number AS value FROM numbers(100);
SELECT group_id, quantilesExactExclusive(0.25, 0.5, 0.75)(value) AS quantiles FROM data1 GROUP BY group_id;
CREATE TABLE data2 AS SELECT toDate('2022-01-01') + number AS date_col, number AS value FROM numbers(100);
SELECT quantilesExactExclusive(0.1, 0.5, 0.9)(value) FROM data2 WHERE date_col >= '2022-01-01' AND date_col < '2022-04-01';
CREATE TABLE test_table (id UInt32, amount Float64, created_at DateTime) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 100.0, '2022-01-01 00:00:00'), (2, 200.0, '2022-01-02 00:00:00'), (3, 300.0, '2022-01-03 00:00:00');
SELECT quantilesExactExclusive(0.0, 1.0)(amount) FROM test_table;
CREATE TABLE generated_data AS SELECT number AS num FROM numbers(10);
CREATE TABLE other_data (num UInt32) ENGINE = Memory;
INSERT INTO other_data VALUES (1), (2), (3), (4), (5);
SELECT g.num, quantilesExactExclusive(0.5)(o.num) AS median FROM generated_data g JOIN other_data o ON g.num >= o.num GROUP BY g.num;
CREATE TABLE date_data AS SELECT toDate('2023-01-01') + number AS date_value, rand() * 100 AS random_number FROM numbers(100);
SELECT quantilesExactExclusive(0.3, 0.6, 0.9)(random_number) FROM date_data WHERE date_value BETWEEN '2023-01-01' AND '2023-04-01';
SELECT quantilesExactExclusive(0.01, 0.99)(value) FROM (SELECT count() AS value FROM numbers(1000));
CREATE TABLE complex_data AS SELECT number AS num, (number * 1.5) AS val, toDate('2020-01-01') + number AS my_date FROM numbers(500);
SELECT quantilesExactExclusive(0.25, 0.75)(val) FROM complex_data WHERE num % 2 = 0;