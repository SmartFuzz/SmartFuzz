CREATE TABLE test_table (input_value String);
INSERT INTO test_table VALUES ('0'), ('1'), ('255'), ('256'), ('257'), ('9999999999999999999999999999999999999999999'), ('-1'), ('abc'), ('NaN'), ('Inf'), ('0xc0fe'), ('3.14'), ('1234567890123456789012345678901234567890');
SELECT toUInt256OrNull(input_value) FROM test_table;
SELECT input_value, toUInt256OrNull(input_value) AS converted_value FROM test_table WHERE toUInt256OrNull(input_value) IS NOT NULL;
SELECT toUInt256OrNull(input_value) FROM test_table WHERE input_value IN ('0', '123', '256', '1e10', '500', '9999999999999999999999999999999999999999998');
SELECT CASE WHEN toUInt256OrNull(input_value) IS NULL THEN 'Invalid' ELSE 'Valid' END AS validity_status FROM test_table;
WITH (SELECT input_value FROM test_table LIMIT 5) AS limited_input SELECT toUInt256OrNull(input_value) FROM limited_input;
SELECT a.input_value, b.other_column, toUInt256OrNull(a.input_value) FROM test_table a JOIN (SELECT '5' AS other_column) b ON a.input_value = '5';
SELECT DISTINCT toUInt256OrNull(input_value) FROM test_table WHERE input_value NOT LIKE 'abc%' AND input_value NOT LIKE '%NaN%' AND input_value NOT LIKE '%Inf%';
SELECT input_value, toUInt256OrNull(input_value) AS converted_value FROM test_table ORDER BY converted_value ASC;
SELECT COUNT(*) AS valid_count FROM (SELECT toUInt256OrNull(input_value) AS converted_value FROM test_table) WHERE converted_value IS NOT NULL;