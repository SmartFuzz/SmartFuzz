CREATE TABLE test (v Variant(UInt32, String, Array(UInt64))) ENGINE = Memory;
INSERT INTO test VALUES (NULL), (1), ('Test'), ([1, 2, 3]);
SELECT v, v.String, v.UInt32, v.`Array(UInt64)` FROM test;
SELECT * FROM test WHERE variantType(v) = 'UInt32' AND v.UInt32 < 10;
SELECT * FROM test WHERE variantElement(v, 'String') = 'Test';
SELECT toTypeName(v) FROM test;
SET allow_experimental_variant_type = 1;
CREATE TABLE multi_type (id UInt32, value Variant(Int32, Float64, String)) ENGINE = Memory;
INSERT INTO multi_type VALUES (1, 42), (2, 3.14), (3, 'Example String');
SELECT id, variantElement(value, 'Int32') AS int_value, variantElement(value, 'Float64') AS float_value, variantElement(value, 'String') AS str_value FROM multi_type;
SET use_variant_as_common_type = 1;
SELECT if(v = 1, v, v + 10) AS variant_result FROM (SELECT v.UInt32 FROM test WHERE variantType(v) = 'UInt32');
CREATE TABLE joins_test (id UInt32, data Variant(Int32, String)) ENGINE = Memory;
INSERT INTO joins_test VALUES (1, 'Join Test'), (2, 22);
SELECT j.id, j.data.String FROM test AS t JOIN joins_test AS j ON variantElement(t.v, 'UInt32') = j.id;
CREATE TABLE nested_test (id UInt32, nested Variant(Variant(Int32, String), Array(UInt64))) ENGINE = Memory;
INSERT INTO nested_test VALUES (1, NULL), (2, (42, 'Nested String')), (3, [1, 2, 3]);
SELECT id, variantElement(nested, 'Variant(Int32, String)') AS nested_value FROM nested_test;
SET allow_suspicious_variant_types = 1;
CREATE TABLE mixed_test (mixed Variant(Int64, UInt32)) ENGINE = Memory;
INSERT INTO mixed_test VALUES (1::Int64), (2::UInt32), (3::Int64);
SELECT mixed, variantType(mixed) FROM mixed_test WHERE variantType(mixed) = 'UInt32';
SELECT variantElement(mixed, 'Int64') AS int_value, variantElement(mixed, 'UInt32') AS uint_value FROM mixed_test;
CREATE TABLE json_test (data Variant(String, Int32, Array(UInt64))) ENGINE = Memory;
INSERT INTO json_test VALUES ('{"key": "value"}', 123, [1, 2, 3]);
SELECT JSONExtract(data, 'key', 'Variant(String)') AS extracted_value FROM json_test;
SELECT variantElement(data, 'Array(UInt64)') FROM json_test;
SELECT CAST(data AS Variant(String, Int32)) FROM json_test;