CREATE TABLE test_table (id UInt32, values Array(Int32));
INSERT INTO test_table VALUES (1, [0, 0, 1, 2]), (2, [0, 0, 0, 0]), (3, [1, 2, 3, 0, 0]);
SELECT arrayFirstIndex(x -> x > 0, values) FROM test_table;
SELECT id, arrayFirstIndex(x -> x < 3, values) AS first_index FROM test_table WHERE id > 1;
CREATE TABLE other_table (ref UInt32, references Array(UInt32));
INSERT INTO other_table VALUES (1, [2, 3]), (2, [0]), (3, [4, 5, 6]);
SELECT tt.id, arrayFirstIndex(x -> x > 0, tt.values) AS first_index, ot.ref FROM test_table AS tt JOIN other_table AS ot ON tt.id = ot.ref;
SELECT id, arrayFirstIndex(x -> x = 0, values) AS first_zero_index FROM test_table WHERE arrayFirstIndex(x -> x > 1, values) > 0;
CREATE TABLE combined_table AS SELECT tt.id, arrayFirstIndex(x -> x = 3, tt.values) AS first_threes, ot.references FROM test_table tt LEFT JOIN other_table ot ON tt.id = ot.ref;
SELECT id, first_threes FROM combined_table WHERE first_threes IS NOT NULL;
SELECT id, arrayFirstIndex(x -> x IS NOT NULL, [NULL, 2, NULL, 4]) AS non_null_index;