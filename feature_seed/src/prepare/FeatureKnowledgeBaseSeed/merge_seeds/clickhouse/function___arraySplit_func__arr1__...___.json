CREATE TABLE test_arraySplit (a ARRAY(Int32), b ARRAY(Int32)) ENGINE = Memory;
INSERT INTO test_arraySplit VALUES ([1, 2, 3, 4, 5], [1, 0, 0, 1, 0]);
SELECT arraySplit((x, y) -> y, a, b) AS res FROM test_arraySplit;
CREATE TABLE test_arraySplit2 (x ARRAY(Int32), y ARRAY(Int32)) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO test_arraySplit2 VALUES ([1, 2, 3], [0, 1, 0]), ([4, 5, 6], [1, 0, 0]);
SELECT arraySplit((x, y) -> y, x, y) AS res FROM test_arraySplit2;
SELECT arraySplit((x, y) -> x - y, [10, 20, 30, 40], [1, 2, 3, 4]) AS res;
CREATE TABLE test_complex (arr1 ARRAY(Int32), arr2 ARRAY(Int32)) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO test_complex VALUES ([1, 2, 3, 4], [0, 1, 0, 1]);
SELECT arraySplit((x, y) -> y, arr1, arr2) AS result FROM test_complex WHERE arrayLength(arr1) > 2;
CREATE TABLE nested_test (id Int32, data ARRAY(Int32)) ENGINE = Memory;
INSERT INTO nested_test VALUES (1, [1, 2, 3]), (2, [4, 5, 6]);
SELECT id, arraySplit((x, y) -> y, data, [0, 1, 0]) AS res FROM nested_test;
CREATE TABLE join_test (id Int32, values ARRAY(Int32)) ENGINE = Memory;
INSERT INTO join_test VALUES (1, [10, 20]), (2, [30, 40]);
SELECT jt.id, arraySplit((x, y) -> y, jt.values, [1, 0]) AS res FROM join_test jt WHERE jt.id = 1;
SELECT arraySplit((x, y) -> if(x + y > 10, 1, 0), [5, 6, 7], [5, 4, 3]) AS res;