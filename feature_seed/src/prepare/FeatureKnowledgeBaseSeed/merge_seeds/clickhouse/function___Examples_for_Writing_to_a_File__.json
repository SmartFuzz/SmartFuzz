CREATE TABLE test_data (column1 UInt32, column2 UInt32, column3 UInt32) ENGINE = Memory;
INSERT INTO TABLE FUNCTION file('test.tsv', 'TSV', 'column1 UInt32, column2 UInt32, column3 UInt32') VALUES (1, 2, 3), (3, 2, 1), (1, 3, 2);
SELECT column1, column2, column3 FROM test_data WHERE column1 = 1;
INSERT INTO TABLE FUNCTION file('test_{_partition_id}.tsv', 'TSV', 'column1 UInt32, column2 UInt32, column3 UInt32') PARTITION BY column3 VALUES (1, 2, 3), (3, 2, 1), (1, 3, 2);
CREATE TABLE other_data (columnA UInt32, columnB UInt32) ENGINE = Memory;
INSERT INTO other_data VALUES (4, 5), (6, 7), (8, 9);
INSERT INTO TABLE FUNCTION file('combined_output.tsv', 'TSV', 'column1 UInt32, column2 UInt32') SELECT td.column1, od.columnB FROM test_data td JOIN other_data od ON td.column2 = od.columnA WHERE td.column1 > 1;
CREATE TABLE complex_data (col1 UInt32, col2 UInt32, col3 UInt32) ENGINE = MergeTree() ORDER BY col1;
INSERT INTO complex_data VALUES (1, 2, 3), (3, 2, 1), (2, 3, 1);
INSERT INTO TABLE FUNCTION file('complex_{_partition_id}.tsv', 'TSV', 'col1 UInt32, col2 UInt32') PARTITION BY col3 SELECT col1, col2 FROM complex_data WHERE col2 = 2;
