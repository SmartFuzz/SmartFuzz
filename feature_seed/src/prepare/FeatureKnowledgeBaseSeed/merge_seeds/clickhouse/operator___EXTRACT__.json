CREATE TABLE test_dates (event_date DateTime);
INSERT INTO test_dates VALUES (toDateTime('2023-01-01 12:34:56'));
INSERT INTO test_dates VALUES (toDateTime('2023-02-28 23:59:59'));
INSERT INTO test_dates VALUES (toDateTime('2023-03-31 00:00:00'));
SELECT EXTRACT(DAY FROM event_date) AS day_part FROM test_dates;
SELECT EXTRACT(MONTH FROM event_date) AS month_part FROM test_dates;
SELECT EXTRACT(YEAR FROM event_date) AS year_part FROM test_dates;
SELECT EXTRACT(HOUR FROM event_date) AS hour_part FROM test_dates;
SELECT EXTRACT(MINUTE FROM event_date) AS minute_part FROM test_dates;
SELECT EXTRACT(SECOND FROM event_date) AS second_part FROM test_dates;
SELECT event_date, EXTRACT(DAY FROM event_date) AS day_part FROM test_dates WHERE EXTRACT(MONTH FROM event_date) = 2;
SELECT event_date, EXTRACT(YEAR FROM event_date), EXTRACT(MONTH FROM event_date) FROM test_dates WHERE EXTRACT(SECOND FROM event_date) > 30;
SELECT DISTINCT EXTRACT(DAY FROM event_date) AS day_part FROM test_dates WHERE EXTRACT(YEAR FROM event_date) = 2023;
SELECT EXTRACT(MONTH FROM event_date), COUNT(*) FROM test_dates GROUP BY EXTRACT(MONTH FROM event_date);
SELECT event_date, EXTRACT(DAY FROM event_date) AS day_part FROM (SELECT toDateTime('2023-04-15 12:15:15') AS event_date INTERSECT SELECT event_date FROM test_dates);