CREATE TABLE test_vectors (id UInt32, vector1 Array(Int32), vector2 Array(Int32));
INSERT INTO test_vectors VALUES (1, [1, 2, 3], [4, 5, 6]);
INSERT INTO test_vectors VALUES (2, [1, 2, 3], [4, 5]);
INSERT INTO test_vectors VALUES (3, [1, 2, 3], [4, 5, 6, 7]);
SELECT arrayDotProduct(vector1, vector2) AS dot_product FROM test_vectors WHERE id = 1;
SELECT arrayDotProduct([1, 2.5, 3], [4.5, 5.5, 6]) AS res, toTypeName(res);
SELECT arrayDotProduct((1, 2, 3), (4, 5, 6)) AS res, toTypeName(res);
SELECT arrayDotProduct([1, 2, NULL], [4, NULL, 6]) AS res, toTypeName(res);
SELECT arrayDotProduct((1::UInt16, 2::Float32, 3::Float64), (4::UInt32, 5::Int8, 6::Int64)) AS res, toTypeName(res);
WITH (SELECT arrayMap(i -> i * 10, [1, 2, 3]) AS vec1, [4, 5, 6] AS vec2) AS vectors SELECT arrayDotProduct(vec1, vec2) AS res;
WITH (SELECT arrayJoin([[1, 2, 3], [2, 3, 4]]) AS vec1, arrayJoin([[4, 5, 6], [5, 6, 7]]) AS vec2) SELECT arrayDotProduct(vec1, vec2) AS res;
SELECT arrayDotProduct([2, 2], [1, 1]) AS res, toTypeName(res), toTypeName(arrayDotProduct(vector1, vector2)) FROM test_vectors WHERE id = 1;
SELECT arrayDotProduct([NULL, 5], [1, 2]) AS res;
SELECT res AS dot_product FROM (SELECT arrayDotProduct([1, 2], [3, 4]) AS res);
SELECT arrayDotProduct(vector1, vector2) AS dot_product FROM test_vectors WHERE id = 2 UNION SELECT arrayDotProduct([1, 1, 1], [1, 1, 1]);