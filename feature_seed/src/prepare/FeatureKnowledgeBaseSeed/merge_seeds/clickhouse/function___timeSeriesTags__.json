CREATE TABLE db_name.time_series_table ENGINE=TimeSeries TAGS tags_table;
CREATE TABLE db_name.time_series_table ENGINE=TimeSeries TAGS INNER UUID '01234567-89ab-cdef-0123-456789abcdef';
CREATE TABLE tags_table (tag_id UUID, tag_value String);
INSERT INTO tags_table VALUES (UUID('01234567-89ab-cdef-0123-456789abcdef'), 'value1');
INSERT INTO tags_table VALUES (UUID('12345678-90ab-cdef-0123-456789abcdef'), 'value2');
SELECT * FROM timeSeriesTags(db_name.time_series_table);
SELECT * FROM timeSeriesTags('db_name.time_series_table');
SELECT * FROM timeSeriesTags('db_name', 'time_series_table');
CREATE TABLE db_name.time_series_table_2 ENGINE=TimeSeries TAGS tags_table;
SELECT t.tag_id FROM tags_table t JOIN timeSeriesTags(db_name.time_series_table) ts ON t.tag_id = ts.tag_id;
SELECT COUNT(*) FROM timeSeriesTags(db_name.time_series_table) WHERE tag_value = 'value1';
SELECT * FROM timeSeriesTags(db_name.time_series_table) WHERE tag_id IN (SELECT tag_id FROM tags_table WHERE tag_value LIKE 'value%');
SELECT * FROM (SELECT * FROM timeSeriesTags(db_name.time_series_table)) AS ts WHERE ts.tag_id IS NOT NULL;
WITH (SELECT tag_value FROM tags_table WHERE tag_value = 'value1') AS predefined_value SELECT * FROM timeSeriesTags(db_name.time_series_table) WHERE tag_value = predefined_value;
