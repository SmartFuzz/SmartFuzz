CREATE TABLE test_table (number UInt32, text String);
INSERT INTO test_table VALUES (1, 'good'), (2, 'better'), (3, 'best');
SELECT formatRow('CSV', number, text) FROM test_table;
SELECT formatRow('TSV', number, text) FROM test_table;
CREATE TABLE another_table (id UInt32, value String);
INSERT INTO another_table VALUES (1, 'first'), (2, 'second');
SELECT formatRow('CustomSeparated', t.number, t.text) FROM test_table AS t INNER JOIN another_table AS a ON t.number = a.id SETTINGS format_custom_result_before_delimiter='<prefix>\n', format_custom_result_after_delimiter='<suffix>';
SELECT formatRow('CommaSeparated', number + 1, text) FROM test_table WHERE number < 3;
SELECT formatRow('CSV', (SELECT count(*) FROM test_table), 'total') AS result;
SELECT formatRow('CSV', number, concat(text, ' extra')) FROM (SELECT * FROM test_table) WHERE number IN (1, 2);
SELECT formatRow('TSV', number, (SELECT text FROM test_table WHERE number = 3)) FROM test_table WHERE number < 3;
SELECT formatRow('CustomSeparated', number, text) FROM (SELECT number, text FROM test_table WHERE number <= 2) AS subquery SETTINGS format_custom_result_before_delimiter='<prefix>\n', format_custom_result_after_delimiter='<suffix>';
CREATE TABLE complex_table (num UInt32, str String, flag UInt8) ENGINE = MergeTree() ORDER BY num;
INSERT INTO complex_table VALUES (1, 'yes', 1), (2, 'no', 0);
SELECT formatRow('CSV', t.num, t.str, t.flag) FROM complex_table AS t WHERE t.flag = 1;
SELECT formatRow('CustomSeparated', (SELECT avg(num) FROM complex_table), (SELECT count(*) FROM complex_table WHERE flag = 0)) AS stats;