CREATE TABLE test_table (value String);
INSERT INTO test_table VALUES ('-8'), ('256'), ('abc'), ('-1.5'), ('NaN'), ('Inf'), ('0xc0fe'), ('-128'), ('128');
SELECT toInt8OrDefault(value, CAST('-1', 'Int8')) AS converted_value FROM test_table;
SELECT toInt8OrDefault(value, CAST('0', 'Int8')) AS converted_value FROM test_table WHERE value NOT LIKE 'abc';
SELECT toInt8OrDefault(value, CAST('5', 'Int8')) AS converted_value FROM (SELECT value FROM test_table WHERE value IN ('-8', 'abc', 'Inf'));
WITH (SELECT COUNT(*) FROM test_table WHERE value = 'abc') AS err_count SELECT toInt8OrDefault(value, CAST(err_count, 'Int8')) AS converted_value FROM test_table;
CREATE TABLE another_table (id UInt64, value String);
INSERT INTO another_table VALUES (1, '10'), (2, 'abc'), (3, '128'), (4, 'NaN');
SELECT a.id, toInt8OrDefault(a.value, CAST('0', 'Int8')) AS converted_value FROM test_table AS t INNER JOIN another_table AS a ON t.value = a.value;
SELECT toInt8OrDefault(a.value, CASE WHEN a.value = 'abc' THEN CAST('100', 'Int8') ELSE CAST('-1', 'Int8') END) AS converted_value FROM another_table AS a;
SELECT toInt8OrDefault(ROUND(value, 2), CAST('0', 'Int8')) AS rounded_value FROM (SELECT 1.5 AS value UNION ALL SELECT 2.8 UNION ALL SELECT 'NaN' UNION ALL SELECT '-Inf');