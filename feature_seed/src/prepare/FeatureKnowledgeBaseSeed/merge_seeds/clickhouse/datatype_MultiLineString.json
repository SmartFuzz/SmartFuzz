CREATE TABLE geo_multilinestring (l MultiLineString) ENGINE = Memory();
INSERT INTO geo_multilinestring VALUES([[(0, 0), (10, 0), (10, 10), (0, 10)], [(1, 1), (2, 2), (3, 3)]]);
INSERT INTO geo_multilinestring VALUES([[(0, 0), (0, 1)], [(1, 1), (1, 2)]]);
INSERT INTO geo_multilinestring VALUES([[(0, 0), (0, 0)], [(0, 0), (0, 0)]]);
SELECT l, toTypeName(l) FROM geo_multilinestring WHERE l IS NOT NULL;
CREATE TABLE geo_multilinestring_2 (id Int32, lines MultiLineString) ENGINE = Memory();
INSERT INTO geo_multilinestring_2 VALUES (1, [[(0, 0), (10, 0)], [(5, 5), (10, 10)]]), (2, [[(1, 1), (2, 2), (3, 3)]]);
SELECT a.l, b.lines FROM geo_multilinestring a JOIN geo_multilinestring_2 b ON a.l = b.lines;
SELECT arrayJoin(l) AS line_segment FROM geo_multilinestring;
SELECT COUNT(*) FROM geo_multilinestring WHERE length(l) > 0;
CREATE TABLE geo_multilinestring_counts AS SELECT l, COUNT(*) AS count FROM geo_multilinestring GROUP BY l;
INSERT INTO geo_multilinestring_counts SELECT l, COUNT(*) FROM geo_multilinestring GROUP BY l;
SELECT distinct l FROM geo_multilinestring WHERE arrayLength(l) > 1;
SELECT l, arrayMap(x -> arrayMap(y -> toTypeName(y), x), l) AS type_names FROM geo_multilinestring;