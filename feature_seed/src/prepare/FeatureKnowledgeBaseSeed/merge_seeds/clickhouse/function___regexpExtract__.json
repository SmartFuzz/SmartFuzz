CREATE TABLE test_data (input_string String);
INSERT INTO test_data VALUES ('100-200'), ('300-400'), ('abc-xyz'), ('5-10'), ('12-34'), ('-5--10');
SELECT regexpExtract(input_string, '(\\d+)-(\\d+)', 1) AS first_number FROM test_data;
SELECT regexpExtract(input_string, '(\\d+)-(\\d+)', 2) AS second_number FROM test_data;
SELECT regexpExtract(input_string, '(\\d+)-(\\d+)', 0) AS full_match FROM test_data;
SELECT input_string, regexpExtract(input_string, '(\\d+)-(\\d+)', 1) AS first_number, regexpExtract(input_string, '(\\d+)-(\\d+)', 2) AS second_number FROM test_data WHERE regexpExtract(input_string, '(\\d+)-(\\d+)', 1) IS NOT NULL;
SELECT input_string, COUNT(*) AS matches FROM test_data WHERE regexpExtract(input_string, '(\\d+)-(\\d+)', 1) IS NOT NULL GROUP BY input_string;
WITH (SELECT regexpExtract('Value: 25, Code: 123', 'Value: (\\d+), Code: (\\d+)', 1)) AS extracted_value, (SELECT regexpExtract('Value: 25, Code: 123', 'Value: (\\d+), Code: (\\d+)', 2)) AS extracted_code SELECT extracted_value, extracted_code;
SELECT COUNT(*) FROM (SELECT regexpExtract(input_string, '(\\d+)-(\\d+)', 1) AS first_number FROM test_data) AS subquery WHERE first_number IS NOT NULL;
SELECT DISTINCT regexpExtract(input_string, '([a-z]+)-([a-z]+)', 1) FROM test_data WHERE input_string LIKE 'abc-%';
CREATE TABLE another_table (desc_string String);
INSERT INTO another_table VALUES ('item 1: 100-200'), ('item 2: 300-400');
SELECT t1.input_string, t2.desc_string, regexpExtract(t1.input_string, '(\\d+)-(\\d+)', 1) AS first_num FROM test_data AS t1 JOIN another_table AS t2 ON regexpExtract(t2.desc_string, '(\\d+)-(\\d+)', 1) = regexpExtract(t1.input_string, '(\\d+)-(\\d+)');