SELECT emptyArrayUInt32();
CREATE TABLE test_table (id UInt32, value Array(UInt32));
INSERT INTO test_table VALUES (1, emptyArrayUInt32()), (2, [1, 2, 3]), (3, emptyArrayUInt32());
SELECT id, arrayJoin(value) FROM test_table WHERE arrayLength(value) = 0;
SELECT id FROM test_table WHERE value = emptyArrayUInt32();
SELECT id, count(value) FROM test_table GROUP BY id HAVING value = emptyArrayUInt32();
WITH (SELECT emptyArrayUInt32()) AS empty_array SELECT id FROM test_table WHERE value = empty_array;
CREATE TABLE another_table (a UInt32, b UInt32);
INSERT INTO another_table VALUES (1, 10), (2, 20), (3, 30);
SELECT a, arrayJoin(arrayConcat(emptyArrayUInt32(), [b])) FROM another_table;
SELECT id, sum(arrayLength(value)) FROM test_table GROUP BY id HAVING sum(arrayLength(value)) = 0;