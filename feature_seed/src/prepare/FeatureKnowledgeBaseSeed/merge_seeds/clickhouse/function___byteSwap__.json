SELECT id, value, byteSwap(value) AS swapped_value FROM test_byteSwap;
SELECT id, byteSwap(value) FROM (SELECT value FROM test_byteSwap WHERE id = 1) AS subquery;
SELECT t1.id, byteSwap(t1.value) FROM test_byteSwap AS t1 JOIN (SELECT id, value FROM test_byteSwap WHERE value < 100000) AS t2 ON t1.id = t2.id;
CREATE TABLE test_byteSwap_logs (operation String, old_value UInt32, new_value UInt32, timestamp DateTime DEFAULT now());
INSERT INTO test_byteSwap_logs SELECT 'byteSwap', value, byteSwap(value), now() FROM test_byteSwap;
SELECT COUNT(*), AVG(byteSwap(value)) FROM test_byteSwap;
SELECT id, byteSwap(value) AS swapped_value FROM test_byteSwap WHERE swapped_value > 10000;
SELECT MAX(byteSwap(value)), MIN(byteSwap(value)) FROM (SELECT value FROM test_byteSwap) AS subquery;