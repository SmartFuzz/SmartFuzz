CREATE TABLE target_table (id UInt32, name String);
INSERT INTO target_table SELECT * FROM input('id UInt32, name String') VALUES (1, 'Alice'), (2, 'Bob');
CREATE TABLE source_table (source_id UInt32, source_name String);
INSERT INTO source_table VALUES (1, 'Charlie'), (2, 'Dana');
INSERT INTO target_table SELECT * FROM input('source_id UInt32, source_name String') SELECT source_id + 2 AS id, upper(source_name) AS name FROM source_table;
CREATE TABLE another_table (key UInt32, value Float64);
INSERT INTO another_table VALUES (1, 10.0), (2, 20.0);
INSERT INTO target_table SELECT * FROM input('key UInt32, value Float64') SELECT key, toString(value) AS name FROM another_table WHERE value > 15.0;
INSERT INTO target_table SELECT * FROM input('id UInt32, name String') SELECT 3 AS id, 'Eve' AS name UNION ALL SELECT 4 AS id, 'Frank' AS name;
CREATE TABLE join_table (join_id UInt32, join_name String);
INSERT INTO join_table VALUES (1, 'Gina'), (2, 'Hugh');
INSERT INTO target_table SELECT * FROM input('join_id UInt32, join_name String') SELECT jt.join_id, lower(jt.join_name) FROM join_table jt WHERE jt.join_id IN (SELECT DISTINCT id FROM target_table);