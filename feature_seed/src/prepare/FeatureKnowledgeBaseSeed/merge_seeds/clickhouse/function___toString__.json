CREATE TABLE test_dates (date_col Date, datetime_col DateTime);
INSERT INTO test_dates VALUES ('2023-01-01', '2023-01-01 12:00:00');
INSERT INTO test_dates VALUES ('2023-12-31', '2023-12-31 23:59:59');
SELECT toString(date_col) AS date_string FROM test_dates;
SELECT toString(datetime_col, 'Europe/London') AS datetime_string FROM test_dates;
SELECT toString(toDate('2023-10-25')) AS date_str;
SELECT toString(toDateTime(1698199605), 'Asia/Yekaterinburg') AS formatted_datetime_string;
SELECT toString(toDate(70000)) AS date_timestamp_string;
SELECT toString(toDateTime(1698199605)) AS datetime_unix_timestamp_string;
SELECT toString(1635609600) AS unix_timestamp_converted_date;
SELECT toString(date_col, 'Asia/Tokyo'), toString(datetime_col, 'Asia/Tokyo') FROM test_dates WHERE date_col = '2023-01-01';
SELECT ts, toString(ts) AS str_ts FROM (SELECT now() AS ts) AS current_time;
SELECT t.date_col, t.datetime_col, toString(t.date_col) AS date_string, toString(t.datetime_col) AS datetime_string FROM test_dates AS t WHERE date_col < '2023-06-01';
SELECT a.date_col, b.datetime_col, toString(a.date_col) AS date_string, toString(b.datetime_col, 'Europe/Paris') AS datetime_string FROM test_dates AS a JOIN test_dates AS b ON a.date_col = b.date_col;
SELECT DISTINCT toString(toDateTime(CAST(1698199605 AS UInt32)), 'America/New_York') FROM (SELECT number FROM numbers(10));
SELECT toString(null) AS null_string;
SELECT toString(toDate('2023-10-25')), toString(toDateTime('2023-10-25 14:30:00')) UNION ALL SELECT toString(toDate('2023-11-01')), toString(toDateTime('2023-11-01 09:15:00'));