CREATE TABLE test_table (input_value String, default_value UInt256);
INSERT INTO test_table VALUES ('-256', CAST('0', 'UInt256'));
INSERT INTO test_table VALUES ('abc', CAST('0', 'UInt256'));
INSERT INTO test_table VALUES ('123.456', CAST('10', 'UInt256'));
INSERT INTO test_table VALUES ('0xc0fe', CAST('5', 'UInt256'));
INSERT INTO test_table VALUES ('NaN', CAST('0', 'UInt256'));
INSERT INTO test_table VALUES ('Inf', CAST('0', 'UInt256'));
INSERT INTO test_table VALUES ('-1e10', CAST('100', 'UInt256'));
INSERT INTO test_table VALUES (CAST(9223372036854775807 AS String), CAST('0', 'UInt256'));
SELECT toUInt256OrDefault(input_value, default_value) FROM test_table;
SELECT toUInt256OrDefault(input_value, CAST('10', 'UInt256')) FROM test_table WHERE default_value = 10;
SELECT (SELECT toUInt256OrDefault(input_value, default_value) FROM test_table WHERE input_value = 'abc') + 5 AS result;
SELECT t1.input_value, toUInt256OrDefault(t2.input_value, CAST('0', 'UInt256')) FROM (SELECT '200' AS input_value) AS t1 JOIN (SELECT '500' AS input_value) AS t2 ON toUInt256OrDefault(t1.input_value, CAST('0', 'UInt256')) > 0;