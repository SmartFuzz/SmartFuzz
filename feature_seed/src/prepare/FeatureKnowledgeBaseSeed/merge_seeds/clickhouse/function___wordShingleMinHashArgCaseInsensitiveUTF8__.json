CREATE TABLE IF NOT EXISTS test_shingles (text String);
INSERT INTO test_shingles VALUES ('ClickHouse is fast.');
INSERT INTO test_shingles VALUES ('ClickHouse is powerful for OLAP.');
INSERT INTO test_shingles VALUES ('Data processing made easy with ClickHouse.');
SELECT wordShingleMinHashArgCaseInsensitiveUTF8(text, 1, 6) FROM test_shingles;
SELECT wordShingleMinHashArgCaseInsensitiveUTF8(text, 3, 6) AS hashes FROM test_shingles WHERE text LIKE '%fast%';
SELECT text, wordShingleMinHashArgCaseInsensitiveUTF8(text, 2, 5) FROM test_shingles ORDER BY text;
SELECT wordShingleMinHashArgCaseInsensitiveUTF8('Multiple tables can be joined!', 1, 4) AS min_max_hashes;
CREATE TABLE IF NOT EXISTS more_shingles (id UInt32, text String);
INSERT INTO more_shingles VALUES (1, 'Join me for a ClickHouse session.'), (2, 'Big data analytics with speed.');
SELECT t1.text, wordShingleMinHashArgCaseInsensitiveUTF8(t1.text, 3, 5) AS shingle_hashes FROM test_shingles t1 JOIN more_shingles t2 ON t1.text LIKE CONCAT('%', t2.text, '%');
SELECT text, wordShingleMinHashArgCaseInsensitiveUTF8(text, 5, 8) FROM test_shingles WHERE LENGTH(text) > 10;
WITH (SELECT wordShingleMinHashArgCaseInsensitiveUTF8(text, 3, 2) FROM test_shingles) AS shingle_data SELECT * FROM shingle_data;
SELECT COUNT(*) FROM (SELECT wordShingleMinHashArgCaseInsensitiveUTF8(text, 1, 1) FROM test_shingles) AS shingle_count;
SELECT wordShingleMinHashArgCaseInsensitiveUTF8(COALESCE(text, 'Default String'), 2, 5) FROM test_shingles;
SELECT wordShingleMinHashArgCaseInsensitiveUTF8(text, 25, 25) FROM test_shingles WHERE LENGTH(text) <= 100;