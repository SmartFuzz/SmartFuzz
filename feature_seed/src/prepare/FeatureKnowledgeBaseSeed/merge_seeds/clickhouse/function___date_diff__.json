CREATE TABLE date_test (start_time DateTime, end_time DateTime);
INSERT INTO date_test VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-01-01 01:00:00'));
SELECT dateDiff('hour', start_time, end_time) FROM date_test;
INSERT INTO date_test VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-02-01 00:00:00'));
SELECT dateDiff('month', start_time, end_time) FROM date_test;
INSERT INTO date_test VALUES (toDateTime('2022-12-31 23:59:59'), toDateTime('2023-01-01 00:00:00'));
SELECT dateDiff('second', start_time, end_time) FROM date_test;
INSERT INTO date_test VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2024-01-01 00:00:00'));
SELECT dateDiff('year', start_time, end_time) FROM date_test;
INSERT INTO date_test VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-01-08 00:00:00'));
SELECT dateDiff('week', start_time, end_time) FROM date_test;
INSERT INTO date_test VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-01-01 23:59:59'));
SELECT dateDiff('minute', start_time, end_time) FROM date_test;
INSERT INTO date_test VALUES (toDateTime('2021-01-01 00:00:00'), toDateTime('2023-01-01 00:00:00'));
SELECT dateDiff('day', start_time, end_time) FROM date_test;
CREATE TABLE date_summary AS SELECT dateDiff('day', start_time, end_time) AS days_difference FROM date_test;
SELECT days_difference, COUNT(*) FROM date_summary GROUP BY days_difference;
INSERT INTO date_test VALUES (toDateTime('2023-01-01 12:00:00'), toDateTime('2023-01-01 12:30:00'));
SELECT dateDiff('minute', start_time, end_time) AS minutes_diff FROM date_test WHERE minutes_diff > 0;
CREATE TABLE nested_test AS SELECT dateDiff('day', s.start_time, e.end_time) AS days_diff FROM (SELECT toDateTime('2023-01-01 00:00:00') AS start_time) AS s, (SELECT toDateTime('2024-01-01 00:00:00') AS end_time) AS e;
SELECT * FROM nested_test;
INSERT INTO date_test VALUES (toDateTime('2023-01-01 00:00:00'), toDateTime('2023-03-01 00:00:00'));
INSERT INTO date_test VALUES (toDateTime('2023-02-01 12:00:00'), toDateTime('2023-02-01 12:15:00'));
SELECT dateDiff('minute', start_time, end_time) AS minute_diff, COUNT(*) FROM date_test GROUP BY minute_diff HAVING minute_diff < 20;