CREATE TABLE test_table1 (id UInt32, name String) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE test_table2 (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE test_table3 (id UInt32, description String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table1 VALUES (1, 'Alice'), (2, 'Bob');
INSERT INTO test_table2 VALUES (1, 10.5), (2, 20.5);
INSERT INTO test_table3 VALUES (1, 'First entry'), (2, 'Second entry');
SELECT * FROM test_table1 PARALLEL WITH SELECT * FROM test_table2 PARALLEL WITH SELECT * FROM test_table3;
ALTER TABLE test_table1 ADD COLUMN age UInt8;
ALTER TABLE test_table2 ADD COLUMN timestamp DateTime;
DROP TABLE IF EXISTS test_table1 PARALLEL WITH DROP TABLE IF EXISTS test_table2;
SELECT id, name FROM test_table1 WHERE id IN (SELECT id FROM test_table2 WHERE value > 15.0) PARALLEL WITH SELECT id, description FROM test_table3 WHERE description LIKE '%entry%';
SELECT COUNT(*) FROM test_table1 PARALLEL WITH SELECT COUNT(*) FROM test_table2;
CREATE TABLE test_table4 (id UInt32, status String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table4 VALUES (1, 'active'), (2, 'inactive');
SELECT id, name, status FROM test_table1 JOIN test_table4 ON test_table1.id = test_table4.id PARALLEL WITH SELECT id, value FROM test_table2 WHERE value < 25.0;
CREATE TABLE test_table5 (id UInt32, score Int32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table5 VALUES (1, 100), (2, 200);
SELECT AVG(score) FROM test_table5 WHERE id IN (SELECT id FROM test_table1) PARALLEL WITH SELECT MIN(value) FROM test_table2 WHERE id IN (SELECT id FROM test_table1);