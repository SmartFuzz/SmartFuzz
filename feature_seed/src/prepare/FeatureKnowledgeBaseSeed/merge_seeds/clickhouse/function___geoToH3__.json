CREATE TABLE geo_test (lon Float64, lat Float64, resolution UInt8);
INSERT INTO geo_test VALUES (37.79506683, 55.71290588, 15);
SELECT geoToH3(lon, lat, resolution) AS h3Index FROM geo_test;
INSERT INTO geo_test VALUES (0.0, 0.0, 0);
SELECT geoToH3(lon, lat, resolution) AS h3Index FROM geo_test WHERE resolution = 0;
INSERT INTO geo_test VALUES (180.0, 90.0, 15), (-180.0, -90.0, 15);
SELECT geoToH3(lon, lat, resolution) AS h3Index FROM geo_test WHERE lon BETWEEN -180 AND 180 AND lat BETWEEN -90 AND 90;
SELECT COUNT(*) as count, geoToH3(lon, lat, resolution) AS h3Index FROM geo_test GROUP BY h3Index;
SELECT geoToH3(lon, lat, 8) FROM geo_test WHERE lon IN (SELECT lon FROM geo_test WHERE lat < 0);
CREATE TABLE location_data (id UInt32, lon Float64, lat Float64, resolution UInt8);
INSERT INTO location_data VALUES (1, 37.79506683, 55.71290588, 15), (2, 30.0, 60.0, 10);
SELECT ld.id, geoToH3(ld.lon, ld.lat, ld.resolution) AS h3Index FROM location_data ld JOIN geo_test gt ON ld.id = 1 WHERE ld.resolution = 10;
SELECT geoToH3(37.79506683 + 0.1, 55.71290588 + 0.1, 15) AS h3Index, geoToH3(lon, lat, resolution) AS h3Index2 FROM geo_test;
CREATE TABLE geo_test_2 AS SELECT * FROM geo_test;
SELECT COUNT(*) FROM geo_test_2 WHERE geoToH3(lon, lat, 5) IS NOT NULL;
SELECT geoToH3(37.79506683, 55.71290588, resolution) AS h3Index FROM (SELECT resolution FROM geo_test LIMIT 5);