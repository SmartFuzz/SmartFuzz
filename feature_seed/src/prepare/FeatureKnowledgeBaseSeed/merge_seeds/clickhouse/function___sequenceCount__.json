CREATE TABLE events (time DateTime, number UInt8) ENGINE = MergeTree() ORDER BY time;
INSERT INTO events VALUES ('2023-01-01 00:00:01', 1), ('2023-01-01 00:00:02', 2), ('2023-01-01 00:00:03', 1), ('2023-01-01 00:00:04', 3);
SELECT sequenceCount('(?1).*(?2)')(time, number = 1, number = 2) FROM events;
CREATE TABLE events2 (time DateTime, number UInt8) ENGINE = MergeTree() ORDER BY time;
INSERT INTO events2 VALUES ('2023-01-01 00:00:10', 1), ('2023-01-01 00:00:11', 1), ('2023-01-01 00:00:12', 2);
SELECT sequenceCount('(?1)(?2)')(time, number = 1, number = 1) FROM events2;
SELECT COUNT(*) FROM (SELECT sequenceCount('(?1).*(?2)')(time, number = 2, number = 1) FROM events GROUP BY time);
WITH (SELECT COUNT(*) FROM events) AS total_events SELECT sequenceCount('(?1).*(?2)')(time, number = 1, number = 2) AS matched_events, total_events FROM events;
CREATE TABLE events3 (time DateTime, number UInt8) ENGINE = MergeTree() ORDER BY time;
INSERT INTO events3 VALUES ('2023-01-01 00:00:20', 1), ('2023-01-01 00:00:21', 2), ('2023-01-01 00:00:22', 3), ('2023-01-01 00:00:23', 1);
SELECT sequenceCount('(?1).*(?2)')(time, number = 1, number = 3) FROM events3;
SELECT sequenceCount('(?1)(?2)')(time, number = 1, number = 2) FROM (SELECT * FROM events3 WHERE number IN (1, 2));
CREATE TABLE events4 (time DateTime, number UInt8) ENGINE = MergeTree() ORDER BY time;
INSERT INTO events4 VALUES ('2023-01-01 00:00:30', 1), ('2023-01-01 00:00:31', 2), ('2023-01-01 00:00:32', 2), ('2023-01-01 00:00:33', 1);
SELECT COUNT(DISTINCT number) AS unique_numbers, sequenceCount('(?1).*(?2)')(time, number = 1, number = 2) AS matched_sequences FROM events4 GROUP BY number;
SELECT sequenceCount('(?1).*(?2)')(time, number = 1, number = 2) FROM (SELECT time, number FROM events4 ORDER BY time LIMIT 10);