CREATE TABLE test_table (id UInt32, random_value Float64);
INSERT INTO test_table (id, random_value) VALUES (1, randCanonical());
INSERT INTO test_table (id, random_value) VALUES (2, randCanonical());
INSERT INTO test_table (id, random_value) VALUES (3, randCanonical());
SELECT AVG(random_value) FROM test_table;
SELECT id FROM test_table WHERE random_value > 0.5;
SELECT id, random_value FROM test_table ORDER BY random_value DESC LIMIT 5;
SELECT COUNT(*) FROM (SELECT randCanonical() AS rand_val FROM numbers(1000) WHERE rand_val < 0.3);
SELECT SUM(randCanonical()) AS total_random FROM (SELECT randCanonical() FROM test_table);
CREATE TABLE another_table (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO another_table SELECT id, randCanonical() FROM test_table;
SELECT t1.id, t1.random_value, t2.value FROM test_table t1 JOIN another_table t2 ON t1.id = t2.id WHERE t1.random_value < t2.value;
SELECT COUNT(*) FROM (SELECT COUNT(*) AS random_counts FROM (SELECT randCanonical() AS rand_val FROM numbers(5000)) GROUP BY rand_val);
SELECT id, random_value FROM (SELECT id, randCanonical() AS random_value FROM test_table) WHERE random_value BETWEEN 0.25 AND 0.75;