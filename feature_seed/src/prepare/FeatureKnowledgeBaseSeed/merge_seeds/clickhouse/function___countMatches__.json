CREATE TABLE test_strings (haystack String, pattern String);
INSERT INTO test_strings VALUES ('foobar.com', 'o+'), ('aaaa', 'aa'), ('abcdef', 'd+'), ('', 'a+'), ('abc', 'abc'), ('test123', '[0-9]+'), ('whitespace test', '\s+');
SELECT countMatches(haystack, pattern) FROM test_strings;
SELECT countMatches(haystack, 'o+') AS count_o, countMatches(haystack, 'a+') AS count_a FROM test_strings;
SELECT haystack, countMatches(haystack, 'a+') FROM test_strings WHERE haystack != '';
SELECT countMatches(haystack, pattern) FROM (SELECT 'foo bar baz' AS haystack, 'o+' AS pattern);
SELECT countMatches(haystack, '^[a-z]+$') FROM (SELECT 'test', 'example', '123' AS haystack) AS subquery;
CREATE TABLE search_patterns (pattern String);
INSERT INTO search_patterns VALUES ('o+'), ('a+'), ('[0-9]+');
SELECT haystack, countMatches(haystack, sp.pattern) FROM test_strings JOIN search_patterns AS sp ON 1=1;
SELECT haystack, countMatches(replaceOne(haystack, ' ', ''), pattern) FROM test_strings WHERE haystack IS NOT NULL;
SELECT countMatches(NULL, 'a+') AS count_null;
SELECT haystack, countMatches(haystack, '^[a-zA-Z]+$') AS alpha_count FROM (SELECT 'OnlyLetters' AS haystack UNION ALL SELECT '1234' UNION ALL SELECT '' UNION ALL SELECT 'Letters123') AS subquery;