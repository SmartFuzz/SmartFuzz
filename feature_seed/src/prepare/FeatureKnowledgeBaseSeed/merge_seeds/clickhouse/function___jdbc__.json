CREATE TABLE sample_table (id Int32, value String);
INSERT INTO sample_table VALUES (1, 'data1'), (2, 'data2'), (3, 'data3');
SELECT * FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select id, value from sample_table');
CREATE TABLE remote_table (num Int32, desc String);
INSERT INTO remote_table VALUES (100, 'description1'), (200, 'description2');
SELECT a.id, a.value, b.num FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select id, value from sample_table') a JOIN jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'remote_schema', 'select num from remote_table') b ON a.id = b.num;
SELECT * FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select value, LENGTH(value) as value_length from sample_table WHERE LENGTH(value) > 4');
SELECT a.id, a.value, b.desc FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select id, value from sample_table') a LEFT JOIN jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'remote_schema', 'select num, desc from remote_table') b ON a.id = b.num WHERE b.num IS NOT NULL;
SELECT DISTINCT value FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select value from sample_table WHERE id IN (SELECT id FROM sample_table WHERE value LIKE ''data%'')') ORDER BY value;
SELECT COUNT(*) FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select id from sample_table') WHERE id BETWEEN 1 AND 3;
SELECT * FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'other_schema', 'show databases');
CREATE TABLE merge_table (key Int32, val String);
INSERT INTO merge_table VALUES (1, 'one'), (2, 'two');
SELECT a.key, a.val, b.value FROM jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'other_schema', 'select key, val from merge_table') a FULL OUTER JOIN jdbc('jdbc:mysql://localhost:3306/?user=root&password=root', 'sample_schema', 'select id, value from sample_table') b ON a.key = b.id;