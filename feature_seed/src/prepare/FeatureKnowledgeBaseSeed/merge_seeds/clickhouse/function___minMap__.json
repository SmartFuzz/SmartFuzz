CREATE TABLE test_minMap (a Array(Int32), b Array(Int64));
INSERT INTO test_minMap VALUES ([1, 2, 3], [5, 5, 5]), ([2, 3, 4], [3, 3, 3]), ([1, 2, 1], [4, 2, 1]);
SELECT minMap(a, b) FROM test_minMap;
SELECT minMap(a, b) FROM (SELECT a, b FROM test_minMap WHERE arrayJoin(a) > 1);
SELECT minMap(a, b) FROM (SELECT a, b FROM test_minMap WHERE arrayJoin(b) < 5) GROUP BY a;
CREATE TABLE test_minMap_join (c Array(Int32), d Array(Int64));
INSERT INTO test_minMap_join VALUES ([3, 4, 5], [6, 6, 6]), ([5, 6, 7], [7, 7, 7]);
SELECT minMap(t1.a, t1.b) FROM test_minMap AS t1 JOIN test_minMap_join AS t2 ON arrayJoin(t1.a) = arrayJoin(t2.c;
SELECT minMap(tuple(a, b), tuple(c, d)) FROM (SELECT a, b FROM test_minMap) AS t1 JOIN (SELECT c, d FROM test_minMap_join) AS t2;
SELECT minMap(a, b) FROM (SELECT ARRAY [NULL, 5] AS a, ARRAY [10, 15] AS b) AS temp;
SELECT minMap(a, b) FROM test_minMap WHERE length(a) > 0 AND length(b) > 0;