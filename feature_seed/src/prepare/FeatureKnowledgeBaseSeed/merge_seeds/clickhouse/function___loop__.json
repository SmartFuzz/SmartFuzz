CREATE DATABASE IF NOT EXISTS test_database;
CREATE TABLE IF NOT EXISTS test_database.test_table (id UInt32, value String);
INSERT INTO test_database.test_table VALUES (1, 'a'), (2, 'b'), (3, 'c');
SELECT * FROM loop(test_database, test_table);
SELECT * FROM loop(test_database.test_table) LIMIT 5;
SELECT * FROM loop(test_table) WHERE id > 1;
SELECT id, value FROM loop(test_database.test_table) WHERE id < 3;
SELECT * FROM loop(test_database.test_table) UNION SELECT * FROM loop(test_database.test_table);
SELECT * FROM loop(numbers(5)) AS a JOIN loop(numbers(3)) AS b ON a.number = b.number;
SELECT COUNT(*) FROM loop(test_database, test_table) GROUP BY value;
SELECT * FROM loop(numbers(10)) WHERE number % 2 = 0 LIMIT 5;
SELECT * FROM loop(test_database.test_table) WHERE id IN (SELECT id FROM test_database.test_table WHERE id < 3);
SELECT sum(number) FROM loop(numbers(100));
CREATE TABLE IF NOT EXISTS another_table (col1 UInt32, col2 String);
INSERT INTO another_table VALUES (10, 'x'), (20, 'y');
SELECT * FROM loop(another_table) JOIN loop(test_database.test_table) ON another_table.col1 = test_database.test_table.id;