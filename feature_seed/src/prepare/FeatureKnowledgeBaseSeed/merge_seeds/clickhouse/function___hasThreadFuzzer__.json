CREATE TABLE test_thread_fuzzer (id UInt32, value String);
INSERT INTO test_thread_fuzzer VALUES (1, 'test1'), (2, 'test2'), (3, 'test3');
SELECT count() FROM test_thread_fuzzer WHERE length(value) > 3;
CREATE TABLE test_fuzzer_backup AS test_thread_fuzzer ENGINE = MergeTree() ORDER BY id;
CREATE DIMENSION last_insert AS (SELECT max(id) FROM test_thread_fuzzer);
SELECT hasThreadFuzzer();
SELECT hasThreadFuzzer() AND EXISTS (SELECT 1 FROM test_thread_fuzzer WHERE value LIKE 'test%');
SELECT hasThreadFuzzer() FROM (SELECT count(*) AS total FROM test_thread_fuzzer) t;
WITH (SELECT min(id) AS min_id FROM test_thread_fuzzer) AS subquery SELECT hasThreadFuzzer() WHERE min_id IS NOT NULL;
CREATE TABLE extended_test_thread_fuzzer (id UInt32, value String, created_at DateTime DEFAULT now()) ENGINE = MergeTree() ORDER BY id;
INSERT INTO extended_test_thread_fuzzer VALUES (1, 'data1', now()), (2, 'data2', now()), (3, 'data3', now());
SELECT hasThreadFuzzer(), (SELECT count() FROM extended_test_thread_fuzzer) AS total_rows;
WITH (SELECT value FROM test_thread_fuzzer WHERE id = 1) AS test_value SELECT hasThreadFuzzer() AND test_value = 'test1';
SELECT hasThreadFuzzer() WHERE (SELECT count() FROM test_thread_fuzzer) > 0;
CREATE TABLE fuzzer_test_results (result String) ENGINE = Memory;
INSERT INTO fuzzer_test_results SELECT toString(hasThreadFuzzer()) FROM extended_test_thread_fuzzer WHERE created_at > now() - interval 1 day;