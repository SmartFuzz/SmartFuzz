CREATE TABLE IF NOT EXISTS test_table (id Int32, value Int32);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 30);
SELECT id, value, if(value > 15, 'High', 'Low') AS category FROM test_table;
CREATE TABLE IF NOT EXISTS nested_table (id Int32, test_id Int32, detail String);
INSERT INTO nested_table VALUES (1, 1, 'Detail 1'), (2, 1, 'Detail 2'), (3, 2, 'Detail 3');
SELECT nt.id, nt.detail, if(tt.value IS NULL, 'No Value', 'Has Value') AS value_status FROM nested_table nt LEFT JOIN test_table tt ON nt.test_id = tt.id;
CREATE TABLE IF NOT EXISTS join_table (id Int32, reference_id Int32, description String);
INSERT INTO join_table VALUES (1, 1, 'Join 1'), (2, 2, 'Join 2'), (3, NULL, 'Join 3');
SELECT jt.id, jt.description, if(jt.reference_id IS NOT NULL, 'Linked', 'Unlinked') AS link_status FROM join_table jt;
SELECT id, value, if(value < 10, 'Too Low', if(value <= 20, 'Acceptable', 'Too High')) AS evaluation FROM test_table;
SELECT nt.id, nt.detail, if(tt.value > 25, 'Above Threshold', if(tt.value IS NOT NULL, 'Within Range', 'Value Missing')) AS report FROM nested_table nt INNER JOIN test_table tt ON nt.test_id = tt.id;
SELECT id, if(value = 30, (SELECT COUNT(*) FROM nested_table), 0) AS detail_count FROM test_table;