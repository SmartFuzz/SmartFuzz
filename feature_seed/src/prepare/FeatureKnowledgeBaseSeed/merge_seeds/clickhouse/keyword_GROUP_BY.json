CREATE TABLE t_null_big (x Int32, y Nullable(Int32)) ENGINE = MergeTree() ORDER BY y;
INSERT INTO t_null_big VALUES (1, NULL), (2, NULL), (3, 1), (4, 1);
SELECT sum(x), y FROM t_null_big GROUP BY y;
SELECT sum(x) as total, y FROM t_null_big GROUP BY y WITH TOTALS;
SELECT sum(x), y FROM t_null_big GROUP BY y WITH ROLLUP;
SELECT sum(x), y FROM t_null_big GROUP BY y WITH CUBE;
SELECT y, count(*) FROM t_null_big GROUP BY y HAVING count(*) > 1;
SELECT y, sum(x) FROM (SELECT x, y FROM t_null_big) GROUP BY y;
SELECT sum(x) FROM t_null_big GROUP BY ALL;
SELECT sum(x), y FROM t_null_big GROUP BY y HAVING sum(x) > 1;
SELECT sum(x) FROM t_null_big GROUP BY y WITH TOTALS HAVING sum(x) > 1;
SELECT y, any(x) FROM t_null_big GROUP BY y;
SELECT y, max(x) FROM t_null_big GROUP BY y WITH ROLLUP;
SELECT y, sum(x), avg(x) FROM t_null_big GROUP BY y ORDER BY y DESC;
CREATE TABLE t (a Int32, b String) ENGINE = MergeTree() ORDER BY a;
INSERT INTO t VALUES (1, 'foo'), (1, 'bar'), (2, 'foo'), (3, 'baz');
SELECT a, count(b) FROM t GROUP BY a;
SELECT a, any(b) FROM t GROUP BY a HAVING count(b) > 1;
SELECT a, sum(x) as total FROM (SELECT x, a FROM t_null_big) GROUP BY a WITH ROLLUP;
SELECT a, sum(x) FROM t JOIN t_null_big ON t.a = t_null_big.y GROUP BY a;
SELECT y, sum(x) FROM t_null_big GROUP BY GROUPING SETS ((y), ());
CREATE TABLE source (x Int32, y Nullable(Int32)) ENGINE = MergeTree() ORDER BY (x);
INSERT INTO source VALUES (1, 1), (2, NULL), (1, 1), (3, NULL);
SELECT y, count(*) FROM source GROUP BY y WITH TOTALS;
SELECT y, count(*) FROM source GROUP BY y WITH CUBE;
SELECT y, count(*) FROM (SELECT * FROM source WHERE y IS NOT NULL) GROUP BY y;