CREATE TABLE h3_edges (index UInt64);
INSERT INTO h3_edges VALUES (1248204388774707199);
SELECT h3UnidirectionalEdgeIsValid(index) as validOrNot FROM h3_edges;
CREATE TABLE h3_test_cases (index UInt64, expected UInt8);
INSERT INTO h3_test_cases VALUES (1248204388774707199, 1), (1248204388774707198, 0);
SELECT index, expected, h3UnidirectionalEdgeIsValid(index) as actual FROM h3_test_cases;
WITH (SELECT index FROM h3_edges LIMIT 1) AS edge_index SELECT h3UnidirectionalEdgeIsValid(edge_index) as validOrNot;
CREATE TABLE edge_results AS SELECT index, h3UnidirectionalEdgeIsValid(index) as validStatus FROM h3_edges;
SELECT COUNT(*) FROM edge_results WHERE validStatus = 1;
WITH (SELECT index FROM h3_test_cases) AS valid_indices SELECT h3UnidirectionalEdgeIsValid(index) FROM valid_indices;
SELECT index, IF(h3UnidirectionalEdgeIsValid(index), 'Valid', 'Invalid') AS validity FROM (SELECT index FROM h3_edges) AS subquery;
SELECT index FROM h3_edges JOIN h3_test_cases ON h3_edges.index = h3_test_cases.index WHERE h3UnidirectionalEdgeIsValid(h3_edges.index) != h3_test_cases.expected;