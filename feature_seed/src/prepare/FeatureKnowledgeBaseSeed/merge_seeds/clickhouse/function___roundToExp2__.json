CREATE TABLE numbers_example (number UInt32);
INSERT INTO numbers_example VALUES (0), (0.5), (1), (2), (3.5), (8), (16), (31), (64);
SELECT number, roundToExp2(number) FROM numbers_example;
SELECT *, roundToExp2(number) AS rounded_value FROM numbers_example WHERE number > 5;
WITH (SELECT AVG(number) FROM numbers_example) AS avg_value SELECT roundToExp2(avg_value);
SELECT n.number, r.rounded_value FROM numbers_example AS n JOIN (SELECT number, roundToExp2(number) AS rounded_value FROM numbers_example) AS r ON n.number = r.number WHERE r.rounded_value < 8;
SELECT number, roundToExp2(roundToExp2(number)) AS double_rounded FROM numbers_example;
CREATE TABLE complex_example AS SELECT number, roundToExp2(number) AS rounded_value FROM numbers_example;
SELECT COUNT(*) FROM complex_example WHERE rounded_value = 4;
SELECT DISTINCT rounded_value FROM (SELECT roundToExp2(number) AS rounded_value FROM numbers_example) AS rounded_numbers WHERE rounded_value > 0;