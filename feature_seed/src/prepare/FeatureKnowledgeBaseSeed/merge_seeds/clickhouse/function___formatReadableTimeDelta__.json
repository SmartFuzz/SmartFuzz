CREATE TABLE time_deltas (delta UInt64);
INSERT INTO time_deltas VALUES (1), (100), (60000), (3600000), (86400000), (31536000000);
SELECT delta, formatReadableTimeDelta(delta) AS time_delta FROM time_deltas;
SELECT arrayJoin([1000, 60000, 3610000]) AS elapsed, formatReadableTimeDelta(elapsed, 'seconds') AS time_delta FROM time_deltas;
SELECT arrayJoin([1000, 60000, 3610000]) AS elapsed, formatReadableTimeDelta(elapsed, 'minutes', 'milliseconds') AS time_delta WHERE elapsed > 50000;
SELECT arrayJoin([100, 12345, 432546534]) AS elapsed, formatReadableTimeDelta(elapsed, 'days') AS time_delta FROM time_deltas GROUP BY time_delta;
SELECT t1.delta, formatReadableTimeDelta(t1.delta, 'milliseconds', 'microseconds') AS time_delta FROM (SELECT delta FROM time_deltas) AS t1 WHERE t1.delta < 2000000;
WITH (SELECT SUM(delta) FROM time_deltas) AS total_delta SELECT total_delta, formatReadableTimeDelta(total_delta) AS readable_total FROM time_deltas;
CREATE TABLE time_range (start DeltaTime, end DeltaTime);
INSERT INTO time_range VALUES (toStartOfSecond(now()), toStartOfSecond(now()) + 1000);
SELECT start, end, formatReadableTimeDelta(toUnixTimestamp(end - start), 'seconds', 'milliseconds') AS time_interval FROM time_range;
SELECT arrayJoin([0, 1001, 60000, 7200000, 31536000000]) AS elapsed, formatReadableTimeDelta(elapsed, 'years', 'nanoseconds') AS time_delta FROM (SELECT delta FROM time_deltas) ORDER BY elapsed DESC;