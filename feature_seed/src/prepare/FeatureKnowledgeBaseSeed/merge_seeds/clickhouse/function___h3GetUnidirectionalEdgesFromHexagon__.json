CREATE TABLE edges_test (hexagon_index UInt64);
INSERT INTO edges_test VALUES (1248204388774707199);
SELECT h3GetUnidirectionalEdgesFromHexagon(hexagon_index) AS edges FROM edges_test;
CREATE TABLE hexagon_data (index UInt64);
INSERT INTO hexagon_data VALUES (0), (1248204388774707199), (18446744073709551615);
SELECT h3GetUnidirectionalEdgesFromHexagon(index) AS edges FROM hexagon_data;
SELECT index, h3GetUnidirectionalEdgesFromHexagon(index) AS edges FROM hexagon_data WHERE index > 0;
CREATE TABLE unidirectional_edges AS SELECT h3GetUnidirectionalEdgesFromHexagon(1248204388774707199) AS edges;
SELECT * FROM unidirectional_edges;
WITH (SELECT hexagon_index FROM edges_test WHERE hexagon_index = 1248204388774707199) AS selected_hexagon SELECT h3GetUnidirectionalEdgesFromHexagon(selected_hexagon) AS edges;
CREATE TABLE additional_data (index UInt64, value String);
INSERT INTO additional_data VALUES (1248204388774707199, 'test1'), (1, 'test2');
SELECT ad.value, h3GetUnidirectionalEdgesFromHexagon(ad.index) AS edges FROM additional_data ad WHERE ad.index IN (SELECT index FROM edges_test);
SELECT hexagon_index, h3GetUnidirectionalEdgesFromHexagon(hexagon_index) AS edges FROM edges_test WHERE hexagon_index IN (SELECT index FROM additional_data WHERE value = 'test1');