CREATE TABLE datetime_tests (id Int32, datetime_str String);
INSERT INTO datetime_tests VALUES (1, '2022-10-11T12:34:56.789Z'), (2, 'invalid-datetime'), (3, '2023-01-01T00:00:00.000Z');
CREATE TABLE processed_dates AS SELECT id, parseDateTime64InJodaSyntaxOrZero(datetime_str, 3) AS parsed_date FROM datetime_tests;
SELECT id, parsed_date FROM processed_dates WHERE parsed_date != toDateTime64('1970-01-01 00:00:00', 3);
CREATE TABLE more_complex AS SELECT a.id, b.parsed_date FROM datetime_tests a JOIN (SELECT id, parseDateTime64InJodaSyntaxOrZero(datetime_str, 3) AS parsed_date FROM datetime_tests) b ON a.id = b.id;
SELECT * FROM more_complex WHERE parsed_date = toDateTime64('1970-01-01 00:00:00', 3 OR parsed_date IS NOT NULL;
SELECT count(*) FROM more_complex WHERE parsed_date = toDateTime64('1970-01-01 00:00:00', 3);
SELECT id, parsed_date FROM more_complex WHERE parsed_date IS NULL OR parsed_date = toDateTime64('1970-01-01 00:00:00', 3);
INSERT INTO datetime_tests VALUES (4, '2023-12-31T23:59:59.999Z');
CREATE TABLE final_results AS SELECT id, datetime_str, parseDateTime64InJodaSyntaxOrZero(datetime_str, 3) AS result FROM datetime_tests;