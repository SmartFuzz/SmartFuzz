CREATE TABLE test_tuples (`id` Int32, `data` Tuple(String, UInt8)) ENGINE = Memory;
INSERT INTO test_tuples VALUES (1, ('apple', 10)), (2, ('banana', 20));
SELECT id, data.1 AS fruit, data.2 AS quantity FROM test_tuples;
SELECT id, (data.2 * 2) AS double_quantity FROM test_tuples WHERE data.1 = 'banana';
SELECT tuple(1, 2, 3, (4, 5)) AS my_tuple;
SELECT (1, 'a', 3.14) > (0, 'b', 2);
SELECT (data.1, data.2) FROM test_tuples WHERE data = ('banana', 20);
CREATE TABLE named_test (`info` Tuple(name String, age UInt32)) ENGINE = Memory;
INSERT INTO named_test VALUES (('John Doe', 30)), (('Jane Doe', 25));
SELECT info.1 AS name FROM named_test WHERE info.2 < 30;
SELECT tupleElement(info, 1) AS name, age FROM (SELECT info, info.2 AS age FROM named_test);
CREATE TABLE complex_data (`key` Int64, `values` Array(Tuple(name String, score Float64)) ENGINE = Memory;
INSERT INTO complex_data VALUES (1, [('Alice', 9.5), ('Bob', 8.7)]), (2, [('Charlie', 7.5), ('Dave', 9.2)]);
SELECT key, arrayJoin(values) AS value_data FROM complex_data WHERE key = 1;
CREATE TABLE main_data (`id` UInt32, `details` Tuple(name String, age Int8, score Float64)) ENGINE = Memory;
INSERT INTO main_data VALUES (1, ('Alice', 30, 90.5)), (2, ('Bob', 25, 85.0));
SELECT details.1 AS name, details.2 AS age, details.3 AS score FROM main_data WHERE details.3 > 80.0;
SELECT id, details FROM main_data WHERE details.2 = (SELECT max(details.2) FROM main_data);
SELECT details FROM main_data WHERE details = ('Alice', 30, 90.5);
CREATE TABLE secondary_data (`group_id` Int32, `info` Tuple(group_name String, member_count Int32)) ENGINE = Memory;
INSERT INTO secondary_data VALUES (1, ('Group A', 5)), (2, ('Group B', 10));
SELECT info.1 FROM secondary_data WHERE group_id IN (SELECT group_id FROM secondary_data WHERE info.2 > 5);
SELECT (SELECT count(*) FROM secondary_data) AS group_total, (SELECT count(*) FROM main_data) AS member_total;