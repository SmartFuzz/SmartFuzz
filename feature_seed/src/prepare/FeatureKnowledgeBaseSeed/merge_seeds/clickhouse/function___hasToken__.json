CREATE TABLE test_table (haystack String);
INSERT INTO test_table VALUES ('Hello World'), ('ClickHouse is great'), ('Token not found here');
SELECT hasToken(haystack, 'Hello') FROM test_table;
SELECT hasToken(haystack, 'ClickHouse') FROM test_table WHERE haystack = 'ClickHouse is great';
SELECT hasToken(haystack, 'Token') AS token_found FROM (SELECT haystack FROM test_table WHERE haystack LIKE '%found%') AS subquery;
SELECT hasToken(haystack, 'not') + hasToken(haystack, 'here') AS result FROM test_table;
SELECT haystack, hasToken(haystack, 'World') AS is_present FROM (SELECT haystack FROM test_table) AS subquery;
SELECT if(hasToken(haystack, 'great'), 'Exists', 'Does not exist') AS token_status FROM test_table;
CREATE TABLE test_table2 (haystack String) ENGINE = MergeTree() ORDER BY haystack;
INSERT INTO test_table2 SELECT haystack FROM test_table;
SELECT hasToken(t1.haystack, 'not') FROM test_table2 t1 INNER JOIN test_table t2 ON t1.haystack = t2.haystack;
SELECT hasToken(haystack, 'ClickHouse') + hasToken(haystack, 'Hello') FROM test_table WHERE haystack IN (SELECT haystack FROM test_table WHERE haystack LIKE '%Token%');
SELECT hasToken('Token@123', 'Token') AS token_check;