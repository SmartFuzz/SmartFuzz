CREATE TABLE test_table (id UInt32, random_value Float64) ENGINE = Memory;
INSERT INTO test_table SELECT number, randLogNormal(0, 1) FROM numbers(10);
SELECT * FROM test_table WHERE random_value > 10.0;
SELECT id, randLogNormal(100, 5) AS log_value FROM test_table WHERE id < 5;
SELECT id, randLogNormal(50, 2) FROM test_table WHERE random_value < 1.0 ORDER BY id DESC;
CREATE TABLE test_table2 (val Float64) ENGINE = Memory;
INSERT INTO test_table2 SELECT randLogNormal(0, 0.1) FROM numbers(20);
SELECT AVG(randLogNormal(0, 0.5)) AS avg_random_value FROM test_table2;
SELECT (SELECT COUNT(*) FROM test_table WHERE random_value > 50) AS high_values_count, randLogNormal(30, 10);
SELECT id, (SELECT randLogNormal(1, 4)) FROM test_table LIMIT 3;
CREATE TABLE combined_test (a UInt32, b Float64) ENGINE = Memory;
INSERT INTO combined_test SELECT id, randLogNormal(200, 25) FROM test_table;
SELECT ct.a, ct.b, (SELECT randLogNormal(2, 1) FROM combined_test WHERE a = ct.a) AS sub_val FROM combined_test AS ct;
SELECT id, (SELECT AVG(b) FROM combined_test WHERE b > 0) AS avg_b FROM combined_test ORDER BY id;