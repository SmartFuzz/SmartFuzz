CREATE TABLE test_dates (input String, expected DateTime);
INSERT INTO test_dates VALUES ('2023-10-01 12:00:00', parseDateTimeBestEffortUSOrZero('2023-10-01 12:00:00'));
INSERT INTO test_dates VALUES ('invalid date', parseDateTimeBestEffortUSOrZero('invalid date'));
INSERT INTO test_dates VALUES ('10/01/2023 12:00:00 AM', parseDateTimeBestEffortUSOrZero('10/01/2023 12:00:00 AM'));
INSERT INTO test_dates VALUES ('01/01/1970', parseDateTimeBestEffortUSOrZero('01/01/1970'));
INSERT INTO test_dates VALUES ('01/01/2023 00:00!', parseDateTimeBestEffortUSOrZero('01/01/2023 00:00!'));
INSERT INTO test_dates VALUES ('2023-10-01', parseDateTimeBestEffortUSOrZero('2023-10-01'));
INSERT INTO test_dates VALUES ('12/31/9999', parseDateTimeBestEffortUSOrZero('12/31/9999'));
SELECT input, expected FROM test_dates WHERE expected = parseDateTimeBestEffortUSOrZero(input);
SELECT input FROM test_dates WHERE expected = '1970-01-01 00:00:00' AND expected != parseDateTimeBestEffortUSOrZero(input);
CREATE TABLE results AS SELECT input, expected FROM test_dates WHERE expected = '1970-01-01 00:00:00';
SELECT COUNT(*) FROM results;
CREATE TABLE valid_dates AS SELECT input FROM test_dates WHERE expected != '1970-01-01 00:00:00';
SELECT COUNT(*) FROM valid_dates;
SELECT a.input, b.expected FROM test_dates AS a JOIN valid_dates AS b ON a.input = b.input;