CREATE TABLE test_strings (s String);
INSERT INTO test_strings VALUES ('Hello World');
INSERT INTO test_strings VALUES ('ClickHouse Database');
INSERT INTO test_strings VALUES ('Testing ngramSimHash');
INSERT INTO test_strings VALUES ('Fuzz Testing ClickHouse');
SELECT ngramSimHash(s, 2) AS Hash FROM test_strings;
SELECT ngramSimHash(s, 3) AS Hash FROM test_strings WHERE s LIKE '%Click%';
SELECT ngramSimHash(s, 4) AS Hash, COUNT(*) FROM test_strings GROUP BY Hash;
SELECT t1.s, ngramSimHash(t1.s, 5) AS Hash FROM test_strings t1 JOIN test_strings t2 ON ngramSimHash(t1.s) = ngramSimHash(t2.s) WHERE t1.s != t2.s;
SELECT ngramSimHash('abcd', 1) AS Hash UNION ALL SELECT ngramSimHash('xyz', 1) AS Hash;
CREATE TABLE duplicate_test (str String, ngram_hash UInt64);
INSERT INTO duplicate_test (str, ngram_hash) SELECT s, ngramSimHash(s) FROM test_strings;
SELECT str FROM duplicate_test WHERE ngram_hash = ngramSimHash('Hello World');
SELECT ngramSimHash('Test string with special characters #$%&*', 3) AS Hash;
INSERT INTO test_strings VALUES ('Another Example?');
SELECT ngramSimHash(s, 7) AS Hash FROM test_strings ORDER BY Hash DESC;