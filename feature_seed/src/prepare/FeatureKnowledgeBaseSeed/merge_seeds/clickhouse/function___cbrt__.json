CREATE TABLE test_cbrt (id Int32, value Float32);
INSERT INTO test_cbrt VALUES (1, 0), (2, 1), (3, 8), (4, 27), (5, -1), (6, 64);
SELECT id, cbrt(value) AS cubic_root FROM test_cbrt;
CREATE TABLE table_a (value Float32);
INSERT INTO table_a VALUES (1.0), (8.0), (-1.0), (27.0);
CREATE TABLE table_b (value Float32);
INSERT INTO table_b VALUES (1.0), (0.0), (64.0);
SELECT a.value, cbrt(a.value) AS cbrt_a, b.value, cbrt(b.value) AS cbrt_b FROM table_a AS a JOIN table_b AS b ON a.value > b.value;
WITH (SELECT cbrt(value) FROM test_cbrt WHERE value IS NOT NULL) AS cubic_roots SELECT AVG(cubic_roots) AS average_cubic_root FROM cubic_roots;
CREATE TABLE multi_table_test (id Int32, value Float32);
INSERT INTO multi_table_test VALUES (1, 1.0), (2, 8.0), (3, -8.0), (4, 27.0);
SELECT m.id, m.value, c.cbrt AS cubic_root FROM multi_table_test AS m, (SELECT cbrt(value) AS cbrt FROM test_cbrt) AS c WHERE m.value = 8.0 OR m.value = -8.0;
CREATE TABLE boundaries_test (value Float64);
INSERT INTO boundaries_test VALUES (0.0), (1.0), (2.0), (3.0), (Float64)NULL, (Float64)INFINITY, (Float64)-INFINITY;
SELECT cbrt(value) AS cubic_root FROM boundaries_test;
SELECT id, value, cbrt(value) FROM test_cbrt WHERE value IN (SELECT value FROM table_a WHERE value < 10);