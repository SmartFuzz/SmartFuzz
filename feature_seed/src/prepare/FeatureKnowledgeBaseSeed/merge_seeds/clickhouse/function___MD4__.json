CREATE TABLE test_md4 (id Int32, data String);
INSERT INTO test_md4 VALUES (1, 'test string'), (2, 'another test'), (3, 'hash me'), (4, 'boundary testing');
SELECT id, MD4(data) AS md4_hash FROM test_md4;
WITH data AS (SELECT data FROM test_md4 WHERE id = 1) SELECT MD4(data) FROM data;
SELECT t.id, MD4(t.data) AS md4_hash FROM test_md4 t WHERE LENGTH(t.data) <= 100;
CREATE TABLE test_md4_subquery AS SELECT id, MD4(data) AS md4_hash FROM test_md4;
SELECT a.id, b.md4_hash FROM test_md4 a JOIN (SELECT id, MD4(data) AS md4_hash FROM test_md4) b ON a.id = b.id;
SELECT id, MD4(data), LENGTH(MD4(data)) AS md4_length FROM test_md4 WHERE LENGTH(data) > 5;
SELECT id, MD4(data) FROM (SELECT data FROM test_md4 WHERE id = 2 UNION SELECT 'combined test') AS combined_data;
SELECT MD4(data) FROM test_md4 WHERE data IN (SELECT data FROM test_md4 WHERE id > 1);
SELECT MD4(CONCAT(data, ID)) AS complex_md4_hash FROM test_md4;
SELECT MD4(CAST(data AS FixedString(32))) AS fixed_size_md4_hash FROM test_md4;
CREATE TABLE test_md4_join AS SELECT a.id AS id1, b.id AS id2, MD4(CONCAT(a.data, b.data)) AS md4_combined FROM test_md4 a JOIN test_md4 b ON a.id != b.id;
SELECT md4_combined FROM test_md4_join WHERE id1 < 3 AND id2 > 1;