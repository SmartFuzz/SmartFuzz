CREATE TABLE test_dates (date_field Date, date_time_field DateTime, date_string_field String);
INSERT INTO test_dates VALUES (toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
SELECT subtractQuarters(date_field, 1) AS date_subtracted FROM test_dates;
SELECT subtractQuarters(date_time_field, 1) AS date_time_subtracted FROM test_dates;
SELECT subtractQuarters(date_string_field, 1) AS date_string_subtracted FROM test_dates;
WITH (SELECT date_field FROM test_dates) AS selected_dates SELECT subtractQuarters(selected_dates, 2) AS date_subtracted_with_subquery;
WITH (SELECT date_time_field FROM test_dates WHERE date_time_field < toDateTime('2025-01-01')) AS filtered_dates SELECT subtractQuarters(filtered_dates, 3) AS filtered_date_subtracted;
SELECT date_field, subtractQuarters(date_field, num) AS date_with_variable_quarters FROM test_dates CROSS JOIN (SELECT [1, 2, 3] AS num);
SELECT subtractQuarters(toDate('2023-12-31'), 1) AS end_of_year_subtraction;
SELECT subtractQuarters(toDateTime('2024-03-31 12:00:00'), 4) AS end_of_march_subtraction;
SELECT subtractQuarters(toDateTime('2024-01-31 00:00:00'), -1) AS adding_quarters;