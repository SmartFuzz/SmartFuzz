CREATE TABLE uuid_table (id UUID, variant Int32);
INSERT INTO uuid_table VALUES (toUUID('612f3c40-5d3b-217e-707b-6a546a3d7b29'), 1);
INSERT INTO uuid_table VALUES (toUUID('123e4567-e89b-12d3-a456-426614174000'), 2);
SELECT id, UUIDToNum(id) AS bytes FROM uuid_table;
SELECT id, UUIDToNum(id, variant) AS bytes FROM uuid_table WHERE variant = 1;
SELECT id, UUIDToNum(id, 2) AS bytes FROM uuid_table WHERE variant = 2;
CREATE TABLE uuid_nested AS SELECT id, UUIDToNum(id) AS bytes FROM (SELECT toUUID('612f3c40-5d3b-217e-707b-6a546a3d7b29') AS id) tmp;
SELECT id, bytes FROM (SELECT id, UUIDToNum(id) AS bytes FROM uuid_table) AS subquery WHERE bytes IS NOT NULL;
SELECT a.id, a.bytes, b.bytes FROM (SELECT id, UUIDToNum(id) AS bytes FROM uuid_table WHERE variant = 1) AS a JOIN (SELECT id, UUIDToNum(id, 2) AS bytes FROM uuid_table WHERE variant = 2) AS b ON a.id = b.id;
SELECT id, UUIDToNum(toUUID('ffffffff-ffff-ffff-ffff-ffffffffffff'), 1) AS bytes FROM uuid_table;
SELECT COUNT(*) FROM uuid_table WHERE UUIDToNum(id) IS NOT NULL;