CREATE TABLE test_table (id UInt32, value UInt32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50), (6, 60);
SELECT approx_top_count(value, 3) FROM test_table;
SELECT approx_top_count(value, 2) FROM (SELECT value FROM test_table WHERE id < 5);
CREATE TABLE nested_table (id UInt32, group_id UInt32, value UInt32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO nested_table VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30), (4, 2, 30), (5, 3, 40), (6, 3, 50);
SELECT group_id, approx_top_count(value, 2) FROM nested_table GROUP BY group_id;
SELECT group_id, approx_top_count(value, 1) FROM (SELECT group_id, value FROM nested_table WHERE value > 15) GROUP BY group_id;
CREATE TABLE join_table_1 (id UInt32, value UInt32) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE join_table_2 (id UInt32, join_id UInt32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO join_table_1 VALUES (1, 10), (2, 20), (3, 20), (4, 30);
INSERT INTO join_table_2 VALUES (1, 1), (2, 1), (3, 2), (4, 3);
SELECT jt.join_id, approx_top_count(jt1.value, 2) FROM join_table_2 jt JOIN join_table_1 jt1 ON jt.id = jt1.id GROUP BY jt.join_id;
SELECT approx_top_count(value, 5) FROM (SELECT value FROM test_table) AS subquery;
SELECT id, approx_top_count(value, 2) FROM test_table GROUP BY id ORDER BY approx_top_count(value, 2);