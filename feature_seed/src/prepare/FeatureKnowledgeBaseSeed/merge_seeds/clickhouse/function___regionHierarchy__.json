CREATE TABLE geobase (id UInt32, parent_id UInt32);
INSERT INTO geobase VALUES (1, NULL), (2, 1), (3, 1), (4, 2), (5, 3);
SELECT regionHierarchy(1) AS arr FROM geobase;
SELECT regionHierarchy(2) AS arr FROM geobase;
SELECT regionHierarchy(5) AS arr FROM geobase;
SELECT regionHierarchy(3) AS arr, arrayMap(id -> regionToName(id, 'en'), arr) FROM geobase;
SELECT arr FROM (SELECT regionHierarchy(number::UInt32) AS arr FROM numbers(5));
WITH (SELECT id FROM geobase WHERE id IN (1, 2, 3)) AS valid_ids SELECT regionHierarchy(id) AS arr FROM valid_ids;
SELECT regionHierarchy(0) AS arr FROM geobase WHERE id = 0;
SELECT regionHierarchy(id), arrayMap(id -> regionToName(id, 'en'), regionHierarchy(id)) FROM geobase GROUP BY id;
CREATE TABLE geobase2 AS geobase ENGINE = MergeTree() ORDER BY id;
INSERT INTO geobase2 SELECT * FROM geobase;
SELECT regionHierarchy(id) AS arr FROM geobase2 WHERE arr[1] IN (SELECT parent_id FROM geobase WHERE id > 2);
SELECT arr FROM (SELECT regionHierarchy(id) AS arr FROM geobase2) WHERE arrayLength(arr) > 1;