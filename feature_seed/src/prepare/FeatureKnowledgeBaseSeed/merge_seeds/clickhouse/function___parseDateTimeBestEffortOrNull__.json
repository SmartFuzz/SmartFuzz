CREATE TABLE test_dates (raw_date STRING);
INSERT INTO test_dates VALUES ('2023-10-01 12:00:00');
INSERT INTO test_dates VALUES ('foo');
INSERT INTO test_dates VALUES ('2023-10-01');
INSERT INTO test_dates VALUES ('2023-10-01 25:00:00');
INSERT INTO test_dates VALUES (NULL);
SELECT raw_date, parseDateTimeBestEffortOrNull(raw_date) AS parsed_date FROM test_dates;
CREATE TABLE orders (id UInt32, date STRING);
INSERT INTO orders VALUES (1, '2023-01-01 08:00:00'), (2, 'invalid date'), (3, '2023-10-01 18:30:00');
SELECT id, parseDateTimeBestEffortOrNull(date) AS parsed_order_date FROM orders WHERE parsed_order_date IS NOT NULL;
CREATE TABLE temp_dates AS SELECT * FROM test_dates;
SELECT temp_dates.raw_date, parseDateTimeBestEffortOrNull(temp_dates.raw_date) AS parsed_temp_date FROM temp_dates WHERE parsed_temp_date IS NULL;
CREATE TABLE combined_data (event_id UInt32, event_time STRING, user_id UInt32);
INSERT INTO combined_data VALUES (1, '2023-11-01 14:30:00', 101), (2, '2023-11-01 15:45:00', 102), (3, 'invalid', 103);
SELECT c.event_id, parseDateTimeBestEffortOrNull(c.event_time) AS parsed_event_time, u.user_id FROM combined_data AS c JOIN orders AS o ON c.event_id = o.id JOIN (SELECT id, parseDateTimeBestEffortOrNull(date) AS valid_date FROM orders WHERE parseDateTimeBestEffortOrNull(date) IS NOT NULL) AS u ON c.user_id = u.id;
CREATE TABLE joined_dates (event STRING, event_time STRING);
INSERT INTO joined_dates VALUES ('start', '2023-11-20 08:00:00'), ('end', 'invalid-time');
SELECT j.event, parseDateTimeBestEffortOrNull(j.event_time) AS processed_event_time FROM joined_dates AS j;
CREATE TABLE testing_dates (input_date STRING);
INSERT INTO testing_dates VALUES ('2023-00-10'), ('2023-02-29 00:00:00'), ('abc'), ('2023-12-31 23:59:59'), ('2024-02-29 23:59:59');
SELECT input_date, parseDateTimeBestEffortOrNull(input_date) AS valid_date FROM testing_dates WHERE valid_date IS NOT NULL;