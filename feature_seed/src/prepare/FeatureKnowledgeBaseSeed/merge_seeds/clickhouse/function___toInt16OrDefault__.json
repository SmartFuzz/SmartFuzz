CREATE TABLE test_table (input_value String, default_value Int16) ENGINE = MergeTree() ORDER BY input_value;
INSERT INTO test_table VALUES ('-20', CAST('-1', 'Int16')), ('abc', CAST('-1', 'Int16')), ('32768', CAST('-1', 'Int16')), ('-32769', CAST('-1', 'Int16')), ('0xc0fe', CAST('-1', 'Int16')), ('NaN', CAST('-1', 'Int16')), ('Inf', CAST('-1', 'Int16'));
SELECT input_value, toInt16OrDefault(input_value, default_value) FROM test_table;
SELECT toInt16OrDefault((SELECT input_value FROM test_table WHERE input_value = 'abc' LIMIT 1), CAST('0', 'Int16')) AS result;
SELECT t1.input_value, t2.default_value, toInt16OrDefault(t1.input_value, t2.default_value) FROM test_table t1 JOIN test_table t2 ON t1.default_value = t2.default_value;
SELECT toInt16OrDefault(CASE WHEN input_value = 'abc' THEN '10' ELSE input_value END, CAST('0', 'Int16')) FROM test_table;
WITH (SELECT MAX(input_value) FROM test_table) AS max_value SELECT toInt16OrDefault(max_value, CAST('-1', 'Int16'));
SELECT input_value, toInt16OrDefault(input_value, 0) FROM (SELECT input_value FROM test_table WHERE default_value = CAST('-1', 'Int16')) AS temp_table;
SELECT DISTINCT toInt16OrDefault(input_value, CAST('-1', 'Int16')) FROM test_table WHERE input_value != 'abc' AND input_value != 'Inf';
SELECT toInt16OrDefault(IF(input_value LIKE '%c%', CAST('-1', 'Int16'), '0'), CAST('0', 'Int16')) AS result FROM test_table;