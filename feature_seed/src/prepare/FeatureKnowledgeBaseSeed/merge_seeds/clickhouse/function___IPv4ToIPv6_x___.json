CREATE TABLE ip_addresses (id UInt32, ip_address UInt32);
INSERT INTO ip_addresses VALUES (1, IPv4StringToNum('192.168.0.1')), (2, IPv4StringToNum('127.0.0.1')), (3, IPv4StringToNum('10.0.0.1'));
SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM ip_addresses;
SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM ip_addresses WHERE ip_address < IPv4StringToNum('192.168.0.2');
SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM (SELECT ip_address FROM ip_addresses WHERE id = 1);
CREATE TABLE ip_summary AS SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM ip_addresses;
SELECT s.id, s.ipv6_address FROM ip_summary AS s JOIN ip_addresses AS i ON s.id = i.id WHERE i.ip_address = IPv4StringToNum('10.0.0.1');
SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM ip_addresses WHERE ip_address IN (IPv4StringToNum('192.168.0.1'), IPv4StringToNum('127.0.0.1'));
WITH (SELECT IPAddresses FROM ip_addresses) AS ip_list SELECT IPv6NumToString(IPv4ToIPv6(ip_address)) FROM ip_list WHERE ip_address NOT IN (IPv4StringToNum('192.168.0.1'));
INSERT INTO ip_addresses VALUES (4, IPv4StringToNum('255.255.255.255'));
SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM ip_addresses WHERE id >= 1 ORDER BY id DESC;
SELECT COUNT(*) FROM ip_addresses WHERE IPv6NumToString(IPv4ToIPv6(ip_address)) LIKE '::ffff:%';
SELECT IPv6NumToString(IPv4ToIPv6(IPv4StringToNum('0.0.0.0'))) AS ipv6_zero_address;
SELECT IPv6NumToString(IPv4ToIPv6(IPv4StringToNum('255.255.255.255'))) AS ipv6_broadcast_address;
CREATE TABLE ip_logs AS SELECT id, IPv6NumToString(IPv4ToIPv6(ip_address)) AS ipv6_address FROM ip_addresses WHERE ip_address > IPv4StringToNum('0.0.0.0');