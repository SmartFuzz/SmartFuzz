DROP TABLE IF EXISTS population_data;
CREATE TABLE population_data (value UInt8) ENGINE = Memory;
INSERT INTO population_data VALUES (1), (2), (3), (4), (5), (5), (5), (6), (7), (8);
SELECT varPopStable(value) AS population_variance FROM population_data;
DROP TABLE IF EXISTS empty_data;
CREATE TABLE empty_data (num Float64) ENGINE = Memory;
SELECT varPopStable(num) AS population_variance FROM empty_data;
DROP TABLE IF EXISTS mixed_data;
CREATE TABLE mixed_data (val Float64) ENGINE = Memory;
INSERT INTO mixed_data VALUES (1.0), (2.5), (3.5), (4.7), (5.0), (6.2), (7.1);
SELECT varPopStable(val) AS population_variance FROM mixed_data;
DROP TABLE IF EXISTS large_dataset;
CREATE TABLE large_dataset (num UInt64) ENGINE = Memory;
INSERT INTO large_dataset SELECT number FROM system.numbers LIMIT 10000;
SELECT varPopStable(num) AS population_variance FROM large_dataset;
DROP TABLE IF EXISTS joined_data;
CREATE TABLE joined_data1 (id UInt8, value UInt8) ENGINE = Memory;
CREATE TABLE joined_data2 (id UInt8, value UInt8) ENGINE = Memory;
INSERT INTO joined_data1 VALUES (1, 10), (2, 20), (3, 30);
INSERT INTO joined_data2 VALUES (1, 5), (2, 15), (3, 25);
SELECT varPopStable(j1.value + j2.value) AS population_variance FROM joined_data1 j1 JOIN joined_data2 j2 ON j1.id = j2.id;
DROP TABLE IF EXISTS nested_data;
CREATE TABLE nested_data (val Float64) ENGINE = Memory;
INSERT INTO nested_data VALUES (1.0), (1.0), (3.0), (2.0);
SELECT varPopStable((SELECT AVG(val) FROM nested_data)) AS population_variance AVG from nested_data;
DROP TABLE IF EXISTS decimal_data;
CREATE TABLE decimal_data (val Decimal(10, 2)) ENGINE = Memory;
INSERT INTO decimal_data VALUES (1.11), (2.22), (3.33), (4.44), (5.55);
SELECT varPopStable(val) AS population_variance FROM decimal_data;
DROP TABLE IF EXISTS subquery_data;
CREATE TABLE subquery_data (num UInt32) ENGINE = Memory;
INSERT INTO subquery_data VALUES (1), (4), (6), (8), (10);
SELECT varPopStable(num) AS population_variance FROM (SELECT num FROM subquery_data WHERE num > 3);
DROP TABLE IF EXISTS complex_data;
CREATE TABLE complex_data (a UInt8, b Float64) ENGINE = Memory;
INSERT INTO complex_data VALUES (1, 1.0), (2, 2.0), (3, 3.0), (4, 4.0);
SELECT varPopStable(a + b) AS population_variance FROM complex_data;