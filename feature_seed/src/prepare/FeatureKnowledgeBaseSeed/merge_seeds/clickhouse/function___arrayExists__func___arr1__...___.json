CREATE TABLE test_array (id UInt32, values Array(UInt32));
INSERT INTO test_array VALUES (1, [1, 2, 3]), (2, [0, 0, 0]), (3, [5, 0, 0]), (4, [0, 0, 2]);
SELECT arrayExists(x -> x > 0, values) AS has_positive FROM test_array;
SELECT id, arrayExists(x -> x % 2 = 0, values) AS has_even FROM test_array WHERE id IN (1, 3);
SELECT id, arrayExists(x -> x = 0, values) AS has_zero FROM test_array;
SELECT arrayExists((x, y) -> x > y, values, [2, 3, 4]) AS exists_greater FROM test_array;
CREATE TABLE test_nested (arr Array(Array(UInt32));
INSERT INTO test_nested VALUES ([1, 2, 3]), ([0, 0, 0]), ([5, 0, 0]), ([0, 0, 2]);
SELECT arrayExists(x -> arrayExists(y -> y > 1, x), arr) AS has_nested_positive FROM test_nested;
SELECT id, arrayExists(x -> x > 3, values) AS any_greater_than_three FROM test_array WHERE id IN (SELECT id FROM test_array WHERE id > 2);
CREATE TABLE test_multi_join (id UInt32, values Array(UInt32), category String);
INSERT INTO test_multi_join VALUES (1, [1, 2, 3], 'A'), (2, [0, 0, 0], 'B'), (3, [5, 0, 0], 'A'), (4, [0, 0, 2], 'C');
SELECT category, arrayExists(x -> x > 0, values) AS has_positive FROM test_multi_join GROUP BY category;
SELECT t1.id, arrayExists(x -> x < 0, t2.values) AS has_negative FROM test_array t1 JOIN test_array t2 ON t1.id = t2.id WHERE id < 4;