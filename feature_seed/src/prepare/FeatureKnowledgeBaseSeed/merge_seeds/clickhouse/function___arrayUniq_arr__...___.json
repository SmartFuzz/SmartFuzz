CREATE TABLE test_arrayUniq (arr Array(Int32));
INSERT INTO test_arrayUniq VALUES (NULL), ([1, 2, 3]), ([1, 2, 2]), ([3, 3, 3]), ([1, 1, 2]);
SELECT arrayUniq(arr) AS unique_count FROM test_arrayUniq;
SELECT arrayUniq([1, 2, 2, 3]) AS unique_elements;
SELECT arrayUniq([1, 1, 1], [2, 2, 2], [3, 3, 3]) AS unique_tuples;
SELECT arrayUniq(arr) FROM test_arrayUniq WHERE arr IS NOT NULL;
SELECT arr, arrayUniq(arr) FROM test_arrayUniq GROUP BY arr;
CREATE TABLE test_multiArray (arr1 Array(Int32), arr2 Array(String));
INSERT INTO test_multiArray VALUES ([1, 2], ['a', 'b']), ([1, 2], ['a', 'a']), ([2, 2], ['b', 'b']);
SELECT arrayUniq(arr1, arr2) AS unique_tuples FROM test_multiArray;
SELECT arrayUniq(arr1), arrayUniq(arr2) FROM test_multiArray;
CREATE TABLE test_nested AS (SELECT arr FROM test_arrayUniq);
SELECT arrayUniq(arr) FROM (SELECT arr FROM test_nested) AS nested;
CREATE TABLE complex_join AS (SELECT arr1, arr2 FROM test_multiArray JOIN test_arrayUniq ON arrayUniq(test_multiArray.arr1) > 0);
SELECT arrayUniq(arr1) AS unique_arr1, arrayUniq(arr2) AS unique_arr2 FROM complex_join;
SELECT arrayUniq(arr), COUNT(*) FROM test_arrayUniq GROUP BY arr HAVING arrayUniq(arr) > 1;