CREATE TABLE test_hash (value String, id Int32) ENGINE = Memory;
INSERT INTO test_hash VALUES ('', 1);
INSERT INTO test_hash VALUES ('Hello, world!', 2);
INSERT INTO test_hash VALUES ('1234567890', 3);
INSERT INTO test_hash VALUES ('!@#$%^&*()', 4);
INSERT INTO test_hash VALUES (CAST(123 AS String), 5);
INSERT INTO test_hash VALUES (CAST(-123 AS String), 6);
INSERT INTO test_hash VALUES (CAST(2147483647 AS String), 7);
INSERT INTO test_hash VALUES (CAST(-2147483648 AS String), 8);
SELECT javaHash(value) FROM test_hash WHERE id = 1;
SELECT javaHash(value) FROM test_hash WHERE value LIKE 'Hello%';
SELECT javaHash(toInt32(id)) FROM test_hash WHERE id > 0;
SELECT javaHash(value) FROM test_hash WHERE id IN (SELECT id FROM test_hash WHERE value LIKE '%123%');
SELECT javaHash(CONCAT(value, toString(id))) FROM test_hash;
WITH (SELECT MAX(id) FROM test_hash) AS max_id SELECT javaHash(value) FROM test_hash WHERE id = max_id;
SELECT t1.id, javaHash(t1.value) AS hash_value FROM test_hash AS t1 JOIN (SELECT id FROM test_hash WHERE id % 2 = 0) AS t2 ON t1.id = t2.id;
SELECT javaHash(value) FROM (SELECT value FROM test_hash WHERE id < 5) AS subquery;
SELECT javaHash(value) FROM test_hash WHERE value = (SELECT value FROM test_hash WHERE id = 2);
SELECT javaHash(value) FROM (SELECT DISTINCT value FROM test_hash) AS unique_values;