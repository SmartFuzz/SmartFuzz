CREATE TABLE test_table (value String);
INSERT INTO test_table VALUES ('255'), ('-1'), ('256'), ('8.5'), ('abc'), ('0xc0fe'), ('Inf'), ('NaN'), ('0'), ('-128'), ('128'), ('123.456');
SELECT toUInt8OrNull(value) FROM test_table;
SELECT a.value AS original_value, toUInt8OrNull(a.value) AS converted_value FROM test_table a WHERE a.value NOT LIKE '%abc%';
CREATE TABLE another_table (num String);
INSERT INTO another_table VALUES ('15'), ('-2'), ('300'), ('-0.75'), ('0.999'), ('100.5');
SELECT a.value, b.num, toUInt8OrNull(a.value) + toUInt8OrNull(b.num) AS sum FROM test_table a JOIN another_table b ON a.value = '0' OR b.num = '0';
SELECT COUNT(*) AS valid_count FROM (SELECT toUInt8OrNull(value) FROM test_table WHERE value NOT LIKE '%abc%' AND value NOT LIKE '%Inf%' AND value NOT LIKE '%NaN%');
SELECT toUInt8OrNull(value) AS result FROM (SELECT '200' AS value UNION ALL SELECT 'abc' UNION ALL SELECT '256' UNION ALL SELECT '100') ORDER BY result ASC;
SELECT avg(toUInt8OrNull(value)) AS average FROM test_table WHERE value IN ('0', '100', '200', '255');
SELECT CASE WHEN toUInt8OrNull(value) IS NULL THEN 'Invalid' ELSE 'Valid' END AS validity FROM test_table;