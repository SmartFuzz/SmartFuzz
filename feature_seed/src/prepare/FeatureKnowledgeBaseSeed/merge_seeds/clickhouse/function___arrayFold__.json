CREATE TABLE test_table (id Int32, values Array(Int32));
INSERT INTO test_table VALUES (1, [1, 2, 3]), (2, [4, 5, 6]), (3, [7, 8, 9]);
SELECT arrayFold(acc, x -> acc + x * 2, [1, 2, 3], 0) AS result FROM test_table;
SELECT arrayFold(acc, x -> (acc.1 + x, acc.2 + x * 3), [10, 20, 30], (1::Int64, 0::Int64)) AS complex_result FROM test_table;
CREATE TABLE another_table (num Int32);
INSERT INTO another_table VALUES (1), (2), (3);
SELECT arrayFold(acc, x -> acc + x, (SELECT arrayJoin(values) FROM test_table WHERE id = 1), 0) AS fold_result FROM another_table;
SELECT arrayFold(acc, x -> (acc.1 + x * 3, acc.2 + x), range(5), (0, 0)) AS result_fibonacci FROM numbers(1, 10);
SELECT id, arrayFold(acc, x -> acc + x, values, 0) AS accumulated_sum FROM test_table GROUP BY id;
SELECT id, arrayFold(acc, x -> acc + (x * 2), arrayJoin(values), 0) AS split_sum FROM test_table GROUP BY id;
SELECT arrayFold(acc, x -> (acc.1 + x, acc.2 + 1), range(15), (0, 0)).1 AS even_count FROM another_table;
SELECT arrayFold(acc, x -> acc + x, arrayMap(y -> y * 10, values), 0) AS mapped_sum FROM test_table WHERE id = 2;