CREATE TABLE test_table (id UInt64, value String);
INSERT INTO test_table VALUES (1, '-256'), (2, '-256.256'), (3, '12345678901234567890'), (4, '0'), (5, '256'), (6, '99999999999999999999999999999999');
SELECT toInt256(value) AS converted_value FROM test_table WHERE id IN (1, 2);
SELECT toInt256(value) AS converted_value FROM test_table WHERE value LIKE '%256%';
SELECT id, toInt256(value) AS converted_value FROM test_table WHERE converted_value < 0 OR converted_value > 255;
SELECT id, toInt256(value) AS converted_value FROM (SELECT DISTINCT value FROM test_table WHERE value NOT LIKE '%-%') AS subquery;
SELECT t1.id, toInt256(t2.value) AS converted_value FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.value <> t2.value;
SELECT SUM(toInt256(value)) AS total FROM test_table;
SELECT toInt256(value + '0.5') AS floating_conversion FROM test_table WHERE id = 3;
SELECT toInt256(value) FROM (SELECT value FROM test_table WHERE id < 4) AS temp WHERE temp.value IS NOT NULL;
SELECT id, toInt256(-value) AS negated_value FROM (SELECT value FROM test_table WHERE value LIKE '%5') AS temp;
SELECT toInt256(CAST(value AS UInt8)) AS casted_value FROM test_table WHERE id = 1;
SELECT toInt256('0xc0fe') AS binary_conversion FROM test_table WHERE id = 1;