DROP TABLE IF EXISTS test;
CREATE TABLE test (a UInt32, b Float64, c Float64, d Float64) ENGINE = Memory;
INSERT INTO test (a, b, c, d) VALUES (1, 5.6, -4.4, 2.6), (2, -9.6, 3, 3.3), (3, -1.3, -4, 1.2), (4, 5.3, 9.7, 2.3), (5, 4.4, 0.037, 1.222), (6, -8.6, -7.8, 2.1233), (7, 5.1, 9.3, 8.1222), (8, 7.9, -3.6, 9.837), (9, -8.2, 0.62, 8.43555), (10, -3, 7.3, 6.762);
SELECT arrayJoin(corrMatrix(a, b, c, d)) AS corrMatrix FROM test;
SELECT arrayMap(x -> round(x, 3), arrayJoin(corrMatrix(b, c))) AS corrMatrix FROM test;
DROP TABLE IF EXISTS test2;
CREATE TABLE test2 (x UInt32, y Float64, z Float64) ENGINE = Memory;
INSERT INTO test2 (x, y, z) VALUES (1, 1.1, 2.2), (2, 2.2, 1.1), (3, 3.3, 0.0);
SELECT corrMatrix(test.a, test.b, test2.y) FROM test JOIN test2 ON test.a = test2.x;
SELECT arrayJoin(corrMatrix((SELECT avg(b) FROM test WHERE c < 0.0), (SELECT min(c) FROM test2))) AS corrMatrix;
SELECT corrMatrix(a, b, (SELECT avg(d) FROM test) AS avg_d) FROM test;
WITH (SELECT avg(b) FROM test) AS avg_b, (SELECT stddev(c) FROM test2) AS stddev_c SELECT corrMatrix(avg_b, stddev_c) AS corrMatrix FROM dual;
DROP TABLE IF EXISTS complex_test;
CREATE TABLE complex_test (id UInt32, val1 Float64, val2 Float64, val3 Float64) ENGINE = Memory;
INSERT INTO complex_test (id, val1, val2, val3) VALUES (1, 10.1, 20.2, 30.3), (2, 15.5, 25.5, 35.5), (3, 20.0, 40.0, 60.0);
SELECT arrayMap(x -> round(x, 4), arrayJoin(corrMatrix(val1, val2, val3))) FROM complex_test;