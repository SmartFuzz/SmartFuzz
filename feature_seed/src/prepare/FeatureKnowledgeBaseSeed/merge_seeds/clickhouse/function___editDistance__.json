CREATE TABLE strings_table (id UInt32, original String, modified String);
INSERT INTO strings_table VALUES (1, 'clickhouse', 'mouse'), (2, 'test', 'contests'), (3, 'a', 'b'), (4, 'hello', 'hell'), (5, '', '');
SELECT editDistance(original, modified) AS distance FROM strings_table;
SELECT id, editDistance(original, modified) FROM strings_table WHERE editDistance(original, modified) < 5;
SELECT id, editDistance(original, modified) AS distance FROM strings_table ORDER BY distance DESC;
SELECT id FROM strings_table WHERE editDistance(original, 'clickhouse') < 10;
SELECT original, modified, editDistance(original, modified) AS distance FROM (SELECT * FROM strings_table) AS subquery WHERE distance <= 3;
CREATE TABLE another_table (id UInt32, value String);
INSERT INTO another_table VALUES (1, 'clickhouse'), (2, 'clickhouse'), (3, 'mouse');
SELECT a.id, editDistance(a.value, b.value) AS distance FROM another_table AS a JOIN another_table AS b ON a.id != b.id WHERE editDistance(a.value, b.value) < 5;
SELECT SUM(editDistance(original, modified)) AS total_distance FROM strings_table;
SELECT editDistance('abc', '') AS distance_empty;
SELECT editDistance('', '') AS distance_empty_both;