CREATE TABLE test_table (ts_value Int64);
INSERT INTO test_table VALUES (1234567891011), (1633036800000000000), (-1234567891011), (0);
WITH CAST(ts_value, 'Int64') AS i64 SELECT fromUnixTimestamp64Nano(i64, 'UTC') AS x FROM test_table;
WITH (SELECT MAX(ts_value) FROM test_table) AS max_ts, (SELECT MIN(ts_value) FROM test_table) AS min_ts SELECT fromUnixTimestamp64Nano(max_ts, 'UTC'), fromUnixTimestamp64Nano(min_ts, 'UTC') AS min_time;
SELECT i64, fromUnixTimestamp64Nano(i64) AS converted_time FROM (SELECT ts_value AS i64 FROM test_table) WHERE i64 > 0;
WITH (SELECT ts_value AS ts FROM test_table) AS subquery SELECT fromUnixTimestamp64Nano(ts, 'Europe/London') AS london_time FROM subquery;
SELECT t1.ts_value, fromUnixTimestamp64Nano(t1.ts_value) AS datetime_utc, fromUnixTimestamp64Nano(t1.ts_value, 'Asia/Tokyo') AS datetime_tokyo FROM test_table t1 WHERE t1.ts_value > 0;
WITH (SELECT DISTINCT ts_value FROM test_table WHERE ts_value BETWEEN -2000000000000 AND 2000000000000) AS filtered_ts SELECT fromUnixTimestamp64Nano(ts_value) FROM filtered_ts;
CREATE TABLE timezone_tests (value Int64, timezone String);
INSERT INTO timezone_tests VALUES (1633036800000000000, 'UTC'), (1633036800000000000, 'America/New_York'), (1633036800000000000, 'Asia/Tokyo');
SELECT fromUnixTimestamp64Nano(value, timezone) FROM timezone_tests;
SELECT fromUnixTimestamp64Nano(NULL), fromUnixTimestamp64Nano(1234567891011), fromUnixTimestamp64Nano(-1234567891011) AS negative_timestamp;