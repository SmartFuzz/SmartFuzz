CREATE TABLE test_floor (value Float64, precision Int32);
INSERT INTO test_floor VALUES (123.45, 1), (12345.678, -1), (-128, -1), (100.99, 0);
SELECT floor(value, precision) AS rounded FROM test_floor;
SELECT floor(floor(123.456, 1) + 10) AS rounded;
SELECT floor(floor(floor(-130.75, 0), -1) - 5) AS rounded;
SELECT floor(123.999) AS rounded, floor(-123.999) AS rounded_negative;
SELECT (SELECT floor(value) FROM test_floor WHERE precision = 1) AS inner_query_result;
SELECT floor(floor(value, 1) + 10) FROM (SELECT value FROM test_floor) AS subquery;
CREATE TABLE test_floor2 (id UInt32, value Float32);
INSERT INTO test_floor2 VALUES (1, 123.45), (2, -129.99), (3, 0);
SELECT t1.id, floor(t1.value, 1) AS rounded1, floor(t2.value, 0) AS rounded2 FROM test_floor t1 JOIN test_floor2 t2 ON t1.value > t2.value;
CREATE TABLE overflow_test (overflow_value Int8);
INSERT INTO overflow_test VALUES (-128);
SELECT floor(overflow_value, -1) AS rounded FROM overflow_test;
-- should return undefined;