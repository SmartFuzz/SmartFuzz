CREATE TABLE sum_map_test(    date Date,    timeslot DateTime,    statusMap Nested(        status UInt16,        requests UInt64    ),    statusMapTuple Tuple(Array(Int32), Array(Int32))) ENGINE = Log;
INSERT INTO sum_map_test VALUES    ('2001-01-01', '2001-01-01 00:00:00', [1, 2, 3], [5, 10, 15], ([1, 2, 3], [5, 10, 15])),    ('2001-01-01', '2001-01-01 00:00:00', [2, 3, 4], [10, 20, 30], ([2, 3, 4], [10, 20, 30])),    ('2001-01-01', '2001-01-01 00:01:00', [4, 5, 6], [15, 15, 15], ([4, 5, 6], [15, 15, 15])),    ('2001-01-01', '2001-01-01 00:01:00', [6, 7, 8], [20, 20, 20], ([6, 7, 8], [20, 20, 20]));
SELECT    timeslot,    sumMap(statusMap.status, statusMap.requests) AS summed_status,    sumMap(statusMapTuple) AS summed_tupleFROM sum_map_testGROUP BY timeslot;
CREATE TABLE another_sum_map_test(    id UInt32,    keyArray Array(Int32),    valueArray Array(Int32)) ENGINE = Log;
INSERT INTO another_sum_map_test VALUES    (1, [1, 2, 2], [10, 20, 30]),    (2, [3, 4, 4], [15, 15, 15]);
SELECT    keyArray,    valueArray,    sumMap(keyArray, valueArray) AS summed_resultFROM another_sum_map_test;
CREATE TABLE complex_sum_map(    userId UInt32,    transactionDate Date,    categories Nested(        categoryId UInt16,        amounts UInt64    )) ENGINE = Log;
INSERT INTO complex_sum_map VALUES    (1, '2022-01-01', [1, 2], [100, 200]),    (1, '2022-01-01', [2, 3], [300, 400]),    (2, '2022-01-01', [1, 3], [150, 250]);
SELECT    userId,    sumMap(categories.categoryId, categories.amounts) AS category_totalsFROM complex_sum_mapGROUP BY userId;
CREATE TABLE nested_sum_map(    itemId UInt32,    date Date,    data Tuple(Array(Int32), Array(Int32))) ENGINE = Log;
INSERT INTO nested_sum_map VALUES    (1, '2023-01-01', ([1, 2], [10, 20])),    (2, '2023-01-01', ([2, 3], [25, 35]));
SELECT    date,    sumMap(data.1, data.2) AS total_sumFROM nested_sum_mapGROUP BY date;
SELECT    timeslot,    sumMap(statusMap.status, statusMap.requests) AS status_requestsFROM sum_map_testWHERE date = '2001-01-01'GROUP BY timeslot HAVING count(*) > 1;