CREATE DATABASE test_db;
USE test_db;
CREATE TABLE test_db.users (id UInt32, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_db.users VALUES (1, 'Alice'), (2, 'Bob');
SELECT * FROM test_db.users;
USE another_db;
CREATE TABLE another_db.orders (order_id UInt32, user_id UInt32) ENGINE = MergeTree() ORDER BY order_id;
INSERT INTO another_db.orders VALUES (101, 1), (102, 2);
USE test_db;
SELECT u.name, o.order_id FROM test_db.users u JOIN another_db.orders o ON u.id = o.user_id;
CREATE TABLE test_db.products (product_id UInt32, product_name String) ENGINE = MergeTree() ORDER BY product_id;
INSERT INTO test_db.products VALUES (1, 'Laptop'), (2, 'Tablet');
SELECT p.product_name FROM test_db.products p WHERE p.product_id IN (SELECT DISTINCT o.user_id FROM another_db.orders o);
USE test_db;
SELECT count(*) FROM test_db.users WHERE name LIKE '%A%';
USE test_db;
CREATE TABLE test_db.sales (sale_id UInt32, product_id UInt32, amount Float32) ENGINE = MergeTree() ORDER BY sale_id;
INSERT INTO test_db.sales VALUES (1, 1, 1500.5), (2, 2, 300.0);
SELECT SUM(s.amount) FROM test_db.sales s JOIN test_db.products p ON s.product_id = p.product_id WHERE p.product_name = 'Laptop';
CREATE DATABASE test_db_copy;
USE test_db_copy;
CREATE TABLE users_copy AS test_db.users;
USE test_db;
SELECT count(*) FROM test_db.users WHERE id IN (SELECT user_id FROM another_db.orders);
DROP DATABASE test_db;
USE test_db;
DROP TABLE users;