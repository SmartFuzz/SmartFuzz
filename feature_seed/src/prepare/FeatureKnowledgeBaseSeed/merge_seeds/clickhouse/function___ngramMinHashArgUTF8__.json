CREATE TABLE test_strings (value String);
INSERT INTO test_strings VALUES ('ClickHouse'), ('Data Science'), ('Big Data'), ('Fuzzy Testing');
SELECT ngramMinHashArgUTF8(value, 3, 6) FROM test_strings;
SELECT ngramMinHashArgUTF8(value, 1, 10) FROM test_strings;
SELECT ngramMinHashArgUTF8(value, 25, 25) FROM test_strings;
SELECT ngramMinHashArgUTF8(value) FROM test_strings WHERE value LIKE '%Data%';
SELECT ngramMinHashArgUTF8(value, 4) AS hashes FROM test_strings WHERE length(value) > 10;
SELECT t.value, n.1 AS min_hash, n.2 AS max_hash FROM test_strings t, (SELECT ngramMinHashArgUTF8(value, 5, 3) FROM test_strings) AS n;
SELECT ngramMinHashArgUTF8(value) FROM test_strings GROUP BY value HAVING count(*) > 1;
SELECT ngramMinHashArgUTF8(value, 3, 6) FROM (SELECT value FROM test_strings WHERE length(value) < 15) AS subquery;
SELECT ngramMinHashArgUTF8(value, 3, 6) FROM test_strings WHERE value IN (SELECT value FROM test_strings WHERE value LIKE '%Data%');
CREATE TABLE test_results (min_hash String, max_hash String);
INSERT INTO test_results SELECT ngramMinHashArgUTF8(value, 5, 5).1, ngramMinHashArgUTF8(value, 5, 5).2 FROM test_strings;
SELECT * FROM test_results ORDER BY min_hash;
SELECT value, ngramMinHashArgUTF8(value, 8, 10) FROM test_strings WHERE ngramMinHashArgUTF8(value) IS NOT NULL;
SELECT t.value, n.1 AS min_hash, n.2 AS max_hash FROM test_strings t JOIN (SELECT value, ngramMinHashArgUTF8(value) FROM test_strings) AS n ON t.value = n.value ORDER BY min_hash;