CREATE TABLE test_dates (date_value DateTime) ENGINE = MergeTree() ORDER BY date_value;
INSERT INTO test_dates VALUES (toDateTime('2023-01-01 00:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-02-28 10:20:30'));
INSERT INTO test_dates VALUES (toDateTime('2023-02-29 10:20:30'));
INSERT INTO test_dates VALUES (toDateTime('2023-03-31 15:45:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-21 10:20:30'));
INSERT INTO test_dates VALUES (toDateTime('2023-12-31 23:59:59'));
CREATE TABLE test_months AS SELECT toDateTime('2023-01-01 00:00:00') AS month_start UNION ALL SELECT toDateTime('2023-02-01 00:00:00') UNION ALL SELECT toDateTime('2023-03-01 00:00:00');
SELECT date_value, toDayOfMonth(date_value) FROM test_dates;
SELECT toDayOfMonth(toDateTime('2023-01-01 12:00:00')) AS day_of_month;
SELECT toDayOfMonth(toDateTime('2023-04-30 12:00:00')) AS day_of_month;
SELECT AVG(toDayOfMonth(date_value)) FROM test_dates;
SELECT COUNT(*) FROM (SELECT toDayOfMonth(date_value) AS day FROM test_dates HAVING day > 15);
SELECT t1.date_value, toDayOfMonth(t1.date_value) AS day, t2.month_start FROM test_dates t1 JOIN test_months t2 ON t1.date_value >= t2.month_start;
SELECT SUM(toDayOfMonth(date_value)) OVER (PARTITION BY toStartOfMonth(date_value)) AS month_day_sum FROM test_dates;
SELECT toDayOfMonth(toDateTime('2023-07-31 12:00:00')) AS last_day_of_month;
SELECT toDayOfMonth(toDateTime('2022-02-28 00:00:00')) AS february_end_day;