CREATE TABLE file_paths (path String);
INSERT INTO file_paths VALUES ('some/long/path/to/file'), ('c:\windows\system32\file.exe'), ('/usr/local/bin/'), ('C:\'), ('no/slashes/here');
SELECT path, basename(path) FROM file_paths;
SELECT path, basename(path) FROM file_paths WHERE path LIKE 'some%';
SELECT DISTINCT basename(path) FROM file_paths;
SELECT basename(path) AS filename FROM (SELECT path FROM file_paths WHERE path NOT LIKE '%/%' AND path NOT LIKE '%\\%') AS no_slash_paths;
SELECT basename(path) AS filename FROM file_paths WHERE basename(path) != '';
WITH (SELECT path FROM file_paths WHERE path LIKE 'c:\%') AS windows_paths SELECT basename(path) FROM windows_paths;
SELECT path, basename(CONCAT(path, '/')) AS filename_with_slash FROM file_paths;
SELECT basename(path) FROM (SELECT path FROM file_paths WHERE path != '') AS filtered_paths;
SELECT path, COUNT(*) FROM file_paths GROUP BY basename(path);