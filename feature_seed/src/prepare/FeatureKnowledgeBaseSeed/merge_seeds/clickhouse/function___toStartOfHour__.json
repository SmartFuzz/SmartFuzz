CREATE TABLE test_dates (event_time DateTime);
INSERT INTO test_dates VALUES (toDateTime('2023-04-21 10:20:30'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-21 10:59:59'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-21 11:00:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-21 23:45:00'));
INSERT INTO test_dates VALUES (toDateTime('2023-04-21 00:00:01'));
SELECT toStartOfHour(event_time) FROM test_dates;
SELECT toStartOfHour(toDateTime('2023-06-01 15:30:45')) AS rounded_time;
SELECT d.event_time, toStartOfHour(d.event_time) AS start_of_hour FROM test_dates AS d WHERE d.event_time < toDateTime('2023-04-21 12:00:00');
SELECT d.event_time, toStartOfHour(d.event_time) AS start_of_hour FROM test_dates AS d JOIN (SELECT toDateTime('2023-04-21 12:30:00') AS threshold) AS t ON d.event_time < t.threshold;
SELECT toStartOfHour(toDateTime64('2023-04-21 10:30:45.123456', 6)) AS rounded_time;
SELECT event_time, toStartOfHour(event_time) AS rounded_time FROM (SELECT * FROM test_dates WHERE event_time >= toDateTime('2023-04-21 10:00:00')) AS filtered;
CREATE TABLE event_logs (log_time DateTime, message String) ENGINE = MergeTree() ORDER BY log_time;
INSERT INTO event_logs VALUES (toDateTime('2023-04-21 10:20:30'), 'Event A');
INSERT INTO event_logs VALUES (toDateTime('2023-04-21 10:45:10'), 'Event B');
SELECT message, toStartOfHour(log_time) AS hour FROM event_logs;
SELECT COUNT(*) FROM event_logs WHERE toStartOfHour(log_time) = toStartOfHour(toDateTime('2023-04-21 10:45:00'));