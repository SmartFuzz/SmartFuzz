CREATE TABLE xml_test (id UInt32, content String);
INSERT INTO xml_test VALUES (1, 'Hello, "world"!'), (2, '<123>'), (3, '&clickhouse'), (4, '\'foo\'');
SELECT encodeXMLComponent(content) FROM xml_test;
SELECT id, encodeXMLComponent(content) AS escaped_content FROM xml_test WHERE id > 1;
SELECT id, encodeXMLComponent(content) AS escaped_content FROM xml_test WHERE content IS NOT NULL;
SELECT id, encodeXMLComponent(content) AS escaped_content FROM xml_test WHERE encodeXMLComponent(content) LIKE '%&%';
CREATE TABLE xml_test_2 (id UInt32, description String);
INSERT INTO xml_test_2 VALUES (1, 'Sample with <tag> and & special cases');
SELECT xml_test.id, encodeXMLComponent(xml_test.content) AS escaped_content, xml_test_2.description FROM xml_test JOIN xml_test_2 ON xml_test.id = xml_test_2.id;
SELECT id, encodeXMLComponent(content) AS escaped_content FROM xml_test WHERE id IN (SELECT id FROM xml_test_2);
SELECT (SELECT encodeXMLComponent(content) FROM xml_test WHERE id = 1) AS single_escape, (SELECT encodeXMLComponent(content) FROM xml_test_2 WHERE id = 1) AS nested_escape;