CREATE TABLE tupletest (col Tuple(user_ID UInt64, session_ID UInt64)) ENGINE = Memory;
INSERT INTO tupletest VALUES (tuple(100, 2502)), (tuple(1, 100));
SELECT tupleToNameValuePairs(col) FROM tupletest;
CREATE TABLE nestedtest (col Tuple(a Tuple(b UInt32, c UInt32), d UInt32)) ENGINE = Memory;
INSERT INTO nestedtest VALUES (tuple(tuple(10, 20), 30)), (tuple(tuple(5, 15), 25));
SELECT arrayJoin(tupleToNameValuePairs(col)) FROM nestedtest;
CREATE TABLE multiTableTest (t1_col Tuple(value1 UInt32, value2 UInt32), t2_col Tuple(valueA UInt32, valueB UInt32)) ENGINE = MergeTree() ORDER BY t1_col.value1;
INSERT INTO multiTableTest VALUES (tuple(1, 2), tuple(3, 4)), (tuple(5, 6), tuple(7, 8));
SELECT tupleToNameValuePairs(t1_col), tupleToNameValuePairs(t2_col) FROM multiTableTest;
CREATE TABLE complexTest (col Tuple(cpu Float64, memory Float64, disk Float64)) ENGINE = Memory;
INSERT INTO complexTest VALUES (tuple(3.3, 5.5, 6.6));
SELECT arrayJoin(tupleToNameValuePairs(col)) FROM complexTest;
CREATE TABLE advancedTest (t1_col Tuple(a String, b Float64), t2_col Tuple(c String, d Int32)) ENGINE = Memory;
INSERT INTO advancedTest VALUES (tuple('first', 3.25), tuple('second', 4.75));
SELECT tupleToNameValuePairs(t1_col) AS t1_pairs, tupleToNameValuePairs(t2_col) AS t2_pairs FROM advancedTest;
CREATE TABLE edgeCaseTest (col Tuple(x Int32, y Int32)) ENGINE = Memory;
INSERT INTO edgeCaseTest VALUES (tuple(0, 0)), (tuple(-1, -1)), (tuple(2147483647, 2147483647));
SELECT arrayJoin(tupleToNameValuePairs(col)) FROM edgeCaseTest;
CREATE TABLE fuzzyTest (col Tuple(mixed String, value Int32)) ENGINE = Memory;
INSERT INTO fuzzyTest VALUES (tuple('test', 10)), (tuple('fuzz', -5));
SELECT tupleToNameValuePairs(col) FROM fuzzyTest;