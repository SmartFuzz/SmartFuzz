CREATE TABLE test_table (value Int32);
INSERT INTO test_table VALUES (1), (2), (3), (4), (5);
SELECT blockSerializedSize(value) FROM test_table;
SELECT blockSerializedSize(value) * 2 AS double_size FROM test_table;
CREATE TABLE nested_table (long_value Array(Int64));
INSERT INTO nested_table VALUES ([1, 2, 3]), ([4, 5, 6]);
SELECT blockSerializedSize(long_value) FROM nested_table;
SELECT blockSerializedSize(maxState(value)) AS max_serialized FROM test_table;
SELECT blockSerializedSize(SELECT AVG(value) FROM test_table) AS avg_serialized;
CREATE TABLE join_table1 (id Int32, value String);
CREATE TABLE join_table2 (id Int32, value String);
INSERT INTO join_table1 VALUES (1, 'a'), (2, 'b');
INSERT INTO join_table2 VALUES (1, 'x'), (2, 'y');
SELECT blockSerializedSize(t1.value) FROM join_table1 AS t1 JOIN join_table2 AS t2 ON t1.id = t2.id;
SELECT blockSerializedSize(value + 10) FROM test_table;
SELECT blockSerializedSize(concat(value, '-') ) FROM test_table;
CREATE TABLE more_complex (id Int32, values Array(Int32));
INSERT INTO more_complex VALUES (1, [1,2,3]), (2, [4,5,6]);
SELECT blockSerializedSize(ArraySum(values)) FROM more_complex;
SELECT AVG(blockSerializedSize(value)) FROM test_table GROUP BY value;
SELECT blockSerializedSize(SELECT count(*) FROM test_table) AS count_size;