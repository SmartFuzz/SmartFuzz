CREATE TABLE test_table (id Int32, value Float64);
INSERT INTO test_table VALUES (1, 5.4), (2, -3.2), (3, 0.0);
SELECT negate(value) AS negated_value FROM test_table;
SELECT id, negate(value) AS negated_value FROM test_table WHERE id = 1;
CREATE TABLE nested_table (num Int32);
INSERT INTO nested_table VALUES (10), (20), (30);
SELECT negate((SELECT AVG(num) FROM nested_table)) AS negated_avg;
CREATE TABLE join_table1 (key Int32, value1 Float64);
INSERT INTO join_table1 VALUES (1, 10.5), (2, -2.5);
CREATE TABLE join_table2 (key Int32, value2 Float64);
INSERT INTO join_table2 VALUES (1, 5.0), (2, 3.5);
SELECT jt1.key, negate(jt1.value1 + jt2.value2) AS negated_sum FROM join_table1 jt1 JOIN join_table2 jt2 ON jt1.key = jt2.key;
SELECT negate(negate(value)) AS double_negate FROM test_table;
SELECT DISTINCT id, negate(value) AS negated_value FROM test_table WHERE value < 0;