CREATE TABLE test_division (id UInt32, value_a Float64, value_b Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_division VALUES (1, 10.0, 2.0), (2, 20.5, 0.0), (3, 15.5, 1.5);
SELECT id, value_a / value_b AS result FROM test_division WHERE value_b != 0;
SELECT id, value_a / value_b AS division_result FROM test_division WHERE value_a > 0 AND value_b IS NOT NULL;
SELECT id, (SELECT AVG(value_a) FROM test_division) / (SELECT AVG(value_b) FROM test_division WHERE value_b != 0) AS avg_division FROM test_division;
CREATE TABLE test_multiplication (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_multiplication VALUES (1, 5.0), (2, 0.0), (3, -3.0);
SELECT id, value * (SELECT COUNT(*) FROM test_division) AS multiplied_value FROM test_multiplication;
SELECT id, (SELECT value_a FROM test_division WHERE id = 1) / (SELECT value_b FROM test_division WHERE id = 2) AS division_result;
SELECT id, case when value_b <> 0 then value_a / value_b else NULL end AS safe_division FROM test_division;
CREATE TABLE complex_test (id UInt32, group_id UInt32, total_value Float64) ENGINE = MergeTree() ORDER BY (group_id, id);
INSERT INTO complex_test VALUES (1, 1, 100.0), (2, 1, 50.0), (3, 2, 75.0);
SELECT group_id, SUM(total_value) / COUNT(*) AS average_value FROM complex_test GROUP BY group_id;
SELECT a.id, a.value_a / (SELECT MAX(b.value_b) FROM test_division b WHERE b.value_b > 0) AS normalized_value FROM test_division a WHERE a.value_a > 10;
SELECT a.id, adiv.b.value_b, a.value_a / NULLIF(b.value_b, 0) AS safe_division FROM test_division a JOIN test_division b ON a.id = b.id;