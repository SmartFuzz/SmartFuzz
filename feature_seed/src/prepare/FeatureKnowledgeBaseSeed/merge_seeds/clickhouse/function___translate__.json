CREATE TABLE test_strings (original String);
INSERT INTO test_strings VALUES ('abcdef'), ('Hello, World!'), ('123456'), ('!@#$%^&*()'), ('你好，世界！');
SELECT translate(original, 'abcdef', 'ABCDEF') AS translated FROM test_strings;
SELECT translate(original, 'Hello', 'hELLO') AS translated FROM test_strings;
SELECT translate(original, 'delor', 'DELOR') AS translated FROM test_strings WHERE original LIKE '%o%';
SELECT original, translate(original, ' ', '_') AS translated FROM test_strings;
SELECT translate(original, '!@#$', '####') AS translated FROM test_strings WHERE original ILIKE '%#%';
WITH (SELECT original FROM test_strings LIMIT 1) AS subquery SELECT translate(original, 'def', 'XYZ') FROM subquery;
CREATE TABLE test_results AS SELECT translate(original, 'abc', 'XYZ') AS translated FROM test_strings;
SELECT a.original, b.translated FROM test_strings AS a JOIN (SELECT original, translate(original, '123456', 'abcdef') AS translated FROM test_strings) AS b ON a.original = b.original;
SELECT translate(translate(original, 'abcdef', 'ABCDEF'), 'ABCDE', 'abcde') AS nested_translation FROM test_strings;
SELECT translate(original, 'delor', '') AS empty_string_translate FROM test_strings;
SELECT translate(NULL, 'abc', 'XYZ') AS null_case_translate;