CREATE TABLE bitmap_table1 (id UInt32, bitmap_col1 AggregateFunction(bitmapBuild, UInt32)) ENGINE = MergeTree() ORDER BY id;
CREATE TABLE bitmap_table2 (id UInt32, bitmap_col2 AggregateFunction(bitmapBuild, UInt32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO bitmap_table1 VALUES (1, bitmapBuild([1, 2, 3])), (2, bitmapBuild([2, 3, 4])), (3, bitmapBuild([5]));
INSERT INTO bitmap_table2 VALUES (1, bitmapBuild([3, 4, 5])), (2, bitmapBuild([1, 2])), (3, bitmapBuild([]));
SELECT bitmapToArray(bitmapAnd(bitmap_col1, bitmap_col2)) AS res FROM (SELECT id, bitmap_col1 FROM bitmap_table1) AS t1 JOIN (SELECT id, bitmap_col2 FROM bitmap_table2) AS t2 ON t1.id = t2.id;
SELECT bitmapToArray(bitmapAnd(bitmapBuild([]), bitmapBuild([1,2,3]))) AS res_empty_one;
SELECT bitmapToArray(bitmapAnd(bitmapBuild([1,2,3]), bitmapBuild([]))) AS res_empty_two;
SELECT bitmapToArray(bitmapAnd(bitmapBuild([1,2]), bitmapBuild([1,2]))) AS res_identical;
SELECT bitmapToArray(bitmapAnd(bitmapBuild([1,2]), bitmapBuild([2,3]))) AS res_partial;
SELECT id, bitmapToArray(bitmapAnd(bitmap_col1, bitmap_col2)) AS intersection FROM bitmap_table1 JOIN bitmap_table2 ON bitmap_table1.id = bitmap_table2.id WHERE bitmap_col1 != bitmapBuild([]) AND bitmap_col2 != bitmapBuild([]);