CREATE TABLE edges (edge UInt64);
INSERT INTO edges VALUES (1248204388774707197), (1248204388774707198), (1248204388774707199);
SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM edges;
SELECT edge, h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM edges WHERE edge > 1248204388774707190;
SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM edges WHERE edge < 1248204388774707199 ORDER BY origin DESC;
SELECT (SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) FROM edges LIMIT 1) AS origin LIMIT 1;
CREATE TABLE edge_info (id UInt32, edge UInt64);
INSERT INTO edge_info VALUES (1, 1248204388774707197), (2, 1248204388774707198);
SELECT e.id, h3GetOriginIndexFromUnidirectionalEdge(e.edge) AS origin FROM edge_info AS e JOIN edges AS ed ON e.edge = ed.edge;
SELECT COUNT(*), h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM edges GROUP BY origin HAVING COUNT(*) > 1;
WITH (SELECT edge FROM edges WHERE edge = 1248204388774707197) AS selected_edge SELECT h3GetOriginIndexFromUnidirectionalEdge(selected_edge) AS origin;
SELECT h3GetOriginIndexFromUnidirectionalEdge(CAST(edge AS UInt64)) AS origin FROM edges WHERE edge IS NOT NULL;
CREATE TABLE complex_edges (edge UInt64, edge_type String);
INSERT INTO complex_edges VALUES (1248204388774707197, 'type_a'), (1248204388774707198, 'type_b');
SELECT ce.edge_type, h3GetOriginIndexFromUnidirectionalEdge(ce.edge) AS origin FROM complex_edges AS ce WHERE ce.edge_type = 'type_a';
SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM (SELECT edge FROM edges WHERE edge BETWEEN 1248204388774707190 AND 1248204388774707199) AS sub;
CREATE TABLE edge_records AS SELECT edge FROM edges WHERE edge > 1248204388774707190;
SELECT h3GetOriginIndexFromUnidirectionalEdge(edge) AS origin FROM edge_records WHERE edge < 1248204388774707198;