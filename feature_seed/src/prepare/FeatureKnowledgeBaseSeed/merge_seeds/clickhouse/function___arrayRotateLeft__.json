CREATE TABLE test_array (arr Array(Int32));
INSERT INTO test_array VALUES ([1, 2, 3, 4, 5, 6]), ([7, 8, 9]), (null);
SELECT arrayRotateLeft(arr, 2) AS rotated FROM test_array;
SELECT arrayRotateLeft(arr, 0) AS rotated FROM test_array;
SELECT arrayRotateLeft(arr, length(arr)) AS rotated FROM test_array;
SELECT arrayRotateLeft(arr, -1) AS rotated FROM test_array;
SELECT arrayRotateLeft(arr, -3) AS rotated FROM test_array;
SELECT arrayRotateLeft(arr, -length(arr)) AS rotated FROM test_array;
SELECT arrayRotateLeft([arrayJoin(arr)], 3) AS rotated FROM test_array;
SELECT arrayRotateLeft((SELECT arrayAgg(arr) FROM test_array), 1) AS rotated;
SELECT arrayRotateLeft(arr, 5) AS rotated FROM (SELECT arr FROM test_array WHERE arr IS NOT NULL);
CREATE TABLE test_join (id Int32, arr Array(Int32));
INSERT INTO test_join VALUES (1, [1, 2, 3]), (2, [4, 5, 6]);
SELECT t1.id, arrayRotateLeft(t1.arr, 1) AS rotated FROM test_join AS t1 JOIN test_array AS t2 ON t1.id = 1;
SELECT arrayRotateLeft(arr, n) AS rotated FROM test_array, (SELECT 2 AS n) AS n_table;
SELECT arrayRotateLeft([arrayJoin(arr)], -2) AS rotated FROM test_array WHERE arr IS NOT NULL;