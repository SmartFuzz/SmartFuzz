CREATE TABLE test_dates (id UInt32, start_date Date);
INSERT INTO test_dates VALUES (1, toDate('2024-06-15'));
INSERT INTO test_dates VALUES (2, toDate('2024-12-31'));
SELECT id, start_date + toIntervalDay(5) AS result FROM test_dates;
SELECT id, start_date + toIntervalDay(-10) AS result FROM test_dates;
WITH toIntervalDay(15) AS interval_day SELECT start_date, start_date + interval_day AS result FROM test_dates;
SELECT id, start_date + toIntervalDay(0) AS result FROM test_dates;
WITH (SELECT AVG(id) FROM test_dates) AS avg_id SELECT start_date + toIntervalDay(avg_id) AS result FROM test_dates;
CREATE TABLE test_dates_2 (id UInt32, end_date Date);
INSERT INTO test_dates_2 VALUES (1, toDate('2024-06-30'));
INSERT INTO test_dates_2 VALUES (2, toDate('2024-12-31'));
SELECT a.id, a.start_date, b.end_date, a.start_date + toIntervalDay(b.id) AS new_date FROM test_dates a JOIN test_dates_2 b ON a.id = b.id;
WITH (SELECT MAX(id) FROM test_dates) AS max_id SELECT start_date + toIntervalDay(3.5) AS result FROM test_dates WHERE id = max_id;
SELECT start_date, start_date + toIntervalDay(CAST('10' AS Int32)) AS ten_days_added FROM test_dates;