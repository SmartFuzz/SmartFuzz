CREATE TABLE points (id UInt32, vector Tuple(Float64, Float64));
INSERT INTO points VALUES (1, (1, 2)), (2, (2, 3));
SELECT L1Distance((1, 2), (2, 3));
SELECT L1Distance(vector, (4, 5)) FROM points WHERE id = 1;
SELECT id, L1Distance(vector, (0, 0)) AS distance FROM points ORDER BY distance;
SELECT L1Distance((1, 1, 1), (2, 2, 2));
CREATE TABLE additional_points (vector Tuple(Float64, Float64) NOT NULL);
INSERT INTO additional_points VALUES ((3, 4)), ((5, 6));
SELECT id, L1Distance(p.vector, a.vector) AS distance FROM points p JOIN additional_points a ON p.id = 1;
SELECT L1Distance((0, 0), (0, 0));
SELECT L1Distance((1, -1), (1, 1));
SELECT L1Distance((1, 2, 3), (4, 5, 6)) AS distance;
-- Testing with three-dimensional vectors;
SELECT L1Distance(vector, (1, 1)) AS distance FROM points WHERE id IN (SELECT id FROM points WHERE id > 1);
SELECT L1Distance((1, 2), (NULL, 3));
SELECT L1Distance((1, 2), (2, NULL));
SELECT L1Distance((1, 2), (2, 3)) + L1Distance((2, 3), (3, 4)) AS total_distance;