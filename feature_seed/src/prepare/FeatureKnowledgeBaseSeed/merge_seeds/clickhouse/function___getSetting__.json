CREATE TABLE settings (name String, value String);
INSERT INTO settings VALUES ('custom_a', '123'), ('custom_b', '456'), ('custom_c', '789');
SELECT getSetting('custom_a');
SET custom_d = '100';
SELECT getSetting('custom_d');
SET custom_e = 'string_value';
SELECT getSetting('custom_e');
SELECT getSetting(name) FROM settings WHERE name LIKE 'custom_%';
CREATE TABLE users (id UInt32, name String, setting_name String);
INSERT INTO users VALUES (1, 'user1', 'custom_a'), (2, 'user2', 'custom_b');
SELECT user_id, getSetting(setting_name) FROM users JOIN settings ON users.setting_name = settings.name;
SET custom_f = 'true';
SELECT getSetting('custom_f') AS current_setting, COUNT(*) FROM settings;
SET custom_g = '3.14';
SELECT getSetting('custom_g') AS setting_value, ROUND(1.0 + getSetting('custom_g')) AS rounded_value;
SET custom_h = 'level_1';
SELECT setting_name, getSetting(setting_name) FROM users WHERE id = (SELECT MIN(id) FROM users);
CREATE TABLE temp_settings AS SELECT * FROM settings WHERE name = 'custom_b';
SELECT getSetting((SELECT name FROM temp_settings WHERE name = 'custom_b')) AS fetched_setting;