CREATE TABLE rectangles (id UInt64, lowPoint UInt64, highPoint UInt64);
INSERT INTO rectangles VALUES (1, 5178914411069187297, 5177056748191934217), (2, 5179062030687166815, 5177056748191934217);
SELECT s2RectIntersection(lowPoint, highPoint, lowPoint, highPoint) AS rectIntersection FROM rectangles WHERE id = 1;
WITH (SELECT lowPoint FROM rectangles WHERE id = 1) AS rect1Low, (SELECT highPoint FROM rectangles WHERE id = 1) AS rect1High, (SELECT lowPoint FROM rectangles WHERE id = 2) AS rect2Low, (SELECT highPoint FROM rectangles WHERE id = 2) AS rect2High SELECT s2RectIntersection(rect1Low, rect1High, rect2Low, rect2High) AS rectIntersection;
SELECT s2RectIntersection(0, 0, 0, 0) AS rectIntersection;
SELECT s2RectIntersection(5178914411069187297, 5177056748191934217, 5178914411069187297, 5177056748191934217) AS rectIntersection;
SELECT s2RectIntersection(5178914411069187297, 5177056748191934217, 5179062030687166815, 5177056748191934217) AS rectIntersection UNION ALL SELECT s2RectIntersection(0, 0, 0, 0) AS rectIntersection;
SELECT s2RectIntersection(lowPoint, highPoint, 5179062030687166815, 5177056748191934217) AS rectIntersection FROM rectangles ORDER BY id ASC LIMIT 1;
CREATE TABLE intersections (intersection UInt64);
INSERT INTO intersections SELECT s2RectIntersection(lowPoint, highPoint, 5179062030687166815, 5177056748191934217) FROM rectangles;
SELECT * FROM intersections WHERE intersection > 0;