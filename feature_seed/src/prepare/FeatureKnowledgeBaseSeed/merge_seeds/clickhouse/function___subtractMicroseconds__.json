CREATE TABLE test_dates (date_time DateTime64(6));
INSERT INTO test_dates VALUES (toDateTime('2024-01-01 00:00:00'));
SELECT subtractMicroseconds(date_time, 1000000) AS result FROM test_dates;
SELECT subtractMicroseconds(date_time, 500000) AS result_half FROM test_dates;
WITH subtracted1 AS (SELECT subtractMicroseconds(date_time, 1000000) AS sub1 FROM test_dates), subtracted2 AS (SELECT subtractMicroseconds(sub1, 500000) AS sub2 FROM subtracted1) SELECT sub1, sub2 FROM subtracted1 JOIN subtracted2 ON 1=1;
SELECT subtractMicroseconds(date_time, pow(10, 6)) AS result_pow FROM test_dates;
WITH num_microseconds AS (SELECT 1000000 AS num) SELECT subtractMicroseconds(date_time, num) AS result FROM test_dates JOIN num_microseconds ON 1=1;
CREATE TABLE date_strings (date_time_string String);
INSERT INTO date_strings VALUES ('2024-01-01 00:00:00');
SELECT subtractMicroseconds(date_time_string, 2000000) AS string_result FROM date_strings;
WITH date_query AS (SELECT date_time_string FROM date_strings) SELECT subtractMicroseconds(date_time, 3000000) AS complex_result FROM test_dates JOIN date_query ON 1=1;
SELECT subtractMicroseconds(toDateTime('2024-01-01 00:00:00'), -1000000) AS negative_subtract;
SELECT subtractMicroseconds(toDateTime('2024-01-01 00:00:00'), 0) AS zero_subtract;
WITH nested_sub AS (SELECT subtractMicroseconds(date_time, 1000000) AS inner_result FROM test_dates) SELECT inner_result FROM nested_sub;