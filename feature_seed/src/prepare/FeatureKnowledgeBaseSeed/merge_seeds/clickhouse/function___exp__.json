CREATE TABLE exp_test (id UInt32, value Float64);
INSERT INTO exp_test VALUES (1, -1.0), (2, 0.0), (3, 1.0), (4, 10.0);
SELECT exp(value) FROM exp_test;
SELECT id, exp(value) AS exp_value FROM exp_test WHERE value < 0;
SELECT id, exp(value) AS exp_value FROM exp_test WHERE value BETWEEN 0 AND 10;
SELECT id, exp(value) AS exp_value FROM exp_test ORDER BY exp_value DESC;
CREATE TABLE exp_test_subquery AS SELECT value FROM exp_test WHERE value > 0;
SELECT id, (SELECT exp(value) FROM exp_test_subquery) AS exp_result FROM exp_test WHERE id = 2;
CREATE TABLE exp_test_join (id UInt32, ref_id UInt32);
INSERT INTO exp_test_join VALUES (1, 1), (2, 2), (3, 3);
SELECT e.id, exp(e.value) AS exp_value, j.ref_id FROM exp_test e JOIN exp_test_join j ON e.id = j.id WHERE e.value < 1;
SELECT id, exp(value) AS exp_value FROM exp_test WHERE exp(value) < 1;
SELECT id, exp(value) + 2 AS adjusted_exp FROM exp_test;
SELECT id, exp(CASE WHEN value < 0 THEN value ELSE null END) AS conditional_exp FROM exp_test;
SELECT (SELECT exp(MAX(value)) FROM exp_test) AS max_exp_value, (SELECT exp(MIN(value)) FROM exp_test) AS min_exp_value;