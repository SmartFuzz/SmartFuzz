CREATE TABLE test_divide (a FLOAT, b FLOAT);
INSERT INTO test_divide VALUES (10, 2), (15, 0), (NULL, 5), (7, 3);
SELECT a, b, divide(a, b) AS result FROM test_divide;
SELECT a, b, divide(a, b) AS result FROM test_divide WHERE b <> 0;
SELECT a, b, divide(a, b) AS result FROM test_divide WHERE b IS NOT NULL;
CREATE TABLE test_nested_divide AS SELECT a, b, divide(a, b) AS result FROM test_divide;
SELECT result FROM (SELECT a, b, divide(a, b) AS result FROM test_divide) AS subquery WHERE result > 2;
SELECT t1.a, t2.b, divide(t1.a, t2.b) AS result FROM test_divide AS t1 JOIN test_divide AS t2 ON t1.a > t2.b;
SELECT a, b, divide(a, divide(b, 2)) AS nested_result FROM test_divide WHERE b != 0;
SELECT a, b, divide(a, b) AS result FROM test_divide WHERE divide(b, 5) < 1;