CREATE TABLE fqdn_test (id Int32, name String);
INSERT INTO fqdn_test VALUES (1, 'example.com'), (2, 'test.com');
SELECT fqdn();
SELECT FQDN() AS server_name FROM fqdn_test WHERE id = 1;
SELECT fqdn() FROM (SELECT id, name FROM fqdn_test) AS t;
SELECT FQDN() AS server, name FROM fqdn_test JOIN (SELECT id FROM fqdn_test WHERE id > 0) AS ids ON fqdn_test.id = ids.id;
SELECT fqdn() || ' - ' || name FROM fqdn_test WHERE LENGTH(name) > 0;
WITH (SELECT name FROM fqdn_test WHERE id = 1) AS domain_name SELECT FQDN(), domain_name;
SELECT FQDN() AS complete_host FROM (SELECT id FROM fqdn_test) AS ids GROUP BY complete_host;
CREATE TABLE fqdn_test2 (host String);
INSERT INTO fqdn_test2 VALUES ('example.com'), ('anotherdomain.com');
SELECT fqdn(), host FROM fqdn_test2 JOIN fqdn_test ON fqdn_test.id = 1;
SELECT FQDN() AS full_domain, COUNT(*) FROM fqdn_test GROUP BY full_domain;
SELECT fqdn() FROM fqdn_test WHERE id IN (SELECT id FROM fqdn_test WHERE name LIKE 'test%');