CREATE TABLE test_equal (id UInt32, value1 Float32, value2 Float32);
INSERT INTO test_equal VALUES (1, 1.0, 1.0), (2, 1.1, 1.1), (3, 1.2, 1.3), (4, NULL, NULL), (5, 0.0, 0.0);
SELECT id, value1, value2 FROM test_equal WHERE equals(value1, value2);
SELECT id FROM test_equal WHERE value1 = value2;
SELECT id FROM test_equal WHERE value1 == value2;
WITH (SELECT MAX(value1) FROM test_equal) AS max_value SELECT id FROM test_equal WHERE value2 = max_value;
CREATE TABLE test_left_join (id UInt32, value UInt32);
INSERT INTO test_left_join VALUES (1, 3), (2, 4), (3, 5);
SELECT a.id FROM test_equal AS a LEFT JOIN test_left_join AS b ON a.id = b.id WHERE a.value1 = b.value;
CREATE TABLE test_nested (id UInt32, group_id UInt32, score Float32);
INSERT INTO test_nested VALUES (1, 1, 10.0), (2, 1, 15.0), (3, 2, 20.0);
SELECT group_id FROM test_nested WHERE score = (SELECT MAX(score) FROM test_nested WHERE group_id = 1);