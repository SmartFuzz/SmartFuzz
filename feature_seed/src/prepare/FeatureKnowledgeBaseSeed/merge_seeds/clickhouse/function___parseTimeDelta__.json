SELECT parseTimeDelta('0s');
SELECT parseTimeDelta('9999999999s');
SELECT parseTimeDelta('1min');
SELECT parseTimeDelta('60s');
SELECT parseTimeDelta('1hr');
SELECT parseTimeDelta('1d');
SELECT parseTimeDelta('1.5hr');
SELECT parseTimeDelta('1yr');
SELECT parseTimeDelta('1yr2mo3d4h5m6s');
SELECT parseTimeDelta('1yr+1mo+1d');
SELECT parseTimeDelta('1.5d+4h+20min');
CREATE TABLE time_delays (id UInt32, duration String);
INSERT INTO time_delays VALUES (1, '1hr'), (2, '30min'), (3, '45s');
SELECT id, parseTimeDelta(duration) FROM time_delays WHERE parseTimeDelta(duration) > 1800;
SELECT id, parseTimeDelta('2yr + 3mo + ' || duration) FROM time_delays;
SELECT parseTimeDelta('1d + 12h + 10min') * 2 AS total_seconds;
SELECT (SELECT parseTimeDelta(duration) FROM time_delays WHERE id = 2) + parseTimeDelta('1h') AS final_duration;
CREATE TABLE other_time_delays (time_data String);
INSERT INTO other_time_delays VALUES ('1hr'), ('2min'), ('3s');
SELECT parseTimeDelta(time_data) AS seconds FROM other_time_delays WHERE seconds < 100;
SELECT parseTimeDelta('1mo + 10d') + (SELECT sum(parseTimeDelta(duration)) FROM time_delays) AS cumulative_duration;