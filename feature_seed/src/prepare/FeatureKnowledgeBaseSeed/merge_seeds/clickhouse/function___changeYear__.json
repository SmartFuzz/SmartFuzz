CREATE TABLE test_dates (event_date Date, event_time DateTime);
INSERT INTO test_dates VALUES (toDate('1980-07-15'), toDateTime('1980-07-15 12:00:00'));
INSERT INTO test_dates VALUES (toDate('1995-12-31'), toDateTime('1995-12-31 23:59:59'));
INSERT INTO test_dates VALUES (toDate('2005-02-28'), toDateTime('2005-02-28 14:30:00'));
INSERT INTO test_dates VALUES (toDate('2010-02-28'), toDateTime('2010-02-28 06:15:00'));
INSERT INTO test_dates VALUES (toDate('2020-02-29'), toDateTime('2020-02-29 22:45:00'));
SELECT changeYear(event_date, 2023) AS updated_date FROM test_dates;
SELECT changeYear(event_time, 2023) AS updated_time FROM test_dates;
SELECT changeYear(changeYear(event_date, 2025), 2030) AS double_changed_year FROM test_dates;
SELECT event_date, changeYear(event_date, 2000) AS new_year FROM test_dates WHERE event_date < toDate('2000-01-01');
SELECT event_time, changeYear(event_time, 1999) AS new_year_time FROM test_dates WHERE event_time >= toDateTime('2000-01-01 00:00:00');
SELECT (SELECT changeYear(event_date, 2023) FROM test_dates WHERE event_date < toDate('2000-01-01')) AS inner_query_result;
SELECT event_date, changeYear(event_date, 2077) AS future_event_date FROM test_dates WHERE event_date IN (SELECT event_date FROM test_dates WHERE event_date < toDate('2010-01-01')) ORDER BY future_event_date;
CREATE TABLE other_events (event_time DateTime32);
INSERT INTO other_events VALUES (toDateTime32('1995-12-31 14:30:00', 1)), (toDateTime32('2022-11-11 09:15:00', 1));
SELECT changeYear(e.event_time, 2023) AS updated_event_time FROM other_events e JOIN test_dates d ON e.event_time = d.event_time;
SELECT d.event_date, changeYear(d.event_date, 2023) AS updated_date, changeYear(e.event_time, 2023) AS updated_event_time FROM test_dates d FULL JOIN other_events e ON d.event_time = e.event_time WHERE d.event_date IS NOT NULL;