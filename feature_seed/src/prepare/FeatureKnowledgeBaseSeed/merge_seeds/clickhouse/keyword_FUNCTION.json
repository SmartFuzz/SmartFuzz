CREATE FUNCTION add_two_numbers(value1 Float64, value2 Float64) RETURNS Float64 AS (value1 + value2);
CREATE FUNCTION multiply_and_add(values Array(Float64), increment Float64) RETURNS Float64 AS (arraySum(values) + increment);
CREATE FUNCTION conditional_increment(value Float64) RETURNS Float64 AS (IF(value > 10, value + 1, value));
CREATE FUNCTION complex_calculation(a Float64, b Float64, c Float64) RETURNS Float64 AS (a * b + conditional_increment(c));
CREATE FUNCTION max_of_three(a Float64, b Float64, c Float64) RETURNS Float64 AS (greatest(a, greatest(b, c)));
CREATE TABLE test_table (id UInt32, value Float64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO test_table VALUES (1, 5.0), (2, 15.0), (3, 25.0);
SELECT id, add_two_numbers(value, 10) AS increased_value FROM test_table;
SELECT id, multiply_and_add([value, 5.0, 2.0], 3.0) AS total_value FROM test_table;
SELECT id, complex_calculation(value, 2.0, 10.0) AS final_value FROM test_table;
SELECT id, max_of_three(value, 20.0, 15.0) AS max_value FROM test_table;
CREATE FUNCTION calculate_discount(price Float64, discount Float64) RETURNS Float64 AS (price * (1 - discount / 100));
SELECT id, calculate_discount(value, 25.0) AS discounted_price FROM test_table;
CREATE TABLE another_table (user_id UInt32, purchase_value Float64) ENGINE = MergeTree() ORDER BY user_id;
INSERT INTO another_table VALUES (1, 45.0), (2, 30.0), (3, 15.0);
SELECT t.id, add_two_numbers(t.value, at.purchase_value) AS combined_value FROM test_table t JOIN another_table at ON t.id = at.user_id;
SELECT id, IF(value < 15, 'Low', 'High') AS value_category FROM test_table;