CREATE TABLE filesizes (id Int32, size_bytes Int64);
INSERT INTO filesizes VALUES (1, 1), (2, 1024), (3, 1048576), (4, 192851925);
SELECT id, size_bytes, formatReadableDecimalSize(size_bytes) AS formatted_size FROM filesizes;
SELECT id, size_bytes, formatReadableDecimalSize(size_bytes) AS formatted_size FROM (SELECT id, size_bytes FROM filesizes) AS fs;
SELECT sum(size_bytes) AS total_bytes, formatReadableDecimalSize(sum(size_bytes)) AS total_size FROM filesizes;
CREATE TABLE additional_filesizes (id Int32, size_bytes Int64);
INSERT INTO additional_filesizes VALUES (1, 512), (2, 2048), (3, 10485760);
SELECT a.id, a.size_bytes, formatReadableDecimalSize(a.size_bytes) AS formatted_size, b.size_bytes, formatReadableDecimalSize(b.size_bytes) AS additional_formatted_size FROM filesizes AS a JOIN additional_filesizes AS b ON a.id = b.id;
WITH (SELECT sum(size_bytes) FROM filesizes) AS total FROM dual SELECT formatReadableDecimalSize(total) AS readable_total;
SELECT id, size_bytes, formatReadableDecimalSize(size_bytes) AS formatted_size FROM (SELECT size_bytes FROM filesizes WHERE size_bytes > 0);
SELECT size_bytes, formatReadableDecimalSize(size_bytes) FROM filesizes WHERE formatReadableDecimalSize(size_bytes) LIKE '%MB';