CREATE TABLE salary (user String, salary Int64) ENGINE = Memory;
INSERT INTO salary VALUES ('Alice', 50000), ('Bob', 60000), ('Charlie', 40000), ('Dave', 60000);
SELECT argMin(user, salary) FROM salary;
CREATE TABLE test (a Nullable(String), b Nullable(Int64)) ENGINE = Memory AS SELECT * FROM VALUES((NULL, 0), ('a', 1), ('b', 2), ('c', 2), (NULL, NULL), ('d', NULL));
SELECT argMin(a, b), min(b) FROM test;
SELECT argMin(tuple(a), b) FROM test;
SELECT (argMin((a, b), b) as t).1 argMinA, t.2 argMinB FROM test;
SELECT argMin(a, b), min(b) FROM test WHERE a IS NULL and b IS NULL;
SELECT argMin(a, (b, a)), min(tuple(b, a)) FROM test;
SELECT argMin((a, b), (b, a)), min(tuple(b, a)) FROM test;
CREATE TABLE department (dept String, salary Int64) ENGINE = Memory;
INSERT INTO department VALUES ('HR', 45000), ('IT', 70000), ('Finance', 70000), ('Marketing', 40000);
SELECT argMin(dept, salary) FROM department GROUP BY salary;
CREATE TABLE project (name String, cost Int64) ENGINE = Memory;
INSERT INTO project VALUES ('Project A', 100000), ('Project B', 80000), ('Project C', 120000);
SELECT argMin(name, cost) FROM project;
SELECT argMin(u.user, s.salary) FROM salary s JOIN (SELECT user FROM salary WHERE salary > 50000) u ON s.user = u.user;
SELECT argMin(user, salary) FROM (SELECT user, salary FROM salary WHERE salary > 45000) AS filtered;
SELECT argMin(a, b) FROM (SELECT a, b FROM test WHERE b IS NOT NULL) AS filtered_test;