INSERT INTO s2_test VALUES (1, 5178914411069187297, 5177056748191934217), (2, 5178914411069187000, 5177056748191900000);
SELECT s2RectAdd(point_low, point_high, 5179056748191934217) AS rectAdd FROM s2_test WHERE id = 1;
SELECT s2RectAdd(s2PointLow, s2PointHigh, 5178900000000000000) FROM (SELECT point_low AS s2PointLow, point_high AS s2PointHigh FROM s2_test WHERE id = 2);
