CREATE TABLE test_uptime (id Int32);
INSERT INTO test_uptime VALUES (1), (2), (3);
SELECT uptime() AS Uptime FROM test_uptime;
SELECT COUNT(*) AS UptimeCount, uptime() AS Uptime FROM test_uptime;
SELECT uptime() AS Uptime, id FROM test_uptime WHERE id < 2;
SELECT uptime() AS Uptime, (SELECT AVG(id) FROM test_uptime) AS AvgID FROM test_uptime;
WITH uptime() AS server_uptime SELECT AVG(id) as AverageID, server_uptime FROM test_uptime;
SELECT id, uptime() AS Uptime FROM test_uptime CROSS JOIN (SELECT uptime() AS server_uptime) AS server;
CREATE TABLE uptime_distribution (shard UInt32);
INSERT INTO uptime_distribution VALUES (1), (2), (3);
SELECT uptime() AS UptimePerShard FROM uptime_distribution GROUP BY shard;
SELECT MAX(uptime()) AS MaxUptime, MIN(uptime()) AS MinUptime FROM (SELECT uptime() AS Uptime FROM test_uptime) AS sub;
SELECT EXISTS(SELECT * FROM test_uptime WHERE uptime() > 0) AS UptimeExists;
SELECT id, uptime() AS Uptime FROM test_uptime WHERE uptime() > (SELECT AVG(uptime()) FROM (SELECT uptime() AS Uptime FROM test_uptime));