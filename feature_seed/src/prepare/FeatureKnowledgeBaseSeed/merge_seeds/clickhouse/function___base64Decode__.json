CREATE TABLE base64_test (encoded_str String);
INSERT INTO base64_test VALUES ('Y2xpY2tob3VzZQ=='), ('U29tZSByYW5kb20gZGVjb2RlZA=='), ('SGVsbG8gV29ybGQ=');
SELECT base64Decode(encoded_str) FROM base64_test;
SELECT base64Decode(concat('U29tZSByYW5kb20gZGVjb20=', '==')) FROM base64_test;
SELECT base64Decode('') AS empty_decode;
SELECT base64Decode('aGVsbG8=') AS single_char_decode;
SELECT base64Decode('VGhpcyBpcyBhIHRlc3Q=') AS normal_decode;
SELECT base64Decode('4pyTIMOg4pi44p2+PC9zdmc+') AS decode_special_chars;
SELECT base64Decode(encoded_str) AS decoded FROM base64_test WHERE encoded_str LIKE 'Y%';
CREATE TABLE nested_test AS SELECT base64Decode('U29tZSByYW5kb20gZGVjb2RlZA==') AS out_str;
SELECT t1.encoded_str, t2.out_str FROM base64_test t1 JOIN nested_test t2 ON true;
SELECT COUNT(*) FROM (SELECT base64Decode(encoded_str) AS decoded FROM base64_test) AS decoded_table;
SELECT base64Decode(encoded_str) as decoded FROM base64_test WHERE encoded_str IN (SELECT encoded_str FROM base64_test LIMIT 1);
SELECT base64Decode('SW5jb3JyZWN0IHZhbHVlCg==') AS multi_line_text;
SELECT base64Decode(base64Encode('Hello World')) AS reverse_encoded;
SELECT base64Decode(NULL) AS null_decode;
CREATE TABLE more_tests (str_encoded String) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO more_tests VALUES ('UGxheWZvb3Q='), ('8J+YgPCfjIs='), ('VGVzdCBzdHJpbmc=');
SELECT base64Decode(str_encoded) FROM more_tests;
SELECT IF(isNull(base64Decode(str_encoded)), 'Invalid', 'Valid') AS validity FROM more_tests;