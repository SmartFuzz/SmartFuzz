CREATE TABLE test_bucket (value Float32);
INSERT INTO test_bucket VALUES (10.15), (0), (-10), (25), (15), (-20);
SELECT widthBucket(value, -8.6, 23, 18) FROM test_bucket;
SELECT widthBucket(10.15, -8.6, 23, 18) AS bucket_number;
SELECT widthBucket(value, low, high, count) FROM (SELECT value, -8.6 AS low, 23 AS high, 18 AS count FROM test_bucket);
SELECT widthBucket(25, -8.6, 23, 18) AS bucket_number;
-- Should return count + 1;
SELECT widthBucket(-10, -8.6, 23, 18) AS bucket_number;
-- Should return 0;
CREATE TABLE range_table (low Float32, high Float32, count UInt32);
INSERT INTO range_table VALUES (-10, 10, 5), (0, 50, 20), (15, 30, 7);
SELECT widthBucket(5, low, high, count) FROM range_table;
SELECT a.value, widthBucket(a.value, b.low, b.high, b.count) AS bucket_number FROM test_bucket AS a JOIN range_table AS b ON a.value < b.high;
WITH (SELECT COUNT(*) FROM test_bucket) AS total_values SELECT widthBucket(5, -10, 10, total_values) AS bucket_number;
SELECT widthBucket(15, low, high, 0) FROM range_table;
-- This should fail due to count being zero;