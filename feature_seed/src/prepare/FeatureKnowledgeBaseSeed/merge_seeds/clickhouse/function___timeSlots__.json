CREATE TABLE time_slots_test (start_time DateTime, duration UInt32, size UInt32);
INSERT INTO time_slots_test VALUES (toDateTime('2012-01-01 12:20:00'), 600, 1800);
INSERT INTO time_slots_test VALUES (toDateTime('1980-12-12 21:01:02'), 600, 299);
INSERT INTO time_slots_test VALUES (toDateTime64('1980-12-12 21:01:02.1234', 4), toDecimal64(600.1, 1), toDecimal64(299, 0));
SELECT timeSlots(start_time, duration, size) FROM time_slots_test WHERE duration >= 0;
SELECT timeSlots(toDateTime('2023-10-01 10:00:00'), toUInt32(86400), toUInt32(3600));
SELECT timeSlots(toDateTime64('2023-10-15 15:45:30.567', 3), toDecimal64(1200.0, 1), toDecimal64(1800.0, 0));
SELECT timeSlots(toDateTime('1999-12-31 23:59:59'), toUInt32(60), toUInt32(1));
SELECT count(*) FROM (SELECT timeSlots(toDateTime('2022-01-01 00:00:00'), 7200, 3600) AS slot FROM system.tables);
SELECT timeSlots(toDateTime64('2021-01-01 12:00:00.123456', 6), toDecimal64(300.5, 1));
SELECT DISTINCT timeSlots(toDateTime('2022-01-01 00:00:00'), toUInt32(5400), 900) FROM (SELECT * FROM time_slots_test ORDER BY start_time LIMIT 10) AS limited;