CREATE TABLE test_arrays (id UInt32, arr Array(Int32));
INSERT INTO test_arrays VALUES (1, [1, 2]), (2, [3, 4]), (3, [5, 6]);
SELECT arrayConcat(arr, [7, 8]) AS concatenated_arr FROM test_arrays WHERE id = 1;
SELECT arrayConcat([1, 2], [3, 4], arrayConcat([5, 6], [7, 8])) AS res;
SELECT arrayConcat([1, 2], [3, 4], [5]) AS simple_concat;
SELECT arrayConcat() AS empty_concat;
SELECT arrayConcat(arr, [9]) AS extended_arr FROM test_arrays WHERE id IN (SELECT id FROM test_arrays WHERE id < 3);
SELECT arrayConcat((SELECT arr FROM test_arrays WHERE id = 1), (SELECT arr FROM test_arrays WHERE id = 2)) AS subquery_concat;
SELECT id, arrayConcat(arr, [1, 2, 3]) AS new_arr FROM test_arrays;
SELECT arrayConcat(arr, arrayFill(0, 1, 3)) AS filled_concat FROM test_arrays WHERE id = 2;
CREATE TABLE test_arrays_2 (group_id UInt32, nested_arr Array(Array(Int32));
INSERT INTO test_arrays_2 VALUES (1, [[1,2], [3,4]]), (2, [[5,6], [7,8]]);
SELECT arrayConcat(arrayConcat(nested_arr[1], nested_arr[2]), [9]) AS concatenated_nested FROM test_arrays_2;
SELECT arrayConcat(arr, arrayConcat([9, 10], [11, 12])) AS complex_concat FROM test_arrays WHERE id = 3;
SELECT arrayConcat((SELECT arr FROM test_arrays WHERE id = 1), (SELECT arr FROM test_arrays WHERE id = 2), [13, 14]) AS combined_concat;
SELECT arrayConcat([NULL], [1, 2]) AS with_nulls;
SELECT arrayConcat(arrayMap(x -> x + 1, [1, 2]), [3, 4]) AS mapped_concat;