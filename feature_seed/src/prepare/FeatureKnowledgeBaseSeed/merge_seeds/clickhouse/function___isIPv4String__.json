CREATE TABLE ip_addresses (addr String);
INSERT INTO ip_addresses VALUES ('0.0.0.0'), ('127.0.0.1'), ('192.168.1.1'), ('255.255.255.255'), ('300.300.300.300'), ('::1'), ('::ffff:127.0.0.1');
SELECT addr, isIPv4String(addr) FROM ip_addresses;
SELECT addr, isIPv4String(addr) FROM ip_addresses WHERE isIPv4String(addr) = 1;
SELECT addr, isIPv4String(addr) AS is_ipv4 FROM (SELECT ['0.0.0.0', '255.255.255.255', '192.168.0.1', '256.256.256.256'] AS addr) ARRAY JOIN addr;
WITH (SELECT addr FROM ip_addresses WHERE isIPv4String(addr) = 1) AS valid_ips SELECT valid_ips.addr, isIPv4String(valid_ips.addr) FROM valid_ips;
SELECT addr, isIPv4String(addr) FROM ip_addresses UNION ALL SELECT addr, isIPv4String(addr) FROM (SELECT ['::1', '::ffff:192.168.1.1', '1.1.1.1', '172.16.254.1'] AS addr) ARRAY JOIN addr;
CREATE TABLE temp_ips AS SELECT addr FROM (SELECT ['1.1.1.1', '255.255.255.255', '::1'] AS addr) ARRAY JOIN addr;
SELECT temp_ips.addr, isIPv4String(temp_ips.addr) FROM temp_ips WHERE temp_ips.addr LIKE '%.%.%.%';
SELECT addr, isIPv4String(addr) FROM ip_addresses WHERE isIPv4String(addr) = 0 AND addr NOT IN (SELECT addr FROM ip_addresses WHERE isIPv4String(addr) = 1);