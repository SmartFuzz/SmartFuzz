CREATE TABLE t (id UInt64, num Nullable(Int32)) ENGINE = MergeTree() ORDER BY id;
INSERT INTO t VALUES (1, 1), (2, 2), (3, NULL), (4, 2), (5, 3);
SELECT count() FROM t;
SELECT count(num) FROM t;
SELECT count(DISTINCT num) FROM t;
SELECT id, count(num) FROM t GROUP BY id;
SELECT id, count() FROM (SELECT id FROM t WHERE num IS NOT NULL) AS subquery GROUP BY id;
CREATE TABLE t2 (id UInt64, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO t2 VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Alice'), (4, NULL);
SELECT count(name) FROM t2 WHERE name IS NOT NULL;
SELECT count(DISTINCT name) FROM t2;
SELECT t.id, count(t.num) FROM t JOIN t2 ON t.id = t2.id GROUP BY t.id;
SELECT count(*) FROM (SELECT * FROM t WHERE num IS NULL);
SELECT count(num) FROM (SELECT num FROM t WHERE num >= 1) AS filtered;
SELECT count(num) FROM (SELECT id, num FROM t ORDER BY id LIMIT 3) AS limited;
SELECT count() FROM t WHERE (id % 2) = 0;
SELECT count(DISTINCT num) FROM (SELECT num FROM t WHERE num IS NOT NULL) AS distinct_nums;
SELECT count(*) FROM (SELECT t.id, t.num FROM t JOIN t2 ON t.id = t2.id WHERE t.num IS NOT NULL);
CREATE TEMPORARY TABLE t3 (value Nullable(Int32)) ENGINE = Memory;
INSERT INTO t3 VALUES (NULL), (NULL), (1), (2), (2);
SELECT count(value) FROM t3;
SELECT count(DISTINCT value) FROM t3;