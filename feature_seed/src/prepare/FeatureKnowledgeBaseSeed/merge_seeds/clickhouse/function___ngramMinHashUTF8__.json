CREATE TABLE test_strings (id UInt32, value String);
INSERT INTO test_strings VALUES (1, 'ClickHouse'), (2, 'Clickhouse'), (3, 'clickhouse'), (4, 'ClickHouse ClickHouse'), (5, 'ClickHouse 12345');
SELECT ngramMinHashUTF8(value, 3, 6) FROM test_strings;
SELECT ngramMinHashUTF8(value) AS hash_tuple FROM test_strings WHERE id < 3;
SELECT t1.id, ngramMinHashUTF8(t1.value, ngramsize.ngramsize, hashnum.hashnum) FROM test_strings AS t1 JOIN (SELECT 3 AS ngramsize, 6 AS hashnum) AS params ON t1.id = 1;
SELECT ngramMinHashUTF8(value, 5, 10) FROM (SELECT value FROM test_strings WHERE id = 3) AS filtered;
CREATE TABLE string_hashes AS SELECT id, ngramMinHashUTF8(value) AS hash_tuple FROM test_strings;
SELECT * FROM string_hashes WHERE hash_tuple.1 = (SELECT hash_tuple.1 FROM string_hashes WHERE id = 1);
SELECT t1.value, ngramMinHashUTF8(t1.value, 1, 1) AS new_hash FROM test_strings AS t1 WHERE EXISTS (SELECT 1 FROM test_strings AS t2 WHERE t1.value != t2.value);
SELECT ngramMinHashUTF8(value, 4, 4) FROM test_strings WHERE length(value) > 10;
SELECT id, ngramMinHashUTF8(value, 2, 2) FROM test_strings WHERE value LIKE '%House%' OR value LIKE '%click%';