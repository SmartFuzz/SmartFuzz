CREATE TABLE morton_test (code UInt64) ENGINE = MergeTree() ORDER BY code;
INSERT INTO morton_test VALUES (1), (2), (3), (4), (5), (6), (7), (8), (32768), (4294967295);
SELECT mortonDecode(1, 0) FROM morton_test;
SELECT mortonDecode(3, 53) FROM morton_test;
SELECT mortonDecode(8, 0) FROM morton_test;
SELECT untuple(mortonDecode(2, code)) FROM morton_test;
CREATE TABLE morton_numbers (n1 UInt32, n2 UInt32, n3 UInt16, n4 UInt16, n5 UInt8, n6 UInt8, n7 UInt8, n8 UInt8) ENGINE = MergeTree() ORDER BY n1;
INSERT INTO morton_numbers VALUES (1, 2, 3, 4, 5, 6, 7, 8);
SELECT untuple(mortonDecode(8, mortonEncode(n1, n2, n3, n4, n5, n6, n7, n8))) FROM morton_numbers;
WITH (mortonDecode(3, 53) AS result) SELECT result;
SELECT a.n1, a.n2, mortonDecode(2, b.code) FROM morton_numbers AS a JOIN morton_test AS b ON a.n1 = 1;
SELECT count(*) FROM morton_numbers WHERE untuple(mortonDecode(3, 53)) IS NOT NULL;
SELECT coalesce(mortonDecode(4, code), tuple(0, 0)) FROM morton_test;
CREATE TABLE complex_morton (id UInt32, code UInt64) ENGINE = MergeTree() ORDER BY id;
INSERT INTO complex_morton SELECT generateRandomUInt32(), (number + 1) * (2 ^ (3 + number)) FROM system.numbers LIMIT 8;
SELECT untuple(mortonDecode(4, code)) FROM complex_morton WHERE id < 5;
SELECT a.id, untuple(mortonDecode(2, b.code)) FROM complex_morton AS a JOIN morton_test AS b ON a.id = 1;
SELECT sum(mortonDecode(1, code)[1]) FROM morton_test GROUP BY code;