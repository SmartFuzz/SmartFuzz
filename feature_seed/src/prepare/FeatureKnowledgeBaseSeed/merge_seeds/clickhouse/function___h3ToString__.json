CREATE TABLE h3_data (index UInt64);
INSERT INTO h3_data VALUES (617420388352917503), (0), (18446744073709551615);
SELECT h3ToString(index) AS h3_string FROM h3_data;
SELECT h3ToString(0) AS h3_string_zero;
SELECT h3ToString(18446744073709551615) AS h3_string_max;
SELECT h3ToString(index) AS h3_string FROM h3_data WHERE index < 1000;
SELECT h3ToString(index) AS h3_string FROM (SELECT index FROM h3_data WHERE index > 0) AS subquery;
CREATE TABLE additional_data (extra UInt64);
INSERT INTO additional_data VALUES (617420388352917503), (12345678901234567890);
SELECT h3ToString(t.index) AS h3_string FROM h3_data AS t JOIN additional_data AS a ON t.index = a.extra;
SELECT h3ToString(t.index) AS h3_string FROM h3_data AS t WHERE EXISTS (SELECT 1 FROM additional_data AS a WHERE a.extra = t.index);
SELECT h3ToString(index + 1) AS h3_string_incremented FROM h3_data;
SELECT h3ToString(index) AS h3_string FROM (SELECT index FROM h3_data ORDER BY index LIMIT 5) AS limited_indexes;