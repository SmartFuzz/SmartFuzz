CREATE TABLE test_table (val UInt8, val_float Float32, val_string String, val_date Date);
INSERT INTO test_table VALUES (255, 1.5, 'test', '2023-10-01');
INSERT INTO test_table VALUES (0, 0.0, 'test', '1970-01-01');
INSERT INTO test_table VALUES (1, 4.5, 'hello', '2023-12-31');
SELECT val, reinterpretAsUInt32(val) AS reinterpret_val FROM test_table;
SELECT val_float, reinterpretAsUInt32(val_float) AS reinterpret_val_float FROM test_table;
SELECT val_string, reinterpretAsUInt32(val_string) AS reinterpret_val_string FROM test_table;
SELECT val_date, reinterpretAsUInt32(val_date) AS reinterpret_val_date FROM test_table;
SELECT val, val_float, reinterpretAsUInt32(val) + reinterpretAsUInt32(val_float) AS combined FROM test_table;
SELECT val, reinterpretAsUInt32(val) AS reinterpret_val, reinterpretAsUInt32(val_float) AS reinterpret_float_val FROM test_table WHERE reinterpretAsUInt32(val) > 0;
WITH (SELECT toUInt32(val) FROM test_table WHERE val > 0) AS subquery SELECT reinterpretAsUInt32(val) AS reinterpret_val FROM subquery;
CREATE TABLE another_table (col1 UInt16, col2 UInt32);
INSERT INTO another_table VALUES (1000, 5000);
SELECT a.col1, reinterpretAsUInt32(a.col1) AS reinterpret_col1, b.col2 FROM another_table a JOIN test_table b ON a.col1 = toUInt16(b.val);
SELECT val, reinterpretAsUInt32(val) AS reinterpret_val FROM test_table UNION ALL SELECT reinterpretAsUInt32(val_float) AS reinterpret_val FROM test_table;
SELECT reinterpretAsUInt32(val), reinterpretAsUInt32(val_float), reinterpretAsUInt32(val_string) FROM test_table WHERE val > 128 AND val_float < 10.0;