CREATE TABLE dates_table (event_date Date);
INSERT INTO dates_table (event_date) VALUES (yesterday());
SELECT event_date FROM dates_table WHERE event_date = yesterday();
SELECT event_date, COUNT(*) FROM dates_table GROUP BY event_date HAVING event_date = yesterday();
CREATE TABLE another_table (event_id UInt32, event_date Date DEFAULT yesterday());
INSERT INTO another_table (event_id) VALUES (1), (2), (3);
SELECT event_id FROM another_table WHERE event_date = yesterday();
WITH yesterday_date AS (SELECT yesterday() AS y) SELECT COUNT(*) FROM dates_table, yesterday_date WHERE event_date = y;
CREATE TABLE user_actions (user_id UInt32, action_date Date);
INSERT INTO user_actions (user_id, action_date) VALUES (1, yesterday()), (2, yesterday()), (3, yesterday() - 1);
SELECT user_id FROM user_actions u JOIN dates_table d ON u.action_date = d.event_date WHERE d.event_date = yesterday();
SELECT MAX(action_date) FROM user_actions WHERE action_date < yesterday();
CREATE TABLE possible_events (event_name String, event_date Date);
INSERT INTO possible_events (event_name, event_date) VALUES ('Event A', yesterday()), ('Event B', yesterday() - 1);
SELECT event_name FROM possible_events WHERE event_date = yesterday();
CREATE TABLE complex_table (id UInt32, created_at DateTime DEFAULT now());
INSERT INTO complex_table (id) VALUES (1), (2), (3);
SELECT id FROM complex_table WHERE created_at < yesterday();
SELECT id FROM complex_table WHERE created_at = yesterday() AND id IN (SELECT id FROM another_table);
WITH yesterday_value AS (SELECT yesterday() AS y) SELECT y, COUNT(*) FROM complex_table, yesterday_value WHERE created_at = y GROUP BY y;