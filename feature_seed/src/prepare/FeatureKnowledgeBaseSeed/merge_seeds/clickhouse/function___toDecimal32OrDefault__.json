CREATE TABLE test_table (value String);
INSERT INTO test_table VALUES ('0.0001'), ('1234567890'), ('1.15'), ('9999999999'), ('0.1'), ('-0.1'), ('NaN'), ('Inf'), ('0xc0fe');
SELECT toDecimal32OrDefault(value, 5, CAST('0', 'Decimal32(5)')) AS test_output FROM test_table;
WITH subquery AS (SELECT value FROM test_table WHERE toDecimal32OrDefault(value, 5) > 0) SELECT COUNT(*) FROM subquery;
CREATE TABLE another_table (num String);
INSERT INTO another_table VALUES ('0.9999999999'), ('10000000000'), ('-9999999999'), ('123.456789'), ('Inf');
SELECT a.value, toDecimal32OrDefault(a.value, 5, CAST('1', 'Decimal32(5)')) AS decimal_output, b.num FROM test_table AS a JOIN another_table AS b ON a.value = b.num;
SELECT toDecimal32OrDefault(toString(SUM(value)), 3, CAST('-1', 'Decimal32(3)')) FROM (SELECT 0.001 AS value UNION ALL SELECT '0.002');
SELECT toDecimal32OrDefault(toString(1.999999999), 0) AS decimal_result, toTypeName(decimal_result) FROM (SELECT 1.999999999) AS derived_table;
SELECT toDecimal32OrDefault('123.4567', 4) AS valid_decimal, toDecimal32OrDefault('9999999999', 0, CAST('999', 'Decimal32(0)')) AS overflow_decimal, toDecimal32OrDefault('0.1', 1) AS small_decimal FORMAT Vertical;