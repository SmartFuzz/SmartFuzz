CREATE TABLE test_dates (date_string String);
INSERT INTO test_dates VALUES ('2022-12-30 13:44:17');
INSERT INTO test_dates VALUES ('invalid-date');
INSERT INTO test_dates VALUES ('');
SELECT toDateTimeOrNull(date_string) FROM test_dates;
SELECT toDateTimeOrNull(date_string), toDateTimeOrNull('2023-01-01 00:00:00') FROM test_dates;
SELECT COUNT(*) FROM (SELECT toDateTimeOrNull(date_string) AS datetime FROM test_dates) AS subquery WHERE datetime IS NULL;
SELECT t.date_string, toDateTimeOrNull(t.date_string) AS converted_date FROM test_dates AS t JOIN (SELECT '2022-12-30 13:44:17' AS fixed_date) AS fixed ON t.date_string = fixed.fixed_date;
CREATE TABLE additional_dates (date_string String) ENGINE = MergeTree() ORDER BY date_string;
INSERT INTO additional_dates VALUES ('2022-01-01 10:00:00'), ('2022-12-31 23:59:59'), ('2023-02-30 14:00:00');
SELECT toDateTimeOrNull(date_string) FROM additional_dates WHERE toDateTimeOrNull(date_string) IS NOT NULL;
SELECT arrayJoin([toDateTimeOrNull('2022-01-01 10:00:00'), toDateTimeOrNull('2022-12-31 23:59:59'), toDateTimeOrNull('invalid')]) AS converted_dates;
SELECT (SELECT toDateTimeOrNull(date_string) FROM test_dates) AS sub_query_date_time WHERE sub_query_date_time IS NOT NULL;