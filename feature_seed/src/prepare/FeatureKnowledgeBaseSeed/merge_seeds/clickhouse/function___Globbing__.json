CREATE TABLE example01 (id Int32, value Float64);
CREATE TABLE example02 (id Int32, value Float64);
INSERT INTO example01 VALUES (1, 123.45), (2, 678.90);
INSERT INTO example02 VALUES (1, 234.56), (2, 789.01);
SELECT * FROM example0{1,2};
SELECT * FROM example0{1..2};
SELECT * FROM example{01..03};
CREATE TABLE example03 (id Int32, name String) ENGINE = MergeTree() ORDER BY id;
INSERT INTO example03 VALUES (1, 'A'), (2, 'B');
SELECT * FROM example0{1..3} WHERE id IN (SELECT id FROM example03 WHERE name = 'A');
CREATE TABLE example04 (id Int32) ENGINE = ReplicatedMergeTree('/clickhouse/tables/{shard}/example04', '{replica}') ORDER BY id;
INSERT INTO example04 VALUES (1), (2);
SELECT * FROM example0{1|2}-1;
SELECT * FROM example0{1..2}-1 WHERE id = (SELECT MAX(id) FROM example04);
WITH (SELECT AVG(value) FROM example01) AS avg_value, (SELECT MIN(value) FROM example02) AS min_value SELECT avg_value, min_value;
SELECT * FROM example0{1|2}-{1|2};
CREATE TABLE example05 AS example03 ENGINE = MergeTree() ORDER BY id;
INSERT INTO example05 SELECT * FROM example0{1,2};