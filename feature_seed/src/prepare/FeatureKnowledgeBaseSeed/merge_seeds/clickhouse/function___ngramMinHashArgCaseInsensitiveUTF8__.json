CREATE TABLE test_strings (input_string String);
INSERT INTO test_strings VALUES ('ClickHouse');
INSERT INTO test_strings VALUES ('Fuzz Testing');
INSERT INTO test_strings VALUES ('n-gram functionality tests');
INSERT INTO test_strings VALUES ('Case Insensitivity example');
SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 3, 6) FROM test_strings;
SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string) FROM test_strings;
SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 1) FROM test_strings;
SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 25, 25) FROM (SELECT input_string FROM test_strings WHERE input_string LIKE '%Testing%');
SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 5, 10) FROM test_strings WHERE input_string NOT LIKE '%example%';
SELECT input_string, ngramMinHashArgCaseInsensitiveUTF8(input_string, 4, 6) AS ngram_hashes FROM test_strings WHERE length(input_string) > 15;
WITH (SELECT input_string FROM test_strings WHERE input_string LIKE '%n-gram%') AS subquery SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 3) FROM subquery;
CREATE TABLE ngram_results AS SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 2) FROM test_strings;
INSERT INTO ngram_results SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 4, 5) FROM test_strings WHERE length(input_string) < 20;
SELECT COUNT(*) FROM ngram_results;
SELECT ngramMinHashArgCaseInsensitiveUTF8(input_string, 3, 6) FROM test_strings GROUP BY input_string HAVING COUNT(*) > 1;