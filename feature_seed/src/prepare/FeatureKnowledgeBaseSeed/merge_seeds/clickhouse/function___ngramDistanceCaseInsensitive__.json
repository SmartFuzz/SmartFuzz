CREATE TABLE test_strings (haystack String, needle String);
INSERT INTO test_strings VALUES ('ClickHouse', 'clickhouse');
INSERT INTO test_strings VALUES ('testing', 'TESTING');
INSERT INTO test_strings VALUES ('fuzzy logic', 'Fuzzy Logic');
INSERT INTO test_strings VALUES ('OpenAI', 'openai');
INSERT INTO test_strings VALUES ('12345', '12345');
INSERT INTO test_strings VALUES ('aBcDeF', 'abcdef');
INSERT INTO test_strings VALUES ('space test', 'SPACE TEST');
SELECT ngramDistanceCaseInsensitive(haystack, needle) AS similarity FROM test_strings WHERE similarity >= 0.5;
SELECT ngramDistanceCaseInsensitive('hello world', 'HELLO WORLD') AS similarity;
SELECT ngramDistanceCaseInsensitive('Case Sensitive Test', 'case insensitive test') AS similarity FROM test_strings;
SELECT ngramDistanceCaseInsensitive(haystack, needle) AS similarity FROM test_strings WHERE haystack LIKE 'Click%';
SELECT ngramDistanceCaseInsensitive(haystack, needle) FROM (SELECT haystack, needle FROM test_strings WHERE haystack != needle) AS subquery;
SELECT haystack, needle, ngramDistanceCaseInsensitive(haystack, needle) AS distance FROM test_strings WHERE ngramDistanceCaseInsensitive(haystack, needle) < 0.3;
SELECT AVG(ngramDistanceCaseInsensitive(haystack, needle)) AS average_similarity FROM test_strings;
SELECT ngramDistanceCaseInsensitive('abc123', 'ABC123') AS case_insensitive_similarity, ngramDistanceCaseInsensitive('abc123', 'abc123') AS case_sensitive_similarity;
SELECT ngramDistanceCaseInsensitive(haystack, 'exactmatch') AS distance FROM (SELECT haystack FROM test_strings) AS subquery;
SELECT ngramDistanceCaseInsensitive(CONCAT('prefix_', haystack), needle) AS modified_distance FROM test_strings;