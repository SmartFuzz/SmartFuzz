CREATE TABLE test_dates (id UInt32, timestamp String);
INSERT INTO test_dates VALUES (1, '65'), (2, 'A'), (3, '100000'), (4, '0'), (5, '2021-01-01 00:00:00');
SELECT reinterpretAsDateTime(timestamp) FROM test_dates WHERE id = 1;
SELECT reinterpretAsDateTime(timestamp) FROM test_dates WHERE id IN (2, 3);
SELECT reinterpretAsDateTime(timestamp) FROM test_dates WHERE id NOT IN (4);
SELECT reinterpretAsDateTime(timestamp) AS event_time FROM test_dates WHERE event_time < reinterpretAsDateTime('0');
WITH (SELECT reinterpretAsDateTime('60') AS valid_time) AS subquery SELECT id, valid_time FROM test_dates WHERE reinterpretAsDateTime(timestamp) > valid_time;
CREATE TABLE filtered_dates AS SELECT id, reinterpretAsDateTime(timestamp) AS event_time FROM test_dates WHERE reinterpretAsDateTime(timestamp) IS NOT NULL;
SELECT d.id, d.event_time FROM filtered_dates d JOIN (SELECT 1 AS id) AS j ON d.id = j.id;
SELECT reinterpretAsDateTime('2500000000') AS future_timestamp;
SELECT reinterpretAsDateTime('9999999999') AS out_of_range_timestamp;