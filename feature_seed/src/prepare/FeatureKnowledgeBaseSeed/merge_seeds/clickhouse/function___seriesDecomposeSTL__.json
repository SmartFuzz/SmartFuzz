SELECT seriesDecomposeSTL([1, 2, 3, 4, 5, 6, 7, 8, 9], 3) AS decomposition;
SELECT seriesDecomposeSTL([100.0, 200.0, 300.0, 400.0], 2) AS decomposition;
SELECT seriesDecomposeSTL(arrayConcat(array(10.0, 20.0), array(30.0, 40.0, 50.0)), 3) AS decomposition;
CREATE TABLE time_series_test (id UInt32, value FLOAT) ENGINE = Memory;
