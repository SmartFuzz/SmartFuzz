CREATE TABLE time_series_data (value FLOAT) ENGINE = Memory;
INSERT INTO time_series_data VALUES (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (10.1), (20.45), (40.34);
SELECT seriesDecomposeSTL(array(SELECT value FROM time_series_data), 3) AS decomposition;
CREATE TABLE time_series_data_large (value FLOAT) ENGINE = Memory;
INSERT INTO time_series_data_large VALUES (10.1), (20.45), (40.34), (10.1), (20.45), (40.34), (30.5), (25.0), (40.1), (15.0), (10.0), (20.0), (25.5), (30.0), (45.0), (50.0), (35.5), (30.1), (55.0), (60.0);
