CREATE TABLE test_dates (id UInt32, eventDate Date, eventDateTime DateTime, eventDateTime64 DateTime64(3));
INSERT INTO test_dates VALUES (1, toDate('1999-01-01'), toDateTime('1999-01-01 00:00:00'), toDateTime64('1999-01-01 00:00:00.000', 3));
SELECT changeHour(eventDateTime, 14) FROM test_dates WHERE id = 1;
SELECT changeHour(eventDate, 14) FROM test_dates WHERE id = 1;
SELECT changeHour(changeHour(eventDateTime64, 5), 10) FROM test_dates WHERE id = 1;
SELECT changeHour(toDateTime('1999-12-31 23:59:59'), 1) as newDateTime FROM test_dates;
SELECT id, changeHour(eventDateTime, 18) AS updatedTime FROM test_dates WHERE eventDateTime < toDateTime('2000-01-01 00:00:00');
SELECT changeHour(toDateTime64('2023-03-10 10:45:12.123', 3), 22) as updatedTime FROM test_dates;
WITH changedDate AS (SELECT changeHour(eventDateTime, 12) AS noonTime FROM test_dates) SELECT * FROM changedDate;
CREATE TABLE temp_dates AS SELECT changeHour(toDate('2000-01-01'), 7) AS modifiedDate;
SELECT changeHour(eventDateTime, 24) FROM test_dates HAVING updatedTime < toDateTime('2023-01-01 00:00:00');
SELECT id, changeHour(eventDateTime, 0) AS resetHour FROM test_dates WHERE id < 2;