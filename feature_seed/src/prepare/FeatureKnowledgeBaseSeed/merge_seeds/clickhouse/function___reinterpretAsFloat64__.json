CREATE TABLE test_table (value UInt64);
INSERT INTO test_table VALUES (0), (1), (2), (4294967295), (18446744073709551615);
SELECT reinterpretAsFloat64(value) FROM test_table;
CREATE TABLE float_table (float_value Float64);
INSERT INTO float_table VALUES (0.0), (1.1), (2.2), (3.333), (4.4444);
SELECT reinterpretAsFloat64(float_value) FROM float_table;
CREATE TABLE uuid_table (uuid_value UUID);
INSERT INTO uuid_table VALUES (generateUUIDv4()), (generateUUIDv4());
SELECT reinterpretAsFloat64(toUInt64(uuid_value)) FROM uuid_table;
CREATE TABLE date_table (date_value Date);
INSERT INTO date_table VALUES ('2020-01-01'), ('2021-12-31');
SELECT reinterpretAsFloat64(toUInt64(date_value)) FROM date_table;
SELECT reinterpretAsFloat64(toFloat64(value)) AS floating_value FROM test_table;
SELECT reinterpretAsFloat64(toFloat64(0.5)) + reinterpretAsFloat64(toFloat64(1.5));
SELECT reinterpretAsFloat64(t1.x) FROM (SELECT reinterpretAsUInt64(toFloat64(1000000)) AS x) AS t1;
SELECT reinterpretAsFloat64(x) FROM (SELECT reinterpretAsUInt64(2) AS x) UNION SELECT reinterpretAsFloat64(3.0);
SELECT reinterpretAsFloat64(0) AS zero_float, reinterpretAsFloat64(1) AS one_float FROM test_table;
SELECT reinterpretAsFloat64(toFloat64(x.value)) FROM (SELECT value FROM test_table WHERE value < 3) AS x;
SELECT * FROM (SELECT reinterpretAsFloat64(value) AS float64_value FROM test_table) AS subquery WHERE float64_value > 0.0;