CREATE TABLE test_strings (haystack String) ENGINE = Memory;
INSERT INTO test_strings VALUES ('ClickHouse'), ('HelloWorld'), ('example'), ('multiSearchAllPositionsCaseInsensitive function'), ('Testing is fun');
SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['C', 'H']) FROM test_strings;
SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['hello', 'world']) FROM test_strings;
SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['t', 'T']) FROM test_strings;
SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['function', 'TESTING']) FROM test_strings;
SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['CLICKHOUSE', 'Multi']) FROM test_strings;
SELECT (SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['click'])) AS positions FROM test_strings;
SELECT haystack, multiSearchAllPositionsCaseInsensitive(haystack, ['e', 'E']) FROM test_strings WHERE haystack LIKE '%e%';
SELECT multiSearchAllPositionsCaseInsensitive('Testing with ClickHouse!', ['test', 'Click']);
SELECT arrayJoin(multiSearchAllPositionsCaseInsensitive(haystack, ['multi', 'search'])) AS positions FROM test_strings;
CREATE TABLE test_results (positions Array(UInt64)) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO test_results SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['searching']) FROM test_strings;
SELECT haystack, multiSearchAllPositionsCaseInsensitive(haystack, ['nonexistent']) FROM test_strings;
SELECT multiSearchAllPositionsCaseInsensitive(haystack, ['T', 'S', 'W']) FROM (SELECT haystack FROM test_strings);