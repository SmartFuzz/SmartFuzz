CREATE TABLE dates_test (date_string String);
INSERT INTO dates_test VALUES ('2020-01-01'), ('2020-01-02'), ('invalid-date');
SELECT toModifiedJulianDayOrNull(date_string) FROM dates_test;
CREATE TABLE more_dates (date_col Date);
INSERT INTO more_dates VALUES ('2020-01-01'), ('2020-04-15'), ('2020-12-31'), ('2023-08-22');
SELECT toModifiedJulianDayOrNull(date_col) FROM more_dates;
SELECT toModifiedJulianDayOrNull(date_col) AS mjd FROM more_dates WHERE date_col < '2021-01-01';
CREATE TABLE complex_dates (date_string String, value Int32);
INSERT INTO complex_dates VALUES ('2021-02-28', 1), ('not-a-date', 2), ('2021-03-01', 3);
SELECT date_string, toModifiedJulianDayOrNull(date_string) AS mjd FROM complex_dates WHERE value = 1;
SELECT (SELECT toModifiedJulianDayOrNull(date_string) FROM dates_test WHERE date_string = '2020-01-01') AS mjd_01, (SELECT toModifiedJulianDayOrNull(date_string) FROM dates_test WHERE date_string = 'invalid-date') AS mjd_invalid;
CREATE TABLE joined_dates AS SELECT t1.date_string, t2.value FROM dates_test AS t1 JOIN complex_dates AS t2 ON t1.date_string = '2020-01-01' OR t2.date_string = '2021-03-01';
SELECT toModifiedJulianDayOrNull(date_string) FROM joined_dates;
SELECT count(*), toModifiedJulianDayOrNull(date_col) AS mjd FROM more_dates GROUP BY mjd;
SELECT toModifiedJulianDayOrNull(date_string) FROM (SELECT date_string FROM dates_test WHERE date_string LIKE '2020-%') AS filtered_dates;