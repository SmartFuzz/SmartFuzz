CREATE TABLE test_dates (date DateTime);
INSERT INTO test_dates VALUES (toDateTime('2024-06-15 00:00:00'));
WITH toIntervalHour(0) AS interval_0 SELECT date + interval_0 AS result FROM test_dates;
WITH toIntervalHour(1) AS interval_1 SELECT date + interval_1 AS result FROM test_dates;
WITH toIntervalHour(5) AS interval_5 SELECT date + interval_5 AS result FROM test_dates;
WITH toIntervalHour(10) AS interval_10 SELECT date + interval_10 AS result FROM test_dates;
WITH toIntervalHour(24) AS interval_24 SELECT date + interval_24 AS result FROM test_dates;
WITH toIntervalHour(-1) AS interval_neg_1 SELECT date + interval_neg_1 AS result FROM test_dates;
WITH toIntervalHour(0.5) AS interval_half_hour SELECT date + interval_half_hour AS result FROM test_dates;
WITH toIntervalHour(CAST(12 AS Int32)) AS interval_casted_select SELECT date + interval_casted_select AS result FROM test_dates;
CREATE TABLE test_numbers (num Int32);
INSERT INTO test_numbers VALUES (1), (5), (10), (24), (-1), (0);
WITH (SELECT sum(num) FROM test_numbers) AS total_num, toIntervalHour(total_num) AS interval_total SELECT date + interval_total AS result FROM test_dates;
WITH (SELECT max(num) FROM test_numbers) AS max_num, toIntervalHour(max_num) AS interval_max SELECT date + interval_max AS result FROM test_dates;
WITH (SELECT avg(num) FROM test_numbers) AS avg_num, toIntervalHour(avg_num) AS interval_avg SELECT date + interval_avg AS result FROM test_dates;
WITH toIntervalHour(12) AS interval_12, (SELECT date FROM test_dates) AS base_date SELECT base_date + interval_12 AS result FROM test_dates;
WITH (SELECT toIntervalHour(num) FROM test_numbers) AS intervals SELECT date + intervals AS result FROM test_dates;