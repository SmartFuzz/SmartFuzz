CREATE TABLE test_strings (id UInt32, string1 String, string2 String);
INSERT INTO test_strings VALUES (1, 'jaro', 'jaro'), (2, 'test', 'tset'), (3, 'clickhouse', 'click');
SELECT jaroWinklerSimilarity(string1, string2) FROM test_strings;
SELECT id, jaroWinklerSimilarity('test', 'taste') AS similarity FROM test_strings WHERE similarity > 0.5;
SELECT jaroWinklerSimilarity(substring(string1, 1, 3), substring(string2, 1, 3)) FROM test_strings;
SELECT id, jaroWinklerSimilarity(string1, LOWER(string2)) AS similarity FROM test_strings;
SELECT id, jaroWinklerSimilarity(string1, string2) AS similarity FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE string2 LIKE 'c%');
CREATE TABLE comparison_results AS SELECT id, jaroWinklerSimilarity(string1, string2) AS similarity FROM test_strings;
SELECT id, similarity FROM comparison_results WHERE similarity < 0.8;
SELECT jaroWinklerSimilarity(REPLACE(string1, 'click', 'clik'), string2) FROM test_strings;
WITH (SELECT string1 FROM test_strings WHERE id = 1) AS str1, (SELECT string2 FROM test_strings WHERE id = 2) AS str2 SELECT jaroWinklerSimilarity(str1, str2);
CREATE TABLE similar_strings AS SELECT DISTINCT string1, string2 FROM test_strings WHERE jaroWinklerSimilarity(string1, string2) > 0.7;
SELECT jaroWinklerSimilarity(string1, string2) FROM test_strings WHERE string1 IS NOT NULL AND string2 IS NOT NULL;
SELECT COUNT(*) AS similar_pairs, AVG(jaroWinklerSimilarity(string1, string2)) AS avg_similarity FROM test_strings;
INSERT INTO test_strings VALUES (4, '', 'nonempty'), (5, 'nonempty', '');
SELECT jaroWinklerSimilarity(string1, string2) FROM test_strings WHERE (string1 = '' AND string2 != '') OR (string1 != '' AND string2 = '');