CREATE TABLE test_shingle (input_string String, shinglesize UInt8, hashnum UInt8);
INSERT INTO test_shingle VALUES ('ClickHouse® is a column-oriented database management system (DBMS) for online analytical processing of queries (OLAP).', 3, 6);
INSERT INTO test_shingle VALUES ('Fuzzy testing is amazing!', 1, 2);
INSERT INTO test_shingle VALUES ('How do we handle edge cases in ClickHouse?', 25, 25);
SELECT wordShingleMinHashArg(input_string, shinglesize, hashnum) FROM test_shingle;
SELECT * FROM (SELECT wordShingleMinHashArg(input_string, 3, 6) AS results FROM test_shingle WHERE hashnum > 2) AS subquery WHERE results.1 IS NOT NULL;
CREATE TABLE other_data (input String);
INSERT INTO other_data VALUES ('Performing hash functions efficiently.');
SELECT wordShingleMinHashArg(t.input_string, t.shinglesize, t.hashnum) FROM (SELECT * FROM test_shingle UNION ALL SELECT * FROM other_data) AS t;
SELECT AVG(length) FROM (SELECT length(wordShingleMinHashArg(input_string, 3, 6)) AS length FROM test_shingle) AS lengths;
SELECT wordShingleMinHashArg('Edge cases include: empty strings, single words, and very long inputs.', 1, 1) AS min_hash_results;
SELECT wordShingleMinHashArg('Uppercase and lowercase differences: ClickHouse vs clickhouse', 2, 5) AS max_hash_results;