CREATE TABLE geo_test (id UInt32, point Point, polygon Polygon, multipolygon MultiPolygon, linestring LineString, multiline MultiLineString);
INSERT INTO geo_test VALUES (1, (0., 0.), [(0., 0.), (10., 0.), (10., 10.), (0., 10.)], [[[(0., 0.), (10., 0.), (10., 10.), (0., 10.)], [(4., 4.), (5., 4.), (5., 5.), (4., 5.)]]], [(0., 0.), (10., 10.)], [[(0., 0.), (5., 5.)], [(5., 0.), (0., 5.);
]]);
SELECT wkt(point) FROM geo_test WHERE id = 1;
SELECT wkt(polygon) FROM geo_test WHERE id IN (SELECT id FROM geo_test WHERE id > 0);
SELECT wkt(multipolygon) FROM geo_test WHERE id = (SELECT max(id) FROM geo_test);
SELECT wkt(linestring) AS line_wkt, wkt(multilinestring) AS multi_line_wkt FROM geo_test WHERE id = 1;
SELECT wkt((SELECT point FROM geo_test WHERE id = 1)) AS point_wkt;
SELECT wkt(ARRAY[(SELECT point FROM geo_test WHERE id IN (1, 2))]) AS array_points_wkt;
CREATE TABLE geo_points (point Point) ENGINE = MergeTree() ORDER BY tuple();
INSERT INTO geo_points VALUES ((1., 2.)), ((3., 4.)), ((5., 6.));
SELECT wkt(point) FROM geo_points WHERE point IN (SELECT point FROM geo_points WHERE point.x > 2);
SELECT wkt(polygon), id FROM geo_test WHERE polygon IS NOT NULL;
SELECT COUNT(*) FROM geo_test HAVING wkt(multilinestring) IS NOT NULL;
SELECT wkt((SELECT point FROM geo_test WHERE id = 1 LIMIT 1)) AS nested_point_wkt;
SELECT wkt((SELECT ARRAY[(1., 1.), (2., 2.)])) AS complex_point_wkt;