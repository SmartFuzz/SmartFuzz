CREATE TABLE test_table_1 (id UInt32, name String, age UInt8) ENGINE = Memory;
INSERT INTO test_table_1 VALUES (1, 'Alice', 30), (2, 'Bob', 25), (3, 'Charlie', 35);
SELECT * EXCEPT (age) FROM test_table_1;
CREATE TABLE test_table_2 (id UInt32, salary Float32, department String) ENGINE = Memory;
INSERT INTO test_table_2 VALUES (1, 50000.0, 'HR'), (2, 60000.0, 'IT'), (3, 70000.0, 'Finance');
SELECT * EXCEPT (salary) FROM test_table_2;
SELECT t1.id, t1.name EXCEPT (t1.age), t2.salary FROM test_table_1 AS t1 JOIN test_table_2 AS t2 ON t1.id = t2.id;
CREATE TABLE test_table_3 (user_id UInt32, login_time DateTime, user_agent String) ENGINE = Memory;
INSERT INTO test_table_3 VALUES (1, '2021-01-01 10:00:00', 'Mozilla/5.0'), (2, '2021-01-02 11:00:00', 'Chrome/88.0');
SELECT user_id, login_time EXCEPT (user_agent) FROM test_table_3;
SELECT * EXCEPT (user_agent) FROM (SELECT user_id, login_time, user_agent FROM test_table_3) AS sub;
SELECT * EXCEPT (age, salary) FROM (SELECT t1.age, t2.salary FROM test_table_1 AS t1 JOIN test_table_2 AS t2 ON t1.id = t2.id) AS combined;
SELECT id, name EXCEPT (name) FROM (SELECT id, name FROM test_table_1 UNION ALL SELECT id, department AS name FROM test_table_2) AS combined;