CREATE TABLE test_dates (event_date Date, event_time DateTime, event_time_string String);
INSERT INTO test_dates VALUES (toDate('2023-12-31'), toDateTime('2023-12-31 23:59:00'), '2023-12-31 23:59:00');
SELECT addMinutes(event_date, 1) AS event_plus_one_minute FROM test_dates;
SELECT addMinutes(event_time, 120) AS event_plus_two_hours FROM test_dates;
SELECT addMinutes(event_time_string, 1440) AS event_plus_one_day FROM test_dates;
SELECT event_date, addMinutes(event_time, 60) AS event_plus_one_hour, addMinutes(event_time_string, -60) AS event_minus_one_hour FROM test_dates;
WITH (SELECT toDate('2024-01-01') AS start_date, toDate('2024-12-31') AS end_date) AS dates SELECT addMinutes(start_date, (number * 30)) AS monthly_incremented_dates FROM numbers(12) WHERE addMinutes(start_date, (number * 30)) <= end_date;
SELECT addMinutes(event_time, 60 * (number + 1)) AS incremented_times FROM test_dates JOIN numbers(3) AS n ON true;
WITH '2023-01-01 00:00:00' AS initial_date SELECT addMinutes(initial_date, -1) AS one_minute_before, addMinutes(initial_date, 60 * 24) AS one_day_after;
SELECT event_date, addMinutes(event_time_string, n.value) AS incremented_time FROM test_dates CROSS JOIN (SELECT number * 30 AS value FROM numbers(5)) AS n;
SELECT addMinutes(toDateTime('2023-07-01 12:00:00'), 59) AS add_just_below_an_hour, addMinutes(toDateTime('2023-07-01 12:00:00'), 60) AS add_exactly_an_hour;
SELECT addMinutes(toDateTime('2024-02-29 23:30:00'), 30) AS add_to_leap_day, addMinutes(toDateTime('2024-02-29 23:59:00'), 1) AS add_to_leap_day_end;
INSERT INTO test_dates VALUES (toDate('2023-01-28'), toDateTime('2023-01-28 21:45:00'), '2023-01-28 21:45:00');
SELECT addMinutes(event_time, 1) FROM test_dates WHERE event_date = toDate('2023-01-28');