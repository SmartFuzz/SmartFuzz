CREATE TABLE test_table (name String, value UInt32);
INSERT INTO test_table VALUES ('some_file_1', 100), ('some_file_2', 200), ('another_file_1', 300);
SELECT count(*) FROM hdfs('hdfs://hdfs1:9000/{some,another}_dir/some_file_{1..2}', 'TSV', 'name String, value UInt32');
SELECT count(*) FROM hdfs('hdfs://hdfs1:9000/some_dir/*', 'TSV', 'name String, value UInt32') WHERE value > 150;
SELECT count(*) FROM hdfs('hdfs://hdfs1:9000/big_dir/file{0..9}{0..9}{0..9}', 'CSV', 'name String, value UInt32') HAVING count(*) > 5;
SELECT name, value FROM test_table WHERE value IN (SELECT value FROM hdfs('hdfs://hdfs1:9000/{some,another}_dir/some_file_{1..2}', 'TSV', 'name String, value UInt32'));
SELECT SUM(value) FROM hdfs('hdfs://hdfs1:9000/{some,another}_dir/*', 'TSV', 'name String, value UInt32') GROUP BY name ORDER BY SUM(value) DESC;
SELECT * FROM hdfs('hdfs://hdfs1:9000/{a,b,c}_dir/**', 'TSV', 'name String, value UInt32') WHERE name LIKE 'some_file_%' AND value BETWEEN 100 AND 250;
CREATE TABLE temp AS SELECT * FROM hdfs('hdfs://hdfs1:9000/{some,another}_dir/some_file_1', 'TSV', 'name String, value UInt32');
SELECT DISTINCT name FROM temp WHERE name LIKE 'another_file_%' AND value < 300;
SELECT COUNT(*) FROM (SELECT DISTINCT name FROM hdfs('hdfs://hdfs1:9000/dir{1..3}/{sub_dir1,sub_dir2}/*', 'TSV', 'name String, value UInt32'));
SELECT * FROM hdfs('hdfs://hdfs1:9000/datadir/*.txt', 'TSV', 'name String, value UInt32') WHERE value IS NOT NULL ORDER BY value DESC;