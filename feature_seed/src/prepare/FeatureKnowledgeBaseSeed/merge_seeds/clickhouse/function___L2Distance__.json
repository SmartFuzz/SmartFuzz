SELECT L2Distance((0, 0), (0, 0));
SELECT L2Distance((1, 1), (1, 1));
SELECT L2Distance((1, 1), (2, 2));
SELECT L2Distance((1.5, 2.5), (2.5, 3.5));
SELECT L2Distance((-1, -2), (1, 2));
SELECT L2Distance((1, 0), (0, 1));
SELECT L2Distance((0.001, 0.002), (0.002, 0.003));
CREATE TABLE vectors (id UInt32, vector Array(Float32));
INSERT INTO vectors VALUES (1, [1.0, 2.0]), (2, [3.0, 4.0]);
SELECT id, L2Distance(vector, [0, 0]) AS distance FROM vectors;
SELECT L2Distance((SELECT vector FROM vectors WHERE id = 1), (SELECT vector FROM vectors WHERE id = 2));
SELECT L2Distance((SELECT avg(x) FROM (SELECT arrayJoin(vector) AS x FROM vectors WHERE id = 1)), (SELECT avg(y) FROM (SELECT arrayJoin(vector) AS y FROM vectors WHERE id = 2)));
SELECT id, L2Distance(vector, (SELECT vector FROM vectors WHERE id = 2)) AS distance FROM vectors WHERE id != 2;
WITH (SELECT vector FROM vectors WHERE id = 1) AS v1, (SELECT vector FROM vectors WHERE id = 2) AS v2 SELECT L2Distance(v1, v2);