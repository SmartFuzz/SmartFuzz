CREATE TABLE test_array_min (id UInt32, values Array(Int32));
INSERT INTO test_array_min VALUES (1, [3, 5, 1, 4]), (2, [2, 8, 6]), (3, [0, -1, -5, -3]), (4, NULL);
SELECT arrayMin(values) AS min_value FROM test_array_min;
SELECT arrayMin(x -> (x * 2), values) AS transformed_min FROM test_array_min;
SELECT id, arrayMin(values) AS min_value FROM test_array_min GROUP BY id HAVING min_value > 1;
SELECT arrayMin(values) AS min_value FROM (SELECT values FROM test_array_min WHERE id = 1 UNION ALL SELECT values FROM test_array_min WHERE id = 2);
CREATE TABLE test_subquery (group_id UInt32, val Array(Int32));
INSERT INTO test_subquery VALUES (1, [10, 20, 30]), (1, [5, 15, 25]), (2, [100, 200]);
SELECT group_id, arrayMin(val) AS min_val FROM test_subquery GROUP BY group_id;
SELECT group_id, arrayMin(x -> (-x), val) AS min_neg_val FROM test_subquery GROUP BY group_id;
SELECT avg(arrayMin(values)) AS avg_min_value FROM test_array_min;
SELECT arrayMin((SELECT values FROM test_array_min WHERE values IS NOT NULL)) AS overall_min;
SELECT arrayMin(arrayMap(x -> x * 3, values)) AS multiplied_min FROM test_array_min WHERE id = 3;
SELECT arrayMin(arrayConcat([1, 2], [3, 4, 5])) AS concatenated_min;
SELECT arrayMin(arrayFilter(x -> x > 0, values)) AS positive_min FROM test_array_min WHERE id = 4;