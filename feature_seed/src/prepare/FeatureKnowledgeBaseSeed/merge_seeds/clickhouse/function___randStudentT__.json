CREATE TABLE student_samples (id UInt64, value Float64);
INSERT INTO student_samples VALUES (1, randStudentT(1));
INSERT INTO student_samples VALUES (2, randStudentT(5));
INSERT INTO student_samples VALUES (3, randStudentT(10));
INSERT INTO student_samples VALUES (4, randStudentT(20));
INSERT INTO student_samples VALUES (5, randStudentT(100));
SELECT AVG(value) FROM student_samples;
SELECT COUNT(*) FROM student_samples WHERE value > 0;
SELECT value FROM student_samples ORDER BY value LIMIT 1;
SELECT id, value, randStudentT(10) AS random_value FROM student_samples WHERE value < 0;
CREATE TABLE student_summary AS SELECT id, value, randStudentT(5) AS random_t_value FROM student_samples;
SELECT SUM(random_t_value) FROM student_summary;
SELECT a.id, a.value, b.random_t_value FROM student_samples AS a JOIN (SELECT id, randStudentT(30) AS random_t_value FROM numbers(10)) AS b ON a.id = b.id;
SELECT * FROM (SELECT randStudentT(2) AS random_value FROM numbers(100)) AS temp WHERE random_value < 0;
SELECT ARRAY_JOIN(arrayMap(x -> randStudentT(x), [1, 2, 3, 10, 20])) AS randoms;
SELECT id, value FROM (SELECT id, randStudentT(3) AS t_value FROM student_samples) WHERE t_value > 0;