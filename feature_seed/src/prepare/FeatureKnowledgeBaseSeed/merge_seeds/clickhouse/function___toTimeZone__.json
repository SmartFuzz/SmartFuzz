CREATE TABLE test_times (event_time DateTime, timezone String);
INSERT INTO test_times VALUES (toDateTime('2022-07-01 12:00:00', 'UTC'), 'Asia/Yekaterinburg');
INSERT INTO test_times VALUES (toDateTime('2022-07-01 12:00:00', 'UTC'), 'US/Samoa');
SELECT event_time, toTimeZone(event_time, timezone) AS localized_time FROM test_times;
CREATE TABLE test_dates (event_date Date, timezone String);
INSERT INTO test_dates VALUES (toDate('2022-07-01', 'UTC'), 'Asia/Tokyo');
INSERT INTO test_dates VALUES (toDate('2022-07-01', 'UTC'), 'Europe/London');
SELECT event_date, toTimeZone(toDateTime(event_date, 'UTC'), timezone) AS localized_datetime FROM test_dates;
SELECT toTimeZone(toDateTime('2019-01-01 00:00:00', 'UTC'), 'America/New_York') AS time_ny, toTypeName(time_ny) AS type_ny;
SELECT toTimeZone(toDateTime('2023-05-15 18:30:00', 'UTC'), 'Asia/Kolkata') AS time_kolkata;
SELECT toTimeZone(toDateTime(toDate('2022-05-01'), 'UTC'), 'Pacific/Auckland') AS time_auckland;
SELECT toTimeZone(toDateTime('2020-12-31 23:59:59', 'UTC'), 'Europe/Paris') AS time_paris;
WITH (SELECT toDateTime('2021-08-30 10:00:00', 'UTC')) AS original_time SELECT original_time, toTimeZone(original_time, 'Australia/Sydney') AS time_sydney;
SELECT original_time, toTimeZone(original_time, timezone) AS adjusted_time FROM (SELECT toDateTime('2021-12-01 12:00:00', 'UTC') AS original_time, 'America/Los_Angeles' AS timezone UNION ALL SELECT toDateTime('2021-12-01 12:00:00', 'UTC'), 'UTC') AS subquery;
SELECT toTimeZone(toDateTime('2019-06-15 15:30:00', 'UTC'), 'GMT') AS gmt_time, toTimeZone(toDateTime('2019-06-15 15:30:00', 'UTC'), 'Asia/Tokyo') AS tokyo_time;