CREATE TABLE test_strings (s FixedString(10));
INSERT INTO test_strings VALUES (toFixedString('foo', 10));
INSERT INTO test_strings VALUES (toFixedString('foo\0bar', 10));
INSERT INTO test_strings VALUES (toFixedString('123\0abc', 10));
INSERT INTO test_strings VALUES (toFixedString('\0start', 10));
INSERT INTO test_strings VALUES (toFixedString('nozero', 10));
SELECT s, toStringCutToZero(s) AS s_cut FROM test_strings;
CREATE TABLE nested_test AS SELECT toFixedString('alpha\0beta', 10) AS s;
SELECT s, (SELECT toStringCutToZero(s) FROM nested_test) AS s_cut FROM nested_test;
CREATE TABLE table1 (id Int32, s FixedString(10));
CREATE TABLE table2 (id Int32, reference Int32);
INSERT INTO table1 VALUES (1, toFixedString('foo\0bar', 10)), (2, toFixedString('baz', 10));
INSERT INTO table2 VALUES (1, 1), (2, 1);
SELECT t1.s, toStringCutToZero(t1.s) AS s_cut FROM table1 t1 JOIN table2 t2 ON t1.id = t2.reference;
WITH (SELECT toFixedString('string\0test', 10)) AS s FROM (SELECT 1) tmp SELECT toStringCutToZero(s) AS s_cut;
SELECT toStringCutToZero(toFixedString('data\0truncate', 20)) AS result;