CREATE TABLE test_table (val String);
INSERT INTO test_table VALUES ('256'), ('-1'), ('0.5'), ('NaN'), ('Inf'), ('abc'), ('0xc0fe'), ('0b101010');
SELECT toUInt8OrDefault(val, CAST('0', 'UInt8')) FROM test_table;
SELECT toUInt8OrDefault(val) FROM test_table;
SELECT val, toUInt8OrDefault(val, CAST('10', 'UInt8')) AS converted FROM test_table WHERE converted > 5;
CREATE TABLE other_table (val1 Float64, val2 String);
INSERT INTO other_table VALUES (3.5, '8'), (0.0, 'abc'), (1.2, '0xc0fe'), (-1.0, 'Inf');
SELECT val1, toUInt8OrDefault(val2, CAST('0', 'UInt8')) FROM other_table WHERE val1 > 1.0;
SELECT COUNT(*) FROM (SELECT toUInt8OrDefault(val, CAST('5', 'UInt8')) FROM other_table) AS subquery WHERE val > 3;
SELECT val, toUInt8OrDefault(val, CAST('12', 'UInt8')) FROM (SELECT val FROM test_table UNION SELECT val1 AS val FROM other_table) AS combined;
SELECT DISTINCT toUInt8OrDefault(CAST(val AS String), CAST('0', 'UInt8')) FROM (SELECT val1 FROM other_table WHERE val1 IS NOT NULL) AS nested_query;