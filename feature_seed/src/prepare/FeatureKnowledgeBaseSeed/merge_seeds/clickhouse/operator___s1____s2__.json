CREATE TABLE test_concat (s1 String, s2 String);
INSERT INTO test_concat VALUES ('Hello', ' World');
INSERT INTO test_concat VALUES ('ClickHouse', ' Database');
INSERT INTO test_concat VALUES (NULL, 'Test');
INSERT INTO test_concat VALUES ('Fuzzy', NULL);
INSERT INTO test_concat VALUES (NULL, NULL);
SELECT s1 || s2 AS concatenated FROM test_concat;
SELECT s1 || ' - ' || s2 AS concatenated FROM test_concat WHERE s1 IS NOT NULL;
CREATE TABLE test_nested_concat AS SELECT s1, s2 FROM test_concat;
SELECT (SELECT s1 || s2 FROM test_concat WHERE s1 = 'Hello') AS greeting, (SELECT s1 || s2 FROM test_concat WHERE s2 = 'Database') AS info;
SELECT a.s1 || b.s2 AS combined FROM test_concat AS a JOIN test_concat AS b ON a.s1 != b.s1;
WITH (SELECT 'Test' AS prefix) AS subquery SELECT prefix || s1 AS prefixed FROM test_concat;
SELECT COUNT(*) FROM test_concat WHERE s1 || s2 LIKE 'Hello%';
SELECT s1 || s2 AS concatenated FROM (SELECT s1, s2 FROM test_concat WHERE s1 IS NOT NULL) WHERE s2 IS NOT NULL;
CREATE TABLE test_complex_concat AS SELECT s1, s2, s1 || s2 AS concatenated FROM test_concat WHERE s1 || s2 != '';
SELECT DISTINCT s1 || s2 FROM test_concat ORDER BY concatenated;
SELECT arrayJoin([s1, s2]) || '!' AS exclamation FROM test_concat;