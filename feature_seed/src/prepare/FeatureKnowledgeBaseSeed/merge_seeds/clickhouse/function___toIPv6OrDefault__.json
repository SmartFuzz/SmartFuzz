CREATE TABLE test_ips (ip_string String);
INSERT INTO test_ips VALUES ('::1'), ('2001:0db8:85a3:0000:0000:8a2e:0370:7334'), ('invalid_ip'), ('127.0.0.1'), ('2001:0db8:85a3:0000:0000:8a2e:0370:7334.5');
SELECT toIPv6OrDefault(ip_string) AS ipv6_result FROM test_ips;
SELECT toIPv6OrDefault(ip_string, '::') AS ipv6_result_with_default FROM test_ips;
SELECT toIPv6OrDefault(ip_string, toIPv6('1.1.1.1')) AS ipv6_result_with_provided_default FROM test_ips;
WITH '2001:0db8:85a3:0000:0000:8a2e:0370:7334' AS valid_ipv6, 'invalid_ipv6' AS invalid_ipv6 SELECT toIPv6OrDefault(valid_ipv6) AS valid_ipv6_result, toIPv6OrDefault(invalid_ipv6, '::') AS invalid_ipv6_result;
WITH '127.0.0.1' AS valid_ipv4, '192.168.1.1.1' AS invalid_ipv4 SELECT toIPv6OrDefault(valid_ipv4) AS valid_ipv6_from_ipv4, toIPv6OrDefault(invalid_ipv4, '::1') AS invalid_ipv6_result;
SELECT ip_string, toIPv6OrDefault(ip_string) AS result FROM test_ips WHERE toIPv6OrDefault(ip_string) != '::' ORDER BY result ASC;
CREATE TABLE test_subquery (ip String);
INSERT INTO test_subquery VALUES ('::1'), ('2001:0db8:85a3:0000:0000:8a2e:0370:7334');
SELECT ip, (SELECT toIPv6OrDefault(ip) FROM test_subquery) AS nested_result FROM test_subquery;
SELECT ip_string, toIPv6OrDefault(ip_string) AS ipv6_result FROM (SELECT ip_string FROM test_ips WHERE ip_string LIKE '2001:%') AS filtered_ips;
WITH '127.0.0.1' AS ip_val, 'invalid_ip_address' AS invalid_ip_val SELECT toIPv6OrDefault(ip_val) AS valid_ip, toIPv6OrDefault(invalid_ip_val, '2001:0db8:85a3:0000:0000:8a2e:0370:7334') AS IPV6_fallback;