SELECT emptyArrayUInt16();
CREATE TABLE test_table (id UInt32, values Array(UInt16));
INSERT INTO test_table VALUES (1, emptyArrayUInt16()), (2, [1, 2, 3]), (3, emptyArrayUInt16());
SELECT id, values FROM test_table WHERE length(values) = 0;
SELECT id FROM test_table WHERE values = emptyArrayUInt16();
SELECT id, arrayJoin(values) AS value FROM test_table WHERE arrayLength(values) = 0;
WITH (SELECT emptyArrayUInt16() AS empty_array) SELECT arrayLength(empty_array) AS length;
SELECT id FROM (SELECT id, emptyArrayUInt16() AS empty_array FROM test_table) AS subquery WHERE arrayLength(empty_array) = 0;
CREATE TABLE secondary_table (ref UInt32, test_ref Array(UInt16));
INSERT INTO secondary_table VALUES (1, [1]), (2, [2]), (3, emptyArrayUInt16());
SELECT t.id, s.ref FROM test_table AS t JOIN secondary_table AS s ON t.id = s.ref WHERE length(s.test_ref) = 0;