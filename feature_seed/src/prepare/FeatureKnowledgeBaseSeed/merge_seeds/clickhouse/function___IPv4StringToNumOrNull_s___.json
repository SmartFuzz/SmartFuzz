CREATE TABLE ip_test (ip_address String);
INSERT INTO ip_test VALUES ('192.168.1.1');
INSERT INTO ip_test VALUES ('255.255.255.255');
INSERT INTO ip_test VALUES ('256.100.100.100');
INSERT INTO ip_test VALUES ('192.168.1.');
INSERT INTO ip_test VALUES ('192.168.1.300');
INSERT INTO ip_test VALUES ('invalid_ip_address');
INSERT INTO ip_test VALUES ('0.0.0.0');
INSERT INTO ip_test VALUES (NULL);
SELECT ip_address, IPv4StringToNumOrNull(ip_address) AS ip_num FROM ip_test;
SELECT ip_address, IPv4StringToNumOrNull(ip_address) AS ip_num FROM ip_test WHERE IPv4StringToNumOrNull(ip_address) IS NOT NULL;
CREATE TABLE valid_ips AS SELECT ip_address FROM ip_test WHERE IPv4StringToNumOrNull(ip_address) IS NOT NULL;
CREATE TABLE invalid_ips AS SELECT ip_address FROM ip_test WHERE IPv4StringToNumOrNull(ip_address) IS NULL;
SELECT COUNT(*) AS valid_count FROM valid_ips;
SELECT COUNT(*) AS invalid_count FROM invalid_ips;
SELECT ip_address, IPv4StringToNumOrNull(ip_address) AS ip_num FROM ip_test WHERE ip_address IN (SELECT ip_address FROM valid_ips);
SELECT AVG(IPv4StringToNumOrNull(ip_address)) AS avg_ip_num FROM ip_test WHERE IPv4StringToNumOrNull(ip_address) IS NOT NULL;
WITH temp AS (SELECT IPv4StringToNumOrNull(ip_address) AS ip_num FROM ip_test) SELECT COUNT(*) FROM temp WHERE ip_num IS NOT NULL;
SELECT ip_address, ipv4_num FROM (SELECT ip_address, IPv4StringToNumOrNull(ip_address) AS ipv4_num FROM ip_test) WHERE ipv4_num > 0;
SELECT ip_num FROM (SELECT IPv4StringToNumOrNull(ip_address) AS ip_num FROM ip_test) WHERE ip_num IS NULL;