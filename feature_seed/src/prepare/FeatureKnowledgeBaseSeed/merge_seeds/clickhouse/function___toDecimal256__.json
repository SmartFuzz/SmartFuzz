CREATE TABLE test_table (value Decimal256(76, 0));
INSERT INTO test_table VALUES (toDecimal256(100, 1));
INSERT INTO test_table VALUES (toDecimal256(99.9999, 4));
INSERT INTO test_table VALUES (toDecimal256('1234567890123456789012345678901234567890123456789012345678901234567890123456789012345678901234567890', 10));
INSERT INTO test_table VALUES (toDecimal256(1.15, 2));
SELECT value FROM test_table WHERE value = toDecimal256(1.15, 2);
SELECT value, toDecimal256(value, 3) AS converted_value FROM test_table WHERE value < toDecimal256('100', 0);
SELECT toDecimal256(subquery.value, 1) FROM (SELECT value FROM test_table) AS subquery WHERE subquery.value > 0;
SELECT a.value, b.value FROM test_table AS a JOIN test_table AS b ON a.value > b.value;
CREATE TABLE another_table (id UInt32, value String);
INSERT INTO another_table VALUES (1, '99.67');
SELECT toDecimal256(a.value, 2) AS decimal_value FROM another_table AS a WHERE a.id = 1;
SELECT toDecimal256(CAST('100.50' AS String), 2) AS converted_value;
CREATE TABLE overflow_table (value Decimal256(76, 5));
INSERT INTO overflow_table VALUES (toDecimal256('99999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999999', 1));
SELECT toDecimal256('1000.77', 3) AS precision_test;
SELECT toDecimal256(value, 0) AS integer_part FROM test_table WHERE toDecimal256(value, 0) < 100;
INSERT INTO test_table VALUES (toDecimal256(1e30, 0));
INSERT INTO test_table VALUES (toDecimal256(-1e30, 0));
SELECT COUNT(*) FROM test_table WHERE toDecimal256(value, 0) > 0;
SELECT toDecimal256(Float64(value), 4) AS float_conversion FROM test_table;