CREATE TABLE test_char (id Int32, value String);
INSERT INTO test_char VALUES (1, char(72, 101, 108, 108, 111));
INSERT INTO test_char VALUES (2, char(0xB0, 0xC0, 0xB1));
INSERT INTO test_char VALUES (3, char(128, 255, 260, 300));
INSERT INTO test_char VALUES (4, char(0, 12, 255));
SELECT value FROM test_char WHERE id = 1;
SELECT value FROM test_char WHERE id = 2;
SELECT value FROM test_char WHERE id = 3;
SELECT char(104.9, 101, 108.5, 108, 111) AS hello;
SELECT char(local_id + 50, 100) FROM (SELECT id AS local_id FROM test_char) WHERE local_id > 0;
SELECT char(0x100, 0x200) AS round_test;
SELECT char(c1, c2) FROM (SELECT char(72, 101) AS c1, char(108, 111) AS c2) AS t;
SELECT char(127, 128, 130, 255) AS boundary_test;
SELECT char(100.9, 200, 300, 400) AS overflow_test FROM (SELECT 1) AS t;
SELECT char(-1, 0, 1, 2) AS negative_test;
CREATE TABLE test_char_join (id Int32, value String);
INSERT INTO test_char_join VALUES (1, char(65, 66)), (2, char(67, 68));
SELECT CONCAT(tc.value, tj.value) AS combined_value FROM test_char tc JOIN test_char_join tj ON tc.id = 1;
SELECT char(256, 257) AS multitable_test FROM (SELECT id FROM test_char WHERE id < 3) AS t;
SELECT char(0xFF, 0xAA, 0xCC) AS hex_test;