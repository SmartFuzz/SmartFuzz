CREATE TABLE bitmask_test (num UInt64);
INSERT INTO bitmask_test VALUES (0), (1), (2), (3), (4), (5), (6), (7), (8), (15), (16), (31), (32), (63), (64), (127), (128), (255), (256);
SELECT num, bitmaskToArray(num) AS powers_of_two FROM bitmask_test;
CREATE TABLE bitmask_summary AS SELECT num, bitmaskToArray(num) AS powers_of_two FROM bitmask_test;
SELECT COUNT(*) FROM bitmask_summary WHERE length(powers_of_two) > 0;
WITH (SELECT bitmaskToArray(num) FROM bitmask_test WHERE num > 0) AS powers FROM (SELECT * FROM bitmask_test) AS t WHERE num < 64;
SELECT num, arrayJoin(bitmaskToArray(num)) AS power FROM bitmask_test WHERE power > 0;
CREATE TABLE results AS SELECT num, bitmaskToArray(num) AS powers_of_two FROM bitmask_test WHERE num <= 255;
SELECT num, arrayJoin(bitmaskToArray(num)) AS power FROM results WHERE power = 8;
SELECT AVG(length(bitmaskToArray(num))) AS average_length FROM bitmask_test WHERE num > 10;