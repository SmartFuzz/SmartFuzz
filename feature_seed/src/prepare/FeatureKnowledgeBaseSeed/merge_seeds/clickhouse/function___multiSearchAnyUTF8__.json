CREATE TABLE test_strings (haystack String);
INSERT INTO test_strings VALUES ('ClickHouse is awesome!'), ('Hello World!'), ('UTF-8 encoding test case.');
SELECT multiSearchAnyUTF8(haystack, ['Click', 'Hello']) FROM test_strings;
SELECT multiSearchAnyUTF8(haystack, ['UTF-8', 'test']) FROM test_strings;
SELECT multiSearchAnyUTF8(haystack, ['notfound']) FROM test_strings;
SELECT multiSearchAnyUTF8(haystack, ['Hello', 'World']) FROM test_strings WHERE haystack LIKE '%World%';
SELECT multiSearchAnyUTF8(haystack, ['awesome', 'test']) FROM (SELECT haystack FROM test_strings WHERE haystack LIKE '%test%') AS tmp;
SELECT multiSearchAnyUTF8(haystack, ['Click', 'H']) FROM (SELECT haystack FROM test_strings) AS subquery WHERE haystack LIKE '%ClickHouse%';
CREATE TABLE search_results AS SELECT multiSearchAnyUTF8(haystack, ['Click', 'H']) AS result FROM test_strings;
SELECT result FROM search_results WHERE result = 1;
SELECT COUNT(*) FROM (SELECT multiSearchAnyUTF8(haystack, ['test', 'case']) FROM test_strings) AS search_results WHERE result = 1;
SELECT multiSearchAnyUTF8(haystack, ['unique']) AS result FROM (SELECT DISTINCT haystack FROM test_strings) AS unique_strings;