CREATE TABLE test_strings (haystack String, pattern String);
INSERT INTO test_strings VALUES ('hello world', 'world');
INSERT INTO test_strings VALUES ('ClickHouse is powerful', 'clickhouse');
INSERT INTO test_strings VALUES ('countMatchesCaseInsensitive is useful', 'USEFUL');
INSERT INTO test_strings VALUES ('abABabAB', 'ab');
INSERT INTO test_strings VALUES ('case CASE case', 'case');
SELECT countMatchesCaseInsensitive(haystack, pattern) FROM test_strings;
SELECT countMatchesCaseInsensitive(haystack, 'case') AS matches FROM test_strings WHERE matches > 0;
SELECT SUM(num_matches) FROM (SELECT countMatchesCaseInsensitive(haystack, pattern) AS num_matches FROM test_strings);
SELECT countMatchesCaseInsensitive(haystack, 'match') AS total_matches FROM (SELECT haystack FROM test_strings WHERE haystack LIKE '%match%') AS filtered;
CREATE TABLE patterns (pattern String);
INSERT INTO patterns VALUES ('clickhouse'), ('case');
SELECT countMatchesCaseInsensitive(t.haystack, p.pattern) FROM test_strings AS t JOIN patterns AS p ON t.haystack LIKE '%' || p.pattern || '%';
SELECT countMatchesCaseInsensitive('A', 'aa') AS case_insensitive_test;
SELECT countMatchesCaseInsensitive('abcABCabc', 'abc') AS mixed_case_test;
SELECT countMatchesCaseInsensitive(CONCAT('Uppercase ', 'lowercase'), 'lowercase') AS concat_test;
SELECT countMatchesCaseInsensitive(LOWER(haystack), LOWER(pattern)) FROM test_strings;
SELECT countMatchesCaseInsensitive('AAaaAAaaAA', 'aa') AS overlapping_test;