CREATE TABLE remote_table (id UInt32, value String) ENGINE = MergeTree() ORDER BY id;
SELECT * FROM remote_table WHERE id NOT IN (SELECT id FROM remote_table WHERE value LIKE 'test%');
CREATE TABLE local_table (id UInt32, r_id UInt32) ENGINE = MergeTree() ORDER BY id;
INSERT INTO local_table VALUES (1, 1), (2, 1), (3, 2);
INSERT INTO remote_table VALUES (1, 'test1'), (2, 'test2'), (3, 'test3');
SELECT DISTINCT rt.value FROM remote_table rt JOIN local_table lt ON rt.id = lt.r_id WHERE lt.id < 3;
SELECT COUNT(*) FROM remote_table WHERE id IN (SELECT r_id FROM local_table WHERE id > 1) HAVING COUNT(*) > 1;
SELECT rt.value, AVG(lt.id) AS avg_id FROM remote_table rt LEFT JOIN local_table lt ON rt.id = lt.r_id GROUP BY rt.value HAVING avg_id IS NOT NULL;
CREATE TABLE temp_table AS SELECT * FROM remote_table WHERE id < 10;
SELECT COUNT(DISTINCT value) FROM temp_table WHERE id >= 2 AND id <= 5;
CREATE TABLE another_table AS SELECT * FROM remote_table WHERE id > 0;
SELECT rt.value FROM remote_table rt, another_table at WHERE rt.id = at.id ORDER BY rt.value DESC LIMIT 5;
SELECT rt.value FROM remote_table rt WHERE id IN (SELECT DISTINCT r_id FROM local_table) UNION SELECT 'None' AS value;
SELECT COUNT(*) FROM (SELECT DISTINCT value FROM remote_table WHERE LENGTH(value) > 5) AS subquery;
SELECT rt.value, SUM(CASE WHEN lt.id IS NOT NULL THEN 1 ELSE 0 END) AS matched FROM remote_table rt FULL OUTER JOIN local_table lt ON rt.id = lt.r_id GROUP BY rt.value;