CREATE TABLE test_lgamma (value FLOAT);
INSERT INTO test_lgamma VALUES (-1), (0), (1), (2), (5.5), (10.0), (15.0);
SELECT lgamma(value) FROM test_lgamma;
SELECT value, lgamma(value) FROM test_lgamma WHERE value > 0;
SELECT value, lgamma(value) AS log_gamma FROM test_lgamma WHERE value BETWEEN 1 AND 10;
WITH (SELECT AVG(value) FROM test_lgamma) AS avg_value SELECT lgamma(avg_value) FROM test_lgamma;
CREATE TABLE t1 AS SELECT value FROM test_lgamma WHERE value < 1;
INSERT INTO t1 VALUES (0.5), (0.9);
SELECT lgamma(value) FROM t1 UNION ALL SELECT lgamma(value) FROM test_lgamma WHERE value > 5;
SELECT lgamma(SELECT MAX(value) FROM test_lgamma) AS max_log_gamma;
CREATE TABLE t2 AS SELECT DISTINCT value FROM test_lgamma;
SELECT lgamma(t2.value), t2.value FROM t2 JOIN test_lgamma ON t2.value = test_lgamma.value WHERE t2.value IS NOT NULL;