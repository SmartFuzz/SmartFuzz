CREATE TABLE date_test (test_date Date);
INSERT INTO date_test VALUES (toDate('1990-01-01'));
INSERT INTO date_test VALUES (toDate('1993-11-25'));
INSERT INTO date_test VALUES (toDate('2000-01-01'));
INSERT INTO date_test VALUES (toDate('2005-01-05'));
INSERT INTO date_test VALUES (toDate('2010-07-15'));
INSERT INTO date_test VALUES (toDate('2015-12-31'));
INSERT INTO date_test VALUES (toDate('2020-03-15'));
INSERT INTO date_test VALUES (toDate('2023-10-01'));
SELECT test_date, toRelativeQuarterNum(test_date) AS quarter_num FROM date_test;
SELECT test_date, toRelativeQuarterNum(test_date) AS quarter_num FROM date_test WHERE test_date >= toDate('1993-01-01');
SELECT SUM(toRelativeQuarterNum(test_date)) FROM date_test;
SELECT test_date, (SELECT toRelativeQuarterNum(dateTest.test_date) FROM date_test AS dateTest WHERE dateTest.test_date < '2005-01-01') AS prior_quarters FROM date_test;
SELECT d1.test_date, d2.test_date, toRelativeQuarterNum(d1.test_date) - toRelativeQuarterNum(d2.test_date) AS quarter_difference FROM date_test AS d1 JOIN date_test AS d2 ON d1.test_date > d2.test_date;
SELECT test_date, toRelativeQuarterNum(test_date) AS quarter_num FROM date_test WHERE toRelativeQuarterNum(test_date) > 10 ORDER BY quarter_num DESC;
SELECT AVG(toRelativeQuarterNum(test_date)) FROM date_test WHERE test_date BETWEEN toDate('1993-01-01') AND toDate('2010-01-01');