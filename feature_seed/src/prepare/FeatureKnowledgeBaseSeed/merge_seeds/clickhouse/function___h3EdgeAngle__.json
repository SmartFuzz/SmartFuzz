CREATE TABLE h3_resolutions (resolution UInt8);
INSERT INTO h3_resolutions VALUES (0), (1), (5), (10), (15);
SELECT h3EdgeAngle(resolution) AS edgeAngle FROM h3_resolutions WHERE resolution BETWEEN 0 AND 15;
SELECT h3EdgeAngle(0) AS edgeAngle;
-- Lower boundary test;
SELECT h3EdgeAngle(15) AS edgeAngle;
-- Upper boundary test;
SELECT h3EdgeAngle(7) AS edgeAngle FROM (SELECT resolution FROM h3_resolutions WHERE resolution < 10) AS subquery;
CREATE TABLE h3_data (hexagon UInt64, resolution UInt8);
INSERT INTO h3_data VALUES (1234567890123456789, 5), (9876543210987654321, 10), (1928374655647382910, 0);
SELECT h3EdgeAngle(d.resolution) AS edgeAngle FROM h3_data d JOIN h3_resolutions r ON d.resolution = r.resolution WHERE r.resolution IN (5, 10);
SELECT AVG(h3EdgeAngle(resolution)) FROM h3_data;
SELECT h3EdgeAngle((SELECT MAX(resolution) FROM h3_resolutions)) AS edgeAngle;