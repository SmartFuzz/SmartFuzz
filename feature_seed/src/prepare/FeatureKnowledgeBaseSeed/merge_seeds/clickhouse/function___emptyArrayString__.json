CREATE TABLE test_table (id UInt32, arr Array(String));
INSERT INTO test_table VALUES (1, emptyArrayString()), (2, ['test1', 'test2']), (3, emptyArrayString());
SELECT id, arr FROM test_table WHERE arr = emptyArrayString();
SELECT id FROM test_table WHERE arr = emptyArrayString() UNION SELECT id FROM test_table WHERE arr = ['another_test'];
SELECT id, arrayJoin(arr) AS elem FROM test_table WHERE id IN (SELECT id FROM test_table WHERE arr = emptyArrayString());
WITH emptyArrayString() AS empty_array SELECT id FROM test_table WHERE empty_array = arr;
CREATE TABLE another_table (group_id UInt32, group_arr Array(String));
INSERT INTO another_table VALUES (1, emptyArrayString()), (2, ['group1', 'group2']);
SELECT t1.id, t2.group_id FROM test_table AS t1 JOIN another_table AS t2 ON t1.id = t2.group_id WHERE t2.group_arr = emptyArrayString();
SELECT emptyArrayString() AS empty_string_array, COUNT(*) FROM test_table GROUP BY empty_string_array;