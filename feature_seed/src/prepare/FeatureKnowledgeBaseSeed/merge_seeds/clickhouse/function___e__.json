CREATE TABLE math_test (id Int32, value Float64);
INSERT INTO math_test VALUES (1, e()), (2, e() + 1), (3, e() - 1);
SELECT id, value FROM math_test WHERE value > e();
CREATE TABLE second_table (id Int32, val Float64);
INSERT INTO second_table VALUES (1, e()), (2, 2 * e()), (3, 3 * e());
SELECT a.id, a.value, b.val FROM math_test AS a JOIN second_table AS b ON a.id = b.id WHERE a.value < b.val;
SELECT COUNT(*) FROM math_test WHERE value BETWEEN (e() - 0.1) AND (e() + 0.1);
SELECT id, exp(1) AS exp_value, e() AS e_value FROM math_test;
SELECT id, value * e() AS scaled_value FROM math_test WHERE value > 0;
CREATE TABLE complex_case (val Float64);
INSERT INTO complex_case VALUES (e()), (e() + 0.5), (e() - 0.5);
SELECT AVG(scale.num * e()) AS average_scale FROM (SELECT val * 2 AS num FROM complex_case) AS scale;
SELECT id, val FROM second_table WHERE val IN (SELECT value FROM math_test WHERE id < 3);