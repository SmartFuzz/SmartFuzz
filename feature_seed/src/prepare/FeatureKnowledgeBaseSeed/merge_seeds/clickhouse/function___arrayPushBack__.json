CREATE TABLE test_array_push (id UInt32, arr Array(String));
INSERT INTO test_array_push VALUES (1, ['a', 'b']), (2, ['c']);
SELECT arrayPushBack(arr, 'd') AS new_arr FROM test_array_push WHERE id = 1;
SELECT id, arrayPushBack(arr, NULL) AS new_arr FROM test_array_push;
SELECT arrayPushBack(arrayPushBack(arr, 'e'), 'f') AS new_arr FROM test_array_push WHERE id = 2;
SELECT arrayPushBack(['x', 'y', NULL], 'z') AS new_arr;
SELECT id, arrayPushBack(arr, 'd') AS new_arr FROM test_array_push WHERE arr[1] = 'b';
SELECT DISTINCT arrayPushBack(arr, 'new_value') AS updated_arr FROM (SELECT arr FROM test_array_push WHERE id IN (1, 2));
CREATE TABLE test_numbers (num UInt32, nums Array(UInt32));
INSERT INTO test_numbers VALUES (1, [1, 2, 3]), (2, [4, 5]);
SELECT arrayPushBack(nums, 6) AS new_nums FROM test_numbers;
SELECT id, arrayPushBack(nums, NULL) AS nullable_nums FROM test_numbers;
SELECT id, arrayPushBack(arrayPushBack(nums, 7), 8) AS multi_push_nums FROM test_numbers WHERE num = 1;
SELECT arrayPushBack(arr, 'apple') AS fruit_array FROM (SELECT arr FROM test_array_push) WHERE id = 1;
SELECT id, arrayPushBack(arr, 'banana') AS updated_array FROM test_array_push WHERE length(arr) = 2;