CREATE TABLE test_concat (id Int32, str1 String, str2 String);
INSERT INTO test_concat VALUES (1, 'Hello, ', 'World!');
INSERT INTO test_concat VALUES (2, NULL, 'test');
INSERT INTO test_concat VALUES (3, 'Welcome to ', NULL);
INSERT INTO test_concat VALUES (4, 'Foo', 'Bar');
INSERT INTO test_concat VALUES (5, '123', '456');
INSERT INTO test_concat VALUES (6, 'Final', 'Test');
SELECT concat(str1, str2) FROM test_concat WHERE id = 1;
SELECT concat(str1, str2) FROM test_concat WHERE id = 2;
SELECT id, concat(str1, str2) as concatenated FROM test_concat WHERE str1 IS NOT NULL;
SELECT concat(str1, ' ', str2) FROM test_concat WHERE id = 4;
SELECT concat('Result: ', concat(str1, str2)) as final_result FROM test_concat;
WITH (SELECT concat('A', 'B') AS nested_concat) SELECT concat(nested_concat, 'C') FROM (SELECT DISTINCT concat(str1, str2) AS nested_concat FROM test_concat);
CREATE TABLE other_table (info String);
INSERT INTO other_table VALUES ('Test 1'), ('Test 2');
SELECT concat(info, ': ', str1) FROM other_table CROSS JOIN test_concat WHERE id = 3;
SELECT concat('User ', id, ': ', str1, str2) FROM test_concat WHERE id IN (SELECT id FROM test_concat WHERE str1 != 'Welcome to ');
SELECT concat('Leading text', ' - ', concat(str1, ' | ', str2)) FROM test_concat;
SELECT concat(str1, ' - ', (SELECT concat('Inner ', 'Join') FROM other_table LIMIT 1)) FROM test_concat WHERE id = 5;