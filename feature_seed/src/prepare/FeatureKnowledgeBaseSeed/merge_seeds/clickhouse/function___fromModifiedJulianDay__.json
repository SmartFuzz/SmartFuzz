CREATE TABLE test_dates (day_number Int32);
INSERT INTO test_dates VALUES (-678941), (-678940), (0), (58849), (2973483), (2973484);
SELECT fromModifiedJulianDay(day_number) FROM test_dates WHERE day_number BETWEEN -678941 AND 2973483;
SELECT CASE WHEN day_number < -678941 THEN 'Out of bounds' WHEN day_number > 2973483 THEN 'Out of bounds' ELSE fromModifiedJulianDay(day_number) END AS formatted_date FROM test_dates;
SELECT day_number, fromModifiedJulianDay(day_number) AS formatted_date FROM (SELECT * FROM test_dates WHERE day_number <> 0) AS valid_days WHERE formatted_date IS NOT NULL;
SELECT day_number, (SELECT fromModifiedJulianDay(day_number) AS formatted_date FROM test_dates WHERE day_number = t.day_number) FROM (SELECT day_number FROM test_dates) AS t;
CREATE TABLE result_dates AS SELECT day_number, fromModifiedJulianDay(day_number) AS formatted_date FROM test_dates WHERE day_number BETWEEN -678941 AND 2973483;
SELECT DISTINCT formatted_date FROM (SELECT fromModifiedJulianDay(day_number) AS formatted_date FROM test_dates WHERE day_number != -678940 UNION ALL SELECT fromModifiedJulianDay(day_number) AS formatted_date FROM test_dates WHERE day_number > 0);