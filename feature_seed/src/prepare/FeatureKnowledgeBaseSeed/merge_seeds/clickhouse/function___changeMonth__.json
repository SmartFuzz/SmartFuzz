CREATE TABLE test_dates (date_col Date, datetime_col DateTime);
INSERT INTO test_dates VALUES (toDate('2023-01-01'), toDateTime('2023-01-01 12:00:00'));
INSERT INTO test_dates VALUES (toDate('2023-12-31'), toDateTime('2023-12-31 23:59:59'));
SELECT changeMonth(date_col, 2) FROM test_dates;
SELECT changeMonth(datetime_col, 4) FROM test_dates;
SELECT changeMonth(changeMonth(datetime_col, 1), 5) FROM test_dates;
SELECT changeMonth(toDate('1999-12-31'), 1) AS new_date, changeMonth(toDateTime('1999-12-31 23:59:59'), 1) AS new_datetime;
WITH (SELECT toDate('1999-06-15')) AS base_date SELECT changeMonth(base_date, 7) AS new_month;
SELECT changeMonth(toDateTime64(date_col, 3), 7) FROM test_dates WHERE date_col = toDate('2023-01-01');
WITH (SELECT changeMonth(date_col, 10) FROM test_dates WHERE date_col < toDate('2023-06-01')) AS month_changes SELECT * FROM month_changes;
SELECT changeMonth(toDateTime64('1999-01-01 00:00:00.000', 3), 2) AS new_date_time, changeMonth(toDateTime64('1999-01-01 00:00:00.000', 3), 14) AS new_date_time_out_of_bounds;
SELECT changeMonth(toDate('2022-01-31'), 2) AS change_valid_month, changeMonth(toDate('2022-01-31'), 13) AS change_invalid_month;
SELECT changeMonth(changeMonth(toDate('2020-01-31'), 2), 3) AS nested_change_month;
SELECT changeMonth(toDate('2023-02-28'), 3) AS end_of_month_change;
CREATE TABLE date_test (full_date DateTime);
INSERT INTO date_test VALUES (toDateTime('2023-02-28 12:00:00')), (toDateTime('2023-01-31 12:00:00'));
SELECT changeMonth(full_date, 3) FROM date_test;
SELECT changeMonth(toDateTime('2000-02-28 15:30:00'), -1) AS invalid_month_change;