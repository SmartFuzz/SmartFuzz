CREATE TABLE vectors (id UInt32, vector Tuple(Float32, Float32));
INSERT INTO vectors VALUES (1, (1, 2)), (2, (2, 3)), (3, (0, 0)), (4, (1, 1)), (5, (3, 4));
SELECT cosineDistance((1, 2), (2, 3));
SELECT cosineDistance((0, 0), (0, 0));
SELECT cosineDistance((1, 0), (0, 1));
SELECT cosineDistance((3, 4), (0, 0));
SELECT id, cosineDistance(vector, (1, 2)) AS distance FROM vectors WHERE distance < 0.5;
SELECT id1, id2, cosineDistance(vector1, vector2) AS distance FROM (SELECT id AS id1, vector AS vector1 FROM vectors) AS t1 JOIN (SELECT id AS id2, vector AS vector2 FROM vectors) AS t2 ON id1 < id2;
SELECT id, distance FROM (SELECT id, cosineDistance(vector1, vector2) AS distance FROM (SELECT vector AS vector1 FROM vectors WHERE id = 1) AS t1 CROSS JOIN (SELECT vector AS vector2 FROM vectors WHERE id = 2) AS t2) WHERE distance IS NOT NULL;
SELECT id, cosineDistance(vector, (0.5, 0.5)) AS distance FROM vectors GROUP BY id HAVING distance < 0.1;
CREATE TABLE test_results (vector1 Tuple(Float32, Float32), vector2 Tuple(Float32, Float32), distance Float32);
INSERT INTO test_results SELECT vector, (2, 3), cosineDistance(vector, (2, 3)) FROM vectors;
SELECT AVG(distance) FROM test_results;
SELECT COUNT(*) FROM vectors WHERE cosineDistance(vector, (1, 2)) = 0;