CREATE TABLE test_dates (id Int32, date_col Date, date_time_col DateTime, date_time_string_col String);
INSERT INTO test_dates VALUES (1, toDate('2024-01-01'), toDateTime('2024-01-01 00:00:00'), '2024-01-01 00:00:00');
INSERT INTO test_dates VALUES (2, toDate('2024-02-01'), toDateTime('2024-02-01 12:00:00'), '2024-02-01 12:00:00');
INSERT INTO test_dates VALUES (3, toDate('2025-01-01'), toDateTime('2025-01-01 23:00:00'), '2025-01-01 23:00:00');
SELECT addWeeks(date_col, 5) AS add_weeks_with_date FROM test_dates WHERE id = 1;
SELECT addWeeks(date_time_col, 3) AS add_weeks_with_date_time FROM test_dates WHERE id = 2;
SELECT addWeeks(date_time_string_col, 10) AS add_weeks_with_date_time_string FROM test_dates WHERE id = 3;
WITH (SELECT date_col FROM test_dates WHERE id = 1) AS subquery_date SELECT addWeeks(subquery_date, 2) AS add_weeks_from_subquery;
WITH (SELECT date_time_col FROM test_dates WHERE id = 2) AS subquery_date_time SELECT addWeeks(subquery_date_time, -1) AS add_weeks_negative;
WITH (SELECT date_time_string_col FROM test_dates WHERE id = 3) AS subquery_date_time_string SELECT addWeeks(subquery_date_time_string, 0) AS add_weeks_zero;
SELECT * FROM test_dates WHERE id IN (SELECT id FROM test_dates WHERE date_col <= addWeeks(CURRENT_DATE(), 2));
SELECT d.id, addWeeks(d.date_col, 1) AS new_date FROM test_dates AS d JOIN (SELECT toDate('2024-01-01') AS ref_date) AS r ON d.date_col < r.ref_date;