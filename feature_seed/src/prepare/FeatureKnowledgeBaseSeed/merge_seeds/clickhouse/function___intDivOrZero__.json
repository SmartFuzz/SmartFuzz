CREATE TABLE test_div (a Int32, b Int32);
INSERT INTO test_div VALUES (10, 2), (10, 0), (10, -3), (0, 2), (-10, -1), (-10, 0);
SELECT intDivOrZero(a, b) AS result FROM test_div;
CREATE TABLE test_nested (id Int32, value Int32);
INSERT INTO test_nested VALUES (1, 5), (2, 0), (3, -8);
SELECT id, intDivOrZero(value, (SELECT max(value) FROM test_nested)) AS result FROM test_nested;
CREATE TABLE test_join (id1 Int32, id2 Int32, value1 Int32, value2 Int32);
INSERT INTO test_join VALUES (1, 1, 15, 3), (2, 1, 10, 0), (3, 2, -5, -1);
SELECT j.id1, intDivOrZero(j.value1, j.value2) AS div_result FROM test_join AS j JOIN test_nested AS n ON j.id2 = n.id;
CREATE TABLE test_complex (x Int32, y Int32);
INSERT INTO test_complex VALUES (6, 2), (10, 0), (4, -2);
SELECT intDivOrZero((SELECT sum(x) FROM test_complex), (SELECT count(y) FROM test_complex WHERE y != 0));
CREATE TABLE outer_table (val1 Int32, val2 Int32);
INSERT INTO outer_table VALUES (50, 2), (20, 0), (30, 3);
SELECT o.val1, intDivOrZero(o.val1, (SELECT sum(val2) FROM outer_table)) AS safe_div FROM outer_table AS o;
CREATE TABLE complex_join (a Int32, b Int32, c Int32);
INSERT INTO complex_join VALUES (1, 2, 3), (4, 0, 1), (2, 5, -1);
SELECT cj.a, intDivOrZero(cj.b, (SELECT max(c) FROM complex_join)) AS safe_div FROM complex_join AS cj;