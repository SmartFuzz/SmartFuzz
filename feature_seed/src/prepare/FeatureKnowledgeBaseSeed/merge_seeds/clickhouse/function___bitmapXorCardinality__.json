CREATE TABLE test_bitmaps (id UInt32, b1 AggregateFunction(bitmap, UInt32), b2 AggregateFunction(bitmap, UInt32)) ENGINE = Memory;
INSERT INTO test_bitmaps VALUES (1, bitmapBuild([1, 2, 3]), bitmapBuild([3, 4, 5]));
INSERT INTO test_bitmaps VALUES (2, bitmapBuild([6, 7, 8]), bitmapBuild([8, 9, 10]));
SELECT bitmapXorCardinality(b1, b2) AS xor_cardinality FROM test_bitmaps WHERE id = 1;
SELECT bitmapXorCardinality(bitmapBuild([1]), bitmapBuild([1])) AS xor_cardinality;
SELECT bitmapXorCardinality(bitmapBuild([]), bitmapBuild([2, 3])) AS xor_cardinality;
SELECT bitmapXorCardinality(bitmapBuild([1, 2, 3]), bitmapBuild([])) AS xor_cardinality;
SELECT id, bitmapXorCardinality(b1, b2) AS xor_cardinality FROM test_bitmaps;
SELECT id, bitmapXorCardinality(bitmapBuild([1,2,3,4]), bitmapBuild([4,5,6])) AS xor_cardinality FROM test_bitmaps;
CREATE TABLE test_bitmap_join (group_id UInt32, b1 AggregateFunction(bitmap, UInt32), b2 AggregateFunction(bitmap, UInt32)) ENGINE = Memory;
INSERT INTO test_bitmap_join VALUES (1, bitmapBuild([1, 2]), bitmapBuild([2, 3]));
INSERT INTO test_bitmap_join VALUES (2, bitmapBuild([3, 4]), bitmapBuild([4, 5]));
SELECT group_id, bitmapXorCardinality(b1, b2) AS xor_cardinality FROM test_bitmap_join WHERE group_id IN (SELECT group_id FROM test_bitmap_join WHERE group_id = 1);
SELECT ... FROM (SELECT id, bitmapXorCardinality(b1, b2) AS xor_cardinality FROM test_bitmaps) t1 JOIN (SELECT id, bitmapXorCardinality(b1, b2) AS xor_cardinality FROM test_bitmaps WHERE id > 1) t2 ON t1.id = t2.id;