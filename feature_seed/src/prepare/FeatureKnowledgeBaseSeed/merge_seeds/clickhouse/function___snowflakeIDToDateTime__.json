CREATE TABLE snowflake_ids (id UInt64);
INSERT INTO snowflake_ids VALUES (7204436857747984384), (1288834974657), (0), (1234567890123), (99999999999999999999);
SELECT snowflakeIDToDateTime(id) AS dt FROM snowflake_ids;
SELECT id, snowflakeIDToDateTime(id, 1288834974657) AS dt_epoch FROM snowflake_ids WHERE id > 0;
SELECT id, snowflakeIDToDateTime(id, 0, 'UTC') AS dt_utc FROM snowflake_ids WHERE id IN (SELECT id FROM snowflake_ids WHERE id < 7204436857747984384);
CREATE TABLE joined_table AS SELECT id, snowflakeIDToDateTime(id) AS dt FROM snowflake_ids;
SELECT a.id, b.dt FROM snowflake_ids a JOIN (SELECT id, snowflakeIDToDateTime(id) AS dt FROM snowflake_ids) b ON a.id = b.id;
SELECT DISTINCT snowflakeIDToDateTime(id) FROM snowflake_ids WHERE id IS NOT NULL;
SELECT snowflakeIDToDateTime(id + 1) AS next_dt FROM snowflake_ids WHERE id <= (SELECT MAX(id) FROM snowflake_ids);
WITH (SELECT COUNT(*) FROM snowflake_ids) AS cnt SELECT snowflakeIDToDateTime(id) AS dt FROM snowflake_ids WHERE cnt > 0;