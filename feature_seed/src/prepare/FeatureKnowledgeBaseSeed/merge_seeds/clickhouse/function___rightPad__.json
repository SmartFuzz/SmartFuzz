CREATE TABLE test_strings (input_string String, desired_length Int32, pad_string String DEFAULT ' ');
INSERT INTO test_strings VALUES ('abc', 7, '*'), ('test', 10, '#'), ('longer string', 5, '.'), ('xyz', 3, '-');
SELECT rightPad(input_string, desired_length, pad_string) FROM test_strings;
SELECT rightPad(input_string, desired_length) FROM test_strings WHERE desired_length > 5;
SELECT rightPad(input_string, 7) AS padded_default FROM test_strings WHERE input_string = 'abc';
SELECT rightPad(input_string, length(input_string) * 2, '123') FROM test_strings;
SELECT rightPad(input_string, 10, '#') AS padded_result FROM test_strings WHERE desired_length >= 10;
CREATE TABLE another_table (col1 String, col2 Int32);
INSERT INTO another_table VALUES ('A', 1), ('B', 2), ('C', 3);
SELECT rightPad(concat(col1, ' padded'), 15, '-') FROM another_table;
SELECT rightPad(substring(input_string, 1, 2), 5, '*') FROM test_strings WHERE input_string LIKE 'ab%';
SELECT rightPad(arrayJoin(['test', 'string', 'Hello']), 10) FROM test_strings;
WITH (SELECT AVG(desired_length) FROM test_strings) AS avg_len SELECT rightPad(input_string, avg_len, '.') FROM test_strings;
SELECT rightPad(input_string, MAX(desired_length) OVER()) AS max_padded FROM test_strings;
SELECT rightPad(input_string, 6, '*') AS custom_pad FROM test_strings WHERE input_string != 'longer string';
SELECT rightPad(input_string, desired_length + 2, '!!') AS extended_pad FROM test_strings;