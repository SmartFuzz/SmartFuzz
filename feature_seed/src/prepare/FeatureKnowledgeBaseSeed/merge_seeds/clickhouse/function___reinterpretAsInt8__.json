CREATE TABLE test_table (value UInt8);
INSERT INTO test_table VALUES (127), (128), (255), (256);
SELECT value, reinterpretAsInt8(value) AS reinterpret_value FROM test_table;
SELECT reinterpretAsInt8(toUInt8(257)) AS res;
SELECT reinterpretAsInt8(toUInt8(255)) AS res;
SELECT reinterpretAsInt8(toFloat32(3.14)) AS res;
CREATE TABLE another_table (uuid UUID);
INSERT INTO another_table VALUES (generateUUIDv4());
SELECT reinterpretAsInt8(toUInt8(254)), reinterpretAsInt8(toUInt8(255)), reinterpretAsInt8(toUInt8(256)) FROM another_table;
SELECT t.value, reinterpretAsInt8(t.value + 1) AS reinterpret_value FROM test_table t JOIN another_table a ON reinterpretAsInt8(a.uuid) IS NOT NULL;
SELECT reinterpretAsInt8(reinterpretAsInt8(128) + reinterpretAsInt8(64)) AS reinterpreted_sum;
SELECT interpretAsInt8(CAST(value AS Float64)) AS float_reinterpret FROM test_table;
SELECT reinterpretAsInt8(toString(value)) AS str_reinterpret FROM test_table;
CREATE TABLE complex_table (f1 Float32, f2 UInt8);
INSERT INTO complex_table VALUES (10.1, 1), (20.3, 2), (30.6, 3);
SELECT f1, reinterpretAsInt8(f2) AS interpreted_f2 FROM complex_table WHERE reinterpretAsInt8(f2) > 0;