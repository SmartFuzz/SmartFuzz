CREATE TABLE test_dates (event_date DateTime) ENGINE = Memory;
INSERT INTO test_dates VALUES (toDateTime('1990-01-01 00:00:00')), (toDateTime('2000-01-01 00:00:00')), (toDateTime('2020-01-01 10:00:00'));
SELECT toRelativeMinuteNum(event_date) FROM test_dates;
SELECT toRelativeMinuteNum(toDateTime('2023-10-05 12:00:00')) AS current_time_in_minutes, toRelativeMinuteNum(toDateTime('1980-05-23 15:30:00')) AS past_time_in_minutes;
SELECT event_date, toRelativeMinuteNum(event_date) FROM test_dates WHERE event_date < toDateTime('1995-12-31 23:59:59');
SELECT AVG(toRelativeMinuteNum(event_date)) FROM test_dates;
SELECT a.event_date, b.event_date, toRelativeMinuteNum(a.event_date) as minutes_a, toRelativeMinuteNum(b.event_date) as minutes_b FROM test_dates AS a JOIN test_dates AS b ON toRelativeMinuteNum(a.event_date) < toRelativeMinuteNum(b.event_date);
SELECT (SELECT toRelativeMinuteNum(event_date) FROM test_dates WHERE event_date = (SELECT MAX(event_date) FROM test_dates)) AS latest_event_minutes;
WITH (SELECT COUNT(*) FROM test_dates) AS total_count SELECT toRelativeMinuteNum(toDateTime('2021-01-01 12:00:00')) AS test_time, total_count FROM test_dates;
SELECT toRelativeMinuteNum(toDateTime('1900-01-01 00:00:00')) AS minute_zero_bound, toRelativeMinuteNum(toDateTime('2150-01-01 00:00:00')) AS minute_future_bound;