CREATE TABLE radians_table (value Float64);
INSERT INTO radians_table VALUES (0), (3.141592653589793), (6.283185307179586), (-3.141592653589793), (1.570796326794897), (7.853981633974483);
SELECT degrees(value) FROM radians_table;
SELECT degrees(value) AS degrees_value FROM radians_table WHERE value > 0;
SELECT degrees(value + 1.0) AS incremented_degrees FROM radians_table;
CREATE TABLE angles AS SELECT value FROM radians_table;
SELECT a.value AS radians, degrees(a.value) AS degrees FROM angles a JOIN radians_table b ON a.value = -b.value;
SELECT degrees(AVG(value)) AS avg_degrees FROM radians_table;
SELECT degrees((SELECT SUM(value) FROM radians_table)) AS total_degrees;
SELECT degrees(CASE WHEN value > 0 THEN value ELSE 0 END) AS case_degrees FROM radians_table;
WITH (SELECT MAX(value) FROM radians_table) AS max_value SELECT degrees(max_value) AS degrees_max FROM radians_table;
CREATE TABLE radians_extra (extra_value Float64);
INSERT INTO radians_extra VALUES (3.0), (4.0);
SELECT d.value AS radians, degrees(d.value) AS degrees, e.extra_value FROM radians_table d CROSS JOIN radians_extra e;
SELECT degrees(degrees(3.141592653589793)) AS nested_degree;
WITH (SELECT value FROM radians_table LIMIT 1 OFFSET 1) AS rad_select SELECT degrees(rad_select) AS degrees_selected;