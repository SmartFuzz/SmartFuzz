CREATE TABLE dates_test (event_date DateTime) ENGINE = MergeTree() ORDER BY event_date;
INSERT INTO dates_test VALUES ('2023-04-21 10:20:30'), ('2023-04-30 15:20:30'), ('2022-12-31 23:59:59'), ('2023-05-01 00:00:01');
SELECT toStartOfMonth(event_date) FROM dates_test;
SELECT toStartOfMonth(toDateTime('2023-04-21 10:20:30')) AS start_of_month;
SELECT toStartOfMonth(toDateTime('2023-01-01 00:00:00')) AS start_of_month_first_day;
SELECT toStartOfMonth(toDateTime('2023-01-31 23:59:59')) AS start_of_month_end_day;
SELECT MAX(toStartOfMonth(event_date)) FROM dates_test;
SELECT COUNT(*) AS total_events, toStartOfMonth(event_date) AS month FROM dates_test GROUP BY month;
SELECT DISTINCT toStartOfMonth(event_date) FROM (SELECT event_date FROM dates_test WHERE event_date >= '2023-01-01' AND event_date < '2023-06-01') AS filtered_events;
SELECT event_date, toStartOfMonth(event_date) FROM dates_test WHERE toStartOfMonth(event_date) = '2023-04-01';
SELECT t1.event_date, t2.month FROM dates_test AS t1 JOIN (SELECT DISTINCT toStartOfMonth(event_date) AS month FROM dates_test) AS t2 ON toStartOfMonth(t1.event_date) = t2.month;