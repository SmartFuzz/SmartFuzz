CREATE TABLE test_strings (id Int32, text String);
INSERT INTO test_strings VALUES (1, 'Hello World'), (2, 'OpenAI ChatGPT'), (3, 'clickHOUSE TEST'), (4, 'case insensitive'), (5, 'Boundary conditions');
SELECT id, text FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'hello') > 0;
SELECT id FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'CLICKhouse') > 0;
SELECT id, text FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'INSENSITIVE') > 0 AND id < 5;
SELECT id FROM (SELECT id, text FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'Boundary') > 0) AS subquery;
CREATE TABLE test_words (word String);
INSERT INTO test_words VALUES ('Hello'), ('hello'), ('HELLO'), ('world');
SELECT * FROM test_words WHERE positionCaseInsensitiveUTF8(word, 'HELLO') > 0;
SELECT t1.id, t1.text, t2.word FROM test_strings AS t1 JOIN test_words AS t2 ON positionCaseInsensitiveUTF8(t1.text, t2.word) > 0;
SELECT DISTINCT id FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'ai') > 0 UNION SELECT DISTINCT id FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'TEST') > 0;
SELECT id FROM test_strings WHERE positionCaseInsensitiveUTF8(text, '') = 0;
SELECT id, text FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'condition') = LENGTH(text);
SELECT id FROM test_strings WHERE positionCaseInsensitiveUTF8(text, ' ') = 0;
SELECT id FROM test_strings WHERE positionCaseInsensitiveUTF8(text, 'case INSENSITIVE') > 0 ORDER BY id DESC;