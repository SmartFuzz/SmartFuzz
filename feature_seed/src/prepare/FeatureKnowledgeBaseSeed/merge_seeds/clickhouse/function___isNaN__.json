CREATE TABLE numbers (value Float64);
INSERT INTO numbers VALUES (NaN), (1.0), (2.0), (3.5), (NaN), (0.0);
SELECT value, isNaN(value) AS is_nan FROM numbers;
SELECT value, isNaN(value) AS is_nan FROM numbers WHERE isNaN(value);
CREATE TABLE more_numbers (id UInt32, value Float64);
INSERT INTO more_numbers VALUES (1, 1.0), (2, NaN), (3, 3.5), (4, 0.0);
SELECT mn.id, mn.value, isNaN(mn.value) AS is_nan FROM more_numbers mn JOIN numbers n ON mn.id = n.value;
SELECT COUNT(*) AS nan_count FROM numbers WHERE isNaN(value);
SELECT AVG(value) AS average_value, isNaN(AVG(value)) AS is_nan_avg FROM numbers;
SELECT (SELECT COUNT(*) FROM numbers WHERE isNaN(value)) AS total_nans, (SELECT COUNT(*) FROM numbers) AS total_count;
CREATE TABLE complex_numbers (group_id UInt32, num_value Float64);
INSERT INTO complex_numbers VALUES (1, 1.0), (1, NaN), (2, 2.2), (2, 3.3), (1, 0.0);
SELECT group_id, COUNT(*) AS count, SUM(isNaN(num_value)) AS nan_count FROM complex_numbers GROUP BY group_id;
SELECT (SELECT COUNT(*) FROM complex_numbers WHERE isNaN(num_value) AND group_id = 1) AS group_1_nan_count, (SELECT COUNT(*) FROM complex_numbers WHERE group_id = 1) AS group_1_total_count;
SELECT DISTINCT isNaN(num_value) FROM complex_numbers;
SELECT group_id, AVG(num_value) AS average_value, isNaN(average_value) AS is_nan_avg FROM complex_numbers GROUP BY group_id HAVING group_id = 1;