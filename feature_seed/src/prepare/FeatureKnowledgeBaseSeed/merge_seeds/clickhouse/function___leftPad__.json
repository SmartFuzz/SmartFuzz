CREATE TABLE test_strings (input_string String, padded_length Int32, pad_string String DEFAULT ' ') ENGINE = MergeTree() ORDER BY input_string;
INSERT INTO test_strings VALUES ('abc', 7, '*'), ('def', 7, NULL), ('xyz', 5, '#'), ('longer_string', 5, '-');
SELECT leftPad(input_string, padded_length, pad_string) FROM test_strings;
SELECT leftPad('short', 10) as padded_short FROM test_strings;
SELECT leftPad('example', 5) as trimmed_example FROM test_strings;
SELECT leftPad('data', 8, '0'), leftPad('test', 6, 'foo'), leftPad('string', 10) FROM test_strings;
SELECT leftPad(data.input_string, 10, 'XYZ') FROM (SELECT input_string FROM test_strings WHERE padded_length > 5) as data;
SELECT leftPad((SELECT input_string FROM test_strings WHERE padded_length = 7 LIMIT 1), 10) AS nested_padding;
SELECT leftPad(CONCAT('Result: ', input_string), 20, '-') FROM test_strings WHERE padded_length < 8;
WITH (SELECT input_string FROM test_strings WHERE padded_length = 5) AS subquery SELECT leftPad(input_string, 10) FROM subquery;