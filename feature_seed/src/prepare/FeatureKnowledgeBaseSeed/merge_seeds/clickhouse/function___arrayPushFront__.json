CREATE TABLE test_array_push (arr Array(String));
INSERT INTO test_array_push VALUES (['b']);
SELECT arrayPushFront(arr, 'a') AS result FROM test_array_push;
CREATE TABLE numbers_array (num Array(Int32));
INSERT INTO numbers_array VALUES ([1, 2, 3]);
SELECT arrayPushFront(num, 0) AS result FROM numbers_array;
SELECT arrayPushFront(['c', 'd', 'e'], 'b') AS result;
CREATE TABLE nullable_array (arr Array(Nullable(Int32)));
INSERT INTO nullable_array VALUES ([1, NULL, 3]);
SELECT arrayPushFront(arr, NULL) AS result FROM nullable_array;
SELECT arrayPushFront(arr, -1) AS result FROM numbers_array WHERE num[1] >= 2;
CREATE TABLE complex_test (arr Array(Int32), val Int32);
INSERT INTO complex_test VALUES ([1, 2], 10), ([3, 4], 20);
SELECT arrayPushFront(arr, val) AS result FROM complex_test;
SELECT arrayPushFront(arrayPushFront(arr, 1), 2) AS result FROM numbers_array;
CREATE TABLE nested_array (arr Array(Array(Int32)));
INSERT INTO nested_array VALUES ([[1, 2], [3, 4]]);
SELECT arrayPushFront(arr[1], 0) AS result FROM nested_array;
CREATE TABLE joined_array (id UInt32, ar Array(String));
INSERT INTO joined_array VALUES (1, ['x']), (2, ['y']);
SELECT arrayPushFront(a.ar, 'z') AS result FROM joined_array AS a JOIN joined_array AS b ON a.id = b.id;