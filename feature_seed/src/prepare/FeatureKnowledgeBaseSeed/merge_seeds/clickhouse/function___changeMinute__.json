CREATE TABLE test_dates (dt Date, dt32 Date32, dt64 DateTime64(3)) ENGINE = Memory;
INSERT INTO test_dates VALUES (toDate('1999-01-01'), toDate32('1999-01-01'), toDateTime64('1999-01-01 00:00:00.000', 3));
SELECT changeMinute(dt, 15) FROM test_dates;
SELECT changeMinute(dt32, 45) FROM test_dates;
SELECT changeMinute(dt64, 30) FROM test_dates;
SELECT changeMinute(changeMinute(toDate('1999-01-01'), 15), 30) FROM test_dates;
SELECT changeMinute(toDateTime64('1999-01-01 00:00:00.000', 3), (SELECT number FROM system.numbers LIMIT 1)) FROM test_dates;
SELECT changeMinute(dt, CAST(number AS Int32) % 60) FROM test_dates CROSS JOIN system.numbers AS n WHERE n.number < 60;
SELECT dt, changeMinute(dt, 0) AS minute_changed_0, changeMinute(dt, 59) AS minute_changed_59 FROM test_dates;
SELECT changeMinute(toDate('2023-10-01'), 0), changeMinute(toDate('2023-10-01'), 59);
SELECT dt, dt32, dt64, changeMinute(dt64, 1) FROM test_dates WHERE changeMinute(dt32, 30) IS NOT NULL;