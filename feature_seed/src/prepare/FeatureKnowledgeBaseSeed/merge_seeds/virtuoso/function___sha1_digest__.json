CREATE TABLE test_table (id INT, data VARCHAR);
INSERT INTO test_table (id, data) VALUES (1, 'demodemo');
SELECT sha1_digest(data) FROM test_table WHERE id = 1;
INSERT INTO test_table (id, data) VALUES (2, '');
SELECT sha1_digest(data) FROM test_table WHERE id = 2;
INSERT INTO test_table (id, data) VALUES (3, NULL);
SELECT sha1_digest(data) FROM test_table WHERE id = 3;
CREATE TABLE another_table (user_id INT, info VARCHAR);
INSERT INTO another_table (user_id, info) VALUES (1, 'user_data');
SELECT a.user_id, sha1_digest(a.info) FROM another_table a JOIN test_table t ON a.user_id = t.id;
SELECT sha1_digest(CONCAT(t.data, a.info)) FROM test_table t JOIN another_table a ON t.id = a.user_id;
SELECT sha1_digest(COALESCE(data, 'default')) FROM test_table;
SELECT sha1_digest(subquery.sha1_value) FROM (SELECT data AS sha1_value FROM test_table) subquery;
SELECT sha1_digest(UPPER(data)) FROM test_table;
SELECT sha1_digest(LOWER(data)) FROM test_table WHERE LENGTH(data) > 5;