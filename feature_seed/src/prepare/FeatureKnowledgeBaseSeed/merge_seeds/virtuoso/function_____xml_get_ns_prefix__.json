CREATE TABLE namespace_test (id INT, uri VARCHAR(255), prefix VARCHAR(100));
INSERT INTO namespace_test (id, uri, prefix) VALUES (1, 'http://www.w3.org/1999/xhtml', 'html');
INSERT INTO namespace_test (id, uri, prefix) VALUES (2, 'http://www.w3.org/2000/xmlns/', 'xml');
INSERT INTO namespace_test (id, uri, prefix) VALUES (3, 'http://www.example.com/ns/', NULL);
SELECT __xml_get_ns_prefix('http://www.w3.org/1999/xhtml') AS prefix1;
SELECT __xml_get_ns_prefix('http://www.w3.org/2000/xmlns/') AS prefix2;
SELECT __xml_get_ns_prefix('http://www.example.com/ns/') AS prefix3;
SELECT t.uri, __xml_get_ns_prefix(t.uri) FROM namespace_test t WHERE t.id = 1;
SELECT t.uri, __xml_get_ns_prefix(t.uri) FROM namespace_test t WHERE t.prefix IS NULL;
SELECT t1.uri, __xml_get_ns_prefix(t1.uri) FROM namespace_test t1 JOIN namespace_test t2 ON t1.id = t2.id WHERE t2.prefix IS NOT NULL;
SELECT (SELECT __xml_get_ns_prefix('http://www.w3.org/1999/xhtml') AS html_prefix) AS html_prefix, (SELECT __xml_get_ns_prefix('http://www.w3.org/2000/xmlns/') AS xml_prefix) AS xml_prefix;
SELECT COALESCE((SELECT __xml_get_ns_prefix('http://www.example.com/ns/') AS example_prefix), 'not found') AS example_prefix;
SELECT DISTINCT __xml_get_ns_prefix(t.uri) FROM namespace_test t WHERE t.uri LIKE 'http://%';
SELECT COUNT(*) FROM namespace_test WHERE __xml_get_ns_prefix(uri) IS NOT NULL;