CREATE TABLE test_table (id integer, data varchar);
INSERT INTO test_table (id, data) VALUES (1, make_string(10));
CREATE PROCEDURE manipulate_string () { declare _str varchar;
declare _inx integer;
_str := 'Hello';
while (_inx < length(_str)) { aset(_str, _inx, ASCII(substr('World', _inx + 1, 1)));
_inx := _inx + 1;
} return (_str);
};
SELECT manipulate_string();
CREATE PROCEDURE replace_characters (in str varchar) { declare _inx integer;
if (str is null) return (str);
while (_inx < length(str)) { aset(str, _inx, 65 + _inx);
_inx := _inx + 1;
} return (str);
};
SELECT replace_characters('');
SELECT replace_characters(NULL);
SELECT replace_characters('A');
CREATE TABLE numbers (num integer);
INSERT INTO numbers (num) VALUES (0), (1), (2), (3), (4);
CREATE PROCEDURE reverse_numbers () { declare _str varchar;
declare _inx1 integer;
declare _inx2 integer;
declare len integer;
len := 5;
_str := make_string(len);
_inx1 := 0;
_inx2 := len - 1;
while (_inx1 < len / 2) { aset(_str, _inx1, aref(nums, _inx2));
aset(_str, _inx2, aref(nums, _inx1));
_inx1 := _inx1 + 1;
_inx2 := _inx2 - 1;
} return (_str);
};
SELECT reverse_numbers();
SELECT (SELECT aset('Sample', 2, 90) FROM test_table WHERE id = 1);
CREATE PROCEDURE combine_strings (in str1 varchar, in str2 varchar) { declare _combined varchar;
_combined := make_string(length(str1) + length(str2));
for i in 0 to length(str1) - 1 { aset(_combined, i, aref(str1, i));
} for j in 0 to length(str2) - 1 { aset(_combined, length(str1) + j, aref(str2, j));
} return (_combined);
};
SELECT combine_strings('Hello', 'World');
CREATE PROCEDURE modify_nested_tables () { declare _str varchar;
declare _temp varchar;
_str := (SELECT data FROM test_table WHERE id = 1);
_temp := 'Test';
aset(_str, 0, ASCII(substr(_temp, 1, 1)));
return (_str);
};
SELECT modify_nested_tables();