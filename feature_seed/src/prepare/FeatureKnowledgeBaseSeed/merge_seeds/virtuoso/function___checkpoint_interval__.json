CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(100));
INSERT INTO test_table (id, value) VALUES (1, 'test1');
INSERT INTO test_table (id, value) VALUES (2, 'test2');
CREATE TABLE another_table (id INT PRIMARY KEY, fk_id INT REFERENCES test_table(id), description VARCHAR(255));
INSERT INTO another_table (id, fk_id, description) VALUES (1, 1, 'description1');
INSERT INTO another_table (id, fk_id, description) VALUES (2, 2, 'description2');
SELECT * FROM test_table WHERE id IN (SELECT fk_id FROM another_table WHERE description = 'description1');
SELECT COUNT(*) FROM test_table WHERE value LIKE '%test%';
SELECT tt.value, at.description FROM test_table tt JOIN another_table at ON tt.id = at.fk_id WHERE tt.id = (SELECT MAX(id) FROM test_table);
