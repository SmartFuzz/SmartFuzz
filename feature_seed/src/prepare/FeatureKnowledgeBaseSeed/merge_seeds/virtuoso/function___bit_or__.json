CREATE TABLE test_numbers (id INT, num1 INT, num2 INT);
INSERT INTO test_numbers VALUES (1, 18, 6);
INSERT INTO test_numbers VALUES (2, -18, -6);
INSERT INTO test_numbers VALUES (3, 2147483647, 1);
INSERT INTO test_numbers VALUES (4, 0, 0);
INSERT INTO test_numbers VALUES (5, 2147483648, 1);
INSERT INTO test_numbers VALUES (6, -1, -2);
SELECT bit_or(num1, num2) FROM test_numbers WHERE id = 1;
SELECT bit_or(num1, num2) FROM test_numbers WHERE id = 2;
SELECT bit_or(num1, num2) FROM test_numbers WHERE id = 3;
SELECT bit_or(num1, num2) FROM test_numbers WHERE id = 4;
SELECT bit_or(num1, num2) FROM test_numbers WHERE id = 5;
SELECT bit_or(num1, num2) FROM test_numbers WHERE id = 6;
SELECT id, bit_or(num1, num2) AS result FROM test_numbers GROUP BY id;
SELECT id, bit_or(num1, num2) AS result FROM test_numbers WHERE id IN (SELECT id FROM test_numbers WHERE num1 < 0);
SELECT a.id, bit_or(a.num1, b.num2) AS result FROM test_numbers a JOIN test_numbers b ON a.id != b.id;
SELECT id, (bit_or(num1, num2) + 5) AS adjusted_result FROM test_numbers;
SELECT id, bit_or(num1, (SELECT MAX(num2) FROM test_numbers)) AS max_or_result FROM test_numbers;