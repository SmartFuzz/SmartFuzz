CREATE TABLE trigonometric_functions (angle DOUBLE PRECISION, result DOUBLE PRECISION);
INSERT INTO trigonometric_functions (angle, result) VALUES (0, cos(0));
INSERT INTO trigonometric_functions (angle, result) VALUES (0, sin(0));
INSERT INTO trigonometric_functions (angle, result) VALUES (pi()/2, cos(pi()/2));
INSERT INTO trigonometric_functions (angle, result) VALUES (pi()/2, sin(pi()/2));
INSERT INTO trigonometric_functions (angle, result) VALUES (pi(), cos(pi()));
INSERT INTO trigonometric_functions (angle, result) VALUES (pi(), sin(pi()));
SELECT angle, result FROM trigonometric_functions WHERE angle BETWEEN -pi() AND pi();
SELECT angle, result FROM trigonometric_functions WHERE result = tan(angle) AND angle != (pi()/2);
SELECT angle, result FROM trigonometric_functions WHERE angle = atan(1) OR angle = atan2(1, 1);
CREATE TABLE additional_trig_data (x DOUBLE PRECISION, y DOUBLE PRECISION, angle DOUBLE PRECISION);
INSERT INTO additional_trig_data (x, y, angle) VALUES (1, 1, atan2(1, 1));
SELECT a.angle, a.result FROM trigonometric_functions a JOIN additional_trig_data b ON a.result = b.angle;
SELECT DISTINCT cos(angle), sin(angle) FROM trigonometric_functions GROUP BY angle HAVING cos(angle) > 0;
DELETE FROM trigonometric_functions WHERE angle < -pi() OR angle > pi();
SELECT COUNT(*) FROM trigonometric_functions WHERE result IS NULL;
SELECT angle FROM trigonometric_functions WHERE angle = degrees(90) OR angle = degrees(0);