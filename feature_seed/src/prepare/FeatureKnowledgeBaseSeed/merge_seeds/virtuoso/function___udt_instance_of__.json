CREATE TYPE SER_UDT AS (field1 INT, field2 VARCHAR(50));
CREATE TYPE SER_UDT_SUB UNDER SER_UDT AS (field3 DATE);
SELECT udt_instance_of('SER_UDT');
SELECT udt_instance_of(new SER_UDT());
SELECT udt_instance_of('SER_UDT_SUB', 'SER_UDT');
SELECT udt_instance_of(new SER_UDT(), 'SER_UDT_SUB');
SELECT CASE WHEN udt_instance_of(new SER_UDT(), 'SER_UDT') THEN 'Match' ELSE 'No Match' END AS TypeMatch;
SELECT udt_instance_of((SELECT new SER_UDT() AS Example WHERE Example.field1 > 5));
SELECT udt_instance_of(new SER_UDT_SUB()) AND udt_instance_of(new SER_UDT());
SELECT udt_instance_of(new SER_UDT()) OR udt_instance_of('SER_UDT_SUB');
SELECT udt_instance_of('SER_UDT_SUB') AS SubType FROM (SELECT 'SER_UDT_SUB' AS Type) AS Temp;
SELECT A.TypeName FROM (SELECT 'SER_UDT' AS TypeName) AS A WHERE udt_instance_of(A.TypeName);
WITH Types AS (SELECT 'SER_UDT' AS TypeName UNION SELECT 'SER_UDT_SUB') SELECT TypeName FROM Types WHERE udt_instance_of(TypeName);
SELECT (SELECT udt_instance_of(new SER_UDT_SUB()) AS SubTypeCheck) FROM DUAL WHERE udt_instance_of('SER_UDT');
SELECT COUNT(*) FROM (SELECT udt_instance_of(new SER_UDT()) AS TypeCheck) AS Result WHERE TypeCheck = TRUE;