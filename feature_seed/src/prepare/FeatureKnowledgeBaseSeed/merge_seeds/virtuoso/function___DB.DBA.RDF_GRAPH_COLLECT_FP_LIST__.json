CREATE GRAPH <http://example.org/graph1>;
CREATE GRAPH <http://example.org/graph2>;
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/subject1> <http://example.org/predicate1> <http://example.org/object1> . } };
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/subject2> <http://example.org/predicate2> <http://example.org/object2> . } };
SELECT ?property WHERE { GRAPH <http://example.org/graph1> { ?s ?property ?o . } };
SELECT DISTINCT ?s WHERE { GRAPH <http://example.org/graph1> { ?s <http://example.org/predicate1> ?o . } } LIMIT 10;
SELECT ?s ?o WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . } FILTER(?o = <http://example.org/object1>) };
SELECT ?subject ?predicate ?object WHERE { GRAPH <http://example.org/graph1> { ?subject ?predicate ?object . } UNION { GRAPH <http://example.org/graph2> { ?subject ?predicate ?object . } } };
SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . } GRAPH <http://example.org/graph2> { ?s <http://example.org/predicate1> ?o . } };
SELECT ?s WHERE { { SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . } } LIMIT 5 } UNION { SELECT ?s WHERE { GRAPH <http://example.org/graph2> { ?s ?p ?o . } } LIMIT 5 } };
SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . } } ORDER BY ?s LIMIT 10 OFFSET 5;
SELECT (COUNT(?s) AS ?count) WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . } };
SELECT ?s ?o WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o . FILTER(STR(?o) = 'object1') } } ORDER BY ?s;
SELECT ?property WHERE { GRAPH <http://example.org/graph1> { ?s ?property ?o . BIND(STR(?property) AS ?propStr) FILTER(?propStr = 'predicate1') } };