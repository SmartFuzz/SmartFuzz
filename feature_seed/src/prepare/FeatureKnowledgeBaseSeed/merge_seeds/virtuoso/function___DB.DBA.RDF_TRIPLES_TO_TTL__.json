CREATE GRAPH <http://fake.example.org/graph/>;
INSERT DATA { GRAPH <http://fake.example.org/graph/> { <http://example.org/item1> <http://example.org/property> "Value1" . } };
INSERT DATA { GRAPH <http://fake.example.org/graph/> { <http://example.org/item2> <http://example.org/property> "Value2" . } };
INSERT DATA { GRAPH <http://fake.example.org/graph/> { <http://example.org/item3> <http://example.org/property> "Value3" . } };
CREATE PROCEDURE RDFXML2N3 (IN _rdfxml VARCHAR) { DECLARE triples, ses ANY;
DECLARE STRG VARCHAR;
result_names(STRG);
DELETE FROM RDF_QUAD WHERE G=DB.DBA.RDF_MAKE_IID_OF_QNAME('http://fake.example.org/graph/');
DB.DBA.RDF_LOAD_RDFXML_MT(_rdfxml, 'http://fake.example.org/base/', 'http://fake.example.org/graph/');
FOR (SPARQL DEFINE output:valmode 'LONG' SELECT ?s ?p ?o WHERE { GRAPH <http://fake.example.org/graph/> { ?s ?p ?o } } ORDER BY ?s ?p ?o) DO { ses := string_output();
DB.DBA.RDF_TRIPLES_TO_TTL(vector(vector('s', 'p', 'o')), ses);
result(sprintf('%s\t%d %d', replace(string_output_string(ses), '\n', ' '), rdf_box_type('o'), rdf_box_data_tag('o')));
} } DONE;
CALL RDFXML2N3('<?xml version="1.0"?><rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#" xmlns:dc="http://purl.org/dc/elements/1.1/" xmlns:ex="http://example.org/stuff/1.0/"><rdf:Description rdf:about="http://www.example.org/resource1"><dc:title>Example Title 1</dc:title></rdf:Description><rdf:Description rdf:about="http://www.example.org/resource2"><ex:editor><rdf:Description><ex:fullName>John Doe</ex:fullName></rdf:Description></ex:editor></rdf:Description></rdf:RDF>');
SELECT ?s ?p ?o WHERE { GRAPH <http://fake.example.org/graph/> { ?s ?p ?o } };
INSERT DATA { GRAPH <http://fake.example.org/graph/> { <http://example.org/item4> <http://example.org/property> "Value4" . } };
DELETE { GRAPH <http://fake.example.org/graph/> { ?s ?p ?o } } WHERE { GRAPH <http://fake.example.org/graph/> { ?s ?p ?o } };
SELECT ?s ?p ?o WHERE { GRAPH <http://fake.example.org/graph/> { ?s ?p ?o } } ORDER BY ?s DESC;
SELECT (COUNT(?s) AS ?count) WHERE { GRAPH <http://fake.example.org/graph/> { ?s ?p ?o } };
CREATE INDEX ON RDF_QUAD (G);