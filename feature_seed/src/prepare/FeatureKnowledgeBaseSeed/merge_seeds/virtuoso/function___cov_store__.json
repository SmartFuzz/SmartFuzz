CREATE TABLE test_coverage (id INT PRIMARY KEY, coverage_data TEXT);
INSERT INTO test_coverage (id, coverage_data) VALUES (1, 'Line 1: functionA called');
INSERT INTO test_coverage (id, coverage_data) VALUES (2, 'Line 2: functionB called');
INSERT INTO test_coverage (id, coverage_data) VALUES (3, 'Line 3: functionC called');
SELECT * FROM test_coverage WHERE id = 1;
SELECT coverage_data FROM test_coverage WHERE id = (SELECT MAX(id) FROM test_coverage);
SELECT * FROM test_coverage WHERE id IN (SELECT id FROM test_coverage WHERE coverage_data LIKE '%function%');
UPDATE test_coverage SET coverage_data = 'Line 1: functionA modified' WHERE id = 1;
DELETE FROM test_coverage WHERE id = 2;
SELECT COUNT(*) FROM test_coverage WHERE coverage_data IS NOT NULL;
SELECT * FROM test_coverage t1 JOIN (SELECT id, COUNT(*) as call_count FROM test_coverage GROUP BY id) t2 ON t1.id = t2.id WHERE t2.call_count > 1;
INSERT INTO test_coverage (id, coverage_data) SELECT t1.id, t1.coverage_data FROM (VALUES (4, 'Line 4: functionD called'), (5, 'Line 5: functionE called')) AS t1(id, coverage_data);
SELECT id, coverage_data FROM test_coverage WHERE LENGTH(coverage_data) < 50;
SELECT id, coverage_data FROM test_coverage ORDER BY LENGTH(coverage_data) DESC LIMIT 5;
CREATE TABLE test_summary AS SELECT COUNT(*) as total_entries FROM test_coverage;
SELECT t1.id, t1.coverage_data FROM test_coverage t1 LEFT JOIN test_coverage t2 ON t1.id = t2.id WHERE t2.id IS NULL;