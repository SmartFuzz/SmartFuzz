DELETE FROM businessEntity WHERE businessKey = 'businessKey1';
DELETE FROM businessEntity WHERE businessKey IN (SELECT businessKey FROM businessEntity WHERE status = 'inactive');
DELETE FROM businessEntity WHERE businessKey IN (SELECT businessKey FROM businessEntity WHERE businessName LIKE '%test%');
DELETE FROM businessEntity WHERE EXISTS (SELECT 1 FROM service WHERE service.businessKey = businessEntity.businessKey AND service.status = 'inactive');
DELETE FROM businessEntity WHERE businessKey IN (SELECT businessKey FROM businessEntity WHERE creationDate < '2022-01-01');
DELETE FROM businessEntity WHERE businessKey IN (SELECT businessKey FROM businessEntity be JOIN category c ON be.categoryId = c.id WHERE c.name = 'obsolete');
DELETE FROM businessEntity WHERE businessKey IN (SELECT businessKey FROM (SELECT businessKey FROM businessEntity WHERE createdBy = 'admin' LIMIT 10) AS subquery);
DELETE FROM businessEntity WHERE businessKey NOT IN (SELECT businessKey FROM service);
DELETE FROM businessEntity WHERE businessKey IN (SELECT b.businessKey FROM businessEntity b JOIN businessRelations br ON b.businessKey = br.childBusinessKey WHERE br.parentBusinessKey = 'parentKey1');
DELETE FROM businessEntity WHERE businessKey = (SELECT businessKey FROM businessEntity ORDER BY creationDate DESC LIMIT 1);