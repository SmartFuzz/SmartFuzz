CREATE TABLE test_strings (id INTEGER, value VARCHAR(255));
INSERT INTO test_strings (id, value) VALUES (1, 'AbracadabrA');
INSERT INTO test_strings (id, value) VALUES (2, 'hello');
INSERT INTO test_strings (id, value) VALUES (3, 'world');
INSERT INTO test_strings (id, value) VALUES (4, 'abracadabra');
INSERT INTO test_strings (id, value) VALUES (5, 'abracadabrA');
SELECT ends_with(value, 'rA') FROM test_strings WHERE id = 1;
SELECT ends_with(value, 'o') FROM test_strings WHERE id = 2;
SELECT DISTINCT ends_with(value, 'd') FROM test_strings;
SELECT id, value, ends_with(value, 'A') AS ends_with_A FROM test_strings WHERE ends_with(value, 'A') = 1;
SELECT t1.id, t1.value FROM test_strings t1 JOIN test_strings t2 ON ends_with(t1.value, t2.value) WHERE t2.id = 4;
SELECT ends_with(value, 'A') AS ends_with_A, COUNT(*) FROM test_strings GROUP BY ends_with_A;
SELECT (SELECT value FROM test_strings WHERE id = 5) AS string_value, ends_with((SELECT value FROM test_strings WHERE id = 5), 'rA') AS ends_with_result;
SELECT ends_with(NULL, 'A') AS result;
SELECT ends_with('test', '') AS result;
SELECT ends_with('', 'test') AS result;
SELECT ends_with('', '') AS result;