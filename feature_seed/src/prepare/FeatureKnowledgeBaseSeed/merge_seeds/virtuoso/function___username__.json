CREATE TABLE users (id INT, username VARCHAR, password VARCHAR);
INSERT INTO users (id, username, password) VALUES (1, 'dba', 'secret');
SELECT username() AS current_user;
SELECT user AS current_user FROM users WHERE id = 1;
SELECT (SELECT username() FROM users) AS current_user;
SELECT username(), (SELECT COUNT(*) FROM users) AS total_users;
SELECT u.username FROM users u JOIN (SELECT id FROM users WHERE password = 'secret') AS user_filter ON u.id = user_filter.id;
SELECT username() AS current_user, (SELECT MAX(id) FROM users) AS max_user_id;
SELECT username() AS current_user WHERE EXISTS (SELECT * FROM users);
SELECT username() FROM users WHERE username IN (SELECT username FROM users WHERE id < 10);
SELECT username() FROM (SELECT * FROM users) AS user_alias WHERE username = 'dba';
SELECT (CASE WHEN (SELECT COUNT(*) FROM users) > 0 THEN username() ELSE 'no users' END) AS current_user_status;