CREATE TABLE geometries (id INTEGER PRIMARY KEY, geom GEOMETRY);
INSERT INTO geometries (id, geom) VALUES (1, st_point(10, 20, 30, 40));
INSERT INTO geometries (id, geom) VALUES (2, st_point(5, 15, 25, 35));
INSERT INTO geometries (id, geom) VALUES (3, st_point(0, 0, 0, 0));
INSERT INTO geometries (id, geom) VALUES (4, st_point(-10, -10, -10, -10));
INSERT INTO geometries (id, geom) VALUES (5, st_point(100, 200, 300, 400));
SELECT st_z(geom) FROM geometries WHERE id = 1;
SELECT st_z(geom) FROM geometries WHERE id = 2;
SELECT st_z(geom) FROM geometries WHERE id = 3;
SELECT st_z(geom) FROM geometries WHERE id = 4;
SELECT st_z(geom) FROM geometries WHERE id = 5;
SELECT st_z(st_point(10, 20, 30, 40)) AS z_coord, st_z(st_point(5, 15, 25, 35)) AS z_coord2;
SELECT z_vals.geom_id, z_vals.z_coord FROM (SELECT id AS geom_id, st_z(geom) AS z_coord FROM geometries) z_vals WHERE z_coord > 20;
WITH z_values AS (SELECT id, st_z(geom) AS z_val FROM geometries) SELECT * FROM z_values WHERE z_val < 50;
SELECT COUNT(*) FROM geometries WHERE st_z(geom) IS NOT NULL;
SELECT geom FROM geometries WHERE st_z(geom) IN (SELECT z_val FROM (SELECT st_z(geom) AS z_val FROM geometries) subquery WHERE z_val > 0);