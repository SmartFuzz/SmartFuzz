CREATE PROCEDURE schema_assignment_test_1 () { DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
RESULT_NAMES (PROBE);
orig_instance := XMLType ('<sample-xml/>');
RESULT (concat ('"orig_instance" is declared as non schema-based, URI=', cast (orig_instance.getSchemaURL() as varchar)));
schema_based_copy := orig_instance.createSchemaBasedXML ('http://www.example.com/test.xsd');
RESULT (concat ('"schema_based_copy" is schema-based, URI=', schema_based_copy.getSchemaURL()));
} schema_assignment_test_1();
CREATE PROCEDURE schema_assignment_test_2 () { DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
RESULT_NAMES (PROBE);
orig_instance := XMLType ('<sample-xml/>');
schema_based_copy := orig_instance.createSchemaBasedXML ('http://www.example.com/test.xsd');
RESULT (concat ('"orig_instance" is declared as non schema-based, URI=', cast (orig_instance.getSchemaURL() as varchar)));
RESULT (concat ('"schema_based_copy" is schema-based, URI=', schema_based_copy.getSchemaURL()));
} schema_assignment_test_2();
CREATE TABLE xml_data (id INT, xml_column XMLType);
INSERT INTO xml_data (id, xml_column) VALUES (1, XMLType('<data><item>Item 1</item></data>'));
DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
orig_instance := (SELECT xml_column FROM xml_data WHERE id = 1);
schema_based_copy := orig_instance.createSchemaBasedXML ('http://www.example.com/item.xsd');
RESULT (concat ('"schema_based_copy" is schema-based, URI=', schema_based_copy.getSchemaURL()));
CREATE TABLE xml_data_multiple (id INT, xml_column XMLType);
INSERT INTO xml_data_multiple (id, xml_column) VALUES (1, XMLType('<data><item>Item 1</item></data>'));
INSERT INTO xml_data_multiple (id, xml_column) VALUES (2, XMLType('<data><item>Item 2</item></data>'));
DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
orig_instance := (SELECT xml_column FROM xml_data_multiple WHERE id = 1);
schema_based_copy := orig_instance.createSchemaBasedXML ('http://www.example.com/multipleschema.xsd');
RESULT (concat ('"schema_based_copy" is schema-based, URI=', schema_based_copy.getSchemaURL()));
CREATE PROCEDURE schema_assignment_test_boundary () { DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
RESULT_NAMES (PROBE);
orig_instance := XMLType ('<data/>');
schema_based_copy := orig_instance.createSchemaBasedXML (NULL);
RESULT (concat ('"Orig instance URI="', cast (orig_instance.getSchemaURL() as varchar), '" and schema_based_copy URI="', cast (schema_based_copy.getSchemaURL() as varchar), '".'));
} schema_assignment_test_boundary();
CREATE PROCEDURE schema_assignment_test_repeated () { DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
RESULT_NAMES (PROBE);
orig_instance := XMLType ('<data/>');
schema_based_copy := orig_instance.createSchemaBasedXML ('http://www.example.com/test.xsd');
schema_based_copy := schema_based_copy.createSchemaBasedXML ('http://www.example.com/test.xsd');
RESULT (concat ('"orig_instance" URI=', cast (orig_instance.getSchemaURL() as varchar), ', "schema_based_copy" URI=', schema_based_copy.getSchemaURL()));
} schema_assignment_test_repeated();
CREATE PROCEDURE schema_assignment_test_invalid () { DECLARE orig_instance XMLType;
DECLARE schema_based_copy XMLType;
DECLARE PROBE varchar;
RESULT_NAMES (PROBE);
orig_instance := XMLType ('<data/>');
schema_based_copy := orig_instance.createSchemaBasedXML ('invalid-schema-url');
RESULT (concat ('"schema_based_copy" with a malformed URL, URI=', schema_based_copy.getSchemaURL()));
} schema_assignment_test_invalid();