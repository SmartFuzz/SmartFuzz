CREATE TABLE users (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO users (id, name) VALUES (1, 'john doe');
INSERT INTO users (id, name) VALUES (2, 'jane smith');
SELECT upper(name) AS upper_name FROM users;
SELECT u1.name, upper(u2.name) AS upper_name FROM users u1 JOIN users u2 ON u1.id <> u2.id;
SELECT upper(name) FROM (SELECT name FROM users WHERE id = 1) AS subquery;
SELECT upper(name) FROM users WHERE id IN (SELECT id FROM users WHERE name LIKE 'jane%');
CREATE TABLE products (id INT PRIMARY KEY, description VARCHAR(255));
INSERT INTO products (id, description) VALUES (1, 'example product');
SELECT upper(p.description) FROM products p JOIN users u ON p.id = u.id LIMIT 10;
SELECT upper(p.description) FROM products p WHERE EXISTS (SELECT * FROM users u WHERE u.id = p.id);
CREATE TABLE orders (id INT PRIMARY KEY, user_id INT, product_id INT, FOREIGN KEY (user_id) REFERENCES users(id), FOREIGN KEY (product_id) REFERENCES products(id));
INSERT INTO orders (id, user_id, product_id) VALUES (1, 1, 1);
SELECT u.id, upper(u.name), upper(p.description) FROM users u JOIN orders o ON u.id = o.user_id JOIN products p ON o.product_id = p.id;
SELECT upper('hello world!');
SELECT upper('café');
SELECT upper(chr(225));
SELECT upper('ño');
SELECT upper('Бог');