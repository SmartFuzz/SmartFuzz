CREATE TABLE article (id INT, description TEXT);
CREATE TEXT INDEX ON article (description);
INSERT INTO article (id, description) VALUES (1, 'First article description.');
INSERT INTO article (id, description) VALUES (2, 'Second article description with more text.');
UPDATE article SET description = 'Updated first article description.' WHERE id = 1;
DELETE FROM article WHERE id = 2;
SELECT * FROM article WHERE description MATCH 'article';
CREATE TABLE words (id INT, word VARCHAR(255));
CREATE TEXT INDEX ON words (word);
INSERT INTO words (id, word) VALUES (1, 'First');
INSERT INTO words (id, word) VALUES (2, 'Second');
CREATE TEXT INDEX ON article (description);
DROP TEXT TRIGGER ON article (description);
CREATE TABLE author (id INT, name VARCHAR(255));
CREATE TABLE article_author (article_id INT, author_id INT);
INSERT INTO author (id, name) VALUES (1, 'John Doe');
INSERT INTO author (id, name) VALUES (2, 'Jane Smith');
INSERT INTO article_author (article_id, author_id) VALUES (1, 1);
INSERT INTO article_author (article_id, author_id) VALUES (1, 2);
SELECT a.id, a.description, STRING_AGG(au.name, ', ') AS authors FROM article a JOIN article_author aa ON a.id = aa.article_id JOIN author au ON aa.author_id = au.id GROUP BY a.id;
SELECT * FROM article WHERE description MATCH 'description' AND id IN (SELECT article_id FROM article_author WHERE author_id = 1);
UPDATE article SET description = CONCAT(description, ' - Updated') WHERE id < 3;
DELETE FROM article WHERE id NOT IN (SELECT article_id FROM article_author);
CREATE TEXT INDEX ON article (description) WITH OPTIONS ('weight' = '0.5');