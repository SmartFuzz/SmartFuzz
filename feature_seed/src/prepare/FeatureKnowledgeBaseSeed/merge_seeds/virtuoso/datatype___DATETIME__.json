CREATE TABLE event_schedule (event_id INT PRIMARY KEY, event_name VARCHAR(255), event_start DATETIME, event_end DATETIME);
INSERT INTO event_schedule (event_id, event_name, event_start, event_end) VALUES (1, 'New Year Party', '2023-12-31 23:59:59', '2024-01-01 01:00:00');
INSERT INTO event_schedule (event_id, event_name, event_start, event_end) VALUES (2, 'Weekly Meeting', '2023-10-23 09:00:00', '2023-10-23 10:00:00');
SELECT * FROM event_schedule WHERE event_start < '2024-01-01 00:00:00' AND event_end > '2023-10-22 23:59:59';
SELECT event_name FROM event_schedule WHERE event_start BETWEEN '2023-10-01 00:00:00' AND '2023-10-31 23:59:59';
SELECT COUNT(*) FROM event_schedule WHERE event_start < NOW() AND event_end > NOW();
CREATE TABLE date_test (test_id INT PRIMARY KEY, test_date DATETIME);
INSERT INTO date_test (test_id, test_date) VALUES (1, '1998-02-28 00:00:00');
INSERT INTO date_test (test_id, test_date) VALUES (2, '1998-02-29 00:00:00');
SELECT test_id FROM date_test WHERE test_date = '1998-02-28 00:00:00' OR test_date = '1998-02-29 00:00:00';
SELECT event_name FROM event_schedule WHERE DATE(event_start) = '2023-12-31';
SELECT event_id, event_name FROM event_schedule WHERE event_end > event_start ORDER BY event_start DESC;
CREATE TABLE user_activity (user_id INT, activity_time DATETIME, PRIMARY KEY (user_id, activity_time));
INSERT INTO user_activity (user_id, activity_time) VALUES (1001, '2023-10-01 12:00:00'), (1002, '2023-10-02 14:30:00');
SELECT user_id FROM user_activity WHERE activity_time <= NOW() ORDER BY activity_time DESC LIMIT 5;
SELECT a.event_name FROM event_schedule a INNER JOIN user_activity b ON a.event_start <= b.activity_time AND a.event_end >= b.activity_time WHERE b.user_id = 1001;
UPDATE event_schedule SET event_start = '2023-10-31 08:00:00' WHERE event_id = 1;
DELETE FROM event_schedule WHERE event_id = 2 AND event_end < NOW();