CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table (id, value) VALUES (1, 10);
INSERT INTO test_table (id, value) VALUES (2, 20);
SELECT composite_ref(composite(10, 20), 1);
SELECT composite_ref(composite(0, 0), 1);
SELECT composite_ref(composite(255, 0), 1);
SELECT composite_ref(composite(100, 155), 1);
SELECT composite_ref(composite(128, 127), 1);
SELECT composite_ref(composite(255, 255), 1);
SELECT composite_ref(composite(10, 20), composite(5, 15));
SELECT composite_ref(composite((SELECT MAX(value) FROM test_table), 30), 1);
SELECT composite_ref(composite((SELECT MIN(value) FROM test_table), (SELECT SUM(value) FROM test_table)), 1);
SELECT composite_ref(composite((SELECT COUNT(*) FROM test_table), 50), 1);
SELECT composite_ref(composite((SELECT AVG(value) FROM test_table), 100), (SELECT COUNT(*) FROM test_table));
SELECT composite_ref(composite((SELECT value FROM test_table WHERE id = 1), 40), 1);
SELECT composite_ref(composite((SELECT value FROM test_table LIMIT 1), (SELECT value FROM test_table LIMIT 1 OFFSET 1)), 1);