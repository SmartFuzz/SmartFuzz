CREATE PROCEDURE XMLAddAttribute_test_1 () { DECLARE XMLENTITY, ent ANY;
ent := xpath_eval('//b', xtree_doc('<a><b attrX="x" attrY="y"/></a>'));
XMLAddAttribute(ent, 0, 'attrZ', 'z');
result('Modified Document', xpath_eval('/', ent));
};
