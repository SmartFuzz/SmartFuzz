CREATE TABLE test_xml (id INTEGER, xml_data VARCHAR);
INSERT INTO test_xml (id, xml_data) VALUES (1, '<a><b attrX="x" attrY="y"/></a>');
CREATE PROCEDURE XMLAddAttribute_test_4 () { DECLARE XMLENTITY, ent ANY;
SELECT xml_data INTO ent FROM test_xml WHERE id = 1;
ent := xpath_eval('//b', xtree_doc(ent));
XMLAddAttribute(ent, 2, 'attrZ', 'z');
result('Modified Document', xpath_eval('/', ent));
};
