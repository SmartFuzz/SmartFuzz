CREATE TABLE test_locale (id INT, lang_code VARCHAR(10), handler_info VARCHAR(255));
INSERT INTO test_locale (id, lang_code, handler_info) VALUES (1, 'en', 'English Handler');
INSERT INTO test_locale (id, lang_code, handler_info) VALUES (2, 'fr', 'French Handler');
INSERT INTO test_locale (id, lang_code, handler_info) VALUES (3, 'es', 'Spanish Handler');
INSERT INTO test_locale (id, lang_code, handler_info) VALUES (4, 'de', 'German Handler');
INSERT INTO test_locale (id, lang_code, handler_info) VALUES (5, 'zh', 'Chinese Handler');
SELECT lh_get_handler(lang_code) FROM test_locale WHERE id = 1;
SELECT lh_get_handler(lang_code) FROM test_locale WHERE lang_code IN (SELECT lang_code FROM test_locale WHERE id > 2);
SELECT t1.lang_code, lh_get_handler(t1.lang_code), t2.handler_info FROM test_locale t1 JOIN test_locale t2 ON t1.lang_code = t2.lang_code WHERE t1.id < 3;
SELECT lh_get_handler((SELECT lang_code FROM test_locale WHERE id = 3)) AS handler FROM dual;
SELECT lh_get_handler(lang_code) FROM (SELECT lang_code FROM test_locale WHERE id < 4) AS subquery;
SELECT COUNT(*), lh_get_handler(lang_code) FROM test_locale GROUP BY lang_code HAVING COUNT(*) > 1;
SELECT lh_get_handler(t.lang_code) FROM (SELECT DISTINCT lang_code FROM test_locale) AS t WHERE t.lang_code LIKE 'e%';
SELECT lh_get_handler(NULLIF(lang_code, '') ) FROM test_locale WHERE lang_code IS NOT NULL;
WITH lang_info AS (SELECT lang_code, handler_info FROM test_locale) SELECT lh_get_handler(lang_code) FROM lang_info WHERE handler_info IS NOT NULL;
SELECT lh_get_handler(lang_code) FROM test_locale WHERE lang_code NOT IN (SELECT lang_code FROM test_locale WHERE id = 1);