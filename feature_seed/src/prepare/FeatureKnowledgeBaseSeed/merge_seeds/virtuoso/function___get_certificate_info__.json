CREATE TABLE certificates (id int PRIMARY KEY, cert_data any, cert_type int);
INSERT INTO certificates (id, cert_data, cert_type) VALUES (1, '-----BEGIN CERTIFICATE-----...', 0);
INSERT INTO certificates (id, cert_data, cert_type) VALUES (2, '-----BEGIN CERTIFICATE-----...', 1);
INSERT INTO certificates (id, cert_data, cert_type) VALUES (3, '-----BEGIN CERTIFICATE-----...', 3);
SELECT get_certificate_info(1, cert_data, cert_type, '', 'emailAddress') FROM certificates WHERE id = 1;
SELECT get_certificate_info(2, cert_data, cert_type, '', '1.10.16.25') FROM certificates WHERE id = 2;
SELECT get_certificate_info(3, cert_data, cert_type, '', 'nonexistentKey') FROM certificates WHERE id = 3;
CREATE PROCEDURE test_certificate (in cert_id int) BEGIN DECLARE cert_info any;
SET cert_info = get_certificate_info(cert_id, cert_data, cert_type, '', 'emailAddress');
IF cert_info IS NULL THEN SET cert_info = get_certificate_info(cert_id, cert_data, cert_type, '', '1.10.16.25');
END IF;
SELECT cert_info;
END;
CALL test_certificate(1);
CALL test_certificate(2);
CALL test_certificate(3);
SELECT get_certificate_info(NULL, NULL, NULL, '', 'emailAddress');
SELECT get_certificate_info(0, NULL, 0, '', '');
SELECT get_certificate_info(1, '-----BEGIN CERTIFICATE-----...', 2, '', NULL) FROM certificates;
