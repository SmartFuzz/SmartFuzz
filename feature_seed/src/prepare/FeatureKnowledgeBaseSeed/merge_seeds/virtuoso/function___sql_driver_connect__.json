CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
INSERT INTO test_table (id, name) VALUES (2, 'Bob');
SELECT * FROM test_table WHERE id = 1;
CREATE TABLE related_table (id INT PRIMARY KEY, test_id INT, FOREIGN KEY (test_id) REFERENCES test_table(id));
INSERT INTO related_table (id, test_id) VALUES (1, 1);
INSERT INTO related_table (id, test_id) VALUES (2, 2);
SELECT r.id, t.name FROM related_table r JOIN test_table t ON r.test_id = t.id WHERE t.name LIKE 'A%';
SELECT t.* FROM test_table t WHERE t.id IN (SELECT rt.test_id FROM related_table rt WHERE rt.id = 1);
CREATE TABLE complex_table (id INT PRIMARY KEY, value INT);
INSERT INTO complex_table (id, value) VALUES (1, 100), (2, 200);
SELECT c.id, c.value FROM complex_table c WHERE c.value > (SELECT AVG(value) FROM complex_table);
CREATE TABLE join_test (id INT PRIMARY KEY, table_id INT, description VARCHAR(255), FOREIGN KEY (table_id) REFERENCES test_table(id));
INSERT INTO join_test (id, table_id, description) VALUES (1, 1, 'Test Entry 1');
INSERT INTO join_test (id, table_id, description) VALUES (2, 2, 'Test Entry 2');
SELECT jt.description FROM join_test jt INNER JOIN test_table t ON jt.table_id = t.id WHERE t.name = 'Bob';
SELECT jt.* FROM join_test jt WHERE EXISTS (SELECT 1 FROM test_table t WHERE t.id = jt.table_id AND t.name = 'Alice');
SELECT COUNT(*) FROM (SELECT DISTINCT name FROM test_table) AS unique_names;
SELECT t.id, (SELECT COUNT(*) FROM related_table r WHERE r.test_id = t.id) AS related_count FROM test_table t;