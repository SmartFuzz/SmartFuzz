CREATE TABLE employees (EMPLOYEE_ID integer PRIMARY KEY, NAME varchar, START_DATE date);
INSERT INTO employees (EMPLOYEE_ID, NAME, START_DATE) VALUES (1, 'Alice', '2023-01-01');
INSERT INTO employees (EMPLOYEE_ID, NAME, START_DATE) VALUES (2, 'Bob', '2023-01-02');
INSERT INTO employees (EMPLOYEE_ID, NAME, START_DATE) VALUES (3, 'Charlie', NULL);
SELECT sprintf_iri_or_null('http://demo.openlinksw.com:8890/hr/job_history#%d_%s', EMPLOYEE_ID, NAME) FROM employees WHERE EMPLOYEE_ID = 1;
SELECT sprintf_iri_or_null('http://demo.openlinksw.com:8890/hr/job_history#%d_%s', EMPLOYEE_ID, NULL) FROM employees WHERE EMPLOYEE_ID = 3;
SELECT sprintf_iri_or_null('http://demo.openlinksw.com:8890/hr/job_history#%d_%s', EMPLOYEE_ID, NAME) FROM (SELECT EMPLOYEE_ID, NAME FROM employees WHERE START_DATE IS NOT NULL) AS valid_employees;
SELECT sprintf_iri_or_null('http://demo.openlinksw.com:8890/hr/job_history#%d_%s', emp.EMPLOYEE_ID, proj.PROJECT_NAME) FROM employees emp JOIN projects proj ON emp.EMPLOYEE_ID = proj.EMPLOYEE_ID WHERE proj.START_DATE IS NOT NULL;
SELECT sprintf_iri_or_null('http://demo.openlinksw.com:8890/hr/job_history#%d_%s', EMPLOYEE_ID, substr(NAME, 1, 1)) FROM employees;
SELECT sprintf_iri_or_null('http://demo.openlinksw.com:8890/hr/job_history#%d_%s', EMPLOYEE_ID, cast(NULL as varchar)) FROM employees WHERE EMPLOYEE_ID = 2;