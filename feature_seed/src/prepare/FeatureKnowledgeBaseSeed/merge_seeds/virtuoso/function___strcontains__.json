SELECT strcontains(str_value, substring) FROM test_strings;
SELECT id, str_value, substring, strcontains(str_value, substring) AS match FROM test_strings WHERE strcontains(str_value, substring) = 1;
SELECT a.id, a.str_value, b.substring, strcontains(a.str_value, b.substring) as match FROM test_strings a JOIN test_strings b ON a.id != b.id;
SELECT strcontains((SELECT str_value FROM test_strings WHERE id = 1), (SELECT substring FROM test_strings WHERE id = 2));
SELECT strcontains('CaseSensitive', 'casesensitive') AS case_sensitivity;
SELECT strcontains('', '') AS empty_string;
SELECT strcontains('Test', NULL) AS test_null;
SELECT strcontains(NULL, 'test') AS null_test;
SELECT strcontains(NULL, NULL) AS both_null;