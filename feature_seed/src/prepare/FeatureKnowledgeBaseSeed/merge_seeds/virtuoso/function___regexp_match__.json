CREATE TABLE test_strings (id INT, content VARCHAR);
INSERT INTO test_strings (id, content) VALUES (1, 'abcdefg'), (2, 'hijklmnop'), (3, 'qrstuvwxyz');
CREATE TABLE regex_patterns (id INT, pattern VARCHAR);
INSERT INTO regex_patterns (id, pattern) VALUES (1, 'cd'), (2, 'pq'), (3, 'xyz');
CREATE TABLE matched_results (id INT, match_result VARCHAR);
INSERT INTO matched_results (id, match_result) VALUES (1, NULL), (2, NULL), (3, NULL);
CREATE PROCEDURE test_regexp_match() BEGIN DECLARE wrd VARCHAR;
DECLARE ans VARCHAR DEFAULT '';
DECLARE string_content VARCHAR;
DECLARE pattern VARCHAR;
DECLARE i INT DEFAULT 1;
DECLARE last_id INT DEFAULT (SELECT MAX(id) FROM test_strings);
WHILE i <= last_id DO SET string_content = (SELECT content FROM test_strings WHERE id = i);
SET pattern = (SELECT pattern FROM regex_patterns WHERE id = 1);
SET wrd = regexp_match(pattern, string_content);
WHILE wrd IS NOT NULL DO SET ans = CONCAT(ans, ',', wrd);
SET wrd = regexp_match(pattern, string_content, 1);
END WHILE;
INSERT INTO matched_results (match_result) VALUES (ans);
SET ans = '';
SET i = i + 1;
END WHILE;
END;
CALL test_regexp_match();
SELECT * FROM matched_results;
SELECT id, regexp_match('a.*d', content) AS match_result FROM test_strings WHERE regexp_match('a.*d', content) IS NOT NULL;
SELECT id, regexp_match('nope', content) AS match_result FROM test_strings WHERE id IN (SELECT id FROM matched_results WHERE match_result IS NOT NULL);
SELECT id, regexp_match('xyz', content) AS match_result FROM test_strings WHERE content LIKE '%xyz%';
CREATE PROCEDURE fetch_all_matches(IN pattern VARCHAR) BEGIN DECLARE wrd VARCHAR;
DECLARE ans VARCHAR DEFAULT '';
DECLARE str_i VARCHAR;
DECLARE i INT DEFAULT 1;
DECLARE max_id INT DEFAULT (SELECT MAX(id) FROM test_strings);
WHILE i <= max_id DO SET str_i = (SELECT content FROM test_strings WHERE id = i);
SET wrd = regexp_match(pattern, str_i);
WHILE wrd IS NOT NULL DO SET ans = CONCAT(ans, ',', wrd);
SET wrd = regexp_match(pattern, str_i, 1);
END WHILE;
SET i = i + 1;
END WHILE;
SELECT ans AS all_matches;
END;
CALL fetch_all_matches('h.*o');