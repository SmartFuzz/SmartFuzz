CREATE TABLE tModel (id INT PRIMARY KEY, name VARCHAR(255), description VARCHAR(500), category VARCHAR(100));
INSERT INTO tModel (id, name, description, category) VALUES (1, 'TestModel1', 'Description for TestModel1', 'CategoryA');
INSERT INTO tModel (id, name, description, category) VALUES (2, 'TestModel2', 'Description for TestModel2', 'CategoryB');
UPDATE tModel SET description = 'Updated Description for TestModel1' WHERE id = 1;
SELECT * FROM tModel WHERE category = 'CategoryA' AND id IN (SELECT id FROM tModel WHERE name LIKE 'TestModel%');
DELETE FROM tModel WHERE id = (SELECT id FROM tModel WHERE name = 'TestModel2');
SELECT COUNT(*) FROM tModel WHERE LENGTH(description) > 50 AND category != 'CategoryC';
INSERT INTO tModel (id, name, description, category) SELECT MAX(id) + 1, 'TestModel3', 'Description for TestModel3', 'CategoryC' FROM tModel;
SELECT t1.name, t2.name FROM tModel AS t1 JOIN tModel AS t2 ON t1.category = t2.category WHERE t1.id <> t2.id;
WITH CategoryCounts AS (SELECT category, COUNT(*) as count FROM tModel GROUP BY category) SELECT * FROM CategoryCounts WHERE count > 1;