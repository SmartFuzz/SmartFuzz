CREATE TABLE test_table1 (X INT);
INSERT INTO test_table1 (X) VALUES (1), (2), (3), (NULL);
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.X) FROM (SELECT X FROM test_table1 ORDER BY X) as subquery;
CREATE TABLE test_table2 (Y INT);
INSERT INTO test_table2 (Y) VALUES (4), (5), (6), (NULL);
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.Y) FROM (SELECT Y FROM test_table2 ORDER BY Y) as subquery;
CREATE TABLE test_table3 (A INT, B INT);
INSERT INTO test_table3 (A, B) VALUES (1, 10), (2, 20), (3, 30), (NULL, 40);
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.B) FROM (SELECT B FROM test_table3 WHERE A IS NOT NULL ORDER BY A) as subquery;
CREATE TABLE test_table4 (C INT, D INT);
INSERT INTO test_table4 (C, D) VALUES (NULL, 50), (5, NULL), (6, 60);
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.D) FROM (SELECT D FROM test_table4 ORDER BY C) as subquery;
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.X) FROM (SELECT X FROM test_table1 UNION SELECT Y FROM test_table2) as subquery;
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.Z) FROM (SELECT Z FROM (SELECT X AS Z FROM test_table1 UNION SELECT Y AS Z FROM test_table2) AS subquery1 ORDER BY Z) as subquery;
CREATE TABLE test_table5 (E INT, F INT);
INSERT INTO test_table5 (E, F) SELECT X, Y FROM test_table1 CROSS JOIN test_table2;
SELECT DB.DBA.VECTOR_OR_NULL_AGG(subquery.F) FROM (SELECT F FROM test_table5 WHERE F IS NOT NULL ORDER BY E) as subquery;