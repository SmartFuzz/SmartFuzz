CREATE TABLE Geometries (id INT, geom BLOB, name VARCHAR(100));
INSERT INTO Geometries (id, geom, name) VALUES (1, bif:st_geomfromtext('POINT(1 1)', 4326), 'Point A');
INSERT INTO Geometries (id, geom, name) VALUES (2, bif:st_geomfromtext('POINT(4 5)', 4326), 'Point B');
INSERT INTO Geometries (id, geom, name) VALUES (3, bif:st_geomfromtext('LINESTRING(0 0, 5 5)', 4326), 'Line C');
INSERT INTO Geometries (id, geom, name) VALUES (4, bif:st_geomfromtext('POLYGON((0 0, 0 3, 3 3, 3 0, 0 0))', 4326), 'Polygon D');
SELECT a.name AS geometry_a, b.name AS geometry_b, bif:st_distance(a.geom, b.geom) AS distance FROM Geometries a, Geometries b WHERE a.id <> b.id;
SELECT a.geom AS geom_a, b.geom AS geom_b, bif:st_distance(a.geom, b.geom) AS distance FROM Geometries a JOIN Geometries b ON a.id <> b.id WHERE distance < 5;
SELECT (SELECT bif:st_distance(a.geom, b.geom) FROM Geometries a, Geometries b WHERE a.id = 1 AND b.id = 2) AS distance_between_a_b;
SELECT (SELECT MIN(bif:st_distance(a.geom, b.geom)) FROM Geometries a JOIN Geometries b ON a.id <> b.id) AS min_distance;
SELECT MAX(bif:st_distance(a.geom, b.geom)) AS max_distance FROM Geometries a, Geometries b WHERE a.name = 'Point A' AND b.name = 'Line C';
SELECT geom, bif:st_distance(geom, bif:st_geomfromtext('POINT(2 2)', 4326)) AS distance FROM Geometries WHERE distance < 3;