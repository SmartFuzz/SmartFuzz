CREATE TABLE registry_variables (variable_name VARCHAR(255) PRIMARY KEY, variable_value VARCHAR(255));
INSERT INTO registry_variables (variable_name, variable_value) VALUES ('my_variable', 'my_value');
SELECT registry_get('my_variable');
SELECT registry_set('my_variable', 'my_value1');
SELECT registry_get('my_variable');
SELECT registry_set('my_variable', 'my_value2');
SELECT registry_remove('my_variable');
SELECT registry_get('my_variable');
SELECT registry_remove('protected_variable');
CREATE TABLE protected_registry (protected_variable VARCHAR(255) PRIMARY KEY);
INSERT INTO protected_registry (protected_variable) VALUES ('protected_variable');
SELECT registry_remove((SELECT protected_variable FROM protected_registry WHERE protected_variable = 'protected_variable'));
SELECT registry_set('tmp_variable', 'tmp_value');
SELECT registry_remove('tmp_variable');
SELECT registry_get('tmp_variable');
SELECT COUNT(*) FROM (SELECT registry_get('my_variable') AS value) AS subquery WHERE value IS NOT NULL;
SELECT (SELECT registry_get('my_variable') FROM registry_variables) AS current_value, registry_remove('my_variable') AS remove_result;
SELECT registry_set('my_variable', (SELECT MAX(variable_value) FROM registry_variables));
SELECT registry_remove('my_variable');
SELECT registry_get('non_existent_variable');
SELECT registry_remove('non_existent_variable');
SELECT registry_set('my_variable', NULL);
SELECT registry_get('my_variable');
SELECT registry_remove(NULL);