CREATE TABLE Users (id INT PRIMARY KEY, password VARCHAR(255));
INSERT INTO Users (id, password) VALUES (1, 'password');
INSERT INTO Users (id, password) VALUES (2, 'weakpassword');
INSERT INTO Users (id, password) VALUES (3, 'admin1234');
INSERT INTO Users (id, password) VALUES (4, 'P@ssw0rd');
INSERT INTO Users (id, password) VALUES (5, '');
INSERT INTO Users (id, password) VALUES (6, NULL);
SELECT * FROM Users WHERE password IS NOT NULL;
SELECT COUNT(*) FROM Users WHERE password = '';
SELECT COUNT(*) FROM Users WHERE password = 'wrongpassword';
SELECT COUNT(*) FROM Users WHERE password IN ('password', 'wrongpassword');
CREATE TABLE MaintenancePages (id INT PRIMARY KEY, html_content TEXT);
INSERT INTO MaintenancePages (id, html_content) VALUES (1, '<h1>Site is down for maintenance</h1>');
INSERT INTO MaintenancePages (id, html_content) VALUES (2, '<h1>Under Maintenance</h1>');
INSERT INTO MaintenancePages (id, html_content) VALUES (3, '<h1>503 Service Unavailable</h1>');
SELECT * FROM MaintenancePages;
SELECT html_content FROM MaintenancePages WHERE id = (SELECT MAX(id) FROM MaintenancePages);
