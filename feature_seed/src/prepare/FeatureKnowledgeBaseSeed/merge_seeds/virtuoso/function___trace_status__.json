CREATE PROCEDURE trace_status_show () { declare i, l integer;
declare opt, status varchar;
declare arr any;
arr := trace_status();
i := 0;
l := length(arr);
result_names(opt, status);
while (i < l) { result(arr[i], arr[i+1]);
i := i + 2;
};
};
CREATE TABLE test_table (id integer, name varchar);
INSERT INTO test_table VALUES (1, 'test1');
INSERT INTO test_table VALUES (2, 'test2');
SELECT * FROM test_table;
CREATE VIEW test_view AS SELECT id, name FROM test_table WHERE id > 1;
SELECT * FROM test_view;
SELECT id, name FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name LIKE 'test%');
CREATE TABLE another_table (id integer PRIMARY KEY, test_id integer, FOREIGN KEY (test_id) REFERENCES test_table(id));
INSERT INTO another_table VALUES (1, 1);
INSERT INTO another_table VALUES (2, 2);
SELECT a.id, b.name FROM another_table a JOIN test_table b ON a.test_id = b.id WHERE b.name LIKE 'test%';
CREATE OR REPLACE VIEW complex_view AS SELECT t.id, t.name, a.test_id FROM test_table t LEFT JOIN another_table a ON t.id = a.test_id WHERE t.id < 3;
SELECT * FROM complex_view;
CALL trace_status_show();