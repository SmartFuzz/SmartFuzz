CREATE TABLE test_xml_data (id INTEGER, xml_column XML);
INSERT INTO test_xml_data (id, xml_column) VALUES (1, '<root><value>123</value></root>');
INSERT INTO test_xml_data (id, xml_column) VALUES (2, '<root><value>456</value></root>');
INSERT INTO test_xml_data (id, xml_column) VALUES (3, '<root><value>0</value></root>');
INSERT INTO test_xml_data (id, xml_column) VALUES (4, '<root><value>-789</value></root>');
INSERT INTO test_xml_data (id, xml_column) VALUES (5, '<root><value>9999999999</value></root>');
SELECT xpath_integer('/root/value', xml_column) AS extracted_value FROM test_xml_data WHERE id = 1;
SELECT xpath_integer('/root/value', xml_column) AS extracted_value FROM test_xml_data WHERE id = 2;
SELECT xpath_integer('/root/value', xml_column) AS extracted_value FROM test_xml_data WHERE id = 3;
SELECT xpath_integer('/root/value', xml_column) AS extracted_value FROM test_xml_data WHERE id = 4;
SELECT xpath_integer('/root/value', xml_column) AS extracted_value FROM test_xml_data WHERE id = 5;
SELECT a.id, xpath_integer('/root/value', a.xml_column) AS extracted_value FROM test_xml_data a JOIN test_xml_data b ON a.id <> b.id WHERE a.id = 2;
SELECT a.xml_column, xpath_integer('/root/value', a.xml_column) AS extracted_value, (SELECT COUNT(*) FROM test_xml_data) AS total_rows FROM test_xml_data a;
SELECT a.id, xpath_integer('/root/value', a.xml_column) FROM test_xml_data a WHERE EXISTS (SELECT 1 FROM test_xml_data b WHERE b.id = a.id);
SELECT a.id, xpath_integer('/root/value', a.xml_column) FROM test_xml_data a WHERE NOT EXISTS (SELECT 1 FROM test_xml_data b WHERE b.id > a.id);