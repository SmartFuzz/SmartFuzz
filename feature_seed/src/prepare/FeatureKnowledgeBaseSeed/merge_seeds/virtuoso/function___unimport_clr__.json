CREATE CLASS dbo.sanity AS SELECT 1 AS id, 'test' AS name;
CREATE TYPE dbo.sanity AS TABLE (id INT, name VARCHAR(50));
INSERT INTO dbo.sanity VALUES (1, 'test');
SELECT * FROM dbo.sanity;
 DB..unimport_clr(vector('sanity'), vector('sanity'));
SELECT sanity::test('Rob');
SELECT * FROM dbo.sanity WHERE id IN (SELECT id FROM dbo.sanity WHERE name LIKE 'te%');
WITH CTE AS (SELECT id, name FROM dbo.sanity WHERE id > 0) SELECT * FROM CTE;
SELECT san.name FROM dbo.sanity san JOIN (SELECT id FROM dbo.sanity WHERE id < 2) AS sub ON san.id = sub.id;
DROP TYPE dbo.sanity;
