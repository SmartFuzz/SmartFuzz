CREATE GRAPH <http://example.org/graph1>;
CREATE GRAPH <http://example.org/graph2>;
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/node1> <http://example.org/property> <http://example.org/value1> . } };
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/node2> <http://example.org/property> <http://example.org/value2> . } };
SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o } };
SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/graph2> { ?s ?p ?o } };
SELECT ?diff WHERE { BIND(DB.DBA.RDF_GRAPH_DIFF(<http://example.org/graph1>, <http://example.org/graph2>) AS ?diff) };
WITH { SELECT ?g WHERE { GRAPH ?g { ?s ?p ?o } } } AS ?graphList INSERT { GRAPH <http://example.org/diff> { ?s ?p ?o } } WHERE { ?graphList ?s ?p ?o };
SELECT distinct ?subject ?predicate ?object WHERE { GRAPH <http://example.org/graph1> { ?subject ?predicate ?object } UNION GRAPH <http://example.org/graph2> { ?subject ?predicate ?object } };
INSERT { GRAPH <http://example.org/graph3> { ?s ?p ?o } } WHERE { SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o } FILTER (?p = <http://example.org/property>) } };
DELETE WHERE { GRAPH <http://example.org/graph2> { ?s ?p ?o } };
DESCRIBE <http://example.org/node1>;
SELECT ?s ?o WHERE { GRAPH <http://example.org/graph1> { ?s <http://example.org/property> ?o } UNION GRAPH <http://example.org/graph2> { ?s <http://example.org/property> ?o } };