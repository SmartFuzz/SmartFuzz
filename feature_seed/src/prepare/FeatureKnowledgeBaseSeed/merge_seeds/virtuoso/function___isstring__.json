CREATE TABLE test_strings (id INT, value VARCHAR(255));
INSERT INTO test_strings (id, value) VALUES (1, 'Simple string');
INSERT INTO test_strings (id, value) VALUES (2, CAST(123 AS VARCHAR));
INSERT INTO test_strings (id, value) VALUES (3, NULL);
INSERT INTO test_strings (id, value) VALUES (4, '');
INSERT INTO test_strings (id, value) VALUES (5, ' ');
SELECT isstring(value) FROM test_strings WHERE id = 1;
SELECT isstring(value) FROM test_strings WHERE id = 2;
SELECT isstring(value) FROM test_strings WHERE id = 3;
SELECT isstring(value) FROM test_strings WHERE id = 4;
SELECT isstring(value) FROM test_strings WHERE id = 5;
SELECT id, value, isstring(value) AS is_string FROM test_strings WHERE value IS NOT NULL;
CREATE TABLE test_numbers (id INT, value INT);
INSERT INTO test_numbers (id, value) VALUES (1, 100);
INSERT INTO test_numbers (id, value) VALUES (2, 200);
SELECT t.id, t.value, isstring(t.value) FROM test_strings t JOIN test_numbers n ON t.id = n.id;
SELECT t1.value, (SELECT isstring(t2.value) FROM test_strings t2 WHERE t2.id = t1.id) AS is_string FROM test_strings t1;
SELECT isstring(CAST('Another string' AS VARCHAR));
SELECT isstring(CAST(3.14 AS VARCHAR));
SELECT CASE WHEN isstring('Hello') = 1 THEN 'This is a string' ELSE 'Not a string' END AS string_check;
SELECT isstring(CONCAT('Join ', 'these ', 'words'));
SELECT isstring(UPPER('Upper Case Test'));
CREATE TABLE empty_test (id INT);
SELECT isstring(NULLIF((SELECT value FROM empty_test LIMIT 1), NULL));