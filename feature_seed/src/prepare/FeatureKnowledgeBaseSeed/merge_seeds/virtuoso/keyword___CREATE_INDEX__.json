CREATE INDEX idx_article_pubdate ON article (pub_date);
CREATE UNIQUE CLUSTERED INDEX idx_user_name ON db.dba.user (u_name);
CREATE BITMAP INDEX idx_article_flags ON article (flags);
CREATE INDEX idx_order_date ON orders (order_date) WHERE status = 'completed';
CREATE INDEX idx_article_author_pubdate ON article (author_id, pub_date);
CREATE INDEX idx_user_email ON db.dba.user (email);
CREATE UNIQUE INDEX idx_product_code ON products (product_code);
CREATE INDEX idx_combined ON sales (customer_id, sale_date) INCLUDE (total_amount);
CREATE BITMAP INDEX idx_employee_status ON employee (status) WHERE department_id IN (SELECT id FROM department WHERE name = 'Sales');
CREATE INDEX idx_article_flags ON (SELECT flags FROM article WHERE pub_date > '2023-01-01');