CREATE TABLE DB.DBA.SYS_USERS (U_ID INT, U_NAME VARCHAR(255));
INSERT INTO DB.DBA.SYS_USERS (U_ID, U_NAME) VALUES (1, 'admin'), (2, 'user1'), (3, 'user2');
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM DB.DBA.SYS_USERS;
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM DB.DBA.SYS_USERS WHERE U_ID < 3;
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME, U_ID)) FROM DB.DBA.SYS_USERS GROUP BY U_ID;
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM (SELECT U_NAME FROM DB.DBA.SYS_USERS WHERE U_ID > 1) AS filtered_users;
CREATE TABLE DB.DBA.ROLES (R_ID INT, R_NAME VARCHAR(255));
INSERT INTO DB.DBA.ROLES (R_ID, R_NAME) VALUES (1, 'admin_role'), (2, 'user_role');
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U.U_NAME, R.R_NAME)) FROM DB.DBA.SYS_USERS U JOIN DB.DBA.ROLES R ON U.U_ID = R.R_ID;
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM DB.DBA.SYS_USERS WHERE U_ID IN (SELECT R_ID FROM DB.DBA.ROLES);
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM DB.DBA.SYS_USERS ORDER BY U_NAME DESC;
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM (SELECT U_NAME FROM DB.DBA.SYS_USERS ORDER BY U_NAME ASC LIMIT 2) AS top_users;
SELECT DB.DBA.BAG_CONCAT_AGG (vector (U_NAME)) FROM (SELECT DISTINCT U_NAME FROM DB.DBA.SYS_USERS) AS unique_names;