CREATE TABLE test_data (id INT PRIMARY KEY, content VARCHAR(255));
INSERT INTO test_data (id, content) VALUES (1, 'data to encrypt');
INSERT INTO test_data (id, content) VALUES (2, 'more sensitive data');
INSERT INTO test_data (id, content) VALUES (3, 'another piece of data');
SELECT encrypt(content, 'kaes') AS encrypted_content FROM test_data WHERE id = 1;
SELECT encrypt((SELECT content FROM test_data WHERE id = 2), 'kaes') AS encrypted_content;
SELECT t.id, encrypt(t.content, 'kaes') AS encrypted_content FROM test_data t WHERE t.content LIKE '%data%';
SELECT encrypt(s.content, 'kaes') AS encrypted_content FROM (SELECT content FROM test_data WHERE id IN (1, 3)) s;
SELECT encrypt(content, (SELECT 'kaes' FROM dual)) AS encrypted_content FROM test_data;
SELECT encrypt(content, '3DES') AS encrypted_content FROM test_data WHERE id = (SELECT MAX(id) FROM test_data);
DELETE FROM test_data WHERE id = 2;
SELECT encrypt(content, 'kaes') AS encrypted_content FROM (SELECT content FROM test_data WHERE id >= 1) as sub;
SELECT t1.id, encrypt(t1.content, 'kaes') AS encrypted_content FROM test_data t1 JOIN (SELECT id FROM test_data WHERE id > 1) t2 ON t1.id = t2.id;
CREATE TABLE encryption_keys (key_name VARCHAR(50), key_type VARCHAR(10));
INSERT INTO encryption_keys (key_name, key_type) VALUES ('kaes', 'AES');
INSERT INTO encryption_keys (key_name, key_type) VALUES ('k3des', '3DES');
SELECT encrypt(d.content, e.key_name) AS encrypted_content FROM test_data d JOIN encryption_keys e ON e.key_name = 'kaes' WHERE d.id = 1;
SELECT d.id, encrypt(d.content, e.key_name) AS encrypted_content FROM test_data d JOIN encryption_keys e ON e.key_type = 'AES' WHERE d.id IN (SELECT id FROM test_data WHERE id < 4);