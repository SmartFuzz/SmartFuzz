CREATE TABLE test_array (id INT, value ARRAY);
INSERT INTO test_array (id, value) VALUES (1, ARRAY[1, 2, 3]);
INSERT INTO test_array (id, value) VALUES (2, ARRAY['a', 'b', 'c']);
INSERT INTO test_array (id, value) VALUES (3, ARRAY[NULL]);
INSERT INTO test_array (id, value) VALUES (4, ARRAY[1, 2, NULL]);
SELECT id FROM test_array WHERE isarray(value);
SELECT id FROM test_array WHERE isarray(value) AND id IN (SELECT id FROM test_array WHERE value[1] IS NOT NULL);
SELECT t1.id FROM test_array t1 JOIN test_array t2 ON t1.id = t2.id WHERE isarray(t1.value) AND isarray(t2.value);
SELECT id, value FROM test_array WHERE isarray(value) AND id = (SELECT MAX(id) FROM test_array);
CREATE TABLE test_array2 (id INT, value STRING);
INSERT INTO test_array2 (id, value) VALUES (1, 'not_an_array');
SELECT id FROM test_array2 WHERE NOT isarray(value);
WITH valid_arrays AS (SELECT id FROM test_array WHERE isarray(value)) SELECT count(*) FROM valid_arrays;
SELECT id, value FROM test_array WHERE isarray(value) OR id IN (SELECT id FROM test_array2 WHERE NOT isarray(value));
SELECT DISTINCT id FROM test_array WHERE ARRAY_LENGTH(value) > 2 AND isarray(value);