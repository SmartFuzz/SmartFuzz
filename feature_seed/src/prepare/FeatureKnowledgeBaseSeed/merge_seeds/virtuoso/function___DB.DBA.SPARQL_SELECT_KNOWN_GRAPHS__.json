DB.DBA.SPARQL_SELECT_KNOWN_GRAPHS();
DB.DBA.SPARQL_SELECT_KNOWN_GRAPHS();
SELECT * WHERE { GRAPH ?g { ?s ?p ?o } } LIMIT 10;
SELECT DISTINCT ?g WHERE { GRAPH ?g { ?s ?p ?o } } ORDER BY ?g;
SELECT ?g (COUNT(?s) AS ?count) WHERE { GRAPH ?g { ?s ?p ?o } } GROUP BY ?g HAVING (?count > 1);
SELECT ?g WHERE { GRAPH ?g { ?s ?p ?o } UNION { GRAPH <http://example.com/mygraph2> { ?s ?p ?o } } };
SELECT ?g WHERE { GRAPH ?g { ?s ?p ?o FILTER(?s = <http://example.com/mygraph>) } } ORDER BY ?g;
SELECT ?g WHERE { GRAPH ?g { ?s ?p ?o } FILTER regex(str(?g), 'example.com') } ORDER BY ?g;
SELECT ?g WHERE { GRAPH ?g { ?s ?p ?o } FILTER (str(?g) != 'http://example.com/mygraph') } ORDER BY ?g;
SELECT ?g WHERE { GRAPH ?g { ?s ?p ?o } FILTER (isURI(?g)) } LIMIT 5;