EXECUTE SYSTEM SYS_SCHEDULED_EVENT('repl_purge', 'demoserver');
SELECT SUM(CASE WHEN log_level < (SELECT MAX(level) FROM replication_logs WHERE account_name='demoserver') THEN 1 ELSE 0 END) AS purged_count FROM replication_logs;
SELECT * FROM replication_logs WHERE log_level < (SELECT log_level FROM replication_logs WHERE account_name = 'demoserver' ORDER BY log_level DESC LIMIT 1 OFFSET 1);
CREATE INDEX idx_account_name ON replication_logs(account_name);
SELECT DISTINCT account_name FROM replication_logs WHERE log_level < (SELECT MIN(log_level) FROM replication_logs WHERE account_name = 'demoserver');
