CREATE TABLE test_numbers (id INT PRIMARY KEY, num INT);
INSERT INTO test_numbers (id, num) VALUES (1, 0);
INSERT INTO test_numbers (id, num) VALUES (2, 1);
INSERT INTO test_numbers (id, num) VALUES (3, 18);
INSERT INTO test_numbers (id, num) VALUES (4, -18);
INSERT INTO test_numbers (id, num) VALUES (5, 2147483647);
INSERT INTO test_numbers (id, num) VALUES (6, -2147483648);
SELECT bit_not(num) FROM test_numbers WHERE id = 1;
SELECT bit_not(num) FROM test_numbers WHERE id = 2;
SELECT bit_not(num) FROM test_numbers WHERE id = 3;
SELECT bit_not(num) FROM test_numbers WHERE id = 4;
SELECT bit_not(num) FROM test_numbers WHERE id = 5;
SELECT bit_not(num) FROM test_numbers WHERE id = 6;
SELECT id, bit_not(num) AS bit_not_num FROM test_numbers WHERE num BETWEEN -10 AND 10;
SELECT (SELECT bit_not(num) FROM test_numbers WHERE id = 3) AS not_18, (SELECT bit_not(num) FROM test_numbers WHERE id = 4) AS not_neg_18;
SELECT id, (bit_not(num) + 5) AS adjusted_bit_not FROM test_numbers;
SELECT n.id, bit_not(n.num) FROM test_numbers n JOIN (SELECT num FROM test_numbers WHERE id = 5) AS max_num ON n.num < max_num.num;
SELECT id, bit_not(num) FROM test_numbers WHERE id IN (SELECT id FROM (SELECT id FROM test_numbers WHERE num < 0) AS temp);