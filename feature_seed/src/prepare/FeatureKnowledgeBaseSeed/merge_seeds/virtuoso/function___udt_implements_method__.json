CREATE CLASS SER_UDT AS (NEGATE());
DECLARE mtd ANY;
DECLARE inst SER_UDT;
inst := NEW SER_UDT();
mtd := udt_implements_method(inst, 'NEGATE');
IF (mtd <> 0) RETURN CALL (mtd)(inst);
ELSE SIGNAL ('42000', 'No method NEGATE');
