CREATE TABLE xml_documents (id INTEGER PRIMARY KEY, content CLOB);
INSERT INTO xml_documents (id, content) VALUES (1, file_to_string('small_doc.xml'));
INSERT INTO xml_documents (id, content) VALUES (2, file_to_string('large_doc.xml'));
DECLARE TREE any;
tree := xtree_doc(file_to_string('small_doc.xml'), 1, 'http://localhost.localdomain/', 'UTF-8');
DECLARE TREE any;
tree := xtree_doc(file_to_string('mid_size_doc.xml'), 1, 'http://localhost.localdomain/', 'UTF-8');
DECLARE TREE any;
tree := xtree_doc(file_to_string('huge_doc.xml'));
SELECT id FROM xml_documents WHERE id IN (SELECT id FROM xml_documents WHERE LENGTH(content) < 5000000);
SELECT * FROM xml_documents WHERE content LIKE '%<tag>%';
WITH xml_data AS (SELECT content FROM xml_documents WHERE id = 1) SELECT xtree_doc(content) FROM xml_data;
SELECT id, xtree_doc(content) FROM xml_documents WHERE id = (SELECT MAX(id) FROM xml_documents);
INSERT INTO xml_documents (id, content) VALUES (3, '<root><child>Content</child></root>');
SELECT CAST(xtree_doc(content) AS TREE) FROM xml_documents WHERE id = 3;
DELETE FROM xml_documents WHERE id = (SELECT id FROM xml_documents ORDER BY id DESC LIMIT 1);
CREATE TABLE xml_parsed (id INTEGER PRIMARY KEY, parsed_tree ANY);
INSERT INTO xml_parsed (id, parsed_tree) SELECT id, xtree_doc(content) FROM xml_documents;
SELECT parsed_tree FROM xml_parsed WHERE id = 1;
UPDATE xml_documents SET content = file_to_string('updated_doc.xml') WHERE id = 1;
DECLARE TREE any;
tree := xtree_doc(file_to_string('invalid_doc.xml'));
SELECT id FROM xml_documents WHERE content IS NULL;
SELECT COUNT(*) FROM xml_documents WHERE LENGTH(content) > 5000000;
SELECT id, xtree_doc(content) FROM xml_documents WHERE LENGTH(content) <= 5000000 ORDER BY id;