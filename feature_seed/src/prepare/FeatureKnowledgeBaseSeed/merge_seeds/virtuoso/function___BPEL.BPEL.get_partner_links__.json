CREATE TABLE partner_links (id INT PRIMARY KEY, name VARCHAR(255), partnerLinkType VARCHAR(255), partnerRole VARCHAR(255), myRole VARCHAR(255));
INSERT INTO partner_links (id, name, partnerLinkType, partnerRole, myRole) VALUES (1, 'client', 'tns:LoanFlow', 'LoanFlowRequester', 'LoanFlowProvider');
INSERT INTO partner_links (id, name, partnerLinkType, partnerRole) VALUES (2, 'creditRatingService', 'services:CreditRatingService', 'CreditRatingServiceProvider');
INSERT INTO partner_links (id, name, partnerLinkType, myRole, partnerRole) VALUES (3, 'UnitedLoanService', 'services:LoanService', 'LoanServiceRequester', 'LoanServiceProvider');
INSERT INTO partner_links (id, name, partnerLinkType, myRole, partnerRole) VALUES (4, 'StarLoanService', 'services:LoanService', 'LoanServiceRequester', 'LoanServiceProvider');
SELECT BPEL.BPEL.get_partner_links(1);
SELECT BPEL.BPEL.get_partner_links((SELECT MAX(id) FROM partner_links));
SELECT BPEL.BPEL.get_partner_links((SELECT COUNT(*) FROM partner_links) + 1);
SELECT BPEL.BPEL.get_partner_links(2) UNION SELECT BPEL.BPEL.get_partner_links(3);
WITH temp AS (SELECT id FROM partner_links WHERE partnerRole LIKE '%Provider%') SELECT BPEL.BPEL.get_partner_links((SELECT MIN(id) FROM temp));
SELECT BPEL.BPEL.get_partner_links(1) AS partner_links, (SELECT COUNT(*) FROM partner_links) AS total_links;
SELECT BPEL.BPEL.get_partner_links(4) WHERE EXISTS (SELECT 1 FROM partner_links WHERE partnerRole = 'LoanServiceProvider');