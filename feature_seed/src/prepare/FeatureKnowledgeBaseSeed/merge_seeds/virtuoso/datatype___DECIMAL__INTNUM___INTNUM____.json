CREATE TABLE test_decimal (id INT PRIMARY KEY, amount DECIMAL(10, 2));
INSERT INTO test_decimal (id, amount) VALUES (1, DECIMAL(10, 2));
INSERT INTO test_decimal (id, amount) VALUES (2, DECIMAL(1234567890, 2));
INSERT INTO test_decimal (id, amount) VALUES (3, DECIMAL(0, 0));
INSERT INTO test_decimal (id, amount) VALUES (4, DECIMAL(-999999999, 2));
SELECT id, amount FROM test_decimal WHERE amount = DECIMAL(12345, 2);
SELECT id, amount FROM test_decimal WHERE amount > DECIMAL(0, 0) AND amount < DECIMAL(1000, 2);
SELECT id FROM test_decimal WHERE amount BETWEEN DECIMAL(-100, 0) AND DECIMAL(100, 0);
CREATE TABLE second_table (id INT PRIMARY KEY, foreign_id INT, FOREIGN KEY (foreign_id) REFERENCES test_decimal(id));
INSERT INTO second_table (id, foreign_id) VALUES (1, 1);
SELECT d.id, d.amount FROM test_decimal d JOIN second_table s ON d.id = s.foreign_id WHERE d.amount < DECIMAL(0, 0);
SELECT AVG(amount) FROM test_decimal WHERE amount IS NOT NULL;
SELECT MAX(amount), MIN(amount) FROM test_decimal;
UPDATE test_decimal SET amount = DECIMAL(99999999, 2) WHERE id = 2;
DELETE FROM test_decimal WHERE amount < DECIMAL(-1000, 2);
WITH DecimalCTE AS (SELECT id, amount FROM test_decimal WHERE amount > DECIMAL(0, 0)) SELECT * FROM DecimalCTE;
SELECT d.id FROM test_decimal d WHERE EXISTS (SELECT 1 FROM second_table s WHERE s.foreign_id = d.id);
SELECT d.amount + DECIMAL(100, 2) AS updated_amount FROM test_decimal d;
SELECT d.id, d.amount * DECIMAL(1.1, 2) AS incremented_amount FROM test_decimal d WHERE d.amount IS NOT NULL;