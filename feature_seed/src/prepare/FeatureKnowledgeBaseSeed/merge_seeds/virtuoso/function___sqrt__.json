CREATE PROCEDURE calc_sqrts(in _from INTEGER, in _to INTEGER) { DECLARE i INTEGER;
DECLARE result DOUBLE PRECISION;
result_names(i, result);
i := _from;
WHILE (i <= _to) { result(i, sqrt(i));
i := i + 1;
} };
SELECT value, result FROM sqrt_test WHERE value >= 0 ORDER BY value;
SELECT t1.value AS input, t2.result AS output FROM sqrt_test t1 JOIN sqrt_test t2 ON t1.value = t2.value WHERE t1.value <= 10;
WITH sqrt_values AS (SELECT value, sqrt(value) AS sqrt_result FROM sqrt_test) SELECT * FROM sqrt_values WHERE sqrt_result > 0;
SELECT AVG(result) AS average_sqrt FROM sqrt_test WHERE value > 0;
SELECT COUNT(*) FROM sqrt_test WHERE result IS NULL;