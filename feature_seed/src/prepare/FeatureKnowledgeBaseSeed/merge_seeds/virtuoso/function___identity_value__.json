CREATE TABLE test_identity (id INT PRIMARY KEY IDENTITY, name VARCHAR(100));
INSERT INTO test_identity (name) VALUES ('Alice');
SELECT identity_value();
INSERT INTO test_identity (name) VALUES ('Bob');
SELECT identity_value();
INSERT INTO test_identity (name) VALUES (NULL);
SELECT identity_value();
CREATE TABLE another_identity (id INT PRIMARY KEY IDENTITY, description TEXT);
INSERT INTO another_identity (description) VALUES ('Test description');
SELECT identity_value();
INSERT INTO another_identity (description) VALUES ('Another description');
SELECT identity_value();
INSERT INTO test_identity (name) VALUES ('Charlie');
SELECT identity_value();
INSERT INTO (SELECT id FROM another_identity WHERE description = 'Test description') AS temp SELECT identity_value();
INSERT INTO another_identity (description) VALUES ('Third description');
INSERT INTO test_identity (name) VALUES ('Dave');
INSERT INTO (SELECT id FROM test_identity WHERE name = 'Alice') AS temp SELECT identity_value();
CREATE TABLE complex_table (cid INT PRIMARY KEY IDENTITY, value VARCHAR(100));
INSERT INTO complex_table (value) SELECT name FROM test_identity WHERE id IN (SELECT id FROM test_identity WHERE name LIKE 'A%');
SELECT identity_value();
INSERT INTO complex_table (value) SELECT name FROM test_identity WHERE id = (SELECT MAX(id) FROM test_identity);
SELECT identity_value();
CREATE TABLE remote_table (rid INT PRIMARY KEY IDENTITY, remote_value VARCHAR(100));
INSERT INTO remote_table (remote_value) VALUES ('Remote Entry');
SELECT identity_value();
INSERT INTO remote_table (remote_value) VALUES ('Another Remote Entry');
