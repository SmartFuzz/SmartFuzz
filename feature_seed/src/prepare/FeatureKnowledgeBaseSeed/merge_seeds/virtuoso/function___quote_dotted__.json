CREATE TABLE DEMO.EMP (ID INT, NAME VARCHAR(100), DEPARTMENT VARCHAR(100));
INSERT INTO DEMO.EMP (ID, NAME, DEPARTMENT) VALUES (1, 'Alice', 'HR');
INSERT INTO DEMO.EMP (ID, NAME, DEPARTMENT) VALUES (2, 'Bob', 'IT');
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier;
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier FROM DEMO.EMP WHERE ID = 1;
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier, ID FROM DEMO.EMP WHERE DEPARTMENT = 'IT';
CREATE TABLE DEMO.DEPARTMENTS (DEPT_ID INT, DEPT_NAME VARCHAR(100));
INSERT INTO DEMO.DEPARTMENTS (DEPT_ID, DEPT_NAME) VALUES (1, 'HR');
INSERT INTO DEMO.DEPARTMENTS (DEPT_ID, DEPT_NAME) VALUES (2, 'IT');
SELECT e.NAME, d.DEPT_NAME FROM DEMO.EMP e JOIN DEMO.DEPARTMENTS d ON e.DEPARTMENT = d.DEPT_NAME;
SELECT quote_dotted('oracle', 'DEMO.DEPARTMENTS') AS quoted_identifier FROM DEMO.DEPARTMENTS;
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier FROM (SELECT ID, NAME FROM DEMO.EMP WHERE DEPARTMENT = 'HR') subquery;
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier FROM DEMO.EMP WHERE ID IN (SELECT DEPT_ID FROM DEMO.DEPARTMENTS WHERE DEPT_NAME = 'IT');
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier, (SELECT COUNT(*) FROM DEMO.EMP) AS total_employees FROM DEMO.EMP WHERE DEPARTMENT = (SELECT DEPT_NAME FROM DEMO.DEPARTMENTS WHERE DEPT_ID = 2);
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier FROM DEMO.EMP ORDER BY NAME ASC;
SELECT quote_dotted('oracle', 'DEMO.EMP') AS quoted_identifier FROM DEMO.EMP WHERE NAME LIKE 'A%';