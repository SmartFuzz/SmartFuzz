CREATE TABLE test_decimal (id INT PRIMARY KEY, value DECIMAL(10, 2));
INSERT INTO test_decimal (id, value) VALUES (1, 1234567890.00);
INSERT INTO test_decimal (id, value) VALUES (2, -1234567890.00);
INSERT INTO test_decimal (id, value) VALUES (3, 0.00);
INSERT INTO test_decimal (id, value) VALUES (4, 123.45);
INSERT INTO test_decimal (id, value) VALUES (5, -0.01);
SELECT * FROM test_decimal WHERE value < 0;
SELECT SUM(value) AS total FROM test_decimal;
SELECT AVG(value) AS average FROM test_decimal;
SELECT id, value FROM test_decimal WHERE value BETWEEN 100.00 AND 200.00;
CREATE TABLE test_decimal2 (id INT PRIMARY KEY, value DECIMAL(12, 4));
INSERT INTO test_decimal2 (id, value) VALUES (1, 12345.6789);
INSERT INTO test_decimal2 (id, value) SELECT value * 1.05 FROM test_decimal WHERE value > 0;
SELECT d.id, d.value, d2.value AS adjusted_value FROM test_decimal d INNER JOIN test_decimal2 d2 ON d.id = d2.id;
SELECT d.id FROM test_decimal d WHERE d.value = (SELECT MAX(value) FROM test_decimal);
SELECT d.id, d.value FROM test_decimal d WHERE d.value < (SELECT AVG(value) FROM test_decimal);
UPDATE test_decimal SET value = ROUND(value, 1) WHERE id = 1;
DELETE FROM test_decimal WHERE value < 0;