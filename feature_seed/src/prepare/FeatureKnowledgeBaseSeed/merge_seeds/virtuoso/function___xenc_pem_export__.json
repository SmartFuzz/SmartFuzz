CREATE TABLE keys (id INT PRIMARY KEY, name VARCHAR(255), private_key TEXT, public_key TEXT);
INSERT INTO keys (id, name, private_key, public_key) VALUES (1, 'test_key_1', 'private_data_1', 'public_data_1');
INSERT INTO keys (id, name, private_key, public_key) VALUES (2, 'test_key_2', NULL, 'public_data_2');
INSERT INTO keys (id, name, private_key, public_key) VALUES (3, 'test_key_3', 'private_data_3', 'public_data_3');
SELECT xenc_pem_export(NULL);
SELECT xenc_pem_export(public_key) FROM keys WHERE id = 1;
SELECT xenc_pem_export(private_key) FROM keys WHERE id = 1;
SELECT xenc_pem_export(public_key) FROM keys WHERE name = 'test_key_2';
SELECT xenc_pem_export(private_key) FROM keys WHERE id IN (SELECT id FROM keys WHERE name LIKE 'test_key_%');
SELECT xenc_pem_export(public_key) FROM keys WHERE EXISTS (SELECT 1 FROM keys WHERE id = 3);
SELECT xenc_pem_export(NULL) AS pem_output, public_key FROM keys WHERE private_key IS NOT NULL;
SELECT xenc_pem_export(private_key) AS pem_output FROM keys WHERE name = (SELECT name FROM keys ORDER BY id DESC LIMIT 1);
SELECT xenc_pem_export(private_key) AS pem_output FROM keys WHERE id = (SELECT MAX(id) FROM keys);
SELECT xenc_pem_export(private_key) FROM keys WHERE private_key IS NOT NULL AND public_key IS NOT NULL;
SELECT DISTINCT xenc_pem_export(private_key) FROM keys WHERE public_key IS NOT NULL ORDER BY id;
WITH KeyData AS (SELECT * FROM keys WHERE private_key IS NOT NULL) SELECT xenc_pem_export(private_key) FROM KeyData;
SELECT xenc_pem_export(public_key) FROM keys WHERE id = 1 UNION SELECT xenc_pem_export(public_key) FROM keys WHERE id = 2;
SELECT xenc_pem_export(public_key) FROM keys WHERE id IN (SELECT id FROM keys WHERE name = 'test_key_1' OR name = 'test_key_3');