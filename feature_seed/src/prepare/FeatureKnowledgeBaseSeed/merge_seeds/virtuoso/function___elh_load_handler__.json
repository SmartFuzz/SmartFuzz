CREATE TABLE encoding_handlers (id SERIAL PRIMARY KEY, rfc1766_id VARCHAR(10) NOT NULL, iso639_id VARCHAR(10) NOT NULL, handler_name VARCHAR(255) NOT NULL, UNIQUE(rfc1766_id), UNIQUE(iso639_id));
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('en-US', 'en', 'English (United States)');
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('fr-FR', 'fr', 'French (France)');
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('es-ES', 'es', 'Spanish (Spain)');
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('de-DE', 'de', 'German (Germany)');
UPDATE encoding_handlers SET handler_name='Updated English (US)' WHERE rfc1766_id='en-US';
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('de-DE', 'de-DE', 'German (Germany)');
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('ja-JP', 'ja', 'Japanese (Japan)');
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) SELECT 'it-IT', 'it', 'Italian (Italy)' WHERE NOT EXISTS (SELECT 1 FROM encoding_handlers WHERE rfc1766_id='it-IT');
UPDATE encoding_handlers SET handler_name='Updated French (France)' WHERE iso639_id='fr';
SELECT * FROM encoding_handlers WHERE rfc1766_id IN ('en-US', 'fr-FR');
DELETE FROM encoding_handlers WHERE rfc1766_id='es-ES';
SELECT handler_name FROM encoding_handlers WHERE iso639_id = (SELECT iso639_id FROM encoding_handlers WHERE rfc1766_id='ja-JP');
INSERT INTO encoding_handlers (rfc1766_id, iso639_id, handler_name) VALUES ('x-any', 'x-any', 'Custom Handler') ON CONFLICT DO NOTHING;
UPDATE encoding_handlers SET handler_name='Updated German (Germany)' WHERE rfc1766_id = 'de-DE' AND iso639_id = 'de';
SELECT COUNT(*) FROM encoding_handlers WHERE iso639_id IN (SELECT iso639_id FROM encoding_handlers WHERE rfc1766_id='fr-FR');