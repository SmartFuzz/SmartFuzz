CREATE TABLE TOTP_test (id INT PRIMARY KEY, secret_key VARCHAR(255), start_time TIMESTAMP, end_time TIMESTAMP, step INT);
INSERT INTO TOTP_test (id, secret_key, start_time, end_time, step) VALUES (1, 'k2', stringdate('1970-01-01Z'), stringdate('2603-10-11 11:33:20Z'), 30);
SELECT TOTP_generate(stringdate('1970-01-01Z'), stringdate('2603-10-11 11:33:20Z'), 30, 8, secret_key, 'hmac-sha256') FROM TOTP_test WHERE id = 1;
SELECT id, TOTP_generate(stringdate('2000-01-01Z'), stringdate('2023-10-01 10:00:00Z'), 15, 6, secret_key, 'hmac-sha1') AS password FROM TOTP_test;
CREATE TABLE User_data (user_id INT PRIMARY KEY, name VARCHAR(100), secret_key VARCHAR(255));
INSERT INTO User_data (user_id, name, secret_key) VALUES (1, 'Alice', 'k1'), (2, 'Bob', 'k2');
SELECT u.name, TOTP_generate(stringdate('1970-01-01Z'), NOW(), 30, 8, u.secret_key, 'hmac-sha256') AS TOTP FROM User_data u WHERE u.user_id = 2;
WITH TOTP_values AS (SELECT secret_key, TOTP_generate(stringdate('2000-01-01Z'), stringdate('2025-01-01 00:00:00Z'), 60, 8, secret_key, 'hmac-sha512') AS totp_value FROM User_data) SELECT * FROM TOTP_values;
SELECT TOTP_generate(CAST('1970-01-01Z' AS TIMESTAMP), CAST('2603-10-11 11:33:20Z' AS TIMESTAMP), 30, 8, (SELECT secret_key FROM User_data WHERE user_id = 1), 'hmac-sha256') AS totp_value;
SELECT TOTP_generate(stringdate('1990-01-01Z'), stringdate('2050-12-31 23:59:59Z'), 45, 10, 'k3', 'hmac-sha256') AS TOTP_new FROM DUAL;
CREATE TABLE Time_intervals (start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO Time_intervals (start_time, end_time) VALUES (stringdate('1970-01-01Z'), stringdate('3000-12-31 23:59:59Z'));
SELECT TOTP_generate(t.start_time, t.end_time, 30, 8, 'k2', 'hmac-sha256') FROM Time_intervals t WHERE t.start_time >= stringdate('1970-01-01Z');