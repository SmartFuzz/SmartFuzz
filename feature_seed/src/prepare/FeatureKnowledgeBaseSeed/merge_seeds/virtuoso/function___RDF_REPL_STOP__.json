CREATE TABLE log_changes (log_id INT PRIMARY KEY, graph_name VARCHAR(255), change_type VARCHAR(50), change_timestamp TIMESTAMP);
INSERT INTO log_changes (log_id, graph_name, change_type, change_timestamp) SELECT id, graph_name, 'stopped', CURRENT_TIMESTAMP FROM rdf_graphs WHERE replication_status = 'active';
