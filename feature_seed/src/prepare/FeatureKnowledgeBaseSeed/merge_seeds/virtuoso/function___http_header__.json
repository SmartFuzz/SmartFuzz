CREATE TABLE headers (id INT PRIMARY KEY, header_line VARCHAR(255));
INSERT INTO headers (id, header_line) VALUES (1, 'Content-type: text/html\r\n');
INSERT INTO headers (id, header_line) VALUES (2, 'Cache-Control: no-cache\r\n');
INSERT INTO headers (id, header_line) VALUES (3, 'Content-Length: 123\r\n');
SELECT header_line FROM headers WHERE id = 1;
SELECT header_line FROM headers WHERE id = 2;
SELECT header_line FROM headers WHERE id IN (SELECT id FROM headers WHERE id < 3);
SELECT header_line FROM headers WHERE header_line LIKE 'Content%';
DELETE FROM headers WHERE id = 3;
SELECT COUNT(*) FROM headers;
UPDATE headers SET header_line = 'Content-type: application/json\r\n' WHERE id = 1;
INSERT INTO headers (id, header_line) VALUES (4, 'Accept-Encoding: gzip\r\n');
SELECT header_line FROM headers WHERE id IN (SELECT id FROM headers WHERE id > 1 AND header_line LIKE 'Content%');
SELECT h1.header_line, h2.header_line FROM headers h1 JOIN headers h2 ON h1.id <> h2.id LIMIT 5;
CREATE TABLE response (status_code INT, message VARCHAR(255));
INSERT INTO response (status_code, message) VALUES (200, 'OK');
INSERT INTO response (status_code, message) VALUES (404, 'Not Found');
SELECT r.message FROM response r WHERE r.status_code = (SELECT MAX(status_code) FROM response);
UPDATE response SET message = 'Moved Permanently' WHERE status_code = 301;
DELETE FROM response WHERE status_code = 404;