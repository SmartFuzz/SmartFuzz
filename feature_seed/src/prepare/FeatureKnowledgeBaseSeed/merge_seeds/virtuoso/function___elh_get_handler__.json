CREATE TABLE language (id INT, code VARCHAR(10), name VARCHAR(50));
CREATE TABLE localization (id INT, language_id INT, localized_string VARCHAR(255));
INSERT INTO language (id, code, name) VALUES (1, 'en', 'English'), (2, 'es', 'Spanish'), (3, 'fr', 'French');
INSERT INTO localization (id, language_id, localized_string) VALUES (1, 1, 'Hello'), (2, 2, 'Hola'), (3, 3, 'Bonjour');
SELECT * FROM localization WHERE language_id = (SELECT id FROM language WHERE code = 'en') AND localized_string = 'Hello';
SELECT l.localized_string FROM localization l JOIN language lg ON l.language_id = lg.id WHERE lg.code IN ('es', 'fr') AND l.localized_string LIKE '%o%';
SELECT lg.code, COUNT(l.id) FROM language lg LEFT JOIN localization l ON lg.id = l.language_id GROUP BY lg.code HAVING COUNT(l.id) > 0;
SELECT lang.code, (SELECT COUNT(*) FROM localization WHERE language_id = lang.id) AS localization_count FROM language lang ORDER BY localization_count DESC;
SELECT * FROM language WHERE id IN (SELECT language_id FROM localization WHERE localized_string LIKE '%Hello%');
SELECT lg.code, l.localized_string FROM language lg INNER JOIN localization l ON lg.id = l.language_id WHERE l.localized_string IS NOT NULL AND lg.code NOT LIKE '%-%';