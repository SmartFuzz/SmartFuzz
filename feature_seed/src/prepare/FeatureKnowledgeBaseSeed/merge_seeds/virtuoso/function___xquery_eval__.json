CREATE TABLE xml_data (id INT PRIMARY KEY, xt_file NVARCHAR(255), xt_text XML);
INSERT INTO xml_data (id, xt_file, xt_text) VALUES (1, 'file1.xml', '<library><book><title>Introduction</title></book></library>');
INSERT INTO xml_data (id, xt_file, xt_text) VALUES (2, 'file2.xml', '<library><book><title>Advanced Topics</title></book></library>');
SELECT xt_file, xquery_eval('<books>//title</books>', xt_text) FROM xml_data WHERE xpath_contains(xt_text, '//book/title[. = "Introduction"]', t);
SELECT xt_file, xquery_eval('<authors>//author</authors>', xt_text) FROM xml_data WHERE id = 1;
SELECT xt_file, xquery_eval('<element>{count(//book)}</element>', xt_text) FROM xml_data;
SELECT xt_file, xquery_eval('<element>{fn:string-length(//book/title)}</element>', xt_text) FROM xml_data WHERE id IN (SELECT id FROM xml_data WHERE id = 2);
SELECT xt_file, xquery_eval('<titles>{for $b in //book return $b/title}</titles>', xt_text) FROM xml_data;
SELECT xt_file, xquery_eval('<titles>{for $b in //book return <title>{$b/title/text()}</title>}</titles>', xt_text) FROM xml_data WHERE xpath_contains(xt_text, '//book', t);
SELECT xt_file, xquery_eval('<result>{let $val := $p return $val}</result>', xt_text, 1, ARRAY['p', 'some value']) FROM xml_data;
SELECT xt_file, xquery_eval('<result>{for $v in (1, 2, 3) return <num>{$v}</num>}</result>', xt_text) FROM xml_data WHERE id = 1;
SELECT xt_file, xquery_eval('<value>{if (//book/title = "Introduction") then "found" else "not found"}</value>', xt_text) FROM xml_data;
SELECT xt_file, xquery_eval('<result>{$x in (1, 2, 3)} return <item>{$x}</item></result>', xt_text, 0) FROM xml_data;