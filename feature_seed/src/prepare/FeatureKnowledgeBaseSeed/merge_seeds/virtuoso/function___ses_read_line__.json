CREATE TABLE TestData (id INT PRIMARY KEY, data VARCHAR(1024));
INSERT INTO TestData (id, data) VALUES (1, '<p>Some text</p>');
INSERT INTO TestData (id, data) VALUES (2, '<p>Another line of text</p>');
SELECT data FROM TestData WHERE id = 1;
SELECT data FROM TestData WHERE id IN (SELECT id FROM TestData WHERE data LIKE '%text%');
SELECT data FROM TestData WHERE id = 2 AND LENGTH(data) < 1024;
WITH TempData AS (SELECT data FROM TestData WHERE LENGTH(data) < 1024) SELECT COUNT(*) FROM TempData;
SELECT data FROM TestData WHERE data NOT LIKE '%error%' AND id = (SELECT MAX(id) FROM TestData);
SELECT data FROM TestData WHERE id = 1 OR EXISTS (SELECT 1 FROM TestData WHERE id = 2);
SELECT MAX(LENGTH(data)) FROM TestData WHERE LENGTH(data) <= 1024;
SELECT data FROM TestData WHERE LENGTH(data) BETWEEN 1 AND 1024;
UPDATE TestData SET data = '<p>Updated text</p>' WHERE id = 1;
DELETE FROM TestData WHERE id > 1;