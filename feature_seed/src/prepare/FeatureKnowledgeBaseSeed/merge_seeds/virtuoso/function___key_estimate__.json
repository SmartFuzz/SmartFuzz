CREATE TABLE DB.DBA.T1 (id INT, name VARCHAR(100), age INT, city VARCHAR(100));
CREATE INDEX STR1 ON DB.DBA.T1 (name);
INSERT INTO DB.DBA.T1 (id, name, age, city) VALUES (1, 'Alice', 30, 'New York');
INSERT INTO DB.DBA.T1 (id, name, age, city) VALUES (2, 'Bob', 25, 'Los Angeles');
INSERT INTO DB.DBA.T1 (id, name, age, city) VALUES (3, 'Charlie', 35, 'Chicago');
SELECT key_estimate('DB.DBA.T1', 'STR1');
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Alice');
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Bob', 25);
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Charlie', 35);
SELECT key_estimate('DB.DBA.T1', 'STR1', 'NotExist');
SELECT key_estimate('DB.DBA.T1', 'STR1', NULL);
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Alice', 'New York');
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Alice', 'New York', 'Unknown');
SELECT key_estimate('DB.DBA.T1', 'STR1', 1234);
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Alice', 123, 'Bob');
SELECT key_estimate('DB.DBA.T1', 'STR1', 'Alice', 'Multi', (SELECT MAX(age) FROM DB.DBA.T1));
SELECT key_estimate('DB.DBA.T1', 'STR1', (SELECT name FROM DB.DBA.T1 WHERE id = 1));