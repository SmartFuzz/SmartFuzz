CREATE TABLE test_numbers (id INT, value VARCHAR(50));
INSERT INTO test_numbers (id, value) VALUES (1, '3.14159');
INSERT INTO test_numbers (id, value) VALUES (2, '2.71828');
INSERT INTO test_numbers (id, value) VALUES (3, '0.00001');
INSERT INTO test_numbers (id, value) VALUES (4, 'Cadena de los patos amarillos');
INSERT INTO test_numbers (id, value) VALUES (5, '10000000000.0');
INSERT INTO test_numbers (id, value) VALUES (6, '-123.456');
INSERT INTO test_numbers (id, value) VALUES (7, '1e10');
INSERT INTO test_numbers (id, value) VALUES (8, '-1e-10');
SELECT id, atof(value) AS float_value FROM test_numbers;
SELECT id, atof(value) AS float_value FROM test_numbers WHERE id IN (SELECT id FROM test_numbers WHERE id < 5);
SELECT id, atof(value) AS float_value FROM test_numbers ORDER BY float_value DESC;
SELECT (SELECT atof(value) FROM test_numbers WHERE id = 1) + (SELECT atof(value) FROM test_numbers WHERE id = 2) AS sum_float_value;
SELECT id, atof(value) AS float_value FROM test_numbers WHERE atof(value) > 0;
SELECT id, atof(CONCAT(value, '0')) AS float_value FROM test_numbers;
SELECT DISTINCT atof(value) AS unique_float_value FROM test_numbers;