CREATE TABLE test_date_time (id INT, dt TIMESTAMP);
INSERT INTO test_date_time VALUES (1, cast('1999-12-31 11:59+02:00' as datetime));
INSERT INTO test_date_time VALUES (2, cast('2000-01-01 10:00+00:00' as datetime));
INSERT INTO test_date_time VALUES (3, cast('2023-10-01 08:30+05:30' as datetime));
SELECT dt, cast(forget_timezone(dt) as varchar) AS without_timezone FROM test_date_time WHERE id = 1;
SELECT dt, cast(forget_timezone(dt) as varchar) AS without_timezone FROM test_date_time WHERE dt IS NOT NULL;
SELECT dt, cast(forget_timezone(dt) as varchar) AS without_timezone FROM test_date_time WHERE id IN (SELECT id FROM test_date_time WHERE dt < '2001-01-01');
SELECT A.dt, cast(forget_timezone(A.dt) as varchar) AS without_timezone FROM test_date_time A JOIN test_date_time B ON A.id = B.id WHERE B.dt = cast('2000-01-01 10:00+00:00' as datetime);
SELECT dt, cast(forget_timezone(dt) as varchar) AS without_timezone FROM test_date_time WHERE dt <> cast('1999-12-31 11:59+02:00' as datetime);
SELECT dt, cast(forget_timezone(dt) as varchar) AS without_timezone FROM (SELECT dt FROM test_date_time WHERE id = 2) AS subquery;
SELECT dt, (CASE WHEN dt IS NULL THEN NULL ELSE cast(forget_timezone(dt) as varchar) END) AS without_timezone FROM test_date_time;
DELETE FROM test_date_time WHERE id = 3;
SELECT cast(forget_timezone(cast('2023-10-01 08:30+05:30' as datetime)) as varchar) AS without_timezone;
SELECT cast(forget_timezone(cast('2023-12-31 23:59+02:00' as datetime)) as varchar) AS without_timezone;