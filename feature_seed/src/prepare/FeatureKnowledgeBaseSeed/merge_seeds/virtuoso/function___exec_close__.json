CREATE TABLE test_table (id INT, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
INSERT INTO test_table (id, name) VALUES (2, 'Bob');
EXECUTE IMMEDIATE 'SELECT * FROM test_table';
DECLARE cursor_var CURSOR FOR SELECT * FROM test_table;
OPEN cursor_var;
EXEC_CLOSE cursor_var;
CREATE TABLE orders (order_id INT, customer_id INT, amount DECIMAL(10, 2));
INSERT INTO orders (order_id, customer_id, amount) VALUES (101, 1, 99.99);
INSERT INTO orders (order_id, customer_id, amount) VALUES (102, 2, 149.99);
EXECUTE IMMEDIATE 'SELECT * FROM orders WHERE amount > 100';
DECLARE cursor_order CURSOR FOR SELECT * FROM orders JOIN test_table ON orders.customer_id = test_table.id;
OPEN cursor_order;
EXEC_CLOSE cursor_order;
CREATE VIEW high_value_orders AS SELECT * FROM orders WHERE amount > 100;
EXECUTE IMMEDIATE 'SELECT * FROM high_value_orders';
DECLARE cursor_view CURSOR FOR SELECT * FROM high_value_orders;
OPEN cursor_view;
EXEC_CLOSE cursor_view;
SELECT DISTINCT customer_id FROM orders WHERE customer_id IN (SELECT id FROM test_table);
EXECUTE IMMEDIATE 'SELECT * FROM orders WHERE order_id IN (SELECT order_id FROM orders WHERE amount > 100)';
CREATE TABLE payments (payment_id INT, order_id INT, payment_date DATE);
INSERT INTO payments (payment_id, order_id, payment_date) VALUES (1, 101, '2023-10-01');
INSERT INTO payments (payment_id, order_id, payment_date) VALUES (2, 102, '2023-10-02');
DECLARE cursor_payment CURSOR FOR SELECT * FROM payments WHERE payment_id IN (SELECT payment_id FROM payments ORDER BY payment_date DESC LIMIT 1);
OPEN cursor_payment;
EXEC_CLOSE cursor_payment;