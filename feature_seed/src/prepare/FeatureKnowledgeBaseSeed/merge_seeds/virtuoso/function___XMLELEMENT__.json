CREATE TABLE test_table (id INT, name VARCHAR(255));
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
INSERT INTO test_table (id, name) VALUES (2, 'Bob');
SELECT XMLELEMENT('person', XMLELEMENT('name', name), XMLELEMENT('id', id)) FROM test_table;
SELECT XMLELEMENT('employee', XMLELEMENT('name', name), XMLELEMENT('id', id)) FROM test_table WHERE id = 1;
SELECT XMLELEMENT('customer', XMLELEMENT('name', name), XMLELEMENT('order', (SELECT XMLELEMENT('product', 'Widget') FROM DUAL))) FROM test_table;
SELECT XMLELEMENT('book', XMLELEMENT('title', 'The Great Gatsby'), XMLELEMENT('author', 'F. Scott Fitzgerald'), XMLELEMENT('year', 1925));
SELECT XMLELEMENT('order', (SELECT XMLELEMENT('item', XMLELEMENT('name', 'Laptop'), XMLELEMENT('quantity', 1)) FROM DUAL), (SELECT XMLELEMENT('item', XMLELEMENT('name', 'Mouse'), XMLELEMENT('quantity', 2)) FROM DUAL)) FROM DUAL;
SELECT XMLELEMENT('invoice', XMLELEMENT('customer', XMLELEMENT('name', name)), (SELECT XMLELEMENT('total', SUM(price)) FROM orders WHERE customer_id = test_table.id)) FROM test_table;
SELECT XMLELEMENT('product', XMLELEMENT('name', XMLELEMENT('brand', 'BrandName')), XMLELEMENT('details', 'Product details here.')) FROM DUAL;