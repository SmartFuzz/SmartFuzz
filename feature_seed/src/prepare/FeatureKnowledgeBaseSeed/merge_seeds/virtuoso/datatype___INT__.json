CREATE TABLE test_integers (id INT PRIMARY KEY, value INT);
INSERT INTO test_integers (id, value) VALUES (1, 2147483647);
INSERT INTO test_integers (id, value) VALUES (2, -2147483648);
INSERT INTO test_integers (id, value) VALUES (3, 0);
SELECT * FROM test_integers WHERE value BETWEEN -100 AND 100;
SELECT * FROM test_integers WHERE value IN (SELECT value FROM test_integers WHERE value > 100);
UPDATE test_integers SET value = value + 1 WHERE id = 1;
DELETE FROM test_integers WHERE id = 2;
CREATE TABLE test_integers_2 (id INT PRIMARY KEY, value INT);
INSERT INTO test_integers_2 (id, value) VALUES (1, 300);
SELECT a.id, a.value, b.value FROM test_integers a JOIN test_integers_2 b ON a.id = b.id;
SELECT id, COUNT(value) FROM test_integers GROUP BY id HAVING COUNT(value) > 1;
WITH filtered AS (SELECT * FROM test_integers WHERE value < 100) SELECT * FROM filtered WHERE id < 5;
SELECT MAX(value) FROM test_integers WHERE value < 0;
SELECT MIN(value) FROM test_integers WHERE value > 100;
INSERT INTO test_integers (id, value) VALUES (4, 2147483648);
INSERT INTO test_integers (id, value) VALUES (5, -2147483649);
SELECT sum(value) FROM test_integers WHERE value IS NOT NULL;
SELECT DISTINCT value FROM test_integers WHERE value BETWEEN 0 AND 100 ORDER BY value;
CREATE TABLE test_joined (id INT, integer_id INT, FOREIGN KEY (integer_id) REFERENCES test_integers(id));
INSERT INTO test_joined (id, integer_id) VALUES (1, 1);
SELECT t1.id, t1.value, t2.id FROM test_integers t1 LEFT JOIN test_joined t2 ON t1.id = t2.integer_id;