CREATE TABLE registry_test (id INT PRIMARY KEY, setting_name VARCHAR, setting_value VARCHAR);
INSERT INTO registry_test (id, setting_name, setting_value) VALUES (1, 'var_demo', 'initial value');
SELECT registry_get('var_demo');
CALL registry_set('var_demo', 'updated value');
SELECT registry_get('var_demo');
INSERT INTO registry_test (id, setting_name, setting_value) VALUES (2, 'var_edge_case', NULL);
SELECT registry_get('var_edge_case');
SELECT (SELECT registry_get('var_demo') FROM registry_test WHERE setting_name = 'var_demo') AS demo_value;
SELECT (SELECT registry_get(setting_name) FROM registry_test WHERE id = 1) AS demo_value;
CALL registry_set('var_edge_case', 'data for edge case');
SELECT registry_get('var_edge_case') UNION SELECT registry_get('var_demo');
CREATE TABLE another_registry (name VARCHAR, value VARCHAR);
INSERT INTO another_registry (name, value) VALUES ('var_demo', 'some other data');
SELECT registry_get((SELECT name FROM another_registry WHERE value = 'some other data'));
SELECT COUNT(*) FROM another_registry WHERE value IS NOT NULL;
SELECT registry_get((SELECT name FROM registry_test WHERE value IS NULL)) AS null_case;