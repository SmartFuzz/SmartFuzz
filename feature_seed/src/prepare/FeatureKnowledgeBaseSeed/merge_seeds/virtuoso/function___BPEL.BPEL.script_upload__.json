CREATE TABLE bpel_scripts (id INTEGER PRIMARY KEY, name VARCHAR(100), url VARCHAR(255), content TEXT);
INSERT INTO bpel_scripts (name, url, content) VALUES ('LoanFlow', 'file:/LoanFlow.bpel', null);
SELECT BPEL.BPEL.script_upload((SELECT name FROM bpel_scripts WHERE id = 1), (SELECT url FROM bpel_scripts WHERE id = 1), null);
INSERT INTO bpel_scripts (name, url, content) VALUES ('PaymentFlow', 'file:/PaymentFlow.bpel', '<sample>BPEL content</sample>');
SELECT BPEL.BPEL.script_upload('InvoiceFlow', 'file:/InvoiceFlow.bpel', '<sample>BPEL for Invoice</sample>');
SELECT BPEL.BPEL.script_upload('LoanFlow_Empty', null, '<empty content>');
INSERT INTO bpel_scripts (name, url, content) VALUES ('ComplexFlow', 'file:/ComplexFlow.bpel', '<complex>BPEL content with <nested>elements</nested></complex>');
SELECT DISTINCT BPEL.BPEL.script_upload('DynamicFlow_' || id, 'file:/DynamicFlow_' || id || '.bpel', null) FROM (SELECT id FROM bpel_scripts) AS t;
SELECT BPEL.BPEL.script_upload((SELECT name FROM bpel_scripts ORDER BY RANDOM() LIMIT 1), (SELECT url FROM bpel_scripts ORDER BY RANDOM() LIMIT 1), null);
SELECT BPEL.BPEL.script_upload('AdvancedFlow', 'file:/AdvancedFlow.bpel', (SELECT content FROM bpel_scripts WHERE name = 'PaymentFlow'));