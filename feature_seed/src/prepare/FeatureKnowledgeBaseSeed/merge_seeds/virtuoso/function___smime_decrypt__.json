CREATE TABLE test_files (id INT, file_content BLOB, file_type VARCHAR(50));
INSERT INTO test_files (id, file_content, file_type) VALUES (1, file_to_string('test.p7m'), 'p7m');
INSERT INTO test_files (id, file_content, file_type) VALUES (2, file_to_string('test.pem'), 'pem');
INSERT INTO test_files (id, file_content, file_type) VALUES (3, file_to_string('test.key.pem'), 'key.pem');
SELECT smime_decrypt((SELECT file_content FROM test_files WHERE id = 1), (SELECT file_content FROM test_files WHERE id = 2), (SELECT file_content FROM test_files WHERE id = 3), 'secret');
SELECT smime_decrypt(file_to_string('test_large.p7m'), file_to_string('test_large.pem'), file_to_string('test_large.key.pem'), 'secret') FROM dual;
WITH files AS (SELECT file_content FROM test_files WHERE file_type IN ('p7m', 'pem', 'key.pem')) SELECT smime_decrypt((SELECT file_content FROM files WHERE ROWNUM = 1), (SELECT file_content FROM files WHERE ROWNUM = 2), (SELECT file_content FROM files WHERE ROWNUM = 3), 'secret') FROM dual;
SELECT smime_decrypt(file_to_string('empty.p7m'), file_to_string('empty.pem'), file_to_string('empty.key.pem'), 'secret') FROM dual;
SELECT smime_decrypt(file_to_string('corrupted.p7m'), file_to_string('corrupted.pem'), file_to_string('corrupted.key.pem'), 'wrong_secret') FROM dual;
SELECT smime_decrypt(NULL, NULL, NULL, NULL) FROM dual;
SELECT smime_decrypt(file_to_string('test_empty.p7m'), file_to_string('test_empty.pem'), file_to_string('test_empty.key.pem'), '') FROM dual;