CREATE TABLE regression_data (id INT, x_value DOUBLE, y_value DOUBLE);
INSERT INTO regression_data (id, x_value, y_value) VALUES (1, 1.0, 2.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (2, 2.0, 3.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (3, 3.0, 5.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (4, 4.0, 4.0);
INSERT INTO regression_data (id, x_value, y_value) VALUES (5, 5.0, 6.0);
SELECT REGR_R2(y_value, x_value) FROM regression_data WHERE id IS NOT NULL;
SELECT REGR_R2(y_value, x_value) FROM regression_data WHERE x_value IS NOT NULL AND y_value IS NOT NULL;
SELECT REGR_R2(y_value, x_value) FROM (SELECT x_value, y_value FROM regression_data WHERE id > 2) AS subquery;
CREATE TABLE extra_data (id INT, regression_id INT, extra_value DOUBLE);
INSERT INTO extra_data (id, regression_id, extra_value) VALUES (1, 1, 10.0);
INSERT INTO extra_data (id, regression_id, extra_value) VALUES (2, 1, 20.0);
SELECT REGR_R2(d.y_value, d.x_value) FROM regression_data d JOIN extra_data e ON d.id = e.regression_id WHERE e.extra_value > 15;
SELECT REGR_R2(y_value, x_value) FROM regression_data WHERE x_value < 0 OR y_value < 0;
SELECT REGR_R2(y_value, x_value) FROM (SELECT x_value, y_value FROM regression_data WHERE y_value IS NOT NULL) AS valid_data GROUP BY x_value;
WITH filtered_data AS (SELECT x_value, y_value FROM regression_data WHERE y_value > 0) SELECT REGR_R2(y_value, x_value) FROM filtered_data;
SELECT REGR_R2((SELECT AVG(y_value) FROM regression_data), (SELECT AVG(x_value) FROM regression_data));