CREATE TABLE keys (id INT PRIMARY KEY, key_value VARCHAR(255));
INSERT INTO keys (id, key_value) VALUES (1, 'myKey');
SELECT xenc_get_key_identifier(key_value) FROM keys WHERE id = 1;
SELECT xenc_get_key_identifier(('myKey' || 'ExtraSuffix')) AS identifier;
SELECT xenc_get_key_identifier((SELECT key_value FROM keys WHERE id = 1)) AS identifier;
WITH KeyData AS (SELECT key_value FROM keys WHERE id = 1) SELECT xenc_get_key_identifier((SELECT key_value FROM KeyData)) AS identifier;
CREATE TABLE additional_keys (id INT PRIMARY KEY, key_detail VARCHAR(255));
INSERT INTO additional_keys (id, key_detail) VALUES (1, 'myExtraKey');
SELECT xenc_get_key_identifier((SELECT key_detail FROM additional_keys WHERE id = 1) || (SELECT key_value FROM keys WHERE id = 1)) AS combined_identifier;
SELECT xenc_get_key_identifier(CONCAT((SELECT key_value FROM keys WHERE id = 1), (SELECT key_detail FROM additional_keys WHERE id = 1))) AS concatenated_identifier;
SELECT xenc_get_key_identifier('') AS empty_identifier;
SELECT xenc_get_key_identifier(NULL) AS null_identifier;
SELECT xenc_get_key_identifier(REPEAT('A', 255)) AS long_key_identifier;
CREATE TABLE temp_keys (id INT PRIMARY KEY, temp_key VARCHAR(255));
INSERT INTO temp_keys (id, temp_key) VALUES (1, 'myTempKey');
SELECT xenc_get_key_identifier((SELECT temp_key FROM temp_keys WHERE id = 1)) AS temp_identifier;
SELECT xenc_get_key_identifier((SELECT key_value FROM keys ORDER BY id LIMIT 1)) AS first_key_identifier;
SELECT xenc_get_key_identifier((SELECT key_value FROM keys ORDER BY id DESC LIMIT 1)) AS last_key_identifier;
SELECT xenc_get_key_identifier((SELECT MAX(key_value) FROM keys)) AS max_key_identifier;