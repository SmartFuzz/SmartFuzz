CREATE TABLE test_data (id INT, value FLOAT);
INSERT INTO test_data (id, value) VALUES (1, 10.0);
INSERT INTO test_data (id, value) VALUES (2, 20.0);
INSERT INTO test_data (id, value) VALUES (3, 30.0);
SELECT VAR(value) FROM test_data;
INSERT INTO test_data (id, value) VALUES (4, 40.0);
SELECT VAR(value) FROM test_data;
CREATE TABLE test_data_2 (id INT, group_id INT, score FLOAT);
INSERT INTO test_data_2 (id, group_id, score) VALUES (1, 1, 10.0);
INSERT INTO test_data_2 (id, group_id, score) VALUES (2, 1, 20.0);
INSERT INTO test_data_2 (id, group_id, score) VALUES (3, 2, 30.0);
INSERT INTO test_data_2 (id, group_id, score) VALUES (4, 2, 40.0);
SELECT group_id, VAR(score) FROM test_data_2 GROUP BY group_id;
INSERT INTO test_data_2 (id, group_id, score) VALUES (5, 1, 50.0);
SELECT group_id, VAR(score) FROM test_data_2 GROUP BY group_id;
SELECT VAR(value) FROM (SELECT value FROM test_data WHERE id IN (1, 2)) AS sub;
SELECT VAR(sub.value) FROM (SELECT value FROM test_data WHERE id > 1) AS sub;
SELECT VAR(value) FROM (SELECT value FROM test_data WHERE id IN (1)) AS sub;
SELECT VAR(COALESCE(value, 0)) FROM test_data;
SELECT VAR(value) FROM test_data WHERE value IS NOT NULL;