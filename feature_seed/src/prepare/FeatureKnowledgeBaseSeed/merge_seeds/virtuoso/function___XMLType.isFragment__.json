CREATE TABLE Users (ID INT, U_NAME VARCHAR(100));
INSERT INTO Users (ID, U_NAME) VALUES (1, 'BACKUP');
INSERT INTO Users (ID, U_NAME) VALUES (2, 'SOAP');
INSERT INTO Users (ID, U_NAME) VALUES (3, 'dba');
INSERT INTO Users (ID, U_NAME) VALUES (4, 'demo');
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM Users;
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT U_NAME FROM Users WHERE ID < 3);
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT * FROM Users ORDER BY ID DESC);
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT U_NAME FROM Users WHERE U_NAME LIKE 'D%');
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM Users HAVING COUNT(ID) > 2;
CREATE TABLE Documents (DocID INT, Content XMLType);
INSERT INTO Documents (DocID, Content) VALUES (1, XMLType('<root><user><name>BACKUP</name></user></root>'));
INSERT INTO Documents (DocID, Content) VALUES (2, XMLType('<root><user><name>SOAP</name></user><user><name>dba</name></user></root>'));
SELECT Content.isFragment() FROM Documents WHERE DocID = 1;
SELECT Content.isFragment() FROM Documents WHERE DocID = 2;
SELECT XMLType(XMLAGG(XMLELEMENT('root', XMLAGG(XMLELEMENT('User', U_NAME))))).isFragment() FROM Users;
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT DISTINCT U_NAME FROM Users);
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT U_NAME FROM Users UNION SELECT 'Anonymous' AS U_NAME);
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT U_NAME FROM Users WHERE U_NAME IS NOT NULL);
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT U_NAME FROM Users ORDER BY U_NAME ASC LIMIT 10);
SELECT XMLType(XMLAGG(XMLELEMENT('User', U_NAME))).isFragment() FROM (SELECT U_NAME FROM Users WHERE LENGTH(U_NAME) > 5);