CREATE TABLE test_collations (id INT, name VARCHAR(255));
INSERT INTO test_collations (id, name) VALUES (1, 'foo');
INSERT INTO test_collations (id, name) VALUES (2, 'FOO');
SELECT CASE WHEN CAST(name AS VARCHAR COLLATE insensitive_ascii) = CAST('FOO' AS VARCHAR COLLATE insensitive_ascii) THEN 'Match' ELSE 'No Match' END AS comparison FROM test_collations;
SELECT COUNT(*) FROM test_collations WHERE CAST(name AS VARCHAR COLLATE insensitive_ascii) = CAST('  fOo  ' AS VARCHAR COLLATE insensitive_ascii);
SELECT * FROM (SELECT id, name FROM test_collations) AS subquery WHERE CAST(name AS VARCHAR COLLATE insensitive_ascii) = CAST('FOO' AS VARCHAR COLLATE insensitive_ascii);
CREATE TABLE another_table (description VARCHAR(255));
INSERT INTO another_table (description) VALUES ('foo');
SELECT a.id, a.name, b.description FROM test_collations a JOIN another_table b ON CAST(a.name AS VARCHAR COLLATE insensitive_ascii) = CAST(b.description AS VARCHAR COLLATE insensitive_ascii);
CREATE TABLE collation_test (text_column VARCHAR(255) COLLATE insensitive_ascii);
INSERT INTO collation_test (text_column) VALUES ('Foo');
INSERT INTO collation_test (text_column) VALUES ('fOo');
SELECT COUNT(*) FROM collation_test WHERE text_column = 'foo';
SELECT text_column FROM collation_test WHERE CAST(text_column AS VARCHAR COLLATE insensitive_ascii) LIKE 'f%';
SELECT 1 FROM test_collations WHERE CAST(name AS VARCHAR COLLATE insensitive_ascii) IN (SELECT description FROM another_table WHERE CAST(description AS VARCHAR COLLATE insensitive_ascii) LIKE 'f%');