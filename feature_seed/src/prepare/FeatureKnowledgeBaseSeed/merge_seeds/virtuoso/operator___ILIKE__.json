CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie'), (4, 'David');
SELECT * FROM test_table WHERE name ILIKE 'a%';
SELECT * FROM test_table WHERE name ILIKE '%e';
SELECT * FROM test_table WHERE name ILIKE 'B%o';
SELECT * FROM test_table WHERE name ILIKE 'c%';
SELECT * FROM test_table WHERE name ILIKE 'A%ce';
SELECT * FROM test_table WHERE name ILIKE 'A%';
SELECT id FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name ILIKE 'c%');
CREATE TABLE another_table (id INT PRIMARY KEY, description VARCHAR(200));
INSERT INTO another_table (id, description) VALUES (1, 'A quick brown fox'), (2, 'Jumps over the lazy dog');
SELECT at.id, tt.name FROM another_table at JOIN test_table tt ON at.id = tt.id WHERE tt.name ILIKE 'a%';
SELECT tt.id FROM test_table tt WHERE NOT EXISTS (SELECT 1 FROM another_table at WHERE at.description ILIKE tt.name || '%');
SELECT tt.id FROM test_table tt WHERE tt.name ILIKE (SELECT name FROM test_table WHERE id = 1);
CREATE TABLE combined_table (id INT PRIMARY KEY, value VARCHAR(100));
INSERT INTO combined_table (id, value) VALUES (1, 'Value1'), (2, 'VaLuE2');
SELECT ct.id FROM combined_table ct WHERE ct.value ILIKE (SELECT name FROM test_table WHERE id = 2);
SELECT * FROM test_table WHERE name ILIKE ALL (ARRAY['A%', 'B%']);
SELECT * FROM test_table WHERE name ILIKE ANY (ARRAY['A%', 'D%']);
SELECT DISTINCT name FROM test_table WHERE name ILIKE 'a%';