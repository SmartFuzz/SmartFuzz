CREATE TABLE test_ini (id INTEGER PRIMARY KEY, ini_path VARCHAR(255));
INSERT INTO test_ini (id, ini_path) VALUES (1, virtuoso_ini_path());
INSERT INTO test_ini (id, ini_path) VALUES (2, 'path/to/empty.ini');
INSERT INTO test_ini (id, ini_path) VALUES (3, 'path/to/single_section.ini');
INSERT INTO test_ini (id, ini_path) VALUES (4, 'path/to/multiple_sections.ini');
SELECT cfg_section_count(ini_path) FROM test_ini WHERE id = 1;
SELECT cfg_section_count(ini_path) FROM test_ini WHERE ini_path = 'path/to/empty.ini';
SELECT cfg_section_count(ini_path) FROM test_ini WHERE ini_path = 'path/to/single_section.ini';
SELECT cfg_section_count(ini_path) FROM test_ini WHERE ini_path = 'path/to/multiple_sections.ini';
WITH section_counts AS (SELECT id, cfg_section_count(ini_path) AS section_count FROM test_ini) SELECT AVG(section_count) FROM section_counts;
SELECT id, cfg_section_count(ini_path) AS section_count FROM test_ini WHERE section_count > 1;
SELECT * FROM test_ini WHERE id IN (SELECT id FROM test_ini WHERE ini_path LIKE 'path/to/%');
SELECT cfg_section_count(ini_path) FROM test_ini WHERE id = (SELECT MAX(id) FROM test_ini);
SELECT ini_path, cfg_section_count(ini_path) FROM test_ini ORDER BY section_count DESC;