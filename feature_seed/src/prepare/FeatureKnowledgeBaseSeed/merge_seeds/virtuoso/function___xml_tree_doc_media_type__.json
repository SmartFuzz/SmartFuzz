CREATE TABLE example_table (id INT, xml_column XML);
INSERT INTO example_table (id, xml_column) VALUES (1, xml_tree_doc('<A />'));
INSERT INTO example_table (id, xml_column) VALUES (2, xml_tree_doc('<B />'));
CREATE FUNCTION test_function() RETURNS VARCHAR AS $$ SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_column)) FROM example_table WHERE id = 1;
$$ LANGUAGE SQL;
SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_tree_doc('<A />'))) AS media_type;
SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_tree_doc('<B />'))) AS media_type;
SELECT A.media_type FROM (SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_tree_doc('<A />'))) AS media_type) AS A;
SELECT B.media_type FROM (SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_tree_doc('<A />'))) AS media_type UNION SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_tree_doc('<B />'))) AS media_type) AS B;
WITH media_types AS (SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_column)) AS media_type FROM example_table) SELECT COUNT(*) FROM media_types WHERE media_type = 'text/plain';
SELECT COUNT(*) FROM (SELECT xml_tree_doc_media_type(xslt('file:/x.xsl', xml_tree_doc('<A />')))) AS media_types WHERE media_type IN ('text/plain', 'application/xml');