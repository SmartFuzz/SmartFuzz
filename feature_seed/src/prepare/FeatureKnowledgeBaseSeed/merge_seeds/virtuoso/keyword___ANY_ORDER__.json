CREATE TABLE big_table (id INT, some_flag INT, data VARCHAR(255));
INSERT INTO big_table (id, some_flag, data) VALUES (1, 1, 'row1'), (2, 1, 'row2'), (3, 0, 'row3'), (4, 1, 'row4');
SELECT ANY ORDER 100 * FROM big_table WHERE some_flag = 1;
SELECT ANY ORDER 10 * FROM big_table WHERE some_flag = 1 AND id > 1;
SELECT ANY ORDER 50 data FROM (SELECT id, data FROM big_table WHERE some_flag = 1) AS subquery;
SELECT ANY ORDER 3 t1.*, t2.data FROM big_table t1 JOIN big_table t2 ON t1.id = t2.id WHERE t1.some_flag = 1;
SELECT ANY ORDER 25 * FROM (SELECT id, some_flag FROM big_table WHERE some_flag = 1 ORDER BY data) AS ordered_subquery;
CREATE TABLE second_table (id INT, foreign_id INT, value VARCHAR(255));
INSERT INTO second_table (id, foreign_id, value) VALUES (1, 1, 'value1'), (2, 1, 'value2'), (3, 2, 'value3');
SELECT ANY ORDER 5 t1.*, t2.value FROM big_table t1 LEFT JOIN second_table t2 ON t1.id = t2.foreign_id WHERE t1.some_flag = 1;
SELECT ANY ORDER 100 * FROM (SELECT id FROM big_table WHERE some_flag = 1 UNION ALL SELECT id FROM second_table) AS combined_table;