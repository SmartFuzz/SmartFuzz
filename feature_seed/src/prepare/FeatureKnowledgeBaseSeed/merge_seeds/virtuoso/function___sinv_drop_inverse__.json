CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'Test Name');
CREATE INVERSE test_table_inv FOR test_table;
SELECT * FROM test_table_inv;
DROP INVERSE test_table_inv;
SELECT count(*) FROM test_table_inv;
CREATE TABLE another_table (id INT PRIMARY KEY, test_id INT REFERENCES test_table(id));
INSERT INTO another_table (id, test_id) VALUES (1, 1);
CREATE INVERSE another_table_inv FOR another_table;
SELECT a.id, b.name FROM another_table a JOIN test_table b ON a.test_id = b.id;
DROP INVERSE another_table_inv;
SELECT a.id, b.name FROM another_table a LEFT JOIN test_table b ON a.test_id = b.id WHERE b.id IS NULL;
CREATE TABLE complex_table (id INT PRIMARY KEY, desc TEXT);
INSERT INTO complex_table (id, desc) VALUES (1, 'Complex Description');
CREATE INVERSE complex_table_inv FOR complex_table;
SELECT desc FROM complex_table_inv WHERE id = (SELECT MAX(id) FROM complex_table);
DROP INVERSE complex_table_inv;
CREATE TABLE additional_table (id INT PRIMARY KEY, complex_id INT REFERENCES complex_table(id));
INSERT INTO additional_table (id, complex_id) VALUES (1, 1);
SELECT * FROM additional_table WHERE complex_id IN (SELECT id FROM complex_table WHERE desc LIKE 'Complex%');
DROP INVERSE additional_table_inv;