CREATE TABLE test_data (id INT, compressed_data BLOB);
INSERT INTO test_data (id, compressed_data) VALUES (1, gz_compress('test string 1'));
INSERT INTO test_data (id, compressed_data) VALUES (2, gz_compress('test string 2'));
INSERT INTO test_data (id, compressed_data) VALUES (3, gz_compress(repeat('a', 1000)));
INSERT INTO test_data (id, compressed_data) VALUES (4, gz_compress(repeat('b', 5000)));
INSERT INTO test_data (id, compressed_data) VALUES (5, gz_compress(''));
INSERT INTO test_data (id, compressed_data) VALUES (6, gz_compress('1234567890'));
INSERT INTO test_data (id, compressed_data) VALUES (7, gz_compress(repeat('z', 1000000)));
CREATE TABLE output_data (id INT, uncompressed_data VARCHAR(255));
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 1;
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 2;
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 3;
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 4;
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 5;
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 6;
INSERT INTO output_data (id, uncompressed_data) SELECT id, gz_uncompress(compressed_data) FROM test_data WHERE id = 7;
SELECT * FROM output_data WHERE uncompressed_data IS NOT NULL;
DELETE FROM test_data WHERE id IS NULL;
SELECT COUNT(*) FROM output_data WHERE LEN(uncompressed_data) > 0;