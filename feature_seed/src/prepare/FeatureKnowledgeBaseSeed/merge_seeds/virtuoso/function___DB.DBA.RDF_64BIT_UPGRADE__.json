BEGIN;
ALTER TABLE my_table ALTER COLUMN IRI_ID SET DATA TYPE IRI_ID_8;
CREATE TABLE my_table (id INTEGER, IRI_ID IRI_ID, data VARCHAR(255));
INSERT INTO my_table (id, IRI_ID, data) VALUES (1, 'http://example.org/iri1', 'Sample Data 1');
INSERT INTO my_table (id, IRI_ID, data) VALUES (2, 'http://example.org/iri2', 'Sample Data 2');
SELECT * FROM my_table WHERE IRI_ID = 'http://example.org/iri1';
SELECT COUNT(*) FROM my_table WHERE IRI_ID IN (SELECT IRI_ID FROM my_table WHERE data LIKE '%Data%');
CREATE INDEX idx_iri ON my_table(IRI_ID);
DROP TABLE IF EXISTS temp_table;
CREATE TEMPORARY TABLE temp_table AS SELECT * FROM my_table WHERE id < 3;
UPDATE my_table SET data = 'Updated Sample Data' WHERE id = 1;
DELETE FROM my_table WHERE IRI_ID = 'http://example.org/iri2';
CALL DB.DBA.RDF_64BIT_UPGRADE();
COMMIT;
SELECT * FROM my_table WHERE IRI_ID = 'http://example.org/iri1';