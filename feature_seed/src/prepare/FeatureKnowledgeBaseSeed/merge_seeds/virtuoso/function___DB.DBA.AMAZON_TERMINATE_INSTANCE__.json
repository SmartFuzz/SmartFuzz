CREATE TABLE instance_details (id INT PRIMARY KEY, instance_name VARCHAR(255), access_key VARCHAR(255), sec_token VARCHAR(255));
INSERT INTO instance_details (id, instance_name, access_key, sec_token) VALUES (1, 'my_instance_of_linux', 'AKIAJI7ZL427TI5EDF5A', 'CGI/UMaXf2LRUctaj/HGJ57UNy/t7fNCshh8wpJg');
CREATE PROCEDURE test_terminate_instance() { DECLARE access_key, sec_token, p_name VARCHAR;
access_key := (SELECT access_key FROM instance_details WHERE id = 1);
sec_token := (SELECT sec_token FROM instance_details WHERE id = 1);
p_name := (SELECT instance_name FROM instance_details WHERE id = 1);
DB.DBA.AMAZON_TERMINATE_INSTANCE(access_key, p_name, sec_token);
};
CALL test_terminate_instance();
