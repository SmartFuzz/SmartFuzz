CREATE TABLE test_numeric (id NUMERIC(10, 0), value NUMERIC(10, 2));
INSERT INTO test_numeric (id, value) VALUES (1, 123.45);
INSERT INTO test_numeric (id, value) VALUES (2, 9999999999.99);
INSERT INTO test_numeric (id, value) VALUES (3, -1234567890.12);
INSERT INTO test_numeric (id, value) VALUES (4, 0.01);
INSERT INTO test_numeric (id, value) VALUES (5, -0.01);
SELECT * FROM test_numeric WHERE value > 100.00;
SELECT SUM(value) FROM test_numeric WHERE id < 4;
CREATE TABLE another_table (ref_id NUMERIC(10, 0), description VARCHAR(50));
INSERT INTO another_table (ref_id, description) VALUES (1, 'A sample entry');
SELECT t1.id, t1.value, t2.description FROM test_numeric t1 JOIN another_table t2 ON t1.id = t2.ref_id WHERE t1.value < 1000.00;
SELECT MAX(value) AS max_value, MIN(value) AS min_value FROM test_numeric;
INSERT INTO test_numeric (id, value) SELECT id, AVG(value) FROM test_numeric GROUP BY id;
UPDATE test_numeric SET value = value * 1.1 WHERE value IS NOT NULL;
DELETE FROM test_numeric WHERE value < 0;
SELECT COUNT(*) FROM test_numeric WHERE value BETWEEN 100 AND 200;
SELECT id, value, ROUND(value, 1) AS rounded_value FROM test_numeric WHERE id IN (SELECT ref_id FROM another_table WHERE description LIKE 'A%');