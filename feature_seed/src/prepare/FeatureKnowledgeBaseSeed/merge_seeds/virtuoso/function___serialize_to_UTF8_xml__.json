CREATE TABLE test_xml (id INT, content NVARCHAR(500));
INSERT INTO test_xml (id, content) VALUES (1, N'<text>Sample XML with utf-8 &#128;
and &lt;
special&gt;
characters</text>');
INSERT INTO test_xml (id, content) VALUES (2, N'<text>Another entry with non-ASCII characters: &#256;
-&#511;
.</text>');
SELECT serialize_to_UTF8_xml(content) FROM test_xml WHERE id = 1;
SELECT serialize_to_UTF8_xml(content) FROM test_xml WHERE id = 2;
SELECT serialize_to_UTF8_xml(N'<root><child>Child text with special characters: &#255;
</child></root>');
SELECT serialize_to_UTF8_xml(NULL);
SELECT serialize_to_UTF8_xml(N'<element>A nested <inner>element</inner></element>');
WITH xml_data AS (SELECT N'<data>Example of a CTE with &quot;
special&quot;
characters</data>' AS xml_content) SELECT serialize_to_UTF8_xml(xml_content) FROM xml_data;
CREATE TABLE another_xml (data VARCHAR(100));
INSERT INTO another_xml (data) VALUES ('<data>Simple VARCHAR data</data>');
SELECT serialize_to_UTF8_xml(data) FROM another_xml WHERE data IS NOT NULL;
SELECT serialize_to_UTF8_xml(xtree_doc('<test>&#128;
to UTF-8 &#256;
</test>')) AS utf8_serialized;
SELECT serialize_to_UTF8_xml((SELECT content FROM test_xml WHERE id = 2)) AS utf8_from_subquery;
SELECT serialize_to_UTF8_xml((SELECT N'<item>Item with &gt;
greater than</item>')) AS utf8_from_nested_subquery;
SELECT serialize_to_UTF8_xml(CONCAT(N'<xml>', N'&#65533;
', N'</xml>'));