CREATE TABLE test_table (id INT, name VARCHAR(100), created_at TIMESTAMP);
INSERT INTO test_table (id, name, created_at) VALUES (1, 'Alice', NOW());
INSERT INTO test_table (id, name, created_at) VALUES (2, 'Bob', NOW());
SELECT http(name) FROM test_table WHERE id = 1;
SELECT http_value(name) FROM test_table WHERE id = 2;
SELECT http_url(name) FROM test_table WHERE id IN (1, 2);
SELECT http('Welcome, ' || name) FROM test_table WHERE created_at > NOW() - INTERVAL '1 DAY';
SELECT http_value(123.456) AS formatted_number;
SELECT http_url('https://example.com/search?query=test') AS escaped_url;
SELECT http_value((SELECT name FROM test_table WHERE id = 1), 'Hello, ') AS greeting;
SELECT http(name) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name LIKE 'A%') AND created_at < NOW();
SELECT http('User: ' || (SELECT name FROM test_table WHERE id = 1) || ', created ' || http(created_at)) FROM test_table WHERE id = 2;