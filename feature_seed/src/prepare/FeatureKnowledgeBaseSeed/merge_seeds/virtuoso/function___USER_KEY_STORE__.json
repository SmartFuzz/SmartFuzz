CREATE TABLE keys (user VARCHAR(255), key_name VARCHAR(255), key_type VARCHAR(50), key_value TEXT);
INSERT INTO keys (user, key_name, key_type, key_value) VALUES ('alice', 'id_rsa', 'X.509', xenc_pkcs12_export('id_rsa', 'CA Certificate', ''));
INSERT INTO keys (user, key_name, key_type, key_value) VALUES ('bob', 'id_ecdsa', 'X.509', xenc_pkcs12_export('id_ecdsa', 'CA Certificate', ''));
SELECT * FROM keys WHERE user = 'alice' AND key_name = 'id_rsa';
SELECT * FROM keys WHERE user IN (SELECT user FROM keys WHERE key_type = 'X.509') ORDER BY key_name;
UPDATE keys SET key_value = xenc_pkcs12_export('id_rsa', 'Updated Certificate', '') WHERE user = 'alice' AND key_name = 'id_rsa';
DELETE FROM keys WHERE user = 'bob' AND key_name = 'id_ecdsa';
SELECT COUNT(*) AS total_keys FROM keys WHERE user = 'alice';
INSERT INTO keys (user, key_name, key_type, key_value) SELECT 'carol', 'id_ed25519', 'X.509', xenc_pkcs12_export('id_ed25519', 'CA Certificate', '') WHERE NOT EXISTS (SELECT 1 FROM keys WHERE user = 'carol' AND key_name = 'id_ed25519');
CREATE INDEX idx_user ON keys(user);
SELECT user, COUNT(*) AS key_count FROM keys GROUP BY user HAVING key_count > 1;
WITH user_keys AS (SELECT user, key_name FROM keys WHERE key_type = 'X.509') SELECT * FROM user_keys WHERE user = 'alice';
SELECT k1.user, k1.key_name FROM keys k1 JOIN keys k2 ON k1.user = k2.user WHERE k1.key_name != k2.key_name;
INSERT INTO keys (user, key_name, key_type, key_value) VALUES ('dave', 'id_rsa', 'X.509', xenc_pkcs12_export('id_rsa', 'CA Certificate', '')) ON CONFLICT (user, key_name) DO UPDATE SET key_value = EXCLUDED.key_value;
SELECT user, STRING_AGG(key_name, ', ') AS keys FROM keys GROUP BY user ORDER BY user;