SELECT APS_ID FROM DB.DBA.SYS_ANN_PHRASE_SET WHERE APS_SIZE > 5000;
SELECT APS_ID, APS_NAME FROM DB.DBA.SYS_ANN_PHRASE_SET WHERE APS_LANG_NAME IN ('en-US', 'fr-FR');
SELECT * FROM DB.DBA.SYS_ANN_PHRASE_SET AS set1 JOIN DB.DBA.SYS_ANN_PHRASE_SET AS set2 ON set1.APS_ID = set2.APS_APC_ID WHERE set1.APS_OWNER_UID = 'user_1';
SELECT APS_ID, APS_NAME FROM DB.DBA.SYS_ANN_PHRASE_SET WHERE APS_SIZE BETWEEN 1000 AND 5000;
SELECT APS_NAME, COUNT(APS_ID) FROM DB.DBA.SYS_ANN_PHRASE_SET GROUP BY APS_NAME HAVING COUNT(APS_ID) > 1;
