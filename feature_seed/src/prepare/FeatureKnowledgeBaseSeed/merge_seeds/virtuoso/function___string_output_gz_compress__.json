CREATE PROCEDURE gz_test_empty (in fname VARCHAR) AS BEGIN DECLARE dta, res ANY;
DECLARE len INTEGER;
res := string_output();
dta := file_to_string_output(fname);
result_names(len);
result(length(dta));
result(string_output_gz_compress(dta, res));
END;
CREATE PROCEDURE gz_test_long_string (in fname VARCHAR) AS BEGIN DECLARE dta, res ANY;
DECLARE len INTEGER;
res := string_output();
dta := file_to_string_output(fname);
result_names(len);
result(length(dta));
result(string_output_gz_compress(dta, res));
END;
CREATE PROCEDURE gz_test_repeated_characters (in fname VARCHAR) AS BEGIN DECLARE dta, res ANY;
DECLARE len INTEGER;
res := string_output();
dta := file_to_string_output(fname);
result_names(len);
result(length(dta));
result(string_output_gz_compress(dta, res));
END;
CREATE PROCEDURE gz_test_combined (in fname VARCHAR) AS BEGIN DECLARE dta, dta_2, res ANY;
DECLARE len INTEGER;
res := string_output();
dta := file_to_string_output(fname);
dta_2 := string_output();
result_names(len);
result(length(dta));
result(string_output_gz_compress(dta, res));
gz_uncompress(string_output_string(res), dta_2);
IF (md5(dta) <> md5(dta_2)) SIGNAL('SNAFU', 'GZIP algorithm implementation is faulty.');
result(length(dta));
END;
CALL gz_test_empty('tmp/empty.dat');
CALL gz_test_long_string('tmp/long_string.dat');
CALL gz_test_repeated_characters('tmp/repeated.dat');
CALL gz_test_combined('tmp/combined.dat');