CREATE GRAPH <http://geo-api-demo/>;
CREATE TABLE shapes (id INT, geom GEOMETRY);
INSERT INTO shapes VALUES (1, POLYGON((0 0, 0 5, 5 5, 5 0, 0 0))),;
INSERT INTO shapes VALUES (2, POINT(1 1)),;
INSERT INTO shapes VALUES (3, LINESTRING(0 0, 5 5));
SELECT bif:st_get_bounding_box(geom) AS bounding_box, geom FROM shapes;
SELECT bif:st_get_bounding_box(geom) AS bbox, s.id FROM shapes s WHERE s.id IN (SELECT id FROM shapes WHERE id > 1) ORDER BY bbox ASC;
SELECT bif:st_get_bounding_box(geom) AS bbox, s1.geom FROM shapes s1 JOIN shapes s2 ON s1.id <> s2.id WHERE s1.id = 1;
SELECT bif:st_get_bounding_box(geom) AS bbox FROM shapes WHERE geom IS NOT NULL;
SELECT bif:st_get_bounding_box(geom) AS bbox FROM shapes GROUP BY geom HAVING COUNT(*) > 1;
SELECT bif:st_get_bounding_box(geom) AS bbox FROM shapes WHERE geom NOT IN (SELECT geom FROM shapes WHERE id = 2);
WITH BoundingBoxes AS (SELECT bif:st_get_bounding_box(geom) AS bbox FROM shapes) SELECT * FROM BoundingBoxes WHERE bbox IS NOT NULL;
SELECT bif:st_get_bounding_box(geom) AS bounding_box FROM (SELECT geom FROM shapes WHERE id = 1 UNION SELECT geom FROM shapes WHERE id = 2) AS union_shapes;