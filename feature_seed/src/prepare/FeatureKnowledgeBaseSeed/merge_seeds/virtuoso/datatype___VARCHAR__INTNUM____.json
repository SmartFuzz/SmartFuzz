CREATE TABLE TestTable (id INT, value VARCHAR(10));
INSERT INTO TestTable (id, value) VALUES (1, '12345');
INSERT INTO TestTable (id, value) VALUES (2, '67890');
INSERT INTO TestTable (id, value) VALUES (3, '00000');
INSERT INTO TestTable (id, value) VALUES (4, 'ABCDE');
INSERT INTO TestTable (id, value) VALUES (5, '1234567890');
SELECT * FROM TestTable WHERE value LIKE '123%';
SELECT * FROM TestTable WHERE value = (SELECT value FROM TestTable WHERE id = 2);
SELECT A.id, A.value FROM TestTable A JOIN TestTable B ON A.id != B.id WHERE A.value = 'ABCDE';
SELECT COUNT(*) FROM TestTable WHERE LENGTH(value) = 5;
SELECT value FROM TestTable WHERE INSTR(value, '0') > 0;
UPDATE TestTable SET value = '99999' WHERE id = 1;
SELECT id, value FROM TestTable ORDER BY LENGTH(value) DESC;
DELETE FROM TestTable WHERE value IS NULL;
CREATE TABLE AnotherTable (another_id INT, another_value VARCHAR(20));
INSERT INTO AnotherTable (another_id, another_value) VALUES (1, 'TestValue');
SELECT A.id, A.value FROM TestTable A LEFT JOIN AnotherTable B ON A.id = B.another_id WHERE B.another_value IS NULL;
SELECT * FROM TestTable WHERE value NOT LIKE '123%';
INSERT INTO TestTable (id, value) VALUES (6, '');
SELECT DISTINCT value FROM TestTable WHERE LENGTH(value) BETWEEN 1 AND 10;