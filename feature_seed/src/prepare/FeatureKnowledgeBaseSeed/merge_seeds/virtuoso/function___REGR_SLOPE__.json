CREATE TABLE sales (id INT, revenue FLOAT, cost FLOAT);
INSERT INTO sales (id, revenue, cost) VALUES (1, 100.0, 50.0);
INSERT INTO sales (id, revenue, cost) VALUES (2, 200.0, 100.0);
INSERT INTO sales (id, revenue, cost) VALUES (3, NULL, 75.0);
INSERT INTO sales (id, revenue, cost) VALUES (4, 400.0, 200.0);
INSERT INTO sales (id, revenue, cost) VALUES (5, NULL, NULL);
CREATE TABLE expenses (id INT, amount FLOAT);
INSERT INTO expenses (id, amount) VALUES (1, 20.0);
INSERT INTO expenses (id, amount) VALUES (2, 30.0);
SELECT REGR_SLOPE(revenue, cost) FROM sales;
SELECT REGR_SLOPE(revenue, cost) FROM sales WHERE revenue IS NOT NULL AND cost IS NOT NULL;
SELECT REGR_SLOPE(A.revenue, B.amount) FROM sales A JOIN expenses B ON A.id = B.id;
SELECT REGR_SLOPE(revenue, cost) FROM (SELECT revenue, cost FROM sales WHERE revenue IS NOT NULL) AS filtered_sales;
SELECT REGR_SLOPE((SELECT AVG(revenue) FROM sales), (SELECT AVG(cost) FROM sales)) AS average_slope;
WITH sales_data AS (SELECT revenue, cost FROM sales WHERE revenue IS NOT NULL AND cost IS NOT NULL) SELECT REGR_SLOPE(revenue, cost) FROM sales_data;
CREATE TABLE products (id INT, price FLOAT, category_id INT);
INSERT INTO products (id, price, category_id) VALUES (1, 15.5, 1);
INSERT INTO products (id, price, category_id) VALUES (2, 25.5, 2);
INSERT INTO products (id, price, category_id) VALUES (3, 35.5, 1);
SELECT REGR_SLOPE(A.price, B.cost) FROM products A JOIN sales B ON A.id = B.id;
SELECT REGR_SLOPE(MAX(revenue), MIN(cost)) FROM sales WHERE revenue IS NOT NULL AND cost IS NOT NULL;