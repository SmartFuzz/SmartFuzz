CREATE TABLE XMLData (id INT PRIMARY KEY, xml_content XML);
INSERT INTO XMLData (id, xml_content) VALUES (1, XML('<root><child>Example</child></root>'));
INSERT INTO XMLData (id, xml_content) VALUES (2, XML('<root><child>Example2</child></root>'));
SELECT xml_content FROM XMLData WHERE id = 1;
SELECT x.xml_content FROM XMLData x INNER JOIN XMLData y ON x.id = y.id WHERE y.id = 2;
UPDATE XMLData SET xml_content = XML('<root><child>UpdatedExample</child></root>') WHERE id = 1;
SELECT id, xml_content FROM XMLData WHERE xml_content IS NOT NULL;
DELETE FROM XMLData WHERE id = 2;
SELECT COUNT(*) FROM XMLData WHERE xml_content IS NOT NULL;
CREATE PROCEDURE setValidated(id INT) AS BEGIN UPDATE XMLData SET schemaValidated = 1 WHERE id = id;
END;
EXEC setValidated(1);
CALL setValidated(2);
SELECT schemaValidated FROM XMLData WHERE id = 1;
UPDATE XMLData SET schemaValidated = 0 WHERE id = 1;
SELECT schemaValidated FROM XMLData WHERE id = 1;
SELECT * FROM (SELECT xml_content FROM XMLData WHERE id = 1) AS subquery;
SELECT x.xml_content, y.xml_content FROM (SELECT xml_content FROM XMLData WHERE id = 1) x, (SELECT xml_content FROM XMLData WHERE id = 2) y;
CREATE TABLE XMLSchema (schema_id INT PRIMARY KEY, schema_definition XML);
INSERT INTO XMLSchema (schema_id, schema_definition) VALUES (1, XML('<schema><element name="child" type="string" /></schema>'));
UPDATE XMLData SET xml_content = XML('<root><child>ModifiedExample</child></root>') WHERE id = 1 AND schemaValidated = 1;