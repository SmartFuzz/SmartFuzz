CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(255), value INTEGER);
INSERT INTO test_table (name, value) VALUES ('example1', 10);
INSERT INTO test_table (name, value) VALUES ('example2', 20);
INSERT INTO test_table (name, value) VALUES ('example3', 15);
SELECT * FROM test_table WHERE value > (SELECT AVG(value) FROM test_table);
SELECT t1.name, t2.value FROM test_table t1 JOIN test_table t2 ON t1.value = t2.value WHERE t1.id != t2.id;
SELECT t1.name, (SELECT COUNT(*) FROM test_table t2 WHERE t2.value > t1.value) AS greater_count FROM test_table t1;
WITH temp AS (SELECT id, name, value FROM test_table WHERE value > 10) SELECT * FROM temp;
DELETE FROM test_table WHERE id = (SELECT id FROM test_table WHERE name = 'example3');
CREATE TABLE another_table (id INTEGER PRIMARY KEY, test_id INTEGER, description VARCHAR(255), FOREIGN KEY(test_id) REFERENCES test_table(id));
INSERT INTO another_table (test_id, description) VALUES (1, 'Test Description 1');
INSERT INTO another_table (test_id, description) VALUES (2, 'Test Description 2');
SELECT a.description FROM another_table a JOIN test_table t ON a.test_id = t.id WHERE t.value < 20;
UPDATE test_table SET value = value * 2 WHERE name = 'example1';
SELECT t.name, (SELECT COUNT(*) FROM another_table a WHERE a.test_id = t.id) AS related_records FROM test_table t;
DROP TABLE another_table;
DROP TABLE test_table;