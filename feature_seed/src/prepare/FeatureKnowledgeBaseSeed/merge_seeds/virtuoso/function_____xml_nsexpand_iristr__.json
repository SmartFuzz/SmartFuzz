CREATE TABLE namespaces (prefix VARCHAR(255), iri VARCHAR(255));
INSERT INTO namespaces (prefix, iri) VALUES ('foaf', 'http://xmlns.com/foaf/0.1/');
INSERT INTO namespaces (prefix, iri) VALUES ('rdf', 'http://www.w3.org/1999/02/22-rdf-syntax-ns#');
SELECT __xml_nsexpand_iristr('foaf:knows');
SELECT __xml_nsexpand_iristr('rdf:type');
SELECT __xml_nsexpand_iristr('no-namespace-prefix-iri');
SELECT __xml_nsexpand_iristr('no-such-prefix:local');
SELECT __xml_nsexpand_iristr('rdf:subject');
SELECT __xml_nsexpand_iristr('foaf:mbox');
SELECT __xml_nsexpand_iristr((SELECT CONCAT(prefix, ':', 'knows') FROM namespaces WHERE prefix = 'foaf'));
SELECT __xml_nsexpand_iristr(CONCAT('rdf:', 'type'));
SELECT __xml_nsexpand_iristr('no-such-prefix:local') WHERE EXISTS (SELECT 1 FROM namespaces WHERE prefix = 'no-such-prefix');
SELECT __xml_nsexpand_iristr('foaf:mbox') UNION SELECT __xml_nsexpand_iristr('foaf:homepage');
SELECT __xml_nsexpand_iristr('foaf:knows') AND __xml_nsexpand_iristr('rdf:type');
SELECT __xml_nsexpand_iristr((SELECT prefix || ':knows' FROM namespaces WHERE prefix = 'foaf')) AS full_iri;
SELECT __xml_nsexpand_iristr('no-such-prefix:local') INTERSECT SELECT __xml_nsexpand_iristr('rdf:type');