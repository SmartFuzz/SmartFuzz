CREATE TABLE points (id INT, x FLOAT, y FLOAT);
CREATE TABLE segments (id INT, x1 FLOAT, y1 FLOAT, x2 FLOAT, y2 FLOAT);
INSERT INTO points (id, x, y) VALUES (1, 5, 5);
INSERT INTO points (id, x, y) VALUES (2, 5, 0);
INSERT INTO points (id, x, y) VALUES (3, 5, -1);
INSERT INTO points (id, x, y) VALUES (4, 5, -5);
INSERT INTO segments (id, x1, y1, x2, y2) VALUES (1, 0, 3, 4, 0);
INSERT INTO segments (id, x1, y1, x2, y2) VALUES (2, 1, 1, 3, 1);
INSERT INTO segments (id, x1, y1, x2, y2) VALUES (3, 0, 0, 0, 4);
SELECT dist_from_point_to_line_segment(x, y, x1, y1, x2, y2) FROM points JOIN segments ON points.id = 1;
SELECT dist_from_point_to_line_segment(x, y, x1, y1, x2, y2) FROM points JOIN segments ON points.id = 2;
SELECT dist_from_point_to_line_segment(5, 5, 0, 3, 4, 0) AS distance1, dist_from_point_to_line_segment(5, 0, 0, 3, 4, 0) AS distance2;
SELECT segment.id, dist_from_point_to_line_segment(p.x, p.y, s.x1, s.y1, s.x2, s.y2) AS distance FROM points p, segments s WHERE p.x = 5 AND p.y = 5;
SELECT (SELECT dist_from_point_to_line_segment(p.x, p.y, s.x1, s.y1, s.x2, s.y2) FROM points p JOIN segments s WHERE p.id = 1) AS distance1, (SELECT dist_from_point_to_line_segment(p.x, p.y, s.x1, s.y1, s.x2, s.y2) FROM points p JOIN segments s WHERE p.id = 3) AS distance2;
SELECT dist_from_point_to_line_segment(10, 10, 0, 0, 5, 5);
SELECT dist_from_point_to_line_segment(-5, -5, 0, 0, 5, 5);
SELECT DISTINCT dist_from_point_to_line_segment(p.x, p.y, s.x1, s.y1, s.x2, s.y2) FROM points p CROSS JOIN segments s;
SELECT COUNT(*) FROM (SELECT dist_from_point_to_line_segment(p.x, p.y, s.x1, s.y1, s.x2, s.y2) FROM points p JOIN segments s) AS distances WHERE distances < 5;