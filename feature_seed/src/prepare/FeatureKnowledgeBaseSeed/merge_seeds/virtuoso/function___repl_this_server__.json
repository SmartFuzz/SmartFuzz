CREATE TABLE servers (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO servers (id, name) VALUES (1, 'demo-srv');
INSERT INTO servers (id, name) VALUES (2, 'test-srv');
INSERT INTO servers (id, name) VALUES (3, 'prod-srv');
SELECT repl_this_server();
SELECT name FROM servers WHERE id = (SELECT id FROM servers LIMIT 1);
SELECT COUNT(*) FROM servers WHERE name = (SELECT repl_this_server());
SELECT s1.name FROM servers s1 INNER JOIN (SELECT repl_this_server() AS calling_server) s2 ON s1.name = s2.calling_server;
SELECT CASE WHEN repl_this_server() IS NOT NULL THEN 'Server Exists' ELSE 'Server Not Found' END;
WITH server_info AS (SELECT name FROM servers) SELECT repl_this_server() FROM server_info WHERE name LIKE 'demo%';
SELECT repl_this_server() AS current_server, (SELECT COUNT(*) FROM servers) AS total_servers;
SELECT name FROM servers WHERE id IN (SELECT id FROM servers WHERE name = 'demo-srv');
SELECT CONCAT('Current Server: ', repl_this_server()) AS server_status;