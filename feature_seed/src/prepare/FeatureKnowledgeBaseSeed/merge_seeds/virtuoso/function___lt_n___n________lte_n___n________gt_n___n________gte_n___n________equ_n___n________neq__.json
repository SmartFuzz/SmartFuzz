CREATE TABLE test_table (id INT, value1 FLOAT, value2 FLOAT);
INSERT INTO test_table (id, value1, value2) VALUES (1, 10, 20);
INSERT INTO test_table (id, value1, value2) VALUES (2, 15, 15);
INSERT INTO test_table (id, value1, value2) VALUES (3, 25, 10);
SELECT lt(value1, value2) FROM test_table WHERE id = 1;
SELECT lte(value1, value2) FROM test_table WHERE id = 2;
SELECT gt(value1, value2) FROM test_table WHERE id = 3;
SELECT gte(value1, value2) FROM (SELECT value1, value2 FROM test_table WHERE id = 1) AS subquery;
SELECT equ(value1, value2) FROM test_table WHERE id = 2;
SELECT neq(value1, value2) FROM test_table WHERE id = 3;
SELECT lt(atof('10.0'), 10) FROM test_table;
SELECT gte(NULL, 1234) FROM test_table;
SELECT lt(value1, (SELECT value2 FROM test_table WHERE id = 1)) FROM test_table WHERE id = 2;
SELECT equ(17, 17.0) FROM test_table WHERE id = 1;
SELECT neq((SELECT value1 FROM test_table WHERE id = 3), 25);
SELECT gte(atof('17.1'), 17.1) FROM test_table WHERE id = 1;
SELECT lt(1234, NULL) FROM test_table;
SELECT neq(NULL, NULL) FROM test_table;