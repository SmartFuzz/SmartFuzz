CREATE TABLE sequences (name VARCHAR(255), state VARCHAR(255));
INSERT INTO sequences VALUES ('sequence1', 'active');
INSERT INTO sequences VALUES ('sequence2', 'inactive');
INSERT INTO sequences VALUES ('sequence3', 'paused');
INSERT INTO sequences VALUES ('sequence4', 'active');
SELECT name, state FROM sequences WHERE state = 'active';
SELECT name, state FROM sequences WHERE state IN (SELECT DISTINCT state FROM sequences);
SELECT s1.name, s1.state FROM sequences s1 JOIN sequences s2 ON s1.state = s2.state WHERE s1.name <> s2.name;
SELECT name, state FROM sequences ORDER BY RANDOM() LIMIT 5;
SELECT name, state FROM (SELECT name, state FROM sequences WHERE state = 'active') AS active_sequences;
WITH sequence_states AS (SELECT name, state FROM sequences) SELECT * FROM sequence_states WHERE state LIKE 'p%';
SELECT COUNT(*) FROM sequences WHERE state = 'inactive';
SELECT name FROM sequences WHERE LENGTH(name) > 10;
SELECT name, state FROM sequences WHERE name IN (SELECT name FROM sequences WHERE state = 'paused') ORDER BY name DESC;
SELECT ss1.name, ss2.state FROM sequences ss1 CROSS JOIN sequences ss2 WHERE ss1.state <> ss2.state;
DELETE FROM sequences WHERE state = 'inactive';
TRUNCATE TABLE sequences;
INSERT INTO sequences (name, state) VALUES ('sequence5', NULL);
SELECT name, COALESCE(state, 'unknown') AS state FROM sequences;
SELECT name, state FROM sequences UNION SELECT 'nonExistent', 'unknown' WHERE NOT EXISTS (SELECT 1 FROM sequences WHERE name = 'nonExistent');