CREATE TABLE test_words (word VARCHAR(100));
INSERT INTO test_words (word) VALUES ('a'), ('effective'), ('the'), ('is'), ('sample'), ('noise'), ('', 'UTF-8', 'X-ANY');
SELECT vt_is_noise(word, 'UTF-8', 'X-ANY') FROM test_words WHERE LENGTH(word) < 2;
SELECT vt_is_noise(word, 'UTF-8', 'X-ANY') FROM test_words WHERE word IN (SELECT word FROM test_words WHERE LENGTH(word) = 0);
SELECT word, vt_is_noise(word, 'UTF-8', 'X-ANY') AS is_noise FROM (SELECT DISTINCT word FROM test_words WHERE word IS NOT NULL) AS unique_words;
SELECT vt_is_noise('the', 'UTF-8', 'X-ANY') AS result FROM dual UNION SELECT vt_is_noise('sample', 'UTF-8', 'X-ANY') AS result FROM dual;
WITH noise_candidates AS (SELECT word FROM test_words WHERE LENGTH(word) > 3) SELECT word, vt_is_noise(word, 'UTF-8', 'X-ANY') FROM noise_candidates;
SELECT DISTINCT vt_is_noise(word, 'UTF-8', 'X-ANY') FROM (SELECT word FROM test_words WHERE word LIKE '%a%') AS filtered_words;
SELECT vt_is_noise(word, 'UTF-8', 'X-ANY') FROM test_words WHERE EXISTS (SELECT 1 FROM test_words WHERE word = 'noise' AND LENGTH(word) > 3);
SELECT vt_is_noise(word, 'UTF-8', 'X-ANY') FROM test_words WHERE word NOT IN (SELECT word FROM test_words WHERE LENGTH(word) = 1) LIMIT 10;