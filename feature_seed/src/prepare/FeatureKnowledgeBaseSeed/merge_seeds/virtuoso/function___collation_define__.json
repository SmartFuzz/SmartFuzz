CREATE TABLE test_collation (id INT PRIMARY KEY, name VARCHAR(255));
INSERT INTO test_collation (id, name) VALUES (1, 'a'), (2, 'b'), (3, 'A');
CREATE COLLATION custom_collation AS 'COLLATE utf8_general_ci';
SELECT * FROM test_collation ORDER BY name COLLATE custom_collation;
CREATE FUNCTION use_collation() RETURNS TABLE(id INT, name VARCHAR(255)) AS 'SELECT id, name FROM test_collation ORDER BY name COLLATE custom_collation;
' LANGUAGE SQL;
CREATE TABLE another_table (value VARCHAR(255));
INSERT INTO another_table (value) VALUES ('c'), ('C'), ('d');
SELECT * FROM another_table ORDER BY value COLLATE custom_collation;
SELECT a.id, a.name FROM test_collation a JOIN another_table b ON a.name = b.value COLLATE custom_collation;
CREATE COLLATION another_collation AS 'COLLATE utf8_bin';
SELECT * FROM test_collation WHERE name COLLATE another_collation = 'a';
SELECT COUNT(*) FROM test_collation WHERE name COLLATE custom_collation IN (SELECT value FROM another_table);
INSERT INTO test_collation (id, name) VALUES (4, 'e'), (5, 'E');
SELECT * FROM test_collation WHERE name COLLATE custom_collation LIKE 'e%';
SELECT * FROM (SELECT id, name FROM test_collation WHERE id > 1) AS subquery ORDER BY name COLLATE custom_collation;
DROP COLLATION custom_collation;
DROP COLLATION another_collation;