CREATE TABLE test_table (id INT, arg1 VARCHAR(100), arg2 VARCHAR(100));
CREATE PROCEDURE test_proc_1 () { log_text ('INSERT INTO test_table (id, arg1) VALUES (?, ?)', 1, 'value1');
};
CREATE PROCEDURE test_proc_2 () { log_text ('UPDATE test_table SET arg1 = ? WHERE id = ?', 'updated_value', 1);
};
CREATE PROCEDURE test_proc_3 () { log_text ('DELETE FROM test_table WHERE id = ?', 2);
};
CREATE PROCEDURE test_proc_4 () { log_text ('SELECT * FROM test_table WHERE arg1 = ? AND arg2 = ?', 'value1', 'value2');
};
CREATE PROCEDURE test_proc_5 () { log_text ('INSERT INTO test_table (id, arg1, arg2) VALUES (?, ?, ?)', 3, 'value3', 'value4');
};
CREATE PROCEDURE test_proc_6 () { log_text ('INSERT INTO test_table (id, arg1) VALUES (?, ?);
log_text (''SELECT * FROM test_table WHERE id = ?'', ?)', 4, 'value5', 4, 4);
};
CREATE TABLE another_table (key_id INT, foreign_key_id INT);
CREATE PROCEDURE test_proc_7 () { log_text ('INSERT INTO another_table (key_id, foreign_key_id) SELECT t.id, ? FROM test_table t WHERE t.arg1 = ?', 5, 'value1');
};
CREATE PROCEDURE test_proc_8 () { log_text ('SELECT t1.id, t2.arg1 FROM test_table t1 JOIN another_table t2 ON t1.id = t2.foreign_key_id WHERE t1.arg2 = ?', 'value2');
};
CREATE PROCEDURE test_proc_9 () { log_text ('INSERT INTO test_table (id, arg1) SELECT MAX(key_id), ''new_value'' FROM another_table');
};