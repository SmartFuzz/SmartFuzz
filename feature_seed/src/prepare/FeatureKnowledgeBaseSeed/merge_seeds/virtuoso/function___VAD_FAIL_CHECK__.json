CREATE TABLE test_table1 (id INTEGER PRIMARY KEY, value VARCHAR(255));
CREATE TABLE test_table2 (id INTEGER PRIMARY KEY, ref_id INTEGER, FOREIGN KEY (ref_id) REFERENCES test_table1(id));
INSERT INTO test_table1 (id, value) VALUES (1, 'test1');
INSERT INTO test_table1 (id, value) VALUES (2, 'test2');
INSERT INTO test_table2 (id, ref_id) VALUES (1, 1);
INSERT INTO test_table2 (id, ref_id) VALUES (2, 2);
SELECT * FROM test_table1 WHERE id = (SELECT MAX(id) FROM test_table1);
SELECT t1.value FROM test_table1 t1 INNER JOIN test_table2 t2 ON t1.id = t2.ref_id WHERE t2.id = 1;
SELECT COUNT(*) FROM test_table2 WHERE ref_id IN (SELECT id FROM test_table1 WHERE value LIKE 'test%');
DELETE FROM test_table2 WHERE id = (SELECT t2.id FROM test_table2 t2 WHERE ref_id = (SELECT id FROM test_table1 WHERE value = 'test1') LIMIT 1);
UPDATE test_table1 SET value = 'updated_value' WHERE id = (SELECT id FROM test_table1 WHERE value = 'test2');
SELECT value FROM test_table1 WHERE id NOT IN (SELECT ref_id FROM test_table2);
SELECT EXISTS (SELECT 1 FROM test_table1 WHERE value = 'non_existing_value');
SELECT t1.value FROM test_table1 t1 LEFT JOIN test_table2 t2 ON t1.id = t2.ref_id WHERE t2.ref_id IS NULL;
DROP TABLE IF EXISTS test_table2;
DROP TABLE IF EXISTS test_table1;