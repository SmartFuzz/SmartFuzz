CREATE TABLE test_iri_split (iri VARCHAR(255), prefix VARCHAR(255), local_part VARCHAR(255));
INSERT INTO test_iri_split (iri) VALUES ('http://example.com/ns#localPart1');
INSERT INTO test_iri_split (iri) VALUES ('http://example.org/ns#localPart2');
INSERT INTO test_iri_split (iri) VALUES ('https://data.example.com/namespace#part3');
SELECT iri_split(iri) AS (prefix, local_part) FROM test_iri_split WHERE iri IS NOT NULL;
SELECT iri_split(iri, local_part) FROM test_iri_split WHERE prefix IS NOT NULL;
SELECT * FROM (SELECT iri, iri_split(iri) AS (prefix, local_part) FROM test_iri_split) AS split_results WHERE prefix = 'http://example.com/ns';
WITH temp AS (SELECT iri, iri_split(iri) AS (prefix, local_part) FROM test_iri_split) SELECT prefix, COUNT(*) FROM temp GROUP BY prefix;
SELECT DISTINCT prefix FROM (SELECT iri, iri_split(iri) AS (prefix, local_part) FROM test_iri_split WHERE local_part IS NOT NULL) AS split_results;
CREATE TABLE additional_data (some_id INT, iri_data VARCHAR(255));
INSERT INTO additional_data (some_id, iri_data) VALUES (1, 'http://example.com/ns#localPart1'), (2, 'http://example.org/ns#localPart2');
SELECT a.some_id, iri_split(a.iri_data) AS (prefix, local_part) FROM additional_data a JOIN test_iri_split b ON a.iri_data = b.iri;
SELECT b.prefix, COUNT(*) FROM additional_data a JOIN test_iri_split b ON a.iri_data = b.iri GROUP BY b.prefix;
SELECT iri_split('http://example.com/#') AS (prefix, local_part);
SELECT iri_split('urn:example:namespace') AS (prefix, local_part);
SELECT iri_split('mailto:user@example.com') AS (prefix, local_part);
SELECT iri_split('ftp://ftp.example.com/path/to/resource') AS (prefix, local_part);