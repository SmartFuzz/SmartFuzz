CREATE TABLE Users (ID INT PRIMARY KEY, Name VARCHAR(100), Email VARCHAR(100), CreatedAt TIMESTAMP);
CREATE TABLE Tokens (TokenID INT PRIMARY KEY, UserID INT, Token VARCHAR(255), ExpiresAt TIMESTAMP, FOREIGN KEY (UserID) REFERENCES Users(ID));
INSERT INTO Users (ID, Name, Email, CreatedAt) VALUES (1, 'Alice', 'alice@example.com', NOW());
INSERT INTO Users (ID, Name, Email, CreatedAt) VALUES (2, 'Bob', 'bob@example.com', NOW());
INSERT INTO Tokens (TokenID, UserID, Token, ExpiresAt) VALUES (1, 1, 'abc123', NOW() + INTERVAL '1 hour');
INSERT INTO Tokens (TokenID, UserID, Token, ExpiresAt) VALUES (2, 2, 'def456', NOW() + INTERVAL '1 hour');
SELECT * FROM Users WHERE ID IN (SELECT UserID FROM Tokens WHERE ExpiresAt > NOW());
SELECT U.Name, T.Token FROM Users U JOIN Tokens T ON U.ID = T.UserID WHERE T.ExpiresAt > NOW();
SELECT U.Name, (SELECT COUNT(*) FROM Tokens T WHERE T.UserID = U.ID) AS TokenCount FROM Users U;
UPDATE Tokens SET ExpiresAt = NOW() + INTERVAL '2 hours' WHERE TokenID = 1;
DELETE FROM Tokens WHERE TokenID = (SELECT TokenID FROM Tokens WHERE UserID = 2 LIMIT 1);
CREATE INDEX idx_user_email ON Users (Email);
SELECT U.Name, T.Token FROM Users U LEFT JOIN Tokens T ON U.ID = T.UserID WHERE T.Token IS NULL;
SELECT UserID, COUNT(TokenID) AS TokenNumber FROM Tokens GROUP BY UserID HAVING COUNT(TokenID) > 1;
SELECT U.Name FROM Users U WHERE EXISTS (SELECT 1 FROM Tokens T WHERE T.UserID = U.ID AND T.ExpiresAt > NOW());
CREATE TABLE AuditLog (LogID INT PRIMARY KEY, UserID INT, Action VARCHAR(255), LogTime TIMESTAMP, FOREIGN KEY (UserID) REFERENCES Users(ID));
INSERT INTO AuditLog (LogID, UserID, Action, LogTime) SELECT ROW_NUMBER() OVER (), U.ID, 'TokenRequested', NOW() FROM Users U;
SELECT U.Name, COUNT(AL.Action) FROM Users U LEFT JOIN AuditLog AL ON U.ID = AL.UserID GROUP BY U.Name;
DELETE FROM Users WHERE ID NOT IN (SELECT DISTINCT UserID FROM Tokens);