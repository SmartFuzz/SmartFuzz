SELECT DISTINCT (bif:st_astext(geometry)) FROM geodata WHERE id < 5;
SELECT DISTINCT (bif:st_astext(geometry)) FROM geodata WHERE id IN (SELECT id FROM geodata WHERE id > 5);
SELECT g1.id, bif:st_astext(g1.geometry) AS geometry_wkt FROM geodata g1 JOIN geodata g2 ON g1.id < g2.id;
SELECT bif:st_astext(geometry) FROM geodata WHERE geometry IS NOT NULL;
SELECT DISTINCT (bif:st_astext(geometry)), COUNT(*) FROM geodata GROUP BY geometry;
SELECT bif:st_astext(geometry) FROM geodata WHERE geometry = (SELECT geometry FROM geodata WHERE id = 5);
SELECT bif:st_astext(geo.geometry) FROM (SELECT geometry FROM geodata WHERE id = 1) AS geo;