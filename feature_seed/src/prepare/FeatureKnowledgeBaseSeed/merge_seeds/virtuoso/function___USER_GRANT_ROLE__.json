CREATE ROLE role_admin;
CREATE ROLE role_user;
CREATE USER user1 IDENTIFIED BY 'password1';
CREATE USER user2 IDENTIFIED BY 'password2';
GRANT role_admin TO user1;
GRANT role_user TO user2;
GRANT role_user TO role_admin;
GRANT role_admin TO (SELECT user_name FROM users WHERE user_id = 1);
GRANT role_user TO (SELECT user_name FROM users WHERE user_id IN (SELECT user_id FROM user_roles WHERE role_name = 'role_admin'));
GRANT role_admin TO (SELECT u.user_name FROM users u JOIN user_roles ur ON u.user_id = ur.user_id WHERE ur.role_name = 'role_user' AND u.is_active = 1);
GRANT (SELECT role_name FROM roles WHERE role_level > 1) TO user1;
GRANT role_user TO user1 WHERE user1.user_id = (SELECT user_id FROM users WHERE user_name = 'user1');
GRANT role_user TO (SELECT user_id FROM users WHERE user_name LIKE 'user%') WHERE user_id NOT IN (SELECT user_id FROM user_roles WHERE role_name = 'role_admin');