CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table (id, value) VALUES (1, 10);
INSERT INTO test_table (id, value) VALUES (2, 20);
INSERT INTO test_table (id, value) VALUES (3, 10);
SELECT * FROM test_table WHERE value != 20;
SELECT * FROM test_table WHERE value != (SELECT MAX(value) FROM test_table);
CREATE TABLE test_table_2 (id INT, description VARCHAR(100));
INSERT INTO test_table_2 (id, description) VALUES (1, 'Test A');
INSERT INTO test_table_2 (id, description) VALUES (2, 'Test B');
SELECT t1.id, t2.description FROM test_table t1 INNER JOIN test_table_2 t2 ON t1.id != t2.id;
SELECT * FROM test_table WHERE id NOT IN (SELECT id FROM test_table_2 WHERE description != 'Test B');
SELECT COUNT(*) FROM test_table WHERE value != 10 AND id != 1;
SELECT id FROM test_table WHERE EXISTS (SELECT 1 FROM test_table_2 WHERE test_table.value != test_table_2.id);
CREATE TABLE test_table_3 (id INT, status BOOL);
INSERT INTO test_table_3 (id, status) VALUES (1, TRUE);
INSERT INTO test_table_3 (id, status) VALUES (2, FALSE);
SELECT id FROM test_table_3 WHERE status != TRUE;
SELECT * FROM test_table t1 WHERE EXISTS (SELECT * FROM test_table_3 t2 WHERE t1.value != t2.id);
SELECT MAX(value) FROM test_table WHERE value != (SELECT MIN(value) FROM test_table);