CREATE TABLE test_char (id INT, char_value CHAR(5));
INSERT INTO test_char (id, char_value) VALUES (1, 'A');
INSERT INTO test_char (id, char_value) VALUES (2, 'AB');
INSERT INTO test_char (id, char_value) VALUES (3, 'ABC');
INSERT INTO test_char (id, char_value) VALUES (4, 'ABCD');
INSERT INTO test_char (id, char_value) VALUES (5, 'ABCDE');
INSERT INTO test_char (id, char_value) VALUES (6, '');
INSERT INTO test_char (id, char_value) VALUES (7, 'ABCDE');
INSERT INTO test_char (id, char_value) VALUES (8, 'ABCDEF');
SELECT * FROM test_char WHERE char_value = 'A';
SELECT * FROM test_char WHERE char_value LIKE 'AB%';
SELECT id, char_value FROM test_char WHERE LENGTH(char_value) > 3;
SELECT id, char_value FROM test_char WHERE char_value IN ('A', 'AB');
CREATE TABLE test_char_join (id INT, char_value CHAR(5));
INSERT INTO test_char_join (id, char_value) VALUES (10, 'XY');
SELECT a.id, a.char_value FROM test_char a JOIN test_char_join b ON a.id = b.id WHERE a.char_value = 'A';
SELECT a.id, COUNT(b.id) FROM test_char a LEFT JOIN test_char_join b ON a.id = b.id GROUP BY a.id HAVING COUNT(b.id) > 0;
SELECT MAX(LENGTH(char_value)) FROM test_char;
SELECT id, char_value FROM test_char WHERE char_value NOT LIKE '%C%';
CREATE TABLE test_char_complex (id INT, char_value CHAR(5));
INSERT INTO test_char_complex (id, char_value) SELECT id, char_value FROM test_char WHERE LENGTH(char_value) = 5;
SELECT a.id, a.char_value FROM test_char a WHERE EXISTS (SELECT 1 FROM test_char_complex b WHERE b.char_value = a.char_value);
SELECT a.id, 'Matching: ' || a.char_value FROM test_char a WHERE a.char_value IN (SELECT char_value FROM test_char_complex WHERE id < 5);