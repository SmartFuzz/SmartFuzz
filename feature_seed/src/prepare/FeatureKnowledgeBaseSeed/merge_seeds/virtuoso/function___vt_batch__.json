CREATE TABLE test_documents (id VARCHAR(255), content TEXT);
CREATE TEXT INDEX idx_content ON test_documents(content);
INSERT INTO test_documents (id, content) VALUES ('doc1', 'This is a test document.');
INSERT INTO test_documents (id, content) VALUES ('doc2', 'Another test document with more content.');
BEGIN;
DECLARE vt_batch_object AS vt_batch;
vt_batch_object := vt_batch();
CALL vt_batch_d_id(vt_batch_object, 'doc1');
CALL vt_batch_feed(vt_batch_object, 'test document');
CALL vt_batch_feed(vt_batch_object, 'document');
CALL VT_BATCH_PROCESS_test_documents_content(vt_batch_object);
COMMIT;
SELECT id FROM test_documents WHERE content CONTAINS 'test' OR content CONTAINS 'document';
SELECT d.id FROM test_documents d JOIN (SELECT 'doc1' AS doc_id) sub ON d.id = sub.doc_id;
SELECT d.id FROM test_documents d WHERE EXISTS (SELECT 1 FROM test_documents d2 WHERE d2.id = d.id AND d2.content CONTAINS 'test');
SET @batch = vt_batch();
CALL vt_batch_d_id(@batch, 'doc2');
CALL vt_batch_feed(@batch, 'content');
CALL VT_BATCH_PROCESS_test_documents_content(@batch);
CREATE TABLE additional_data (data_id VARCHAR(255), related_content TEXT);
INSERT INTO additional_data (data_id, related_content) VALUES ('data1', 'Related content for document one.');
SELECT d.id FROM test_documents d LEFT JOIN additional_data a ON d.id = a.data_id WHERE a.related_content IS NOT NULL;
SELECT d.id FROM test_documents d WHERE d.id NOT IN (SELECT data_id FROM additional_data);