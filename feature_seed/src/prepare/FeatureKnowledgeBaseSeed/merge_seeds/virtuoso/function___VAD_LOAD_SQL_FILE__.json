CREATE TABLE test_table (id INT PRIMARY KEY, name VARCHAR(100), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
INSERT INTO test_table (id, name) VALUES (2, 'Bob');
CREATE TABLE related_table (parent_id INT, child_name VARCHAR(100), FOREIGN KEY (parent_id) REFERENCES test_table(id));
INSERT INTO related_table (parent_id, child_name) VALUES (1, 'Child A');
INSERT INTO related_table (parent_id, child_name) VALUES (1, 'Child B');
INSERT INTO related_table (parent_id, child_name) VALUES (2, 'Child C');
SELECT name, (SELECT COUNT(*) FROM related_table WHERE parent_id = test_table.id) AS child_count FROM test_table;
UPDATE test_table SET name = 'Alice Updated' WHERE id = 1;
DELETE FROM related_table WHERE child_name = 'Child A';
SELECT id, name FROM test_table WHERE id IN (SELECT parent_id FROM related_table);
CREATE INDEX idx_name ON test_table(name);
SELECT t1.name, t2.child_name FROM test_table t1 JOIN related_table t2 ON t1.id = t2.parent_id WHERE t1.name LIKE 'A%';
UPDATE related_table SET child_name = 'Updated Child B' WHERE parent_id = 1 AND child_name = 'Child B';
CREATE VIEW test_view AS SELECT name, (SELECT COUNT(*) FROM related_table WHERE parent_id = test_table.id) AS child_count FROM test_table;
SELECT * FROM test_view WHERE child_count > 0;
DROP VIEW test_view;
DROP TABLE related_table;
DROP TABLE test_table;