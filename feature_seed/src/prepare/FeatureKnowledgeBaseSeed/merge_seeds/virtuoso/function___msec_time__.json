CREATE PROCEDURE measure_execution_time(in n integer) { DECLARE t, result integer;
t := msec_time();
result := fib(n);
RETURN result;
};
CREATE TABLE performance_logs (id integer PRIMARY KEY, operation varchar, duration integer, created_at timestamp);
INSERT INTO performance_logs (operation, duration, created_at) VALUES ('fib(10)', (SELECT msec_time() FROM performance_logs LIMIT 1), CURRENT_TIMESTAMP);
CREATE PROCEDURE log_execution_time(in n integer) { DECLARE t integer;
t := msec_time();
CALL measure_execution_time(n);
INSERT INTO performance_logs (operation, duration, created_at) VALUES (sprintf('fib(%d)', n), msec_time() - t, CURRENT_TIMESTAMP);
};
CREATE PROCEDURE time_fib_with_logs(in n integer) { DECLARE msg varchar;
result_names(msg);
CALL log_execution_time(n);
result(sprintf('fib(%d) executed with msec_time logging.', n));
};
SELECT id, operation, duration FROM performance_logs WHERE duration > (SELECT AVG(duration) FROM performance_logs) ORDER BY duration DESC;
CREATE TABLE test_results (test_id integer PRIMARY KEY, test_name varchar, execution_time integer);
INSERT INTO test_results (test_id, test_name, execution_time) VALUES (1, 'Test fib(5)', (SELECT msec_time() FROM performance_logs WHERE operation = 'fib(5)' LIMIT 1));
WITH RECURSIVE fib_sequence AS (SELECT 1 AS value UNION ALL SELECT value + (SELECT value FROM fib_sequence LIMIT 1 OFFSET 1) FROM fib_sequence LIMIT 10) SELECT msec_time(), SUM(value) FROM fib_sequence;
CREATE VIEW long_running_tests AS SELECT operation, duration FROM performance_logs WHERE duration > 100;