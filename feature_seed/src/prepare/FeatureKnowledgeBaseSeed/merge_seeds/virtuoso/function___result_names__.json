CREATE TABLE test_table_1 (id INT, name VARCHAR(255));
CREATE TABLE test_table_2 (id INT, age INT, address VARCHAR(255));
result_names('id', 'name', 'age');
result(1, 'Alice', 30);
result(2, 'Bob', 25);
end_results();
result_names('id', 'address');
result(1, '123 Main St');
result(2, '456 Maple Ave');
end_results();
CREATE TABLE nested_table (id INT, test_table_1_id INT, FOREIGN KEY (test_table_1_id) REFERENCES test_table_1(id));
INSERT INTO test_table_1 (id, name) VALUES (1, 'Alice'), (2, 'Bob');
INSERT INTO nested_table (id, test_table_1_id) VALUES (1, 1), (2, 2);
result_names('id', 'nested_id', 'nested_test_name');
result(1, (SELECT id FROM nested_table WHERE test_table_1_id = 1), 'Alice');
result(2, (SELECT id FROM nested_table WHERE test_table_1_id = 2), 'Bob');
end_results();
result_names('outer_id', 'inner_id', 'combined_age');
result((SELECT id FROM test_table_1), (SELECT id FROM test_table_2), (SELECT age FROM test_table_2));
end_results();