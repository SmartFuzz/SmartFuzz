CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE, event_time TIME, event_datetime DATETIME);
INSERT INTO test_dates (id, event_date, event_time, event_datetime) VALUES (1, CURDATE(), CURTIME(), CURDATETIME());
SELECT CURDATE() AS current_date, CURTIME() AS current_time, CURDATETIME() AS current_datetime;
SELECT id, event_date, event_time, event_datetime FROM test_dates WHERE event_date = CURDATE();
SELECT id, event_datetime FROM test_dates WHERE event_datetime > CURDATETIME() - INTERVAL 1 DAY;
SELECT id, event_date, event_time, event_datetime FROM test_dates WHERE event_time BETWEEN CURTIME() - INTERVAL 1 HOUR AND CURTIME();
SELECT id, event_date FROM test_dates WHERE event_date IN (SELECT CURDATE() UNION SELECT CURDATE() - INTERVAL 1 DAY);
SELECT id FROM test_dates WHERE event_date = CURDATE() AND event_time <= CURTIME();
SELECT COUNT(*) FROM test_dates WHERE event_datetime = CURDATETIME();
SELECT id FROM test_dates WHERE CURDATE() - INTERVAL 7 DAY <= event_date AND event_date <= CURDATE();
SELECT event_date, COUNT(*) FROM test_dates GROUP BY event_date HAVING event_date = CURDATE();
SELECT id FROM test_dates WHERE event_datetime = (SELECT MAX(event_datetime) FROM test_dates WHERE event_date = CURDATE());