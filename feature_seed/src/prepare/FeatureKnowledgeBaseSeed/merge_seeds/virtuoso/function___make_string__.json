CREATE TABLE test_strings (id INTEGER PRIMARY KEY, generated_string VARCHAR);
INSERT INTO test_strings (id, generated_string) VALUES (1, make_string(0));
INSERT INTO test_strings (id, generated_string) VALUES (2, make_string(1));
INSERT INTO test_strings (id, generated_string) VALUES (3, make_string(10));
INSERT INTO test_strings (id, generated_string) VALUES (4, make_string(100));
INSERT INTO test_strings (id, generated_string) VALUES (5, make_string(255));
INSERT INTO test_strings (id, generated_string) VALUES (6, make_string(1024));
SELECT id, generated_string FROM test_strings WHERE generated_string = make_string(0);
SELECT id, generated_string FROM test_strings WHERE LENGTH(generated_string) = 10;
SELECT id, generated_string FROM test_strings WHERE generated_string LIKE make_string(1) || '%';
CREATE TABLE additional_strings (string_value VARCHAR);
INSERT INTO additional_strings (string_value) VALUES (make_string(26));
SELECT a.id, a.generated_string, b.string_value FROM test_strings a JOIN additional_strings b ON a.id = 1;
SELECT a.generated_string FROM test_strings a WHERE EXISTS (SELECT 1 FROM additional_strings b WHERE b.string_value = make_string(26));