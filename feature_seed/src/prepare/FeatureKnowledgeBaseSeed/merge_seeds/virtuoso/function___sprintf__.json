CREATE TABLE test_table (id INT, name VARCHAR(255), description VARCHAR(2000));
INSERT INTO test_table VALUES (1, 'Single Quote Test', sprintf('This is a test with a single quote: '' quote', 'test'));
INSERT INTO test_table VALUES (2, 'Long String Test', sprintf('A very long string that exceeds the limit: %s', 'x'.repeat(2001)));
INSERT INTO test_table VALUES (3, 'Escaped Single Quote', sprintf('Example with an escaped single quote: %S', 'This is a single quote: '' '));
INSERT INTO test_table VALUES (4, 'Escaped Identifier', sprintf('Example with an escaped identifier: %I', 'identifier with spaces'));
INSERT INTO test_table VALUES (5, 'Escaped URL', sprintf('Example with an escaped URL: %U', 'http://example.com/space test'));
INSERT INTO test_table VALUES (6, 'Leading Space Replacement', sprintf('Leading spaces replaced: %{+}s', '   leading spaces'));
INSERT INTO test_table VALUES (7, 'Escaped HTTP Value', sprintf('Escaped HTTP Value example: %V', 'value with spaces here'));
SELECT sprintf('User: %s, Age: %d', name, 25) FROM test_table WHERE id = 1;
SELECT name, sprintf('Description: %s', description) AS formatted_description FROM test_table WHERE id < 4;
SELECT t1.id, sprintf('Record %d from test_table: %s', t1.id, t1.name) AS formatted_output FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.id > 0;
INSERT INTO test_table VALUES (8, 'Fuzz Test', sprintf('%U with %d items', 'http://example.com/items', 999));
SELECT sprintf('Item count: %d', COUNT(*)) FROM test_table WHERE name LIKE 'Single Quote%';
SELECT sprintf('%{var_name}U: %s', 'http://example.com?id=1') FROM DUAL;
DELETE FROM test_table WHERE id = sprintf('%d', 1);
UPDATE test_table SET description = sprintf('Updated Description: %s', 'new description') WHERE id = 2;