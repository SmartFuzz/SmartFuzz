CREATE GRAPH <http://example.org/graph1>;
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/subject1> <http://example.org/predicate1> <http://example.org/object1> . } };
CREATE PROCEDURE test_rdf_serialization(in qry varchar, in dflt_graph varchar) { declare ses, rset, triples any;
declare txt varchar;
ses := string_output();
rset := DB.DBA.SPARQL_EVAL_TO_ARRAY (qry, dflt_graph, 1);
triples := dict_list_keys (rset[0][0], 1);
DB.DBA.RDF_TRIPLES_TO_RDF_XML_TEXT (triples, 1, ses);
txt := string_output_string (ses);
dump_large_text (txt);
};
EXECUTE test_rdf_serialization('SELECT * WHERE { ?s ?p ?o }', '<http://example.org/graph1>');
CREATE GRAPH <http://example.org/graph2>;
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/subject2> <http://example.org/predicate2> <http://example.org/object2> . <http://example.org/subject3> <http://example.org/predicate3> <http://example.org/object3> . } };
CREATE PROCEDURE complex_test(in qry varchar, in dflt_graph varchar) { declare ses, rset, triples any;
declare txt varchar;
ses := string_output();
rset := DB.DBA.SPARQL_EVAL_TO_ARRAY (qry, dflt_graph, 1);
triples := dict_list_keys (rset[0][0], 1);
DB.DBA.RDF_TRIPLES_TO_RDF_XML_TEXT (triples, 1, ses);
txt := string_output_string (ses);
dump_large_text (txt);
};
EXECUTE complex_test('SELECT ?s ?p ?o WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o } UNION GRAPH <http://example.org/graph2> { ?s ?p ?o } }', '<http://example.org/graph1>');
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/subject4> <http://example.org/predicate4> <http://example.org/object4> . } };
EXECUTE test_rdf_serialization('SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s ?p ?o } }', '<http://example.org/graph1>');
CREATE PROCEDURE nested_test(in qry varchar, in dflt_graph varchar) { declare ses, rset, triples any;
declare txt varchar;
ses := string_output();
rset := DB.DBA.SPARQL_EVAL_TO_ARRAY (qry, dflt_graph, 1);
triples := dict_list_keys (rset[0][0], 1);
DB.DBA.RDF_TRIPLES_TO_RDF_XML_TEXT (triples, 1, ses);
txt := string_output_string (ses);
dump_large_text (txt);
};
EXECUTE nested_test('SELECT ?s WHERE { { SELECT ?s WHERE { ?s ?p ?o } } UNION { SELECT ?s WHERE { ?s ?p2 ?o2 } } }', '<http://example.org/graph1>');