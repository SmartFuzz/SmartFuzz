CREATE TABLE nntp_servers (id INT PRIMARY KEY, server_name VARCHAR(255), requires_auth BOOLEAN, last_checked DATETIME);
INSERT INTO nntp_servers (id, server_name, requires_auth, last_checked) VALUES (1, 'news.example.com', TRUE, NOW());
INSERT INTO nntp_servers (id, server_name, requires_auth, last_checked) VALUES (2, 'news.example.org', FALSE, NOW());
CREATE TABLE users (user_id INT PRIMARY KEY, username VARCHAR(255), password VARCHAR(255));
INSERT INTO users (user_id, username, password) VALUES (1, 'user1', 'password123');
INSERT INTO users (user_id, username, password) VALUES (2, 'user2', 'password456');
SELECT * FROM nntp_servers WHERE requires_auth = TRUE;
SELECT s.server_name FROM nntp_servers s JOIN users u ON u.user_id = 1 WHERE s.requires_auth = TRUE;
SELECT server_name FROM nntp_servers WHERE id IN (SELECT id FROM nntp_servers WHERE requires_auth = TRUE) AND last_checked > NOW() - INTERVAL '1 DAY';
SELECT u.username, s.server_name FROM users u LEFT JOIN nntp_servers s ON s.requires_auth = TRUE WHERE u.user_id = 1;
SELECT u.username, COUNT(s.id) AS authorized_servers FROM users u JOIN nntp_servers s ON s.requires_auth = TRUE GROUP BY u.username;