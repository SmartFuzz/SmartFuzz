CREATE TABLE test_varchar (id INT, name VARCHAR(255), description VARCHAR(500));
INSERT INTO test_varchar (id, name, description) VALUES (1, 'John Doe', 'A sample description for John Doe');
INSERT INTO test_varchar (id, name, description) VALUES (2, 'A very long name that exceeds normal usage', 'Description for long name');
INSERT INTO test_varchar (id, name, description) VALUES (3, 'Jane', 'A short description');
SELECT * FROM test_varchar WHERE LENGTH(name) <= 255;
SELECT * FROM test_varchar WHERE LENGTH(description) > 0;
SELECT * FROM test_varchar WHERE name LIKE 'J%';
SELECT id, name FROM test_varchar WHERE LENGTH(name) BETWEEN 1 AND 255;
UPDATE test_varchar SET description = 'Updated description.' WHERE id = 2;
DELETE FROM test_varchar WHERE name = 'John Doe';
SELECT DISTINCT name FROM test_varchar WHERE description IS NOT NULL;
CREATE TABLE other_table (id INT, name VARCHAR(100), FOREIGN KEY (id) REFERENCES test_varchar(id));
INSERT INTO other_table (id, name) SELECT id, name FROM test_varchar WHERE id < 3;
SELECT tt.id, tt.name, ot.name FROM test_varchar tt JOIN other_table ot ON tt.id = ot.id;
SELECT tt.id, tt.name FROM test_varchar tt WHERE tt.name IN (SELECT name FROM other_table);
SELECT tt.id, tt.name, (SELECT COUNT(*) FROM other_table WHERE name LIKE CONCAT('%', tt.name, '%')) AS count_related FROM test_varchar tt;