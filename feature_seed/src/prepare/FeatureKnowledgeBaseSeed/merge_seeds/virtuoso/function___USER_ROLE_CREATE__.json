CREATE ROLE new_user_role;
CREATE ROLE admin_role WITH PASSWORD 'admin123';
CREATE ROLE read_only_role IN DATABASE my_database;
CREATE ROLE complex_role WITH LOGIN AS 'user1' ENCRYPTED PASSWORD 'securepass';
CREATE ROLE role_with_schema_access IN SCHEMA public;
CREATE ROLE external_role WITH CONNECTION LIMIT 5;
CREATE ROLE temporary_role CREATEROLE;
CREATE ROLE role_with_grants IN DATABASE my_database GRANT SELECT ON ALL TABLES TO role_with_grants;
CREATE ROLE nested_role AS (SELECT role_name FROM role_schema WHERE role_id = '001');
CREATE ROLE role_nested_with_access IN SCHEMA (SELECT schema_name FROM information_schema.schemata WHERE catalog_name = 'my_database') WHERE EXISTS (SELECT * FROM role_permissions WHERE permission = 'EXECUTE');
CREATE ROLE user_role_with_conditions AS (SELECT r.role_name FROM roles r JOIN users u ON r.user_id = u.id WHERE u.name = 'test_user');
CREATE ROLE hybrid_role AS (SELECT role_id FROM unnest(ARRAY['admin', 'user', 'developer']) AS role_id) WITH LOGIN;