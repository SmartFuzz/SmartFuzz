CREATE PROCEDURE csr_gen_test_1() { declare kname, cvalue varchar;
xenc_key_RSA_create('testRSAkey1', 2048);
xenc_x509_csr_generate('testRSAkey1', vector('CN', 'Test User 1', 'C', 'US', 'O', 'Company1', 'OU', 'IT', 'emailAddress', 'test1@company.com'), vector('subjectAltName', 'DNS: test.company.com', 'nsComment', 'Test CSR 1', 'authorityKeyIdentifier', 'keyid,issuer:always'));
};
CREATE PROCEDURE csr_gen_test_2() { declare kname, cvalue varchar;
xenc_key_RSA_create('testRSAkey2', 2048);
xenc_x509_csr_generate('testRSAkey2', vector('CN', 'Test User 2', 'C', 'UK', 'O', 'Company2', 'OU', 'HR', 'emailAddress', 'test2@company.com'), vector('subjectAltName', 'IP: 192.168.1.1', 'nsComment', 'Test CSR 2', 'authorityKeyIdentifier', 'keyid,issuer:always'));
};
CREATE TABLE csr_records (id INT PRIMARY KEY, csr TEXT);
INSERT INTO csr_records (id, csr) SELECT 1, csr_gen_test_1();
INSERT INTO csr_records (id, csr) SELECT 2, csr_gen_test_2();
CREATE PROCEDURE csr_gen_complex() { declare kname, cvalue varchar;
xenc_key_RSA_create('complexRSAkey', 4096);
xenc_x509_csr_generate('complexRSAkey', vector('CN', 'Complex User', 'C', 'FR', 'O', 'ComplexCompany', 'OU', 'Development', 'emailAddress', 'complex@company.com'), vector('subjectAltName', 'email: complex@company.com', 'nsComment', 'Complex CSR', 'authorityKeyIdentifier', 'keyid,issuer:always'));
};
SELECT csr FROM csr_records WHERE id IN (SELECT id FROM csr_records WHERE csr IS NOT NULL);
SELECT r.id, r.csr FROM csr_records r JOIN (SELECT id FROM csr_records WHERE csr IS NOT NULL) AS filtered ON r.id = filtered.id;
CREATE TABLE csr_logs (log_id INT PRIMARY KEY, csr_id INT, log_entry TEXT, FOREIGN KEY (csr_id) REFERENCES csr_records(id));
INSERT INTO csr_logs (log_id, csr_id, log_entry) SELECT 1, r.id, 'CSR generated for user: ' || (SELECT vector('CN', 'Test User 1')) FROM csr_records r WHERE r.id = 1;