CREATE TABLE test_varbinary (id INT PRIMARY KEY, data VARBINARY(255));
INSERT INTO test_varbinary (id, data) VALUES (1, CAST('binary data example' AS VARBINARY(255)));
INSERT INTO test_varbinary (id, data) VALUES (2, CAST('another example' AS VARBINARY(255)));
INSERT INTO test_varbinary (id, data) VALUES (3, CAST(0xDEADBEEF AS VARBINARY(4)));
SELECT id, data FROM test_varbinary WHERE LENGTH(data) = 18;
CREATE TABLE test_varbinary_extra (ref_id INT, data VARBINARY(100), FOREIGN KEY (ref_id) REFERENCES test_varbinary(id));
INSERT INTO test_varbinary_extra (ref_id, data) VALUES (1, CAST(0x1234 AS VARBINARY(2)));
SELECT t1.id, t1.data, t2.data FROM test_varbinary t1 JOIN test_varbinary_extra t2 ON t1.id = t2.ref_id WHERE LENGTH(t2.data) <= 100;
SELECT t1.id, t1.data FROM test_varbinary t1 WHERE t1.id IN (SELECT ref_id FROM test_varbinary_extra WHERE LENGTH(data) < 50);
UPDATE test_varbinary SET data = CAST('updated binary data' AS VARBINARY(255)) WHERE id = 1;
DELETE FROM test_varbinary WHERE LENGTH(data) > 200;
SELECT COUNT(*) FROM test_varbinary WHERE data IS NOT NULL;
CREATE TABLE test_varbinary_complex (id INT, data VARBINARY(500), timestamp DATETIME DEFAULT CURRENT_TIMESTAMP);
INSERT INTO test_varbinary_complex (id, data) VALUES (1, CAST(0xABCDEF AS VARBINARY(6)));
SELECT id, data, timestamp FROM test_varbinary_complex WHERE timestamp >= (SELECT MAX(timestamp) FROM test_varbinary_complex WHERE id = 1);