CREATE TABLE test_table (id INT, value VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'abc');
INSERT INTO test_table (id, value) VALUES (2, 'def');
INSERT INTO test_table (id, value) VALUES (3, NULL);
SELECT xte_nodebld_final(value, 'xyz') AS corrected_value FROM test_table WHERE id = 1;
SELECT xte_nodebld_final(value, NULL) AS corrected_value FROM test_table WHERE id = 2;
SELECT xte_nodebld_final(value, 'new_value') AS corrected_value FROM (SELECT value FROM test_table WHERE id IN (1, 2)) AS subquery;
WITH updated_values AS (SELECT xte_nodebld_final(value, 'replacement') AS new_value FROM test_table) SELECT * FROM updated_values;
SELECT value, xte_nodebld_final(value, 'override') AS modified_value FROM test_table WHERE value IS NOT NULL ORDER BY id;
DELETE FROM test_table WHERE id = 3;
SELECT xte_nodebld_final(NULL, 'default') AS corrected_default_value;
CREATE TABLE another_table (check_value VARCHAR(255));
INSERT INTO another_table (check_value) VALUES ('example');
SELECT (SELECT xte_nodebld_final(value, 'substitution') FROM test_table) AS outer_value, (SELECT check_value FROM another_table) AS inner_value;
SELECT xte_nodebld_final(value, 'another_substitution') AS adjusted_value FROM (SELECT value FROM test_table LIMIT 1) AS single_item;