CREATE TABLE test_floats (id INT, value FLOAT);
INSERT INTO test_floats (id, value) VALUES (1, FLOAT(0));
INSERT INTO test_floats (id, value) VALUES (2, FLOAT(-1));
INSERT INTO test_floats (id, value) VALUES (3, FLOAT(1));
INSERT INTO test_floats (id, value) VALUES (4, FLOAT(123456789));
INSERT INTO test_floats (id, value) VALUES (5, FLOAT(-123456789));
INSERT INTO test_floats (id, value) VALUES (6, FLOAT(3.14159));
INSERT INTO test_floats (id, value) VALUES (7, FLOAT(1.0E10));
INSERT INTO test_floats (id, value) VALUES (8, FLOAT(-1.0E10));
SELECT id, value FROM test_floats WHERE value > FLOAT(0) ORDER BY value;
SELECT AVG(value) AS average_value FROM test_floats WHERE id IN (SELECT id FROM test_floats WHERE value < FLOAT(100));
SELECT t1.id, t1.value FROM test_floats t1 JOIN (SELECT id FROM test_floats WHERE value < FLOAT(0)) t2 ON t1.id = t2.id;
UPDATE test_floats SET value = FLOAT(0) WHERE id = 1;
DELETE FROM test_floats WHERE value = FLOAT(-1);
CREATE TABLE test_floats2 (id INT, parent_id INT, value FLOAT, FOREIGN KEY (parent_id) REFERENCES test_floats(id));
INSERT INTO test_floats2 (id, parent_id, value) VALUES (1, 1, FLOAT(1.5));
SELECT t2.id, t2.value FROM test_floats2 t2 JOIN test_floats t1 ON t2.parent_id = t1.id WHERE t1.value > FLOAT(1);
SELECT COUNT(*) FROM test_floats WHERE value BETWEEN FLOAT(-1.5) AND FLOAT(1.5);
SELECT id, FLOAT(value) AS float_value FROM test_floats WHERE value IS NOT NULL;
SELECT DISTINCT FLOAT(value) FROM test_floats WHERE value IS NOT NULL ORDER BY float_value;