CREATE TABLE dav_users (uid VARCHAR(255) PRIMARY KEY, pwd VARCHAR(255), gid VARCHAR(255), perms INT, home_directory VARCHAR(255), full_name VARCHAR(255), email VARCHAR(255));
CREATE TABLE dav_groups (gid VARCHAR(255) PRIMARY KEY);
INSERT INTO dav_groups (gid) VALUES ('group1');
INSERT INTO dav_users (uid, pwd, gid, perms, home_directory, full_name, email) VALUES ('user1', 'secret1', 'group1', 0, '/home/user1', 'User One', 'user1@example.com');
SELECT * FROM dav_users WHERE uid = (SELECT uid FROM dav_users WHERE email = 'user1@example.com');
SELECT home_directory FROM dav_users WHERE uid = 'user1';
SELECT gid FROM dav_groups WHERE gid = (SELECT gid FROM dav_users WHERE uid = 'user1');
INSERT INTO dav_groups (gid) VALUES ('group2');
INSERT INTO dav_users (uid, pwd, gid, perms, home_directory, full_name, email) VALUES ('user2', 'secret2', 'group2', 0, '/home/user2', 'User Two', 'user2@example.com');
