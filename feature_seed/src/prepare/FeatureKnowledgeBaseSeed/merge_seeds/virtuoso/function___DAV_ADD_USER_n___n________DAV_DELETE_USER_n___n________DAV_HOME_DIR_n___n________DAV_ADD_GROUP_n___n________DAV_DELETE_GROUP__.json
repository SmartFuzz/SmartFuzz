DELETE FROM dav_groups WHERE gid = 'group1';
SELECT COUNT(*) FROM dav_users WHERE gid = (SELECT gid FROM dav_groups WHERE gid = 'group2');
CREATE INDEX idx_email ON dav_users(email);
SELECT * FROM dav_users WHERE uid IN (SELECT uid FROM dav_users WHERE email LIKE '%@example.com');
UPDATE dav_users SET pwd = 'new_secret' WHERE uid = 'user2';
SELECT user1.full_name, group2.gid FROM dav_users AS user1 JOIN dav_users AS user2 ON user1.gid = user2.gid WHERE user1.uid = 'user1' AND user2.uid = 'user2';