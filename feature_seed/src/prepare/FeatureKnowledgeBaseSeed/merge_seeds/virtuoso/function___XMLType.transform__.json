CREATE TABLE test_table (id INT, xml_data XML);
INSERT INTO test_table (id, xml_data) VALUES (1, '<root><element>Test</element></root>');
INSERT INTO test_table (id, xml_data) VALUES (2, '<root><element>Example</element></root>');
SELECT id FROM test_table WHERE xml_data IS NOT NULL;
SELECT id, xml_data FROM test_table WHERE xml_data LIKE '<root>%';
SELECT t1.id, t2.xml_data FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.xml_data != t2.xml_data;
SELECT (SELECT COUNT(*) FROM test_table) AS total_count, (SELECT id FROM test_table WHERE id > 1 LIMIT 1) AS sample_id;
SELECT id FROM test_table WHERE EXISTS (SELECT 1 FROM test_table WHERE xml_data LIKE '%Test%') AND xml_data IS NOT NULL;
SELECT id FROM (SELECT id, xml_data FROM test_table WHERE xml_data LIKE '<root>%') AS filtered WHERE id < 3;
SELECT id, xml_data FROM (SELECT id, xml_data FROM test_table) AS subquery WHERE id NOT IN (SELECT id FROM test_table WHERE xml_data IS NULL);