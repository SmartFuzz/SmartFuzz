CREATE TABLE test_serialization (id INT, data BLOB);
INSERT INTO test_serialization (id, data) VALUES (1, serialize('{"name":"John","age":30,"children":[{"name":"Jane"},{"name":"Doe"}]}'));
INSERT INTO test_serialization (id, data) VALUES (2, serialize('{"numbers":[1,2,3,4,5],"details":{"height":180,"weight":75}}'));
INSERT INTO test_serialization (id, data) VALUES (3, serialize('{"array":[[{"level":1},{"level":2}],[{"level":3}]]}'));
INSERT INTO test_serialization (id, data) VALUES (4, serialize('{"mixed":["string", 42, null, false]}'));
SELECT id, deserialize(data) FROM test_serialization WHERE id <= 2;
SELECT id, deserialize(data) FROM test_serialization WHERE data IS NOT NULL;
CREATE TABLE test_nested_serialization (id INT, parent_id INT, data BLOB, FOREIGN KEY (parent_id) REFERENCES test_serialization(id));
INSERT INTO test_nested_serialization (id, parent_id, data) VALUES (1, 1, serialize('{"nested":[{"sublevel":{"key":"value"}}]}'));
SELECT id, deserialize(data) FROM test_nested_serialization WHERE parent_id = (SELECT id FROM test_serialization WHERE id = 1);
CREATE TABLE test_large_data (id INT, data BLOB);
INSERT INTO test_large_data (id, data) VALUES (1, serialize(REPEAT('{"repeat":true}, 16000)));
SELECT id, LENGTH(data) FROM test_large_data WHERE id = 1;
SELECT id, deserialize(data) FROM test_large_data WHERE LENGTH(data) <= 16777215;