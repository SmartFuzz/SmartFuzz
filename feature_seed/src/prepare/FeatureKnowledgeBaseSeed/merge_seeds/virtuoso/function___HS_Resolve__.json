SELECT HS_Resolve('10.1038/35057062');
SELECT HS_Resolve('10.1000/xyz123');
SELECT HS_Resolve(NULL);
SELECT HS_Resolve('');
SELECT HS_Resolve('10.1038/35057062') AS url, CURRENT_TIMESTAMP AS query_time;
SELECT HS_Resolve(doi) FROM (SELECT '10.1038/35057062' AS doi) AS t;
SELECT HS_Resolve(doi) FROM doi_table WHERE doi IS NOT NULL;
SELECT HS_Resolve(doi) FROM doi_table WHERE LENGTH(doi) > 0 AND doi LIKE '10.%';
WITH doi_cte AS (SELECT '10.1038/35057062' AS doi) SELECT HS_Resolve(doi) FROM doi_cte;
SELECT HS_Resolve(doi) FROM (SELECT doi FROM doi_table WHERE doi LIKE '10.%') AS filtered;
SELECT doi, HS_Resolve(doi) FROM doi_table WHERE doi IN ('10.1038/35057062', '10.1000/xyz123');
SELECT EXISTS(SELECT 1 FROM doi_table WHERE HS_Resolve(doi) IS NOT NULL);
SELECT HS_Resolve('10.1038/35057062'), HS_Resolve('10.1000/xyz123') UNION SELECT HS_Resolve('10.1155/123456.78');
CREATE TABLE doi_table (doi VARCHAR(100) PRIMARY KEY);
INSERT INTO doi_table (doi) VALUES ('10.1038/35057062'), ('10.1000/xyz123');
CREATE INDEX doi_index ON doi_table (doi);
SELECT HS_Resolve(doi) FROM doi_table WHERE doi LIKE '10.%' ORDER BY doi;
SELECT doi, HS_Resolve(doi) FROM doi_table WHERE doi IN (SELECT doi FROM another_table WHERE condition = true);