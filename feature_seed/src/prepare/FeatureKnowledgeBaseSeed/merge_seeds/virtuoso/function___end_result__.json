CREATE TABLE test_table (id INTEGER PRIMARY KEY, name VARCHAR(255), age INTEGER);
CREATE TABLE another_table (test_id INTEGER, foreign_key_id INTEGER, description TEXT);
INSERT INTO test_table (id, name, age) VALUES (1, 'Alice', 30);
INSERT INTO test_table (id, name, age) VALUES (2, 'Bob', 25);
INSERT INTO another_table (test_id, foreign_key_id, description) VALUES (1, 1, 'Sample 1');
INSERT INTO another_table (test_id, foreign_key_id, description) VALUES (2, 2, 'Sample 2');
CALL result_names('id', 'name', 'age');
CALL result(1, 'Alice', 30);
CALL result(2, 'Bob', 25);
CALL end_result();
CALL result_names('test_id', 'foreign_key_id', 'description');
CALL result(1, 1, 'Sample 1');
CALL result(2, 2, 'Sample 2');
CALL end_result();
SELECT * FROM test_table;
SELECT * FROM another_table;
SELECT test_table.name, another_table.description FROM test_table JOIN another_table ON test_table.id = another_table.foreign_key_id;
WITH RECENT AS (SELECT * FROM test_table WHERE age > 20) SELECT name FROM RECENT WHERE id IN (SELECT foreign_key_id FROM another_table);
CREATE VIEW test_view AS SELECT name, age FROM test_table WHERE age < 35;
SELECT * FROM test_view;
CALL end_result();