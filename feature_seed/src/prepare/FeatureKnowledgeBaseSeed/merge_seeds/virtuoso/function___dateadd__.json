CREATE TABLE test_dates (id INT, event_date TIMESTAMP);
INSERT INTO test_dates (id, event_date) VALUES (1, STRINGDATE('1996.10.10'));
INSERT INTO test_dates (id, event_date) VALUES (2, STRINGDATE('2021.03.15'));
SELECT dateadd('day', 10, event_date) FROM test_dates WHERE id = 1;
SELECT dateadd('month', -1, event_date) FROM test_dates WHERE id = 2;
SELECT dateadd('year', 5, event_date) AS future_date FROM test_dates WHERE id = 1;
SELECT dateadd('hour', 24, event_date) FROM (SELECT event_date FROM test_dates WHERE id = 1) AS subquery;
SELECT dateadd('minute', 60, event_date) FROM test_dates WHERE id = 2;
SELECT dateadd('second', -30, event_date) FROM test_dates;
SELECT event_date, dateadd('day', 7, event_date) AS new_date FROM test_dates WHERE event_date < STRINGDATE('2025.01.01');
SELECT dateadd('month', -2, event_date) AS past_date FROM test_dates WHERE EXISTS (SELECT 1 FROM test_dates WHERE id = 1);
SELECT id, dateadd('year', 1, event_date) AS incremented_date FROM test_dates ORDER BY event_date DESC;
CREATE TABLE future_events (id INT, event_date TIMESTAMP, description STRING);
INSERT INTO future_events (id, event_date, description) VALUES (1, STRINGDATE('2023.12.31'), 'New Year Eve');
SELECT id, dateadd('day', 1, event_date) AS next_day FROM future_events WHERE description = 'New Year Eve';
SELECT id, event_date, dateadd('month', 6, event_date) FROM future_events WHERE event_date = (SELECT MAX(event_date) FROM future_events);