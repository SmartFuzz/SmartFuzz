CREATE TABLE test_dict (id INT PRIMARY KEY, key_name VARCHAR(100), value_data VARCHAR(255));
INSERT INTO test_dict (id, key_name, value_data) VALUES (1, 'key1', 'value1');
INSERT INTO test_dict (id, key_name, value_data) VALUES (2, 'key2', 'value2');
INSERT INTO test_dict (id, key_name, value_data) VALUES (3, 'key3', 'value3');
INSERT INTO test_dict (id, key_name, value_data) VALUES (4, 'key4', 'value4');
SELECT * FROM test_dict WHERE key_name = 'key1';
SELECT COUNT(*) FROM test_dict WHERE value_data LIKE 'value%';
SELECT key_name, COUNT(*) as count FROM test_dict GROUP BY key_name HAVING count > 1;
SELECT * FROM test_dict WHERE id IN (SELECT id FROM test_dict WHERE value_data = 'value2');
DELETE FROM test_dict WHERE key_name = 'key3';
UPDATE test_dict SET value_data = 'updated_value' WHERE key_name = 'key1';
SELECT * FROM (SELECT id, key_name FROM test_dict) AS subquery WHERE key_name LIKE 'key%';
CREATE TABLE other_dict (id INT PRIMARY KEY, other_key_name INT, other_value_data VARCHAR(255));
INSERT INTO other_dict (id, other_key_name, other_value_data) VALUES (1, 100, 'valueA');
INSERT INTO other_dict (id, other_key_name, other_value_data) SELECT id, COUNT(*) FROM test_dict GROUP BY id;
SELECT test_dict.key_name, other_dict.other_value_data FROM test_dict JOIN other_dict ON test_dict.id = other_dict.id;
INSERT INTO other_dict (id, other_key_name, other_value_data) VALUES (2, NULL, 'valueB');
SELECT DISTINCT key_name FROM test_dict WHERE value_data IS NOT NULL;
WITH dict_counts AS (SELECT key_name, COUNT(*) as count FROM test_dict GROUP BY key_name) SELECT * FROM dict_counts WHERE count > 1;
SELECT * FROM test_dict WHERE json_contains(value_data, '{"key": "value"}') = 1;
