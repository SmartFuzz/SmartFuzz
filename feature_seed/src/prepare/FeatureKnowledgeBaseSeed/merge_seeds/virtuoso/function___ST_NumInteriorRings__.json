CREATE GRAPH <http://geo-api-demo/>;
INSERT DATA { <point2d> <shape> "POINT(1 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <point4d> <shape> "POINTZM(0 1 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <box1> <shape> "BOX(0 0, 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <linestring> <shape> "LINESTRING(10 21, 12 23, 10 25)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <polygon1> <shape> "POLYGON((1 3,2 4,1 5,0 4,1 3))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <polygon2> <shape> "POLYGON((1.5 3.5,2.5 4.5,1.5 5.5,0.5 4.5,1.5 3.5))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <polygon3> <shape> "POLYGON((1 3,2 4,1 5,0 4,1 3),(1 3.5,1.5 4,1 4.5,0.5 4,1 3.5))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <multipolygon> <shape> "MULTIPOLYGON(((1 3,2 4,1 5,0 4,1 3)),((1 2,2 1,1 0,0 1,1 2)))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <collection> <shape> "GEOMETRYCOLLECTION(POINT(0 0),MULTILINESTRING((1 5,0 1,4 0,5 4),(1 5,1 0,4 0,4 5)),MULTIPOLYGON(((1 3,2 4,1 5,0 4,1 3)),((1 2,2 1,1 0,0 1,1 2))))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
SELECT ?s bif:ST_NumInteriorRings(?o) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } ORDER BY ASC(str(?s));
SELECT ?s bif:ST_NumInteriorRings(?o) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o . FILTER(?o = "POLYGON((1 3,2 4,1 5,0 4,1 3))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry>) } ORDER BY ASC(str(?s));
SELECT DISTINCT ?s WHERE { ?s ?p ?o . BIND(bif:ST_NumInteriorRings(?o) AS ?interiorRings) FILTER(?interiorRings >= 0) } ORDER BY ?interiorRings;
SELECT (COUNT(?s) AS ?count) WHERE { ?s ?p ?o FILTER(bif:ST_NumInteriorRings(?o) IS NOT NULL) };
SELECT ?s bif:ST_NumInteriorRings(?o) FROM <http://geo-api-demo/> WHERE { ?s a <http://www.openlinksw.com/schemas/virtrdf#GeometryPolygon> . ?s ?p ?o } ORDER BY ASC(?s);
SELECT ?s bif:ST_NumInteriorRings(?o) FROM <http://geo-api-demo/> WHERE { ?s ?p ?o . ?s a <http://www.openlinksw.com/schemas/virtrdf#Geometry> OPTIONAL { ?s ?p2 ?o2 } } ORDER BY ASC(str(?s));