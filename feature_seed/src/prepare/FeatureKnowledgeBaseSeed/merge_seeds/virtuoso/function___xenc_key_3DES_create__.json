CREATE TABLE keys (id INTEGER PRIMARY KEY, name VARCHAR(255), secret VARCHAR(255));
INSERT INTO keys (name, secret) VALUES ('key1', 'mysecret1');
INSERT INTO keys (name, secret) VALUES ('key2', 'mysecret2');
INSERT INTO keys (name, secret) VALUES ('key3', 'mysecret3');
SELECT xenc_key_3DES_create(name, secret) FROM keys WHERE id = 1;
SELECT xenc_key_3DES_create(name, secret) FROM keys WHERE id IN (SELECT id FROM keys WHERE secret LIKE 'mysecret%');
SELECT xenc_key_3DES_create(name, secret) FROM keys k1 JOIN (SELECT id FROM keys WHERE name = 'key2') k2 ON k1.id = k2.id;
SELECT xenc_key_3DES_create('session_key', secret) FROM keys WHERE secret IS NOT NULL;
SELECT xenc_key_3DES_create(name, '' || secret) FROM keys WHERE LENGTH(secret) < 255;
SELECT xenc_key_3DES_create(name, secret) AS encrypted_key FROM keys ORDER BY id DESC LIMIT 5;
INSERT INTO keys (name, secret) VALUES ('key4', '');
INSERT INTO keys (name, secret) VALUES ('key5', 'mysecret4mysecret4mysecret4');
SELECT xenc_key_3DES_create(name, SUBSTR(secret, 1, 10)) FROM keys WHERE LENGTH(secret) > 10;
SELECT xenc_key_3DES_create('key_max_length', RPAD('secret', 255, '0')) FROM keys WHERE id = (SELECT MAX(id) FROM keys);