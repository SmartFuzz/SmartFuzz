CREATE TABLE demo.demo.orders (orderid INT, orderdate VARCHAR(10));
INSERT INTO demo.demo.orders (orderid, orderdate) VALUES (1, '1995-05-15');
INSERT INTO demo.demo.orders (orderid, orderdate) VALUES (2, '1996-08-22');
INSERT INTO demo.demo.orders (orderid, orderdate) VALUES (3, '1998-02-10');
SELECT * FROM demo.demo.orders o WHERE o.orderdate BETWEEN stringdate('1994-01-01') AND stringdate('1997-12-31');
SELECT o1.orderid FROM demo.demo.orders o1 WHERE o1.orderdate = stringdate('1995-05-15') AND o1.orderid IN (SELECT o2.orderid FROM demo.demo.orders o2 WHERE o2.orderdate < stringdate('1996-01-01'));
SELECT o.orderid FROM demo.demo.orders o JOIN demo.demo.orders o2 ON o.orderdate BETWEEN stringdate('1995-01-01') AND stringdate('1996-12-31') AND o2.orderdate BETWEEN stringdate('1994-01-01') AND stringdate('1997-12-31');
SELECT COUNT(*) FROM demo.demo.orders WHERE orderdate >= stringdate('1994-01-01');
SELECT o.orderid FROM demo.demo.orders o WHERE o.orderdate < stringdate('1999-01-01') AND o.orderdate > stringdate('1994-12-31');
SELECT o.orderid, COUNT(*) FROM demo.demo.orders o WHERE o.orderdate BETWEEN stringdate('1995-01-01') AND stringdate('1995-12-31') GROUP BY o.orderid HAVING COUNT(*) > 1;