CREATE TABLE namespace_test (id INT PRIMARY KEY, ns_prefix VARCHAR(255), ns_uri VARCHAR(255), persistence BIT);
INSERT INTO namespace_test (id, ns_prefix, ns_uri, persistence) VALUES (1, 'northwind', 'http://demo.openlinksw.com/schemas/northwind#', 1);
INSERT INTO namespace_test (id, ns_prefix, ns_uri, persistence) VALUES (2, 'southernwind', 'http://demo.openlinksw.com/schemas/southernwind#', 0);
DB.DBA.XML_SET_NS_DECL ('northwind', 'http://demo.openlinksw.com/schemas/northwind#', 2);
DB.DBA.XML_SET_NS_DECL ('southernwind', 'http://demo.openlinksw.com/schemas/southernwind#', 0);
INSERT INTO namespace_test (id, ns_prefix, ns_uri, persistence) SELECT id + 2, CONCAT('temp_', ns_prefix), ns_uri, persistence FROM namespace_test WHERE persistence = 1;
SELECT ns_prefix FROM namespace_test WHERE persistence = 1 AND ns_uri LIKE 'http://demo.openlinksw.com/schemas/%';
UPDATE namespace_test SET persistence = 1 WHERE ns_prefix = 'southernwind';
DELETE FROM namespace_test WHERE ns_prefix = 'northwind' AND persistence = 0;
SELECT a.ns_prefix, b.ns_uri FROM namespace_test a JOIN namespace_test b ON a.id = b.id WHERE a.persistence = 1;
DB.DBA.XML_SET_NS_DECL ((SELECT ns_prefix FROM namespace_test WHERE id = 1), (SELECT ns_uri FROM namespace_test WHERE id = 1), (SELECT persistence FROM namespace_test WHERE id = 1));