CREATE TABLE test_types (id INT, type_value INT);
INSERT INTO test_types VALUES (1, 0), (2, 1), (3, 2), (4, 3);
CREATE TABLE type_mapping (type_id INT, type_name STRING);
INSERT INTO type_mapping VALUES (0, 'Undefined'), (1, 'Integer'), (2, 'String'), (3, 'Boolean');
SELECT internal_type_name(0) AS type_description;
SELECT internal_type_name(1) AS type_description;
SELECT internal_type_name((SELECT MAX(type_value) FROM test_types)) AS type_description FROM DUAL;
SELECT dv_type_title(0) AS title_description;
SELECT dv_type_title(2) AS title_description;
SELECT a.type_value, b.type_name FROM test_types a JOIN type_mapping b ON a.type_value = b.type_id WHERE a.id < 5;
SELECT internal_type_name(type_value) FROM test_types WHERE type_value IN (SELECT type_id FROM type_mapping) ORDER BY id;
SELECT DISTINCT dv_type_title(type_value) FROM test_types WHERE type_value >= 0 AND type_value <= 3;
SELECT COUNT(*) FROM test_types WHERE internal_type_name(type_value) IS NOT NULL;
SELECT internal_type_name(COALESCE((SELECT type_value FROM test_types WHERE id = 5), 0)) AS default_type_description;
SELECT a.id, b.type_name FROM test_types a LEFT JOIN type_mapping b ON a.type_value = b.type_id WHERE a.id NOT IN (SELECT id FROM test_types WHERE type_value IS NULL);