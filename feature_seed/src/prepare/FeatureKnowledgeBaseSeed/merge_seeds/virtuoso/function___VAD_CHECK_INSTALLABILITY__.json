CREATE TABLE package_info (package_name VARCHAR(255), version VARCHAR(20), status VARCHAR(20));
INSERT INTO package_info (package_name, version, status) VALUES ('Virtuoso', '7.2.1', 'installed');
INSERT INTO package_info (package_name, version, status) VALUES ('Virtuoso', '7.2.1', 'not_installed');
INSERT INTO package_info (package_name, version, status) VALUES ('SomePackage', '1.0.0', 'installed');
INSERT INTO package_info (package_name, version, status) VALUES ('AnotherPackage', '2.3.4', 'installed');
SELECT * FROM package_info WHERE status = 'installed';
SELECT package_name, version FROM package_info WHERE status = 'not_installed' AND version < '7.2.0';
SELECT COUNT(*) FROM package_info WHERE status = 'installed' AND version = (SELECT MAX(version) FROM package_info WHERE package_name = 'Virtuoso');
SELECT DISTINCT version FROM package_info WHERE package_name IN (SELECT package_name FROM package_info WHERE status = 'installed');
SELECT a.package_name, b.version FROM package_info a JOIN package_info b ON a.status = b.status WHERE a.package_name <> b.package_name;
SELECT package_name, version FROM package_info WHERE package_name NOT IN (SELECT package_name FROM package_info WHERE status = 'installed') AND version NOT LIKE '%.0';
SELECT a.package_name, a.version FROM package_info a WHERE a.status = 'installed' AND NOT EXISTS (SELECT 1 FROM package_info b WHERE b.package_name = a.package_name AND b.version < a.version);
UPDATE package_info SET status = 'not_installed' WHERE package_name = 'SomePackage' AND version = '1.0.0';
DELETE FROM package_info WHERE package_name = 'AnotherPackage' AND version < '2.0.0';
SELECT AVG(LENGTH(version)) FROM package_info WHERE status = 'installed';
WITH installed_packages AS (SELECT package_name FROM package_info WHERE status = 'installed') SELECT COUNT(*) FROM installed_packages;
SELECT a.package_name, (SELECT COUNT(*) FROM package_info b WHERE b.package_name = a.package_name AND b.status = 'installed') AS install_count FROM package_info a GROUP BY a.package_name;