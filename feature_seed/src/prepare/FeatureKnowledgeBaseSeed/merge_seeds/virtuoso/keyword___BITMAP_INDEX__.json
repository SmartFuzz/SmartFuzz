CREATE TABLE article (id INT, status_flag INT, title VARCHAR(255));
CREATE BITMAP INDEX idx_flags ON article (status_flag);
INSERT INTO article (id, status_flag, title) VALUES (1, 0, 'First Article');
INSERT INTO article (id, status_flag, title) VALUES (2, 1, 'Second Article');
INSERT INTO article (id, status_flag, title) VALUES (3, 1, 'Third Article');
INSERT INTO article (id, status_flag, title) VALUES (4, 0, 'Fourth Article');
SELECT title FROM article WHERE status_flag = 1;
CREATE TABLE comments (id INT, article_id INT, content VARCHAR(255));
INSERT INTO comments (id, article_id, content) VALUES (1, 1, 'Comment on First Article');
INSERT INTO comments (id, article_id, content) VALUES (2, 2, 'Comment on Second Article');
INSERT INTO comments (id, article_id, content) VALUES (3, 3, 'Comment on Third Article');
CREATE BITMAP INDEX idx_article_comments ON comments (article_id);
SELECT a.title FROM article a JOIN comments c ON a.id = c.article_id WHERE a.status_flag = 1;
SELECT a.title, COUNT(c.id) AS comment_count FROM article a LEFT JOIN comments c ON a.id = c.article_id GROUP BY a.id HAVING a.status_flag = 0;
SELECT a.title FROM article a WHERE EXISTS (SELECT 1 FROM comments c WHERE c.article_id = a.id);
CREATE TABLE users (id INT, name VARCHAR(255), status_flag INT);
CREATE BITMAP INDEX idx_user_status ON users (status_flag);
INSERT INTO users (id, name, status_flag) VALUES (1, 'User One', 1);
INSERT INTO users (id, name, status_flag) VALUES (2, 'User Two', 0);
SELECT name FROM users WHERE status_flag IN (SELECT status_flag FROM article WHERE status_flag = 1);
SELECT a.title, u.name FROM article a JOIN users u ON a.status_flag = u.status_flag;
CREATE TABLE tags (id INT, tag_name VARCHAR(100), status_flag INT);
CREATE BITMAP INDEX idx_tags ON tags (status_flag);
INSERT INTO tags (id, tag_name, status_flag) VALUES (1, 'Tag1', 1);
INSERT INTO tags (id, tag_name, status_flag) VALUES (2, 'Tag2', 0);
INSERT INTO tags (id, tag_name, status_flag) VALUES (3, 'Tag3', 1);
SELECT t.tag_name FROM tags t WHERE t.status_flag = (SELECT MAX(status_flag) FROM tags);