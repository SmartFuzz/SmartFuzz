CREATE TABLE ANN_PHRASES (id INTEGER PRIMARY KEY, phrase_name VARCHAR(255), advertiser_id VARCHAR(50));
INSERT INTO ANN_PHRASES (id, phrase_name, advertiser_id) VALUES (1, 'simple test', 'dba');
INSERT INTO ANN_PHRASES (id, phrase_name, advertiser_id) VALUES (2, 'another test', 'dba');
SELECT ANN_PHRASE_CLASS_DEL('simple test', 'dba', 'dba');
SELECT ANN_PHRASE_CLASS_DEL('another test', 'dba', 'dba');
INSERT INTO ANN_PHRASES (id, phrase_name, advertiser_id) VALUES (3, 'test for deletion', 'advertiser1');
SELECT ANN_PHRASE_CLASS_DEL('test for deletion', 'advertiser1', 'advertiser1');
CREATE TABLE ADVERTISERS (ads_id INTEGER PRIMARY KEY, name VARCHAR(255));
INSERT INTO ADVERTISERS (ads_id, name) VALUES (1, 'advertiser1');
INSERT INTO ADVERTISERS (ads_id, name) VALUES (2, 'advertiser2');
SELECT ANN_PHRASE_CLASS_DEL('simple test', 'advertiser1', 'dba');
INSERT INTO ANN_PHRASES (id, phrase_name, advertiser_id) VALUES (4, 'test edge case', 'advertiser2');
SELECT ANN_PHRASE_CLASS_DEL('test edge case', 'advertiser2', 'advertiser2');
SELECT ANN_PHRASE_CLASS_DEL('non_existing_phrase', 'dba', 'dba');
SELECT ANN_PHRASE_CLASS_DEL(NULL, 'dba', 'dba');
SELECT ANN_PHRASE_CLASS_DEL('simple test', NULL, 'dba');
SELECT ANN_PHRASE_CLASS_DEL('simple test', 'dba', NULL);
SELECT ANN_PHRASE_CLASS_DEL('another test', '', 'dba');
SELECT ANN_PHRASE_CLASS_DEL('simple test', 'dba', 'advertiser1');
CREATE TABLE ADVERTISER_PHRASES (ad_id INTEGER, phrase_id INTEGER, PRIMARY KEY (ad_id, phrase_id), FOREIGN KEY (phrase_id) REFERENCES ANN_PHRASES(id));
INSERT INTO ADVERTISER_PHRASES (ad_id, phrase_id) VALUES (1, 1);
