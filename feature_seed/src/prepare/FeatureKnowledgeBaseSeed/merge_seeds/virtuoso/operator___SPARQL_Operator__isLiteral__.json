CREATE GRAPH <http://example.org/graph1>;
INSERT DATA { GRAPH <http://example.org/graph1> { <http://example.org/resource1> <http://example.org/property> "Literal Value" . } };
SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s <http://example.org/property> ?o . FILTER(isLiteral(?o)) } };
CREATE TABLE test_literals (id INT, value VARCHAR);
INSERT INTO test_literals (id, value) VALUES (1, 'Test String'), (2, 'Another Literal');
SELECT * FROM test_literals WHERE value = 'Test String' AND isLiteral(value);
WITH { SELECT ?s WHERE { GRAPH <http://example.org/graph1> { ?s <http://example.org/property> ?o . FILTER(isLiteral(?o)) } } } AS literals SELECT ?s WHERE { ?s <http://example.org/relatedTo> ?o . ?o ?p ?literal . FILTER(isLiteral(?literal));
};
INSERT DATA { GRAPH <http://example.org/graph2> { <http://example.org/resource2> <http://example.org/property> 'Another Literal' . } };
SELECT ?o WHERE { GRAPH <http://example.org/graph2> { <http://example.org/resource2> <http://example.org/property> ?o . FILTER(isLiteral(?o)) } };
INSERT INTO test_literals (id, value) VALUES (3, 'Third Literal');
SELECT id, value FROM test_literals WHERE isLiteral(value) AND id = (SELECT MAX(id) FROM test_literals);