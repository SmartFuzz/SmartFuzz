CREATE TABLE datetime_test (id INT, timestamp DATETIME);
INSERT INTO datetime_test (id, timestamp) VALUES (1, sysutcdatetime());
INSERT INTO datetime_test (id, timestamp) VALUES (2, sysutcdatetime(500));
SELECT * FROM datetime_test WHERE timestamp > sysutcdatetime();
SELECT * FROM datetime_test WHERE timestamp BETWEEN sysutcdatetime(1000) AND sysutcdatetime(2000);
SELECT id, timestamp, sysutcdatetime(1) AS adjusted_timestamp FROM datetime_test WHERE id = 1;
WITH adjusted_times AS (SELECT id, sysutcdatetime(2) AS new_time FROM datetime_test) SELECT * FROM adjusted_times WHERE new_time IS NOT NULL;
SELECT dt.id, dt.timestamp FROM datetime_test dt JOIN (SELECT sysutcdatetime() AS now_time) current_time ON dt.timestamp < current_time.now_time;
SELECT MAX(timestamp) FROM datetime_test WHERE timestamp < sysutcdatetime(100);
SELECT id FROM datetime_test WHERE timestamp IN (SELECT sysutcdatetime() FROM datetime_test WHERE id = 1);
SELECT dt.id, dt.timestamp FROM datetime_test dt WHERE dt.timestamp = sysutcdatetime(0) OR dt.timestamp = sysutcdatetime(1);
UPDATE datetime_test SET timestamp = sysutcdatetime(100) WHERE id = 1;
DELETE FROM datetime_test WHERE timestamp < sysutcdatetime();
SELECT COUNT(*) FROM datetime_test WHERE timestamp IS NOT NULL;
SELECT dt1.id, dt1.timestamp, dt2.timestamp FROM datetime_test dt1 JOIN datetime_test dt2 ON dt1.timestamp > dt2.timestamp;
SELECT sysutcdatetime() AS current_time, (SELECT COUNT(*) FROM datetime_test) AS record_count;