CREATE TABLE test_strings (id INT, description VARCHAR(255));
INSERT INTO test_strings (id, description) VALUES (1, 'Joe Smith, 10045 Berry Lane, San Joseph, CA 91234');
INSERT INTO test_strings (id, description) VALUES (2, 'The code 1234 is broken at levels 5.0 and 54321.');
INSERT INTO test_strings (id, description) VALUES (3, 'My postal code is 94043.');
INSERT INTO test_strings (id, description) VALUES (4, '4567-8901-2345 and 87654 not a match');
SELECT REGEXP_INSTR(description, '[[:digit:]]{5}', 1, 1) AS first_occurrence FROM test_strings WHERE id = 1;
SELECT REGEXP_INSTR(description, '([[:digit:]]{4})', 1, 1) AS first_occurrence FROM test_strings WHERE id = 2;
SELECT REGEXP_INSTR(description, '^[[:digit:]]{5}', 1, 1) AS first_occurrence FROM test_strings WHERE id = 3;
SELECT REGEXP_INSTR(description, '[[:digit:]]{5}', 1, 2) AS second_occurrence FROM test_strings WHERE id = 4;
SELECT id, REGEXP_INSTR(description, '[aeiou]', 1, 1) AS first_vowel_occurrence FROM test_strings;
SELECT a.id, REGEXP_INSTR(b.description, '[[:alpha:]]+', 1, 1) AS first_alpha_occurrence FROM test_strings a JOIN test_strings b ON a.id = b.id;
SELECT REGEXP_INSTR('Start at 12345, move to 67890', '[[:digit:]]{5}', 10, 1) AS occurrence_after_tenth_character;
SELECT id, REGEXP_INSTR(description, 'not a match', 1, 1) AS no_match_occurrence FROM test_strings WHERE REGEXP_INSTR(description, 'not a match', 1, 1) = 0;
SELECT DISTINCT REGEXP_INSTR(description, '^[0-9]', 1, 1) AS starts_with_digit FROM test_strings;
SELECT REGEXP_INSTR(description, '[0-9]+', 1, 1) AS first_digit_occurrence FROM (SELECT description FROM test_strings WHERE id > 2) AS subquery;
SELECT REGEXP_INSTR(description, '[0-9]{5}', 1, 1) AS five_digit_occurrence FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE description LIKE '%CA%');