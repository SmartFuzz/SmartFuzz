CREATE TABLE test_data (id INTEGER PRIMARY KEY, data VARCHAR(255));
INSERT INTO test_data (id, data) VALUES (1, 'test data 1');
INSERT INTO test_data (id, data) VALUES (2, 'test data 2');
INSERT INTO test_data (id, data) VALUES (3, 'another test data');
INSERT INTO test_data (id, data) VALUES (4, 'data with special char !@#');
INSERT INTO test_data (id, data) VALUES (5, '');
SELECT bif:crc64(data) AS crc_value FROM test_data WHERE id = 1;
SELECT bif:crc64(data) AS crc_value FROM test_data WHERE data IS NOT NULL;
SELECT bif:crc64(data) AS crc_value FROM test_data WHERE LENGTH(data) > 0;
SELECT t1.id, t2.crc_value FROM test_data AS t1 JOIN (SELECT id, bif:crc64(data) AS crc_value FROM test_data) AS t2 ON t1.id = t2.id WHERE t1.id > 0;
SELECT bif:crc64(CONCAT(data, 'suffix')) AS crc_value FROM test_data WHERE id < 4;
SELECT bif:crc64(data) AS crc_value FROM test_data WHERE NOT data = 'test data 1';
SELECT DISTINCT bif:crc64(data) AS crc_value FROM test_data;
SELECT bif:crc64(data) AS crc_value FROM test_data WHERE id IN (SELECT id FROM test_data WHERE LENGTH(data) > 0);
SELECT id, bif:crc64(data) AS crc_value FROM (SELECT id, data FROM test_data WHERE id <= 5) AS subquery WHERE data LIKE '%test%';
SELECT t1.id, bif:crc64(t1.data || t2.data) AS combined_crc FROM test_data AS t1 JOIN test_data AS t2 ON t1.id <> t2.id;