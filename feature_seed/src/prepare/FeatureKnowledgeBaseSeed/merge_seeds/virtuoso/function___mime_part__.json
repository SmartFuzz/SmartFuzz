CREATE TABLE mime_test (id INT PRIMARY KEY, part VARCHAR, encoding VARCHAR, content TEXT);
INSERT INTO mime_test (id, part, encoding, content) VALUES (1, 'part1', '8bit', 'this is the first part');
INSERT INTO mime_test (id, part, encoding, content) VALUES (2, 'part2', 'base64', 'dGhpcyBpcyBhIHNlY29uZA==');
SELECT MIME_BODY(vector(MIME_PART(null, null, encoding, content), MIME_PART(null, null, 'base64', 'dGhpcyBpcyBhIHNlY29uZA=='))) FROM mime_test WHERE id = 1;
SELECT MIME_BODY(vector(MIME_PART(null, null, null, 'text part'), MIME_PART(null, null, '7bit', 'another part'))) AS mime_message FROM mime_test WHERE id < 3;
SELECT MIME_BODY(vector(MIME_PART(null, null, null, 'Part A'), MIME_PART(null, null, 'quoted-printable', 'Part B'))) FROM (SELECT * FROM mime_test WHERE id = 1 UNION SELECT * FROM mime_test WHERE id = 2);
SELECT MIME_BODY(vector(MIME_PART(null, null, null, 'Nested Part'), MIME_PART(null, null, 'base64', (SELECT content FROM mime_test WHERE id = 1))) AS email_body FROM mime_test WHERE id = 1;
SELECT MIME_BODY(vector(MIME_PART(null, null, '7bit', 'Simple Text Part'), MIME_PART(null, null, 'base64', (SELECT encoding FROM mime_test WHERE part = 'part2'))) FROM mime_test LIMIT 1;
SELECT MIME_BODY(vector(MIME_PART(null, null, null, 'Outer Message Header'), MIME_PART(null, null, null, (SELECT content FROM mime_test WHERE part = 'part1'))) AS full_message FROM mime_test;
SELECT MIME_BODY(vector(MIME_PART(null, null, 'binary', 'First binary part'), MIME_PART(null, null, 'quoated-printable', 'Second binary part'))) FROM mime_test WHERE part IN (SELECT part FROM mime_test WHERE id BETWEEN 1 AND 2);