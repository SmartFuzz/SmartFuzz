CREATE TABLE businessEntity (id INT PRIMARY KEY, name VARCHAR(255), description TEXT, status VARCHAR(50));
CREATE TABLE externalRegistry (id INT PRIMARY KEY, businessEntityId INT, registryName VARCHAR(255), additionalAttributes TEXT, FOREIGN KEY (businessEntityId) REFERENCES businessEntity(id));
INSERT INTO businessEntity (id, name, description, status) VALUES (1, 'Business A', 'Description A', 'active');
INSERT INTO businessEntity (id, name, description, status) VALUES (2, 'Business B', 'Description B', 'inactive');
INSERT INTO externalRegistry (id, businessEntityId, registryName, additionalAttributes) VALUES (1, 1, 'Registry 1', '{"attr1":"value1", "attr2":"value2"}');
INSERT INTO externalRegistry (id, businessEntityId, registryName, additionalAttributes) VALUES (2, 1, 'Registry 2', '{"attr3":"value3"}');
INSERT INTO externalRegistry (id, businessEntityId, registryName, additionalAttributes) VALUES (3, 2, 'Registry 3', '{"attr4":"value4", "attr5":"value5"}');
SELECT b.id, b.name, b.description, b.status, e.registryName, e.additionalAttributes FROM businessEntity b LEFT JOIN externalRegistry e ON b.id = e.businessEntityId WHERE b.status = 'active';
SELECT b.id, b.name, b.description, (SELECT COUNT(*) FROM externalRegistry e WHERE e.businessEntityId = b.id) AS registry_count FROM businessEntity b WHERE b.status = 'inactive';
SELECT b.id, b.name, b.description, e.registryName, e.additionalAttributes FROM businessEntity b JOIN externalRegistry e ON b.id = e.businessEntityId WHERE e.additionalAttributes IS NOT NULL AND b.name LIKE 'Business%';
SELECT b.id, b.name, (SELECT GROUP_CONCAT(e.registryName) FROM externalRegistry e WHERE e.businessEntityId = b.id) AS registry_names FROM businessEntity b WHERE EXISTS (SELECT 1 FROM externalRegistry e WHERE e.businessEntityId = b.id);