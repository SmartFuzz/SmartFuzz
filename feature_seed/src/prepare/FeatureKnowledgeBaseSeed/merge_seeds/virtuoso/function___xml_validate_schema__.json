CREATE TABLE xml_test (id INT PRIMARY KEY, xml_data VARCHAR, schema_location VARCHAR);
INSERT INTO xml_test (id, xml_data, schema_location) VALUES (1, '<root><element>value</element></root>', 'http://localhost.localdomain/schema.xsd');
INSERT INTO xml_test (id, xml_data, schema_location) VALUES (2, '<root><element></element></root>', NULL);
INSERT INTO xml_test (id, xml_data, schema_location) VALUES (3, '<root><element>value</element></root>', '');
DECLARE _result VARCHAR;
SET _result = xml_validate_schema((SELECT xml_data FROM xml_test WHERE id = 1), 0, (SELECT schema_location FROM xml_test WHERE id = 1), 'UTF-8', 'x-any', 'Validation=SGML FsaBadWs=IGNORE BuildStandalone=ENABLE MaxErrors=100');
DECLARE _result VARCHAR;
SET _result = xml_validate_schema((SELECT xml_data FROM xml_test WHERE id = 2), 0, '', 'UTF-8', 'x-any', 'Validation=SGML FsaBadWs=IGNORE BuildStandalone=ENABLE MaxErrors=100');
DECLARE _result VARCHAR;
SET _result = xml_validate_schema((SELECT xml_data FROM xml_test WHERE id = 3), 0, 'http://localhost.localdomain/schema.xsd', 'UTF-8', 'x-any', 'Validation=SGML FsaBadWs=IGNORE BuildStandalone=ENABLE MaxErrors=100');
CREATE TABLE xml_validation_results (test_id INT, error_message VARCHAR);
INSERT INTO xml_validation_results (test_id, error_message) VALUES (1, _result);
INSERT INTO xml_validation_results (test_id, error_message) SELECT id, xml_validate_schema(xml_data, 0, schema_location, 'UTF-8', 'x-any', 'Validation=SGML FsaBadWs=IGNORE BuildStandalone=ENABLE MaxErrors=100') FROM xml_test;
SELECT * FROM xml_validation_results WHERE error_message IS NOT NULL;