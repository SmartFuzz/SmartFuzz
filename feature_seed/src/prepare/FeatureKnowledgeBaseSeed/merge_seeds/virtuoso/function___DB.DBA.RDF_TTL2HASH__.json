CREATE GRAPH test_graph;
INSERT DATA { GRAPH test_graph { <http://example.org/subject1> <http://example.org/predicate1> <http://example.org/object1> . } };
INSERT DATA { GRAPH test_graph { <http://example.org/subject2> <http://example.org/predicate2> <http://example.org/object2> . } };
INSERT DATA { GRAPH test_graph { <http://example.org/subject3> <http://example.org/predicate3> <http://example.org/object3> . } };
SELECT * FROM DB.DBA.RDF_TTL2HASH('test_graph') AS dict WHERE dict['<http://example.org/subject1>'] IS NOT NULL;
SELECT * FROM DB.DBA.RDF_TTL2HASH('test_graph') AS dict WHERE dict['<http://example.org/subject2>'] IS NOT NULL AND dict['<http://example.org/subject3>'] IS NOT NULL;
WITH temp AS (SELECT dict FROM DB.DBA.RDF_TTL2HASH('test_graph')) SELECT * FROM temp WHERE temp.dict['<http://example.org/subject1>'] = '<http://example.org/object1>';
SELECT dict1, dict2 FROM (SELECT dict FROM DB.DBA.RDF_TTL2HASH('test_graph')) AS dict1 JOIN (SELECT dict FROM DB.DBA.RDF_TTL2HASH('test_graph')) AS dict2 ON dict1['<http://example.org/subject2>'] = dict2['<http://example.org/subject3>'];
SELECT * FROM DB.DBA.RDF_TTL2HASH('test_graph') WHERE 'long valmode' IN (SELECT 'long valmode' FROM DB.DBA.RDF_TTL2HASH('test_graph') LIMIT 10);