CREATE TABLE test_xml (id INT, xml_data XMLType);
INSERT INTO test_xml (id, xml_data) VALUES (1, XMLType('<valid><data /></valid>', 'file://xmlschema/test0001/clean.xsd'));
INSERT INTO test_xml (id, xml_data) VALUES (2, XMLType('<invalid><data /></invalid>', 'file://xmlschema/test0001/clean.xsd'));
SELECT xml_data.isSchemaValid('file://xmlschema/test0001/clean.xsd') FROM test_xml WHERE id = 1;
SELECT xml_data.isSchemaValid('file://xmlschema/test0001/clean.xsd') FROM test_xml WHERE id = 2;
SELECT id, xml_data.isSchemaValid('file://non_existent_schema.xsd') FROM test_xml;
INSERT INTO test_xml (id, xml_data) VALUES (3, XMLType('<root><child></child></root>'));
SELECT xml_data.isSchemaValid() FROM test_xml WHERE id = 3;
CREATE TABLE test_xml_multi (id INT, xml_data XMLType);
INSERT INTO test_xml_multi (id, xml_data) SELECT id, XMLType('<valid><data /></valid>', 'file://xmlschema/test0001/clean.xsd') FROM test_xml;
SELECT t1.xml_data.isSchemaValid('file://xmlschema/test0001/clean.xsd') FROM test_xml t1 JOIN test_xml_multi t2 ON t1.id = t2.id;
SELECT t.xml_data.isSchemaValid('file://xmlschema/test0001/clean.xsd') FROM (SELECT xml_data FROM test_xml) t;
INSERT INTO test_xml (id, xml_data) VALUES (4, XMLType('<complex><data nested="true"/></complex>', 'file://xmlschema/test0002/complex.xsd'));
SELECT xml_data.isSchemaValid('file://xmlschema/test0002/complex.xsd') FROM test_xml WHERE id = 4;