CREATE TABLE TestTable (ID INT, Name VARCHAR(100));
INSERT INTO TestTable (ID, Name) VALUES (1, 'Alice');
INSERT INTO TestTable (ID, Name) VALUES (2, 'Bob');
CREATE CURSOR TestCursor FOR SELECT * FROM TestTable;
OPEN TestCursor;
FETCH TestCursor;
DECLARE @Bookmark VARBINARY;
SET @Bookmark = BOOKMARK(TestCursor);
FETCH TestCursor BOOKMARK @Bookmark;
CREATE TABLE AnotherTable (ID INT, Description VARCHAR(255));
INSERT INTO AnotherTable (ID, Description) VALUES (1, 'First Description');
INSERT INTO AnotherTable (ID, Description) VALUES (2, 'Second Description');
CREATE CURSOR AnotherCursor FOR SELECT * FROM AnotherTable;
OPEN AnotherCursor;
DECLARE @AnotherBookmark VARBINARY;
SET @AnotherBookmark = BOOKMARK(AnotherCursor);
FETCH AnotherCursor;
SELECT * FROM TestTable WHERE ID IN (SELECT ID FROM AnotherTable WHERE ID = 1);
FETCH TestCursor BOOKMARK NULL;
CLOSE TestCursor;
CLOSE AnotherCursor;