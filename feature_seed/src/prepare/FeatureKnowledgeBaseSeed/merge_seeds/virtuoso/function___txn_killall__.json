CREATE TABLE test_table (id INT PRIMARY KEY, value VARCHAR(255));
INSERT INTO test_table (id, value) VALUES (1, 'First'), (2, 'Second'), (3, 'Third');
BEGIN;
INSERT INTO test_table (id, value) VALUES (4, 'Fourth');
SELECT * FROM test_table WHERE id = 4;
COMMIT;
BEGIN;
INSERT INTO test_table (id, value) VALUES (5, 'Fifth');
SELECT * FROM test_table WHERE id = 5;
ROLLBACK;
BEGIN;
SELECT * FROM test_table WHERE value = (SELECT value FROM test_table WHERE id = 2);
INSERT INTO test_table (id, value) VALUES (6, 'Sixth');
COMMIT;
BEGIN;
UPDATE test_table SET value = 'Updated' WHERE id = (SELECT id FROM test_table WHERE value = 'Third');
COMMIT;
BEGIN;
INSERT INTO test_table (id, value) VALUES (7, (SELECT value FROM test_table WHERE id = 1));
COMMIT;
BEGIN;
DELETE FROM test_table WHERE id = (SELECT id FROM test_table ORDER BY RANDOM() LIMIT 1);
ROLLBACK;
BEGIN;
UPDATE test_table SET value = 'Changed' WHERE id IN (SELECT id FROM test_table WHERE value LIKE 'F%');
COMMIT;
BEGIN;
INSERT INTO test_table (id, value) SELECT 8, 'Eighth' UNION SELECT 9, 'Ninth';
COMMIT;
