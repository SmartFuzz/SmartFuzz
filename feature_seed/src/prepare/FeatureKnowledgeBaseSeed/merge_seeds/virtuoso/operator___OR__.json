CREATE TABLE test_table_1 (id INTEGER, value BOOLEAN);
INSERT INTO test_table_1 (id, value) VALUES (1, TRUE);
INSERT INTO test_table_1 (id, value) VALUES (2, FALSE);
SELECT id, value FROM test_table_1 WHERE value = TRUE OR id = 2;
CREATE TABLE test_table_2 (id INTEGER, description VARCHAR(255));
INSERT INTO test_table_2 (id, description) VALUES (1, 'Test 1');
INSERT INTO test_table_2 (id, description) VALUES (2, 'Test 2');
SELECT a.id, a.value FROM test_table_1 AS a JOIN test_table_2 AS b ON a.id = b.id WHERE a.value = TRUE OR b.description = 'Test 2';
CREATE TABLE test_table_3 (id INTEGER, flags BOOLEAN);
INSERT INTO test_table_3 (id, flags) VALUES (1, TRUE), (2, TRUE), (3, FALSE);
SELECT id FROM test_table_3 WHERE flags = TRUE OR id IN (SELECT id FROM test_table_1 WHERE value = FALSE);
SELECT id, (SELECT COUNT(*) FROM test_table_1) AS total FROM test_table_3 WHERE flags = TRUE OR total > 0;
CREATE TABLE test_table_4 (id INTEGER, status BOOLEAN);
INSERT INTO test_table_4 (id, status) VALUES (1, TRUE), (2, FALSE), (3, TRUE);
SELECT id FROM test_table_4 WHERE status = FALSE OR id < 3;
SELECT id FROM (SELECT id FROM test_table_4 WHERE status = TRUE) AS valid_ids WHERE id OR FALSE;
CREATE TABLE complex_table_1 (id INTEGER, type VARCHAR(50));
INSERT INTO complex_table_1 (id, type) VALUES (1, 'A'), (2, 'B');
SELECT id FROM complex_table_1 WHERE type = 'A' OR (SELECT MIN(id) FROM complex_table_1) = 2;
SELECT * FROM complex_table_1 WHERE id > 0 OR EXISTS (SELECT 1 FROM test_table_1 WHERE value = TRUE);