CREATE TABLE transactions (id INT PRIMARY KEY, transaction_time TIMESTAMP);
INSERT INTO transactions (id, transaction_time) VALUES (1, get_timestamp());
INSERT INTO transactions (id, transaction_time) VALUES (2, get_timestamp() + INTERVAL '1 hour');
INSERT INTO transactions (id, transaction_time) VALUES (3, get_timestamp() - INTERVAL '1 day');
SELECT id, transaction_time FROM transactions WHERE transaction_time >= get_timestamp() - INTERVAL '1 month';
SELECT COUNT(*) FROM transactions WHERE transaction_time < get_timestamp();
SELECT id, transaction_time FROM transactions WHERE transaction_time = (SELECT MAX(transaction_time) FROM transactions);
SELECT T1.id FROM transactions T1 JOIN transactions T2 ON T1.transaction_time = T2.transaction_time WHERE T1.id != T2.id;
SELECT id, transaction_time FROM transactions ORDER BY transaction_time DESC LIMIT 5;
CREATE INDEX idx_transaction_time ON transactions (transaction_time);
SELECT id FROM transactions WHERE transaction_time BETWEEN get_timestamp() - INTERVAL '1 week' AND get_timestamp();
WITH recent_transactions AS (SELECT id, transaction_time FROM transactions WHERE transaction_time > get_timestamp() - INTERVAL '2 days') SELECT COUNT(*) FROM recent_transactions;