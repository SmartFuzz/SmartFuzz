CREATE TABLE mydsn..rb_test (ID INT PRIMARY KEY, Value VARCHAR(255));
DELETE FROM mydsn..rb_test;
COMMIT WORK;
CREATE PROCEDURE TEST_COMMIT () { COMMIT WORK;
INSERT INTO mydsn..rb_test VALUES (1, 'First Entry');
sql_transact('mydsn');
INSERT INTO mydsn..rb_test VALUES (2, 'Second Entry');
COMMIT WORK;
};
CREATE PROCEDURE TEST_ROLLBACK () { COMMIT WORK;
INSERT INTO mydsn..rb_test VALUES (1, 'First Entry');
sql_transact('mydsn', 1);
INSERT INTO mydsn..rb_test VALUES (2, 'Second Entry');
ROLLBACK WORK;
};
CREATE SELECT STATEMENT FOR LOGGING: SELECT ID, Value FROM mydsn..rb_test WHERE ID IN (SELECT ID FROM mydsn..rb_test WHERE Value LIKE 'Entry%');
INSERT INTO mydsn..rb_test VALUES (1, 'Rollback Test');
CALL TEST_ROLLBACK();
SELECT * FROM mydsn..rb_test WHERE ID = 1;
COMMIT WORK;
CALL TEST_COMMIT();
SELECT MIN(ID) FROM mydsn..rb_test;
INSERT INTO mydsn..rb_test VALUES (3, 'Third Entry');
COMMIT WORK;
SELECT ID, Value FROM mydsn..rb_test WHERE ID >= (SELECT MIN(ID) FROM mydsn..rb_test);
DELETE FROM mydsn..rb_test WHERE ID > 1;
COMMIT WORK;
CREATE PROCEDURE TEST_NESTED () { COMMIT WORK;
INSERT INTO mydsn..rb_test VALUES (1, 'Outer Entry');
sql_transact('mydsn');
CREATE PROCEDURE NESTED_PROC () { INSERT INTO mydsn..rb_test VALUES (2, 'Nested Entry');
};
CALL NESTED_PROC();
COMMIT WORK;
};
CALL TEST_NESTED();
SELECT ID, (SELECT COUNT(*) FROM mydsn..rb_test) AS TotalEntries FROM mydsn..rb_test WHERE Value IS NOT NULL;
CREATE TABLE mydsn..secondary_table (RelatedID INT, Description VARCHAR(255));
INSERT INTO mydsn..secondary_table VALUES (1, 'Description for Entry 1');
INSERT INTO mydsn..secondary_table VALUES (2, 'Description for Entry 2');
SELECT rb.ID, st.Description FROM mydsn..rb_test rb JOIN mydsn..secondary_table st ON rb.ID = st.RelatedID;
sql_transact('mydsn');
UPDATE mydsn..rb_test SET Value = 'Updated Entry' WHERE ID = 1;
COMMIT WORK;