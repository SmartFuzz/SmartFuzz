CREATE TABLE test_table (id INT, flag1 BOOLEAN, flag2 BOOLEAN);
INSERT INTO test_table (id, flag1, flag2) VALUES (1, TRUE, TRUE);
INSERT INTO test_table (id, flag1, flag2) VALUES (2, TRUE, FALSE);
INSERT INTO test_table (id, flag1, flag2) VALUES (3, FALSE, TRUE);
INSERT INTO test_table (id, flag1, flag2) VALUES (4, FALSE, FALSE);
SELECT id FROM test_table WHERE flag1 AND flag2;
SELECT (SELECT COUNT(*) FROM test_table WHERE flag1) AND (SELECT COUNT(*) FROM test_table WHERE flag2);
SELECT id FROM test_table WHERE flag1 AND (SELECT COUNT(*) FROM test_table WHERE flag2) > 0;
SELECT id FROM test_table AS t1 JOIN test_table AS t2 ON t1.id = t2.id WHERE t1.flag1 AND t2.flag2;
SELECT * FROM (SELECT id, flag1 AND flag2 AS result FROM test_table) AS derived_table WHERE result;
SELECT id FROM test_table WHERE (flag1 OR flag2) AND flag1;
SELECT id FROM test_table WHERE flag1 AND NOT flag2;
SELECT id FROM test_table WHERE EXISTS (SELECT 1 FROM test_table t2 WHERE t2.flag1 AND t2.flag2);
SELECT id FROM test_table WHERE flag1 = TRUE AND (SELECT COUNT(*) FROM test_table WHERE flag1) > 1;
SELECT t1.id FROM test_table t1, test_table t2 WHERE t1.flag1 AND t2.flag2 AND t1.id != t2.id;