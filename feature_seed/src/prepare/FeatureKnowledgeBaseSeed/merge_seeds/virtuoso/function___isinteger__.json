CREATE TABLE test_integers (id INT, value INT);
INSERT INTO test_integers (id, value) VALUES (1, 5);
INSERT INTO test_integers (id, value) VALUES (2, NULL);
INSERT INTO test_integers (id, value) VALUES (3, 'test');
INSERT INTO test_integers (id, value) VALUES (4, 0);
INSERT INTO test_integers (id, value) VALUES (5, -10);
INSERT INTO test_integers (id, value) VALUES (6, -1);
SELECT id, value, isinteger(value) AS is_integer FROM test_integers;
SELECT id, value FROM test_integers WHERE isinteger(value) = 1;
SELECT id FROM (SELECT id, value FROM test_integers WHERE isinteger(value) = 1) AS filtered;
SELECT ti.id FROM test_integers ti JOIN (SELECT id, value FROM test_integers WHERE value = 0) AS zero ON ti.id = zero.id;
SELECT COUNT(*) FROM (SELECT id FROM test_integers WHERE isinteger(value) = 0) AS non_integers;
SELECT (SELECT COUNT(*) FROM test_integers WHERE isinteger(value) = 1) AS integer_count, (SELECT COUNT(*) FROM test_integers) AS total_count;
SELECT id, value FROM test_integers WHERE isinteger(value) IN (SELECT value FROM test_integers WHERE id < 3) AND id > 0;
SELECT DISTINCT ti.id FROM test_integers ti LEFT JOIN test_integers tj ON ti.value = tj.value WHERE isinteger(ti.value) = 1;
SELECT ti.id FROM test_integers ti WHERE EXISTS (SELECT 1 FROM test_integers tj WHERE ti.id = tj.id AND isinteger(tj.value) = 1);