CREATE TABLE sales (id INT, amount NUMERIC);
INSERT INTO sales (id, amount) VALUES (1, 100.0), (2, 150.0), (3, 200.0);
SELECT STDDEV_SAMP(amount) FROM sales;
CREATE TABLE products (id INT, price NUMERIC);
INSERT INTO products (id, price) VALUES (1, 10.0), (2, 20.0), (3, 30.0);
SELECT STDDEV_SAMP(price) FROM products;
SELECT STDDEV_SAMP(subquery.amount) FROM (SELECT amount FROM sales) AS subquery;
SELECT p.id, STDDEV_SAMP(s.amount) FROM products p JOIN sales s ON p.id = s.id GROUP BY p.id;
CREATE TABLE orders (order_id INT, customer_id INT, total NUMERIC);
INSERT INTO orders (order_id, customer_id, total) VALUES (1, 1, 300.0), (2, 2, 400.0), (3, 2, 500.0);
SELECT STDDEV_SAMP(total) FROM orders;
SELECT STDDEV_SAMP(a.amount) FROM (SELECT amount FROM sales WHERE amount > 100) AS a;
SELECT AVG(price), STDDEV_SAMP(price) FROM products WHERE price < 25;
SELECT customer_id, STDDEV_SAMP(total) FROM orders GROUP BY customer_id HAVING STDDEV_SAMP(total) IS NOT NULL;
SELECT STDDEV_SAMP(amount) FROM (SELECT amount FROM sales UNION SELECT amount FROM orders) AS combined;
SELECT STDDEV_SAMP(derived.amount) FROM (SELECT id, amount FROM sales WHERE id IN (1, 2)) AS derived;