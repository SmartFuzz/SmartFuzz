CREATE TABLE foaf_namespace (namespace VARCHAR, predicate VARCHAR);
INSERT INTO foaf_namespace VALUES ('foaf', 'knows');
INSERT INTO foaf_namespace VALUES ('foaf', 'likes');
SELECT __xml_ns_iristr(namespace, predicate) FROM foaf_namespace WHERE namespace = 'foaf';
SELECT __xml_ns_iristr(namespace, 'knows') AS iri_knows, __xml_ns_iristr(namespace, 'likes') AS iri_likes FROM foaf_namespace;
CREATE TABLE rdf_data (subject VARCHAR, predicate VARCHAR, object VARCHAR);
INSERT INTO rdf_data VALUES ('http://example.org/person1', 'foaf:knows', 'http://example.org/person2');
SELECT __xml_ns_iristr('foaf', 'knows') AS iri FROM rdf_data WHERE subject = 'http://example.org/person1';
SELECT __xml_ns_iristr('foaf', 'knows') AS iri_knows, __xml_ns_iristr('foaf', 'likes') AS iri_likes FROM rdf_data WHERE object LIKE 'http://example.org/%';
SELECT COUNT(*), __xml_ns_iristr('foaf', 'knows') FROM rdf_data GROUP BY __xml_ns_iristr('foaf', 'knows');
SELECT a.subject, __xml_ns_iristr(a.namespace, a.predicate) FROM (SELECT 'http://example.org/person1' AS subject, 'foaf' AS namespace, 'knows' AS predicate) AS a;
SELECT __xml_ns_iristr('foaf', 'knows') AS iri FROM rdf_data WHERE predicate IN (SELECT predicate FROM foaf_namespace);
SELECT __xml_ns_iristr(namespace, predicate) AS iri FROM (SELECT DISTINCT namespace, predicate FROM foaf_namespace JOIN rdf_data ON foaf_namespace.predicate = rdf_data.predicate);