CREATE TABLE documents (id INT PRIMARY KEY, content XML);
INSERT INTO documents (id, content) VALUES (1, '<root><node>value1</node></root>');
INSERT INTO documents (id, content) VALUES (2, '<root><node>value2</node></root>');
UPDATE documents SET content = updateXML(content, '/root/node', '<node>newValue1</node>') WHERE id = 1;
SELECT id, updateXML(content, '/root/node', '<node>changedValue</node>') AS updated_content FROM documents WHERE id = 2;
SELECT id, updateXML((SELECT content FROM documents WHERE id = 1), '/root/node', '<node>nestedChange</node>') AS nested_updated_content FROM documents;
CREATE TABLE additional_data (id INT PRIMARY KEY, doc_id INT, FOREIGN KEY (doc_id) REFERENCES documents(id));
INSERT INTO additional_data (id, doc_id) VALUES (1, 1);
SELECT a.id, updateXML(d.content, '/root/node', '<node>mergedChange</node>') AS merged_content FROM documents d JOIN additional_data a ON d.id = a.doc_id;
UPDATE documents SET content = updateXML(content, '/root', '<newRoot><node>insertedValue</node></newRoot>') WHERE id = 2;
SELECT updateXML(content, '/root/node', '<node>updatedThroughJoin</node>') FROM documents d JOIN additional_data a ON d.id = a.doc_id WHERE a.id = 1;