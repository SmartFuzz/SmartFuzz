CREATE TABLE test_table (id INT, value1 INT, value2 INT);
INSERT INTO test_table (id, value1, value2) VALUES (1, 18, 6);
INSERT INTO test_table (id, value1, value2) VALUES (2, -18, -6);
INSERT INTO test_table (id, value1, value2) VALUES (3, 0, 0);
INSERT INTO test_table (id, value1, value2) VALUES (4, 2147483647, 1);
INSERT INTO test_table (id, value1, value2) VALUES (5, -2147483648, -1);
INSERT INTO test_table (id, value1, value2) VALUES (6, 1, 2147483647);
INSERT INTO test_table (id, value1, value2) VALUES (7, 1, -1);
INSERT INTO test_table (id, value1, value2) VALUES (8, -1, -1);
SELECT bit_and(value1, value2) FROM test_table WHERE id = 1;
SELECT bit_and(value1, value2) FROM test_table WHERE id = 2;
SELECT bit_and(value1, value2) FROM test_table WHERE id = 3;
SELECT bit_and(value1, value2) FROM test_table WHERE id = 4;
SELECT bit_and(value1, value2) FROM test_table WHERE id = 5;
SELECT bit_and(value1, value2) FROM test_table WHERE value1 > 0 AND value2 < 10;
SELECT bit_and((SELECT value1 FROM test_table WHERE id = 1), (SELECT value2 FROM test_table WHERE id = 2));
SELECT bit_and(value1, (SELECT MAX(value2) FROM test_table)) FROM test_table;
SELECT bit_and(value1, value2) AS bit_result FROM test_table ORDER BY bit_result DESC;
SELECT * FROM test_table WHERE bit_and(value1, value2) > 0;
SELECT SUM(bit_and(value1, value2)) FROM test_table;