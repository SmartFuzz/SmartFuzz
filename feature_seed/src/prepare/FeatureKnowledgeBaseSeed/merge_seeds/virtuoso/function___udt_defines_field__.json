CREATE TYPE SER_UDT AS (field1 VARCHAR(50), field2 INTEGER);
CREATE TYPE SER_UDT_SUB AS (field1 VARCHAR(50), field2 INTEGER, field3 BOOLEAN);
INSERT INTO SER_UDT (field1, field2) VALUES ('A', 1);
INSERT INTO SER_UDT (field1, field2) VALUES ('B', 2);
INSERT INTO SER_UDT_SUB (field1, field2, field3) VALUES ('A', 1, TRUE);
INSERT INTO SER_UDT_SUB (field1, field2, field3) VALUES ('B', 2, FALSE);
SELECT udt_defines_field(new SER_UDT(), 'field1');
SELECT udt_defines_field(new SER_UDT(), 'field2');
SELECT udt_defines_field(new SER_UDT(), 'field3');
SELECT udt_defines_field(new SER_UDT_SUB(), 'field1');
SELECT udt_defines_field(new SER_UDT_SUB(), 'field2');
SELECT udt_defines_field(new SER_UDT_SUB(), 'field3');
SELECT udt_defines_field(new SER_UDT(), 'A') AND udt_defines_field(new SER_UDT_SUB(), 'field1');
SELECT (SELECT udt_defines_field(new SER_UDT(), 'A') WHERE EXISTS (SELECT 1 FROM SER_UDT)) AS result;
SELECT COUNT(*) FROM (SELECT udt_defines_field(new SER_UDT(), 'B') AS field_exists) subquery WHERE field_exists;
SELECT CASE WHEN udt_defines_field(new SER_UDT(), 'B') THEN 'Exists' ELSE 'Does not exist' END AS field_check;
SELECT udt_defines_field(new SER_UDT_SUB(), 'field3') OR udt_defines_field(new SER_UDT(), 'A') AS field_check_combined;
SELECT udt_defines_field(new SER_UDT(), (SELECT 'field1' FROM dual)) AS dynamic_field_check;