CREATE TABLE coverage_results (id INT PRIMARY KEY, function_name VARCHAR(255), execution_time FLOAT, call_count INT);
INSERT INTO coverage_results (id, function_name, execution_time, call_count) VALUES (1, 'test_function_a', 0.123, 10);
INSERT INTO coverage_results (id, function_name, execution_time, call_count) VALUES (2, 'test_function_b', 0.456, 5);
SELECT * FROM coverage_results WHERE call_count > 0;
SELECT function_name, SUM(execution_time) AS total_time FROM coverage_results GROUP BY function_name HAVING total_time > 0.1;
CREATE TABLE function_details (id INT, function_name VARCHAR(255), details TEXT, FOREIGN KEY (id) REFERENCES coverage_results(id));
INSERT INTO function_details (id, function_name, details) VALUES (1, 'test_function_a', 'Detailed metrics about test function A.');
SELECT cr.function_name, fd.details FROM coverage_results cr JOIN function_details fd ON cr.id = fd.id WHERE cr.execution_time > 0;
SELECT cr.function_name, AVG(cr.execution_time) AS avg_time FROM coverage_results cr GROUP BY cr.function_name HAVING avg_time < 0.5;
CREATE INDEX idx_function_name ON coverage_results(function_name);
DELETE FROM coverage_results WHERE execution_time < 0.1;
UPDATE coverage_results SET call_count = call_count + 1 WHERE function_name = 'test_function_b';
SELECT COUNT(*) FROM coverage_results WHERE execution_time BETWEEN 0.1 AND 0.5;
SELECT function_name, MAX(execution_time) AS max_time FROM coverage_results GROUP BY function_name;
DROP TABLE IF EXISTS temp_coverage;
CREATE TEMP TABLE temp_coverage AS SELECT * FROM coverage_results WHERE call_count > 1;