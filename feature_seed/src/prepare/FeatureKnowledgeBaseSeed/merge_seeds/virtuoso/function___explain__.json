CREATE TABLE sys_users (U_ID INT, U_NAME VARCHAR(255), U_IS_ROLE BOOLEAN, U_FULL_NAME VARCHAR(255), U_E_MAIL VARCHAR(255), U_PASSWORD VARCHAR(255), U_GROUP VARCHAR(255), U_LOGIN_TIME TIMESTAMP, U_ACCOUNT_DISABLED BOOLEAN, U_DAV_ENABLE BOOLEAN, U_SQL_ENABLE BOOLEAN, U_DATA TEXT, U_METHODS TEXT, U_DEF_PERMS TEXT, U_HOME TEXT, U_PASSWORD_HOOK TEXT, U_PASSWORD_HOOK_DATA TEXT, U_GET_PASSWORD TEXT, U_DEF_QUAL TEXT, U_OPTS TEXT);
CREATE TABLE orders (ORDER_ID INT, U_ID INT, PRODUCT_NAME VARCHAR(255), QUANTITY INT, ORDER_DATE TIMESTAMP, FOREIGN KEY (U_ID) REFERENCES sys_users(U_ID));
INSERT INTO sys_users VALUES (1, 'Alice', FALSE, 'Alice Smith', 'alice@example.com', 'password123', 'Users', CURRENT_TIMESTAMP, FALSE, TRUE, TRUE, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
INSERT INTO sys_users VALUES (2, 'Bob', TRUE, 'Bob Johnson', 'bob@example.com', 'password456', 'Admins', CURRENT_TIMESTAMP, FALSE, TRUE, TRUE, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL, NULL);
INSERT INTO orders VALUES (1, 1, 'Widget', 10, CURRENT_TIMESTAMP);
INSERT INTO orders VALUES (2, 2, 'Gadget', 5, CURRENT_TIMESTAMP);
EXPLAIN SELECT * FROM sys_users WHERE U_ACCOUNT_DISABLED = FALSE;
EXPLAIN SELECT U_NAME, PRODUCT_NAME FROM sys_users JOIN orders ON sys_users.U_ID = orders.U_ID WHERE U_IS_ROLE = TRUE;
EXPLAIN SELECT * FROM (SELECT U_ID, U_NAME FROM sys_users WHERE U_IS_ROLE = FALSE) AS non_admins;
EXPLAIN SELECT U_NAME FROM sys_users WHERE U_ID IN (SELECT U_ID FROM orders WHERE QUANTITY > 5);
EXPLAIN SELECT sys_users.U_NAME, orders.PRODUCT_NAME FROM sys_users LEFT JOIN orders ON sys_users.U_ID = orders.U_ID WHERE orders.ORDER_DATE > CURRENT_TIMESTAMP - INTERVAL '30 days';
EXPLAIN SELECT U_NAME, COUNT(ORDER_ID) FROM sys_users LEFT JOIN orders ON sys_users.U_ID = orders.U_ID GROUP BY U_NAME HAVING COUNT(ORDER_ID) > 0;
EXPLAIN SELECT * FROM sys_users WHERE EXISTS (SELECT 1 FROM orders WHERE orders.U_ID = sys_users.U_ID);
EXPLAIN SELECT * FROM sys_users WHERE U_NAME LIKE 'A%';
EXPLAIN SELECT * FROM sys_users ORDER BY U_LOGIN_TIME DESC LIMIT 5;
EXPLAIN SELECT * FROM (SELECT U_ID, COUNT(*) AS order_count FROM orders GROUP BY U_ID) AS order_summary WHERE order_count > 3;
EXPLAIN SELECT sys_users.U_NAME, orders.PRODUCT_NAME FROM sys_users INNER JOIN orders ON sys_users.U_ID = orders.U_ID WHERE sys_users.U_LOGIN_TIME < CURRENT_TIMESTAMP - INTERVAL '1 year';
EXPLAIN SELECT * FROM orders WHERE ORDER_DATE BETWEEN '2023-01-01' AND '2023-12-31';
EXPLAIN SELECT sys_users.U_NAME FROM sys_users WHERE U_ID NOT IN (SELECT U_ID FROM orders);