CREATE TABLE test_table (id INT, name VARCHAR(100));
INSERT INTO test_table (id, name) VALUES (1, 'Test1');
INSERT INTO test_table (id, name) VALUES (2, 'Test2');
SELECT make_array(0) AS array_0;
SELECT make_array(1) AS array_1;
SELECT make_array(10) AS array_10;
SELECT make_array(100) AS array_100;
SELECT make_array(1000) AS array_1000;
SELECT make_array(-1) AS array_negative;
SELECT make_array(2) FROM (SELECT COUNT(*) AS count FROM test_table) AS temp_table;
SELECT make_array(CASE WHEN COUNT(*) > 0 THEN 5 ELSE 0 END) FROM test_table;
SELECT make_array(3) WHERE EXISTS (SELECT 1 FROM test_table WHERE id = 1);
SELECT make_array(5) WHERE NOT EXISTS (SELECT 1 FROM test_table WHERE id = 3);
SELECT make_array(5 + (SELECT COUNT(*) FROM test_table)) AS calculated_array_length;
WITH temp AS (SELECT COUNT(*) AS cnt FROM test_table) SELECT make_array(cnt) FROM temp;
CREATE TABLE another_table (value INT);
INSERT INTO another_table (value) VALUES (1), (2), (3), (4), (5);
SELECT make_array(BASIC_FUNCTION(value)) FROM another_table WHERE value < 3;
SELECT make_array(SELECT COUNT(*) FROM another_table WHERE value >= 3) AS array_from_subquery;