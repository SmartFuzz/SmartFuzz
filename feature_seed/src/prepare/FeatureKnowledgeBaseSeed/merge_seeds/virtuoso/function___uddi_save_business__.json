CREATE TABLE businessEntity (id INTEGER PRIMARY KEY, name VARCHAR(255), description VARCHAR(255), updated_at TIMESTAMP);
INSERT INTO businessEntity (id, name, description, updated_at) VALUES (1, 'Acme Corporation', 'A fictional corporation for testing.', CURRENT_TIMESTAMP);
INSERT INTO businessEntity (id, name, description, updated_at) VALUES (2, 'Globex Corporation', 'Another fictional company for testing.', CURRENT_TIMESTAMP);
UPDATE businessEntity SET description = 'Updated description for Acme Corporation.' WHERE id = 1;
SELECT * FROM businessEntity WHERE id = (SELECT MAX(id) FROM businessEntity);
DELETE FROM businessEntity WHERE id NOT IN (SELECT id FROM businessEntity WHERE description IS NOT NULL);
CREATE TABLE businessDetails (business_id INTEGER, address VARCHAR(255), FOREIGN KEY(business_id) REFERENCES businessEntity(id));
INSERT INTO businessDetails (business_id, address) VALUES (1, '1234 Elm Street, Springfield, IL');
INSERT INTO businessDetails (business_id, address) SELECT id, '5678 Oak Street, Springfield, IL' FROM businessEntity WHERE name = 'Globex Corporation';
SELECT b.name, bd.address FROM businessEntity b JOIN businessDetails bd ON b.id = bd.business_id WHERE bd.address LIKE '%Street%';
UPDATE businessEntity SET updated_at = CURRENT_TIMESTAMP WHERE id IN (SELECT business_id FROM businessDetails WHERE address LIKE '%Street%');
SELECT b.name, COUNT(bd.address) FROM businessEntity b LEFT JOIN businessDetails bd ON b.id = bd.business_id GROUP BY b.name HAVING COUNT(bd.address) > 1;
DELETE FROM businessDetails WHERE business_id NOT IN (SELECT id FROM businessEntity);
SELECT b.name, b.updated_at FROM businessEntity b WHERE b.updated_at > (SELECT MAX(updated_at) FROM businessEntity WHERE id = 2);