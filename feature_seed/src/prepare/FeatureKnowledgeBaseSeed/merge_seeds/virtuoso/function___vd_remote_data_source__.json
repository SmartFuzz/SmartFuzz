CREATE TABLE remote_users (id INT PRIMARY KEY, username VARCHAR(50), password VARCHAR(50));
CREATE TABLE orders (id INT PRIMARY KEY, user_id INT, order_date DATE, FOREIGN KEY (user_id) REFERENCES remote_users(id));
INSERT INTO remote_users (id, username, password) VALUES (1, 'user1', 'pass1');
INSERT INTO remote_users (id, username, password) VALUES (2, 'user2', 'pass2');
INSERT INTO orders (id, user_id, order_date) VALUES (1, 1, '2023-10-01');
INSERT INTO orders (id, user_id, order_date) VALUES (2, 2, '2023-10-02');
SELECT u.username, COUNT(o.id) as order_count FROM remote_users u LEFT JOIN orders o ON u.id = o.user_id GROUP BY u.username;
SELECT username FROM remote_users WHERE id = (SELECT user_id FROM orders WHERE id = 1);
SELECT u.username FROM remote_users u WHERE EXISTS (SELECT 1 FROM orders o WHERE o.user_id = u.id);
SELECT u.username, o.order_date FROM remote_users u JOIN orders o ON u.id = o.user_id WHERE o.order_date >= '2023-10-01' AND o.order_date <= '2023-10-31';
DROP TABLE IF EXISTS remote_users;
DROP TABLE IF EXISTS orders;
CREATE TABLE temp_data (temp_id INT, temp_value VARCHAR(100));
INSERT INTO temp_data (temp_id, temp_value) SELECT id, username FROM remote_users;
SELECT temp_value FROM temp_data WHERE temp_id IN (SELECT id FROM remote_users WHERE username LIKE 'user%');
CREATE VIEW user_order_summary AS SELECT u.username, COUNT(o.id) as total_orders FROM remote_users u JOIN orders o ON u.id = o.user_id GROUP BY u.username;
SELECT * FROM user_order_summary WHERE total_orders > 0;
ALTER TABLE orders ADD COLUMN status VARCHAR(20);
UPDATE orders SET status = 'completed' WHERE id = 1;
DELETE FROM orders WHERE status = 'completed';