CREATE TABLE test_email (id INT PRIMARY KEY, email_content TEXT);
INSERT INTO test_email (id, email_content) VALUES (1, file_to_string('test.eml'));
CREATE TABLE test_certs (id INT PRIMARY KEY, cert_content TEXT);
INSERT INTO test_certs (id, cert_content) VALUES (1, file_to_string('testcerts.pem'));
SELECT smime_encrypt (file_to_string('test.eml'), pem_certificates_to_array(file_to_string('testcerts.pem')), 'aes256') AS encrypted_email FROM test_email WHERE id = 1;
SELECT smime_encrypt (e.email_content, pem_certificates_to_array(c.cert_content), 'aes256') FROM test_email AS e JOIN test_certs AS c ON e.id = c.id;
SELECT smime_encrypt (file_to_string('non_existent.eml'), pem_certificates_to_array(file_to_string('testcerts.pem')), 'aes256') AS encrypted_email FROM test_email WHERE id = (SELECT MAX(id) FROM test_email);
SELECT smime_encrypt (file_to_string('test.eml'), pem_certificates_to_array(file_to_string('testcerts.pem')), 'aes128') AS encrypted_email_aes128, smime_encrypt (file_to_string('test.eml'), pem_certificates_to_array(file_to_string('testcerts.pem')), 'aes192') AS encrypted_email_aes192 FROM test_email WHERE id = 1;
SELECT smime_encrypt (file_to_string('test.eml'), pem_certificates_to_array(file_to_string('testcerts.pem')), 'aes256') FROM (SELECT email_content FROM test_email WHERE id = 1) AS subquery;
SELECT smime_encrypt (e.email_content, pem_certificates_to_array(c.cert_content), 'aes256') FROM (SELECT * FROM test_email WHERE id = 1) AS e JOIN (SELECT * FROM test_certs WHERE id = 1) AS c ON e.id = c.id;