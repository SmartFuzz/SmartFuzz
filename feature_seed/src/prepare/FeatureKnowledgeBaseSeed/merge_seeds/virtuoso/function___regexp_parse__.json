CREATE TABLE test_strings (id INT PRIMARY KEY, value VARCHAR(255));
INSERT INTO test_strings (id, value) VALUES (1, 'Sample text for testing regexp_parse function 1234 with offsets');
INSERT INTO test_strings (id, value) VALUES (2, 'Another example with a number 5678, where we find 234');
SELECT regexp_parse(value, '\d+', 0) FROM test_strings;
SELECT regexp_parse(value, '(\d+).*', 0) FROM test_strings;
SELECT regexp_parse(value, '(\d+).*?(\d+)', 0) FROM test_strings;
SELECT regexp_parse(value, '(\w+)', 0) FROM (SELECT value FROM test_strings WHERE id = 1) AS subquery;
SELECT a.id, regexp_parse(b.value, '(\w+)', 0) FROM test_strings a JOIN test_strings b ON a.id < b.id;
SELECT c.id, regexp_parse(c.value, '(\d{3})', 0) FROM (SELECT value, id FROM test_strings) AS c WHERE id = (SELECT MAX(id) FROM test_strings);
SELECT regexp_parse(value, '(\d+)(\D+)(\d+)', 0) FROM (SELECT value FROM test_strings WHERE id IN (1,2)) AS combined;
SELECT regexp_parse(value, '([a-zA-Z]+)', 0) FROM test_strings WHERE value LIKE '%test%';