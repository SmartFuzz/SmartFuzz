CREATE TABLE items (id INT, name VARCHAR(255), xml_data XML);
INSERT INTO items (id, name, xml_data) VALUES (1, 'Item 1', '<item><subitem>Subitem 1</subitem></item>');
INSERT INTO items (id, name, xml_data) VALUES (2, 'Item 2', '<item><subitem>Subitem 2</subitem><subitem>Subitem 3</subitem></item>');
INSERT INTO items (id, name, xml_data) VALUES (3, 'Item 3', '<item><!-- Comment --><subitem>Subitem 4</subitem></item>');
INSERT INTO items (id, name, xml_data) VALUES (4, 'Item 4', '<item><subitem>Subitem 5</subitem><subitem>Subitem 6</subitem></item>');
SELECT xpath_string('//item', xml_data) FROM items WHERE name = 'Item 1';
SELECT xpath_string('//subitem', xml_data) FROM items WHERE id = 2;
SELECT name, xpath_string('//subitem', xml_data) AS subitems FROM items WHERE id IN (1, 2);
SELECT i1.name, i2.name FROM items i1 JOIN items i2 ON xpath_string('//subitem', i1.xml_data) = xpath_string('//subitem', i2.xml_data WHERE i1.id <> i2.id);
SELECT xpath_string('//item', xml_data) FROM items WHERE id = (SELECT MAX(id) FROM items);
CREATE TABLE categories (id INT, name VARCHAR(255));
INSERT INTO categories (id, name) VALUES (1, 'Category 1');
INSERT INTO categories (id, name) VALUES (2, 'Category 2');
INSERT INTO items (id, name, xml_data) VALUES (5, 'Item 5', '<item><category>Category 1</category></item>');
SELECT xpath_string('//category', xml_data) FROM items WHERE EXISTS (SELECT * FROM categories WHERE categories.name = 'Category 1');
SELECT COUNT(*) FROM items WHERE xpath_string('//*[local-name() = "subitem"]', xml_data) IS NOT NULL;
SELECT name, xpath_string('//item/subitem', xml_data) FROM items GROUP BY name HAVING COUNT(xpath_string('//subitem', xml_data)) > 1;