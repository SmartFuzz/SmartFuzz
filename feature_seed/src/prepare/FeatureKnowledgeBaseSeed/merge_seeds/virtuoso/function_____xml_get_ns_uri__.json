CREATE GRAPH <http://example.org/ns1>;
PREFIX ns1: <http://example.org/ns1/> INSERT DATA { GRAPH <http://example.org/ns1> { ns1:subject1 ns1:predicate1 ns1:object1 } };
SELECT __xml_get_ns_uri('ns1') AS uri WHERE {};
SELECT __xml_get_ns_uri('nonexistent_ns') AS uri WHERE {};
PREFIX ns2: <http://example.org/ns2/> INSERT DATA { GRAPH <http://example.org/ns2> { ns2:subject2 ns2:predicate2 ns2:object2 } };
SELECT __xml_get_ns_uri('ns2') AS uri WHERE {};
SELECT result.uri FROM (SELECT __xml_get_ns_uri('ns1') AS uri) AS result WHERE result.uri IS NOT NULL;
SELECT result.uri FROM (SELECT __xml_get_ns_uri('ns1') AS uri UNION SELECT __xml_get_ns_uri('ns2') AS uri) AS result WHERE result.uri IS NOT NULL;
SELECT G1.ns AS prefix, __xml_get_ns_uri(G1.ns) AS uri FROM (SELECT 'ns1' AS ns UNION SELECT 'ns2' AS ns) AS G1;
INSERT DATA { GRAPH <http://example.org/ns1> { ns1:subject1 ns1:predicate1 ns1:object1 } };
SELECT __xml_get_ns_uri('ns1') AS uri FROM GRAPH <http://example.org/ns1> WHERE {};
SELECT __xml_get_ns_uri('ns1'), __xml_get_ns_uri('ns2'), __xml_get_ns_uri('nonexistent_ns') AS uris WHERE {};
SELECT __xml_get_ns_uri('ns1') AS uri1, __xml_get_ns_uri('ns2') AS uri2 WHERE uri1 IS NOT NULL AND uri2 IS NOT NULL;
WITH RECURSIVE ns_prefixes (prefix) AS (SELECT 'ns1' UNION ALL SELECT 'ns2') SELECT prefix, __xml_get_ns_uri(prefix) AS uri FROM ns_prefixes;
SELECT __xml_get_ns_uri(COALESCE((SELECT prefix FROM prefixes_table LIMIT 1), 'default_ns')) AS uri WHERE {};
CREATE TABLE prefixes_table (prefix VARCHAR(100));
INSERT INTO prefixes_table VALUES ('ns1'), ('ns2');
SELECT __xml_get_ns_uri((SELECT prefix FROM prefixes_table LIMIT 1)) AS uri WHERE {};
SELECT uri FROM (SELECT __xml_get_ns_uri('ns1') AS uri1, __xml_get_ns_uri('ns2') AS uri2) AS uris WHERE uri1 IS NOT NULL OR uri2 IS NOT NULL;