CREATE GRAPH <http://geo-api-demo/>;
INSERT DATA { <http://geo-api-demo/point2d> <shape> "POINT(1 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <http://geo-api-demo/box1> <shape> "BOX(0 0, 2 3)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <http://geo-api-demo/linestring> <shape> "LINESTRING(10 21, 12 23, 10 25)"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
INSERT DATA { <http://geo-api-demo/polygon1> <shape> "POLYGON((1 3,2 4,1 5,0 4,1 3))"^^<http://www.openlinksw.com/schemas/virtrdf#Geometry> . };
SELECT ?s, bif:st_mmax(?o) as ?mmax FROM <http://geo-api-demo/> WHERE { ?s ?p ?o . FILTER(?o != <http://geo-api-demo/point2d>) };
SELECT ?s, bif:st_mmax(?o) AS ?mmax FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } GROUP BY ?s HAVING (COUNT(?o) > 1);
SELECT ?s, bif:st_mmax(?o) AS ?mmax FROM <http://geo-api-demo/> WHERE { { ?s ?p ?o1 . FILTER(bif:st_intersects(?o1, <http://geo-api-demo/box1>)) } UNION { ?s ?p ?o2 . FILTER(bif:st_within(?o2, <http://geo-api-demo/polygon1>)) } };
SELECT ?s, bif:st_mmax(?o) AS ?mmax FROM <http://geo-api-demo/> WHERE { ?s ?p ?o } ORDER BY DESC(?mmax) LIMIT 10;
SELECT ?s, bif:st_mmax(?o) AS ?mmax FROM <http://geo-api-demo/> WHERE { ?s ?p ?o FILTER(STR(?o) = "LINESTRING(10 21, 12 23, 10 25)") };