CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE);
INSERT INTO test_dates (id, event_date) VALUES (1, '2023-01-01');
INSERT INTO test_dates (id, event_date) VALUES (2, '2022-12-31');
SELECT * FROM test_dates WHERE event_date BETWEEN '2022-12-31' AND '2023-01-01';
SELECT * FROM test_dates WHERE event_date < '2023-01-01' OR event_date > '2023-01-01';
CREATE TABLE event_summary (summary_id INT PRIMARY KEY, event_date DATE, event_name VARCHAR(255));
INSERT INTO event_summary (summary_id, event_date, event_name) VALUES (1, '2023-02-28', 'Leap Year Event');
INSERT INTO event_summary (summary_id, event_date, event_name) VALUES (2, '2023-02-29', 'Non-existent Date');
SELECT COUNT(*) FROM event_summary WHERE event_date IS NULL;
SELECT (SELECT COUNT(*) FROM event_summary) AS total_events, (SELECT COUNT(*) FROM test_dates) AS total_test_dates;
SELECT es.event_name FROM event_summary es JOIN test_dates td ON es.event_date = td.event_date WHERE td.id = 1;
SELECT id, event_date FROM test_dates WHERE event_date = (SELECT MAX(event_date) FROM event_summary);
CREATE TABLE date_range (start_date DATE, end_date DATE);
INSERT INTO date_range (start_date, end_date) VALUES ('2023-01-01', '2023-12-31');
SELECT * FROM date_range WHERE end_date - start_date = 364;
SELECT * FROM date_range WHERE start_date = '2023-01-01' AND end_date >= '2023-01-01';