CREATE TABLE stylesheets (id INT PRIMARY KEY, uri VARCHAR(255), content TEXT);
INSERT INTO stylesheets (id, uri, content) VALUES (1, 'virt://WS.WS.SYS_DAV_RES.RES_FULL_PATH.RES_CONTENT:/DAV/stylesheets/document.xsl', '<xsl:stylesheet></xsl:stylesheet>');
INSERT INTO stylesheets (id, uri, content) VALUES (2, 'http://remote.server/stylesheets/stylesheet.xsl', '<xsl:stylesheet></xsl:stylesheet>');
INSERT INTO stylesheets (id, uri, content) VALUES (3, 'virt://WS.WS.SYS_DAV_RES.RES_FULL_PATH.RES_CONTENT:/DAV/stylesheets/another_stylesheet.xsl', '<xsl:stylesheet></xsl:stylesheet>');
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id = 1));
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id = 2));
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id = (SELECT MAX(id) FROM stylesheets)));
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE uri LIKE 'http://%'));
SELECT xslt_stale('virt://WS.WS.SYS_DAV_RES.RES_FULL_PATH.RES_CONTENT:/DAV/stylesheets/document.xsl');
SELECT xslt_stale('http://remote.server/stylesheets/stylesheet.xsl');
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id IN (1, 2)));
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE content LIKE '%stylesheet%'));
SELECT xslt_stale((SELECT uri FROM stylesheets s1 JOIN stylesheets s2 ON s1.id = s2.id WHERE s1.id = 1));
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id = (SELECT MIN(id) FROM stylesheets)));
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id > 0 ORDER BY id DESC LIMIT 1));
DELETE FROM stylesheets WHERE id = 3;
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE id = 3));
UPDATE stylesheets SET content = '<xsl:stylesheet><xsl:import href="http://another.server/stylesheets/stylesheet.xsl"/></xsl:stylesheet>' WHERE id = 2;
SELECT xslt_stale((SELECT uri FROM stylesheets WHERE content LIKE '%import%'));