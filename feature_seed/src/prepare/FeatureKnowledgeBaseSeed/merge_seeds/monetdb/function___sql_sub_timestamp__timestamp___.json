CREATE TABLE timestamps (id INT, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, timestamp '2023-01-01 10:00:00', timestamp '2023-01-01 10:30:00');
INSERT INTO timestamps VALUES (2, timestamp '2023-01-02 12:00:00', timestamp '2023-01-02 13:00:00');
INSERT INTO timestamps VALUES (3, timestamp '2023-01-03 14:00:00', timestamp '2023-01-03 15:00:00');
SELECT sql_sub(end_time, start_time) FROM timestamps;
SELECT t1.id, sql_sub(t1.end_time, t1.start_time) AS difference FROM timestamps t1 WHERE t1.id = 2;
SELECT (SELECT sql_sub(a.end_time, a.start_time) FROM timestamps a WHERE a.id = 1) AS first_diff, (SELECT sql_sub(b.end_time, b.start_time) FROM timestamps b WHERE b.id = 2) AS second_diff;
CREATE TABLE more_timestamps (user_id INT, event_time TIMESTAMP);
INSERT INTO more_timestamps VALUES (1, timestamp '2023-01-01 09:00:00');
SELECT t.id, sql_sub(t.end_time, t.start_time) AS duration FROM timestamps t JOIN more_timestamps m ON sql_sub(t.start_time, m.event_time) > 0;
SELECT id, sql_sub(start_time, timestamp '2023-01-01 00:00:00') AS seconds_since_midnight FROM timestamps WHERE start_time > timestamp '2023-01-01 00:00:00';
SELECT sql_sub((SELECT MAX(end_time) FROM timestamps), (SELECT MIN(start_time) FROM timestamps)) AS overall_duration;