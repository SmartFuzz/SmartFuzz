CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 30), (1, 10), (2, NULL), (3, 30);
SELECT sum(distinct value) FROM test_table;
SELECT sum(distinct value/2) FROM test_table;
CREATE TABLE another_table (id INT, ref_id INT);
INSERT INTO another_table VALUES (1, 1), (2, 2), (3, 1);
SELECT sum(distinct t.value) FROM test_table t JOIN another_table a ON t.id = a.ref_id;
SELECT sum(distinct t.value + 5) FROM test_table t;
SELECT sum(distinct value) FROM (SELECT value FROM test_table WHERE value > 15) AS subquery;
SELECT sum(distinct (value * 2 - 5)) FROM test_table WHERE value IS NOT NULL;
CREATE TABLE mixed_table (group_id INT, score INT);
INSERT INTO mixed_table VALUES (1, 100), (1, 150), (2, 200), (2, 200), (1, 100);
SELECT sum(distinct score) FROM mixed_table GROUP BY group_id;
SELECT sum(distinct (t.value * 3)) FROM test_table t WHERE EXISTS (SELECT 1 FROM another_table a WHERE a.ref_id = t.id);
INSERT INTO test_table VALUES (4, NULL), (5, 15);
SELECT sum(distinct value) FROM test_table WHERE value IS NOT NULL;
SELECT sum(distinct value/4) FROM test_table WHERE id < 3;