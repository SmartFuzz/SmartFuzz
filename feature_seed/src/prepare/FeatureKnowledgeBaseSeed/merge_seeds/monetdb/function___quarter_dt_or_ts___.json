CREATE TABLE t_dates (id INT PRIMARY KEY, dt DATE);
INSERT INTO t_dates VALUES (1, DATE '2020-01-15');
INSERT INTO t_dates VALUES (2, DATE '2020-04-22');
INSERT INTO t_dates VALUES (3, DATE '2020-07-10');
INSERT INTO t_dates VALUES (4, DATE '2020-10-30');
INSERT INTO t_dates VALUES (5, DATE '2020-12-31');
SELECT id, quarter(dt) AS quarter_number FROM t_dates;
SELECT COUNT(*) AS quarter_count FROM (SELECT quarter(dt) FROM t_dates) AS q;
CREATE TABLE t_timestamps (id INT PRIMARY KEY, ts TIMESTAMP);
INSERT INTO t_timestamps VALUES (1, TIMESTAMP '2020-01-15 12:30:00');
INSERT INTO t_timestamps VALUES (2, TIMESTAMP '2020-05-10 09:45:00');
SELECT ts, quarter(ts) AS quarter_number FROM t_timestamps WHERE ts >= TIMESTAMP '2020-01-01 00:00:00';
SELECT AVG(quarter(dt)) AS avg_quarter FROM t_dates;
CREATE TABLE t_join (id INT PRIMARY KEY, fk_id INT, description TEXT, FOREIGN KEY (fk_id) REFERENCES t_dates(id));
INSERT INTO t_join VALUES (1, 2, 'Join entry for April date');
INSERT INTO t_join VALUES (2, 3, 'Join entry for July date');
SELECT j.description, quarter(d.dt) AS quarter_number FROM t_join j INNER JOIN t_dates d ON j.fk_id = d.id;
SELECT id, CASE WHEN quarter(dt) = 1 THEN 'Q1' WHEN quarter(dt) = 2 THEN 'Q2' WHEN quarter(dt) = 3 THEN 'Q3' WHEN quarter(dt) = 4 THEN 'Q4' END AS quarter_label FROM t_dates;
SELECT MAX(quarter(dt)) AS max_quarter FROM t_dates WHERE dt BETWEEN DATE '2020-01-01' AND DATE '2020-12-31';
SELECT COUNT(*), quarter(dt) FROM t_dates GROUP BY quarter(dt);