CREATE TABLE test_strings (id INT PRIMARY KEY, str_value STRING);
INSERT INTO test_strings VALUES (1, 'hello'), (2, 'world'), (3, 'kiss');
SELECT repeat(str_value, 3) FROM test_strings WHERE id = 1;
SELECT repeat(str_value, 5) AS repeated_string FROM test_strings WHERE id IN (1, 2);
SELECT repeat('abc', 0) AS empty_repeat;
SELECT repeat('single', 1) AS single_repeat;
SELECT repeat(CONCAT(str_value, ' '), 2) FROM test_strings WHERE id = 2;
SELECT (SELECT repeat(str_value, 4) FROM test_strings WHERE id = 3) AS subquery_repeat;
CREATE TABLE additional_strings (id INT PRIMARY KEY, additional_string STRING);
INSERT INTO additional_strings VALUES (1, 'foo'), (2, 'bar');
SELECT repeat(a.str_value || b.additional_string, 2) FROM test_strings a JOIN additional_strings b ON a.id = b.id;
SELECT repeat(REPLACE('test', 't', 'T'), 3) AS replaced_repeat;
SELECT repeat('a', 1000) AS long_string_repeat;
SELECT repeat('short', CASE WHEN id = 1 THEN 2 ELSE 3 END) FROM test_strings;