DECLARE v1 timestamp;
DECLARE v2 timestamp, v3 timestamp;
DECLARE my_var integer;
DECLARE a1, a2 float;
DECLARE temp_date timestamp;
SET temp_date = now();
SELECT temp_date;
DECLARE num1 integer;
SET num1 = (SELECT COUNT(*) FROM sys.var);
DECLARE start_time timestamp, end_time timestamp;
SET start_time = '2023-01-01 00:00:00';
SET end_time = '2023-12-31 23:59:59';
CREATE TABLE temp_table (id integer, value float);
DECLARE v_id integer;
SET v_id = (SELECT MAX(id) FROM temp_table);
DECLARE x1 integer;
SELECT x1 FROM (SELECT 1 AS x1 UNION SELECT 2) AS temp;
DECLARE varA varchar(20), varB varchar(50);
SET varA = 'Test';
SET varB = 'Example';
SELECT varA, varB;
DECLARE ratio float;
SET ratio = (SELECT avg(value) FROM temp_table WHERE id < (SELECT COUNT(*) FROM temp_table));
DECLARE multi_var integer, sum_var float;
SET sum_var = (SELECT SUM(value) FROM temp_table WHERE id = multi_var);
DECLARE var1 integer;
SET var1 = (SELECT COUNT(*) FROM (SELECT DISTINCT id FROM temp_table) AS unique_ids);
DECLARE session_start timestamp;
SET session_start = NOW();
SELECT * FROM sys.var WHERE name = 'session_start';
DECLARE val_a integer;
DECLARE val_b integer;
SET val_a = 10;
SET val_b = 20;
SELECT val_a + val_b AS sum_result;
CREATE TABLE example_table (name varchar(50), age integer);
DECLARE new_name varchar(50);
SET new_name = (SELECT name FROM example_table WHERE age > 21 LIMIT 1);