CREATE TABLE test_table (id INT, name VARCHAR(100), age INT);
CREATE INDEX idx_name ON test_table (name);
CREATE UNIQUE INDEX idx_unique_age ON test_table (age);
CREATE INDEX idx_combined ON test_table (name, age);
CREATE INDEX idx_on_id ON test_table (id);
CREATE INDEX idx_partial ON test_table (name) WHERE age > 30;
CREATE TABLE another_table (id INT, test_id INT, description VARCHAR(255));
CREATE INDEX idx_another_table ON another_table (description);
CREATE INDEX idx_join ON another_table (test_id) WHERE test_id IN (SELECT id FROM test_table WHERE age < 25);
CREATE INDEX idx_complex ON test_table (id) WHERE id IN (SELECT id FROM another_table);
CREATE INDEX idx_multiple ON test_table (name, age) WHERE name LIKE 'A%';
CREATE INDEX idx_not_null ON test_table (name) WHERE name IS NOT NULL;
CREATE INDEX idx_subquery ON test_table (age) WHERE EXISTS (SELECT 1 FROM another_table WHERE another_table.test_id = test_table.id);
CREATE INDEX idx_ordered ON test_table (age) ORDER BY name DESC;
CREATE INDEX idx_no_schema ON test_table (id, name);