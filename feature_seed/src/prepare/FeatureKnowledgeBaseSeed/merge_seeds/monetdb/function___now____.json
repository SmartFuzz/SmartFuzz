CREATE TABLE timestamps (event_time timestamptz);
INSERT INTO timestamps VALUES (now());
SELECT event_time FROM timestamps WHERE event_time = now();
CREATE TABLE events (event_id INT, event_name TEXT, event_time timestamptz);
INSERT INTO events VALUES (1, 'Start', now()), (2, 'Middle', now() - interval '30 minutes'), (3, 'End', now() + interval '1 hour');
SELECT event_name, event_time FROM events WHERE event_time < now();
SELECT event_name, event_time FROM events WHERE event_time BETWEEN now() - interval '1 hour' AND now();
SELECT event_name, event_time FROM events WHERE event_time = (SELECT MAX(event_time) FROM events);
CREATE TABLE user_actions (user_id INT, action_time timestamptz);
INSERT INTO user_actions VALUES (1, now()), (2, now() - interval '45 minutes'), (3, now() + interval '2 hours');
SELECT ua.user_id, e.event_name FROM user_actions ua JOIN events e ON ua.action_time >= e.event_time WHERE ua.action_time <= now();
SELECT COUNT(*) FROM events WHERE event_time > (SELECT now() - interval '2 hours');
SELECT e.event_name FROM events e WHERE e.event_time IN (SELECT action_time FROM user_actions WHERE action_time <= now());