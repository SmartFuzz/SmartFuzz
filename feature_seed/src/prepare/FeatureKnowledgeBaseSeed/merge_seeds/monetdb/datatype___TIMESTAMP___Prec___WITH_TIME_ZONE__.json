CREATE TABLE events (event_id INT, event_time TIMESTAMP(6) WITH TIME ZONE);
INSERT INTO events VALUES (1, TIMESTAMP '2023-10-01 12:00:00.123456+01:00');
INSERT INTO events VALUES (2, TIMESTAMP '2023-10-02 15:30:30.987654-05:00');
SELECT event_id, event_time FROM events WHERE event_time > TIMESTAMP '2023-10-01 12:00:00.000000+00:00' ORDER BY event_time DESC;
CREATE TABLE users (user_id INT, registration_time TIMESTAMP(3) WITH TIME ZONE);
INSERT INTO users VALUES (1, TIMESTAMP '2023-09-30 10:15:00.123+00:00');
INSERT INTO users VALUES (2, TIMESTAMP '2023-10-01 11:20:00.456+00:00');
SELECT u.user_id, u.registration_time, e.event_time FROM users u JOIN events e ON u.user_id = e.event_id WHERE u.registration_time < e.event_time;
CREATE TABLE user_events (user_id INT, event_time TIMESTAMP(0) WITH TIME ZONE);
INSERT INTO user_events SELECT u.user_id, e.event_time FROM users u CROSS JOIN events e WHERE u.user_id = 1;
SELECT COUNT(*) FROM user_events WHERE event_time BETWEEN TIMESTAMP '2023-10-01 00:00:00+01:00' AND TIMESTAMP '2023-10-02 00:00:00+01:00';
CREATE TABLE timestamp_test (test_id INT, ts TIMESTAMP(6) WITH TIME ZONE);
INSERT INTO timestamp_test VALUES (1, TIMESTAMP '2023-10-03 08:30:45.000000+00:00');
INSERT INTO timestamp_test VALUES (2, TIMESTAMP '2023-10-04 09:30:45.555555+02:00');
SELECT test_id, ts, EXTRACT(TIMEZONE FROM ts) AS tz FROM timestamp_test WHERE ts IS NOT NULL;
SELECT t1.test_id, t1.ts FROM timestamp_test t1 JOIN timestamp_test t2 ON t1.ts < t2.ts ORDER BY t1.ts DESC;