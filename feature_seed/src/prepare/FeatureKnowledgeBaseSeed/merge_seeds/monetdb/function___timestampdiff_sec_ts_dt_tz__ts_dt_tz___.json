CREATE TABLE timestamps_example (start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO timestamps_example VALUES (timestamp '2021-12-31 18:40:40', timestamp '2021-12-31 16:30:20');
SELECT timestampdiff_sec(start_time, end_time) FROM timestamps_example;
INSERT INTO timestamps_example VALUES (timestamp '2023-01-01 00:00:00', timestamp '2022-12-31 23:59:59');
SELECT timestampdiff_sec(timestamp '2023-01-01 00:00:00', timestamp '2022-12-31 23:59:59');
SELECT timestampdiff_sec(timestamp '2000-01-01 00:00:00', timestamp '1970-01-01 00:00:00') AS difference;
CREATE TABLE tz_example (tz_start TIMESTAMP WITH TIME ZONE, tz_end TIMESTAMP WITH TIME ZONE);
INSERT INTO tz_example VALUES (timestamp '2021-12-31 18:40:40+01', timestamp '2021-12-31 16:30:20+01');
SELECT timestampdiff_sec(tz_start, tz_end) FROM tz_example;
SELECT timestampdiff_sec(timestamp '2023-10-31 15:00:00', timestamp '2023-10-31 15:00:01') AS tiny_difference;
SELECT timestampdiff_sec(CAST(timestamp '2022-05-15 05:00:00' AS TIMESTAMP), CAST(timestamp '2022-05-15 05:00:10' AS TIMESTAMP)) AS small_diff;
SELECT timestampdiff_sec(timestamp '2021-12-31 23:59:59', timestamp '2022-01-01 00:00:00') AS year_diff;
SELECT timestampdiff_sec(start_time, end_time) FROM (SELECT timestamp '2021-01-01 00:00:00' AS start_time, timestamp '2021-01-02 00:00:00' AS end_time) AS temp;
CREATE TABLE nested_query_example (start TIMESTAMP, end TIMESTAMP);
INSERT INTO nested_query_example VALUES (timestamp '2020-01-01 12:00:00', timestamp '2020-01-01 12:01:00');
SELECT timestampdiff_sec(start, end) FROM (SELECT * FROM nested_query_example) AS subquery;
CREATE TABLE join_example (id INT, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO join_example VALUES (1, timestamp '2021-01-01 09:00:00', timestamp '2021-01-01 11:00:00');
SELECT j.id, timestampdiff_sec(j.start_time, j.end_time) FROM join_example AS j JOIN timestamps_example AS t ON j.id = 1;
SELECT timestampdiff_sec(MAX(start_time), MIN(end_time)) FROM timestamps_example;