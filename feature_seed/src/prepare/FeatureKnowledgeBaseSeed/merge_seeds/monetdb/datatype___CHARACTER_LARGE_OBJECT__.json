CREATE TABLE example_clob (id INT PRIMARY KEY, content CLOB);
INSERT INTO example_clob (id, content) VALUES (1, 'This is a normal string.');
INSERT INTO example_clob (id, content) VALUES (2, 'A string with special characters: !@#$%^&*()');
INSERT INTO example_clob (id, content) VALUES (3, REPEAT('A', 10000));
INSERT INTO example_clob (id, content) VALUES (4, CONCAT(REPEAT('B', 5000), 'C'));
SELECT id, LENGTH(content) FROM example_clob WHERE LENGTH(content) < 10000;
CREATE TABLE other_clob (other_id INT PRIMARY KEY, other_content CLOB);
INSERT INTO other_clob (other_id, other_content) VALUES (1, 'Another CLOB content.');
SELECT ec.id, ec.content, oc.other_content FROM example_clob ec JOIN other_clob oc ON ec.id = oc.other_id;
SELECT ec.id FROM example_clob ec WHERE ec.content LIKE '%normal%';
SELECT ec.id FROM example_clob ec WHERE EXISTS (SELECT 1 FROM other_clob oc WHERE oc.other_id = ec.id);
SELECT ec.id, SUBSTRING(ec.content, 1, 5) AS snippet FROM example_clob ec;
UPDATE example_clob SET content = 'Updated content.' WHERE id = 1;
DELETE FROM example_clob WHERE id = 2;
SELECT ec.id, LENGTH(ec.content) AS content_length FROM example_clob ec ORDER BY content_length DESC;
INSERT INTO example_clob (id, content) VALUES (5, CAST('A very long text with special characters 1234567890!@#$%^' AS CLOB));