CREATE TABLE numbers (value DOUBLE);
INSERT INTO numbers VALUES (1.0), (2.0), (3.0), (4.0);
SELECT prod(value) FROM numbers;
CREATE TABLE more_numbers (id INT, val BIGINT);
INSERT INTO more_numbers VALUES (1, 10), (2, 20), (3, 30);
SELECT prod(val) FROM more_numbers;
CREATE TABLE nested_numbers (val1 DOUBLE, val2 DOUBLE);
INSERT INTO nested_numbers VALUES (1.1, 2.2), (3.3, 4.4);
SELECT (SELECT prod(val1) FROM nested_numbers) + (SELECT prod(val2) FROM nested_numbers);
CREATE TABLE joined_numbers (id INT, value FLOAT);
INSERT INTO joined_numbers VALUES (1, 1.5), (2, 2.5), (3, 3.5);
SELECT prod(a.value) FROM numbers a JOIN joined_numbers b ON a.value = b.value + 1;
CREATE TABLE complex_numbers (part1 DOUBLE, part2 DOUBLE, part3 FLOAT);
INSERT INTO complex_numbers VALUES (2.0, 3.0, 4.0), (1.0, 2.0, 3.0);
SELECT prod(part1 + part2) FROM complex_numbers WHERE part3 < 5;
SELECT prod((SELECT value FROM numbers) + (SELECT val FROM more_numbers WHERE id = 2));