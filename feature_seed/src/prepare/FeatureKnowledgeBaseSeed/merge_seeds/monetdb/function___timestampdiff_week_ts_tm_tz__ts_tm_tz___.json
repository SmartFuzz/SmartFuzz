CREATE TABLE timestamps (id INT PRIMARY KEY, ts_utc TIMESTAMP, ts_tz TIMESTAMP WITH TIME ZONE);
INSERT INTO timestamps VALUES (1, timestamp '2021-12-31 18:40:40', timestamp '2021-12-31 18:40:40-05'), (2, timestamp '2021-02-20 16:30:20', timestamp '2021-02-20 16:30:20+00');
SELECT timestampdiff_week(ts_tz, ts_tz) FROM timestamps WHERE id = 1 AND ts_tz = '2021-12-31 18:40:40-05' AND ts_utc = '2021-12-31 18:40:40';
SELECT timestampdiff_week(timestamp '2021-12-31 18:40:40', timestamp '2021-12-01 18:40:40');
SELECT timestampdiff_week(timestamp '2022-01-01 00:00:00', timestamp '2021-12-31 23:59:59');
SELECT timestampdiff_week(MAX(ts_tz), MIN(ts_tz)) FROM timestamps;
SELECT a.id, timestampdiff_week(a.ts_tz, b.ts_tz) FROM timestamps AS a JOIN timestamps AS b ON a.id <> b.id;
SELECT COUNT(*) AS diff_weeks FROM (SELECT timestampdiff_week(ts_tz, ts_tz) AS diff FROM timestamps) AS subquery;
SELECT timestampdiff_week(ts_tz, ts_tz) + 1 AS adjusted_diff FROM timestamps WHERE ts_utc > '2021-01-01';
SELECT timestampdiff_week(timestamp '2020-12-31 18:40:40', timestamp '2021-01-01 18:40:40') AS week_diff;