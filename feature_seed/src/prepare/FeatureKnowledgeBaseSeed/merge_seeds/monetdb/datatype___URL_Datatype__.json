CREATE TABLE URL_test (url1 URL, url2 URL(512) NOT NULL);
INSERT INTO URL_test VALUES (cast('https://example.com' as url), 'https://www.example.com/some/long/path?query=123');
INSERT INTO URL_test VALUES (convert('http://test.com', url), url 'https://www.monetdb.org/');
SELECT url 'https://openai.com/research/';
SELECT url 'https://subdomain.test.com/path/to/resource?query=abc' AS valid_url;
SELECT * FROM URL_test WHERE url1 = url 'https://www.example.com';
CREATE TABLE URL_analysis (url_data URL NOT NULL, created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO URL_analysis VALUES (cast('https://www.google.com' as url));
SELECT url_data FROM URL_analysis WHERE created_at > CURRENT_TIMESTAMP - INTERVAL '1 day';
SELECT (url 'https://www.example.com/path/to/resource' || url 'http://another.com') AS combined_url;
CREATE TABLE URL_nested (id INT PRIMARY KEY, url1 URL);
INSERT INTO URL_nested SELECT row_number() over (), cast('https://nested.example.com/' as url) FROM generate_series(1, 10);
SELECT (SELECT url1 FROM URL_nested WHERE id = 1) AS nested_url;
SELECT url2 FROM URL_test WHERE url2 LIKE 'https://%.com';
SELECT url 'https://query.example.com/' || 'subpath' AS combined_url;