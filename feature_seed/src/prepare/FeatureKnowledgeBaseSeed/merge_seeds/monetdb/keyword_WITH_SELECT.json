CREATE TABLE sales (id INT, amount DECIMAL(10, 2), region VARCHAR(50));
CREATE TABLE regions (region_id INT, region_name VARCHAR(50));
INSERT INTO regions (region_id, region_name) VALUES (1, 'North'), (2, 'South'), (3, 'East'), (4, 'West');
INSERT INTO sales (id, amount, region) VALUES (1, 150.00, 'North'), (2, 200.50, 'South'), (3, 175.75, 'East'), (4, 225.00, 'West');
WITH sales_summary AS (SELECT region, SUM(amount) AS total_sales FROM sales GROUP BY region) SELECT region, total_sales FROM sales_summary WHERE total_sales > 200.00;
WITH region_sales AS (SELECT region, COUNT(*) AS sales_count FROM sales GROUP BY region) SELECT rs.region_name, r.sales_count FROM regions r JOIN region_sales rs ON r.region_name = rs.region;
WITH ranked_sales AS (SELECT id, amount, ROW_NUMBER() OVER (ORDER BY amount DESC) AS rank FROM sales) SELECT * FROM ranked_sales WHERE rank <= 3;
WITH recursive base AS (SELECT region, COUNT(*) AS sales_count FROM sales GROUP BY region) SELECT b.region, b.sales_count FROM base b WHERE b.sales_count > (SELECT AVG(sales_count) FROM base);
WITH combined_sales AS (SELECT region, SUM(amount) AS total_amount FROM sales GROUP BY region) SELECT cs.region, cs.total_amount FROM combined_sales cs WHERE cs.total_amount = (SELECT MAX(total_amount) FROM combined_sales);
WITH sales_data AS (SELECT id, amount FROM sales), avg_sales AS (SELECT AVG(amount) AS average FROM sales_data) SELECT s.id, s.amount FROM sales_data s, avg_sales a WHERE s.amount > a.average;