CREATE TABLE test_table (id INT, value FLOAT);
INSERT INTO test_table VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, NULL), (5, 50.0);
SELECT sys.quantile(value, 0.5) FROM test_table;
SELECT sys.quantile(value, 0.0) FROM test_table;
SELECT sys.quantile(value, 1.0) FROM test_table;
SELECT sys.quantile(value, 0.7) FROM test_table WHERE id IN (SELECT id FROM test_table WHERE value IS NOT NULL);
SELECT sys.quantile(value, 0.3) FROM (SELECT value FROM test_table WHERE value > 15.0) AS subquery;
CREATE TABLE temp_table (timestamp_col TIMESTAMP);
INSERT INTO temp_table VALUES (TIMESTAMP '2023-01-01 00:00:00'), (TIMESTAMP '2023-01-02 12:30:00'), (TIMESTAMP '2023-01-03 14:45:00');
SELECT sys.quantile(timestamp_col, 0.5) FROM temp_table;
INSERT INTO test_table VALUES (6, 60.0);
SELECT sys.quantile(value, 0.5) FROM test_table GROUP BY id HAVING COUNT(value) > 2;
SELECT sys.quantile(value, 0.9) FROM (SELECT value FROM test_table WHERE id > 2) AS filtered;
SELECT t1.id, sys.quantile(t2.value, 0.5) FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id WHERE t1.value IS NOT NULL GROUP BY t1.id;
CREATE TABLE another_table (value DECIMAL(10, 2));
INSERT INTO another_table VALUES (100.00), (200.00), (300.00), (NULL);
SELECT sys.quantile(value, 0.25) FROM another_table;
INSERT INTO another_table VALUES (400.00);
SELECT sys.quantile(value, 1.0) FROM another_table WHERE value IS NOT NULL;