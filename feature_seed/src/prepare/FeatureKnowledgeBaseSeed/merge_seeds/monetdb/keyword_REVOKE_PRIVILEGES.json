CREATE TABLE web_event (id INT, event_name VARCHAR(255), timestamp TIMESTAMP);
CREATE FUNCTION refresh_func() RETURNS VOID AS $$ BEGIN -- some logic here END;
$$;
GRANT ALL PRIVILEGES ON TABLE web_event TO jan;
REVOKE SELECT ON TABLE web_event FROM PUBLIC;
REVOKE INSERT, DELETE ON TABLE web_event FROM jan;
REVOKE EXECUTE ON FUNCTION refresh_func FROM piet;
REVOKE ALL PRIVILEGES ON FUNCTION refresh_func FROM GROUP admin;
CREATE ROLE admin;
GRANT SELECT, INSERT ON TABLE web_event TO admin;
REVOKE GRANT OPTION FOR INSERT ON TABLE web_event FROM admin;
REVOKE UPDATE, TRUNCATE ON TABLE web_event FROM jan, piet;
REVOKE EXECUTE ON FUNCTION refresh_func FROM PUBLIC;
REVOKE COPY INTO ON TABLE web_event FROM jan;
REVOKE ALL PRIVILEGES ON TABLE web_event FROM jan;
REVOKE INSERT ON TABLE users FROM GROUP admin WHERE EXISTS (SELECT * FROM web_event WHERE event_name = 'login');
REVOKE SELECT ON ALL TABLES IN SCHEMA public FROM user_role;