CREATE TABLE json_test (data TEXT);
INSERT INTO json_test VALUES ('{"a":[1]}');
INSERT INTO json_test VALUES ('{"b":true}');
INSERT INTO json_test VALUES ('{"c":null}');
INSERT INTO json_test VALUES ('{"array":[{"d":2},{"e":3}]}');
INSERT INTO json_test VALUES ('{"invalid_json":}');
INSERT INTO json_test VALUES ('[{"f":1.5},{"g":2.5}]');
INSERT INTO json_test VALUES ('{"key1":"value1", "key2": [1, 2, 3], "key3":{"nested_key": "nested_value"}}');
INSERT INTO json_test VALUES ('{"key1":1, "key2": {"key3":"nested"}}');
SELECT json.isvalid(data) FROM json_test WHERE data IS NOT NULL;
SELECT json.isvalid((SELECT data FROM json_test WHERE data = '{"a":[1]}')) AS valid_json;
WITH valid_data AS (SELECT data FROM json_test WHERE json.isvalid(data)) SELECT COUNT(*) FROM valid_data;
SELECT (SELECT COUNT(*) FROM json_test) AS total_records, (SELECT COUNT(*) FROM json_test WHERE json.isvalid(data)) AS valid_records;
SELECT json.isvalid((SELECT data FROM json_test WHERE data LIKE '%invalid%')) AS is_valid FROM json_test;
SELECT json.isvalid(data) FROM json_test WHERE json.isvalid(data) = FALSE;
CREATE TABLE json_test_complex AS SELECT data, json.isvalid(data) AS is_valid FROM json_test;
SELECT data FROM json_test_complex WHERE is_valid = TRUE;
SELECT COUNT(*) FROM (SELECT data FROM json_test_complex WHERE is_valid = TRUE) AS valid_json_records;