CREATE TABLE test_rand (id INT, rand_value INT);
INSERT INTO test_rand (id, rand_value) VALUES (1, rand());
INSERT INTO test_rand (id, rand_value) VALUES (2, rand());
INSERT INTO test_rand (id, rand_value) VALUES (3, rand());
SELECT * FROM test_rand;
SELECT id, rand_value FROM test_rand WHERE rand_value < 1000;
SELECT SUM(rand_value) FROM test_rand GROUP BY id HAVING SUM(rand_value) > 10;
SELECT id, (rand() % 100) AS random_mod FROM test_rand WHERE random_mod = 0;
CREATE TABLE additional_data (a INT, b INT);
INSERT INTO additional_data (a, b) VALUES (rand(), rand());
SELECT ad.a, ad.b, tr.rand_value FROM additional_data ad JOIN test_rand tr ON ad.a = tr.id WHERE ad.b < 500 AND tr.rand_value > 100;
SELECT rand(), COUNT(*) FROM test_rand GROUP BY rand();
WITH random_values AS (SELECT rand() AS r FROM test_rand) SELECT AVG(r) AS average_rand FROM random_values;
SELECT MAX(rand()) AS max_rand_value FROM test_rand UNION SELECT MIN(rand()) AS min_rand_value FROM test_rand;
CREATE TABLE complex_rand (id SERIAL PRIMARY KEY, random_value INT);
INSERT INTO complex_rand (random_value) SELECT rand() FROM test_rand;
SELECT COUNT(*) FROM complex_rand WHERE random_value > 2147483647;