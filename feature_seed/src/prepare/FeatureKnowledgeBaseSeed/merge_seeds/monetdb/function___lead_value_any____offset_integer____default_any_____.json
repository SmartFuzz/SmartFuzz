CREATE TABLE sales (id INT, product VARCHAR(100), sale_date DATE, amount DECIMAL(10, 2));
INSERT INTO sales VALUES (1, 'A', '2023-01-01', 100.00);
INSERT INTO sales VALUES (2, 'B', '2023-01-02', 150.00);
INSERT INTO sales VALUES (3, 'A', '2023-01-03', 200.00);
INSERT INTO sales VALUES (4, 'B', '2023-01-04', 250.00);
INSERT INTO sales VALUES (5, 'C', '2023-01-05', NULL);
SELECT id, product, amount, lead(amount) OVER (PARTITION BY product ORDER BY sale_date) AS next_amount FROM sales;
SELECT id, product, amount, lead(amount, 2, 0) OVER (PARTITION BY product ORDER BY sale_date) AS next_amount_2 FROM sales;
SELECT id, product, sale_date, lead(sale_date, 1, '2023-01-10') OVER (ORDER BY sale_date) AS next_sale_date FROM sales;
SELECT id, product, amount, lead(amount) OVER (ORDER BY sale_date RANGE BETWEEN INTERVAL '1 DAY' PRECEDING AND CURRENT ROW) AS next_amount_range FROM sales;
CREATE TABLE customer_orders (customer_id INT, order_id INT, order_date DATE);
INSERT INTO customer_orders VALUES (1, 101, '2023-01-01');
INSERT INTO customer_orders VALUES (1, 102, '2023-01-03');
INSERT INTO customer_orders VALUES (2, 201, '2023-01-02');
INSERT INTO customer_orders VALUES (2, 202, '2023-01-05');
SELECT co.customer_id, co.order_id, co.order_date, lead(co.order_date) OVER (PARTITION BY co.customer_id ORDER BY co.order_date) AS next_order_date FROM customer_orders co;
SELECT c.customer_id, c.order_id, c.order_date, lead(c.order_date, 1, '2023-01-11') OVER (PARTITION BY c.customer_id ORDER BY c.order_date) AS custom_next_order_date FROM customer_orders c WHERE c.order_date IS NOT NULL;
SELECT DISTINCT so.product, so.amount, lead(so.amount, 1, 0) OVER (PARTITION BY so.product ORDER BY so.sale_date) AS lead_amount FROM sales AS so WHERE so.amount IS NOT NULL;
WITH order_totals AS (SELECT customer_id, SUM(amount) AS total_amount FROM sales GROUP BY customer_id) SELECT ot.customer_id, ot.total_amount, lead(ot.total_amount) OVER (ORDER BY ot.total_amount) AS next_total FROM order_totals ot;