CREATE TABLE intervals_table (id INT, duration INTERVAL HOUR TO MINUTE);
INSERT INTO intervals_table VALUES (1, INTERVAL '5:30'), (2, INTERVAL '12:45'), (3, INTERVAL '3:15'), (4, INTERVAL '0:0');
SELECT id, duration, EXTRACT(HOUR FROM duration) AS hour_part, EXTRACT(MINUTE FROM duration) AS minute_part FROM intervals_table;
SELECT id FROM intervals_table WHERE duration > INTERVAL '5:0';
SELECT * FROM intervals_table WHERE duration IN (SELECT duration FROM intervals_table WHERE id != 3);
CREATE TABLE another_table (id INT, created_at TIMESTAMP);
INSERT INTO another_table VALUES (1, TIMESTAMP '2023-01-01 10:00:00'), (2, TIMESTAMP '2023-01-02 15:30:00');
SELECT a.id, a.created_at, a.created_at + duration AS new_time FROM another_table a JOIN intervals_table i ON a.id = i.id;
SELECT AVG(EXTRACT(MINUTE FROM duration)) FROM intervals_table;
SELECT COUNT(*) FROM intervals_table WHERE duration BETWEEN INTERVAL '1:0' AND INTERVAL '10:0';
CREATE TABLE additional_table (id INT, interval_data INTERVAL HOUR TO MINUTE);
INSERT INTO additional_table SELECT id, duration FROM intervals_table WHERE duration IS NOT NULL;
SELECT a.id, (SELECT COUNT(*) FROM additional_table WHERE interval_data = a.duration) AS count_matches FROM intervals_table a;
UPDATE intervals_table SET duration = duration + INTERVAL '1:0' WHERE id = 2;
DELETE FROM intervals_table WHERE duration < INTERVAL '2:0';
SELECT DISTINCT duration FROM intervals_table ORDER BY duration DESC LIMIT 5;