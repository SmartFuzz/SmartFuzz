SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2020-01-01';
SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2020-02-29';
SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2020-03-22';
SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2019-11-30';
SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2021-02-28';
SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2021-03-01';
