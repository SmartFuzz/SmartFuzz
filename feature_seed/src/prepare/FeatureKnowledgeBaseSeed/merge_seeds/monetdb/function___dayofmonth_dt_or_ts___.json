SELECT dayofmonth(event_date) FROM test_dates WHERE event_date = DATE '2023-12-31';
SELECT id, dayofmonth(event_date) FROM test_dates WHERE event_date BETWEEN DATE '2020-01-01' AND DATE '2020-12-31';
SELECT id, dayofmonth(event_date) AS day FROM test_dates WHERE dayofmonth(event_date) IN (SELECT dayofmonth(DATE '2020-03-22'));
SELECT t1.id, dayofmonth(t1.event_date), t2.description FROM test_dates AS t1 JOIN event_descriptions AS t2 ON t1.id = t2.event_id;
SELECT t1.id, dayofmonth(t1.event_date) FROM test_dates AS t1 WHERE EXISTS (SELECT 1 FROM some_other_table WHERE some_condition);
SELECT dayofmonth(MIN(event_date)) AS min_day, dayofmonth(MAX(event_date)) AS max_day FROM test_dates;
SELECT COUNT(*), dayofmonth(event_date) FROM test_dates GROUP BY dayofmonth(event_date);