CREATE TABLE test_strings (id INT PRIMARY KEY, s STRING);
INSERT INTO test_strings (id, s) VALUES (1, 'abcdefg');
INSERT INTO test_strings (id, s) VALUES (2, 'highigh');
INSERT INTO test_strings (id, s) VALUES (3, 'substr test');
INSERT INTO test_strings (id, s) VALUES (4, 'gh');
INSERT INTO test_strings (id, s) VALUES (5, '');
INSERT INTO test_strings (id, s) VALUES (6, NULL);
SELECT charindex('gh', s, 1) FROM test_strings WHERE id = 1;
SELECT charindex('gh', s, 1) FROM test_strings WHERE id = 2;
SELECT charindex('sub', s, 1) FROM test_strings WHERE id = 3;
SELECT charindex('test', s, 1) FROM test_strings WHERE id = 3;
SELECT charindex('gh', s, 4) FROM test_strings WHERE id = 2;
SELECT charindex('gh', s, 1) FROM test_strings WHERE id = 4;
SELECT charindex('a', s, 1) FROM test_strings WHERE id = 1;
SELECT charindex('a', s, 0) FROM test_strings WHERE id = 1;
SELECT charindex('nonexistent', s, 1) FROM test_strings WHERE id = 1;
SELECT charindex(specific_substr, s, 1) FROM (SELECT s AS specific_substr FROM test_strings WHERE id = 4) AS temp_table, test_strings WHERE id = 2;
SELECT charindex('x', s, 1) FROM test_strings WHERE id = 5;
SELECT charindex(substr, s, 1) FROM (SELECT 'gh' AS substr) AS subquery, test_strings WHERE id = 2;
SELECT s, charindex('gh', s, 2) FROM test_strings;
SELECT CASE WHEN charindex('gh', s, 1) > 0 THEN 'Found' ELSE 'Not Found' END AS result FROM test_strings;