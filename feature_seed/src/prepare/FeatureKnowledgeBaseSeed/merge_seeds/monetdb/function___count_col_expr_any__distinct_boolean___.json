CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 10), (4, NULL);
SELECT COUNT(value) FROM test_table;
SELECT COUNT(DISTINCT value) FROM test_table;
SELECT COUNT(value) FROM test_table WHERE id > 2;
SELECT COUNT(DISTINCT value) FROM test_table WHERE value IS NOT NULL;
CREATE TABLE another_table (category VARCHAR(20), amount INT);
INSERT INTO another_table VALUES ('A', 100), ('B', 150), ('A', 100), ('C', 200);
SELECT COUNT(DISTINCT category) FROM another_table;
SELECT COUNT(*) FROM (SELECT value FROM test_table WHERE value IS NOT NULL) AS subquery;
SELECT t1.id, COUNT(t2.amount) FROM test_table t1 LEFT JOIN another_table t2 ON t1.value = t2.amount GROUP BY t1.id;
SELECT COUNT(DISTINCT t2.category) FROM test_table t1 JOIN another_table t2 ON t1.value = t2.amount WHERE t1.id < 4;
SELECT COUNT(*) FROM (SELECT DISTINCT value FROM test_table WHERE value > 5) AS distinct_values;
CREATE TABLE complex_table (col1 INT, col2 INT, col3 INT);
INSERT INTO complex_table VALUES (1, 2, NULL), (1, NULL, 3), (NULL, 2, 3), (1, 2, 3);
SELECT COUNT(DISTINCT col1) FROM complex_table;
SELECT COUNT(col2) FROM complex_table WHERE col3 IS NOT NULL;
SELECT COUNT(DISTINCT col1) FROM complex_table WHERE col2 IS NOT NULL AND col3 IS NOT NULL;
SELECT t1.col1, COUNT(DISTINCT t2.col3) FROM complex_table t1 JOIN complex_table t2 ON t1.col1 = t2.col1 GROUP BY t1.col1;