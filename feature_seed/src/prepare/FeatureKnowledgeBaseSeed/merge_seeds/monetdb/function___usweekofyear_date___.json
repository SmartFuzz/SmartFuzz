CREATE TABLE dates_table (id INT, event_date DATE);
INSERT INTO dates_table (id, event_date) VALUES (1, DATE '2020-01-01');
INSERT INTO dates_table (id, event_date) VALUES (2, DATE '2020-03-22');
INSERT INTO dates_table (id, event_date) VALUES (3, DATE '2020-12-31');
INSERT INTO dates_table (id, event_date) VALUES (4, DATE '2021-01-01');
INSERT INTO dates_table (id, event_date) VALUES (5, DATE '2020-12-28');
SELECT usweekofyear(event_date) FROM dates_table WHERE id = 2;
SELECT usweekofyear(event_date) FROM dates_table WHERE event_date BETWEEN DATE '2020-01-01' AND DATE '2020-12-31';
SELECT id, event_date, usweekofyear(event_date) AS week_number FROM dates_table ORDER BY event_date ASC;
CREATE TABLE events (event_id INT, event_name VARCHAR(50), event_date DATE);
INSERT INTO events (event_id, event_name, event_date) VALUES (1, 'New Year', DATE '2020-01-01');
INSERT INTO events (event_id, event_name, event_date) VALUES (2, 'My Birthday', DATE '2020-03-22');
INSERT INTO events (event_id, event_name, event_date) VALUES (3, 'Christmas', DATE '2020-12-25');
SELECT e.event_name, usweekofyear(e.event_date) AS week_number FROM events e WHERE e.event_date >= DATE '2020-01-01';
SELECT DISTINCT usweekofyear(EVENT_DATE) FROM events WHERE event_date IS NOT NULL;
SELECT e.event_name, usweekofyear(e.event_date) AS week_number FROM events e WHERE EXISTS (SELECT 1 FROM dates_table d WHERE d.event_date = e.event_date);
SELECT e.event_name, usweekofyear(e.event_date) AS week_number FROM events e JOIN dates_table d ON e.event_date = d.event_date WHERE d.id BETWEEN 1 AND 3;
SELECT MAX(usweekofyear(event_date)) FROM dates_table;
SELECT MIN(usweekofyear(event_date)) FROM dates_table;
SELECT AVG(usweekofyear(event_date)) FROM dates_table;
SELECT e.event_name, usweekofyear(e.event_date) AS week_number FROM events e WHERE usweekofyear(e.event_date) = (SELECT MAX(usweekofyear(event_date)) FROM events);