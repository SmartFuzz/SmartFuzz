CREATE TABLE test_table (id INT, name VARCHAR(100));
INSERT INTO test_table VALUES (1, 'abCde');
SELECT substr(name, 1) FROM test_table WHERE id = 1;
SELECT substr(name, 5) FROM test_table WHERE id = 1;
SELECT substr(name, 0) FROM test_table WHERE id = 1;
SELECT substr(name, -1) FROM test_table WHERE id = 1;
CREATE TABLE another_table (ref_id INT, description VARCHAR(100));
INSERT INTO another_table VALUES (1, 'Sample description');
SELECT substr(a.description, 1) FROM another_table a JOIN test_table t ON a.ref_id = t.id WHERE t.id = 1;
SELECT substr((SELECT name FROM test_table WHERE id = 1), 3) AS substring FROM test_table;
SELECT substr((SELECT MAX(name) FROM test_table), 2) FROM test_table WHERE id = 1;
SELECT substr(name, LENGTH(name) - 1) FROM test_table WHERE id = 1;
SELECT substr('abcdefgh', 4) || substr(name, 2) FROM test_table WHERE id = 1;
SELECT substr(name, 2) AS substr_start_2, substr(name, LENGTH(name) - 2) AS substr_end FROM test_table WHERE id = 1;
SELECT CONCAT(substr(name, 1, 3), 'xyz') FROM test_table WHERE id = 1;