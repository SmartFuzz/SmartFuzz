CREATE TABLE test_strings (id INT, raw_string STRING);
INSERT INTO test_strings VALUES (1, r'A\fB\tC\n\Z');
INSERT INTO test_strings VALUES (2, r'C\rD\tE\n\Z');
INSERT INTO test_strings VALUES (3, r'X\yZ\a\f\b');
INSERT INTO test_strings VALUES (4, r'Hello\tWorld\n!');
SELECT * FROM test_strings WHERE id = 1;
SELECT * FROM test_strings WHERE raw_string LIKE r'A\%';
SELECT id FROM test_strings WHERE raw_string NOT LIKE r'\d%';
SELECT id FROM test_strings WHERE raw_string IN (SELECT raw_string FROM test_strings WHERE id = 2);
SELECT t1.raw_string, t2.raw_string FROM test_strings t1 JOIN test_strings t2 ON t1.id < t2.id;
SELECT COUNT(*) FROM test_strings WHERE raw_string = r'C\rD\tE\n\Z';
WITH raw_strings AS (SELECT id, raw_string FROM test_strings WHERE id <= 3) SELECT * FROM raw_strings WHERE raw_string LIKE r'%\Z';
SELECT raw_string FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE raw_string LIKE r'%\t%');