CREATE TABLE employees (id INT, name STRING, department STRING, salary INT);
INSERT INTO employees VALUES (1, 'Alice', 'Engineering', 100000);
INSERT INTO employees VALUES (2, 'Bob', 'Engineering', 90000);
INSERT INTO employees VALUES (3, 'Charlie', 'HR', 60000);
INSERT INTO employees VALUES (4, 'Diana', 'Engineering', 80000);
INSERT INTO employees VALUES (5, 'Evan', 'HR', 60000);
CREATE TABLE departments (dept_name STRING, budget INT);
INSERT INTO departments VALUES ('Engineering', 500000);
INSERT INTO departments VALUES ('HR', 200000);
SELECT name, rank(salary) OVER (PARTITION BY department ORDER BY salary DESC) AS salary_rank FROM employees;
SELECT d.dept_name, e.name, rank(e.salary) OVER (PARTITION BY d.dept_name ORDER BY e.salary DESC) AS salary_rank FROM departments d JOIN employees e ON d.dept_name = e.department;
SELECT e1.name, e1.salary, rank(e2.salary) OVER (ORDER BY e2.salary) AS overall_rank FROM employees e1 JOIN employees e2 ON e1.id <> e2.id WHERE e1.salary > e2.salary;
SELECT e.name, e.salary, rank(salary) OVER (ORDER BY salary) AS rank_value FROM (SELECT id, name, salary FROM employees WHERE department = 'Engineering') AS e;
SELECT e.name, e.salary, rank(salary) AS salary_rank FROM (SELECT id, name, salary FROM employees WHERE salary IS NOT NULL) AS e ORDER BY e.salary DESC;
CREATE TABLE sales (id INT, employee_id INT, sale_amount INT);
INSERT INTO sales VALUES (1, 1, 5000);
INSERT INTO sales VALUES (2, 2, 3000);
INSERT INTO sales VALUES (3, 3, 4000);
SELECT e.name, e.salary, rank(s.sale_amount) OVER (PARTITION BY e.department ORDER BY s.sale_amount DESC) AS sales_rank FROM employees e JOIN sales s ON e.id = s.employee_id;