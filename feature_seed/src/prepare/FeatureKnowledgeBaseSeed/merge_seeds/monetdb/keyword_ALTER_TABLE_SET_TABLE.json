CREATE TABLE test_schema.base_table (id INT, value INT, PRIMARY KEY(id));
CREATE TABLE test_schema.merge_table (id INT, value INT, PRIMARY KEY(id));
CREATE TABLE test_schema.partitioned_table (id INT, value INT, PRIMARY KEY(id)) PARTITION BY RANGE (value);
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.merge_table AS PARTITION IN (value);
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.base_table AS PARTITION FROM RANGE MINVALUE 0 TO RANGE MAXVALUE 100 WITH NULL VALUES;
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.merge_table AS PARTITION FOR NULL VALUES;
CREATE TABLE test_schema.another_table (id INT, description TEXT);
ALTER TABLE test_schema.partitioned_table SET TABLE test_schema.another_table AS PARTITION IN (id, value);
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.merge_table AS PARTITION FROM RANGE MINVALUE 10 TO RANGE MAXVALUE 20 WITH NULL VALUES;
CREATE MERGE TABLE test_schema.yet_another_table (id INT, value INT, PRIMARY KEY(id));
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.yet_another_table AS PARTITION IN (value, id);
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.base_table AS PARTITION FOR NULL VALUES;
ALTER TABLE IF EXISTS test_schema.partitioned_table SET TABLE test_schema.merge_table AS PARTITION FROM RANGE MINVALUE 20 TO RANGE MAXVALUE 30 WITH NULL VALUES;