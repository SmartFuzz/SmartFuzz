CREATE TABLE test_table (id INT, name STRING);
CREATE LOADER test_loader AS SELECT * FROM test_table;
COPY LOADER INTO test_table FROM test_loader();
COPY LOADER INTO test_table FROM test_loader('1', 'John Doe');
COPY LOADER INTO test_table FROM test_loader('2', 'Jane Smith');
CREATE TABLE second_table (id INT, value INT);
CREATE LOADER second_loader AS SELECT * FROM second_table;
COPY LOADER INTO second_table FROM second_loader();
COPY LOADER INTO second_table FROM second_loader('3', 100);
COPY LOADER INTO second_table FROM second_loader('4', 200);
COPY LOADER INTO test_table FROM test_loader(('5', 'Emily White'), ('6', 'Michael Brown'));
COPY LOADER INTO test_table FROM test_loader();
COPY LOADER INTO test_table FROM test_loader('7', 'Anna Black');
COPY LOADER INTO test_table FROM (SELECT name FROM second_table WHERE id = 3) AS tmp_loader;
COPY LOADER INTO test_table FROM test_loader('8', (SELECT MAX(value) FROM second_table));
COPY LOADER INTO test_table FROM (SELECT id, name FROM test_table WHERE id > 4);
DROP TABLE IF EXISTS test_table;
DROP TABLE IF EXISTS second_table;