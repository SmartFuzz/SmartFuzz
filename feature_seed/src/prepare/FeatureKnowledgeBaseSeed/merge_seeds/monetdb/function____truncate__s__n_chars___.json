CREATE TABLE test_strings (id INT, str_value VARCHAR(100));
INSERT INTO test_strings VALUES (1, 'Truncate'), (2, 'Hello World'), (3, 'MonetDB is great!');
SELECT "truncate"(str_value, 4) FROM test_strings;
SELECT id, "truncate"(str_value, 5) AS truncated_value FROM test_strings WHERE id = 2;
SELECT "truncate"(str_value, LENGTH(str_value)) FROM test_strings;
SELECT "truncate"(str_value, 0) FROM test_strings;
SELECT "truncate"(str_value, 100) FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE id < 3);
CREATE TABLE extra_strings (extra_id INT, extra_str_value VARCHAR(200));
INSERT INTO extra_strings VALUES (1, 'Fuzzy Testing'), (2, 'Another long string example');
SELECT es.extra_id, "truncate"(es.extra_str_value, 10) AS truncated_extra FROM extra_strings es JOIN test_strings ts ON LENGTH(ts.str_value) < 15;
SELECT ts.id, "truncate"(ts.str_value, n.n_chars) FROM test_strings ts JOIN (SELECT 3 AS n_chars UNION SELECT 7 UNION SELECT 1) n ON LENGTH(ts.str_value) >= n.n_chars;
SELECT "truncate"((SELECT str_value FROM test_strings WHERE id = 3), 10);
SELECT "truncate"(CONCAT(str_value, ' additional text'), 20) AS concatenated_truncate FROM test_strings;
SELECT COUNT(*) FROM (SELECT "truncate"(str_value, 5) FROM test_strings) AS truncated_strings WHERE truncated_strings IS NOT NULL;
CREATE TABLE combined_test AS SELECT "truncate"(str_value, 8) FROM test_strings UNION SELECT "truncate"(extra_str_value, 12) FROM extra_strings;
SELECT * FROM combined_test WHERE "truncate"(str_value, 4) = 'Tru';