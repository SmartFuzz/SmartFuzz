CREATE TABLE timestamps (id INT, event_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '2023-10-01 15:35:02');
INSERT INTO timestamps VALUES (2, TIMESTAMP '2023-10-01 23:45:59');
INSERT INTO timestamps VALUES (3, TIMESTAMP '2023-10-02 00:00:00');
INSERT INTO timestamps VALUES (4, TIMESTAMP '2023-10-02 12:30:30');
SELECT minute(event_time) FROM timestamps WHERE id = 1;
SELECT minute(event_time) FROM timestamps WHERE id = 2;
SELECT minute(event_time) FROM timestamps WHERE id = 3;
SELECT minute(event_time) FROM timestamps WHERE id = 4;
CREATE TABLE timezones (id INT, event_time TIMETZ);
INSERT INTO timezones VALUES (1, TIMETZ '15:35:02.002345+01:00');
INSERT INTO timezones VALUES (2, TIMETZ '13:15:00.000000-05:00');
SELECT minute(event_time) FROM timezones WHERE id = 1;
SELECT minute(event_time) FROM timezones WHERE id = 2;
CREATE TABLE intervals (id INT, interval_time INTERVAL);
INSERT INTO intervals VALUES (1, INTERVAL '1 hour 15 minutes');
SELECT minute(INTERVAL '00:15:00') AS min_interval;
SELECT minute(INTERVAL '01:30:00') AS min_interval;
SELECT minute(INTERVAL '00:00:59') AS min_interval;
SELECT minute(INTERVAL '00:00:00') AS min_interval;
SELECT minute(MAX(event_time)) FROM timestamps;
SELECT minute(MIN(event_time)) FROM timestamps;
SELECT COUNT(*), minute(event_time) FROM timestamps GROUP BY minute(event_time);
SELECT minute(event_time) FROM timestamps WHERE event_time IN (SELECT event_time FROM timestamps WHERE id = 1);
SELECT minute(t1.event_time) FROM timestamps t1 JOIN timestamps t2 ON t1.id <> t2.id WHERE minute(t1.event_time) > minute(t2.event_time);