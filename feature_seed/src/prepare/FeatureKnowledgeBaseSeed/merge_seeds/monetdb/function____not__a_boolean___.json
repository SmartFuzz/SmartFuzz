CREATE TABLE boolean_table (id INT, value BOOLEAN);
INSERT INTO boolean_table VALUES (1, TRUE);
INSERT INTO boolean_table VALUES (2, FALSE);
SELECT NOT value FROM boolean_table WHERE id = 1;
SELECT NOT value FROM boolean_table WHERE id = 2;
CREATE TABLE another_table (id INT, flag BOOLEAN);
INSERT INTO another_table VALUES (1, TRUE);
INSERT INTO another_table VALUES (2, FALSE);
SELECT a.id, NOT a.flag AS negated_flag FROM another_table a JOIN boolean_table b ON a.id = b.id;
SELECT NOT (SELECT value FROM boolean_table WHERE id = 1) AS negated_value;
SELECT NOT (SELECT flag FROM another_table WHERE id = 2) AS negated_flag;
WITH negated AS (SELECT id, NOT value AS negated_value FROM boolean_table) SELECT * FROM negated;
SELECT NOT (id = 1) FROM boolean_table WHERE id IN (1, 2);
SELECT a.id, b.id, NOT (a.value AND b.flag) AS combined_negation FROM boolean_table a JOIN another_table b ON a.id = b.id;
CREATE TABLE complex_table (id INT, is_active BOOLEAN);
INSERT INTO complex_table VALUES (1, TRUE);
INSERT INTO complex_table VALUES (2, FALSE);
SELECT NOT (SELECT COUNT(*) FROM complex_table WHERE is_active = TRUE) > 0 AS has_active;