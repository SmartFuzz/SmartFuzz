CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(50));
INSERT INTO users (id, username) VALUES (1, 'admin');
INSERT INTO users (id, username) VALUES (2, 'jan');
SET USER = admin;
SELECT USER;
SET USER = jan;
SELECT USER;
CREATE TABLE user_roles (user_id INT, role VARCHAR(50), FOREIGN KEY (user_id) REFERENCES users(id));
INSERT INTO user_roles (user_id, role) VALUES (1, 'administrator');
INSERT INTO user_roles (user_id, role) VALUES (2, 'user');
SET USER = (SELECT username FROM users WHERE id = (SELECT MAX(id) FROM users));
SELECT USER;
SET USER = (SELECT username FROM users WHERE id = ?);
SET USER = (SELECT username FROM users WHERE username LIKE 'a%');
CREATE TABLE session (session_id INT, user_id INT, FOREIGN KEY (user_id) REFERENCES users(id));
INSERT INTO session (session_id, user_id) VALUES (1, 1);
INSERT INTO session (session_id, user_id) VALUES (2, 2);
SET USER = (SELECT username FROM users JOIN session ON users.id = session.user_id WHERE session_id = 1);
SELECT USER;
SET USER = jan WHERE EXISTS (SELECT 1 FROM users WHERE username = 'jan');
SET USER = (SELECT username FROM users ORDER BY id DESC LIMIT 1);
SET USER = (SELECT username FROM (SELECT username FROM users ORDER BY username) AS sub ORDER BY sub.username DESC LIMIT 1);
SET USER = (SELECT username FROM users WHERE user_id IN (SELECT user_id FROM user_roles WHERE role = 'user'));