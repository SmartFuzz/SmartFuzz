CREATE TABLE urls (url CLOB);
INSERT INTO urls VALUES ('http://example.com:8080/path');
INSERT INTO urls VALUES ('https://example.com:443/resource');
INSERT INTO urls VALUES ('ftp://ftp.example.com:21/file');
INSERT INTO urls VALUES ('http://127.0.0.1:5000/test');
INSERT INTO urls VALUES ('http://localhost/path?query=param#fragment');
INSERT INTO urls VALUES (NULL);
INSERT INTO urls VALUES ('file:///C:/example.txt');
INSERT INTO urls VALUES ('http://my.web.site:9999');
SELECT sys.getport(url) FROM urls;
SELECT COUNT(*) FROM urls WHERE sys.getport(url) IS NOT NULL;
SELECT url, sys.getport(url) as port FROM urls WHERE sys.getport(url) IS NOT NULL;
SELECT DISTINCT sys.getport(url) FROM urls WHERE sys.getport(url) IN (SELECT sys.getport(url) FROM urls WHERE url LIKE 'http%');
CREATE TABLE test_ports AS SELECT sys.getport(url) AS port FROM urls;
SELECT AVG(sys.getport(port)) FROM (SELECT sys.getport(url) AS port FROM urls WHERE sys.getport(url) IS NOT NULL) AS valid_ports;