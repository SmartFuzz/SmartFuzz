CREATE TABLE test_varchar (id INTEGER PRIMARY KEY, name CHARACTER VARYING (255));
INSERT INTO test_varchar (id, name) VALUES (1, 'John Doe');
INSERT INTO test_varchar (id, name) VALUES (2, 'Alice Smith');
INSERT INTO test_varchar (id, name) VALUES (3, 'B');
SELECT * FROM test_varchar WHERE LENGTH(name) BETWEEN 1 AND 10;
SELECT * FROM test_varchar WHERE name LIKE 'A%';
CREATE TABLE test_varchar2 (id INTEGER PRIMARY KEY, description CHARACTER VARYING (100));
INSERT INTO test_varchar2 (id, description) VALUES (1, 'This is a test');
INSERT INTO test_varchar2 (id, description) VALUES (2, 'Short desc');
SELECT t1.id, t1.name, t2.description FROM test_varchar t1 JOIN test_varchar2 t2 ON t1.id = t2.id;
SELECT id, name FROM test_varchar WHERE id IN (SELECT id FROM test_varchar2 WHERE description LIKE '%test%');
CREATE TABLE test_varchar3 (id INTEGER PRIMARY KEY, comments CHARACTER VARYING (2147483647));
INSERT INTO test_varchar3 (id, comments) VALUES (1, REPEAT('a', 2147483647));
SELECT id FROM test_varchar3 WHERE LENGTH(comments) = 2147483647;
SELECT id FROM test_varchar3 WHERE LENGTH(comments) < 2147483647 ORDER BY id DESC;
CREATE TABLE test_varchar4 (id INTEGER PRIMARY KEY, title CHARACTER VARYING (500));
INSERT INTO test_varchar4 (id, title) VALUES (1, 'Introduction to MonetDB');
INSERT INTO test_varchar4 (id, title) VALUES (2, 'Advanced MonetDB Techniques');
SELECT t1.id, t1.title FROM test_varchar4 t1 WHERE EXISTS (SELECT 1 FROM test_varchar t2 WHERE t2.id = t1.id);
SELECT id, name FROM test_varchar WHERE name IN (SELECT title FROM test_varchar4);