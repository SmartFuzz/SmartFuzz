CREATE TABLE dates_table (date_col DATE);
INSERT INTO dates_table VALUES (date '2020-09-28');
CREATE TABLE another_table (numeric_col INT);
INSERT INTO another_table VALUES (1), (2), (3);
SELECT date '2020-09-28' + INTERVAL '1 DAY' AS next_day;
SELECT date '2020-02-29' AS leap_year_date;
SELECT date '2020-01-01', date '2020-12-31' WHERE date '2020-01-01' < date '2020-12-31';
SELECT (SELECT date '2020-09-28' FROM dates_table WHERE date_col = date '2020-09-28') AS selected_date;
SELECT date '2000-02-29' AS valid_leap_date, date '2001-02-29' AS invalid_leap_date;
SELECT d.date_col FROM dates_table d JOIN another_table a ON a.numeric_col = 1 WHERE date '2020-09-28' = d.date_col;
SELECT date '2023-01-01' - INTERVAL '3 MONTH' AS three_months_ago;
SELECT CASE WHEN date '2020-09-28' >= date '2020-09-01' THEN date '2020-09-28' ELSE date '2020-09-01' END AS return_date;
SELECT d.date_col, (SELECT COUNT(*) FROM another_table) AS count FROM dates_table d;
CREATE TABLE complex_table (id INT, valid_date DATE);
INSERT INTO complex_table VALUES (1, date '2020-01-01'), (2, date '2020-02-29'), (3, date '2021-03-01');
SELECT id, valid_date FROM complex_table WHERE valid_date IS NOT NULL AND valid_date < date '2021-01-01';
SELECT date '2020-09-28' + INTERVAL '0 DAY' AS same_date, date '2020-09-28' + INTERVAL '30 DAY' AS future_date;
INSERT INTO dates_table VALUES (date '2023-10-10'), (date '2023-10-11');
SELECT DISTINCT date_col FROM dates_table ORDER BY date_col DESC;