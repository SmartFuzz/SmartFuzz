CREATE TABLE test_strings (s1 VARCHAR(100), s2 VARCHAR(100));
INSERT INTO test_strings VALUES ('abcd', 'BC'), ('Hello World', 'world'), (NULL, 'test'), ('OpenAI GPT', NULL), ('Fuzzy Testing', 'TY'), ('complexity', 'simpl');
SELECT contains(s1, s2, true) FROM test_strings WHERE s1 IS NOT NULL AND s2 IS NOT NULL;
SELECT s1, s2, contains(s1, s2, false) AS case_sensitive FROM test_strings;
SELECT contains(s1, 'test', true) FROM test_strings WHERE s1 LIKE 'Fuzzy%';
SELECT t1.s1, t2.s2, contains(t1.s1, t2.s2, false) AS case_sensitive FROM test_strings t1 JOIN test_strings t2 ON t1.s1 <> t2.s1 WHERE contains(t1.s1, 'Testing', true);
SELECT s1, s2, contains(s1, s2, false) AS result FROM (SELECT s1, s2 FROM test_strings) AS subquery WHERE result IS NOT NULL;
SELECT COUNT(*) FROM test_strings WHERE contains(s1, s2, true);
CREATE TABLE another_table (s3 VARCHAR(100));
INSERT INTO another_table VALUES ('abcdef'), ('caseTest'), (NULL);
SELECT a.s3, b.s1, contains(b.s1, a.s3, true) AS match FROM another_table a JOIN test_strings b ON contains(b.s1, a.s3, false);
SELECT contains('A quick Brown fox', 'QUICK', true) AS quick_check;
SELECT contains('A quick Brown fox', 'brown', false) AS brown_check;
SELECT CASE WHEN contains('This is a test', 'test', true) THEN 'Contains' ELSE 'Does not contain' END AS test_case_check;