CREATE TABLE test_timestamps (id SERIAL PRIMARY KEY, ts1 TIMESTAMP, ts2 TIMESTAMP);
INSERT INTO test_timestamps (ts1, ts2) VALUES (timestamp '2021-12-31 18:40:40', timestamp '2021-12-31 16:30:20');
INSERT INTO test_timestamps (ts1, ts2) VALUES (timestamp '2021-01-01 00:00:00', timestamp '2020-12-31 23:59:59');
INSERT INTO test_timestamps (ts1, ts2) VALUES (timestamp '2021-06-15 12:15:15', timestamp '2021-06-15 12:00:00');
INSERT INTO test_timestamps (ts1, ts2) VALUES (timestamp '2022-12-31 23:59:59', timestamp '2021-01-01 00:00:01');
SELECT timestampdiff_min(ts1, ts2) FROM test_timestamps WHERE id = 1;
SELECT timestampdiff_min(ts1, ts2) FROM test_timestamps WHERE id = 2;
SELECT timestampdiff_min(ts1, ts2) FROM test_timestamps WHERE id = 3;
SELECT timestampdiff_min(ts1, ts2) FROM test_timestamps WHERE id = 4;
SELECT (SELECT timestampdiff_min(ts1, ts2) FROM test_timestamps WHERE id = 1) + (SELECT timestampdiff_min(ts1, ts2) FROM test_timestamps WHERE id = 2) AS combined_diff;
SELECT t1.id, timestampdiff_min(t1.ts1, t1.ts2) AS difference, t2.ts1 AS subquery_ts FROM test_timestamps t1 JOIN (SELECT ts1 FROM test_timestamps WHERE id = 3) AS t2 ON t1.id = 1;
CREATE TABLE complex_test (id SERIAL PRIMARY KEY, ts_a TIMESTAMP, ts_b TIMESTAMP);
INSERT INTO complex_test (ts_a, ts_b) VALUES (timestamp '2022-01-01 12:00:00', timestamp '2022-01-01 11:00:00');
INSERT INTO complex_test (ts_a, ts_b) VALUES (timestamp '2023-05-01 06:30:00', timestamp '2023-05-01 06:29:00');
SELECT id, timestampdiff_min(ts_a, ts_b) FROM complex_test WHERE ts_a > ts_b;
SELECT COUNT(*), AVG(timestampdiff_min(ts_a, ts_b)) FROM complex_test;
SELECT SUM(timestampdiff_min(ts1, ts2)) - SUM(timestampdiff_min(ts_a, ts_b)) AS total_difference FROM test_timestamps, complex_test;