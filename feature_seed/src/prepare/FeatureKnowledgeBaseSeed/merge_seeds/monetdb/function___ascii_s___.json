CREATE TABLE test_strings (id INT, str VARCHAR(255));
INSERT INTO test_strings VALUES (1, R'€'), (2, R'A'), (3, R'💻'), (4, R'123'), (5, R' '), (6, R'!');
SELECT ascii(str) FROM test_strings WHERE id = 1;
SELECT ascii(str) FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE id > 2);
SELECT ascii(s1.str) FROM test_strings AS s1 JOIN test_strings AS s2 ON s1.id = s2.id WHERE s2.str = R' ';
SELECT ascii(s1.str) + ascii(s2.str) FROM test_strings AS s1, test_strings AS s2 WHERE s1.id < s2.id;
SELECT COUNT(*) FROM (SELECT ascii(str) FROM test_strings WHERE str LIKE R'%A%') AS derived;
SELECT CASE WHEN ascii(str) >= 65 THEN 'Valid' ELSE 'Invalid' END AS validation FROM test_strings;
CREATE TABLE utf_strings (id INT, utf_str VARCHAR(255));
INSERT INTO utf_strings VALUES (1, R'€'), (2, R'Z'), (3, R'😊');
SELECT ascii(utf_str) FROM utf_strings WHERE id = (SELECT MAX(id) FROM utf_strings);
SELECT MAX(ascii(str)) FROM test_strings WHERE ascii(str) > 64;
SELECT ascii(str) FROM test_strings WHERE str NOT LIKE R'%a%' AND id IN (SELECT id FROM test_strings WHERE id < 5);
SELECT ascii(R' ') AS space_code, ascii(R'!') AS exclamation_code;
DELETE FROM test_strings WHERE ascii(str) < 65;