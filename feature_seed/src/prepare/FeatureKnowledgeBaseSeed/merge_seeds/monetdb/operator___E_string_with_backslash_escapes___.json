CREATE TABLE test_strings (id INT, escaped_string STRING);
INSERT INTO test_strings VALUES (1, E'A\fB\tC\n\Z');
INSERT INTO test_strings VALUES (2, E'Hello\nWorld\b!');
INSERT INTO test_strings VALUES (3, E'This is a tab:\tCheck it.');
INSERT INTO test_strings VALUES (4, E'New line:\nNext line.');
INSERT INTO test_strings VALUES (5, E'Alert character:\a and backspace.');
SELECT escaped_string FROM test_strings WHERE id = 1;
SELECT escaped_string FROM test_strings WHERE id = 2 AND escaped_string LIKE E'%\n%';
SELECT CONCAT(escaped_string, ' Extra Text') FROM test_strings WHERE id = 3;
SELECT id, LENGTH(escaped_string) AS length FROM test_strings WHERE LENGTH(escaped_string) > 15;
SELECT t1.escaped_string FROM test_strings t1 JOIN test_strings t2 ON t1.id != t2.id WHERE t1.escaped_string LIKE E'%\b%';
SELECT * FROM (SELECT escaped_string FROM test_strings WHERE id = 4) AS subquery WHERE LENGTH(escaped_string) > 10;
SELECT id, COUNT(*) AS count FROM test_strings GROUP BY id HAVING COUNT(*) > 1;
DELETE FROM test_strings WHERE id = 5;
SELECT escaped_string FROM test_strings ORDER BY id ASC;
SELECT id, (CASE WHEN escaped_string LIKE E'%\t%' THEN 'Contains Tab' ELSE 'No Tab' END) AS tab_check FROM test_strings;