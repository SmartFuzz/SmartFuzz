CREATE TABLE test_power (base DOUBLE, exponent DOUBLE);
INSERT INTO test_power VALUES (2, 5), (3, 3), (0, 1), (1, 100), (-2, 3), (0, 0);
SELECT power(base, exponent) FROM test_power;
SELECT power(2, 0) AS power_zero;
SELECT power(-3, 2) AS power_negative_base_even;
SELECT power(-3, 3) AS power_negative_base_odd;
SELECT power(NULL, 2) AS power_null_base;
SELECT power(2, NULL) AS power_null_exponent;
SELECT power(-2, -3) AS power_negative_exponent;
SELECT power(2.5, 1.5) AS power_float_base_float_exponent;
CREATE TABLE nested_test (id INT, base DOUBLE, exponent DOUBLE);
INSERT INTO nested_test VALUES (1, 3, 3), (2, 4, 2);
SELECT id, power((SELECT base FROM nested_test WHERE id = 1), (SELECT exponent FROM nested_test WHERE id = 2)) AS result FROM nested_test;
SELECT id, power((SELECT SUM(base) FROM nested_test), (SELECT SUM(exponent) FROM nested_test)) AS combined_power FROM nested_test;
CREATE TABLE join_test (id INT, base DOUBLE, exponent DOUBLE);
INSERT INTO join_test VALUES (1, 2, 3), (2, 3, 4);
SELECT jt.id, power(jt.base, jt.exponent) FROM join_test jt JOIN test_power tp ON jt.id = tp.base;
SELECT jt.id, power(jt.base, tp.exponent) FROM join_test jt, test_power tp WHERE jt.id * 2 = tp.exponent;