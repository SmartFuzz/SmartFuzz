CREATE TABLE test_dates (id INT, dt DATE, ts TIMESTAMP);
INSERT INTO test_dates VALUES (1, DATE '2020-01-01', TIMESTAMP '2020-01-01 12:00:00'), (2, DATE '2020-12-31', TIMESTAMP '2020-12-31 23:59:59'), (3, DATE '2021-02-28', TIMESTAMP '2021-02-28 12:00:00'), (4, DATE '2021-03-01', TIMESTAMP '2021-03-01 12:00:00'), (5, DATE '2022-12-31', TIMESTAMP '2022-12-31 12:00:00');
SELECT id, weekofyear(dt) AS week_num FROM test_dates WHERE dt BETWEEN DATE '2020-01-01' AND DATE '2020-12-31';
SELECT id, weekofyear(ts) AS week_num FROM test_dates WHERE ts >= TIMESTAMP '2021-01-01 00:00:00';
SELECT id, weekofyear(ts) AS week_num FROM test_dates WHERE ts < TIMESTAMP '2021-01-01 00:00:00' AND weekofyear(ts) IS NOT NULL;
CREATE TABLE events (event_id INT, event_date DATE);
INSERT INTO events VALUES (101, DATE '2020-03-21'), (102, DATE '2020-03-22'), (103, DATE '2020-03-23');
SELECT e.event_id, e.event_date, weekofyear(e.event_date) AS week_num FROM events e JOIN test_dates t ON weekofyear(e.event_date) = weekofyear(t.dt);
SELECT t.id, weekofyear(dt) AS week_num FROM test_dates t ORDER BY weekofyear(dt) DESC LIMIT 2;
SELECT COUNT(*) AS total_weeks FROM (SELECT DISTINCT weekofyear(dt) AS week_num FROM test_dates) AS unique_weeks;
WITH week_summary AS (SELECT weekofyear(dt) AS week_num, COUNT(*) AS num_dates FROM test_dates GROUP BY week_num) SELECT week_num, num_dates FROM week_summary WHERE week_num BETWEEN 1 AND 53 ORDER BY week_num;