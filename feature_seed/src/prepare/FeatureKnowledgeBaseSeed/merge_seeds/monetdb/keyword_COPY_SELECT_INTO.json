CREATE TABLE test_table (id INT, name VARCHAR(50), created_at TIMESTAMP);
INSERT INTO test_table (id, name, created_at) VALUES (1, 'Alice', NOW()), (2, 'Bob', NOW());
COPY SELECT id, name FROM test_table INTO '/path/to/output_file.txt' ON SERVER;
COPY SELECT * FROM test_table INTO '/path/to/output_file_pipe.txt' ON SERVER USING DELIMITERS '|', '\n', '"';
COPY (SELECT id, name FROM test_table WHERE id > 1) INTO '/path/to/output_file_filtered.txt' ON SERVER;
COPY SELECT t1.id, t1.name, t2.name AS related_name FROM test_table t1 JOIN test_table t2 ON t1.id = t2.id INTO '/path/to/output_file_joined.txt' ON SERVER;
COPY SELECT * FROM (SELECT id, name FROM test_table UNION SELECT id, 'No Name' FROM test_table WHERE name IS NULL) AS combined INTO '/path/to/output_file_union.txt' ON SERVER;
COPY (SELECT id, name FROM test_table ORDER BY created_at DESC LIMIT 5) INTO '/path/to/output_file_limited.txt' ON CLIENT;
COPY SELECT DISTINCT name FROM test_table INTO '/path/to/output_file_distinct.txt' ON SERVER;
COPY SELECT id, name, COALESCE(name, 'Unknown') FROM test_table INTO '/path/to/output_file_coalesce.txt' ON SERVER;
COPY SELECT id, name FROM test_table WHERE created_at >= '2023-01-01' INTO '/path/to/output_file_date.txt' ON CLIENT;
COPY SELECT id, CONCAT(name, '_suffix') FROM test_table INTO '/path/to/output_file_concat.txt' ON SERVER;
COPY SELECT id, name FROM test_table INTO '/path/to/output_file_utf8.txt' ON SERVER;
COPY SELECT * FROM test_table INTO '/path/to/output_file_compressed.gz' ON SERVER;
COPY SELECT * FROM test_table INTO '/path/to/output_file_combined.txt' ON SERVER USING DELIMITERS '\t', '\n', '"';