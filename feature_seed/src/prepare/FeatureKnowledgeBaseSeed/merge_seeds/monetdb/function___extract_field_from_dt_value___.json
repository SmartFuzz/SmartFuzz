CREATE TABLE test_dates (id INT, dt_value DATE);
INSERT INTO test_dates VALUES (1, DATE '2027-03-22');
INSERT INTO test_dates VALUES (2, DATE '2000-01-01');
INSERT INTO test_dates VALUES (3, DATE '1900-12-31');
SELECT extract(year from dt_value) FROM test_dates;
SELECT extract(month from dt_value) FROM test_dates WHERE id = 1;
SELECT extract(day from dt_value) FROM test_dates WHERE dt_value = DATE '2000-01-01';
SELECT extract(dow from dt_value) FROM test_dates WHERE id = 2;
SELECT extract(doy from dt_value) FROM test_dates WHERE id = 3;
SELECT (SELECT extract(quarter from dt_value) FROM test_dates WHERE id = 1) AS quarter, COUNT(*) FROM test_dates;
SELECT dt_value, extract(year from dt_value) AS year, extract(month from dt_value) AS month FROM test_dates WHERE extract(day from dt_value) > 15;
CREATE TABLE additional_dates (id INT, dt_value TIMESTAMP);
INSERT INTO additional_dates VALUES (1, TIMESTAMP '2023-10-01 12:30:45');
INSERT INTO additional_dates VALUES (2, TIMESTAMP '2023-10-15 14:20:55');
SELECT extract(hour from dt_value) FROM additional_dates WHERE id = 1;
SELECT extract(minute from dt_value) FROM additional_dates WHERE dt_value = TIMESTAMP '2023-10-15 14:20:55';
SELECT (SELECT extract(second from dt_value) FROM additional_dates) AS seconds, AVG(EXTRACT(minute FROM dt_value)) FROM additional_dates;
SELECT ad.id, ad.dt_value, ed.doy FROM additional_dates ad JOIN test_dates ed ON extract(doy from ed.dt_value) = extract(doy from ad.dt_value) WHERE ad.id = 1;
SELECT extract(century from dt_value) AS century FROM test_dates WHERE dt_value >= DATE '1900-01-01' AND dt_value <= DATE '2000-12-31';
SELECT COUNT(*), extract(week from dt_value) AS week FROM test_dates GROUP BY week ORDER BY week;
WITH date_info AS (SELECT extract(year from dt_value) AS year, COUNT(*) AS counts FROM test_dates GROUP BY year) SELECT * FROM date_info WHERE counts > 1;