CREATE TABLE accounts (id INT PRIMARY KEY, balance DECIMAL);
CREATE TABLE transactions (id INT PRIMARY KEY, account_id INT, amount DECIMAL, FOREIGN KEY (account_id) REFERENCES accounts(id));
START TRANSACTION;
INSERT INTO accounts (id, balance) VALUES (1, 1000);
INSERT INTO accounts (id, balance) VALUES (2, 2000);
INSERT INTO transactions (id, account_id, amount) VALUES (1, 1, -200);
INSERT INTO transactions (id, account_id, amount) VALUES (2, 2, -500);
COMMIT;
START TRANSACTION;
UPDATE accounts SET balance = balance + (SELECT SUM(amount) FROM transactions WHERE account_id = 1) WHERE id = 1;
COMMIT;
START TRANSACTION;
DELETE FROM transactions WHERE account_id = 2;
COMMIT;
START TRANSACTION;
INSERT INTO transactions (id, account_id, amount) VALUES (3, 1, 300);
INSERT INTO transactions (id, account_id, amount) VALUES (4, 2, 700);
COMMIT;