CREATE TABLE employees (id INT, name VARCHAR(50), salary DECIMAL(10, 2));
CREATE TABLE departments (id INT, department_name VARCHAR(50));
INSERT INTO employees (id, name, salary) VALUES (1, 'Alice', 70000.00);
INSERT INTO employees (id, name, salary) VALUES (2, 'Bob', 60000.00);
INSERT INTO departments (id, department_name) VALUES (1, 'Engineering');
INSERT INTO departments (id, department_name) VALUES (2, 'HR');
TRACE SELECT * FROM employees;
TRACE SELECT name FROM employees WHERE salary > 65000;
TRACE SELECT e.name FROM employees e JOIN departments d ON e.id = d.id WHERE d.department_name = 'Engineering';
TRACE SELECT e.name, d.department_name FROM employees e LEFT JOIN departments d ON e.id = d.id;
TRACE SELECT AVG(salary) FROM employees GROUP BY id;
TRACE SELECT e.name, (SELECT AVG(salary) FROM employees) as avg_salary FROM employees e;
TRACE SELECT e.name FROM employees e WHERE e.salary > (SELECT AVG(salary) FROM employees);
TRACE SELECT department_name, COUNT(*) FROM employees e JOIN departments d ON e.id = d.id GROUP BY department_name;
CREATE TABLE products (id INT, product_name VARCHAR(50), price DECIMAL(10, 2));
INSERT INTO products (id, product_name, price) VALUES (1, 'Product A', 29.99);
INSERT INTO products (id, product_name, price) VALUES (2, 'Product B', 49.99);
TRACE SELECT p.product_name, (SELECT COUNT(*) FROM employees) as employee_count FROM products p;