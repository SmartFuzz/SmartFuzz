CREATE SCHEMA dwh2;
CREATE SEQUENCE dwh2.seq_9201 START WITH 1 INCREMENT BY 1;
INSERT INTO dwh2.seq_9201 VALUES (1);
INSERT INTO dwh2.seq_9201 VALUES (2);
SELECT get_value_for('dwh2', 'seq_9201');
CREATE TABLE t1 (val BIGINT);
INSERT INTO t1 (val) SELECT get_value_for('dwh2', 'seq_9201');
SELECT val FROM t1 WHERE val = get_value_for('dwh2', 'seq_9201');
CREATE TABLE t2 (id BIGINT, seq_val BIGINT);
INSERT INTO t2 (id, seq_val) VALUES (1, get_value_for('dwh2', 'seq_9201'));
SELECT id FROM t2 WHERE seq_val < get_value_for('dwh2', 'seq_9201');
WITH seq_cte AS (SELECT get_value_for('dwh2', 'seq_9201') AS current_seq) SELECT current_seq FROM seq_cte;
SELECT A.id FROM (SELECT id FROM t2) AS A JOIN (SELECT get_value_for('dwh2', 'seq_9201') AS current_seq) AS B ON A.id < B.current_seq;
CREATE TABLE t3 (seq_no BIGINT);
INSERT INTO t3 (seq_no) SELECT get_value_for('dwh2', 'seq_9201') + seq_no FROM t3;
