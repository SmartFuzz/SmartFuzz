CREATE SCHEMA test_schema;
CREATE TABLE test_schema.old_table (id INT, name VARCHAR(100));
ALTER TABLE test_schema.old_table SET SCHEMA new_schema;
CREATE TABLE test_schema.dependent_table (id INT, old_table_id INT REFERENCES test_schema.old_table(id));
ALTER TABLE test_schema.dependent_table SET SCHEMA new_schema;
CREATE VIEW test_schema.view_table AS SELECT * FROM test_schema.old_table;
ALTER TABLE test_schema.view_table SET SCHEMA new_schema;
CREATE INDEX idx_old_table ON test_schema.old_table(id);
ALTER TABLE test_schema.old_table SET SCHEMA new_schema;
CREATE FUNCTION test_schema.my_function() RETURNS VOID AS $$ BEGIN END;
$$ LANGUAGE PLPGSQL;
ALTER TABLE test_schema.my_function SET SCHEMA new_schema;
CREATE TRIGGER trg_old_table AFTER INSERT ON test_schema.old_table FOR EACH ROW EXECUTE PROCEDURE my_function();
ALTER TABLE test_schema.old_table SET SCHEMA new_schema;