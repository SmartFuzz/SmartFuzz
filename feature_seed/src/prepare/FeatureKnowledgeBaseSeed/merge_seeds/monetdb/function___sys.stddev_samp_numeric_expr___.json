CREATE TABLE sales (id INT, amount DECIMAL(10, 2));
INSERT INTO sales VALUES (1, 100.00), (2, 150.50), (3, 200.25);
SELECT sys.stddev_samp(amount) FROM sales;
CREATE TABLE orders (order_id INT, sale_id INT, quantity INT);
INSERT INTO orders VALUES (1, 1, 2), (2, 2, 1), (3, 3, 4);
SELECT sys.stddev_samp(o.quantity) FROM orders o JOIN sales s ON o.sale_id = s.id WHERE s.amount > 120;
CREATE TABLE returns (return_id INT, sale_id INT, amount DECIMAL(10, 2));
INSERT INTO returns VALUES (1, 1, 25.00), (2, 2, 50.00), (3, 3, 75.00);
SELECT sys.stddev_samp(r.amount) FROM returns r JOIN sales s ON r.sale_id = s.id WHERE s.amount < 180;
CREATE TABLE refunds (refund_id INT, sale_id INT, refunded_amount DECIMAL(10, 2));
INSERT INTO refunds VALUES (1, 1, 10.00), (2, 2, 20.00), (3, 3, 30.00);
SELECT sys.stddev_samp(r.refunded_amount) FROM refunds r JOIN sales s ON r.sale_id = s.id WHERE s.id IN (SELECT id FROM sales WHERE amount > 100);
SELECT sys.stddev_samp(sub.amount) FROM (SELECT amount FROM sales WHERE amount IS NOT NULL) AS sub;
SELECT sys.stddev_samp(CASE WHEN amount IS NOT NULL THEN amount ELSE 0 END) FROM sales;