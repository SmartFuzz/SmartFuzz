CREATE TABLE test_table (id INT, value FLOAT);
INSERT INTO test_table VALUES (1, 10.5), (2, 20.0), (3, 15.0), (4, NULL), (5, 25.5);
SELECT MIN(value) FROM test_table;
SELECT MIN(value) OVER() FROM test_table;
SELECT MIN(value) FROM test_table WHERE value IS NOT NULL;
CREATE TABLE another_table (id INT, ref_id INT, amount FLOAT);
INSERT INTO another_table VALUES (1, 1, 5.0), (2, 1, NULL), (3, 2, 10.0);
SELECT MIN(t.value) FROM test_table t JOIN another_table a ON t.id = a.ref_id;
SELECT MIN(value) FROM (SELECT value FROM test_table WHERE id > 0) AS subquery;
CREATE TABLE complex_table (info VARCHAR(100), score FLOAT);
INSERT INTO complex_table VALUES ('A', 50.0), ('B', 60.0), ('C', 40.0);
SELECT MIN(score) FROM complex_table WHERE score > (SELECT MIN(value) FROM test_table);
WITH ranked_scores AS (SELECT score, RANK() OVER (ORDER BY score) AS ranking FROM complex_table) SELECT MIN(score) FROM ranked_scores WHERE ranking <= 2;