CREATE TABLE test_times (time_a TIME, time_b TIME);
INSERT INTO test_times VALUES (TIME '15:15:15', TIME '16:16:16');
INSERT INTO test_times VALUES (TIME '14:15:15', TIME '16:16:16');
INSERT INTO test_times VALUES (TIME '10:00:00', TIME '09:00:00');
INSERT INTO test_times VALUES (TIME '23:59:59', TIME '00:00:01');
INSERT INTO test_times VALUES (TIME '12:30:00', TIME '12:30:00');
SELECT least(time_a, time_b) FROM test_times;
SELECT least(TIME '15:15:15', TIME '14:30:00') AS least_time;
CREATE TABLE other_times (time_c TIME);
INSERT INTO other_times VALUES (TIME '12:00:00');
INSERT INTO other_times VALUES (TIME '13:00:00');
SELECT least(t.time_a, o.time_c) FROM test_times AS t JOIN other_times AS o ON t.time_a IS NOT NULL;
SELECT least(least(TIME '10:00:00', TIME '12:00:00'), TIME '08:00:00') AS min_time;
CREATE TABLE time_values (value TIME);
INSERT INTO time_values VALUES (TIME '17:00:00'), (TIME '18:00:00'), (TIME '19:00:00');
SELECT least(value, TIME '16:00:00') FROM time_values;
SELECT least(SELECT MIN(value) FROM time_values, TIME '16:00:00');