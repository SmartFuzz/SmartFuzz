CREATE TABLE intervals (id INT PRIMARY KEY, interval_value SECOND);
INSERT INTO intervals VALUES (1, interval '0 seconds');
INSERT INTO intervals VALUES (2, interval '59 seconds');
INSERT INTO intervals VALUES (3, interval '60 seconds');
INSERT INTO intervals VALUES (4, interval '61 seconds');
INSERT INTO intervals VALUES (5, interval '120 seconds');
SELECT second(interval_value) FROM intervals WHERE id = 1;
SELECT second(interval_value) FROM intervals WHERE id = 2;
SELECT second(interval_value) FROM intervals WHERE id = 3;
SELECT second(interval_value) FROM intervals WHERE id = 4;
SELECT second(interval_value) FROM intervals WHERE id = 5;
SELECT (SELECT second(interval_value) FROM intervals WHERE id = 1) AS sec1, (SELECT second(interval_value) FROM intervals WHERE id = 2) AS sec2;
SELECT t1.id, second(t2.interval_value) FROM intervals t1 JOIN intervals t2 ON t1.id < t2.id;
SELECT id, second(interval_value) + 10 AS adjusted_seconds FROM intervals WHERE second(interval_value) < 30;
SELECT COUNT(*) FROM intervals WHERE second(interval_value) > 30;
SELECT AVG(second(interval_value)) FROM intervals;
SELECT MAX(second(interval_value)) FROM intervals WHERE id IN (SELECT id FROM intervals WHERE second(interval_value) < 60);