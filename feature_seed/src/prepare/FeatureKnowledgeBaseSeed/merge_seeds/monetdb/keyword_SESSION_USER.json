CREATE TABLE users (id INT PRIMARY KEY, username VARCHAR(50), role VARCHAR(50));
INSERT INTO users (id, username, role) VALUES (1, 'admin', 'administrator');
INSERT INTO users (id, username, role) VALUES (2, 'user1', 'normal user');
INSERT INTO users (id, username, role) VALUES (3, 'user2', 'normal user');
CREATE TABLE roles (id INT PRIMARY KEY, role_name VARCHAR(50));
INSERT INTO roles (id, role_name) VALUES (1, 'administrator');
INSERT INTO roles (id, role_name) VALUES (2, 'normal user');
SELECT SESSION_USER;
SELECT username FROM users WHERE role = (SELECT role_name FROM roles WHERE id = 1);
SELECT username FROM users WHERE id IN (SELECT id FROM users WHERE role = 'normal user');
SELECT u.username FROM users u JOIN roles r ON u.role = r.role_name WHERE r.role_name = SESSION_USER;
CREATE TABLE login_attempts (user_id INT, timestamp TIMESTAMP, success BOOLEAN);
INSERT INTO login_attempts (user_id, timestamp, success) VALUES (1, CURRENT_TIMESTAMP, TRUE);
SELECT COUNT(*) FROM login_attempts WHERE user_id = (SELECT id FROM users WHERE username = SESSION_USER) AND success = TRUE;
CREATE TABLE session_logs (session_id INT, user_id INT, action VARCHAR(100), created_at TIMESTAMP);
INSERT INTO session_logs (session_id, user_id, action, created_at) VALUES (1, (SELECT id FROM users WHERE username = SESSION_USER), 'Login', CURRENT_TIMESTAMP);
SELECT COUNT(*) FROM session_logs WHERE user_id = (SELECT id FROM users WHERE username = SESSION_USER) AND action = 'Login';