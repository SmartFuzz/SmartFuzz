CREATE TABLE test_dates (id INT, event_date DATE);
INSERT INTO test_dates VALUES (1, date '2021-01-01');
INSERT INTO test_dates VALUES (2, date '2021-12-31');
INSERT INTO test_dates VALUES (3, date '2020-02-29');
INSERT INTO test_dates VALUES (4, date '2021-05-15');
SELECT sql_sub(event_date, interval '-1' month) AS adjusted_date FROM test_dates;
SELECT sql_sub(event_date, interval '0' month) AS adjusted_date FROM test_dates;
SELECT sql_sub(event_date, interval '2' month) AS adjusted_date FROM test_dates WHERE id = 1;
SELECT sql_sub(event_date, interval '-3' month) AS adjusted_date FROM (SELECT event_date FROM test_dates WHERE id = 2) AS subquery;
CREATE TABLE event_log (log_id INT, log_date TIMESTAMP);
INSERT INTO event_log VALUES (1, timestamp '2022-03-01 10:00:00');
SELECT sql_sub(log_date, interval '-1' month) AS adjusted_log_date FROM event_log;
SELECT e.id, sql_sub(e.event_date, interval '1' month) AS adjusted_event_date FROM test_dates e JOIN event_log l ON e.id = l.log_id;
SELECT sql_sub(event_date, interval '6' month) AS past_date FROM test_dates WHERE event_date < date '2021-06-01';
SELECT sql_sub(sql_sub(event_date, interval '1' month), interval '5' month) AS double_adjusted_date FROM test_dates;
SELECT event_date, sql_sub(event_date, interval '-1' month) AS next_month FROM test_dates WHERE event_date < date '2021-12-01';