CREATE SCHEMA mysch;
CREATE TABLE mysch.articles (id INTEGER PRIMARY KEY, title VARCHAR(100), content TEXT);
CREATE VIEW mysch.articles_view AS SELECT title FROM mysch.articles;
COMMENT ON VIEW mysch.articles_view IS 'A view that shows the titles of articles';
COMMENT ON VIEW mysch.articles_view IS NULL;
CREATE VIEW mysch.aggregated_view AS SELECT COUNT(*) AS article_count FROM mysch.articles;
COMMENT ON VIEW mysch.aggregated_view IS 'This view shows the count of articles';
COMMENT ON VIEW mysch.articles_view IS '';
CREATE VIEW mysch.joined_view AS SELECT a.title, b.comment FROM mysch.articles a JOIN mysch.comments b ON a.id = b.article_id;
COMMENT ON VIEW mysch.joined_view IS 'This view joins articles with comments';
CREATE VIEW mysch.dynamic_view AS SELECT title FROM mysch.articles WHERE id IN (SELECT id FROM mysch.articles WHERE content LIKE '%test%');
COMMENT ON VIEW mysch.dynamic_view IS 'A view for articles containing the keyword test';
COMMENT ON VIEW mysch.dynamic_view IS NULL;
DROP VIEW mysch.articles_view;
COMMENT ON VIEW mysch.articles_view IS 'This comment will not exist as the view has been dropped';