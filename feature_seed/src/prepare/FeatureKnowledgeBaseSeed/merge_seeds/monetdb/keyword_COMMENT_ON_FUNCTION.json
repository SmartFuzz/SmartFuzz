CREATE FUNCTION test.function1(x INT) RETURNS INT AS 'return x;
' LANGUAGE SQL;
COMMENT ON FUNCTION test.function1 IS 'This function returns the input integer.';
COMMENT ON FUNCTION test.function1 IS NULL;
COMMENT ON FUNCTION test.function1 IS '';
CREATE FUNCTION test.function2(y VARCHAR) RETURNS VARCHAR AS 'return upper(y);
' LANGUAGE SQL;
COMMENT ON FUNCTION test.function2 IS 'This function converts input string to uppercase.';
CREATE FUNCTION test.function3(a INT, b INT) RETURNS INT AS 'return a + b;
' LANGUAGE SQL;
COMMENT ON FUNCTION test.function3 IS 'Adds two integers.';
COMMENT ON FUNCTION test.function3 IS NULL;
COMMENT ON FUNCTION test.function3 IS '';
CREATE FUNCTION test.function4(z FLOAT) RETURNS FLOAT AS 'return z * 2.0;
' LANGUAGE SQL;
COMMENT ON FUNCTION test.function4 IS 'Doubles the input float.';
CREATE FUNCTION test.function5(v INT) RETURNS INT AS 'return IF(v IS NULL, 0, v);
' LANGUAGE SQL;
COMMENT ON FUNCTION test.function5 IS 'Returns 0 if input is NULL, otherwise returns input value.';
COMMENT ON FUNCTION test.function5 IS '';
COMMENT ON FUNCTION test.function5 IS NULL;
COMMENT ON FUNCTION test.function1 IS 'Updated comment for function1.';
COMMENT ON FUNCTION test.function4 IS 'This function now doubles the float, updated comment.';