CREATE TABLE test_strings (id INT PRIMARY KEY, str1 VARCHAR(255), str2 VARCHAR(255));
INSERT INTO test_strings VALUES (1, 'MonetDB', 'DB3');
INSERT INTO test_strings VALUES (2, 'Anna', 'Ana');
INSERT INTO test_strings VALUES (3, 'Soundex', 'Sundex');
INSERT INTO test_strings VALUES (4, 'Fuzz', 'Fuz');
INSERT INTO test_strings VALUES (5, 'Test', 'Tast');
INSERT INTO test_strings VALUES (6, '', 'Test');
INSERT INTO test_strings VALUES (7, 'Test', '');
INSERT INTO test_strings VALUES (8, 'Same', 'Same');
SELECT difference(str1, str2) FROM test_strings WHERE id = 1;
SELECT difference(str1, str2) FROM test_strings WHERE id IN (2, 3);
SELECT a.id, difference(a.str1, b.str2) FROM test_strings a JOIN test_strings b ON a.id <> b.id WHERE a.str1 != b.str2;
SELECT SUM(difference(str1, str2)) FROM test_strings;
SELECT str1, str2, difference(str1, str2) AS diff FROM test_strings ORDER BY diff;
WITH SoundexDifferences AS (SELECT str1, str2, difference(str1, str2) AS diff FROM test_strings) SELECT AVG(diff) FROM SoundexDifferences;
SELECT COUNT(*) FROM test_strings WHERE difference(str1, str2) = 0;
SELECT * FROM test_strings WHERE difference(str1, str2) > 2;
