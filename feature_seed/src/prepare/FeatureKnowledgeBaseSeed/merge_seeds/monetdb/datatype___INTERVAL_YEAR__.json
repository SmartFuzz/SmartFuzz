CREATE TABLE test_intervals (id INT PRIMARY KEY, interval_value INTERVAL YEAR);
INSERT INTO test_intervals VALUES (1, INTERVAL '5' YEAR);
INSERT INTO test_intervals VALUES (2, INTERVAL '12' YEAR);
INSERT INTO test_intervals VALUES (3, INTERVAL '0' YEAR);
INSERT INTO test_intervals VALUES (4, INTERVAL '-3' YEAR);
SELECT id, interval_value FROM test_intervals WHERE interval_value >= INTERVAL '5' YEAR;
SELECT id, EXTRACT(YEAR FROM interval_value) AS years FROM test_intervals;
SELECT id FROM test_intervals WHERE interval_value = INTERVAL '0' YEAR UNION SELECT id FROM test_intervals WHERE interval_value < INTERVAL '0' YEAR;
SELECT a.id, (a.interval_value + INTERVAL '2' YEAR) AS modified_interval FROM test_intervals a JOIN test_intervals b ON a.id = b.id WHERE a.interval_value < b.interval_value;
WITH updated_intervals AS (SELECT id, interval_value + INTERVAL '1' YEAR AS new_interval FROM test_intervals) SELECT * FROM updated_intervals WHERE new_interval > INTERVAL '10' YEAR;
CREATE TABLE temp_intervals (interval_id INT, new_value INTERVAL YEAR);
INSERT INTO temp_intervals SELECT id, interval_value FROM test_intervals WHERE interval_value IS NOT NULL;
SELECT t1.id, t1.interval_value, t2.new_value FROM test_intervals t1 LEFT JOIN temp_intervals t2 ON t1.id = t2.interval_id WHERE t1.interval_value IS NOT NULL;
UPDATE test_intervals SET interval_value = interval_value + INTERVAL '6' YEAR WHERE id = 1;
DELETE FROM test_intervals WHERE interval_value < INTERVAL '0' YEAR;
SELECT COUNT(*) FROM test_intervals WHERE interval_value != INTERVAL '0' YEAR;
SELECT id, interval_value, (interval_value - INTERVAL '3' YEAR) AS decreased_value FROM test_intervals WHERE interval_value > INTERVAL '0' YEAR;