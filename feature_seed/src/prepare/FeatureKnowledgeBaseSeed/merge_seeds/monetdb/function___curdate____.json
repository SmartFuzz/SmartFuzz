CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE);
INSERT INTO test_dates VALUES (1, curdate());
INSERT INTO test_dates VALUES (2, curdate() + INTERVAL '1' DAY);
INSERT INTO test_dates VALUES (3, curdate() - INTERVAL '1' DAY);
SELECT id, event_date, curdate() AS current_date FROM test_dates WHERE event_date = curdate();
SELECT id FROM test_dates WHERE event_date < curdate() AND event_date > curdate() - INTERVAL '30' DAY;
SELECT COUNT(*) FROM test_dates WHERE event_date = (SELECT curdate());
SELECT t1.id FROM test_dates t1 JOIN test_dates t2 ON t1.id != t2.id WHERE t1.event_date = curdate();
SELECT id, event_date FROM test_dates WHERE event_date BETWEEN curdate() - INTERVAL '7' DAY AND curdate();
SELECT id, event_date, curdate() AS today_date FROM test_dates WHERE event_date <= curdate() ORDER BY event_date DESC;