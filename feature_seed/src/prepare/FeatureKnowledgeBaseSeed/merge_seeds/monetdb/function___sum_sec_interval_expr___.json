CREATE TABLE intervals (id INT PRIMARY KEY, duration INTERVAL second);
INSERT INTO intervals VALUES (1, '10s'), (2, '20s'), (3, NULL), (4, '30s');
SELECT sum(cast(duration as interval second)) FROM intervals;
CREATE TABLE more_intervals (id INT PRIMARY KEY, duration INTERVAL second);
INSERT INTO more_intervals VALUES (1, '40s'), (2, NULL), (3, '10s');
SELECT sum(cast(i.duration as interval second)) FROM intervals i JOIN more_intervals m ON i.id = m.id;
CREATE TABLE complex_intervals (group_id INT, interval_duration INTERVAL second);
INSERT INTO complex_intervals VALUES (1, '15s'), (1, '25s'), (1, NULL), (2, '30s');
SELECT group_id, sum(cast(interval_duration as interval second)) FROM complex_intervals GROUP BY group_id;
SELECT sum(cast(duration as interval second)) FROM (SELECT duration FROM intervals WHERE id < 3) AS subquery;
CREATE TABLE different_intervals (user_id INT, event_duration INTERVAL second);
INSERT INTO different_intervals VALUES (1, '5s'), (2, '15s'), (3, NULL), (4, '25s');
SELECT u.user_id, sum(cast(d.event_duration as interval second)) FROM different_intervals d JOIN intervals u ON d.user_id = u.id GROUP BY u.user_id;
SELECT sum(cast((SELECT duration FROM intervals WHERE id = 1) as interval second));
SELECT sum(cast(duration as interval second)) FROM (SELECT * FROM intervals UNION ALL SELECT duration FROM more_intervals) AS unified;