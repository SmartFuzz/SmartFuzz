CREATE TABLE scale_test (value1 INT, value2 INT);
INSERT INTO scale_test VALUES (13, 3);
INSERT INTO scale_test VALUES (0, 100);
INSERT INTO scale_test VALUES (-5, 6);
INSERT INTO scale_test VALUES (2147483647, 1);
INSERT INTO scale_test VALUES (2147483647, 2);
SELECT scale_up(value1, value2) FROM scale_test;
SELECT scale_up(ABS(value1), value2) FROM scale_test WHERE value1 < 0;
SELECT value1, scale_up(value1, value2) AS scaled FROM scale_test WHERE value1 >= 0;
SELECT DISTINCT scale_up(t.value1, t.value2) FROM scale_test t WHERE t.value1 IS NOT NULL;
CREATE TABLE additional_table (value3 INT);
INSERT INTO additional_table VALUES (2);
SELECT scale_up(st.value1, st.value2) * at.value3 AS final_scale FROM scale_test st JOIN additional_table at ON st.value2 = at.value3;
SELECT scale_up(value1, (SELECT MAX(value2) FROM scale_test)) AS scaled_max FROM scale_test;
SELECT scale_up(value1, (SELECT COUNT(*) FROM scale_test)) AS total_scale FROM scale_test GROUP BY value1;
WITH temp_scale AS (SELECT scale_up(value1, value2) AS result FROM scale_test) SELECT AVG(result) FROM temp_scale;