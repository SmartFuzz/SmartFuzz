CREATE TABLE strings_test (id INT PRIMARY KEY, str1 TEXT, str2 TEXT);
INSERT INTO strings_test VALUES (1, 'MonetDB', 'MonetDB'), (2, 'example', 'sample'), (3, 'test', 'test'), (4, 'similarity', 'similariTy'), (5, 'fuzzy', 'buzz');
SELECT jarowinkler(str1, str2) AS similarity FROM strings_test WHERE id = 1;
SELECT jarowinkler('case', 'Case') AS similarity;
SELECT jarowinkler('test', '') AS similarity;
SELECT jarowinkler('', '') AS similarity;
SELECT id, jarowinkler(str1, str2) AS similarity FROM strings_test WHERE str1 LIKE 'M%';
SELECT AVG(jarowinkler(str1, str2)) AS avg_similarity FROM strings_test WHERE str1 <> str2;
SELECT s1.id, s2.id, jarowinkler(s1.str1, s2.str2) AS similarity FROM strings_test s1 JOIN strings_test s2 ON s1.id != s2.id WHERE jarowinkler(s1.str1, s2.str2) > 0.5;
SELECT DISTINCT jarowinkler(s1.str1, s2.str2) FROM strings_test s1, strings_test s2 WHERE LENGTH(s1.str1) > 5 AND LENGTH(s2.str2) > 5;
SELECT id, jarowinkler(str1, str2) AS similarity FROM (SELECT * FROM strings_test WHERE id IN (1, 2, 3)) AS temp_table;