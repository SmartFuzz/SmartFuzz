CREATE TABLE test_table (id INT, name VARCHAR(100), value FLOAT);
COPY INTO FROM STDIN INTO test_table FROM stdin USING DELIMITERS '|', '\n', '';
COPY INTO test_table FROM STDIN USING DELIMITERS '\t', '\n', '"' NULL AS 'null' BEST EFFORT;
COPY INTO test_table FROM STDIN (id, name, value) USING DELIMITERS '|', '\n' NULL AS 'NULL';
COPY test_table FROM STDIN USING DELIMITERS '|', '\n' BEST EFFORT INTO (id, name, value);
COPY INTO test_table FROM STDIN USING DELIMITERS '|', '\n', '"' NULL AS 'N/A' OFFSET 100 RECORDS;
COPY INTO test_table FROM STDIN (id, name) USING DELIMITERS '|', ',' NULL AS 'NULL';
CREATE TABLE nested_table (ref_id INT, description VARCHAR(200));
COPY INTO nested_table FROM STDIN USING DELIMITERS '|', '\n', NULL AS 'null';
COPY INTO nested_table FROM STDIN USING DELIMITERS '|' , '\n' NULL AS NULL OFFSET 50 RECORDS;
CREATE TABLE joined_table (id INT, detail VARCHAR(100), ref_id INT);
COPY INTO joined_table FROM STDIN USING DELIMITERS '|', '\n', NULL AS 'null' INTO (id, detail, ref_id);
COPY INTO joined_table FROM STDIN (id, detail) USING DELIMITERS '|', '\n' NULL AS 'null';
COPY INTO joined_table FROM STDIN USING DELIMITERS ',' , '\n' NULL AS 'N/A' OFFSET 10 RECORDS;
CREATE TABLE another_table (item VARCHAR(50), amount INT);
COPY INTO another_table FROM STDIN USING DELIMITERS '|' , '\n' NULL AS NULL;
COPY INTO another_table FROM STDIN USING DELIMITERS ',' , '\n', '"' BEST EFFORT;
COPY INTO another_table FROM STDIN (item, amount) USING DELIMITERS '|' , '\n' NULL AS 'none';