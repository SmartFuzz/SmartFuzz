CREATE TABLE time_test (id INT, event_time TIME(3));
INSERT INTO time_test VALUES (1, '12:00:00.000');
INSERT INTO time_test VALUES (2, '23:59:59.999');
INSERT INTO time_test VALUES (3, '00:00:00.000');
INSERT INTO time_test VALUES (4, '15:30:50.123');
SELECT * FROM time_test WHERE event_time = '12:00:00.000';
SELECT * FROM time_test WHERE event_time < '15:00:00.000';
SELECT COUNT(*) FROM time_test WHERE event_time > '11:59:59.000';
SELECT id, event_time FROM time_test WHERE event_time BETWEEN '10:00:00.000' AND '20:00:00.000';
CREATE TABLE event_log (event_id INT, log_time TIME(5));
INSERT INTO event_log VALUES (1, '14:20:30.12345');
INSERT INTO event_log VALUES (2, '05:15:15.98765');
SELECT e.event_id, t.event_time FROM event_log e JOIN time_test t ON e.log_time > t.event_time;
SELECT e.event_id, t.event_time FROM event_log e LEFT JOIN time_test t ON e.log_time = t.event_time WHERE t.id IS NULL;
SELECT AVG(EXTRACT(SECOND FROM event_time)) FROM time_test;
SELECT MIN(event_time) AS earliest_time FROM time_test;
SELECT MAX(event_time) AS latest_time FROM time_test;
WITH time_summary AS (SELECT event_time, COUNT(*) as count FROM time_test GROUP BY event_time) SELECT * FROM time_summary WHERE count > 1;
SELECT t1.id FROM time_test t1 WHERE NOT EXISTS (SELECT 1 FROM event_log e WHERE e.log_time = t1.event_time);
SELECT t1.event_time, t2.log_time FROM time_test t1 CROSS JOIN event_log t2 WHERE t1.event_time > '12:00:00.000' LIMIT 10;