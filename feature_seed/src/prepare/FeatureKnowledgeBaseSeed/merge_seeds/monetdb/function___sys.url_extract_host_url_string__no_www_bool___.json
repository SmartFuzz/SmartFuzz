CREATE TABLE urls (id INT PRIMARY KEY, url STRING);
INSERT INTO urls VALUES (1, 'http://www.example.com/page'), (2, 'https://example.org/path'), (3, 'ftp://ftp.example.net/resource'), (4, 'https://test.com'), (5, NULL);
SELECT sys.url_extract_host(url, TRUE) FROM urls;
SELECT sys.url_extract_host(url, FALSE) FROM urls WHERE url IS NOT NULL;
SELECT id, sys.url_extract_host(url, TRUE) AS host_no_www, sys.url_extract_host(url, FALSE) AS host_with_www FROM urls;
CREATE TABLE results AS (SELECT id, sys.url_extract_host(url, TRUE) AS host_no_www FROM urls WHERE url LIKE 'http%');
SELECT r.id, r.host_no_www FROM results r JOIN urls u ON r.id = u.id WHERE u.url IS NOT NULL;
SELECT COUNT(*) FROM urls WHERE sys.url_extract_host(url, TRUE) IS NOT NULL;
SELECT DISTINCT sys.url_extract_host(url, TRUE) FROM urls WHERE url IS NOT NULL ORDER BY sys.url_extract_host(url, TRUE);
SELECT sub.id, sub.host_no_www FROM (SELECT id, sys.url_extract_host(url, TRUE) AS host_no_www FROM urls) sub WHERE sub.host_no_www IS NOT NULL;
INSERT INTO urls SELECT id + 10, CONCAT('http://', sys.url_extract_host(url, TRUE) ) FROM urls WHERE url IS NOT NULL;
SELECT y.id, sys.url_extract_host(y.url, TRUE) FROM (SELECT id, url FROM urls WHERE url IS NOT NULL) y WHERE sys.url_extract_host(y.url, TRUE) LIKE 'example%';
CREATE TEMP TABLE temp_urls AS SELECT id, url FROM urls WHERE url IS NOT NULL;
SELECT sys.url_extract_host(temp.url, FALSE) FROM temp_urls temp WHERE temp.url IS NOT NULL;