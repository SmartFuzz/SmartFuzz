CREATE TABLE test_values (val FLOAT);
INSERT INTO test_values VALUES (0.0);
INSERT INTO test_values VALUES (1.0);
INSERT INTO test_values VALUES (8.0);
INSERT INTO test_values VALUES (27.0);
INSERT INTO test_values VALUES (64.0);
INSERT INTO test_values VALUES (-1.0);
INSERT INTO test_values VALUES (-8.0);
INSERT INTO test_values VALUES (-27.0);
SELECT cbrt(val) FROM test_values;
SELECT cbrt(val) AS cube_root FROM test_values WHERE val >= 0;
SELECT t.val, cbrt(t.val) FROM test_values t WHERE cbrt(t.val) < 3;
SELECT cbrt(a.val + b.val) FROM test_values a JOIN test_values b ON a.val < b.val;
SELECT cbrt(s.val) FROM (SELECT val FROM test_values) s WHERE s.val IS NOT NULL;
SELECT t.val, cbrt(t.val) AS cube_root FROM test_values t WHERE t.val IN (0.0, 1.0, 8.0, 27.0);
WITH cte AS (SELECT val FROM test_values WHERE val < 0) SELECT cbrt(val) FROM cte;
SELECT val, cbrt(val) FROM test_values ORDER BY cbrt(val) DESC;