CREATE TABLE test_locate (id INT, value VARCHAR(100));
INSERT INTO test_locate VALUES (1, 'DB's best is DBMonetDB');
INSERT INTO test_locate VALUES (2, 'MonetDB is the best database');
INSERT INTO test_locate VALUES (3, 'DBMonetDB is fast');
SELECT locate('DB', value, 1) FROM test_locate;
SELECT locate('Monet', value, 1) FROM test_locate WHERE id = 2;
SELECT locate('best', value, 0) FROM test_locate;
SELECT locate('DB', value, 11) FROM test_locate;
SELECT loc_value.id, locate('Monet', loc_value.value, 1) AS position FROM test_locate AS loc_value WHERE id = 1;
SELECT id, value, locate('DB', value, 1) AS position FROM test_locate WHERE position > 0;
SELECT id, value FROM (SELECT id, value, locate('best', value, 1) AS pos FROM test_locate) AS subquery WHERE pos > 0;
SELECT tt1.id, tt1.value, locate('DB', tt2.value, 1) FROM test_locate AS tt1 JOIN test_locate AS tt2 ON tt1.id != tt2.id;
CREATE TABLE subquery_test AS SELECT id, value, locate('fast', value, 1) AS position FROM test_locate WHERE position > 0;
SELECT * FROM subquery_test WHERE position = 0;
SELECT locate('Monet', 'DBMonetDB is an open-source database.', 4);
SELECT locate('open', 'DBMonetDB is an open-source database.', 5);
SELECT locate('source', 'DBMonetDB is an open-source database.', 1) AS source_position;