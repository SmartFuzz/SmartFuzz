CREATE TABLE numbers (value FLOAT);
INSERT INTO numbers VALUES (0), (1), (2), (4), (8), (16), (32), (64), (128), (255), (1024);
SELECT log2(value) FROM numbers;
SELECT log2(64.0);
SELECT value, log2(value) FROM numbers WHERE value > 0;
SELECT value, log2(value) AS log_value FROM (SELECT value FROM numbers WHERE value < 1000) AS sub;
CREATE TABLE more_numbers (id INT PRIMARY KEY, value FLOAT);
INSERT INTO more_numbers VALUES (1, 64), (2, 128), (3, 256);
SELECT mn.id, mn.value, log2(mn.value) FROM more_numbers mn JOIN numbers n ON log2(n.value) > 5;
CREATE VIEW log_values AS SELECT value, log2(value) AS log_value FROM numbers WHERE value > 0;
SELECT * FROM log_values WHERE log_value BETWEEN 5 AND 7;
SELECT log2(32.0) + log2(16.0) AS log_sum;
SELECT log2(2) * log2(4) AS log_product;