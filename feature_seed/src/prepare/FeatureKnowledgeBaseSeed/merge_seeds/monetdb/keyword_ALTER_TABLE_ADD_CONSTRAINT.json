CREATE TABLE test_table (id INT, name VARCHAR(100), age INT);
ALTER TABLE test_table ADD CONSTRAINT test_table_pk PRIMARY KEY (id);
ALTER TABLE test_table ADD CONSTRAINT test_table_uc UNIQUE (name);
ALTER TABLE test_table ADD CONSTRAINT test_table_fk FOREIGN KEY (age) REFERENCES reference_table (age) ON DELETE CASCADE;
ALTER TABLE IF EXISTS test_table ADD CONSTRAINT test_table_check CHECK (age > 0);
ALTER TABLE test_table ADD CONSTRAINT test_table_fk2 FOREIGN KEY (id) REFERENCES another_table (identifier) ON UPDATE CASCADE ON DELETE SET NULL;
ALTER TABLE test_table ADD CONSTRAINT test_table_non_null UNIQUE (name, id);
CREATE TABLE reference_table (age INT PRIMARY KEY);
CREATE TABLE another_table (identifier INT PRIMARY KEY, description VARCHAR(255));
ALTER TABLE reference_table ADD CONSTRAINT reference_table_check CHECK (age < 150);
ALTER TABLE test_table ADD CONSTRAINT test_table_complex_fk FOREIGN KEY (name) REFERENCES reference_table (name) MATCH FULL ON UPDATE NO ACTION ON DELETE RESTRICT;
ALTER TABLE test_table ADD CONSTRAINT test_table_age_check CHECK (age BETWEEN 1 AND 120);
ALTER TABLE test_table ADD CONSTRAINT test_table_multi_fk FOREIGN KEY (id, age) REFERENCES reference_table (age, identifier) ON DELETE CASCADE;