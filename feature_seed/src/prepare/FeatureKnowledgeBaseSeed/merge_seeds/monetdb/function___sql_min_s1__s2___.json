CREATE TABLE test_strings (s1 VARCHAR(255), s2 VARCHAR(255));
INSERT INTO test_strings VALUES ('ab', 'ac'), ('apple', 'banana'), ('grape', 'grape'), ('zebra', 'ant');
SELECT sql_min(s1, s2) FROM test_strings;
SELECT sql_min(s1, 'citrus') FROM test_strings;
SELECT sql_min('orange', s2) FROM test_strings;
SELECT sql_min(sql_min(s1, s2), 'kiwi') FROM test_strings;
SELECT MIN(sql_min(s1, s2)) AS min_value FROM test_strings;
SELECT sql_min(s1, s2) AS min_pair, COUNT(*) FROM test_strings GROUP BY min_pair;
SELECT DISTINCT sql_min(s1, s2) FROM test_strings WHERE s1 <> s2;
CREATE TABLE other_strings (s3 VARCHAR(255));
INSERT INTO other_strings VALUES ('banana'), ('apple'), ('avocado');
SELECT sql_min(a.s1, b.s3) FROM test_strings a JOIN other_strings b ON a.s1 <> b.s3;
WITH filtered AS (SELECT s1, s2 FROM test_strings WHERE LENGTH(s1) >= 2 AND LENGTH(s2) >= 2) SELECT sql_min(s1, s2) FROM filtered;
SELECT sql_min(s1, sql_min(s2, 'default')) FROM test_strings;
SELECT sql_min(UPPER(s1), LOWER(s2)) FROM test_strings WHERE s1 IS NOT NULL AND s2 IS NOT NULL;