CREATE TABLE test_timestamps (id INT PRIMARY KEY, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO test_timestamps VALUES (1, timestamp '2021-12-31 18:40:40', timestamp '2021-12-20 16:30:20');
INSERT INTO test_timestamps VALUES (2, timestamp '2021-01-01 00:00:00', timestamp '2020-12-31 23:59:59');
INSERT INTO test_timestamps VALUES (3, timestamp '2022-06-30 15:00:00', timestamp '2022-06-29 15:00:00');
INSERT INTO test_timestamps VALUES (4, timestamp '2023-10-01 08:00:00', timestamp '2023-10-01 07:59:59');
SELECT timestampdiff_day(start_time, end_time) FROM test_timestamps WHERE id = 1;
SELECT timestampdiff_day(start_time, end_time) FROM test_timestamps WHERE id = 2;
SELECT timestampdiff_day(start_time, end_time) FROM test_timestamps WHERE id = 3;
SELECT timestampdiff_day(start_time, end_time) FROM test_timestamps WHERE id = 4;
CREATE TABLE additional_data (ref_id INT, description TEXT);
INSERT INTO additional_data VALUES (1, 'Test case 1'), (2, 'Test case 2');
SELECT a.ref_id, timestampdiff_day(t.start_time, t.end_time) FROM additional_data a JOIN test_timestamps t ON a.ref_id = t.id;
SELECT a.ref_id, CASE WHEN timestampdiff_day(t.start_time, t.end_time) > 0 THEN 'Positive' ELSE 'Non-Positive' END AS diff_type FROM additional_data a JOIN test_timestamps t ON a.ref_id = t.id;
SELECT MAX(timestampdiff_day(start_time, end_time)) FROM test_timestamps;
SELECT AVG(timestampdiff_day(start_time, end_time)) AS average_days FROM test_timestamps;
SELECT COUNT(*) FROM test_timestamps WHERE timestampdiff_day(start_time, end_time) < 0;