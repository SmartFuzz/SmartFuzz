CREATE SCHEMA test_schema;
SET SCHEMA test_schema;
CREATE TABLE test_schema.users (id INT PRIMARY KEY, name VARCHAR(50));
INSERT INTO test_schema.users (id, name) VALUES (1, 'Alice');
INSERT INTO test_schema.users (id, name) VALUES (2, 'Bob');
SET SCHEMA test_schema;
SELECT * FROM users;
SET SCHEMA public;
CREATE TABLE public.orders (order_id INT PRIMARY KEY, user_id INT, amount DECIMAL);
INSERT INTO public.orders (order_id, user_id, amount) VALUES (101, 1, 250.00);
INSERT INTO public.orders (order_id, user_id, amount) VALUES (102, 2, 150.50);
SET SCHEMA public;
SELECT o.order_id, u.name FROM orders o JOIN test_schema.users u ON o.user_id = u.id;
SET SCHEMA test_schema;
CREATE VIEW user_orders AS SELECT u.name, o.amount FROM users u JOIN public.orders o ON u.id = o.user_id;
SELECT * FROM user_orders;
SET SCHEMA public;
CREATE TABLE public.items (item_id INT PRIMARY KEY, description VARCHAR(100));
INSERT INTO public.items (item_id, description) VALUES (1, 'Laptop'), (2, 'Smartphone');
SET SCHEMA public;
SELECT i.description, COUNT(o.order_id) FROM items i LEFT JOIN public.orders o ON i.item_id = o.order_id GROUP BY i.description;
SET SCHEMA test_schema;
DROP VIEW IF EXISTS user_orders;
SET SCHEMA public;
DROP TABLE IF EXISTS orders;
DROP TABLE IF EXISTS items;
SET SCHEMA current_schema;