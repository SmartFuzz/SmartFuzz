CREATE TABLE employees (id INT, name VARCHAR(100), department VARCHAR(100));
INSERT INTO employees VALUES (1, 'Alice', 'HR'), (2, 'Bob', 'Engineering'), (3, 'Charlie', 'Engineering'), (4, 'David', 'Marketing');
CREATE TABLE projects (id INT, project_name VARCHAR(100), department VARCHAR(100));
INSERT INTO projects VALUES (1, 'Project A', 'Engineering'), (2, 'Project B', 'Marketing'), (3, 'Project C', 'HR');
SELECT listagg(name) FROM employees WHERE department = 'Engineering';
SELECT listagg(name ORDER BY id) FROM employees WHERE department IN (SELECT department FROM projects);
SELECT listagg(name) FROM (SELECT name FROM employees WHERE department = 'Engineering') AS eng_employees;
SELECT listagg(name) FROM employees WHERE department = 'HR' GROUP BY department;
SELECT listagg(name) FROM employees WHERE id IN (SELECT id FROM employees WHERE department = 'Engineering');
SELECT d.department, listagg(e.name) FROM employees e JOIN projects p ON e.department = p.department GROUP BY d.department;