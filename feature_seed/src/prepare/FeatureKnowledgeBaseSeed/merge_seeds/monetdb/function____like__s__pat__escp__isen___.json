CREATE TABLE test_table (id INT, test_string VARCHAR(100));
INSERT INTO test_table VALUES (1, 'abc'), (2, 'abcd'), (3, 'abcdef'), (4, 'a%bc'), (5, 'a#bcd'), (6, 'xyza');
SELECT id FROM test_table WHERE "like"(test_string, 'a%', '#', false);
SELECT id FROM test_table WHERE "like"(test_string, 'a%', '#', true);
SELECT id FROM test_table WHERE "like"(test_string, 'b%', '#', false);
SELECT id FROM test_table WHERE "like"(test_string, 'xyz%', '#', false);
SELECT id FROM test_table WHERE "like"(test_string, 'a#b%', '#', false);
SELECT id FROM test_table WHERE "like"(test_string, 'a##b%', '#', false);
SELECT id FROM test_table WHERE "like"(test_string, 'a#%', '#', false);
SELECT id FROM test_table WHERE id IN (SELECT id FROM test_table WHERE "like"(test_string, '%bc%', '#', false));
SELECT t1.id FROM test_table t1 JOIN test_table t2 ON "like"(t1.test_string, t2.test_string, '#', false) WHERE t2.id = 3;
SELECT id FROM test_table WHERE "like"(test_string, 'A%', '#', true);
SELECT id FROM test_table WHERE "like"(test_string, 'a__', '#', false);
SELECT id FROM test_table WHERE "like"(test_string, 'a#%', '#', true);
CREATE TABLE another_table (label VARCHAR(50));
INSERT INTO another_table VALUES ('abc'), ('a%cd'), ('xyz'), ('A%BC');
SELECT a.id, b.label FROM test_table a JOIN another_table b ON "like"(a.test_string, b.label, '#', false);