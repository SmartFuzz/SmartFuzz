CREATE TABLE IF NOT EXISTS webshop.products (id INT PRIMARY KEY, name VARCHAR(255) NOT NULL, price DECIMAL(10,2), created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
CREATE TABLE IF NOT EXISTS webshop.orders LIKE webshop.products, order_id INT PRIMARY KEY, order_date TIMESTAMP, status VARCHAR(50);
CREATE TABLE IF NOT EXISTS webshop.customers (customer_id SERIAL PRIMARY KEY, first_name VARCHAR(100), last_name VARCHAR(100), email VARCHAR(255) UNIQUE NOT NULL, registered_on TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
CREATE TABLE IF NOT EXISTS webshop.products_new (LIKE webshop.products, descr VARCHAR(9999), pict BLOB);
CREATE TABLE IF NOT EXISTS webshop.promo_codes (promo_code VARCHAR(50) PRIMARY KEY, discount_amount DECIMAL(5,2) CHECK (discount_amount > 0), expiration_date DATE NOT NULL);
CREATE TABLE IF NOT EXISTS webshop.product_reviews (review_id SERIAL PRIMARY KEY, product_id INT REFERENCES webshop.products(id), rating INT CHECK (rating BETWEEN 1 AND 5), review_text TEXT);
CREATE TABLE IF NOT EXISTS webshop.order_items (order_item_id SERIAL PRIMARY KEY, order_id INT REFERENCES webshop.orders(order_id), product_id INT REFERENCES webshop.products(id), quantity INT CHECK (quantity > 0));
CREATE TABLE IF NOT EXISTS webshop.categories (category_id SERIAL PRIMARY KEY, category_name VARCHAR(100) UNIQUE NOT NULL);
CREATE TABLE IF NOT EXISTS webshop.product_categories (product_id INT REFERENCES webshop.products(id), category_id INT REFERENCES webshop.categories(category_id), PRIMARY KEY (product_id, category_id));
CREATE TABLE IF NOT EXISTS webshop.shipping_addresses (address_id SERIAL PRIMARY KEY, customer_id INT REFERENCES webshop.customers(customer_id), address_line1 VARCHAR(255), address_line2 VARCHAR(255), city VARCHAR(100), postal_code VARCHAR(20));