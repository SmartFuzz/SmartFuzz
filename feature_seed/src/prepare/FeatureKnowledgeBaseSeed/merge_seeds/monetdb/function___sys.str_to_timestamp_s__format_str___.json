CREATE TABLE timestamps (id INT, timestamp_value TIMESTAMPTZ);
INSERT INTO timestamps VALUES (1, sys.str_to_timestamp('4/30/2021 09:30:49','%m/%d/%Y %H:%M:%S'));
INSERT INTO timestamps VALUES (2, sys.str_to_timestamp('12/31/2022 23:59:59','%m/%d/%Y %H:%M:%S'));
INSERT INTO timestamps VALUES (3, sys.str_to_timestamp('01/01/2023 00:00:01','%m/%d/%Y %H:%M:%S'));
INSERT INTO timestamps VALUES (4, sys.str_to_timestamp('2/28/2020 12:30:00','%m/%d/%Y %H:%M:%S'));
INSERT INTO timestamps VALUES (5, sys.str_to_timestamp('03/15/2025 15:00:00','%m/%d/%Y %H:%M:%S'));
SELECT * FROM timestamps WHERE timestamp_value > sys.str_to_timestamp('01/01/2022 00:00:00','%m/%d/%Y %H:%M:%S');
SELECT COUNT(*) FROM timestamps WHERE timestamp_value <= sys.str_to_timestamp('12/31/2022 23:59:59','%m/%d/%Y %H:%M:%S');
SELECT id, timestamp_value, sys.str_to_timestamp('06/01/2023 09:00:00','%m/%d/%Y %H:%M:%S') AS new_timestamp FROM timestamps WHERE timestamp_value < sys.str_to_timestamp('07/01/2023 09:00:00','%m/%d/%Y %H:%M:%S');
CREATE TABLE additional_timestamps (id INT, base_timestamp TIMESTAMPTZ);
INSERT INTO additional_timestamps VALUES (1, sys.str_to_timestamp('5/20/2021 10:00:00','%m/%d/%Y %H:%M:%S'));
INSERT INTO additional_timestamps VALUES (2, sys.str_to_timestamp('6/15/2021 11:30:00','%m/%d/%Y %H:%M:%S'));
SELECT a.id, a.base_timestamp, b.timestamp_value FROM additional_timestamps a JOIN timestamps b ON a.base_timestamp < b.timestamp_value WHERE b.timestamp_value BETWEEN sys.str_to_timestamp('01/01/2021 00:00:00','%m/%d/%Y %H:%M:%S') AND sys.str_to_timestamp('12/31/2021 23:59:59','%m/%d/%Y %H:%M:%S');
SELECT id, timestamp_value FROM timestamps WHERE timestamp_value IS NOT NULL ORDER BY timestamp_value DESC LIMIT 1;
SELECT id FROM timestamps WHERE timestamp_value = (SELECT MAX(timestamp_value) FROM timestamps);
SELECT MIN(timestamp_value) AS earliest, MAX(timestamp_value) AS latest FROM timestamps;