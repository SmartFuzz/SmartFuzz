CREATE TABLE test_strings (s1 VARCHAR(255), s2 VARCHAR(255), id INT, r INT, t INT);
INSERT INTO test_strings VALUES ('kitten', 'sitting', 1, 2, 1);
INSERT INTO test_strings VALUES ('flaw', 'lawn', 2, 1, 1);
INSERT INTO test_strings VALUES ('intention', 'execution', 3, 1, 1);
INSERT INTO test_strings VALUES ('MonetDB', 'DB3', 4, 2, 1);
SELECT levenshtein(s1, s2, id, r, t) FROM test_strings WHERE id = 1;
SELECT MAX(levenshtein(s1, s2, id, r, t)) FROM test_strings;
SELECT s1, s2, levenshtein(s1, s2, id, r, t) AS distance FROM test_strings WHERE distance <= 3;
SELECT s1, s2, levenshtein(s1, s2, id, r, t) AS distance FROM test_strings WHERE s1 NOT LIKE '%DB%';
CREATE TABLE results AS SELECT s1, s2, levenshtein(s1, s2, id, r, t) AS distance FROM test_strings;
SELECT s1, s2 FROM results WHERE distance = (SELECT MIN(distance) FROM results);
SELECT COUNT(*) FROM test_strings WHERE levenshtein(s1, s2, id, r, t) > 5;
SELECT levenshtein(s1, s2, id, r, t) FROM test_strings WHERE LENGTH(s1) < 5 AND LENGTH(s2) < 5;
SELECT s1, s2 FROM test_strings WHERE levenshtein(s1, s2, id, r, t) BETWEEN 1 AND 2 ORDER BY id;
DELETE FROM test_strings WHERE id > 3;