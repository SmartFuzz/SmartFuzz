CREATE TABLE test_floors (value REAL);
INSERT INTO test_floors VALUES (-42.8), (0.5), (3.9), (-1.5), (2.0), (NULL);
SELECT value, floor(value) AS floored_value FROM test_floors;
CREATE TABLE additional_data (id INT, adj_value REAL);
INSERT INTO additional_data VALUES (1, -42.8), (2, 0.1), (3, 4.6);
SELECT a.id, floor(a.adj_value) AS floored_adj_value FROM additional_data a JOIN test_floors b ON floor(a.adj_value) = floor(b.value);
SELECT floor(sum(value)) FROM test_floors WHERE value IS NOT NULL;
SELECT floor(AVG(value)) AS avg_floored FROM test_floors;
WITH temp AS (SELECT value FROM test_floors WHERE value < 0) SELECT floor(AVG(value)) AS avg_negative_floored FROM temp;
CREATE TABLE more_data (numeric_value DOUBLE);
INSERT INTO more_data VALUES (10.5), (-20.1), (5.2), (NULL);
SELECT numeric_value, floor(numeric_value) AS floored_num FROM more_data WHERE numeric_value IS NOT NULL;
SELECT t1.value, CASE WHEN floor(t1.value) = floor(t2.numeric_value) THEN 'Match' ELSE 'No Match' END AS comparison FROM test_floors t1, more_data t2;
SELECT floor(value + 1.2) AS floored_adjusted FROM test_floors;
SELECT COUNT(*) FROM test_floors WHERE floor(value) < -40;
SELECT value, floor(-value) AS floored_negative FROM test_floors;
SELECT DISTINCT floor(value) FROM test_floors WHERE value IS NOT NULL;