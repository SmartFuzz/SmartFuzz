CREATE TABLE json_example (c1 JSON, c2 JSON(512) NOT NULL);
INSERT INTO json_example (c1, c2) VALUES ('{"store":{"book":[{"category":"reference","author":"Nigel Rees","title":"Sayings of the Century","price":8.95},{"category":"fiction","author":"Evelyn Waugh","title":"Sword of Honour","price":12.99}]},"bicycle":{"color":"red","price":19.95}}', '{"store":{"bike":{"color":"blue","price":25.99}}}');
SELECT json.filter(c1, '$.store.book[0].title') FROM json_example;
SELECT json.keyarray(c1) FROM json_example;
SELECT json.length(c1) FROM json_example WHERE json.isarray(c1);
SELECT json.text(c1, ', ') FROM json_example;
SELECT json.valuearray(c1) FROM json_example WHERE json.isobject(c1);
SELECT json.isvalid('{"key":"value"}') AS valid_json;
SELECT json.isarray('[]') AS is_array, json.isvalid('[]') AS valid_array;
SELECT json.filter(c1, '$..price') FROM json_example;
SELECT json.integer(json.number(c1)) FROM json_example;
SELECT json.filter(c1, '$.store.bicycle.color') AS bicycle_color FROM json_example WHERE json.isobject(c1);
CREATE TABLE json_table (data JSON);
INSERT INTO json_table (data) VALUES ('{"name":"John", "age":30, "city":"New York"}');
SELECT json.filter(data, '$.age') FROM json_table;
SELECT json.length(data) FROM json_table WHERE json.isobject(data);
INSERT INTO json_table (data) VALUES ('{"items":[{"name":"item1"},{"name":"item2"}]}');
SELECT json.valuearray(data) FROM json_table WHERE json.isarray(data);
SELECT json.filter(data, '$.items[*].name') FROM json_table;
SELECT json.length(json.valuearray(data)) FROM json_table WHERE json.isarray(data);
SELECT json.isobject(data) FROM json_table;