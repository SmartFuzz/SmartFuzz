CREATE TABLE test_strings (id INT PRIMARY KEY, str_value VARCHAR(255));
INSERT INTO test_strings VALUES (1, 'MonetDB'), (2, 'SQL'), (3, 'TeStInG'), (4, 'LOWERCASE'), (5, '123abc'), (6, NULL);
SELECT lcase(str_value) FROM test_strings WHERE id = 1;
SELECT lcase(str_value) FROM test_strings WHERE str_value IS NOT NULL;
SELECT id, lcase(str_value) AS lower_str FROM test_strings;
SELECT lcase(CONCAT(str_value, ' is amazing!')) FROM test_strings WHERE id IN (1, 2);
SELECT lcase(substr(str_value, 1, 3)) FROM test_strings;
SELECT id FROM test_strings WHERE lcase(str_value) = 'testing';
SELECT lcase(a.str_value) FROM test_strings a JOIN test_strings b ON a.id = b.id WHERE b.id = 3;
SELECT lcase(COALESCE(str_value, 'default')) FROM test_strings;
SELECT lcase(t1.str_value) FROM (SELECT str_value FROM test_strings WHERE id > 2) AS t1;
SELECT lcase(UPPER(str_value)) FROM test_strings;
SELECT id, lcase(str_value) FROM test_strings WHERE LENGTH(str_value) > 3;
SELECT id, lcase(aggregated) FROM (SELECT GROUP_CONCAT(str_value) AS aggregated FROM test_strings) AS agg_table;