CREATE TABLE strings_table (id INT, value VARCHAR(255));
INSERT INTO strings_table VALUES (1, E' \t Hello World! \t '), (2, E'\n Test String \n'), (3, E' Value with no spaces '), (4, E'  Leading and Trailing Spaces  ');
SELECT id, TRIM(value) FROM strings_table;
SELECT id, TRIM(value) as trimmed_value FROM strings_table WHERE TRIM(value) IS NOT NULL;
CREATE TABLE another_table (id INT, description VARCHAR(255));
INSERT INTO another_table VALUES (1, E' \t Nested Trim Test \t '), (2, E'  Clean this string!  ');
SELECT a.id, TRIM(a.description) as cleaned_description, b.value FROM strings_table a JOIN another_table b ON a.id = b.id;
SELECT id, TRIM(CONCAT(E'\t', value, E'\n')) FROM strings_table WHERE LENGTH(TRIM(value)) > 0;
SELECT id, TRIM(value), LENGTH(TRIM(value)) FROM strings_table WHERE LENGTH(TRIM(value)) > 2;
SELECT id, TRIM(value) FROM strings_table WHERE id IN (SELECT id FROM another_table WHERE TRIM(description) LIKE '%string%');
SELECT id, TRIM(TRIM(value)) as clean_value FROM (SELECT value FROM strings_table) as subquery;