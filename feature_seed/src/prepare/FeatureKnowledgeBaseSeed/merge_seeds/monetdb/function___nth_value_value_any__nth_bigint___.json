CREATE TABLE test_table (id BIGINT, value VARCHAR, created_at DATE);
INSERT INTO test_table VALUES (1, 'first', '2023-01-01'), (2, 'second', '2023-01-02'), (3, 'third', '2023-01-03');
SELECT nth_value(value, 2) OVER (ORDER BY created_at ROWS BETWEEN UNBOUNDED PRECEDING AND UNBOUNDED FOLLOWING) FROM test_table;
SELECT id, nth_value(value, 1) OVER (PARTITION BY id ORDER BY created_at) AS first_value FROM test_table;
SELECT nth_value(value, 3) OVER (ORDER BY created_at ROWS BETWEEN 1 PRECEDING AND 1 FOLLOWING) AS nth_value_result FROM test_table;
SELECT nth_value(value, 1) FROM (SELECT value FROM test_table WHERE id < 2) subquery;
WITH ranked_values AS (SELECT value, nth_value(value, 2) OVER (ORDER BY created_at) AS nth_result FROM test_table) SELECT * FROM ranked_values WHERE nth_result IS NOT NULL;
CREATE TABLE another_table (id BIGINT, related_id BIGINT);
INSERT INTO another_table VALUES (1, 1), (2, 1), (3, 2);
SELECT t.id, nth_value(t.value, 1) OVER (PARTITION BY a.related_id ORDER BY t.created_at) AS nth_value FROM test_table t JOIN another_table a ON t.id = a.related_id;
SELECT nth_value(value, 0) OVER (ORDER BY created_at) AS error_case FROM test_table;
SELECT nth_value(value, 4) OVER (ORDER BY created_at ROWS BETWEEN CURRENT ROW AND UNBOUNDED FOLLOWING) AS out_of_bound FROM test_table;
SELECT related_id, nth_value(t.value, 1) OVER (PARTITION BY related_id ORDER BY t.created_at) FROM another_table a JOIN test_table t ON a.related_id = t.id;