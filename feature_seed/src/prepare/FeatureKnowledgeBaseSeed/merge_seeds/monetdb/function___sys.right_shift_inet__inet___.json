CREATE TABLE test_inet (ip_range inet, ip_address inet);
INSERT INTO test_inet VALUES (inet '192.168.1/24', inet '192.168.1.5');
INSERT INTO test_inet VALUES (inet '192.168.2/24', inet '192.168.2.10');
INSERT INTO test_inet VALUES (inet '192.168.3/32', inet '192.168.3.1');
INSERT INTO test_inet VALUES (inet '192.169.0/16', inet '192.169.1.1');
SELECT sys.right_shift(ip_range, ip_address) FROM test_inet WHERE ip_range IS NOT NULL;
SELECT COUNT(*) FROM test_inet WHERE sys.right_shift(ip_range, ip_address);
SELECT ip_range, ip_address, sys.right_shift(ip_range, ip_address) AS result FROM test_inet WHERE result = TRUE;
SELECT ip_range FROM test_inet WHERE sys.right_shift(ip_range, inet '192.168.1.5') AND ip_range <> inet '192.168.1.0/24';
SELECT * FROM (SELECT ip_range, ip_address, sys.right_shift(ip_range, ip_address) AS check_result FROM test_inet) AS subquery WHERE check_result = TRUE;
CREATE TABLE ip_checks (ip_range inet, check_result boolean);
INSERT INTO ip_checks SELECT ip_range, sys.right_shift(ip_range, ip_address) FROM test_inet;
SELECT * FROM ip_checks WHERE check_result = TRUE;
SELECT ip_range FROM test_inet WHERE sys.right_shift(ip_range, ip_address) OR ip_range = inet '192.168.1/24';
SELECT ip_range, ip_address FROM test_inet WHERE ip_range LIKE '192.168.%' AND sys.right_shift(ip_range, ip_address);
DELETE FROM test_inet WHERE ip_address = inet '192.168.2.10';
SELECT COUNT(*) FROM test_inet WHERE ip_range = inet '192.168.2/24' AND sys.right_shift(ip_range, inet '192.168.2.20');