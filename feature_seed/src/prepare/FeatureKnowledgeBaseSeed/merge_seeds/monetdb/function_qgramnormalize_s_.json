CREATE TABLE test_strings (id INT PRIMARY KEY, original_string VARCHAR(255));
INSERT INTO test_strings (id, original_string) VALUES (1, R'Prize €50!');
INSERT INTO test_strings (id, original_string) VALUES (2, R'hello world!');
INSERT INTO test_strings (id, original_string) VALUES (3, R'ABC123!!@#');
INSERT INTO test_strings (id, original_string) VALUES (4, R'Normal String - Example 123');
INSERT INTO test_strings (id, original_string) VALUES (5, R' sp@ces and  $$ ');
SELECT id, qgramnormalize(original_string) AS normalized_string FROM test_strings;
SELECT id, qgramnormalize(R'!@#$%^&*()') AS normalized_string FROM test_strings WHERE id = 3;
SELECT id, qgramnormalize(original_string) AS normalized_string FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE original_string LIKE 'AB%');
CREATE TABLE normalized_results AS SELECT id, qgramnormalize(original_string) AS normalized_string FROM test_strings;
SELECT id, original_string, normalized_string FROM normalized_results WHERE normalized_string IS NOT NULL;
SELECT COUNT(*) FROM test_strings WHERE original_string = R'hello world!' AND qgramnormalize(original_string) = R'HELLO WORLD ';
UPDATE test_strings SET original_string = R'Updated String!!!' WHERE id = 2;
SELECT id, qgramnormalize(original_string) FROM test_strings WHERE id = (SELECT MAX(id) FROM test_strings);
INSERT INTO test_strings (id, original_string) SELECT MAX(id) + 1, qgramnormalize(original_string) FROM test_strings;