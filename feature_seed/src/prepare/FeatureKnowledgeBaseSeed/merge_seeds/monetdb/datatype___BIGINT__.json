CREATE TABLE test_bigint (id BIGINT PRIMARY KEY, value BIGINT);
INSERT INTO test_bigint (id, value) VALUES (0, 0);
INSERT INTO test_bigint (id, value) VALUES (1, 9223372036854775807);
INSERT INTO test_bigint (id, value) VALUES (2, -9223372036854775807);
INSERT INTO test_bigint (id, value) VALUES (3, -1);
INSERT INTO test_bigint (id, value) VALUES (4, 1234567890123456789);
SELECT * FROM test_bigint WHERE value BETWEEN -9223372036854775807 AND 9223372036854775807;
SELECT MAX(value) FROM test_bigint;
SELECT MIN(value) FROM test_bigint;
SELECT AVG(value) FROM test_bigint;
SELECT id, value * 2 AS double_value FROM test_bigint WHERE value > 0;
WITH temp AS (SELECT id, value FROM test_bigint WHERE value < 100) SELECT COUNT(*) FROM temp;
SELECT t1.id, t1.value + t2.value AS sum_value FROM test_bigint t1 JOIN test_bigint t2 ON t1.id != t2.id;
INSERT INTO test_bigint (id, value) VALUES (5, 9223372036854775807 + 1);
SELECT COUNT(*) FROM test_bigint WHERE value < -9223372036854775807 OR value > 9223372036854775807;