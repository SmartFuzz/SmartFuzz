CREATE TABLE timestamps (id INT PRIMARY KEY, ts_tstz1 TIMESTAMPTZ, ts_tstz2 TIMESTAMPTZ);
INSERT INTO timestamps VALUES (1, timestamp '2021-12-31 18:40:40+00', timestamp '2021-12-30 16:30:20+00');
SELECT timestampdiff(ts_tstz, ts_tstz) FROM timestamps WHERE id = 1;
CREATE TABLE additional_dates (id INT PRIMARY KEY, ts_tstz TIMESTAMPTZ);
INSERT INTO additional_dates VALUES (1, timestamp '2021-01-01 00:00:00+00'), (2, timestamp '2021-01-02 00:00:00+00');
SELECT timestampdiff(ts_tstz, (SELECT ts_tstz FROM additional_dates WHERE id = 1 LIMIT 1)) FROM timestamps WHERE id = 1;
SELECT t1.id, timestampdiff(t1.ts_tstz1, t2.ts_tstz2) FROM timestamps t1 JOIN timestamps t2 ON t1.id = t2.id WHERE t1.id < 2;
SELECT timestampdiff(timestamp '2021-12-31 18:40:40+00', timestamp '2050-01-01 12:00:00+00') AS future_diff;
SELECT timestampdiff(timestamp '2021-12-31 23:59:59+00', timestamp '2021-12-31 00:00:00+00') AS end_of_day_diff;
SELECT COUNT(*) FROM timestamps WHERE timestampdiff(ts_tstz1, ts_tstz2) > interval '1 day';
SELECT id, timestampdiff(ts_tstz1, ts_tstz2) AS diff FROM timestamps WHERE timestampdiff(ts_tstz1, ts_tstz2) BETWEEN interval '1 hour' AND interval '12 hours';
SELECT sum(timestampdiff(ts_tstz1, ts_tstz2)) FROM timestamps;