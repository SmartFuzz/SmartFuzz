CREATE SEQUENCE test_sequence START WITH 1 INCREMENT BY 1 MINVALUE 1 MAXVALUE 100 CACHE 10;
ALTER SEQUENCE test_sequence INCREMENT BY 2;
ALTER SEQUENCE test_sequence RESTART WITH 10;
ALTER SEQUENCE test_sequence MINVALUE 5;
ALTER SEQUENCE test_sequence MAXVALUE 200;
ALTER SEQUENCE test_sequence CACHE 20;
ALTER SEQUENCE test_sequence NO CYCLE;
CREATE SEQUENCE complex_sequence AS BIGINT RESTART WITH 1 INCREMENT BY 5;
ALTER SEQUENCE complex_sequence INCREMENT BY 10 MINVALUE 0 MAXVALUE 1000 CYCLE;
ALTER SEQUENCE test_sequence AS INTEGER RESTART WITH 1;
ALTER SEQUENCE test_sequence RESTART WITH (SELECT COUNT(*) FROM test_table) INCREMENT BY 5;
ALTER SEQUENCE test_sequence INCREMENT BY (SELECT MAX(value) FROM another_table);
CREATE SEQUENCE nested_seq AS INTEGER START WITH (SELECT MIN(id) FROM nested_table) INCREMENT BY 1;
ALTER SEQUENCE (SELECT sequence_name FROM sys.sequences WHERE seq_id = 1) CACHE 5;
ALTER SEQUENCE (SELECT sequence_name FROM information_schema.sequences WHERE schema_name = 'public') MINVALUE 1;
ALTER SEQUENCE complex_sequence RESTART WITH (SELECT NEXTVAL('complex_sequence') + 1) INCREMENT BY 1;