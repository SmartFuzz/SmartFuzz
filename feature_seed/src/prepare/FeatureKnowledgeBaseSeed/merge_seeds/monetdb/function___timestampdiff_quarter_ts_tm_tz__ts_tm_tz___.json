CREATE TABLE timestamps (id INT, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, timestamp '2021-12-31 18:40:40', timestamp '2021-02-20 16:30:20');
SELECT timestampdiff_quarter(start_time, end_time) FROM timestamps WHERE id = 1;
SELECT COUNT(*), timestampdiff_quarter(a.start_time, b.end_time) FROM timestamps a JOIN timestamps b ON a.id <> b.id GROUP BY a.id;
CREATE TABLE timezone_timestamps (id INT, start_time TIMESTAMP WITH TIME ZONE, end_time TIMESTAMP WITH TIME ZONE);
INSERT INTO timezone_timestamps VALUES (1, timestamp '2021-12-31 18:40:40+00', timestamp '2021-02-20 16:30:20+00');
SELECT timestampdiff_quarter(start_time, end_time) FROM timezone_timestamps WHERE id = 1;
SELECT t.id, timestampdiff_quarter(t1.start_time, t2.end_time) FROM timezone_timestamps t1 JOIN timezone_timestamps t2 ON t1.id <> t2.id AS t;
SELECT timestampdiff_quarter(timestamp '2021-06-30 12:00:00', timestamp '2021-03-01 12:00:00') AS quarter_diff;
SELECT timestampdiff_quarter(CURRENT_TIMESTAMP, timestamp '2020-01-01 00:00:00') AS current_diff;
SELECT timestampdiff_quarter(timestamp '2025-01-01 00:00:00', timestamp '2021-01-01 00:00:01') AS future_diff;