CREATE TABLE test_xor (a INT, b INT);
INSERT INTO test_xor VALUES (0, 0);
INSERT INTO test_xor VALUES (1, 1);
INSERT INTO test_xor VALUES (17, 5);
INSERT INTO test_xor VALUES (2147483647, 1);
INSERT INTO test_xor VALUES (2147483647, 2147483647);
INSERT INTO test_xor VALUES (-1, -1);
INSERT INTO test_xor VALUES (-10, 5);
SELECT bit_xor(a, b) FROM test_xor WHERE a >= 0 AND b >= 0;
SELECT bit_xor(a, b) FROM test_xor WHERE a < 0 AND b < 0;
SELECT bit_xor(a, b) FROM test_xor WHERE a & 1 = 0 OR b & 1 = 0;
SELECT bit_xor(a, b) AS result FROM (SELECT a, b FROM test_xor) AS subquery;
CREATE TABLE additional_test (c INT, d INT);
INSERT INTO additional_test VALUES (3, 6);
INSERT INTO additional_test VALUES (8, 12);
SELECT bit_xor(x.a, y.d) FROM test_xor x JOIN additional_test y ON x.a = y.c;
SELECT bit_xor(a, b) FROM test_xor WHERE a IN (SELECT c FROM additional_test WHERE d > 5);
SELECT bit_xor(a, b) FROM test_xor WHERE (a + b) BETWEEN 0 AND 30;
SELECT bit_xor(a, b) FROM test_xor WHERE (SELECT COUNT(*) FROM additional_test) > 1;