CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, NULL), (4, 40);
SELECT max(value) FROM test_table;
CREATE TABLE another_table (id INT, parent_id INT, value INT);
INSERT INTO another_table VALUES (1, NULL, 5), (2, 1, 7), (3, 1, NULL), (4, 2, 10);
SELECT max(value) FROM another_table;
SELECT max(value) FROM another_table WHERE parent_id IS NOT NULL;
SELECT max(value) FROM (SELECT value FROM test_table WHERE value > 15) AS subquery;
SELECT max(t1.value) FROM test_table AS t1 JOIN another_table AS t2 ON t1.id = t2.parent_id;
CREATE TABLE grouped_table (category VARCHAR(50), amount INT);
INSERT INTO grouped_table VALUES ('A', 100), ('A', 200), ('B', 150), ('C', NULL);
SELECT category, max(amount) FROM grouped_table GROUP BY category;
SELECT max(val) FROM (SELECT MAX(value) AS val FROM test_table GROUP BY id) AS grouped;
CREATE TABLE composite_table (group_id INT, item_id INT, item_value INT);
INSERT INTO composite_table VALUES (1, 1, 30), (1, 2, 40), (2, 3, 60), (2, 4, NULL);
SELECT group_id, max(item_value) FROM composite_table GROUP BY group_id;
SELECT max(val) FROM (SELECT max(value) AS val FROM test_table WHERE id < 3) AS subquery;
SELECT max(t1.value) FROM test_table t1 WHERE EXISTS (SELECT 1 FROM another_table t2 WHERE t1.id = t2.parent_id);