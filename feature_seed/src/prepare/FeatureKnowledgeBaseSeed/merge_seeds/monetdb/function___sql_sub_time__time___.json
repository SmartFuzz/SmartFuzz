CREATE TABLE time_example (start_time TIME, end_time TIME);
INSERT INTO time_example VALUES (TIME '09:00:00', TIME '17:00:00');
SELECT sql_sub(start_time, end_time) AS duration FROM time_example;
INSERT INTO time_example VALUES (TIME '00:00:00', TIME '23:59:59');
SELECT sql_sub(start_time, end_time) AS duration FROM time_example WHERE start_time < end_time;
INSERT INTO time_example VALUES (TIME '12:30:45', TIME '14:15:30');
SELECT sql_sub(T1.start_time, T2.end_time) AS interval_diff FROM (SELECT start_time FROM time_example) T1, (SELECT end_time FROM time_example) T2;
INSERT INTO time_example VALUES (TIME '06:00:00', TIME '06:00:00');
SELECT CASE WHEN sql_sub(start_time, end_time) < 0 THEN 'Negative Interval' ELSE 'Positive Interval' END AS interval_status FROM time_example;
CREATE TABLE time_log (event_time TIME, description TEXT);
INSERT INTO time_log VALUES (TIME '09:15:00', 'Start Work');
INSERT INTO time_log VALUES (TIME '17:30:00', 'End Work');
SELECT sql_sub(T1.event_time, T2.event_time) AS work_duration FROM time_log T1, time_log T2 WHERE T1.description = 'Start Work' AND T2.description = 'End Work';
CREATE TABLE appointments (appointment_time TIME, duration TIME);
INSERT INTO appointments VALUES (TIME '10:00:00', TIME '01:30:00');
SELECT sql_sub(appointment_time, sql_sub(T1.appointment_time, T1.duration)) AS free_time FROM appointments T1 WHERE T1.appointment_time < '15:00:00';
SELECT sql_sub(T1.start_time, T2.event_time) AS time_difference FROM time_example T1 JOIN time_log T2 ON T1.start_time < T2.event_time;