CREATE TABLE time_test (id INT, creation_time TIME);
INSERT INTO time_test (id, creation_time) VALUES (1, localtime());
SELECT id, creation_time, localtime() AS current_time FROM time_test;
SELECT id, creation_time, (SELECT localtime()) AS subquery_time FROM time_test;
CREATE TABLE another_time_test (id INT, event_time TIME);
INSERT INTO another_time_test (id, event_time) VALUES (1, localtime()), (2, localtime());
SELECT at.id, at.event_time, lt.current_time FROM another_time_test at JOIN (SELECT localtime() AS current_time) lt ON at.id = lt.current_time;
SELECT id, CASE WHEN creation_time < localtime() THEN 'Past' ELSE 'Future' END AS time_status FROM time_test;
CREATE TABLE complex_time_test (id INT, timestamp_col TIMESTAMP);
INSERT INTO complex_time_test (id, timestamp_col) VALUES (1, localtime()::timestamp), (2, localtime()::timestamp);
SELECT ct.id, ct.timestamp_col, (SELECT localtime()::timestamp) AS nested_current_time FROM complex_time_test ct WHERE ct.timestamp_col < localtime()::timestamp;