CREATE TABLE intervals (id INT PRIMARY KEY, duration INTERVAL HOUR);
INSERT INTO intervals VALUES (1, INTERVAL '1:30:00' HOUR TO SECOND);
INSERT INTO intervals VALUES (2, INTERVAL '0:45:30' HOUR TO SECOND);
INSERT INTO intervals VALUES (3, INTERVAL '2:15:45' HOUR TO SECOND);
SELECT id, duration, EXTRACT(HOUR FROM duration) AS hours FROM intervals;
SELECT id, duration + INTERVAL '0:15:00' HOUR TO SECOND AS updated_duration FROM intervals;
SELECT id, duration - INTERVAL '1:00:00' HOUR TO SECOND AS reduced_duration FROM intervals WHERE duration > INTERVAL '1:00:00' HOUR TO SECOND;
CREATE TABLE related_events (event_id INT PRIMARY KEY, duration INTERVAL HOUR, interval_id INT REFERENCES intervals(id));
INSERT INTO related_events VALUES (1, INTERVAL '0:30:00' HOUR TO SECOND, 1);
INSERT INTO related_events VALUES (2, INTERVAL '1:20:00' HOUR TO SECOND, 2);
SELECT re.event_id, re.duration, i.duration AS interval_duration FROM related_events re JOIN intervals i ON re.interval_id = i.id;
SELECT re.event_id, SUM(re.duration + i.duration) AS total_duration FROM related_events re JOIN intervals i ON re.interval_id = i.id GROUP BY re.event_id;
SELECT (SELECT duration FROM intervals WHERE id = 1) + INTERVAL '0:30:00' HOUR TO SECOND AS future_duration;
SELECT id, duration * 2 AS doubled_duration FROM intervals;
SELECT MAX(duration) FROM intervals;
SELECT AVG(EXTRACT(EPOCH FROM duration)) AS average_seconds FROM intervals;
SELECT * FROM intervals WHERE duration < (SELECT AVG(duration) FROM intervals);