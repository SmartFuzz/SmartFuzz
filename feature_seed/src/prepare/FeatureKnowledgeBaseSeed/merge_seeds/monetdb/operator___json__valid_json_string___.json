CREATE TABLE json_test (id INT, json_data JSON);
INSERT INTO json_test VALUES (1, json '{"a":[1,2,4]}');
INSERT INTO json_test VALUES (2, json '{"b":{"c":5}}');
INSERT INTO json_test VALUES (3, json '{"d":{"e":[7,8,9], "f":10}}');
SELECT * FROM json_test WHERE json_data->>'a' IS NOT NULL;
SELECT json_data FROM json_test WHERE id = 1;
SELECT json_data->'a' FROM json_test WHERE json_data->>'b' IS NULL;
SELECT id FROM json_test WHERE json_data->>'a' = '1' OR json_data->>'a' = '2';
CREATE TABLE json_nested (id INT, parent_json JSON);
INSERT INTO json_nested VALUES (1, json '{"parent":{"child":{"key":"value"}}}');
SELECT parent_json->'parent'->'child'->>'key' FROM json_nested WHERE id = 1;
SELECT id FROM json_nested WHERE parent_json->'parent'->'child'->>'key' = 'value';
CREATE TABLE json_join (id INT, json_data JSON);
INSERT INTO json_join VALUES (1, json '{"key1":"value1"}'), (2, json '{"key2":"value2"}');
SELECT j1.id, j1.json_data->>'key1', j2.json_data->>'key2' FROM json_join j1 JOIN json_join j2 ON j1.id <> j2.id;
SELECT id, json_data->'key1' AS key1_value FROM json_join WHERE json_data IS NOT NULL AND json_data ->> 'key1' = 'value1';
SELECT json_data FROM json_join WHERE json_data->>'key' IS NULL UNION SELECT json_data FROM json_test WHERE json_data->>'a' IS NOT NULL;