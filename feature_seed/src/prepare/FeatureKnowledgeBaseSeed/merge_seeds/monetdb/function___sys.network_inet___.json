CREATE TABLE ip_addresses (id INT PRIMARY KEY, ip inet);
INSERT INTO ip_addresses VALUES (1, inet '192.168.1.5/24');
INSERT INTO ip_addresses VALUES (2, inet '10.0.0.1/16');
INSERT INTO ip_addresses VALUES (3, inet '172.16.0.5/12');
INSERT INTO ip_addresses VALUES (4, inet '0.0.0.0/0');
INSERT INTO ip_addresses VALUES (5, inet '255.255.255.255/32');
SELECT ip, sys.network(ip) FROM ip_addresses;
SELECT ip, sys.network(ip) FROM ip_addresses WHERE sys.network(ip) = sys.network(inet '192.168.1.5/24');
SELECT DISTINCT sys.network(ip) FROM ip_addresses JOIN ip_addresses AS t ON sys.network(ip) = sys.network(t.ip);
SELECT id, ip FROM ip_addresses WHERE sys.network(ip) IN (SELECT sys.network(inet '10.0.0.1/16') UNION SELECT sys.network(inet '192.168.1.5/24'));
CREATE TABLE network_ranges (range inet);
INSERT INTO network_ranges VALUES (inet '192.168.1.0/24'), (inet '10.0.0.0/16');
SELECT COUNT(*) FROM ip_addresses WHERE sys.network(ip) IN (SELECT range FROM network_ranges);
SELECT MAX(sys.network(ip)) FROM ip_addresses;
SELECT MIN(sys.network(ip)) FROM ip_addresses WHERE id < 3;
WITH networks AS (SELECT sys.network(ip) AS net FROM ip_addresses) SELECT net, COUNT(*) FROM networks GROUP BY net;