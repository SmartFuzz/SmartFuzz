CREATE TABLE time_table (event_name VARCHAR(100), event_time TIME(0));
INSERT INTO time_table VALUES ('Morning Meeting', '09:00:00');
INSERT INTO time_table VALUES ('Lunch Break', '12:30:00');
INSERT INTO time_table VALUES ('Afternoon Review', '15:45:00');
INSERT INTO time_table VALUES ('End of Day', '17:00:00');
SELECT * FROM time_table WHERE event_time BETWEEN '00:00:00' AND '23:59:59';
SELECT event_name FROM time_table WHERE event_time < '12:00:00' ORDER BY event_time DESC;
SELECT event_name FROM time_table WHERE event_time >= '17:00:00' AND event_time <= '23:59:59';
SELECT COUNT(*) FROM time_table WHERE event_time IS NOT NULL;
SELECT event_name, event_time FROM time_table WHERE event_time = (SELECT MIN(event_time) FROM time_table);
SELECT event_name FROM time_table WHERE event_time IN (SELECT event_time FROM time_table WHERE event_time > '10:00:00' AND event_time < '15:00:00');
CREATE TABLE schedule (worker_id INT, shift_start TIME(0), shift_end TIME(0));
INSERT INTO schedule VALUES (1, '08:00:00', '16:00:00');
INSERT INTO schedule VALUES (2, '16:00:00', '00:00:00');
SELECT t.event_name FROM time_table t JOIN schedule s ON t.event_time BETWEEN s.shift_start AND s.shift_end WHERE s.worker_id = 1;
SELECT t.event_name FROM time_table t LEFT JOIN schedule s ON t.event_time = s.shift_start WHERE s.worker_id IS NULL;
SELECT event_name FROM time_table WHERE event_time = '00:00:00';
SELECT event_name FROM time_table WHERE event_time = '23:59:59';
SELECT COUNT(*) FROM time_table WHERE event_time NOT BETWEEN '00:00:00' AND '23:59:59';