CREATE TABLE timestamps (event_time TIMESTAMPTZ);
INSERT INTO timestamps VALUES (TIMESTAMPTZ '2021-12-31 18:00:00 +00:00');
INSERT INTO timestamps VALUES (TIMESTAMPTZ '2022-01-01 00:00:00 +00:00');
SELECT sys.timestamp_to_str(event_time, '%Y-%m-%d %H:%M:%S %Z') FROM timestamps;
SELECT sys.timestamp_to_str(event_time, '%m/%d/%Y %l:%M:%S %p') AS formatted_time FROM timestamps WHERE event_time BETWEEN TIMESTAMPTZ '2021-12-31 00:00:00' AND TIMESTAMPTZ '2022-01-01 23:59:59';
CREATE TABLE events (event_id INT, event_time TIMESTAMPTZ);
INSERT INTO events VALUES (1, TIMESTAMPTZ '2021-06-15 10:30:00 +02:00'), (2, TIMESTAMPTZ '2021-12-31 18:00:00 +00:00');
SELECT e.event_id, sys.timestamp_to_str(e.event_time, '%Y-%m-%d %H:%M:%S') FROM events e JOIN timestamps t ON e.event_time = t.event_time;
SELECT sys.timestamp_to_str(event_time, '%Y-%m-%d %H:%M:%S') FROM events WHERE event_time IN (SELECT event_time FROM timestamps);
SELECT sys.timestamp_to_str(MAX(event_time), '%Y-%m-%d %H:%M:%S') FROM events;
SELECT sys.timestamp_to_str(MIN(event_time), '%m/%d/%Y %H:%M:%S %p') FROM events;