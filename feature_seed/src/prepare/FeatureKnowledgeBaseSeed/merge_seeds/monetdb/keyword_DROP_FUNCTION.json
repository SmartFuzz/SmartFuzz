CREATE FUNCTION testfun(int, double) RETURNS double AS 'return $1 + $2;
' LANGUAGE SQL;
DROP FUNCTION testfun(int, double);
CREATE FUNCTION my_schema.my_function(text) RETURNS text AS 'return $1;
' LANGUAGE SQL;
DROP FUNCTION my_schema.my_function(text);
CREATE FUNCTION example_fn(int, varchar) RETURNS varchar AS 'return $2 || $1;
' LANGUAGE SQL;
DROP FUNCTION IF EXISTS example_fn(int, varchar);
DROP FUNCTION my_schema.my_function(text) CASCADE;
CREATE FUNCTION another_fn(bool) RETURNS bool AS 'return NOT $1;
' LANGUAGE SQL;
DROP FUNCTION another_fn(bool) RESTRICT;
DROP FUNCTION IF EXISTS testfun CASCADE;
CREATE FUNCTION func_with_no_args() RETURNS void AS 'return;
' LANGUAGE SQL;
DROP FUNCTION func_with_no_args();
CREATE FUNCTION complex_fn(a int, b double) RETURNS double AS 'return a * b;
' LANGUAGE SQL;
DROP FUNCTION complex_fn(int, double) CASCADE;
CREATE FUNCTION multi_arg_fn(a int, b varchar, c double) RETURNS varchar AS 'return b || a || c::text;
' LANGUAGE SQL;
DROP FUNCTION multi_arg_fn(int, varchar, double) RESTRICT;