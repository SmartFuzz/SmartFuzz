CREATE TABLE test_dates (id INT, date_value DATE);
INSERT INTO test_dates VALUES (1, DATE '1999-12-31');
INSERT INTO test_dates VALUES (2, DATE '2000-01-01');
INSERT INTO test_dates VALUES (3, DATE '2020-03-22');
INSERT INTO test_dates VALUES (4, DATE '2100-02-28');
INSERT INTO test_dates VALUES (5, DATE '2200-01-01');
SELECT id, date_value, century(date_value) FROM test_dates;
SELECT AVG(century(date_value)) FROM test_dates;
SELECT id, century(date_value) AS century_extracted FROM test_dates WHERE century(date_value) > 20;
SELECT id FROM test_dates WHERE century(date_value) = (SELECT MAX(century(date_value)) FROM test_dates);
CREATE TABLE further_tests (id INT, ref_date DATE, related_id INT);
INSERT INTO further_tests VALUES (1, DATE '1980-06-15', 1);
INSERT INTO further_tests VALUES (2, DATE '1990-05-20', 2);
INSERT INTO further_tests VALUES (3, DATE '2010-09-10', 3);
SELECT t.id, t.date_value, ft.ref_date, century(t.date_value) AS century_value FROM test_dates t JOIN further_tests ft ON t.id = ft.related_id WHERE century(t.date_value) = century(ft.ref_date);
SELECT id, date_value, century(date_value) FROM test_dates ORDER BY century(date_value) DESC;
SELECT DISTINCT century(date_value) FROM test_dates WHERE century(date_value) BETWEEN 20 AND 22;