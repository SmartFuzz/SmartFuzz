CREATE TABLE urls (scheme VARCHAR(10), host VARCHAR(100), port INTEGER, path VARCHAR(255));
INSERT INTO urls VALUES ('http', 'example.com', 80, 'home');
INSERT INTO urls VALUES ('https', 'www.a.com', 5567, 'docs/index.html');
INSERT INTO urls VALUES ('ftp', 'ftp.example.com', 21, 'files/file.txt');
INSERT INTO urls VALUES ('mailto', 'user@example.com', NULL, NULL);
SELECT sys.newurl(scheme, host, port, path) FROM urls WHERE port IS NOT NULL;
SELECT sys.newurl('http', host, 80, path) FROM urls WHERE scheme = 'http';
SELECT sys.newurl('https', host, port, path) FROM urls WHERE path IS NOT NULL;
SELECT DISTINCT sys.newurl(scheme, host, port, path) FROM urls WHERE scheme IN ('http', 'https') AND port BETWEEN 1 AND 65535;
SELECT sys.newurl(scheme, host, port, path) AS full_url FROM urls WHERE LENGTH(path) <= 255;
SELECT COUNT(*) FROM (SELECT sys.newurl(scheme, host, port, path) FROM urls) AS url_count WHERE url_count IS NOT NULL;