CREATE TABLE strings_table (s1 VARCHAR(255), s2 VARCHAR(255));
INSERT INTO strings_table VALUES ('MonetDB', 'DB3');
INSERT INTO strings_table VALUES ('test', 'test');
INSERT INTO strings_table VALUES ('test', 'testing');
INSERT INTO strings_table VALUES ('', '');
INSERT INTO strings_table VALUES ('a', '');
INSERT INTO strings_table VALUES ('', 'a');
INSERT INTO strings_table VALUES ('a', 'a');
INSERT INTO strings_table VALUES ('kitten', 'sitting');
INSERT INTO strings_table VALUES ('flaw', 'lawn');
SELECT editdistance(s1, s2) FROM strings_table;
SELECT editdistance(s1, s2) AS distance FROM strings_table WHERE s1 IS NOT NULL AND s2 IS NOT NULL;
SELECT s1, s2, editdistance(s1, s2) AS distance FROM strings_table WHERE LENGTH(s1) > 0 AND LENGTH(s2) > 0;
CREATE TABLE more_strings (s1 VARCHAR(255), s2 VARCHAR(255), context VARCHAR(255));
INSERT INTO more_strings VALUES ('flaw', 'lawn', 'similar words');
INSERT INTO more_strings VALUES ('MonetDB', 'MonetDB', 'exact match');
INSERT INTO more_strings VALUES ('abc', 'abcd', 'prefix match');
SELECT m.context, editdistance(m.s1, m.s2) AS distance FROM more_strings m WHERE distance > 0;
SELECT editdistance('MonetDB', 'MonetDB') AS exact_match_distance;
SELECT editdistance('string', 'stringd') AS one_char_difference;
SELECT editdistance(s1, s2) FROM strings_table WHERE LENGTH(s1) < LENGTH(s2);
SELECT editdistance(a.s1, b.s2) FROM strings_table a JOIN strings_table b ON a.s1 != b.s1 WHERE LENGTH(a.s1) <= LENGTH(b.s2);