CREATE TABLE test_spaces (id INT, description TEXT);
INSERT INTO test_spaces VALUES (1, 'leading spaces'), (2, 'trailing spaces'), (3, 'multiple spaces'), (4, 'no spaces');
SELECT description || space(4) FROM test_spaces WHERE id = 1;
SELECT description || space(0) FROM test_spaces WHERE id = 2;
SELECT description || space(10) FROM test_spaces WHERE id = 3;
SELECT 'Start' || space(3) || 'Middle' || space(2) || 'End' AS complex_space FROM test_spaces WHERE id = 4;
SELECT id, description || space(5) AS spaced_desc FROM test_spaces ORDER BY id;
SELECT 'Result: ' || (SELECT COUNT(*) || space(3) || SUM(id) FROM test_spaces) AS summary;
SELECT DISTINCT space(2) || id || space(2) AS spaced_id FROM test_spaces WHERE id IN (SELECT id FROM test_spaces WHERE id < 3);
SELECT 'Row: ' || t1.id || space(t1.id) || ' of test' AS formatted_space FROM (SELECT id FROM test_spaces) AS t1;
SELECT 'Concatenated' || space(6) || 'Text' FROM (SELECT id FROM test_spaces LIMIT 1) AS subquery;