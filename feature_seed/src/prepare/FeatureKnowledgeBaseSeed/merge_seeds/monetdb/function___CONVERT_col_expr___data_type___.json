CREATE TABLE test_convert (id INT, value VARCHAR(100));
INSERT INTO test_convert VALUES (1, '100.123'), (2, '200.456'), (3, 'invalid'), (4, NULL);
SELECT id, CONVERT(value, DECIMAL(10, 3)) AS converted_value FROM test_convert;
SELECT id, CASE WHEN value IS NOT NULL THEN CONVERT(value, DECIMAL(10, 3)) ELSE NULL END AS converted_value FROM test_convert;
CREATE TABLE test_nested (a INT, b VARCHAR(100));
INSERT INTO test_nested VALUES (1, '10.5'), (2, '20.5');
SELECT a, CONVERT((SELECT SUM(CONVERT(b, DECIMAL(10, 2))) FROM test_nested WHERE a <= 2), DECIMAL(10, 2)) AS total_sum FROM test_nested;
CREATE TABLE test_join (id INT, ref_id INT, amount VARCHAR(50));
INSERT INTO test_join VALUES (1, 1, '1.234'), (2, 1, '4.567'), (3, 2, '8.910');
SELECT T1.id, SUM(CONVERT(T2.amount, DECIMAL(10, 3))) AS total_amount FROM test_join T1 JOIN test_nested T2 ON T1.ref_id = T2.a GROUP BY T1.id;
SELECT id, CONVERT(COALESCE(value, '0'), DECIMAL(10, 3)) AS converted_value FROM test_convert WHERE value IS NOT NULL;
CREATE TABLE mixed_types (mixed_value VARCHAR(100));
INSERT INTO mixed_types VALUES ('123.456'), ('999.999'), ('zero'), (NULL);
SELECT mixed_value, CONVERT(mixed_value, DECIMAL(10, 3)) AS converted_value FROM mixed_types;
SELECT DISTINCT CONVERT(value, DECIMAL(10, 3)) FROM test_convert WHERE CONVERT(value, DECIMAL(10, 3)) IS NOT NULL;