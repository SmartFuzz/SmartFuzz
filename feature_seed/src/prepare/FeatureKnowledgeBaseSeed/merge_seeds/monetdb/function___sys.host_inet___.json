CREATE TABLE ip_addresses (id INT PRIMARY KEY, inet_addr INET);
INSERT INTO ip_addresses VALUES (1, inet '192.168.1.5/24');
INSERT INTO ip_addresses VALUES (2, inet '10.0.0.1/8');
INSERT INTO ip_addresses VALUES (3, inet '172.16.0.10/12');
SELECT sys.host(inet_addr) FROM ip_addresses WHERE id = 1;
SELECT sys.host(inet '255.255.255.255/32');
SELECT sys.host(inet '0.0.0.0/0');
SELECT sys.host(inet '127.0.0.1/8'), sys.host(inet '192.168.100.1/24');
SELECT id, sys.host(inet_addr) FROM ip_addresses WHERE inet_addr IN (SELECT inet '192.168.1.5/24' UNION SELECT inet '10.0.0.1/8');
CREATE TABLE network_info (network_id INT PRIMARY KEY, network_cidr INET);
INSERT INTO network_info VALUES (1, inet '192.168.0.0/16'), (2, inet '172.30.0.0/16');
SELECT n.network_id, sys.host(n.network_cidr) FROM network_info n JOIN ip_addresses i ON sys.host(i.inet_addr) = sys.host(n.network_cidr);
CREATE TABLE log_data (log_id INT PRIMARY KEY, log_ip INET);
INSERT INTO log_data VALUES (1, inet '192.168.1.10/24'), (2, inet '10.0.1.5/24');
SELECT l.log_id, sys.host(l.log_ip) AS ip_address FROM log_data l WHERE l.log_ip != inet '192.168.1.5/24';
SELECT id, sys.host(inet_addr) AS ip_address FROM ip_addresses WHERE inet_addr LIKE '192.168.%';
SELECT DISTINCT sys.host(inet_addr) FROM ip_addresses WHERE sys.host(inet_addr) NOT IN (SELECT sys.host(inet '10.0.0.1/8'));