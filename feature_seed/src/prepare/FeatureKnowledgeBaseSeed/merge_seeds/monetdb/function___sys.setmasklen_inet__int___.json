CREATE TABLE inet_test (id INT, addr INET);
INSERT INTO inet_test VALUES (1, inet '192.168.1.5/24');
INSERT INTO inet_test VALUES (2, inet '10.0.0.1/16');
INSERT INTO inet_test VALUES (3, inet '172.16.0.1/12');
INSERT INTO inet_test VALUES (4, inet '255.255.255.255/32');
INSERT INTO inet_test VALUES (5, inet '0.0.0.0/0');
SELECT sys.setmasklen(addr, 16) FROM inet_test WHERE id = 1;
SELECT sys.setmasklen(addr, 12) FROM inet_test WHERE id = 3;
SELECT sys.setmasklen(addr, 24) AS modified_addr FROM inet_test WHERE modified_addr IS NOT NULL;
SELECT addr, sys.setmasklen(addr, 20) FROM inet_test WHERE id IN (2, 4);
SELECT DISTINCT sys.setmasklen(addr, 30) AS new_mask FROM inet_test WHERE new_mask IS NOT NULL ORDER BY new_mask;
CREATE TABLE subnet_test AS SELECT id, sys.setmasklen(addr, 28) AS subnet FROM inet_test;
SELECT t1.id, t1.addr, t2.subnet FROM inet_test t1 JOIN subnet_test t2 ON t1.id = t2.id WHERE t2.subnet IS NOT NULL;
SELECT sys.setmasklen(addr, 10) FROM inet_test WHERE addr NOT IN (SELECT addr FROM inet_test WHERE id = 5);
INSERT INTO inet_test (id, addr) SELECT id, sys.setmasklen(addr, 16) FROM inet_test WHERE id < 3;