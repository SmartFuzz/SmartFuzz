CREATE TABLE test_table (id INT, name VARCHAR(50), value INT);
INSERT INTO test_table VALUES (1, 'test1', NULL);
INSERT INTO test_table VALUES (2, 'test2', 100);
INSERT INTO test_table VALUES (3, 'test3', NULL);
SELECT isnull(name) FROM test_table;
SELECT isnull(value) FROM test_table WHERE id = 1;
SELECT id FROM test_table WHERE isnull(value);
SELECT id, isnull(value) AS is_value_null FROM test_table WHERE name = 'test1';
SELECT id FROM (SELECT id, value, isnull(value) AS is_value_null FROM test_table) AS subquery WHERE is_value_null;
SELECT COUNT(*) FROM test_table WHERE isnull(name) OR isnull(value);
CREATE TABLE test_table_2 (id INT, test_id INT, description VARCHAR(100));
INSERT INTO test_table_2 VALUES (1, 1, 'test description 1');
INSERT INTO test_table_2 VALUES (2, 2, NULL);
SELECT t1.id, t1.name, isnull(t2.description) FROM test_table t1 LEFT JOIN test_table_2 t2 ON t1.id = t2.test_id;
SELECT t1.id, isnull(t1.value), isnull(t2.description) FROM test_table t1 JOIN test_table_2 t2 ON t1.id = t2.test_id WHERE isnull(t1.value) OR isnull(t2.description);
SELECT isnull(NULL) AS check_null_val;
SELECT isnull(name) FROM test_table WHERE id = 3 UNION SELECT isnull(NULL);
SELECT * FROM (SELECT id, isnull(value) AS is_value_null FROM test_table WHERE isnull(name)) AS subquery;