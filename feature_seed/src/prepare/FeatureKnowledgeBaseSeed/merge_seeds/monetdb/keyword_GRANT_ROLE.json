CREATE ROLE admin_role;
CREATE ROLE user_role;
CREATE USER jan PASSWORD 'securePass';
CREATE USER mike PASSWORD 'securePass';
GRANT admin_role TO jan;
GRANT user_role TO mike;
GRANT admin_role, user_role TO jan, mike;
GRANT controller TO jan WITH ADMIN OPTION;
GRANT user_role TO jan WITH ADMIN grantor;
GRANT admin_role TO (SELECT user_login_name FROM sys.user_role WHERE role_name = 'user_role') WITH ADMIN OPTION;
GRANT admin_role TO (SELECT user_login_name FROM (SELECT user_login_name FROM sys.user_role WHERE role_name = 'user_role') AS subquery) WITH ADMIN grantor;
GRANT user_role TO jan, (SELECT user_login_name FROM sys.user_role WHERE role_name = 'admin_role') WITH ADMIN OPTION;
GRANT controller TO jan, mike WITH ADMIN OPTION;