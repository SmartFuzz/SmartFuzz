CREATE TABLE events (id INT PRIMARY KEY, event_name VARCHAR(100), event_timestamp TIMESTAMP(3));
INSERT INTO events VALUES (1, 'Event A', TIMESTAMP '2023-10-01 10:00:00.123'), (2, 'Event B', TIMESTAMP '2023-10-02 11:30:00.456');
SELECT event_name FROM events WHERE event_timestamp >= TIMESTAMP '2023-10-01 00:00:00' AND event_timestamp < TIMESTAMP '2023-10-03 00:00:00';
CREATE TABLE event_logs (log_id INT PRIMARY KEY, event_id INT, log_timestamp TIMESTAMP, FOREIGN KEY (event_id) REFERENCES events(id));
INSERT INTO event_logs VALUES (1, 1, TIMESTAMP '2023-10-01 10:05:00.789'), (2, 2, TIMESTAMP '2023-10-02 12:00:00.000');
SELECT e.event_name, COUNT(el.log_id) AS log_count FROM events e LEFT JOIN event_logs el ON e.id = el.event_id GROUP BY e.event_name;
SELECT e.event_name FROM events e WHERE e.event_timestamp = (SELECT MAX(event_timestamp) FROM events);
WITH RecentEvents AS (SELECT * FROM events WHERE event_timestamp > TIMESTAMP '2023-10-01 00:00:00') SELECT * FROM RecentEvents;
CREATE TABLE temp_records (record_id INT PRIMARY KEY, record_time TIMESTAMP DEFAULT CURRENT_TIMESTAMP);
INSERT INTO temp_records (record_id) VALUES (1), (2), (3);
SELECT record_id, record_time FROM temp_records WHERE record_time BETWEEN TIMESTAMP '2023-10-01 10:00:00' AND CURRENT_TIMESTAMP;
SELECT event_name, COUNT(*) FROM event_logs WHERE log_timestamp > (SELECT MIN(log_timestamp) FROM event_logs) GROUP BY event_id;
DELETE FROM events WHERE event_timestamp < TIMESTAMP '2023-09-30 23:59:59';
SELECT AVG(EXTRACT(SECOND FROM event_timestamp)) AS avg_seconds FROM events;
SELECT DISTINCT EXTRACT(YEAR FROM event_timestamp) AS event_year FROM events ORDER BY event_year DESC;