CREATE TABLE users (id UUID PRIMARY KEY, name VARCHAR(100));
INSERT INTO users VALUES (uuid 'e31960fb-dc8b-452d-ab30-b342723e756a', 'Alice');
INSERT INTO users VALUES (uuid 'a2c5f9a5-4c1b-4e81-8b1e-c3f90f45db35', 'Bob');
SELECT * FROM users WHERE id = uuid 'e31960fb-dc8b-452d-ab30-b342723e756a';
CREATE TABLE orders (order_id INTEGER PRIMARY KEY, user_id UUID, amount DECIMAL);
INSERT INTO orders VALUES (1, uuid 'e31960fb-dc8b-452d-ab30-b342723e756a', 250.00);
INSERT INTO orders VALUES (2, uuid 'a2c5f9a5-4c1b-4e81-8b1e-c3f90f45db35', 150.00);
SELECT u.name, o.amount FROM users u JOIN orders o ON u.id = o.user_id WHERE u.id = uuid 'e31960fb-dc8b-452d-ab30-b342723e756a';
SELECT COUNT(*) FROM orders WHERE user_id = uuid 'a2c5f9a5-4c1b-4e81-8b1e-c3f90f45db35';
CREATE TABLE products (product_id INTEGER PRIMARY KEY, product_uuid UUID, product_name VARCHAR(100));
INSERT INTO products VALUES (1, uuid 'b5b15457-c8e8-4fbd-966f-3d6bdb8aaca4', 'Widget');
INSERT INTO products VALUES (2, uuid 'e0bca5b5-c1a0-4d9e-b5db-ba7da69cbf96', 'Gadget');
SELECT u.name, COUNT(o.order_id) FROM users u LEFT JOIN orders o ON u.id = o.user_id GROUP BY u.id;
SELECT p.product_name, o.amount FROM products p JOIN orders o ON p.product_uuid = o.user_id;