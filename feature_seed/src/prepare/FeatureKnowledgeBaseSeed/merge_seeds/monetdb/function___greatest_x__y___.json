CREATE TABLE test_dates (id INT PRIMARY KEY, event_date DATE);
INSERT INTO test_dates (id, event_date) VALUES (1, DATE '2020-03-22'), (2, DATE '2020-03-25');
SELECT greatest(event_date, DATE '2020-03-23') FROM test_dates;
SELECT greatest(DATE '2020-03-22', DATE '2020-03-25') AS max_date;
SELECT id, greatest(event_date, DATE '2020-03-26') AS max_event_date FROM test_dates;
CREATE TABLE test_numbers (id INT PRIMARY KEY, num1 INT, num2 INT);
INSERT INTO test_numbers (id, num1, num2) VALUES (1, 10, 20), (2, 30, 25);
SELECT id, greatest(num1, num2) FROM test_numbers;
SELECT id, greatest(num1, 15) AS max_num FROM test_numbers WHERE num2 > 20;
SELECT id, greatest((SELECT MAX(event_date) FROM test_dates), DATE '2020-03-24') AS latest_date FROM test_dates;
SELECT id, greatest((SELECT event_date FROM test_dates WHERE id=1), (SELECT event_date FROM test_dates WHERE id=2)) AS max_date FROM test_dates;
SELECT id, (SELECT greatest(num1, num2) FROM test_numbers WHERE id = 1) + 5 AS adjusted_max FROM test_numbers;
SELECT greatest(DATE '2021-01-01', (SELECT MAX(event_date) FROM test_dates)) AS final_max_date;
SELECT greatest(3, greatest(5, 2)) AS nested_greatest;
SELECT (SELECT greatest(num1, num2) FROM test_numbers LIMIT 1) + (SELECT greatest(5, 8) AS max_val) AS combined_max;