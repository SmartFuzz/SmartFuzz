CREATE TABLE test_strings (id INT, str CLOB);
INSERT INTO test_strings VALUES (1, 'abcdefg');
INSERT INTO test_strings VALUES (2, 'hello world');
INSERT INTO test_strings VALUES (3, 'MonetDB is great!');
SELECT substring(str, 1, 3) FROM test_strings WHERE id = 1;
SELECT substring(str, 2, 2) FROM test_strings WHERE id = 2;
SELECT substring(str, 5, 10) FROM test_strings WHERE id = 3;
SELECT substring(str, start, length) FROM (SELECT str, 1 AS start, 3 AS length FROM test_strings WHERE id = 1);
SELECT id, substring(str, 1, length(str)) AS full_string FROM (SELECT *, length(str) AS length FROM test_strings) AS derived;
SELECT substring((SELECT str FROM test_strings WHERE id = 2), 1, 5) AS substring_result;
SELECT A.id, substring(A.str, B.startpos, B.count) FROM test_strings A JOIN (SELECT 1 AS startpos, 4 AS count) B ON A.id = 1;
SELECT id, substring(str, 1, 0) FROM test_strings WHERE id = 1;
SELECT id, substring(str, 5, 5) FROM test_strings WHERE id = 2 UNION SELECT id, substring(str, 1, 4) FROM test_strings WHERE id = 3;
SELECT A.id, substring(A.str, 2, 3) AS substr FROM test_strings A JOIN (SELECT id, str FROM test_strings WHERE id > 1) B ON A.id = B.id;
CREATE TABLE test_substrings AS SELECT id, substring(str, 2, 3) AS sub_str FROM test_strings;
SELECT * FROM test_substrings WHERE sub_str LIKE 'el%';
SELECT COUNT(*) FROM (SELECT substring(str, 2, 2) AS sub FROM test_strings) AS subquery;
SELECT substring('abcdef', -1, 5) AS negative_start_pos;
SELECT id, substring(str, 4, -1) FROM test_strings;
SELECT id, substring(NULL, 1, 2) FROM test_strings;