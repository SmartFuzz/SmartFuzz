CREATE TABLE time_test (id INT PRIMARY KEY, time_string VARCHAR(20), format_string VARCHAR(20));
INSERT INTO time_test VALUES (1, '09:30:49', '%H:%M:%S');
INSERT INTO time_test VALUES (2, '10:15:00', '%H:%M:%S');
INSERT INTO time_test VALUES (3, '23:59:59', '%H:%M:%S');
INSERT INTO time_test VALUES (4, '00:00:00', '%H:%M:%S');
INSERT INTO time_test VALUES (5, '12:34:56', '%H:%M:%S');
SELECT sys.str_to_time(time_string, format_string) FROM time_test;
SELECT id, sys.str_to_time(time_string, format_string) AS parsed_time FROM time_test WHERE id > 2;
SELECT COUNT(*) FROM time_test WHERE sys.str_to_time(time_string, format_string) IS NOT NULL;
SELECT a.id, sys.str_to_time(a.time_string, a.format_string) AS parsed_time FROM time_test a JOIN time_test b ON a.id = b.id WHERE a.time_string != b.time_string;
CREATE TABLE time_zone_test (id INT PRIMARY KEY, tz VARCHAR(10), time_string VARCHAR(20));
INSERT INTO time_zone_test VALUES (1, 'UTC', '09:30:49');
INSERT INTO time_zone_test VALUES (2, 'PST', '10:15:00');
INSERT INTO time_zone_test VALUES (3, 'EST', '23:59:59');
SELECT a.id, sys.str_to_time(CONCAT(a.time_string, ' ', a.tz), '%H:%M:%S %Z') AS parsed_tz_time FROM time_zone_test a;
SELECT MAX(sys.str_to_time(time_string, format_string)) FROM time_test;
SELECT MIN(sys.str_to_time(time_string, format_string)) FROM time_test;
SELECT AVG(EXTRACT(EPOCH FROM sys.str_to_time(time_string, format_string))) FROM time_test;
CREATE VIEW parsed_times AS SELECT id, sys.str_to_time(time_string, format_string) AS parsed_time FROM time_test;
SELECT * FROM parsed_times WHERE parsed_time > '12:00:00';