CREATE TABLE test_strings (s1 VARCHAR(255), s2 VARCHAR(255));
INSERT INTO test_strings VALUES ('abc', 'bc');
INSERT INTO test_strings VALUES ('abcdef', 'def');
INSERT INTO test_strings VALUES ('hello', 'world');
INSERT INTO test_strings VALUES (NULL, 'test');
INSERT INTO test_strings VALUES ('test', NULL);
INSERT INTO test_strings VALUES (NULL, NULL);
SELECT endswith(s1, s2) FROM test_strings;
SELECT endswith('example', 'ple') AS result1, endswith(s1, 'test') AS result2 FROM test_strings;
SELECT endswith('qwerty', s2) FROM test_strings WHERE s1 LIKE 'q%';
SELECT s1, s2 FROM test_strings WHERE endswith(s1, s2) IS TRUE;
SELECT COUNT(*) FROM test_strings WHERE endswith(s1, 'test');
CREATE TABLE additional_strings (id INT, another_string VARCHAR(255));
INSERT INTO additional_strings VALUES (1, 'sample'), (2, 'example');
SELECT t.s1, a.another_string FROM test_strings t JOIN additional_strings a ON endswith(t.s1, a.another_string);
SELECT s1, s2 FROM test_strings WHERE endswith(s1, 'c') OR endswith(s2, 'b');
SELECT s1, endswith(s1, s2) FROM (SELECT s1, s2 FROM test_strings) AS subquery WHERE endswith(s1, s2) IS NOT NULL;