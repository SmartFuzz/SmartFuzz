CREATE TABLE test_table (id INT, name VARCHAR(50));
INSERT INTO test_table VALUES (1, 'test1'), (2, 'test2'), (3, 'test3');
SAVEPOINT sp1;
UPDATE test_table SET name = 'updated1' WHERE id = 1;
RELEASE SAVEPOINT sp1;
SAVEPOINT sp2;
INSERT INTO test_table VALUES (4, 'test4');
RELEASE SAVEPOINT sp2;
SAVEPOINT sp3;
DELETE FROM test_table WHERE id = 2;
RELEASE SAVEPOINT sp3;
SAVEPOINT sp4;
SELECT * FROM test_table WHERE id IN (SELECT id FROM test_table WHERE name LIKE 'test%');
RELEASE SAVEPOINT sp4;
SAVEPOINT sp5;
UPDATE test_table SET name = 'test2_updated' WHERE id = (SELECT MAX(id) FROM test_table);
RELEASE SAVEPOINT sp5;
SAVEPOINT sp6;
RELEASE SAVEPOINT sp6;