CREATE TABLE test_json (data JSON);
INSERT INTO test_json VALUES (json '{"id":2, "nm":"X"}');
SELECT json.keyarray(data) FROM test_json;
CREATE TABLE another_json (data JSON);
INSERT INTO another_json VALUES (json '{"name":"Test", "value":3, "nested":{"key":"value"}}');
SELECT json.keyarray(data) FROM another_json;
INSERT INTO test_json VALUES (json '{"a":1, "b":{"c":2}, "d":[1,2,3]}');
SELECT json.keyarray(data) FROM test_json WHERE data IS NOT NULL;
CREATE TABLE complex_json (id INT, data JSON);
INSERT INTO complex_json VALUES (1, json '{"x":10, "y":{"z":"A"}}');
INSERT INTO complex_json VALUES (2, json '{"alpha":"Beta", "gamma":[5,6]}');
SELECT id, json.keyarray(data) FROM complex_json;
SELECT json.keyarray(data) FROM complex_json WHERE id = 1;
CREATE TABLE user_data (user_id INT, info JSON);
INSERT INTO user_data VALUES (100, json '{"username":"user1", "profile":{"age":25, "active":true}}');
SELECT json.keyarray(info) FROM user_data WHERE user_id = 100;
SELECT json.keyarray(info) FROM user_data WHERE info IS NOT NULL;
CREATE TABLE multi_layer_json (id INT, data JSON);
INSERT INTO multi_layer_json VALUES (1, json '{"level1":{"level2":{"level3":"data"}}}');
SELECT json.keyarray(data) FROM multi_layer_json;
CREATE TABLE mixed_data (id INT, json_data JSON);
INSERT INTO mixed_data VALUES (1, json '{"key": "value", "list": ["item1", "item2"]}');
INSERT INTO mixed_data VALUES (2, json '{"x": [1, 2, 3], "y": {"nested_key": "nested_value"}}');
SELECT json.keyarray(json_data) FROM mixed_data WHERE json_data IS NOT NULL;
SELECT json.keyarray(data) FROM mixed_data WHERE id = 2;
CREATE TABLE nested_json (data JSON);
INSERT INTO nested_json VALUES (json '{"outer":{"inner":{"key":"value"}}}');
SELECT json.keyarray(data) FROM nested_json;
CREATE TABLE json_with_array (id INT, json_data JSON);
INSERT INTO json_with_array VALUES (1, json '{"items":[{"name":"item1"},{"name":"item2"}]}');
SELECT json.keyarray(json_data) FROM json_with_array;
WITH json_subquery AS (SELECT json_array('{"status":"ok", "data":[{"id":1},{"id":2}]}') AS js) SELECT json.keyarray(js) FROM json_subquery;