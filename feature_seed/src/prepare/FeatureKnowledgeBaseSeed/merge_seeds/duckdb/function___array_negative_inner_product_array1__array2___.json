CREATE TABLE test_arrays (array1 FLOAT[], array2 FLOAT[]);
INSERT INTO test_arrays VALUES (array_value(1.0::FLOAT, 2.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT));
INSERT INTO test_arrays VALUES (array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
INSERT INTO test_arrays VALUES (array_value(0.0::FLOAT, 0.0::FLOAT), array_value(3.0::FLOAT, 4.0::FLOAT));
INSERT INTO test_arrays VALUES (array_value(-1.0::FLOAT, 2.0::FLOAT), array_value(2.0::FLOAT, -3.0::FLOAT));
SELECT array_negative_inner_product(array1, array2) FROM test_arrays;
SELECT array_negative_inner_product(array_value(1.0::FLOAT), array_value(2.0::FLOAT)) AS negative_inner_product_1;
SELECT array_negative_inner_product(array_value(5.0::FLOAT, 3.0::FLOAT, 2.0::FLOAT), array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT)) AS negative_inner_product_2;
SELECT (SELECT array_negative_inner_product(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT)) WHERE 1 = 1) AS negative_inner_product_example;
WITH temp_arrays AS (SELECT array_value(1.0::FLOAT, 2.0::FLOAT) AS a1, array_value(2.0::FLOAT, 3.0::FLOAT) AS a2) SELECT array_negative_inner_product(a1, a2) FROM temp_arrays;
CREATE TABLE array_pairs AS SELECT array_value(1.0::FLOAT, 2.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT) UNION SELECT array_value(-1.0::FLOAT, -2.0::FLOAT), array_value(-3.0::FLOAT, -4.0::FLOAT);
SELECT array_negative_inner_product(a1, a2) FROM array_pairs;
CREATE TABLE more_complex_pairs (id INT, a1 FLOAT[], a2 FLOAT[]);
INSERT INTO more_complex_pairs VALUES (1, array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(4.0::FLOAT, 5.0::FLOAT, 6.0::FLOAT)), (2, array_value(-1.0::FLOAT, -2.0::FLOAT, -3.0::FLOAT), array_value(-4.0::FLOAT, -5.0::FLOAT, -6.0::FLOAT));
SELECT id, array_negative_inner_product(a1, a2) AS negative_inner_product FROM more_complex_pairs;
SELECT id FROM more_complex_pairs WHERE array_negative_inner_product(a1, a2) < -10;