CREATE TABLE numbers (n INTEGER);
INSERT INTO numbers VALUES (0), (1), (2), (3), (4), (5), (10);
SELECT n, factorial(n) AS factorial_value FROM numbers;
SELECT (SELECT factorial(n) FROM numbers WHERE n = 5) AS factorial_of_5;
SELECT n, CASE WHEN n < 0 THEN NULL ELSE factorial(n) END AS factorial_value FROM numbers;
SELECT n, factorial(n) FROM (SELECT n FROM numbers WHERE n <= 5) AS subquery;
SELECT a.n, b.n, factorial(a.n) * factorial(b.n) AS multiplied_factorials FROM numbers a JOIN numbers b ON a.n = b.n WHERE a.n < 5;
WITH recursive fact(n, result) AS (SELECT 0, 1 UNION ALL SELECT n + 1, result * (n + 1) FROM fact WHERE n < 4) SELECT n, result FROM fact;
SELECT n, factorial(n) AS factorial_value FROM numbers WHERE n IN (SELECT DISTINCT n FROM numbers WHERE n < 6 ORDER BY n DESC);
SELECT n, factorial(n) AS factorial_value, (SELECT COUNT(*) FROM numbers) AS total_numbers FROM numbers WHERE n >= 0;