CREATE TABLE test_strings (string_value VARCHAR);
INSERT INTO test_strings VALUES ('abc'), ('aBc'), ('ABc'), ('abcd'), ('abEf'), ('A%BCD'), ('%XYZ'), ('%abc'), ('A$%C'), ('A%c$');
SELECT ilike_escape(string_value, 'a%bc', '$') FROM test_strings;
SELECT ilike_escape(string_value, 'A$%C', '$') FROM test_strings WHERE string_value LIKE '%C' OR string_value LIKE '%c';
CREATE TABLE additional_test_strings (like_specifier VARCHAR, escape_character VARCHAR);
INSERT INTO additional_test_strings VALUES ('%ABC%', '$'), ('A_%C', '$'), ('abc%', '%'), ('%abc%c', '$');
SELECT t1.string_value FROM test_strings t1 JOIN additional_test_strings t2 ON ilike_escape(t1.string_value, t2.like_specifier, t2.escape_character);
SELECT COUNT(*) FROM test_strings WHERE ilike_escape(string_value, 'A$c%', '$') AND string_value IS NOT NULL;
SELECT DISTINCT string_value FROM test_strings WHERE ilike_escape(string_value, 'A%BC', '$') AND string_value NOT LIKE '%$';
WITH matching_strings AS (SELECT string_value FROM test_strings WHERE ilike_escape(string_value, '%a%', '$')) SELECT COUNT(*) FROM matching_strings;
SELECT EXISTS (SELECT 1 FROM test_strings WHERE ilike_escape(string_value, 'AB_%D', '$')) AS Exists_AB_D;