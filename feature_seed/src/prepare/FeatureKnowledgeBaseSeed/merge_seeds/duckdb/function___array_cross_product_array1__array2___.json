CREATE TABLE test_arrays (array1 FLOAT[], array2 FLOAT[]);
INSERT INTO test_arrays VALUES (array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
SELECT array_cross_product(array1, array2) FROM test_arrays;
INSERT INTO test_arrays VALUES (array_value(4.0::FLOAT, 5.0::FLOAT, 6.0::FLOAT), array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT));
SELECT array_cross_product(array1, array2) AS cross_product FROM test_arrays WHERE array1[1] > 0.0;
CREATE TABLE another_array (array_a FLOAT[], array_b FLOAT[]);
INSERT INTO another_array VALUES (array_value(0.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT), array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT));
SELECT array_cross_product(array1, array2) FROM test_arrays CROSS JOIN another_array;
SELECT array_cross_product(array_value(1.0::FLOAT, 1.0::FLOAT, 1.0::FLOAT), array_value(1.0::FLOAT, 1.0::FLOAT, 1.0::FLOAT)) AS single_element_case;
SELECT array_cross_product(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(3.0::FLOAT, 2.0::FLOAT, 1.0::FLOAT)) AS reverse_case;
WITH temp AS (SELECT array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT) AS vec1, array_value(3.0::FLOAT, 2.0::FLOAT, 1.0::FLOAT) AS vec2) SELECT array_cross_product(vec1, vec2) FROM temp;
SELECT array_cross_product(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, NULL, 4.0::FLOAT)) AS invalid_case;
CREATE TABLE dynamic_arrays (dynamic_array1 FLOAT[], dynamic_array2 FLOAT[]);
INSERT INTO dynamic_arrays SELECT array_value(rand() % 10::FLOAT, rand() % 10::FLOAT, rand() % 10::FLOAT), array_value(rand() % 10::FLOAT, rand() % 10::FLOAT, rand() % 10::FLOAT) FROM range(1, 10);
SELECT array_cross_product(dynamic_array1, dynamic_array2) FROM dynamic_arrays;
SELECT array_cross_product(array1, array2) FROM (SELECT array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT) AS array1, array_value(3.0::FLOAT, 2.0::FLOAT, 1.0::FLOAT) AS array2) AS subquery;
SELECT array_cross_product(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(0.0::FLOAT, 0.0::FLOAT, [NULL])) AS null_case;