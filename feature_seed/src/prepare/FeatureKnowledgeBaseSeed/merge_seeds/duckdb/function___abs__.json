CREATE TABLE numbers (val FLOAT);
INSERT INTO numbers VALUES (-17.4), (5.2), (-3.14), (0), (42);
SELECT abs(val) FROM numbers;
CREATE TABLE more_numbers (val FLOAT);
INSERT INTO more_numbers VALUES (-100.5), (12.3), (26.7), (-0.1), (-50);
SELECT a.val, b.val, abs(a.val + b.val) AS combined_abs FROM numbers AS a JOIN more_numbers AS b ON a.val < 0 AND b.val > 0;
SELECT abs((SELECT AVG(val) FROM numbers)) AS avg_abs FROM numbers;
CREATE TABLE values_with_null (val FLOAT);
INSERT INTO values_with_null VALUES (NULL), (-14.6), (9.2), (NULL);
SELECT abs(val) FROM values_with_null;
SELECT abs(SUM(val)) FROM values_with_null WHERE val IS NOT NULL;
SELECT abs(20 - (SELECT MAX(val) FROM numbers)) AS distance_from_20;