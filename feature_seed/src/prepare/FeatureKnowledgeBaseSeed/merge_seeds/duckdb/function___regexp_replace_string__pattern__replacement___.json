CREATE TABLE test_strings (input_string VARCHAR, pattern VARCHAR, replacement VARCHAR);
INSERT INTO test_strings VALUES ('hello', '[lo]', '-');
INSERT INTO test_strings VALUES ('world', '[aeiou]', '*');
INSERT INTO test_strings VALUES ('duckdb is cool', 'c+', 'C');
INSERT INTO test_strings VALUES ('abc123', '[0-9]', '');
INSERT INTO test_strings VALUES ('abcd', '[bc]', 'X');
CREATE TABLE result AS SELECT input_string, regexp_replace(input_string, pattern, replacement) AS replaced_string FROM test_strings;
SELECT * FROM result;
SELECT input_string, regexp_replace(input_string, '[l]', '-' ) AS modified FROM test_strings WHERE input_string LIKE '%l%';
SELECT t1.input_string, t2.replaced_string FROM (SELECT input_string, regexp_replace(input_string, '[oe]', '8') AS replaced_string FROM test_strings) t1 JOIN (SELECT input_string, regexp_replace(input_string, '[i]', 'I') AS replaced_string FROM test_strings) t2 ON t1.input_string = t2.input_string;
CREATE TABLE nested_test AS SELECT (SELECT regexp_replace('fine-tuning', '-', '_')) AS replaced;
SELECT * FROM nested_test;
SELECT DISTINCT regexp_replace(input_string, '[^a-z]', '') AS cleaned FROM test_strings WHERE regexp_replace(input_string, '[^a-z]', '') != '';