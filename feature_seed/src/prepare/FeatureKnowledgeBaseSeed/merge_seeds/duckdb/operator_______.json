CREATE TABLE list_data (id INT, number_list LIST<INT>);
INSERT INTO list_data VALUES (1, [1, 2, 3, 4]), (2, [5, 6]), (3, [7, 8, 9, 10]);
SELECT * FROM list_data WHERE number_list @> [3, 4];
SELECT * FROM list_data WHERE number_list @> [5];
SELECT id FROM list_data WHERE number_list @> (SELECT [2, 3] INTERSECT SELECT 2);
CREATE TABLE additional_data (id INT, related_list LIST<INT>);
INSERT INTO additional_data VALUES (1, [3, 4]), (2, [2, 7, 8]);
SELECT ld.id FROM list_data ld JOIN additional_data ad ON ld.number_list @> ad.related_list;
SELECT DISTINCT ld.id FROM list_data ld WHERE EXISTS (SELECT 1 FROM additional_data ad WHERE ld.number_list @> [ad.id, 4]);
SELECT * FROM list_data WHERE number_list @> (SELECT number_list FROM list_data WHERE id = 1);
SELECT count(*) FROM list_data WHERE number_list @> [1, 2] OR number_list @> [7];
CREATE TABLE complex_data (id INT, value_list LIST<INT>);
INSERT INTO complex_data VALUES (1, [1, 2]), (2, [2, 3, 4]), (3, [1, 3]);
SELECT * FROM list_data ld WHERE ld.number_list @> (SELECT value_list FROM complex_data WHERE id = 2);
SELECT (SELECT number_list FROM list_data WHERE id = 1) @> [4, 3];
SELECT * FROM list_data WHERE number_list @> (SELECT array_agg(value_list) FROM complex_data);