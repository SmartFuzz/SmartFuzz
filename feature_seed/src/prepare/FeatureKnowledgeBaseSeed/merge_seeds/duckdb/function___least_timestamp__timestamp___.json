CREATE TABLE timestamps (event_id INT, event_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '1992-09-20 20:38:48'), (2, TIMESTAMP '1992-03-22 01:02:03.1234');
SELECT least(event_time, TIMESTAMP '1995-01-01 00:00:00') FROM timestamps;
SELECT least(TIMESTAMP '2023-01-01 00:00:00', TIMESTAMP '2022-12-31 23:59:59') AS earliest;
WITH temp AS (SELECT TIMESTAMP '2000-01-01 00:00:00' AS time1, TIMESTAMP '1999-01-01 00:00:00' AS time2) SELECT least(time1, time2) FROM temp;
CREATE TABLE more_timestamps (group_id INT, time1 TIMESTAMP, time2 TIMESTAMP);
INSERT INTO more_timestamps VALUES (1, TIMESTAMP '2023-01-01 12:00:00', TIMESTAMP '2022-12-31 18:00:00'), (2, TIMESTAMP '2023-06-01 08:00:00', TIMESTAMP '2023-05-31 23:59:59');
SELECT group_id, least(time1, time2) AS earliest_time FROM more_timestamps WHERE group_id = 1;
SELECT least(TIMESTAMP '1995-01-01 00:00:00', least(TIMESTAMP '1992-09-20 20:38:48', TIMESTAMP '1992-03-22 01:02:03.1234')) AS final_least;
SELECT event_id, least(TIMESTAMP '1990-01-01 00:00:00', LEAST(event_time, TIMESTAMP '2023-01-01 00:00:00')) AS earliest_event FROM timestamps;
CREATE TABLE events (event_id INT);
INSERT INTO events VALUES (1), (2);
SELECT event_id, least(TIMESTAMP '2020-01-01', TIMESTAMP '2019-01-01') AS least_date FROM events;
SELECT least(TIMESTAMP '2022-05-15 10:15:30', TIMESTAMP '2022-05-15 10:15:30.000001'), least(TIMESTAMP '2023-01-01', TIMESTAMP '2022-12-31') FROM timestamps;