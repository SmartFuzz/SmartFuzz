CREATE TABLE numbers (value INT);
INSERT INTO numbers VALUES (1), (2), (3), (4), (5);
SELECT list_reduce(ARRAY(SELECT value FROM numbers), (x, y) -> x + y) AS total_sum;
CREATE TABLE more_numbers (id INT, value INT);
INSERT INTO more_numbers VALUES (1, 10), (2, 20), (3, 30);
SELECT list_reduce(ARRAY(SELECT value FROM more_numbers WHERE id > 1), (x, y) -> x + y) AS partial_sum;
CREATE TABLE nested_numbers (group_id INT, number_value INT);
INSERT INTO nested_numbers VALUES (1, 100), (1, 200), (2, 300);
SELECT group_id, list_reduce(ARRAY(SELECT number_value FROM nested_numbers WHERE group_id = g.group_id), (x, y) -> x + y) AS group_sum FROM (SELECT DISTINCT group_id FROM nested_numbers AS g);
CREATE TABLE join_numbers (id INT, value INT);
INSERT INTO join_numbers VALUES (1, 5), (2, 10);
SELECT n.id, list_reduce(ARRAY(SELECT value FROM join_numbers j WHERE j.id = n.id), (x, y) -> x * y) AS product FROM join_numbers n;
CREATE TABLE additional_numbers (num INT);
INSERT INTO additional_numbers VALUES (9), (16), (25);
SELECT list_reduce(ARRAY(SELECT SQRT(num) FROM additional_numbers), (x, y) -> x + y) AS total_sqrt_sum;
CREATE TABLE complex_numbers (category TEXT, amount INT);
INSERT INTO complex_numbers VALUES ('A', 1), ('A', 2), ('B', 3), ('B', 4);
SELECT category, list_reduce(ARRAY(SELECT amount FROM complex_numbers c WHERE c.category = t.category), (x, y) -> x + y) AS category_total FROM complex_numbers AS t GROUP BY category;