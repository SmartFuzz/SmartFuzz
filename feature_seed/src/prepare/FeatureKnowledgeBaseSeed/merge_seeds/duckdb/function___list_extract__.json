CREATE TABLE test_lists (id INTEGER, values LIST<INTEGER>);
INSERT INTO test_lists VALUES (1, [1, 2, 3]), (2, [4, 5, 6]), (3, [7, 8]);
SELECT values[1] FROM test_lists WHERE id = 1;
SELECT values[2] FROM test_lists WHERE id = 2;
SELECT list_extract(values, 0) FROM test_lists WHERE id = 1;
SELECT list_extract(values, 0) FROM test_lists WHERE id = 3;
SELECT values[0] + values[1] AS sum_values FROM test_lists;
SELECT (SELECT values[1] FROM test_lists WHERE id = 2) + (SELECT values[0] FROM test_lists WHERE id = 1) AS combined_value;
CREATE TABLE test_lists_extra (user_id INTEGER, extra_values LIST<INTEGER>);
INSERT INTO test_lists_extra VALUES (1, [10, 20]), (2, [30, 40, 50]);
SELECT a.id, list_extract(a.values, 1) AS extracted, b.extra_values[2] FROM test_lists a JOIN test_lists_extra b ON a.id = b.user_id;
SELECT list_extract(values, list_extract(values, 1)) FROM test_lists WHERE id = 2;
SELECT list_extract(values, 2) AS third_value FROM test_lists WHERE id = (SELECT MAX(id) FROM test_lists);
SELECT list_extract(values, 3) AS non_existent_value FROM test_lists WHERE id = 1;
SELECT (SELECT COUNT(*) FROM test_lists WHERE list_extract(values, 1) > 3) AS count_greater_than_3;