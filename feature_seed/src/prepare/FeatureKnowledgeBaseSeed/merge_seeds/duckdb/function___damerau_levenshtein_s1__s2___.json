CREATE TABLE test_strings (s1 VARCHAR, s2 VARCHAR);
INSERT INTO test_strings VALUES ('duckdb', 'udckbd'), ('kitten', 'sitting'), ('flaw', 'lawn'), ('intention', 'execution');
SELECT s1, s2, damerau_levenshtein(s1, s2) AS distance FROM test_strings;
CREATE TABLE string_pairs AS SELECT s1, s2 FROM test_strings WHERE damerau_levenshtein(s1, s2) < 3;
SELECT a.s1, a.s2, damerau_levenshtein(a.s1, b.s1) AS distance FROM test_strings a JOIN test_strings b ON a.s1 <> b.s1;
SELECT s1, s2, damerau_levenshtein('abc', s2) AS distance FROM test_strings WHERE length(s2) < 5;
SELECT s1, s2 FROM test_strings WHERE damerau_levenshtein(s1, s2) = (SELECT MAX(damerau_levenshtein(s1, s2)) FROM test_strings);
WITH distances AS (SELECT s1, s2, damerau_levenshtein(s1, s2) AS distance FROM test_strings) SELECT * FROM distances WHERE distance <= 2 ORDER BY distance;
SELECT s1, s2 FROM test_strings ORDER BY damerau_levenshtein(s1, s2) DESC LIMIT 5;
SELECT *, CASE WHEN damerau_levenshtein(s1, s2) < 2 THEN 'Similar' ELSE 'Different' END AS similarity FROM test_strings;