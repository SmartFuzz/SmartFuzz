CREATE TABLE timestamps (event_time TEXT);
INSERT INTO timestamps VALUES ('Wed, 1 January 1992 - 08:38:40 PST'), ('Fri, 15 July 2022 - 20:34:00 UTC');
SELECT strptime(event_time, '%a, %-d %B %Y - %H:%M:%S %Z') AS parsed_time FROM timestamps;
CREATE TABLE events (event_id INT, event_time TEXT);
INSERT INTO events VALUES (1, 'Mon, 5 February 1990 - 10:22:30 GMT'), (2, 'Thu, 12 August 2021 - 16:45:00 UTC');
SELECT e.event_id, strptime(e.event_time, '%a, %-d %B %Y - %H:%M:%S %Z') AS converted_time FROM events e;
SELECT (SELECT strptime(e.event_time, '%a, %-d %B %Y - %H:%M:%S %Z') FROM events e WHERE e.event_id = 1) AS first_event_time;
SELECT e1.event_id, strptime(e1.event_time, '%a, %-d %B %Y - %H:%M:%S %Z') AS event_time, e2.event_id AS related_event_id, strptime(e2.event_time, '%a, %-d %B %Y - %H:%M:%S %Z') AS related_time FROM events e1 JOIN events e2 ON e1.event_id <> e2.event_id;
WITH parsed AS (SELECT strptime(event_time, '%a, %-d %B %Y - %H:%M:%S %Z') AS parsed_time FROM timestamps) SELECT parsed_time FROM parsed WHERE parsed_time IS NOT NULL;
CREATE TABLE parsed_timestamps AS SELECT strptime(event_time, '%a, %-d %B %Y - %H:%M:%S %Z') AS parsed_time FROM timestamps;
SELECT COUNT(*), MIN(parsed_time), MAX(parsed_time) FROM parsed_timestamps;