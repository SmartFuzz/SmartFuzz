CREATE TABLE test_data (id INTEGER, value FLOAT);
INSERT INTO test_data VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, NULL), (5, 50.0);
SELECT variance(value) FROM test_data WHERE value IS NOT NULL;
SELECT variance(value) FROM (SELECT value FROM test_data WHERE value > 15);
SELECT COUNT(id), variance(value) FROM test_data GROUP BY id HAVING COUNT(id) > 1;
CREATE TABLE additional_data (id INTEGER, group_id INTEGER, score FLOAT);
INSERT INTO additional_data VALUES (1, 1, 5.0), (2, 1, 15.0), (3, 2, 25.0);
SELECT a.group_id, variance(a.score) FROM additional_data a JOIN test_data t ON a.id = t.id GROUP BY a.group_id;
WITH temp AS (SELECT value FROM test_data WHERE value IS NOT NULL) SELECT variance(value) FROM temp;
SELECT variance(value) OVER (PARTITION BY id IS NOT NULL) FROM test_data;
SELECT id, variance(value) FROM (SELECT id, value FROM test_data GROUP BY id) AS sub;
SELECT variance(value) FROM (SELECT value FROM test_data WHERE value BETWEEN 10 AND 40) AS filtered_values;
CREATE TABLE edge_case (value FLOAT);
INSERT INTO edge_case VALUES (NULL), (NULL), (NULL);
SELECT variance(value) FROM edge_case;
SELECT variance(value) FROM (SELECT value FROM edge_case) WHERE value IS NOT NULL;