CREATE TABLE test_strings (id INTEGER, example_string VARCHAR);
INSERT INTO test_strings VALUES (1, 'a%c'), (2, 'b%c'), (3, 'a$d'), (4, 'a$b%c'), (5, 'c$%');
SELECT id, not_like_escape(example_string, 'a$%c', '$') AS result FROM test_strings WHERE id IN (1, 3);
SELECT id, not_like_escape(example_string, 'b$%c', '$') AS result FROM test_strings;
CREATE TABLE lookup_patterns (pattern VARCHAR, description VARCHAR);
INSERT INTO lookup_patterns VALUES ('a$b%', 'matches a followed by b and anything'), ('%c', 'ends with c');
SELECT l.pattern, t.id, not_like_escape(t.example_string, l.pattern, '$') AS not_match FROM test_strings t JOIN lookup_patterns l ON l.pattern LIKE '%';
CREATE TABLE additional_strings (id INTEGER, content VARCHAR);
INSERT INTO additional_strings VALUES (1, 'abcd'), (2, 'a$c');
SELECT a.id, not_like_escape(a.content, 'a$b%', '$') AS result FROM additional_strings a WHERE a.id < 3;
SELECT a.id, not_like_escape(a.content, l.pattern, '$') AS result FROM additional_strings a JOIN lookup_patterns l ON a.content LIKE concat('%', l.pattern, '%') WHERE not_like_escape(a.content, l.pattern, '$') = true;
CREATE TABLE complex_test (id INTEGER, pattern VARCHAR, string_to_test VARCHAR);
INSERT INTO complex_test VALUES (1, 'a$%c', 'a%c'), (2, 'a$%c', 'x$%y');
SELECT id, not_like_escape(string_to_test, pattern, '$') AS match_result FROM complex_test;
CREATE TABLE final_test (id INTEGER, test_string VARCHAR, match_pattern VARCHAR);
INSERT INTO final_test VALUES (1, 'hello%', 'h%o'), (2, 'goodbye$', 'g$d'), (3, 'wild$card%', 'w$c%');
SELECT f.test_string, f.match_pattern, not_like_escape(f.test_string, f.match_pattern, '$') AS match_outcome FROM final_test f WHERE f.id > 1;