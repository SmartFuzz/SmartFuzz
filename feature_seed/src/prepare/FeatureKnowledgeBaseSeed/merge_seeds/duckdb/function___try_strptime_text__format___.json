CREATE TABLE test_timestamps (input_text VARCHAR, input_format VARCHAR, expected_result TIMESTAMP);
INSERT INTO test_timestamps VALUES ('Wed, 1 January 1992 - 08:38:40 PM', '%a, %-d %B %Y - %I:%M:%S %p', '1992-01-01 20:38:40'),;
('Invalid date string', '%a, %-d %B %Y - %I:%M:%S %p', NULL),;
('Thu, 29 February 1996 - 05:40:00 AM', '%a, %-d %B %Y - %I:%M:%S %p', '1996-02-29 05:40:00');
SELECT input_text, try_strptime(input_text, input_format) AS parsed_result FROM test_timestamps;
SELECT input_text, expected_result, try_strptime(input_text, input_format) AS parsed_result FROM test_timestamps WHERE expected_result IS NOT NULL;
SELECT input_text, try_strptime(input_text, input_format) AS parsed_result FROM test_timestamps WHERE expected_result IS NULL;
SELECT COUNT(*) FROM test_timestamps WHERE try_strptime(input_text, input_format) IS NULL;
SELECT (SELECT COUNT(*) FROM test_timestamps WHERE expected_result IS NULL) AS failed_cases, (SELECT COUNT(*) FROM test_timestamps) AS total_cases;
CREATE TABLE complex_test AS SELECT t.input_text, t.input_format, try_strptime(t.input_text, t.input_format) AS parsed_result FROM test_timestamps t WHERE t.expected_result IS NOT NULL;
SELECT a.input_text, b.input_format, try_strptime(a.input_text, b.input_format) AS parsed_result FROM test_timestamps a JOIN test_timestamps b ON a.input_text <> b.input_text LIMIT 10;