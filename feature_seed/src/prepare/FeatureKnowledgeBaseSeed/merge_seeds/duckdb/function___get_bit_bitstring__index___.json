CREATE TABLE bitstrings (id INTEGER PRIMARY KEY, data BITSTRING);
INSERT INTO bitstrings VALUES (1, '0110010'::BITSTRING);
INSERT INTO bitstrings VALUES (2, '1101011'::BITSTRING);
INSERT INTO bitstrings VALUES (3, '0000000'::BITSTRING);
INSERT INTO bitstrings VALUES (4, '1111111'::BITSTRING);
SELECT get_bit(data, 0) AS bit_0, get_bit(data, 1) AS bit_1, get_bit(data, 2) AS bit_2 FROM bitstrings;
SELECT id, get_bit(data, 3) FROM bitstrings WHERE id = 2;
SELECT id, get_bit(data, 6) AS last_bit FROM bitstrings WHERE id IN (SELECT id FROM bitstrings WHERE get_bit(data, 5) = 1);
SELECT b1.id, get_bit(b1.data, 2) AS second_bit, b2.data FROM bitstrings b1 JOIN bitstrings b2 ON get_bit(b1.data, 1) = get_bit(b2.data, 1);
SELECT id, get_bit(data, 4) FROM bitstrings WHERE get_bit(data, 0) = 1 AND get_bit(data, 6) = 0;
CREATE TABLE bit_operations AS SELECT id, get_bit(data, 1) AS bit_1, get_bit(data, 2) AS bit_2 FROM bitstrings;
SELECT COUNT(*) FROM bit_operations WHERE bit_1 = 1;
SELECT id, get_bit(data, 7) FROM bitstrings WHERE NOT EXISTS (SELECT 1 FROM bitstrings AS b WHERE get_bit(b.data, 6) = 1 AND b.id = bitstrings.id);
SELECT get_bit(data, 0) FROM bitstrings ORDER BY id;
SELECT MAX(get_bit(data, 3)) FROM bitstrings;
SELECT COUNT(*) FROM bitstrings WHERE get_bit(data, 5) = 1 AND get_bit(data, 6) = 0;