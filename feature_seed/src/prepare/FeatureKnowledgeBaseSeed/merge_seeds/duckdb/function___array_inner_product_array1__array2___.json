CREATE TABLE test_arrays (id INT, array1 FLOAT[], array2 FLOAT[]);
INSERT INTO test_arrays VALUES (1, array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT));
INSERT INTO test_arrays VALUES (2, array_value(0.0::FLOAT, 0.0::FLOAT, 0.0::FLOAT), array_value(3.0::FLOAT, 4.0::FLOAT, 5.0::FLOAT));
INSERT INTO test_arrays VALUES (3, array_value(-1.0::FLOAT, -2.0::FLOAT), array_value(-3.0::FLOAT, -4.0::FLOAT));
INSERT INTO test_arrays VALUES (4, array_value(1.5::FLOAT, 2.5::FLOAT, 3.5::FLOAT, 4.5::FLOAT), array_value(2.5::FLOAT, 3.5::FLOAT, 4.5::FLOAT, 5.5::FLOAT));
SELECT id, array_inner_product(array1, array2) AS inner_product FROM test_arrays WHERE id IN (1, 2, 3);
SELECT id, array_inner_product(array1, array2) AS inner_product FROM (SELECT id, array_value(1.0, 2.0, 3.0) AS array1, array_value(2.0, 3.0, 4.0) AS array2 FROM test_arrays) AS subquery;
SELECT array_inner_product(array_value(1.0::FLOAT, 4.0::FLOAT), array_value(2.0::FLOAT, -1.0::FLOAT)) AS inner_product;
SELECT SUM(array_inner_product(array1, array2)) AS total_inner_product FROM (SELECT array_value(1.0::FLOAT, 2.0::FLOAT) AS array1, array_value(2.0::FLOAT, 3.0::FLOAT) AS array2) AS temp;
SELECT t1.id, array_inner_product(t1.array1, t2.array2) AS inner_product FROM test_arrays t1 JOIN test_arrays t2 ON t1.id = t2.id WHERE t1.id < 3;
SELECT array_inner_product(array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT, NULL), array_value(2.0::FLOAT, 3.0::FLOAT, 4.0::FLOAT, 5.0::FLOAT));