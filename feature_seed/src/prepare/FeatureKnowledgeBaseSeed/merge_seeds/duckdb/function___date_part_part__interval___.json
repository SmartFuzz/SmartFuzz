CREATE TABLE intervals (duration INTERVAL);
INSERT INTO intervals VALUES (INTERVAL '1 year'), (INTERVAL '6 months'), (INTERVAL '3 days'), (INTERVAL '14 months'), (INTERVAL '2 years'), (INTERVAL '732 days');
SELECT date_part('year', duration) FROM intervals;
SELECT date_part('month', duration) FROM intervals WHERE duration IS NOT NULL;
SELECT date_part('day', INTERVAL '0 days'), date_part('hour', INTERVAL '14 months 2 days 5 hours') FROM intervals;
CREATE TABLE events (event_id INT, event_interval INTERVAL);
INSERT INTO events VALUES (1, INTERVAL '1 year'), (2, INTERVAL '2 years'), (3, INTERVAL '5 months');
SELECT e.event_id, date_part('year', e.event_interval) AS event_year FROM events e JOIN intervals i ON date_part('month', i.duration) = 1 WHERE i.duration IS NOT NULL;
SELECT (SELECT date_part('month', INTERVAL '1 year 1 month') + COUNT(*) FROM intervals) AS total_months FROM intervals;
SELECT date_part('day', MIN(duration)) AS min_days FROM intervals WHERE duration IS NOT NULL;
SELECT date_part('year', INTERVAL '4 years') + date_part('month', INTERVAL '6 months') AS total_years FROM intervals;