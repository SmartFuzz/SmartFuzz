CREATE TABLE events (event_time TIMESTAMPTZ, event_name VARCHAR);
INSERT INTO events VALUES (TIMESTAMPTZ '1992-04-20 15:26:00-07', 'Event A');
INSERT INTO events VALUES (TIMESTAMPTZ '1992-04-21 15:26:00-07', 'Event B');
INSERT INTO events VALUES (TIMESTAMPTZ '1992-04-22 15:26:00-07', 'Event C');
SELECT time_bucket(INTERVAL '1 day', event_time, 'Europe/Berlin') AS bucket, COUNT(event_name) AS event_count FROM events GROUP BY bucket ORDER BY bucket;
SELECT time_bucket(INTERVAL '2 days', event_time, 'America/New_York') AS bucket, SUM(CASE WHEN event_name = 'Event A' THEN 1 ELSE 0 END) AS event_a_count FROM events GROUP BY bucket;
WITH event_buckets AS (SELECT time_bucket(INTERVAL '5 hours', event_time, 'UTC') AS bucket, event_name FROM events) SELECT bucket, ARRAY_AGG(event_name) AS event_names FROM event_buckets GROUP BY bucket ORDER BY bucket;
CREATE TABLE event_analysis AS SELECT time_bucket(INTERVAL '2 days', event_time, 'Asia/Tokyo') AS bucket, COUNT(*) AS total_events FROM events GROUP BY bucket;
SELECT eb.bucket, eb.total_events, e.event_name FROM event_analysis eb LEFT JOIN events e ON eb.bucket = time_bucket(INTERVAL '2 days', e.event_time, 'Asia/Tokyo') ORDER BY eb.bucket;
SELECT time_bucket(INTERVAL '1 month', TIMESTAMPTZ '2022-03-15 12:00:00+00', 'UTC') AS monthly_bucket;
SELECT time_bucket(INTERVAL '1 hour', event_time, 'Europe/London') AS hourly_bucket, COUNT(*) FROM events GROUP BY hourly_bucket HAVING COUNT(*) > 1;