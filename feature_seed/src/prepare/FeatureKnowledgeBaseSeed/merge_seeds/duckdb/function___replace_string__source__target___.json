CREATE TABLE test_strings (id INTEGER, original_string VARCHAR);
INSERT INTO test_strings VALUES (1, 'hello'), (2, 'lighthouse'), (3, 'balloon'), (4, 'hello world'), (5, 'duckdb');
SELECT replace(original_string, 'l', '-') FROM test_strings;
SELECT id, replace(original_string, 'hello', 'hi') AS modified_string FROM test_strings WHERE original_string LIKE '%hello%';
SELECT id, replace(original_string, 'o', '0') AS modified_string FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE original_string LIKE '%o%');
CREATE TABLE more_strings (id INTEGER, additional_string VARCHAR);
INSERT INTO more_strings VALUES (1, 'hello'), (2, 'goodbye'), (3, 'hello there');
SELECT t1.id, replace(t1.original_string, 'l', '-') AS modified_string, t2.additional_string FROM test_strings t1 JOIN more_strings t2 ON t1.id = t2.id WHERE t1.original_string LIKE 'hello%';
SELECT id, replace(replace(original_string, 'l', '-'), 'o', '0') AS modified_string FROM test_strings;
WITH replaced AS (SELECT id, replace(original_string, 'o', '0') AS modified_string FROM test_strings) SELECT id, modified_string FROM replaced WHERE modified_string LIKE '%0%';
SELECT id, original_string, replace(original_string, 'l', '-') AS modified_string FROM test_strings WHERE LENGTH(original_string) > 4;
SELECT id, replace((SELECT original_string FROM test_strings WHERE id = 1), 'l', '-') AS modified_string;