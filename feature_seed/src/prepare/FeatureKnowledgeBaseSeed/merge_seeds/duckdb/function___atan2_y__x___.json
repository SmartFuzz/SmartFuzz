CREATE TABLE test_atan2 (y FLOAT, x FLOAT);
INSERT INTO test_atan2 VALUES (0.5, 0.5);
INSERT INTO test_atan2 VALUES (1, 1);
INSERT INTO test_atan2 VALUES (-1, -1);
INSERT INTO test_atan2 VALUES (-1, 1);
INSERT INTO test_atan2 VALUES (1, -1);
INSERT INTO test_atan2 VALUES (0, 0);
SELECT atan2(y, x) FROM test_atan2;
SELECT atan2((SELECT AVG(y) FROM test_atan2), (SELECT AVG(x) FROM test_atan2)) AS avg_angle;
WITH angle_calculations AS (SELECT y, x, atan2(y, x) AS angle FROM test_atan2) SELECT * FROM angle_calculations WHERE angle > 0;
SELECT t1.y, t1.x, atan2(t1.y, t2.x) FROM test_atan2 t1 JOIN test_atan2 t2 ON t1.y = t2.x WHERE t1.x > 0;
SELECT DISTINCT atan2(y, x) OVER (PARTITION BY CASE WHEN x > 0 THEN 1 ELSE 0 END) FROM test_atan2;
CREATE TABLE additional_values (val FLOAT);
INSERT INTO additional_values VALUES (0.0), (2.0), (-2.0);
SELECT atan2(t.y, a.val) FROM test_atan2 t JOIN additional_values a ON t.x = a.val WHERE a.val != 0;