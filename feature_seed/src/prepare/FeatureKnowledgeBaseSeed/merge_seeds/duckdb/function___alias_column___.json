CREATE TABLE employees (id INTEGER, name VARCHAR, department VARCHAR);
CREATE TABLE sales (id INTEGER, employee_id INTEGER, amount DECIMAL);
INSERT INTO employees VALUES (1, 'Alice', 'Sales'), (2, 'Bob', 'Engineering'), (3, 'Charlie', 'Sales');
INSERT INTO sales VALUES (1, 1, 100.00), (2, 2, 200.00), (3, 3, 150.50);
SELECT alias(name) FROM employees;
SELECT alias(AVG(amount)) AS average_sales FROM sales GROUP BY employee_id;
SELECT e.name AS employee_name, s.amount AS sale_amount FROM employees e JOIN sales s ON e.id = s.employee_id WHERE s.amount > 100;
SELECT e.name AS employee_name, (SELECT SUM(amount) FROM sales WHERE employee_id = e.id) AS total_sales FROM employees e;
SELECT alias(e.name) FROM employees e WHERE e.department IN (SELECT department FROM employees WHERE name = 'Alice');
SELECT e.name AS employee_name, COUNT(s.id) AS sale_count FROM employees e LEFT JOIN sales s ON e.id = s.employee_id GROUP BY e.name HAVING sale_count > 0;
SELECT alias(s.amount) FROM sales s WHERE s.amount > (SELECT AVG(amount) FROM sales);