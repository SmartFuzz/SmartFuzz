CREATE TABLE test_table (id INTEGER, value INTEGER);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 30), (4, 40);
SELECT max(value) FROM test_table;
CREATE TABLE test_table2 (id INTEGER, value INTEGER);
INSERT INTO test_table2 VALUES (1, 15), (2, 25), (3, 35), (4, 5);
SELECT max(t1.value) FROM test_table t1 JOIN test_table2 t2 ON t1.id = t2.id;
SELECT max(value) FROM test_table WHERE id IN (SELECT id FROM test_table2 WHERE value > 10);
CREATE TABLE nested_table (group_id INTEGER, subgroup_id INTEGER, value INTEGER);
INSERT INTO nested_table VALUES (1, 1, 5), (1, 2, 15), (2, 1, 25), (2, 2, 10);
SELECT group_id, max(value) FROM nested_table GROUP BY group_id;
SELECT max(value) FROM (SELECT value FROM test_table UNION ALL SELECT value FROM test_table2) AS combined;
CREATE TABLE empty_table (value INTEGER);
SELECT max(value) FROM empty_table;
SELECT max(value) FROM (SELECT value FROM test_table WHERE value IS NOT NULL) AS non_null_values;
SELECT id, max(value) FROM test_table GROUP BY id HAVING max(value) > 20;