CREATE TABLE test_table1 (id INT, list1 ARRAY<INT>, list2 ARRAY<INT>);
INSERT INTO test_table1 VALUES (1, [1, 2, 3], [2, 3, 4]);
INSERT INTO test_table1 VALUES (2, [5, 6, 7], [8, 9]);
INSERT INTO test_table1 VALUES (3, [], [1, 2]);
INSERT INTO test_table1 VALUES (4, [1, 4], []);
INSERT INTO test_table1 VALUES (5, [10, 20], [30, 40]);
SELECT id, array_has_any(list1, list2) AS any_match FROM test_table1;
SELECT id FROM test_table1 WHERE array_has_any(list1, list2) = TRUE;
WITH temp AS (SELECT list1, list2 FROM test_table1 WHERE id = 1) SELECT array_has_any(list1, list2) FROM temp;
SELECT t1.id FROM test_table1 t1 JOIN test_table1 t2 ON array_has_any(t1.list1, t2.list2) WHERE t1.id != t2.id;
CREATE TABLE test_table2 (id INT PRIMARY KEY, list1 ARRAY<INT>, list2 ARRAY<INT>);
INSERT INTO test_table2 SELECT id, list1, list2 FROM test_table1;
SELECT array_has_any(list1, list2) FROM test_table2 WHERE id IN (SELECT id FROM test_table1 WHERE id >= 3);
SELECT array_has_any([1, 2], [2, 3, 4]) AS test_case;
SELECT array_has_any(list1, []) AS empty_list_check FROM test_table1;
SELECT array_has_any([], list2) AS other_empty_check FROM test_table1;