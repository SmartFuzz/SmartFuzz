CREATE TABLE test_map (id INTEGER, data MAP(INTEGER, INTEGER));
INSERT INTO test_map VALUES (1, map([1, 2], [10, 20]));
INSERT INTO test_map VALUES (2, map([3, 4, 5], [30, 40, 50]));
INSERT INTO test_map VALUES (3, map([], []));
INSERT INTO test_map VALUES (4, map([6], [60]));
INSERT INTO test_map VALUES (5, NULL);
SELECT map_keys(data) FROM test_map WHERE id = 1;
SELECT map_keys(data) FROM test_map WHERE id = 2;
SELECT map_keys(data) FROM test_map WHERE id = 3;
SELECT map_keys(data) FROM test_map WHERE id = 4;
SELECT map_keys(data) AS keys FROM test_map WHERE data IS NOT NULL;
SELECT id, map_keys(data) AS keys FROM test_map WHERE data IS NOT NULL ORDER BY id;
SELECT DISTINCT unnest(map_keys(data)) AS unique_keys FROM test_map WHERE data IS NOT NULL;
WITH data_keys AS (SELECT id, map_keys(data) AS keys FROM test_map WHERE data IS NOT NULL) SELECT id, keys FROM data_keys WHERE id IN (SELECT id FROM test_map WHERE id > 1);
SELECT id, map_keys(data) AS keys FROM test_map WHERE data IS NOT NULL UNION SELECT id, map_keys(data) FROM test_map WHERE data IS NULL;