CREATE TABLE test_table (A INTEGER, B INTEGER);
INSERT INTO test_table VALUES (1, 100), (2, 200), (3, 50), (4, 20), (5, 300);
SELECT argMin(A, B, 2) FROM test_table;
SELECT argMin(A, B, 1) FROM test_table;
SELECT argMin(A, B, 10) FROM test_table;
SELECT argMin(A, B, 0) FROM test_table;
CREATE TABLE another_table (C INTEGER);
INSERT INTO another_table VALUES (1), (2);
SELECT argMin(t.A, t.B, 2) FROM test_table t JOIN another_table a ON t.A = a.C;
SELECT argMin(t.A, t.B, 2) FROM (SELECT A, B FROM test_table WHERE B < 250) t;
SELECT argMin(A, B, 2) FROM (SELECT A, B FROM test_table ORDER BY B DESC) AS subquery;
CREATE TABLE nested_table (D INTEGER, E INTEGER);
INSERT INTO nested_table VALUES (10, 1000), (20, 2000), (30, 500), (40, 200);
SELECT argMin(D, E, 2) FROM (SELECT D, E FROM test_table t JOIN nested_table n ON t.A = n.D) AS joined;
SELECT argMin(A, B, 2) FROM (SELECT A, B FROM test_table WHERE B IN (SELECT E FROM nested_table)) t;