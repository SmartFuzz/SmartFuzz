CREATE TABLE test_dates (id INT, date_col DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-02-15');
INSERT INTO test_dates VALUES (2, DATE '2023-01-01');
INSERT INTO test_dates VALUES (3, DATE '2023-12-31');
INSERT INTO test_dates VALUES (4, DATE '2024-04-01');
SELECT id, date_col, week(date_col) AS iso_week FROM test_dates;
SELECT id, date_col, week(date_col) AS iso_week FROM test_dates WHERE date_col >= DATE '1992-01-01';
SELECT id, date_col, week(date_col) AS iso_week FROM test_dates WHERE week(date_col) BETWEEN 1 AND 52;
CREATE TABLE additional_dates (id INT, date_col DATE);
INSERT INTO additional_dates VALUES (1, DATE '2023-02-11'), (2, DATE '2023-02-12');
SELECT td.id, td.date_col, week(td.date_col) AS iso_week, ad.date_col AS additional_date FROM test_dates td JOIN additional_dates ad ON week(td.date_col) = week(ad.date_col);
SELECT id, date_col, week(date_col) AS iso_week, COUNT(*) OVER (PARTITION BY week(date_col)) AS count_per_week FROM test_dates;
SELECT id, date_col, week(date_col) AS iso_week FROM (SELECT * FROM test_dates WHERE date_col < DATE '2024-01-01') AS filtered_dates;
CREATE TABLE month_dates (id INT, month_col INT);
INSERT INTO month_dates VALUES (1, 2), (2, 3), (3, 12);
SELECT td.id, td.date_col, md.month_col, week(td.date_col) AS iso_week FROM test_dates td JOIN month_dates md ON md.month_col = EXTRACT(MONTH FROM td.date_col);