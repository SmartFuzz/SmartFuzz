CREATE TABLE events (event_name VARCHAR, event_time TIMESTAMPTZ);
INSERT INTO events VALUES ('Conference', TIMESTAMPTZ '2023-10-10 14:23:00');
INSERT INTO events VALUES ('Meeting', TIMESTAMPTZ '2023-10-10 16:47:30');
SELECT event_name, datetrunc('hour', event_time) AS truncated_event_time FROM events;
SELECT event_name, datetrunc('day', event_time) AS truncated_event_time FROM events WHERE event_time < TIMESTAMPTZ '2023-10-11 00:00:00';
CREATE TABLE user_activity (user_id INT, activity_time TIMESTAMPTZ);
INSERT INTO user_activity VALUES (101, TIMESTAMPTZ '2023-10-01 08:15:00'), (102, TIMESTAMPTZ '2023-10-01 09:45:15');
SELECT ua.user_id, datetrunc('minute', ua.activity_time) AS truncated_activity_time FROM user_activity ua JOIN events e ON ua.user_id = e.event_name WHERE e.event_time IS NOT NULL;
SELECT COUNT(*) AS activity_count, datetrunc('month', activity_time) AS activity_month FROM user_activity GROUP BY activity_month ORDER BY activity_month DESC;
SELECT e.event_name, datetrunc('week', e.event_time) AS truncated_event_week, COUNT(ua.user_id) AS participants FROM events e LEFT JOIN user_activity ua ON datetrunc('day', e.event_time) = datetrunc('day', ua.activity_time) GROUP BY e.event_name, truncated_event_week;
CREATE TABLE logs (log_id SERIAL PRIMARY KEY, log_time TIMESTAMPTZ NOT NULL DEFAULT CURRENT_TIMESTAMP);
INSERT INTO logs (log_time) VALUES (TIMESTAMPTZ '2023-10-15 12:00:00'), (TIMESTAMPTZ '2023-10-16 12:30:00');
SELECT log_id, datetrunc('second', log_time) AS truncated_log_time FROM logs WHERE log_time >= TIMESTAMPTZ '2023-10-15 00:00:00' AND log_time < TIMESTAMPTZ '2023-10-17 00:00:00';