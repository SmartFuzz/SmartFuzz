CREATE TABLE test_bool_and (id INT, value BOOLEAN);
INSERT INTO test_bool_and VALUES (1, TRUE);
INSERT INTO test_bool_and VALUES (2, TRUE);
INSERT INTO test_bool_and VALUES (3, FALSE);
SELECT bool_and(value) FROM test_bool_and;
CREATE TABLE test_nested (id INT, group_id INT, value BOOLEAN);
INSERT INTO test_nested VALUES (1, 1, TRUE);
INSERT INTO test_nested VALUES (2, 1, TRUE);
INSERT INTO test_nested VALUES (3, 2, TRUE);
INSERT INTO test_nested VALUES (4, 2, FALSE);
SELECT group_id, bool_and(value) FROM test_nested GROUP BY group_id;
CREATE TABLE t1 (id INT, value1 BOOLEAN);
CREATE TABLE t2 (id INT, value2 BOOLEAN);
INSERT INTO t1 VALUES (1, TRUE);
INSERT INTO t1 VALUES (2, FALSE);
INSERT INTO t2 VALUES (1, TRUE);
INSERT INTO t2 VALUES (2, TRUE);
SELECT bool_and(t1.value1) FROM t1 JOIN t2 ON t1.id = t2.id;
SELECT bool_and(value1) OVER (PARTITION BY id) FROM t1;
SELECT bool_and(value) FROM (SELECT value FROM test_bool_and WHERE id IN (1, 2, 3));
SELECT bool_and((SELECT value FROM test_nested WHERE group_id = 1)) FROM test_nested;