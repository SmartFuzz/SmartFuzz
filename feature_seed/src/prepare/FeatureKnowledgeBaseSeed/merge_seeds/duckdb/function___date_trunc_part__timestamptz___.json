CREATE TABLE events (event_id INT, event_time TIMESTAMPTZ);
INSERT INTO events VALUES (1, TIMESTAMPTZ '1992-09-20 20:38:40+00'), (2, TIMESTAMPTZ '1992-09-20 20:50:40+00');
SELECT event_id, date_trunc('hour', event_time) AS truncated_time FROM events;
CREATE TABLE users (user_id INT, registration_time TIMESTAMPTZ);
INSERT INTO users VALUES (1, TIMESTAMPTZ '1992-09-20 19:30:00+00'), (2, TIMESTAMPTZ '1992-09-20 21:00:00+00');
SELECT u.user_id, date_trunc('minute', u.registration_time) AS truncated_registration FROM users u JOIN events e ON u.user_id = e.event_id;
SELECT event_id, date_trunc('day', date_trunc('hour', event_time)) AS truncated_event_time FROM events WHERE event_time >= TIMESTAMPTZ '1992-09-20 20:00:00+00';
SELECT COUNT(*), date_trunc('day', event_time) AS event_date FROM events GROUP BY event_date HAVING COUNT(*) > 1;
WITH truncated AS (SELECT event_id, date_trunc('month', event_time) AS truncated_time FROM events) SELECT truncated_time, COUNT(*) FROM truncated GROUP BY truncated_time;
SELECT e.event_id, date_trunc('second', e.event_time) AS truncated_event_time, u.registration_time FROM events e LEFT JOIN users u ON e.event_id = u.user_id WHERE e.event_time < TIMESTAMPTZ '1992-09-20 21:00:00+00';
SELECT DISTINCT date_trunc('week', event_time) AS event_week FROM events WHERE event_time IS NOT NULL;