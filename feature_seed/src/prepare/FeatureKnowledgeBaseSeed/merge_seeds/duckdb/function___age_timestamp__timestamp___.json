CREATE TABLE timestamps (start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO timestamps VALUES (TIMESTAMP '2001-04-10', TIMESTAMP '1992-09-20');
SELECT age(start_time, end_time) AS time_difference FROM timestamps;
SELECT start_time, end_time, age(end_time, start_time) AS age_diff FROM timestamps WHERE age(end_time, start_time) > INTERVAL '0 years';
CREATE TABLE events (event_id INT, event_time TIMESTAMP);
INSERT INTO events VALUES (1, TIMESTAMP '2010-05-15'), (2, TIMESTAMP '2015-09-30');
SELECT e.event_id, age(e.event_time, t.start_time) AS age_at_start FROM events e JOIN timestamps t ON e.event_time > t.start_time;
SELECT e.event_id, age(e.event_time, t.end_time) AS age_at_end FROM events e INNER JOIN timestamps t ON e.event_time < t.end_time;
WITH age_data AS (SELECT age(start_time, end_time) AS age_diff FROM timestamps) SELECT * FROM age_data WHERE age_diff < INTERVAL '15 years';
SELECT age(TIMESTAMP '2023-01-01 12:00:00', TIMESTAMP '2023-01-01 12:00:00') AS zero_age;
SELECT age(TIMESTAMP '2000-01-01', TIMESTAMP '1999-12-31') AS one_day_difference, age(TIMESTAMP '2000-01-01', TIMESTAMP '2000-01-02') AS negative_one_day_difference;
CREATE TABLE boundary_test (time_a TIMESTAMP, time_b TIMESTAMP);
INSERT INTO boundary_test VALUES (TIMESTAMP '1970-01-01', TIMESTAMP '2099-12-31');
SELECT age(time_b, time_a) AS boundary_diff FROM boundary_test;
SELECT age(TIMESTAMP '2000-02-29', TIMESTAMP '2000-02-28') AS leap_year_difference;
SELECT age(TIMESTAMP '2023-10-01 00:00:00', TIMESTAMP '2023-10-02 00:00:00') AS one_day_difference_including_time;