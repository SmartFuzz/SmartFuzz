CREATE TABLE test_strings (id INT, str_value VARCHAR);
INSERT INTO test_strings VALUES (1, '    test  ');
INSERT INTO test_strings VALUES (2, '   example   ');
INSERT INTO test_strings VALUES (3, '    whitespace    ');
INSERT INTO test_strings VALUES (4, 'noSpaces');
INSERT INTO test_strings VALUES (5, '   ');
INSERT INTO test_strings VALUES (6, '  mixed spaces   and tabs	');
SELECT id, trim(str_value) AS trimmed_value FROM test_strings;
SELECT id FROM test_strings WHERE trim(str_value) = 'test';
SELECT id, trim(str_value), LENGTH(trim(str_value)) AS trimmed_length FROM test_strings;
CREATE TABLE additional_strings (id INT, str_value VARCHAR);
INSERT INTO additional_strings VALUES (1, '    nested  query  ');
INSERT INTO additional_strings VALUES (2, '   join test  ');
SELECT a.id, trim(a.str_value) AS trimmed_a, trim(b.str_value) AS trimmed_b FROM test_strings AS a JOIN additional_strings AS b ON a.id = b.id;
SELECT trim(CONCAT(a.str_value, ' ', b.str_value)) AS combined_trimmed FROM test_strings AS a CROSS JOIN additional_strings AS b;
SELECT trim(subquery.str_value) FROM (SELECT str_value FROM test_strings WHERE id = 1) AS subquery;
SELECT id FROM test_strings WHERE trim(str_value) LIKE 'example';
SELECT str_value, CASE WHEN trim(str_value) = '' THEN 'Empty' ELSE 'Not empty' END AS trim_status FROM test_strings;
SELECT id, trim(CONCAT('    ', str_value, '    ')) AS detailed_trimmed_value FROM test_strings;