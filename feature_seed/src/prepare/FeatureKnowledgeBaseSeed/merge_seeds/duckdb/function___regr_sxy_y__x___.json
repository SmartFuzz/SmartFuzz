CREATE TABLE data_points (id INTEGER, x FLOAT, y FLOAT);
INSERT INTO data_points VALUES (1, 10.0, 20.0), (2, 20.0, 30.0), (3, 30.0, 50.0), (4, 40.0, 80.0);
SELECT regr_sxy(y, x) FROM data_points;
CREATE TABLE more_data (id INTEGER, x FLOAT, y FLOAT);
INSERT INTO more_data VALUES (1, 15.0, 25.0), (2, 45.0, 75.0);
SELECT regr_sxy(d.y, d.x) FROM data_points AS d JOIN more_data AS m ON d.id = m.id;
WITH aggregated AS (SELECT AVG(x) AS avg_x, AVG(y) AS avg_y FROM data_points) SELECT regr_sxy(avg_y, avg_x) FROM aggregated;
SELECT regr_sxy(y, x) FROM (SELECT x, y FROM data_points WHERE y IS NOT NULL) AS subquery;
CREATE TABLE empty_data (x FLOAT, y FLOAT);
SELECT regr_sxy(y, x) FROM empty_data;
SELECT regr_sxy(y, x) FROM (SELECT * FROM data_points WHERE x < 50) AS filtered_data;
SELECT d.id, regr_sxy(y, x) OVER (PARTITION BY d.id) AS regression FROM data_points AS d;