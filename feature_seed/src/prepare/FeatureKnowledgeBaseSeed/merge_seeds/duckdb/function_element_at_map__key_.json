CREATE TABLE test_map (id INTEGER, my_map MAP<INTEGER, INTEGER>);
INSERT INTO test_map VALUES (1, map([100, 200], [42, 43]));
INSERT INTO test_map VALUES (2, map([100, 300], [42, 44]));
SELECT element_at(my_map, 100) FROM test_map WHERE id = 1;
SELECT element_at(my_map, 200) FROM test_map WHERE id = 1;
SELECT element_at(my_map, 300) FROM test_map WHERE id = 2;
SELECT element_at(my_map, 400) FROM test_map WHERE id = 1;
SELECT id, element_at(my_map, 100) AS value FROM test_map WHERE id IN (SELECT id FROM test_map WHERE id > 0);
SELECT t.id, element_at(t.my_map, 100) AS value FROM test_map t JOIN (SELECT id FROM test_map WHERE id < 3) sub ON t.id = sub.id;
SELECT element_at(map(ARRAY[1, 2, 3], ARRAY['a', 'b', 'c']), 1);
SELECT CASE WHEN element_at(my_map, 100) IS NOT NULL THEN 'Key exists' ELSE 'Key does not exist' END AS key_status FROM test_map WHERE id = 1;