CREATE VIEW view1 AS SELECT * FROM tbl;
CREATE OR REPLACE VIEW view1 AS SELECT 42;
CREATE VIEW view1 (a) AS SELECT 42;
CREATE VIEW view2 AS SELECT col1, col2 FROM table1 WHERE col3 = (SELECT MAX(col3) FROM table2);
CREATE OR REPLACE VIEW view3 AS SELECT a.col1, b.col2 FROM table1 a JOIN table2 b ON a.id = b.id;
CREATE VIEW view4 AS SELECT AVG(price) AS avg_price FROM sales WHERE region = 'North';
CREATE VIEW view5 AS SELECT * FROM (SELECT * FROM tbl1 UNION SELECT * FROM tbl2) AS combined;
CREATE OR REPLACE VIEW view6 AS SELECT COUNT(*) AS total_count FROM table3 WHERE status = 'active';
CREATE VIEW view7 AS SELECT customer_id, SUM(amount) AS total_spent FROM transactions GROUP BY customer_id;
CREATE VIEW view8 AS SELECT id, (SELECT COUNT(*) FROM orders WHERE customer_id = customers.id) AS order_count FROM customers;
CREATE VIEW view9 AS SELECT DISTINCT product_id FROM order_items WHERE quantity > 5;
CREATE VIEW view10 AS SELECT t1.column1, t2.column2 FROM table1 t1 LEFT JOIN table2 t2 ON t1.id = t2.id WHERE t1.active = true;
CREATE OR REPLACE VIEW view11 AS SELECT * FROM (SELECT * FROM orders WHERE created_at >= DATE '2023-01-01') AS recent_orders;
CREATE VIEW view12 AS SELECT employee_id, MAX(salary) AS max_salary FROM employees GROUP BY employee_id HAVING MAX(salary) > 100000;
SELECT sql FROM duckdb_views() WHERE view_name = 'view1';
SELECT sql FROM duckdb_views() WHERE view_name = 'view2';