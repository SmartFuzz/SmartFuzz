CREATE TABLE angles (angle FLOAT);
INSERT INTO angles VALUES (0), (30), (45), (60), (90), (120), (180), (270), (360);
SELECT angle, cos(angle) FROM angles;
SELECT cos(PI() * angle / 180) AS cosine_degrees FROM angles;
CREATE TABLE results AS SELECT angle, cos(angle) AS cosine_value FROM angles;
SELECT r.angle, r.cosine_value, (1 - r.cosine_value^2) AS sine_square FROM results r;
SELECT DISTINCT r.angle, cos(r.angle), (SELECT AVG(cos(r.angle)) FROM results) AS avg_cosine FROM results r WHERE r.cosine_value < 0.5;
SELECT r1.angle, cos(r1.angle) FROM results r1 JOIN results r2 ON r1.angle > r2.angle;
CREATE TABLE complex_angles AS SELECT angle, cos(angle) AS cosine_value FROM (SELECT angle FROM angles WHERE angle BETWEEN 0 AND 360) temp;
SELECT angle, cosine_value FROM complex_angles ORDER BY cosine_value DESC;