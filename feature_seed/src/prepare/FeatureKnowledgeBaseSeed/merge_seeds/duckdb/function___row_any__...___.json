CREATE TABLE test_struct (id INTEGER, value FLOAT);
INSERT INTO test_struct VALUES (1, 5.0), (2, 10.0), (3, 15.0);
SELECT row(id, value, value / 2) FROM test_struct;
SELECT row(id, value % 3, value / 3) FROM test_struct;
SELECT row(id, CASE WHEN value > 10 THEN 'High' ELSE 'Low' END) FROM test_struct;
SELECT t1.id, row(t1.value, t2.value) FROM test_struct t1 JOIN test_struct t2 ON t1.id != t2.id;
SELECT row(row(id, value), row(value * 2, value / 2)) FROM test_struct;
SELECT row(id, (SELECT AVG(value) FROM test_struct)) FROM test_struct;
CREATE TABLE nested_example (category VARCHAR, amount FLOAT);
INSERT INTO nested_example VALUES ('A', 100.0), ('B', 200.0);
SELECT row(n.category, row(SUM(n.amount), COUNT(n.amount))) FROM nested_example n GROUP BY n.category;
CREATE TABLE complex_table (num INTEGER, status BOOLEAN);
INSERT INTO complex_table VALUES (5, TRUE), (10, FALSE);
SELECT row(num, status, CASE WHEN status THEN 'Active' ELSE 'Inactive' END) FROM complex_table;