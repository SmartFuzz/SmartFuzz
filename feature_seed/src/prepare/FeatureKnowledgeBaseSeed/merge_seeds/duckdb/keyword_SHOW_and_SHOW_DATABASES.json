CREATE TABLE test_table (id INTEGER, name VARCHAR, value FLOAT);
INSERT INTO test_table VALUES (1, 'Alice', 10.5), (2, 'Bob', 20.0);
SHOW test_table;
SHOW DATABASES;
ATTACH 'my.duckdb' AS my_database;
SHOW DATABASES;
DETACH my_database;
SHOW DATABASES;
CREATE VIEW test_view AS SELECT name, value FROM test_table WHERE value > 15;
SHOW test_view;
CREATE TABLE another_table (id INTEGER, description VARCHAR);
INSERT INTO another_table VALUES (1, 'Test1'), (2, 'Test2');
SHOW another_table;
SHOW DATABASES;
SHOW (SELECT COUNT(*) FROM test_table) AS total_records;
SHOW (SELECT SUM(value) FROM test_table WHERE value > 10) AS total_value;