CREATE TABLE timestamps_test (timestamp_result TIMESTAMP);
INSERT INTO timestamps_test VALUES (make_timestamp(1992, 9, 20, 13, 34, 27.123456));
INSERT INTO timestamps_test VALUES (make_timestamp(1970, 1, 1, 0, 0, 0));
INSERT INTO timestamps_test VALUES (make_timestamp(9999, 12, 31, 23, 59, 59.999999));
INSERT INTO timestamps_test VALUES (make_timestamp(-1, 1, 1, 0, 0, 0));
INSERT INTO timestamps_test VALUES (make_timestamp(2023, 10, 5, 14, 0, 0));
INSERT INTO timestamps_test VALUES (make_timestamp(CAST((SELECT 2020 AS year) AS bigint), CAST((SELECT 10 AS month) AS bigint), CAST((SELECT 5 AS day) AS bigint), CAST((SELECT 15 AS hour) AS bigint), CAST((SELECT 30 AS minute) AS bigint), CAST((SELECT 45 AS second) AS double));
SELECT timestamp_result FROM timestamps_test WHERE timestamp_result >= make_timestamp(1992, 1, 1, 0, 0, 0);
SELECT timestamp_result FROM timestamps_test WHERE timestamp_result BETWEEN make_timestamp(1990, 1, 1, 0, 0, 0) AND make_timestamp(1995, 12, 31, 23, 59, 59.999999);
WITH timestamp_data AS (SELECT make_timestamp(2021, 12, 31, 23, 59, 59.999999) AS timestamp_val) SELECT timestamp_val FROM timestamp_data WHERE timestamp_val IS NOT NULL;