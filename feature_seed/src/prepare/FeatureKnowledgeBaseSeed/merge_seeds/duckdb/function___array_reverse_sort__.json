CREATE TABLE test_list (id INT, values LIST<INT>);
INSERT INTO test_list VALUES (1, [3, 6, 1, 2]);
INSERT INTO test_list VALUES (2, [5, NULL, 4, 1]);
INSERT INTO test_list VALUES (3, [NULL, NULL, NULL]);
INSERT INTO test_list VALUES (4, [7, 8, 5, 2]);
SELECT list_reverse_sort(values) FROM test_list WHERE id = 1;
SELECT list_reverse_sort(values) FROM test_list WHERE id = 2;
SELECT list_reverse_sort(values) FROM test_list WHERE id = 3;
SELECT id, list_reverse_sort(values) AS sorted_values FROM test_list ORDER BY id;
CREATE TABLE additional_data (id INT, related_id INT);
INSERT INTO additional_data VALUES (1, 1), (2, 2), (3, 1);
SELECT t.id, list_reverse_sort(t.values) AS sorted_values FROM test_list t JOIN additional_data a ON t.id = a.related_id WHERE a.id = 1;
SELECT list_reverse_sort(NULL) AS null_case;
SELECT GREATEST(1, 2) AS max_value, list_reverse_sort([GREATEST(3, 1), GREATEST(NULL, 2), 4]) AS sorted_values;
SELECT t.id, list_reverse_sort(t.values) FROM test_list t WHERE list_reverse_sort(t.values) IS NOT NULL;