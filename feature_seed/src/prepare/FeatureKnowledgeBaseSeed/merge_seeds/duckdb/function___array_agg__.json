CREATE TABLE test_table (id INT, value INT);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, 30);
SELECT array_agg(value ORDER BY value) FROM test_table;
CREATE TABLE another_table (group_id INT, name VARCHAR);
INSERT INTO another_table VALUES (1, 'A'), (1, 'B'), (2, 'C');
SELECT group_id, array_agg(name ORDER BY name) FROM another_table GROUP BY group_id;
CREATE TABLE multi_table (id INT, group_id INT, value INT);
INSERT INTO multi_table VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30);
SELECT mt.group_id, array_agg(mt.value) FROM multi_table mt JOIN another_table at ON mt.group_id = at.group_id GROUP BY mt.group_id;
CREATE TABLE nested_table (group_id INT, category VARCHAR);
INSERT INTO nested_table VALUES (1, 'X'), (1, 'Y'), (2, 'Z');
SELECT group_id, array_agg(category) FROM (SELECT group_id, category FROM nested_table WHERE category != 'Z') AS subquery GROUP BY group_id;
CREATE TABLE empty_table (id INT);
SELECT array_agg(value) FROM empty_table;
SELECT array_agg(value ORDER BY value DESC) FROM test_table WHERE id > 0;
CREATE TABLE complex_table (id INT, value INT, status VARCHAR);
INSERT INTO complex_table VALUES (1, 100, 'active'), (2, 200, 'inactive'), (3, 300, 'active');
SELECT status, array_agg(value) FROM complex_table WHERE status = 'active' GROUP BY status ORDER BY status;
SELECT array_agg(distinct value) FROM test_table WHERE value < 25;