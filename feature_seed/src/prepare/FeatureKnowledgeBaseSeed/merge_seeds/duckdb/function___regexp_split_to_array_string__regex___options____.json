SELECT regexp_split_to_array(str, ';
') FROM test_strings;
SELECT regexp_split_to_array(str, ';
') FROM test_strings WHERE str IS NOT NULL;
SELECT regexp_split_to_array(str, '\s+') FROM test_strings WHERE str LIKE '% %';
SELECT regexp_split_to_array(str, ',') AS split_parts FROM (SELECT str FROM test_strings WHERE str LIKE '%,%') AS subquery;
SELECT t1.str, regexp_split_to_array(t1.str, ';
') AS split_array FROM test_strings t1 JOIN (SELECT str FROM test_strings WHERE str LIKE '%;
%') t2 ON t1.str = t2.str;
SELECT str, regexp_split_to_array(str, '\s*[;
]\s*') AS parts FROM (SELECT str FROM test_strings ORDER BY str) AS ordered_strings;
SELECT str, UNNEST(regexp_split_to_array(str, ' ')) AS words FROM test_strings;
