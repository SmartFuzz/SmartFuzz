CREATE TABLE transactions (id INTEGER, amount DECIMAL, created_at TIMESTAMP);
INSERT INTO transactions VALUES (1, 100.00, get_current_time());
INSERT INTO transactions VALUES (2, 200.00, get_current_time());
SELECT get_current_time() AS current_time;
SELECT created_at FROM transactions WHERE created_at = get_current_time();
SELECT t.id, t.amount FROM transactions t JOIN (SELECT get_current_time() AS current_time) AS ct ON t.created_at = ct.current_time;
CREATE TABLE logs (log_id INTEGER, log_time TIMESTAMP);
INSERT INTO logs VALUES (1, get_current_time());
SELECT COUNT(*) FROM logs WHERE log_time BETWEEN get_current_time() - INTERVAL '1 hour' AND get_current_time();
SELECT SUM(amount) FROM transactions WHERE created_at >= get_current_time() - INTERVAL '1 day';
CREATE TABLE summary AS SELECT get_current_time() AS snapshot_time, SUM(amount) AS total_amount FROM transactions;
SELECT snapshot_time FROM summary WHERE snapshot_time = get_current_time();
SELECT (SELECT COUNT(*) FROM transactions) AS total_transactions, get_current_time() AS query_time;
WITH current_time_cte AS (SELECT get_current_time() AS current_time) SELECT current_time, (SELECT COUNT(*) FROM transactions WHERE created_at >= current_time) AS count_today FROM current_time_cte;
SELECT amount FROM transactions WHERE created_at = (SELECT get_current_time());