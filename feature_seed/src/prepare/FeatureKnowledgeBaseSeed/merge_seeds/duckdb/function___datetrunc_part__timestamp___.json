CREATE TABLE events (event_id INT, event_time TIMESTAMP);
INSERT INTO events VALUES (1, TIMESTAMP '1992-09-20 20:38:40'), (2, TIMESTAMP '1992-09-20 19:15:00');
SELECT event_id, datetrunc('hour', event_time) AS truncated_time FROM events;
SELECT event_id FROM events WHERE datetrunc('minute', event_time) = TIMESTAMP '1992-09-20 20:38:00';
CREATE TABLE users (user_id INT, signup_time TIMESTAMP);
INSERT INTO users VALUES (1, TIMESTAMP '1992-09-20 20:00:00'), (2, TIMESTAMP '1992-09-20 21:05:00');
SELECT u.user_id, e.event_id, datetrunc('hour', e.event_time) AS event_hour FROM users u JOIN events e ON datetrunc('day', u.signup_time) = datetrunc('day', e.event_time);
SELECT user_id, COUNT(*) AS event_count FROM events GROUP BY datetrunc('day', event_time);
SELECT datetrunc('second', TIMESTAMP '1992-09-20 20:38:40.123456') AS truncated_second;
SELECT datetrunc('minute', MIN(event_time)) AS first_event_time FROM events;
SELECT e.event_id, datetrunc('day', e.event_time) AS event_day, COUNT(u.user_id) AS user_count FROM events e LEFT JOIN users u ON datetrunc('day', u.signup_time) = datetrunc('day', e.event_time) GROUP BY e.event_id, event_day;
SELECT e.event_id, datetrunc('hour', MAX(e.event_time)) AS last_event_hour FROM events e GROUP BY e.event_id;