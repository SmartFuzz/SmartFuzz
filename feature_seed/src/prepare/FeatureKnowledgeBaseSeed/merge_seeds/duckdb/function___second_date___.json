CREATE TABLE timestamps (event_id INT, event_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, TIMESTAMP '2021-08-03 11:59:44.123456'), (2, TIMESTAMP '2022-01-01 00:00:00.000000');
SELECT event_id, second(event_time) FROM timestamps;
SELECT event_id, second(event_time) FROM timestamps WHERE event_id = 1;
SELECT event_id, second(event_time) + 5 AS adjusted_seconds FROM timestamps;
CREATE TABLE events (event_id INT, event_time TIMESTAMP);
INSERT INTO events (event_id, event_time) SELECT event_id, event_time FROM timestamps;
SELECT e.event_id, second(e.event_time) FROM events e JOIN timestamps t ON e.event_id = t.event_id WHERE second(t.event_time) < 45;
SELECT event_id, second(event_time) AS second_val FROM timestamps WHERE second(event_time) BETWEEN 0 AND 59;
SELECT event_id, second(event_time) FROM (SELECT event_id, event_time FROM timestamps WHERE event_id = 2) AS subquery;
SELECT second(TIMESTAMP '1970-01-01 00:00:00') AS epoch_seconds;
CREATE TABLE multiple_events (id INT, start_time TIMESTAMP, end_time TIMESTAMP);
INSERT INTO multiple_events VALUES (1, TIMESTAMP '2021-08-03 11:59:44.123456', TIMESTAMP '2021-08-03 12:05:44.123456'), (2, TIMESTAMP '2021-08-03 11:59:45.123456', TIMESTAMP '2021-08-03 12:05:45.123456');
SELECT id, second(start_time) + second(end_time) AS total_seconds FROM multiple_events;
SELECT id, second(COALESCE(start_time, end_time)) AS second_val FROM multiple_events;
SELECT id, second(ADDTIME(start_time, INTERVAL 1 HOUR)) AS second_plus_hour FROM multiple_events;
SELECT id, CASE WHEN second(start_time) = 59 THEN 'Last Second' ELSE 'Not Last Second' END AS second_status FROM multiple_events;