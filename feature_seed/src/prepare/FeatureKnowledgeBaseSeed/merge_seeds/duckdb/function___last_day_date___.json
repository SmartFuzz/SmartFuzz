CREATE TABLE test_dates (id INTEGER, event_date DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-09-20');
INSERT INTO test_dates VALUES (2, DATE '2023-10-15');
INSERT INTO test_dates VALUES (3, DATE '2024-02-28');
INSERT INTO test_dates VALUES (4, DATE '2024-03-31');
SELECT id, last_day(event_date) AS last_day_of_month FROM test_dates;
SELECT id, last_day(last_day(event_date)) AS last_day_of_last_day FROM test_dates;
CREATE TABLE another_table (reference_id INTEGER, description VARCHAR);
INSERT INTO another_table VALUES (1, 'First Event'), (2, 'Second Event'), (3, 'Third Event');
SELECT a.reference_id, d.event_date, last_day(d.event_date) AS last_day_of_month FROM another_table a JOIN test_dates d ON a.reference_id = d.id;
SELECT id, last_day(COALESCE(event_date, DATE '2023-01-01')) AS last_day_of_month FROM test_dates;
SELECT COUNT(*), last_day(event_date) FROM test_dates GROUP BY last_day(event_date);
CREATE TABLE complex_dates (a DATE, b DATE);
INSERT INTO complex_dates VALUES (DATE '2020-01-20', DATE '2020-01-25');
SELECT last_day(a) AS last_day_a, last_day(b) AS last_day_b FROM complex_dates WHERE last_day(a) != last_day(b);
SELECT id, event_date, last_day(event_date) FROM test_dates WHERE last_day(event_date) > DATE '2024-01-01';
SELECT d.id, last_day(d.event_date) AS last_day, a.description FROM test_dates d LEFT JOIN another_table a ON d.id = a.reference_id WHERE last_day(d.event_date) IS NOT NULL;