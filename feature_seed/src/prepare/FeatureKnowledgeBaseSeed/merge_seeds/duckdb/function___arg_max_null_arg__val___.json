CREATE TABLE test_table (A INT, B INT);
INSERT INTO test_table VALUES (1, 10), (2, 20), (3, NULL), (4, 15);
SELECT arg_max_null(A, B) FROM test_table;
CREATE TABLE test_table2 (A INT, B INT);
INSERT INTO test_table2 VALUES (1, 50), (2, 50), (3, 50), (4, 50);
SELECT arg_max_null(A, B) FROM test_table2;
CREATE TABLE test_table3 (A INT, B INT);
INSERT INTO test_table3 VALUES (1, 30), (2, 60), (3, 90), (4, NULL);
SELECT arg_max_null(A, B) FROM test_table3 WHERE B IS NOT NULL;
CREATE TABLE test_table4 AS SELECT 1 AS A, 10 AS B UNION ALL SELECT 2, 20 UNION ALL SELECT 3, NULL UNION ALL SELECT 4, 15;
SELECT arg_max_null(A, B) FROM test_table4;
WITH ranked AS (SELECT A, B, ROW_NUMBER() OVER (ORDER BY B DESC) AS rnk FROM test_table WHERE B IS NOT NULL) SELECT arg_max_null(A, B) FROM ranked;
CREATE TABLE main_table (A INT, B INT);
INSERT INTO main_table VALUES (1, 5), (2, 10), (3, 15);
CREATE TABLE join_table (C INT, D INT);
INSERT INTO join_table VALUES (1, 20), (2, NULL), (3, 30);
SELECT arg_max_null(main_table.A, join_table.D) FROM main_table JOIN join_table ON main_table.A = join_table.C;
CREATE TABLE filter_table (A INT, B INT);
INSERT INTO filter_table VALUES (1, 0), (2, NULL), (3, 5);
SELECT arg_max_null(A, B) FROM filter_table WHERE B > 0;
SELECT arg_max_null(A, B) FROM test_table WHERE A IN (SELECT A FROM test_table WHERE B IS NOT NULL);