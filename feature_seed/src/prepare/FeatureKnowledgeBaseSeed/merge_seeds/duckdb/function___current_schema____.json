CREATE SCHEMA test_schema;
USE test_schema;
CREATE TABLE t1 (id INTEGER, name VARCHAR);
CREATE TABLE t2 (id INTEGER, description VARCHAR);
INSERT INTO t1 VALUES (1, 'Alice'), (2, 'Bob');
INSERT INTO t2 VALUES (1, 'Description A'), (2, 'Description B');
SELECT current_schema();
CREATE TABLE t3 AS SELECT id, name FROM t1 WHERE id > 0;
SELECT current_schema() AS current, (SELECT current_schema()) AS nested_current_schema;
WITH temp AS (SELECT current_schema() AS temp_schema) SELECT temp_schema FROM temp;
SELECT current_schema() FROM (SELECT current_schema() AS schema_name) AS sub;
SELECT current_schema() FROM t1 JOIN t2 ON t1.id = t2.id WHERE current_schema() = 'test_schema';
CREATE TABLE t4 AS SELECT current_schema() AS schema_name, COUNT(*) FROM t1 GROUP BY schema_name;
SET search_path TO test_schema;
SELECT current_schema();
CREATE TABLE t5 (id INTEGER PRIMARY KEY, schema_name VARCHAR);
INSERT INTO t5 (id, schema_name) VALUES (1, current_schema());
SELECT schema_name FROM t5 WHERE id = 1;