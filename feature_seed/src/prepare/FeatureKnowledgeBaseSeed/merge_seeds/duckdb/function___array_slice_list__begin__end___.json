CREATE TABLE test_strings (id INTEGER, value TEXT);
INSERT INTO test_strings VALUES (1, 'DuckDB'), (2, 'Database'), (3, 'Fuzz Testing'), (4, 'SQL Functions');
SELECT array_slice(value, 1, 5) FROM test_strings;
SELECT array_slice(value, -3, 2) FROM test_strings;
SELECT array_slice(value, 0, -1) FROM test_strings;
SELECT array_slice(value, 2, NULL) FROM test_strings;
SELECT id, array_slice(value, 1, 3) AS sliced FROM test_strings WHERE id = 1;
SELECT a.id, array_slice(a.value, 2, a.id) AS sliced_value FROM (SELECT id, value FROM test_strings WHERE id < 3) AS a;
SELECT a.id, array_slice(b.value, 1, 4) AS sliced_value FROM test_strings a JOIN test_strings b ON a.id < b.id;
SELECT array_slice('Nested Query Example', 8, 15) FROM (SELECT value FROM test_strings WHERE id = 2) AS subquery;
SELECT id, array_slice(value, 1, 2) FROM (SELECT * FROM test_strings WHERE id > 1) AS filtered_strings;