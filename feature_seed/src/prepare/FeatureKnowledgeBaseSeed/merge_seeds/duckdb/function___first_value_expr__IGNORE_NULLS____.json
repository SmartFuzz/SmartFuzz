CREATE TABLE sales (id INTEGER, amount FLOAT, region TEXT, sale_date DATE);
INSERT INTO sales VALUES (1, 100.0, 'North', '2023-01-01'), (2, 200.0, 'North', '2023-01-02'), (3, NULL, 'North', '2023-01-03'), (4, 300.0, 'South', '2023-01-01'), (5, NULL, 'South', '2023-01-02');
SELECT first_value(amount IGNORE NULLS) OVER (PARTITION BY region ORDER BY sale_date) AS first_non_null_sale FROM sales;
CREATE TABLE temperature_readings (id INTEGER, value FLOAT, city TEXT, reading_date DATE);
INSERT INTO temperature_readings VALUES (1, NULL, 'New York', '2023-01-01'), (2, 30.5, 'New York', '2023-01-02'), (3, NULL, 'New York', '2023-01-03'), (4, 25.0, 'Los Angeles', '2023-01-01'), (5, 28.0, 'Los Angeles', '2023-01-02');
SELECT first_value(value IGNORE NULLS) OVER (PARTITION BY city ORDER BY reading_date) AS first_non_null_temperature FROM temperature_readings;
CREATE TABLE customer_orders (order_id INTEGER, customer_id INTEGER, amount FLOAT, order_date DATE);
INSERT INTO customer_orders VALUES (1, 101, NULL, '2023-02-01'), (2, 101, 300.0, '2023-02-02'), (3, 102, 150.0, '2023-02-01'), (4, 102, 200.0, '2023-02-01');
SELECT customer_id, first_value(amount IGNORE NULLS) OVER (PARTITION BY customer_id ORDER BY order_date) AS first_non_null_order_amount FROM customer_orders;
CREATE TABLE employee_salaries (emp_id INTEGER, department_id INTEGER, salary FLOAT);
INSERT INTO employee_salaries VALUES (1, 1, 70000.0), (2, 1, NULL), (3, 2, 80000.0), (4, 2, 85000.0);
SELECT department_id, first_value(salary IGNORE NULLS) OVER (PARTITION BY department_id ORDER BY emp_id) AS first_non_null_salary FROM employee_salaries;
CREATE TABLE transactions (trans_id INTEGER, account_id INTEGER, trans_amount FLOAT, trans_date DATE);
INSERT INTO transactions VALUES (1, 201, NULL, '2023-03-01'), (2, 201, 500.0, '2023-03-02'), (3, 202, 300.0, '2023-03-01'), (4, 202, NULL, '2023-03-02');
SELECT account_id, first_value(trans_amount IGNORE NULLS) OVER (PARTITION BY account_id ORDER BY trans_date) AS first_non_null_transaction_amount FROM transactions;
CREATE TABLE projects (project_id INTEGER, team_id INTEGER, budget FLOAT);
INSERT INTO projects VALUES (1, 1, NULL), (2, 1, 150000.0), (3, 2, 200000.0), (4, 2, NULL);
SELECT team_id, first_value(budget IGNORE NULLS) OVER (PARTITION BY team_id ORDER BY project_id) AS first_non_null_budget FROM projects;