CREATE TABLE test_list (id INT, values LIST<INT>);
INSERT INTO test_list VALUES (1, [4, 5, 6]), (2, [1, 2, 3]), (3, [7, 8, 9]);
SELECT id, list_filter(values, x -> x > 4) AS filtered_values FROM test_list;
SELECT id, list_filter(values, x -> x < 3) AS filtered_values FROM test_list;
SELECT id, list_filter(values, x -> x = 5) AS filtered_values FROM test_list;
CREATE TABLE test_data (group_id INT, score LIST<INT>);
INSERT INTO test_data VALUES (1, [1, 3, 5]), (2, [2, 4, 6]);
SELECT d.group_id, list_filter(d.score, s -> s > 3) AS high_scores FROM test_data d;
SELECT d.group_id, list_filter(d.score, s -> s % 2 = 0) AS even_scores FROM test_data d;
SELECT t.id, list_filter(t.values, x -> x > (SELECT AVG(value) FROM (SELECT UNNEST(values) AS value FROM test_list))) AS above_average FROM test_list t;
CREATE TABLE employee_data (employee_id INT, salaries LIST<INT>);
INSERT INTO employee_data VALUES (1, [3000, 5000, 7000]), (2, [2000, 4000, 6000]);
SELECT e.employee_id, list_filter(e.salaries, s -> s > 4500) AS high_salaries FROM employee_data e;
SELECT t.id, list_filter(t.values, x -> x NOT IN (SELECT UNNEST(salaries) FROM employee_data)) AS unique_values FROM test_list t;
SELECT t.id, list_filter(t.values, x -> x BETWEEN 5 AND 7) AS range_values FROM test_list t;