CREATE TABLE t1 (id INTEGER, value UNION (STRING, INTEGER));
INSERT INTO t1 VALUES (1, 'one'), (2, 2), (3, 'three');
SELECT union_extract(value, 'tag') FROM t1 WHERE id = 1;
CREATE TABLE t2 (uid INTEGER, tag STRING);
INSERT INTO t2 VALUES (1, 'one'), (2, 'two'), (3, 'three');
SELECT union_extract(t1.value, 'k') FROM t1 INNER JOIN t2 ON t1.id = t2.uid;
SELECT union_extract(value, 'k') FROM (SELECT id, value FROM t1 WHERE value IS NOT NULL) AS subquery;
WITH temp AS (SELECT id, value FROM t1 WHERE value IS NOT NULL) SELECT union_extract(temp.value, 'k') FROM temp;
SELECT union_extract(value, 'k') FROM (SELECT id, union(STRING, INTEGER) AS value FROM t1 UNION SELECT uid, tag FROM t2) AS combined;
CREATE TABLE t3 (group_id INTEGER, union_val UNION (STRING, INTEGER));
INSERT INTO t3 VALUES (1, 'alpha'), (1, 100), (2, 'beta');
SELECT group_id, union_extract(union_val, 'k') FROM t3 WHERE group_id = 1;
SELECT union_extract(value, 'k') FROM (SELECT id, union(STRING, INTEGER) AS value FROM t1 WHERE id > 1 UNION ALL SELECT group_id, union_val FROM t3) AS combined_values;