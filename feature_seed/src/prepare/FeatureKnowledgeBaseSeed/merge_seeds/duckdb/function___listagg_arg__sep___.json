CREATE TABLE employees (id INT, name VARCHAR, department VARCHAR);
INSERT INTO employees VALUES (1, 'Alice', 'HR'), (2, 'Bob', 'IT'), (3, 'Charlie', 'HR'), (4, 'David', 'Finance');
SELECT department, listagg(name, ', ') AS all_names FROM employees GROUP BY department ORDER BY department;
CREATE TABLE departments (dep_id INT, dep_name VARCHAR);
INSERT INTO departments VALUES (1, 'HR'), (2, 'IT'), (3, 'Finance');
SELECT d.dep_name, listagg(e.name, ', ') AS employee_names FROM employees e JOIN departments d ON e.department = d.dep_name GROUP BY d.dep_name ORDER BY d.dep_name;
SELECT listagg(name, ';
') WITHIN GROUP (ORDER BY id) AS ordered_names FROM employees WHERE department = 'HR';
CREATE TABLE projects (proj_id INT, proj_name VARCHAR, employee_id INT);
INSERT INTO projects VALUES (1, 'ProjectA', 1), (2, 'ProjectB', 1), (3, 'ProjectC', 2), (4, 'ProjectD', 3);
SELECT e.name, listagg(p.proj_name, ', ') AS projects FROM employees e LEFT JOIN projects p ON e.id = p.employee_id GROUP BY e.name ORDER BY e.name;
SELECT d.dep_name, listagg(e.name, ', ') AS employee_names FROM employees e LEFT JOIN departments d ON e.department = d.dep_name WHERE e.id > 1 GROUP BY d.dep_name ORDER BY d.dep_name;
SELECT listagg(proj_name, ', ') AS project_names FROM projects WHERE employee_id IN (SELECT id FROM employees WHERE department = 'IT');