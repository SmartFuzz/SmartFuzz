CREATE TABLE test_table (id INTEGER PRIMARY KEY, value INTEGER);
INSERT INTO test_table VALUES (1, 100), (2, 200), (3, 300);
CREATE VIEW test_view AS SELECT AVG(value) AS avg_value FROM test_table;
SELECT * FROM test_view WHERE avg_value > 150;
CREATE TABLE additional_table (id INTEGER PRIMARY KEY, test_id INTEGER, FOREIGN KEY(test_id) REFERENCES test_table(id));
INSERT INTO additional_table VALUES (1, 1), (2, 2);
SELECT a.id, a.value, b.test_id FROM test_table a JOIN additional_table b ON a.id = b.test_id WHERE a.value < 250;
CREATE INDEX idx_value ON test_table(value);
SELECT COUNT(*) FROM test_table WHERE value >= 100 UNION SELECT COUNT(*) FROM additional_table;
CREATE TABLE nested_test (id INTEGER PRIMARY KEY, ref_id INTEGER, CONSTRAINT fk_ref FOREIGN KEY(ref_id) REFERENCES test_table(id));
INSERT INTO nested_test VALUES (1, 1), (2, NULL);
SELECT (SELECT COUNT(*) FROM nested_test) AS nested_count, (SELECT COUNT(*) FROM test_table) AS table_count;
ENABLE WAL;
BEGIN;
INSERT INTO test_table VALUES (4, 400);
COMMIT;
SELECT COUNT(*) FROM test_table;
SELECT DISTINCT value FROM test_table WHERE value IN (SELECT value FROM additional_table);
CREATE TEMPORARY TABLE temp_table AS SELECT * FROM test_table WHERE value > 150;
SELECT * FROM temp_table WHERE id = (SELECT MAX(id) FROM temp_table);
FORCE_CHECKPOINT('test_db_file');
DROP TABLE IF EXISTS temp_table;
SELECT COUNT(*) FROM test_table WHERE id NOT IN (SELECT ref_id FROM nested_test WHERE ref_id IS NOT NULL);
CREATE TABLE complex_table AS SELECT t.id, (SELECT AVG(value) FROM test_table) AS avg_value FROM test_table t WHERE t.id > 0;