CREATE TABLE test_dates (id INT, event_date DATE);
INSERT INTO test_dates VALUES (1, DATE '1992-02-15'), (2, DATE '2023-12-31'), (3, DATE '2023-02-29'), (4, DATE '2020-02-29'), (5, DATE '2019-01-01');
SELECT dayofmonth(event_date) FROM test_dates;
SELECT event_date, dayofmonth(event_date) AS day FROM test_dates WHERE event_date >= DATE '2020-01-01';
SELECT id, dayofmonth(event_date) FROM test_dates WHERE dayofmonth(event_date) = 29;
SELECT MAX(dayofmonth(event_date)) AS max_day FROM test_dates WHERE event_date < DATE '2023-01-01';
SELECT id, dayofmonth(event_date) AS day, CASE WHEN dayofmonth(event_date) = 1 THEN 'First' ELSE 'Not First' END AS day_classifier FROM test_dates;
SELECT t1.id, dayofmonth(t1.event_date) AS day_1, dayofmonth(t2.event_date) AS day_2 FROM test_dates t1 JOIN test_dates t2 ON t1.id <> t2.id;
WITH date_summary AS (SELECT event_date, dayofmonth(event_date) AS day FROM test_dates) SELECT day, COUNT(*) FROM date_summary GROUP BY day;
SELECT dayofmonth(CURRENT_DATE) AS today_day, (SELECT dayofmonth(MAX(event_date)) FROM test_dates) AS latest_event_day;