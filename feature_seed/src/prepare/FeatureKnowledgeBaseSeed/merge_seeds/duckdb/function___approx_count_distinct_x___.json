CREATE TABLE test_table (id INT, value VARCHAR);
INSERT INTO test_table VALUES (1, 'A'), (2, 'B'), (3, 'A'), (4, 'C'), (5, 'B'), (6, 'D');
SELECT approx_count_distinct(value) FROM test_table;
CREATE TABLE subquery_table AS SELECT id, value FROM test_table WHERE id > 2;
SELECT approx_count_distinct(value) FROM (SELECT value FROM subquery_table) AS temp;
SELECT id, approx_count_distinct(value) FROM test_table GROUP BY id;
CREATE TABLE another_table (id INT, val VARCHAR);
INSERT INTO another_table VALUES (1, 'E'), (2, 'F'), (3, 'E'), (4, 'G');
SELECT a.id, approx_count_distinct(a.value) FROM test_table a JOIN another_table b ON a.id = b.id GROUP BY a.id;
SELECT approx_count_distinct(value) OVER (PARTITION BY id) FROM test_table;
CREATE TABLE complex_table (id INT, category VARCHAR, amount DECIMAL);
INSERT INTO complex_table VALUES (1, 'X', 10.00), (2, 'Y', 20.00), (3, 'X', 10.00), (4, 'Z', 30.00);
SELECT category, approx_count_distinct(amount) FROM complex_table GROUP BY category;
SELECT approx_count_distinct(b.value) FROM test_table a JOIN another_table b ON a.id = b.id WHERE b.val = 'E';