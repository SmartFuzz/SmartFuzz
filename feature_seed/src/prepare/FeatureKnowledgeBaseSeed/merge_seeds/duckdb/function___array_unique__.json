CREATE TABLE test_table (id INTEGER, numbers LIST<INTEGER>);
INSERT INTO test_table VALUES (1, [1, 1, NULL, -3, 1, 5]);
INSERT INTO test_table VALUES (2, [2, NULL, 3, 3, 2, 3]);
INSERT INTO test_table VALUES (3, [NULL, NULL, NULL]);
INSERT INTO test_table VALUES (4, [1, 1, 1, 1]);
INSERT INTO test_table VALUES (5, [5, 6, 7, 8, 9, 5, 6]);
SELECT id, array_unique(numbers) AS unique_numbers FROM test_table;
SELECT id, array_unique(numbers) AS unique_numbers FROM test_table WHERE id > 2;
SELECT id, array_unique(array_concat(numbers, [10, 10, 11])) AS unique_numbers_combined FROM test_table;
SELECT id, array_unique(numbers) AS unique_numbers FROM test_table WHERE numbers IS NOT NULL;
CREATE TABLE another_table (num_list LIST<INTEGER>);
INSERT INTO another_table VALUES ([1, 2, 2, 3]), ([2, 3, 3, 4]), ([NULL, NULL]);
SELECT a.id, array_unique(a.numbers) AS unique_numbers, b.num_list FROM test_table a JOIN another_table b ON array_contains(a.numbers, 1);
WITH unique_lists AS (SELECT id, array_unique(numbers) AS unique_numbers FROM test_table) SELECT * FROM unique_lists WHERE unique_numbers IS NOT NULL;
SELECT a.id, array_unique(a.numbers) AS unique_numbers FROM test_table a JOIN another_table b ON array_length(a.numbers) > 3;
SELECT array_unique(ARRAY(SELECT unnest(numbers) FROM test_table WHERE id = 1));
SELECT array_unique([SELECT unnest(numbers) FROM another_table WHERE num_list IS NOT NULL]) AS unique_numbers;