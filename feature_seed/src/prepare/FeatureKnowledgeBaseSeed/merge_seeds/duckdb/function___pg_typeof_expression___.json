CREATE TABLE test_table (id INT, name VARCHAR, value FLOAT);
INSERT INTO test_table VALUES (1, 'test1', 1.5), (2, 'test2', NULL), (3, 'test3', 2.0);
SELECT pg_typeof(name) FROM test_table;
SELECT pg_typeof(value) FROM test_table WHERE value IS NOT NULL;
SELECT pg_typeof((SELECT AVG(value) FROM test_table));
SELECT pg_typeof((SELECT name FROM test_table WHERE id = 1));
SELECT pg_typeof(COALESCE((SELECT value FROM test_table WHERE id = 2), 0));
CREATE TABLE another_table (a INT, b VARCHAR);
INSERT INTO another_table VALUES (1, 'foo'), (2, 'bar');
SELECT pg_typeof((SELECT CONCAT(name, b) FROM test_table JOIN another_table ON test_table.id = another_table.a));
SELECT pg_typeof((SELECT SUM(value) FROM test_table GROUP BY id HAVING COUNT(name) > 1));
SELECT pg_typeof((SELECT id, AVG(value) FROM test_table GROUP BY id HAVING AVG(value) IS NOT NULL));
SELECT pg_typeof((SELECT COUNT(*) FROM test_table WHERE pg_typeof(value) = 'float'));