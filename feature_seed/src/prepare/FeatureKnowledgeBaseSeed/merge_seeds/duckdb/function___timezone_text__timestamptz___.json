CREATE TABLE test_timestamps (id INTEGER, event_time TIMESTAMPTZ);
INSERT INTO test_timestamps VALUES (1, TIMESTAMPTZ '2001-02-16 20:38:40-05');
INSERT INTO test_timestamps VALUES (2, TIMESTAMPTZ '2023-10-05 15:30:00-07');
SELECT timezone('America/Denver', event_time) FROM test_timestamps WHERE id = 1;
SELECT timezone('America/New_York', event_time) FROM test_timestamps WHERE id = 2;
SELECT id, timezone('America/Los_Angeles', event_time + INTERVAL '2 hours') FROM test_timestamps;
SELECT id, timezone('UTC', timezone('America/Chicago', event_time)) FROM test_timestamps;
CREATE TABLE events (event_name TEXT, event_time TIMESTAMPTZ, location TEXT);
INSERT INTO events VALUES ('Meeting', TIMESTAMPTZ '2023-10-05 15:30:00-07', 'Room A');
INSERT INTO events VALUES ('Conference', TIMESTAMPTZ '2023-10-06 09:00:00-07', 'Hall 1');
SELECT e.event_name, timezone('America/New_York', e.event_time) FROM events e JOIN test_timestamps t ON e.event_time < t.event_time;
WITH adjusted_times AS (SELECT id, timezone('Europe/London', event_time) AS local_time FROM test_timestamps) SELECT * FROM adjusted_times WHERE local_time > TIMESTAMPTZ '2023-10-05 00:00:00+00';
CREATE TABLE user_activity (user_id INTEGER, activity_time TIMESTAMPTZ);
INSERT INTO user_activity VALUES (1, TIMESTAMPTZ '2023-10-01 12:00:00-05');
INSERT INTO user_activity VALUES (2, TIMESTAMPTZ '2023-10-02 14:00:00+00');
SELECT a.user_id, timezone('Asia/Tokyo', a.activity_time) FROM user_activity a WHERE a.activity_time < TIMESTAMPTZ '2023-10-05 00:00:00+00';
SELECT e.event_name, timezone('America/Denver', MIN(e.event_time)) FROM events e GROUP BY e.event_name HAVING COUNT(e.event_name) > 1;
CREATE TABLE time_zones (zone_name TEXT);
INSERT INTO time_zones VALUES ('America/Denver'), ('America/New_York'), ('UTC');
SELECT z.zone_name, COUNT(*) AS event_count FROM time_zones z LEFT JOIN events e ON e.event_time IS NOT NULL GROUP BY z.zone_name;