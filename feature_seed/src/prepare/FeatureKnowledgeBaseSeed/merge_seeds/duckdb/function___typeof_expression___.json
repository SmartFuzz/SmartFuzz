CREATE TABLE test_data (id INT, text_value VARCHAR, num_value FLOAT, bool_value BOOLEAN);
INSERT INTO test_data VALUES (1, 'abc', 3.14, TRUE), (2, 'def', NULL, FALSE), (3, 'ghi', 2.71, TRUE);
SELECT typeof(text_value) FROM test_data;
SELECT typeof(num_value) FROM test_data WHERE num_value IS NOT NULL;
SELECT typeof(bool_value) FROM test_data WHERE bool_value = TRUE;
SELECT typeof((SELECT COUNT(*) FROM test_data)) AS count_type;
SELECT typeof((SELECT MAX(num_value) FROM test_data WHERE num_value IS NOT NULL)) AS max_num_type;
CREATE TABLE additional_data (data_value INT);
INSERT INTO additional_data VALUES (10), (20), (30);
SELECT typeof((SELECT SUM(test_data.num_value) FROM test_data JOIN additional_data ON test_data.id = additional_data.data_value)) AS sum_type;
SELECT typeof('This is a string') AS string_type, typeof(12345) AS int_type, typeof(12.34) AS float_type, typeof(NULL) AS null_type;
SELECT typeof(ARRAY[1, 2, 3]) AS array_type;
SELECT typeof(ROW(1, 'text')) AS row_type;
SELECT typeof(1 + 1.5) AS arithmetic_type;
SELECT typeof(text_value || ' - concatenated') FROM test_data;