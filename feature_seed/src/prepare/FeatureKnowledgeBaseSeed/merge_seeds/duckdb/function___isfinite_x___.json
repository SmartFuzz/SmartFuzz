CREATE TABLE test_values (val FLOAT);
INSERT INTO test_values VALUES (5.5), (NaN), (Infinity), (-Infinity), (2.3e308), (-2.3e308);
SELECT val, isfinite(val) FROM test_values;
CREATE TABLE limits AS SELECT val FROM test_values;
SELECT COUNT(*) AS finite_count FROM limits WHERE isfinite(val);
SELECT val FROM limits WHERE isfinite(val) AND val > 0;
SELECT val, isfinite(val) AS is_finite FROM limits WHERE val < 0 OR val > 1000;
CREATE TABLE mixed_data (id INT, value FLOAT);
INSERT INTO mixed_data VALUES (1, 0.0), (2, NaN), (3, Infinity), (4, 3.14), (5, -Infinity);
SELECT m.id, m.value, isfinite(m.value) FROM mixed_data m WHERE m.value IS NOT NULL;
WITH finite_values AS (SELECT value FROM mixed_data WHERE isfinite(value)) SELECT COUNT(*) FROM finite_values;
SELECT (SELECT AVG(value) FROM mixed_data WHERE isfinite(value)) AS avg_finite_value, (SELECT COUNT(*) FROM mixed_data) AS total_count;
CREATE TABLE final_results AS SELECT id, value, isfinite(value) AS is_finite FROM mixed_data;
SELECT COUNT(*) FROM final_results WHERE is_finite = true;
SELECT id FROM mixed_data WHERE isfinite(value) OR value < 0 ORDER BY value DESC;