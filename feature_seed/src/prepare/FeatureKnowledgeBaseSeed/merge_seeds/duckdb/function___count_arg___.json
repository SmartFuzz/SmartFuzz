CREATE TABLE test_table (id INT, value VARCHAR);
INSERT INTO test_table VALUES (1, 'A'), (2, 'B'), (3, NULL), (4, 'C');
SELECT COUNT(value) FROM test_table;
CREATE TABLE another_table (ref_id INT, ref_value VARCHAR);
INSERT INTO another_table VALUES (1, 'X'), (1, 'Y'), (2, NULL), (3, 'Z');
SELECT COUNT(value) FROM test_table WHERE id IN (SELECT DISTINCT ref_id FROM another_table WHERE ref_value IS NOT NULL);
SELECT COUNT(DISTINCT value) FROM test_table;
SELECT COUNT(*) FROM (SELECT DISTINCT value FROM test_table WHERE value IS NOT NULL) AS distinct_values;
CREATE TABLE complex_table (group_id INT, group_value VARCHAR);
INSERT INTO complex_table VALUES (1, 'Alpha'), (1, 'Beta'), (2, 'Gamma'), (2, NULL);
SELECT C.group_id, COUNT(C.group_value) FROM complex_table C JOIN test_table T ON C.group_id = T.id GROUP BY C.group_id;
SELECT COUNT(value) FROM test_table WHERE value IN (SELECT DISTINCT ref_value FROM another_table WHERE ref_value IS NOT NULL) AND value IS NOT NULL;
SELECT COUNT(CASE WHEN value IS NOT NULL THEN 1 END) FROM test_table;
CREATE TABLE temp_table (a INT, b INT);
INSERT INTO temp_table VALUES (1, 2), (2, NULL), (NULL, 3), (4, 5);
SELECT COUNT(*) FROM temp_table WHERE a IS NOT NULL OR b IS NOT NULL;
SELECT COUNT(*) FROM (SELECT a, b FROM temp_table WHERE a IS NOT NULL) AS temp_a UNION SELECT COUNT(*) FROM (SELECT a, b FROM temp_table WHERE b IS NOT NULL) AS temp_b;