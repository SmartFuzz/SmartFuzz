CREATE TABLE test_map (m MAP<VARCHAR, INTEGER>);
INSERT INTO test_map VALUES (MAP {'key1': 10, 'key2': 20, 'key3': 30});
SELECT map_contains_value(m, 20) FROM test_map WHERE m IS NOT NULL;
CREATE TABLE another_map (m MAP<VARCHAR, INTEGER>);
INSERT INTO another_map VALUES (MAP {'keyA': 100, 'keyB': 200});
SELECT map_contains_value(t1.m, t2.value) FROM test_map t1 JOIN (SELECT 20 AS value) t2 ON TRUE;
CREATE TABLE complex_map (m MAP<VARCHAR, INTEGER>, id INTEGER);
INSERT INTO complex_map VALUES (MAP {'a': 5, 'b': 10, 'c': 15}, 1), (MAP {'x': 50, 'y': 60}, 2);
SELECT id FROM complex_map WHERE map_contains_value(m, 10);
SELECT case when map_contains_value(m, 15) then 'Exists' else 'Does not exist' end as value_status FROM complex_map WHERE id = 1;
CREATE TABLE nested_map (m MAP<VARCHAR, MAP<VARCHAR, INTEGER>>);
INSERT INTO nested_map VALUES (MAP {'outer1': MAP {'inner1': 1, 'inner2': 2}, 'outer2': MAP {'inner3': 3}});
SELECT map_contains_value(m['outer1'], 2) FROM nested_map;
SELECT map_contains_value((SELECT m FROM nested_map WHERE true LIMIT 1), 1);
SELECT map_contains_value(MAP {'k1': 1, 'k2': 2}, 3) AS result;