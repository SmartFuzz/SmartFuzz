CREATE TABLE test_table (id INTEGER, name VARCHAR);
INSERT INTO test_table VALUES (1, 'test1'), (2, 'test2');
SELECT current_catalog();
WITH catalog_info AS (SELECT current_catalog() AS active_catalog) SELECT * FROM catalog_info;
CREATE TABLE catalog_test (catalog_name VARCHAR);
INSERT INTO catalog_test VALUES (current_catalog());
SELECT a.id, a.name, b.active_catalog FROM test_table a JOIN (SELECT current_catalog() AS active_catalog) b ON a.id = 1;
SELECT current_catalog() AS current_cat WHERE EXISTS (SELECT * FROM test_table);
SELECT current_catalog() AS current_cat FROM (VALUES (1), (2)) AS temp(val);
CREATE VIEW catalog_view AS SELECT current_catalog() AS active_catalog;
SELECT * FROM catalog_view;
SELECT COUNT(*) FROM (SELECT current_catalog() AS catalog FROM test_table) AS derived_count;
SELECT current_catalog() FROM (SELECT id, name FROM test_table ORDER BY id LIMIT 1) AS subquery;
