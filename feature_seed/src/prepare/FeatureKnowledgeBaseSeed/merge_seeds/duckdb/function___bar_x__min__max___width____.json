CREATE TABLE test_data (value FLOAT);
INSERT INTO test_data VALUES (5), (15), (25);
SELECT bar(value, 0, 20, 10) AS bar_output FROM test_data;
SELECT bar(0, 0, 20, 10) AS bar_min_value;
SELECT bar(20, 0, 20, 10) AS bar_max_value;
SELECT bar(10, 10, 10) AS bar_no_width_default;
SELECT bar(5, -10, 30, 20) AS bar_negative_min_positive_range;
SELECT bar(30, 0, 30, 40) AS bar_exceeding_max_and_increasing_width;
SELECT bar(value, 0, 100) AS bar_full_range FROM test_data;
WITH data AS (SELECT value FROM test_data) SELECT bar(value, 0, 20) AS bar_output FROM data;
CREATE TABLE additional_data (x FLOAT, y FLOAT);
INSERT INTO additional_data VALUES (5, 2), (15, 3), (25, 4);
SELECT bar(a.value + b.y, 0, 30, 15) AS combined_bar_output FROM test_data a JOIN additional_data b ON a.value < b.x;
SELECT bar(value, 5, 25, 5) AS bar_custom_width FROM test_data WHERE value > 0;
SELECT bar(5 * value, 0, 100, 20) AS scaled_bar_output FROM test_data;
SELECT DISTINCT bar(value, 0, 50, 30) FROM test_data WHERE value BETWEEN 1 AND 25;