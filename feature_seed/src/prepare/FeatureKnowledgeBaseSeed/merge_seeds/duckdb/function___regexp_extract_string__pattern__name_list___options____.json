CREATE TABLE dates (date_string VARCHAR);
INSERT INTO dates VALUES ('2023-04-15'), ('2022-12-31'), ('2021-01-01');
SELECT regexp_extract(date_string, '(\d+)-(\d+)-(\d+)', ['y', 'm', 'd']) FROM dates;
CREATE TABLE test_data (id INT, input_string VARCHAR);
INSERT INTO test_data VALUES (1, 'abc-123-def'), (2, 'xyz-456-ghi'), (3, 'no-match-here');
SELECT id, regexp_extract(input_string, '([a-z]+)-(\d+)-([a-z]+)', ['part1', 'number', 'part2']) FROM test_data WHERE regexp_extract(input_string, '([a-z]+)-(\d+)-([a-z]+)', ['part1', 'number', 'part2']) IS NOT NULL;
WITH temp AS (SELECT date_string, regexp_extract(date_string, '(\d+)-(\d+)-(\d+)', ['y', 'm', 'd']) AS extracted FROM dates) SELECT extracted.y AS year, extracted.m AS month FROM temp;
CREATE TABLE users (user_id INT, name VARCHAR);
INSERT INTO users VALUES (1, 'John Doe'), (2, 'Jane Doe'), (3, 'Sam Smith');
SELECT user_id, regexp_extract(name, '([A-Za-z]+) ([A-Za-z]+)', ['first_name', 'last_name']) FROM users;
SELECT regexp_extract('test-value=123&test-boolean=true', 'test-value=(\d+)&test-boolean=(true|false)', ['value', 'boolean']) AS result;
SELECT COUNT(*) FROM test_data WHERE regexp_extract(input_string, '(\w+)-(\d+)-(\w+)', ['part1', 'number', 'part3']) IS NOT NULL;
CREATE TABLE data_complexity (data_string VARCHAR);
INSERT INTO data_complexity VALUES ('2023-04-15 xyz'), ('data-2022-12-31 test'), ('not-a-date');
SELECT regexp_extract(data_string, '(\d{4})-(\d{2})-(\d{2})', ['year', 'month', 'day']) FROM data_complexity;