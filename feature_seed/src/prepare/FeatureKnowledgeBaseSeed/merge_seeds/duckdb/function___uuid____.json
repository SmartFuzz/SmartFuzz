CREATE TABLE test_uuids (id UUID, description VARCHAR);
INSERT INTO test_uuids VALUES (uuid(), 'First UUID');
INSERT INTO test_uuids VALUES (uuid(), 'Second UUID');
INSERT INTO test_uuids VALUES (uuid(), 'Third UUID');
SELECT id FROM test_uuids WHERE description LIKE 'First%';
SELECT uuid() AS random_uuid, description FROM test_uuids WHERE id IS NOT NULL;
CREATE TABLE related_table (id INT, uuid_id UUID);
INSERT INTO related_table VALUES (1, uuid());
INSERT INTO related_table VALUES (2, uuid());
SELECT a.id, a.description, b.uuid_id FROM test_uuids AS a JOIN related_table AS b ON uuid() = b.uuid_id;
SELECT COUNT(*) FROM test_uuids WHERE id IN (SELECT uuid() FROM test_uuids);
SELECT (SELECT COUNT(*) FROM test_uuids) AS total_count, uuid() AS unique_uuid;
CREATE TABLE another_table (row_id INT, uuid_col UUID);
INSERT INTO another_table SELECT row_number() OVER (), uuid() FROM test_uuids;
SELECT a.uuid_col, b.description FROM another_table a JOIN test_uuids b ON a.uuid_col = b.id;
SELECT uuid() FROM (SELECT * FROM test_uuids LIMIT 10) AS sub;
SELECT id, uuid() AS new_uuid FROM test_uuids ORDER BY uuid();