CREATE TABLE test_arr (id INTEGER, value FLOAT);
INSERT INTO test_arr VALUES (1, 1.0), (2, 2.0), (3, 3.0);
SELECT array_value(value) FROM test_arr;
SELECT array_value(1.0::FLOAT, 2.0::FLOAT, 3.0::FLOAT) AS arr;
SELECT array_value(COALESCE(v.value, 0), 2.0::FLOAT) FROM test_arr v;
SELECT array_value(value) FROM (SELECT value FROM test_arr WHERE id < 3) AS subquery;
SELECT array_value(t1.val, t2.val) FROM (SELECT value AS val FROM test_arr WHERE id = 1) t1 JOIN (SELECT value AS val FROM test_arr WHERE id = 2) t2;
SELECT array_value(ALL (SELECT value FROM test_arr) ORDER BY id) AS arr_ordered;
CREATE TABLE additional_data (a INTEGER, b FLOAT);
INSERT INTO additional_data VALUES (1, 2.5), (2, 3.5);
SELECT array_value(SELECT value FROM test_arr UNION SELECT b FROM additional_data) as merged_array;
SELECT array_value(1.5::FLOAT, array_value(2.0::FLOAT, 3.5::FLOAT)[]) AS nested_array;
SELECT array_value(value, (SELECT MIN(value) FROM test_arr)) FROM test_arr;
SELECT array_value(1.0, 2.0, 3.0) || array_value(4.0, 5.0) AS combined_array;
CREATE TABLE empty_arr (id INTEGER);
SELECT array_value(value) FROM empty_arr;
SELECT array_value(NULL) AS null_array;