CREATE TABLE timestamps (event_id INT, event_time TIMESTAMP);
INSERT INTO timestamps VALUES (1, '1970-01-01 00:00:00'), (2, '2000-01-01 12:00:00'), (3, '2022-11-07 08:43:04'), (4, '9999-12-31 23:59:59');
SELECT event_id, epoch(event_time) FROM timestamps;
SELECT event_id, epoch(event_time) FROM timestamps WHERE event_time >= '1970-01-01 00:00:00' AND event_time <= '2022-11-07 08:43:04';
SELECT event_id, epoch(event_time) AS epoch_time FROM (SELECT event_id, event_time FROM timestamps WHERE event_id > 1) AS subquery;
CREATE TABLE user_logs (user_id INT, login_time TIMESTAMP);
INSERT INTO user_logs VALUES (101, '2022-12-01 10:00:00'), (102, '2023-01-15 15:30:00');
SELECT ul.user_id, ul.login_time, epoch(ul.login_time) FROM user_logs ul JOIN timestamps t ON ul.user_id = t.event_id;
SELECT event_id, COUNT(*) AS login_count, MAX(epoch(event_time)) AS last_epoch FROM user_logs GROUP BY event_id;
SELECT MAX(epoch(event_time)) FROM timestamps WHERE event_time < (SELECT MIN(login_time) FROM user_logs);
SELECT event_id, epoch(event_time) + 3600 AS adjusted_epoch FROM timestamps WHERE event_id IN (SELECT user_id FROM user_logs);