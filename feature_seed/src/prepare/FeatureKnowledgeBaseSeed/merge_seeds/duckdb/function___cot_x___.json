CREATE TABLE trigonometry_tests (angle FLOAT);
INSERT INTO trigonometry_tests VALUES (0.5), (1), (3.14), (1.5708), (0), (-1), (2), (10);
SELECT angle, cot(angle) FROM trigonometry_tests;
SELECT angle, cot(angle) AS cotangent FROM trigonometry_tests WHERE angle IS NOT NULL;
SELECT angle, cot(angle) FROM trigonometry_tests WHERE angle BETWEEN -10 AND 10;
SELECT angle, cot(angle) FROM trigonometry_tests WHERE angle < 0.1 OR angle > 10;
SELECT angle, cot(angle), cot(angle) * 2 AS double_cotangent FROM trigonometry_tests;
CREATE TABLE advanced_tests (value FLOAT);
INSERT INTO advanced_tests VALUES (10), (20), (30);
SELECT a.angle, cot(a.angle) AS cotangent, b.value FROM trigonometry_tests a JOIN advanced_tests b ON a.angle < b.value;
SELECT a.angle, b.value, cot(a.angle + b.value) FROM trigonometry_tests a, advanced_tests b WHERE a.angle > 0;