CREATE TABLE events (event_name VARCHAR, event_time TIMESTAMPTZ);
INSERT INTO events VALUES ('Conference', TIMESTAMPTZ '1992-09-20 20:38:40'), ('Meeting', TIMESTAMPTZ '1993-10-25 10:15:30');
SELECT datepart('minute', event_time) FROM events;
SELECT event_name, datepart('minute', event_time) AS event_minute FROM events WHERE datepart('minute', event_time) > 30;
CREATE TABLE organizers (organizer_name VARCHAR, event_name VARCHAR);
INSERT INTO organizers VALUES ('Alice', 'Conference'), ('Bob', 'Meeting');
SELECT o.organizer_name, datepart('minute', e.event_time) AS event_minute FROM organizers o JOIN events e ON o.event_name = e.event_name;
SELECT event_name, datepart('hour', event_time) AS event_hour FROM events WHERE datepart('exclude', event_time) <> 0;
WITH event_parts AS (SELECT event_name, datepart('year', event_time) AS event_year, datepart('month', event_time) AS event_month FROM events) SELECT * FROM event_parts WHERE event_year = 1992 AND event_month > 8;
SELECT event_name, datepart('second', event_time) AS event_second FROM events WHERE datepart('hour', event_time) BETWEEN 20 AND 21;
SELECT MAX(datepart('minute', event_time)) AS max_minute FROM events WHERE datepart('year', event_time) = 1992;