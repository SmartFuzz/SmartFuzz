CREATE TABLE test_strings (input_string VARCHAR);
INSERT INTO test_strings VALUES ('hello_world'), ('duckdb_is_great'), ('fuzzy_testing_example'), ('a_b_c_d'), ('regex_test_123'), ('_leading_underscore'), ('trailing_underscore_'), ('no_underscores'), ('multiple__underscores'), ('hello!world!');
SELECT regexp_extract_all(input_string, '([a-z]+)_?', 1) FROM test_strings;
SELECT input_string, regexp_extract_all(input_string, '([a-z]+)_?', 1) AS extracted FROM test_strings WHERE LENGTH(input_string) > 10;
SELECT input_string, regexp_extract_all(input_string, '([a-z]+)_([a-z]+)', 2) AS extracted_group FROM test_strings WHERE input_string LIKE '%_%';
CREATE TABLE test_results AS SELECT input_string, regexp_extract_all(input_string, '([a-z]+)', 0) AS all_matches FROM test_strings;
SELECT input_string, COUNT(*) AS # of matches FROM (SELECT input_string, regexp_extract_all(input_string, '([a-z]+)', 0) AS matches FROM test_strings) AS subquery GROUP BY input_string;
SELECT DISTINCT regexp_extract_all(input_string, '([a-z]+)_?', 1) FROM test_strings ORDER BY input_string;
SELECT t1.input_string, t2.another_string FROM test_strings AS t1 JOIN (SELECT 'extra_data' AS another_string) AS t2 ON LENGTH(t1.input_string) > 10;
SELECT regexp_extract_all(input_string, '([a-z]+)_?', 1) AS extracted FROM (SELECT input_string FROM test_strings WHERE input_string LIKE '%test%') AS filtered;