CREATE TABLE test_rounding (value NUMERIC, decimal_places INTEGER);
INSERT INTO test_rounding VALUES (24.5, 0), (24.5, 1), (24.51, 1), (24.49, 1), (25.5, 0), (25.51, 1), (25.499, 1), (25.5001, 4), (0.005, 2), (0.005, 3), (-0.005, 2);
SELECT value, decimal_places, round_even(value, decimal_places) AS rounded_value FROM test_rounding;
WITH rounded_values AS (SELECT round_even(value, decimal_places) AS rounded_value FROM test_rounding) SELECT rounded_value FROM rounded_values WHERE rounded_value > 24;
SELECT a.value, b.rounded_value FROM (SELECT value, round_even(value, 0) AS rounded_value FROM test_rounding) a JOIN (SELECT value, round_even(value, 1) AS rounded_value FROM test_rounding) b ON a.value = b.value;
CREATE TABLE edge_cases (num NUMERIC, dec_places INTEGER);
INSERT INTO edge_cases VALUES (0, 0), (1.5, 0), (1.5, 1), (2.5, 0), (-1.5, 0), (-1.5, 1), (NULL, 0);
SELECT num, dec_places, round_even(num, dec_places) AS rounded_result FROM edge_cases WHERE num IS NOT NULL;
SELECT round_even(value + (SELECT AVG(value) FROM test_rounding), 1) FROM test_rounding;
SELECT round_even((SELECT MAX(value) FROM test_rounding), -1) AS rounded_negative_place;