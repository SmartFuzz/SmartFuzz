CREATE TABLE time_test (id INTEGER, event_time TIME);
INSERT INTO time_test VALUES (1, TIME '12:00:00'), (2, TIME '23:59:59'), (3, TIME '00:00:00'), (4, TIME '12:30:45.123456');
SELECT * FROM time_test WHERE event_time > TIME '00:00:00' AND event_time < TIME '12:00:00';
SELECT id, event_time FROM time_test WHERE event_time = (SELECT MAX(event_time) FROM time_test);
CREATE TABLE another_table (user_id INTEGER, action_time TIME);
INSERT INTO another_table VALUES (1, TIME '06:15:30'), (2, TIME '15:45:00');
SELECT tt.id, tt.event_time FROM time_test tt JOIN another_table at ON tt.id = at.user_id WHERE at.action_time < ANY (SELECT event_time FROM time_test);
SELECT COUNT(*) FROM time_test WHERE event_time BETWEEN TIME '12:00:00' AND TIME '23:59:59';
SELECT (SELECT MIN(event_time) FROM time_test) AS earliest_time, (SELECT MAX(event_time) FROM time_test) AS latest_time;
DROP TABLE IF EXISTS time_test;
DROP TABLE IF EXISTS another_table;