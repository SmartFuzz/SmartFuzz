CREATE TABLE test_dates (date_column DATE);
INSERT INTO test_dates VALUES (DATE '2022-01-01'), (DATE '2022-01-02'), (DATE '2022-12-31'), (DATE '2023-01-01'), (DATE '2024-01-01'), (DATE '2024-12-31');
SELECT isoyear(date_column) FROM test_dates;
SELECT date_column, isoyear(date_column) FROM test_dates WHERE date_column BETWEEN DATE '2022-01-01' AND DATE '2024-12-31';
SELECT COUNT(*) AS iso_year_count, isoyear(date_column) AS iso_year FROM test_dates GROUP BY iso_year;
SELECT t1.date_column, t2.iso_year FROM (SELECT date_column FROM test_dates) AS t1 INNER JOIN (SELECT date_column, isoyear(date_column) AS iso_year FROM test_dates) AS t2 ON t1.date_column = t2.date_column;
WITH iso_years AS (SELECT date_column, isoyear(date_column) AS iso_year FROM test_dates) SELECT DISTINCT iso_year FROM iso_years ORDER BY iso_year;
SELECT (SELECT COUNT(*) FROM test_dates) AS total_dates, (SELECT COUNT(DISTINCT isoyear(date_column)) FROM test_dates) AS unique_iso_years FROM test_dates;
SELECT d.date_column, d2.date_column, isoyear(d.date_column) AS iso_year FROM test_dates d JOIN test_dates d2 ON isoyear(d.date_column) = isoyear(d2.date_column) WHERE d.date_column < d2.date_column;
CREATE TABLE iso_year_counts AS SELECT isoyear(date_column) AS iso_year, COUNT(*) AS count FROM test_dates GROUP BY iso_year;