CREATE TABLE test_map (id INT, data MAP<INT, INT>);
INSERT INTO test_map VALUES (1, map([100, 200], [42, 43]));
INSERT INTO test_map VALUES (2, map([300], [44]));
INSERT INTO test_map VALUES (3, map([], []));
INSERT INTO test_map VALUES (4, map([1, 2, 3], [10, 20, 30]));
SELECT map_extract(data, 100) FROM test_map WHERE id = 1;
SELECT map_extract(data, 300) FROM test_map WHERE id = 2;
SELECT map_extract(data, 400) FROM test_map WHERE id = 2;
SELECT DISTINCT map_extract(data, 1) FROM test_map WHERE id = 4;
SELECT map_extract(data, 2) as value, id FROM test_map WHERE id IN (1, 4);
SELECT map_extract(data, 200) FROM (SELECT data FROM test_map WHERE id = 1) as subquery;
SELECT id, map_extract(data, 300) FROM test_map WHERE id = (SELECT MIN(id) FROM test_map);
CREATE TABLE another_table (id INT, ref_id INT);
INSERT INTO another_table VALUES (1, 1), (2, 3);
SELECT m.id, map_extract(m.data, a.ref_id) as extracted_value FROM test_map m JOIN another_table a ON m.id = a.ref_id;
SELECT map_extract(data, 1) FROM test_map WHERE data IS NOT NULL;
SELECT map_extract(data, 2) FROM test_map WHERE EXISTS (SELECT 1 FROM test_map WHERE id = 4);