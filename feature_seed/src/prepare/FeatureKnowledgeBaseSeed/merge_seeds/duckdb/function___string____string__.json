CREATE TABLE test_strings (str1 VARCHAR, str2 VARCHAR);
INSERT INTO test_strings VALUES ('Duck', 'DB');
INSERT INTO test_strings VALUES (NULL, 'Example');
INSERT INTO test_strings VALUES ('Hello', NULL);
INSERT INTO test_strings VALUES (NULL, NULL);
SELECT str1 || str2 AS concatenated FROM test_strings;
SELECT (SELECT str1 FROM test_strings WHERE str2 = 'DB') || ' World' AS greeting;
SELECT t1.str1 || ' ' || t2.str2 AS full_name FROM test_strings t1 JOIN test_strings t2 ON t1.str1 = 'Duck' AND t2.str2 = 'DB';
SELECT (SELECT str1 FROM test_strings WHERE str2 IS NOT NULL) || ' concatenated' AS result FROM test_strings LIMIT 1;
CREATE TABLE additional_strings (str VARCHAR);
INSERT INTO additional_strings VALUES ('String1'), ('String2'), (NULL);
SELECT s.str || ' - ' || a.str AS combined FROM additional_strings s JOIN test_strings a ON a.str1 IS NOT NULL;
SELECT (SELECT str1 || ' and ' || str2 FROM test_strings WHERE str1 IS NOT NULL LIMIT 1) AS combined_string;
SELECT STRING_AGG(str1 || str2) AS all_concatenated FROM test_strings WHERE str1 IS NOT NULL;