CREATE TABLE test_dates (event_date DATE);
INSERT INTO test_dates VALUES (DATE '1992-01-01'), (DATE '1992-03-15'), (DATE '1992-04-20'), (DATE '1992-06-10'), (DATE '1992-09-01');
SELECT time_bucket(INTERVAL '1 month', event_date) AS month_bucket FROM test_dates;
SELECT event_date, time_bucket(INTERVAL '1 month', event_date, INTERVAL '2 days') AS month_bucket FROM test_dates ORDER BY event_date;
SELECT event_date, time_bucket(INTERVAL '2 months', event_date) AS bkt FROM test_dates WHERE event_date > DATE '1992-01-15';
CREATE TABLE other_dates (check_date DATE);
INSERT INTO other_dates VALUES (DATE '1992-05-15'), (DATE '1992-06-20'), (DATE '1992-07-25');
SELECT t1.event_date, t2.check_date, time_bucket(INTERVAL '1 month', t1.event_date, INTERVAL '1 week') AS event_month_bucket, time_bucket(INTERVAL '1 month', t2.check_date) AS check_month_bucket FROM test_dates t1 JOIN other_dates t2 ON MONTH(t1.event_date) = MONTH(t2.check_date);
SELECT time_bucket(INTERVAL '3 days', DATE '1992-04-20', INTERVAL '1 day') AS bucketed_date;
SELECT DISTINCT time_bucket(INTERVAL '2 months', event_date) AS bkt FROM test_dates WHERE event_date < DATE '1992-05-01';
SELECT (SELECT time_bucket(INTERVAL '1 month', event_date) FROM test_dates WHERE event_date BETWEEN DATE '1992-01-01' AND DATE '1992-04-30') AS sub_query_bucket;