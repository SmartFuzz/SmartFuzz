CREATE TABLE t1 (id INTEGER, name VARCHAR(50));
INSERT INTO t1 VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');
SELECT * FROM query_table('t1');
CREATE TABLE t2 (id INTEGER, value INTEGER);
INSERT INTO t2 VALUES (1, 100), (2, 200), (3, 300);
SELECT a.id, a.name, b.value FROM query_table('t1') AS a JOIN query_table('t2') AS b ON a.id = b.id;
CREATE TABLE t3 (id INTEGER, description VARCHAR(100));
INSERT INTO t3 VALUES (1, 'Item 1'), (2, 'Item 2'), (3, 'Item 3');
SELECT a.name, (SELECT COUNT(*) FROM query_table('t3') WHERE id = a.id) AS item_count FROM query_table('t1') AS a WHERE a.id IN (SELECT id FROM query_table('t2') WHERE value > 150);
CREATE TABLE t4 (id INTEGER PRIMARY KEY, t1_id INTEGER, t2_id INTEGER, FOREIGN KEY (t1_id) REFERENCES t1(id), FOREIGN KEY (t2_id) REFERENCES t2(id));
INSERT INTO t4 VALUES (1, 1, 3), (2, 2, 1);
SELECT a.name, b.value FROM query_table('t1') AS a JOIN query_table('t4') AS c ON a.id = c.t1_id JOIN query_table('t2') AS b ON c.t2_id = b.id;
CREATE TABLE t5 (id INTEGER, score FLOAT);
INSERT INTO t5 VALUES (1, 85.5), (2, 90.0), (3, 78.0);
SELECT avg(score) FROM query_table('t5') WHERE id IN (SELECT t1_id FROM query_table('t4'));