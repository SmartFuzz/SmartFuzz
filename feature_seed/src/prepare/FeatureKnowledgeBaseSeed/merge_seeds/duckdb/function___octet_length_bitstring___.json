CREATE TABLE test_bitstrings (id INTEGER, b_string BITSTRING);
INSERT INTO test_bitstrings VALUES (1, '1101011'::BITSTRING);
INSERT INTO test_bitstrings VALUES (2, '101010'::BITSTRING);
INSERT INTO test_bitstrings VALUES (3, '1'::BITSTRING);
INSERT INTO test_bitstrings VALUES (4, '110'::BITSTRING);
INSERT INTO test_bitstrings VALUES (5, NULL);
SELECT id, octet_length(b_string) FROM test_bitstrings;
SELECT id, octet_length(b_string) FROM test_bitstrings WHERE b_string IS NOT NULL;
SELECT id, octet_length(b_string) AS length FROM test_bitstrings ORDER BY length DESC;
SELECT id, octet_length(b_string) FROM (SELECT b_string FROM test_bitstrings WHERE id < 4) AS subquery;
CREATE TABLE another_table (bit_key INTEGER PRIMARY KEY, bit_value BITSTRING);
INSERT INTO another_table VALUES (1, '1111'::BITSTRING), (2, '0000'::BITSTRING);
SELECT t.id, octet_length(t.b_string) AS length, a.bit_value FROM test_bitstrings t JOIN another_table a ON t.id = a.bit_key;
WITH cte AS (SELECT b_string FROM test_bitstrings WHERE id > 2) SELECT id, octet_length(b_string) FROM test_bitstrings WHERE b_string IN (SELECT b_string FROM cte);
SELECT COUNT(*) FROM test_bitstrings WHERE octet_length(b_string) = 1;
SELECT octet_length(b_string) AS length FROM test_bitstrings WHERE b_string IS NOT NULL ORDER BY length LIMIT 2;