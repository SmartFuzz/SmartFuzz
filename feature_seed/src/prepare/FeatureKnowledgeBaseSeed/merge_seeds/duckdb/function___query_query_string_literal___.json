CREATE TABLE users (id INT, name VARCHAR);
CREATE TABLE orders (order_id INT, user_id INT, total DECIMAL(10,2));
INSERT INTO users VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');
INSERT INTO orders VALUES (101, 1, 99.99), (102, 1, 199.99), (103, 2, 29.99);
SELECT query('SELECT name FROM users WHERE id IN (SELECT user_id FROM orders WHERE total > 100);
');
SELECT query('SELECT COUNT(*) AS order_count FROM orders WHERE user_id = (SELECT id FROM users WHERE name = ''Alice'');
');
CREATE TABLE products (product_id INT, price DECIMAL(10,2));
INSERT INTO products VALUES (1, 12.50), (2, 35.00), (3, 20.00);
SELECT query('SELECT u.name, sum(o.total) AS total_spent FROM users u JOIN orders o ON u.id = o.user_id GROUP BY u.name HAVING total_spent > 50;
');
SELECT query('SELECT (SELECT AVG(price) FROM products) AS average_price, (SELECT COUNT(*) FROM orders) AS total_orders;
');
CREATE TABLE discounts (discount_id INT, product_id INT, discount_rate DECIMAL(5,2));
INSERT INTO discounts VALUES (1, 1, 0.10), (2, 2, 0.20);
SELECT query('SELECT p.product_id, p.price * (1 - d.discount_rate) AS final_price FROM products p LEFT JOIN discounts d ON p.product_id = d.product_id;
');
SELECT query('WITH UserTotal AS (SELECT user_id, SUM(total) as total_spent FROM orders GROUP BY user_id) SELECT u.name, ut.total_spent FROM users u JOIN UserTotal ut ON u.id = ut.user_id WHERE ut.total_spent > (SELECT AVG(total_spent) FROM UserTotal);
');
SELECT query('SELECT x, (SELECT COUNT(*) FROM orders WHERE user_id = x) AS order_count FROM (SELECT id AS x FROM users);
');