CREATE TABLE timestamps (event_time TIMESTAMP);
INSERT INTO timestamps VALUES (TIMESTAMP '1992-09-20 20:38:48'), (TIMESTAMP '2023-01-01 00:00:00'), (TIMESTAMP '2023-12-31 23:59:59');
SELECT extract('hour' FROM event_time) FROM timestamps;
SELECT event_time, extract('hour' FROM event_time) AS hour_extracted FROM timestamps;
SELECT AVG(extract('hour' FROM event_time)) AS average_hour FROM timestamps;
SELECT e.event_time, e.hour_extracted FROM (SELECT event_time, extract('hour' FROM event_time) AS hour_extracted FROM timestamps) AS e;
CREATE TABLE events (id INT, event_time TIMESTAMP);
INSERT INTO events VALUES (1, TIMESTAMP '1992-09-20 20:38:48'), (2, TIMESTAMP '2023-01-01 00:00:00');
SELECT e.id, extract('hour' FROM e.event_time) AS event_hour FROM events e JOIN timestamps t ON e.event_time = t.event_time;
SELECT document_id, extract('hour' FROM created_at) AS created_hour FROM (SELECT 1 AS document_id, TIMESTAMP '1992-09-20 20:38:48' AS created_at UNION SELECT 2, TIMESTAMP '2023-12-31 23:59:59') AS docs;
SELECT e.id, CASE WHEN extract('hour' FROM e.event_time) < 12 THEN 'Morning' ELSE 'Afternoon' END AS time_of_day FROM events e;
SELECT COUNT(*) AS count_of_mornings FROM (SELECT extract('hour' FROM event_time) AS hour FROM timestamps WHERE extract('hour' FROM event_time) < 12) AS morning_hours;
SELECT DISTINCT extract('hour' FROM event_time) FROM timestamps WHERE extract('hour' FROM event_time) > 5;
CREATE TABLE multi_timestamps (entry_time TIMESTAMP);
INSERT INTO multi_timestamps VALUES (TIMESTAMP '1992-12-31 23:59:59'), (TIMESTAMP '2022-05-15 15:30:55');
SELECT t.entry_time, extract('hour' FROM t.entry_time) AS entry_hour FROM multi_timestamps t UNION SELECT event_time, extract('hour' FROM event_time) FROM timestamps;
SELECT t.event_time, extract('hour' FROM t.event_time) + e.id AS computed_hour FROM events e JOIN timestamps t ON e.event_time = t.event_time;