CREATE TABLE angles (angle_degrees FLOAT);
INSERT INTO angles VALUES (0), (30), (45), (60), (90), (180);
SELECT angle_degrees, tan(RADIANS(angle_degrees)) AS tangent FROM angles;
SELECT angle_degrees, tan(RADIANS(angle_degrees)) AS tangent FROM angles WHERE angle_degrees > 45;
CREATE TABLE results AS SELECT angle_degrees, tan(RADIANS(angle_degrees)) AS tangent FROM angles;
SELECT SUM(tangent) AS total_tangent FROM (SELECT tan(RADIANS(angle_degrees)) AS tangent FROM angles);
SELECT angle_degrees, (SELECT tan(RADIANS(angle_degrees)) FROM angles AS inner_t WHERE inner_t.angle_degrees = angles.angle_degrees) AS tangent FROM angles;
CREATE TABLE angles_joined AS SELECT a.angle_degrees, b.angle_degrees AS angle_degrees_b FROM angles a JOIN angles b ON a.angle_degrees < b.angle_degrees;
SELECT a.angle_degrees, tan(RADIANS(a.angle_degrees)) AS tangent_a, tan(RADIANS(b.angle_degrees)) AS tangent_b FROM angles a JOIN angles b ON a.angle_degrees < b.angle_degrees;
SELECT angle_degrees, tan(RADIANS((SELECT angle_degrees FROM angles LIMIT 1 OFFSET 1))) AS ref_tangent FROM angles;