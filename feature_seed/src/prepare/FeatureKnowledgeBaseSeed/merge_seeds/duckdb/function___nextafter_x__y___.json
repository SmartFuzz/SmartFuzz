CREATE TABLE test_values (x FLOAT, y FLOAT);
INSERT INTO test_values VALUES (1.0, 2.0), (3.4, 4.5), (5.0, 5.0), (0.0, -1.0), (-3.0, -2.0);
SELECT nextafter(x, y) FROM test_values;
SELECT x, y, nextafter(x, y) as next_value FROM test_values WHERE nextafter(x, y) < 2.0;
SELECT a.x, b.y, nextafter(a.x, b.y) as next_value FROM test_values a JOIN test_values b ON a.x < b.y;
CREATE TABLE results AS SELECT nextafter(1.0, 2.0) AS result;
SELECT result FROM results;
WITH recursive test AS (SELECT 0.1 AS x UNION ALL SELECT nextafter(x, 1.0) FROM test WHERE x < 1.0) SELECT x FROM test;
SELECT x, nextafter(x, -3.0) AS next_value FROM test_values WHERE x > -3.0;
SELECT nextafter((SELECT AVG(x) FROM test_values), (SELECT MAX(y) FROM test_values));