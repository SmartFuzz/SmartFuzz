CREATE TABLE numbers (id INTEGER, value INTEGER);
INSERT INTO numbers VALUES (1, 5), (2, 2), (3, 10), (4, 3);
SELECT value // 2 AS divided_value FROM numbers;
SELECT (value + 1) // (value - 1) AS adjusted_division FROM numbers;
SELECT id, value, (value // 2) AS half_value FROM numbers WHERE value > 0;
SELECT (SELECT MAX(value) FROM numbers) // (SELECT MIN(value) FROM numbers) AS boundary_division;
WITH derived AS (SELECT id, value // 2 AS half_value FROM numbers) SELECT * FROM derived WHERE half_value > 1;
SELECT n1.id, n1.value // n2.value AS division_result FROM numbers n1 JOIN numbers n2 ON n1.id <> n2.id;
SELECT id, COUNT(*) AS count, (SUM(value) // COUNT(*)) AS average_division FROM numbers GROUP BY id;
SELECT id, (CAST(value AS FLOAT) // 2) AS float_division FROM numbers;