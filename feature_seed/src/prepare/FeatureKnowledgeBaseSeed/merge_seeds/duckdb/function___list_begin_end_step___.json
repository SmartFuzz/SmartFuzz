CREATE TABLE test_list (id INTEGER, nums LIST<INTEGER>);
INSERT INTO test_list VALUES (1, [1, 2, 3, 4, 5, 6]), (2, [10, 20, 30, 40, 50, 60]);
SELECT nums[:-:2] FROM test_list WHERE id = 1;
SELECT nums[:-1:2] FROM test_list WHERE id = 2;
SELECT nums[1:5:1] FROM test_list WHERE id = 1;
SELECT nums[:3:1] FROM test_list;
SELECT nums[2:-:1] FROM test_list WHERE id = 1;
SELECT nums[2:5:3] FROM test_list WHERE id = 2;
SELECT nums[::2] FROM test_list WHERE id = 1;
WITH subquery AS (SELECT nums FROM test_list WHERE id = 1) SELECT nums[:-:1] FROM subquery;
CREATE TABLE other_nums (id INTEGER, more_nums LIST<INTEGER>);
INSERT INTO other_nums VALUES (1, [7, 8, 9]), (2, [3, 4, 5]);
SELECT t1.nums, t2.more_nums[:-:1] FROM test_list t1 JOIN other_nums t2 ON t1.id = t2.id;
SELECT COUNT(*) FROM (SELECT nums[:-:2] FROM test_list) AS sliced;
SELECT SUM(UNNEST(nums[:-:1])) FROM test_list WHERE id = 1;