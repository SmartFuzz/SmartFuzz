CREATE TABLE test_list (id INT, values LIST<INT>);
INSERT INTO test_list VALUES (1, [NULL, -3]), (2, [4, 5]), (3, [NULL, NULL]), (4, [7, NULL]), (5, [NULL, 6]);
SELECT id, list_any_value(values) FROM test_list;
SELECT id, list_any_value(values) AS any_value FROM test_list WHERE id = 2;
SELECT id, list_any_value(values) AS any_value FROM test_list WHERE any_value IS NOT NULL;
CREATE TABLE additional_list (id INT, more_values LIST<INT>);
INSERT INTO additional_list VALUES (1, [NULL, 2]), (2, [NULL, NULL]), (3, [3, 4]);
SELECT a.id, list_any_value(a.values) AS list_value, list_any_value(b.more_values) AS more_value FROM test_list a JOIN additional_list b ON a.id = b.id;
SELECT list_any_value(list_any_value(values)) AS nested_value FROM (SELECT values FROM test_list) AS subquery;
WITH cte AS (SELECT values FROM test_list WHERE id <= 3) SELECT list_any_value(values) FROM cte;
SELECT id, list_any_value(COALESCE(values, [0])) AS coalesced_value FROM test_list;