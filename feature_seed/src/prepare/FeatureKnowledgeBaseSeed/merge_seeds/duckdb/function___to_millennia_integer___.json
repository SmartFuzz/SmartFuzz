CREATE TABLE test_table (id INTEGER);
INSERT INTO test_table VALUES (1), (2), (3), (4), (5);
SELECT to_millennia(id) AS millennium_interval FROM test_table;
CREATE TABLE data_table (value INTEGER);
INSERT INTO data_table VALUES (0), (1), (999), (1000), (5000);
SELECT value, to_millennia(value) AS millennium_interval FROM data_table WHERE value >= 0;
CREATE TABLE years_table (year INTEGER);
INSERT INTO years_table VALUES (2000), (2500), (3000), (3500);
SELECT year, to_millennia(year / 1000) AS millennium_interval FROM years_table;
CREATE TABLE nested_table (millennia_id INTEGER PRIMARY KEY);
INSERT INTO nested_table SELECT DISTINCT to_millennia(id) FROM test_table;
SELECT n.millennium_id, COUNT(*) AS count FROM nested_table n JOIN test_table t ON n.millennium_id = to_millennia(t.id) GROUP BY n.millennium_id;
WITH millennia_data AS (SELECT id, to_millennia(id) AS millennium_interval FROM test_table) SELECT millennium_interval, COUNT(*) FROM millennia_data GROUP BY millennium_interval;
CREATE TABLE combined_table (num INTEGER);
INSERT INTO combined_table VALUES (10), (20), (100), (1000);
SELECT cb.num, to_millennia(cb.num / 1000) AS millennium_interval FROM combined_table cb WHERE cb.num < 5000;
SELECT DISTINCT to_millennia(value) AS millennium_interval FROM data_table WHERE value BETWEEN 0 AND 10000;
CREATE TABLE full_join_table (a INTEGER, b INTEGER);
INSERT INTO full_join_table VALUES (1, 10), (2, 20), (3, 30);
SELECT a, b, to_millennia(a) AS millennia_a, to_millennia(b) AS millennia_b FROM full_join_table;