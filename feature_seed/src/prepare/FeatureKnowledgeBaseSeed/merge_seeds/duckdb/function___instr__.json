CREATE TABLE test_strings (id INTEGER, text STRING);
INSERT INTO test_strings VALUES (1, 'hello world'), (2, 'this is a test'), (3, 'test test test'), (4, 'abc es def'), (5, 'no match here');
SELECT strpos(text, 'test') FROM test_strings WHERE id = 1;
SELECT strpos(text, 'es') FROM test_strings WHERE id = 4;
SELECT strpos(text, 'notfound') FROM test_strings WHERE id = 2;
SELECT id, text, strpos(text, 'test') AS position FROM test_strings WHERE position > 0;
SELECT id, text, strpos(text, 'hello') AS position FROM (SELECT * FROM test_strings WHERE id = 1) AS subquery;
SELECT t1.id, t2.text, strpos(t2.text, 'test') FROM test_strings AS t1 JOIN test_strings AS t2 ON t1.id <> t2.id;
SELECT id, text, strpos(text, ' ') AS first_space FROM test_strings;
SELECT id, text, strpos(text, text) AS self_match FROM test_strings;
CREATE TABLE additional_strings (id INTEGER, more_text STRING);
INSERT INTO additional_strings VALUES (1, 'nested query test'), (2, 'another test case');
SELECT t1.id, strpos(t1.text, substr(t2.more_text, 1, 4)) FROM test_strings AS t1 JOIN additional_strings AS t2 ON t1.id = t2.id;
SELECT id, strpos(text, 't') + strpos(text, 'e') AS combined_positions FROM test_strings;
SELECT id, text, CASE WHEN strpos(text, 'test') > 0 THEN 'Found' ELSE 'Not Found' END AS test_result FROM test_strings WHERE text IS NOT NULL;
SELECT COUNT(*) FROM test_strings WHERE strpos(text, 't') >= 1;
SELECT DISTINCT strpos(text, 'es') FROM test_strings WHERE text LIKE '%es%';