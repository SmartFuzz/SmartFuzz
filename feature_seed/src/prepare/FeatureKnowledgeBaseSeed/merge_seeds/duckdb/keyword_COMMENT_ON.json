CREATE TABLE test_table (id INTEGER, name VARCHAR);
COMMENT ON TABLE test_table IS 'This is a test table with metadata';
COMMENT ON COLUMN test_table.id IS 'This column holds unique identifiers';
COMMENT ON COLUMN test_table.name IS 'This column stores names';
CREATE VIEW test_view AS SELECT * FROM test_table;
COMMENT ON VIEW test_view IS 'This view selects all data from the test_table';
CREATE INDEX test_index ON test_table(name);
COMMENT ON INDEX test_index IS 'This index is on the name column of test_table';
CREATE SEQUENCE test_sequence START WITH 1 INCREMENT BY 1;
COMMENT ON SEQUENCE test_sequence IS 'This sequence generates unique numbers';
CREATE TYPE test_type AS ENUM ('type1', 'type2');
COMMENT ON TYPE test_type IS 'This is an enumerated type for categorization';
CREATE MACRO test_macro(arg1 INTEGER) AS SELECT arg1 + 1;
COMMENT ON MACRO test_macro IS 'This macro increments input by 1';
CREATE MACRO TABLE test_table_macro AS SELECT * FROM test_table;
COMMENT ON MACRO TABLE test_table_macro IS 'This is a macro table based on test_table';
COMMENT ON TABLE test_table IS NULL;
SELECT comment FROM duckdb_tables();
SELECT comment FROM duckdb_columns();
SELECT comment FROM duckdb_views();
SELECT comment FROM duckdb_indexes();
SELECT comment FROM duckdb_sequences();
SELECT comment FROM duckdb_types();
SELECT comment FROM duckdb_functions();
COMMENT ON TABLE test_table IS 'This is the updated comment after testing';
CREATE TABLE another_table (id INTEGER, description VARCHAR);
COMMENT ON TABLE another_table IS 'Table for testing comments on multiple tables';
CREATE VIEW another_view AS SELECT description FROM another_table WHERE id > 0;
COMMENT ON VIEW another_view IS 'Another view that selects from another_table';
COMMENT ON COLUMN another_table.description IS 'Stores description text';
CREATE INDEX another_index ON another_table(description);
COMMENT ON INDEX another_index IS 'Index on description column of another_table';
CREATE SEQUENCE another_sequence START WITH 1;
COMMENT ON SEQUENCE another_sequence IS 'Sequence for generating IDs';
COMMENT ON TYPE test_type IS NULL;