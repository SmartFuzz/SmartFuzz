CREATE TABLE test_decimals (id INT, value DECIMAL(3, 2));
INSERT INTO test_decimals VALUES (1, 1.23);
INSERT INTO test_decimals VALUES (2, 12.34);
INSERT INTO test_decimals VALUES (3, 0.01);
INSERT INTO test_decimals VALUES (4, 123.45);
SELECT * FROM test_decimals WHERE value < 1.3;
SELECT id, value * 2 AS doubled_value FROM test_decimals;
SELECT id, value + 0.77 AS increased_value FROM test_decimals;
SELECT id FROM test_decimals WHERE value BETWEEN 1.0 AND 1.5;
CREATE TABLE test_joins (id INT, reference DECIMAL(5, 2));
INSERT INTO test_joins VALUES (1, 3.14);
INSERT INTO test_joins VALUES (2, 2.71);
SELECT a.id, a.value, b.reference FROM test_decimals a JOIN test_joins b ON a.id = b.id;
SELECT COUNT(*) FROM test_decimals WHERE value IS NOT NULL;
SELECT MAX(value) FROM test_decimals;
CREATE TABLE performance_test (num DECIMAL(30, 15));
INSERT INTO performance_test VALUES (123456789012345.678901234567890);
INSERT INTO performance_test VALUES (0.000000000000001);
SELECT SUM(num) FROM performance_test;
SELECT AVG(num) FROM performance_test;
CREATE TABLE overflow_test (num DECIMAL(2, 1));
INSERT INTO overflow_test VALUES (9.9);
INSERT INTO overflow_test VALUES (99.1);
SELECT * FROM overflow_test WHERE num > 10;
CREATE TABLE mixed_operations (id INT, value1 DECIMAL(10, 5), value2 DECIMAL(10, 5));
INSERT INTO mixed_operations VALUES (1, 5.12345, 2.98765);
SELECT id, value1 + value2 AS total FROM mixed_operations;
SELECT id, value1 * 2 AS double_value FROM mixed_operations;
SELECT id, (value1 + value2) * 2 AS doubled_total FROM mixed_operations;
SELECT id, ROUND(value1 / value2, 2) AS rounded_division FROM mixed_operations;