CREATE DATABASE memory;
CREATE DATABASE duck;
CREATE SCHEMA main;
CREATE TABLE duck.main.users (id INTEGER, name STRING);
CREATE TABLE memory.data (value INTEGER);
INSERT INTO duck.main.users VALUES (1, 'Alice');
INSERT INTO memory.data VALUES (100);
USE memory;
SELECT * FROM memory.data;
USE duck.main;
SELECT * FROM duck.main.users;
USE main;
SELECT * FROM duck.main.users WHERE id = (SELECT MAX(id) FROM duck.main.users);
USE duck.main;
CREATE TABLE new_table AS SELECT * FROM duck.main.users WHERE id < 2;
USE memory;
CREATE TABLE joined_data AS SELECT a.value, b.name FROM memory.data a JOIN duck.main.users b ON a.value = b.id;
USE memory;
CREATE SCHEMA temp;
USE temp;
CREATE TABLE temp.temp_table (col1 INTEGER, col2 STRING);
INSERT INTO temp.temp_table SELECT value, 'Test' FROM memory.data;
USE duck.main;
CREATE TABLE complex_table AS SELECT u.name, d.value FROM duck.main.users u JOIN memory.data d ON u.id <= d.value;