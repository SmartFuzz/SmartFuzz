CREATE TABLE test_table_1 (value FLOAT);
INSERT INTO test_table_1 VALUES (1.0), (2.0), (3.0), (NULL), (4.0);
SELECT product(value) FROM test_table_1;
CREATE TABLE test_table_2 (category TEXT, amount FLOAT);
INSERT INTO test_table_2 VALUES ('A', 10.0), ('A', NULL), ('B', 20.0), ('B', 30.0);
SELECT category, product(amount) FROM test_table_2 GROUP BY category;
CREATE TABLE test_table_3 (id INT, value FLOAT);
INSERT INTO test_table_3 VALUES (1, 2.0), (2, NULL), (3, 4.0), (4, 5.0);
SELECT product(value + 1) FROM test_table_3;
CREATE TABLE test_table_4 (a INT, b FLOAT);
INSERT INTO test_table_4 VALUES (1, NULL), (2, 3.0), (3, 0.0), (4, 2.0);
SELECT product(b) FROM test_table_4 WHERE a < 3;
CREATE TABLE test_table_5 (group_id INT, value FLOAT);
INSERT INTO test_table_5 VALUES (1, 1.0), (1, NULL), (2, 2.0), (2, 3.0);
SELECT group_id, product(value) FROM test_table_5 GROUP BY group_id UNION SELECT 3, product(value) FROM test_table_5 WHERE group_id = 3;
CREATE TABLE test_table_6 (x FLOAT, y FLOAT);
INSERT INTO test_table_6 VALUES (1.5, 2.0), (2.5, 3.0), (NULL, 4.0);
SELECT product(x) * product(y) FROM test_table_6;