CREATE SEQUENCE seq_start_1 START 1;
CREATE SEQUENCE seq_start_100 START 100;
CREATE SEQUENCE seq_increment_by_3 START 1 INCREMENT BY 3;
CREATE SEQUENCE seq_descending START 99 INCREMENT BY -1;
CREATE SEQUENCE seq_max_value START 1 MAXVALUE 10;
CREATE SEQUENCE seq_cycle START 1 CYCLE;
CREATE OR REPLACE SEQUENCE seq_replace START 1;
CREATE SEQUENCE IF NOT EXISTS seq_if_not_exists;
DROP SEQUENCE seq_to_drop;
DROP SEQUENCE IF EXISTS seq_if_exist;
CREATE SEQUENCE id_seq START 1;
CREATE TABLE test_table (id INTEGER PRIMARY KEY DEFAULT nextval('id_seq'), name VARCHAR);
INSERT INTO test_table (name) VALUES ('Alice'), ('Bob');
CREATE TABLE another_table (name VARCHAR);
INSERT INTO another_table VALUES ('Charlie'), ('David');
CREATE SEQUENCE seq_alter_table START 1;
ALTER TABLE another_table ADD COLUMN id INTEGER DEFAULT nextval('seq_alter_table');
SELECT * FROM another_table;
CREATE SEQUENCE seq_nextval START 1;
SELECT nextval('seq_nextval') AS next_num;
INSERT INTO another_table VALUES (nextval('seq_nextval'), 'Eve');
CREATE SEQUENCE seq_currval START 1;
SELECT nextval('seq_currval') AS num;
SELECT currval('seq_currval') AS current_num;
CREATE SEQUENCE seq_drop_cascade START 1;
CREATE TABLE drop_seq_table (id INTEGER DEFAULT nextval('seq_drop_cascade'), info VARCHAR);
ALTER TABLE drop_seq_table DROP COLUMN id;
DROP SEQUENCE seq_drop_cascade CASCADE;