CREATE TABLE test_intervals (id INTEGER, weeks INTEGER);
INSERT INTO test_intervals VALUES (1, 5);
INSERT INTO test_intervals VALUES (2, 10);
INSERT INTO test_intervals VALUES (3, -1);
INSERT INTO test_intervals VALUES (4, 0);
SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals;
SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals WHERE weeks > 0;
SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals WHERE weeks < 0;
SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals ORDER BY week_interval DESC;
CREATE TABLE additional_data (id INTEGER, weeks INTEGER);
INSERT INTO additional_data VALUES (1, 15);
INSERT INTO additional_data VALUES (2, 20);
SELECT a.id, to_weeks(a.weeks) AS week_interval_a, to_weeks(b.weeks) AS week_interval_b FROM test_intervals a JOIN additional_data b ON a.id = 1;
SELECT id, to_weeks(weeks) AS week_interval FROM (SELECT weeks FROM test_intervals WHERE id >= 1) AS subquery;
WITH week_data AS (SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals WHERE weeks > 0) SELECT * FROM week_data WHERE week_interval < to_weeks(10);
SELECT a.id, to_weeks(a.weeks) AS week_interval_a, AVG(b.weeks) AS avg_weeks FROM test_intervals a LEFT JOIN additional_data b ON a.id = b.id GROUP BY a.id;
CREATE TABLE interval_summary AS SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals;
SELECT COUNT(*) AS count_positive_weeks FROM test_intervals WHERE weeks > 0;
SELECT id, to_weeks(weeks) AS week_interval FROM test_intervals ORDER BY week_interval LIMIT 2;