CREATE TABLE test_table (id INTEGER, value FLOAT);
INSERT INTO test_table VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, 40.0), (5, 50.0);
SELECT max(value, 2) FROM test_table;
SELECT max(value, 3) FROM test_table;
SELECT max(value, 1) FROM test_table WHERE id > 2;
SELECT max(t.value, 2) FROM (SELECT value FROM test_table WHERE id <= 3) AS t;
CREATE TABLE additional_table (group_id INTEGER, group_value FLOAT);
INSERT INTO additional_table VALUES (1, 15.0), (2, 25.0), (3, 35.0);
SELECT max(t.value, 2) FROM test_table t JOIN additional_table a ON t.id = a.group_id;
SELECT max(t.value, 2) FROM (SELECT value FROM test_table UNION SELECT group_value FROM additional_table) AS t;
SELECT max(value, 2) FROM (SELECT value FROM test_table WHERE value < 30) AS sub;
CREATE TABLE complex_table (col1 INTEGER, col2 FLOAT, col3 INTEGER);
INSERT INTO complex_table VALUES (1, 10.0, 1), (2, 20.0, 2), (3, 30.0, 3), (4, 40.0, 4), (5, 50.0, 5);
SELECT max(col2, 3) FROM complex_table WHERE col1 IN (SELECT group_id FROM additional_table);
SELECT max(value, 2) FROM (SELECT value FROM test_table WHERE value > 5) AS subquery WHERE EXISTS (SELECT 1 FROM additional_table WHERE group_id = 1);