CREATE TABLE time_test (id INT, event_time TIME, event_timetz TIMETZ);
INSERT INTO time_test VALUES (1, TIME '11:30:00.123456', TIMETZ '11:30:00.123456+00');
INSERT INTO time_test VALUES (2, TIME '23:59:59.999999', TIMETZ '23:59:59.999999-10:00');
INSERT INTO time_test VALUES (3, TIME '00:00:00.000000', TIMETZ '00:00:00.000000+05:30');
CREATE TABLE events (event_id INT, event_time TIMESTAMP);
INSERT INTO events VALUES (1, TIMESTAMP '1992-09-20 11:30:00.123456');
INSERT INTO events VALUES (2, TIMESTAMP '1992-09-20 23:59:59.999999');
INSERT INTO events VALUES (3, TIMESTAMP '1992-09-20 00:00:00.000000');
SELECT event_time FROM time_test WHERE event_time > TIME '10:00:00';
SELECT event_timetz FROM time_test WHERE event_timetz < TIMETZ '20:00:00-02:00';
SELECT id, event_time FROM time_test WHERE event_time BETWEEN TIME '10:00:00' AND TIME '12:00:00';
SELECT t1.id, t1.event_time, t2.event_time FROM time_test t1 JOIN events t2 ON t1.id = t2.event_id WHERE t1.event_time < TIME '12:00:00';
SELECT event_timetz, (event_timetz AT TIME ZONE 'UTC') AS utc_time FROM time_test;
SELECT (?::TIME + event_time) FROM time_test, (SELECT TIME '00:30:00' AS add_time) AS temp;
SELECT COUNT(*) FROM time_test WHERE EXTRACT(HOUR FROM event_timetz) = 11;
SELECT IF(event_time IS NULL, 'Not Specified', event_time) AS time_status FROM time_test;
SELECT DISTINCT event_time FROM time_test ORDER BY event_time DESC LIMIT 5;
CREATE VIEW morning_events AS SELECT id, event_time FROM time_test WHERE event_time < TIME '12:00:00';
SELECT * FROM morning_events;
DROP TABLE IF EXISTS temp_time_test;
CREATE TABLE temp_time_test AS SELECT event_time, COUNT(*) FROM time_test GROUP BY event_time;