SET memory_limit = '500MB';
SET threads = 2;
SET SESSION default_collation = 'utf8';
RESET memory_limit;
SET GLOBAL sort_order = 'asc';
RESET threads;
SET threads TO 4;
SELECT current_setting('memory_limit');
SET GLOBAL memory_limit = '20GB';
SET SESSION sort_order = 'desc';
CREATE TABLE test_table (id INTEGER, name VARCHAR);
INSERT INTO test_table (id, name) VALUES (1, 'Alice');
INSERT INTO test_table (id, name) VALUES (2, 'Bob');
SELECT * FROM test_table WHERE id < 3;
SET GLOBAL threads = (SELECT COUNT(*) FROM test_table);
SET default_collation = (SELECT current_setting('default_collation'));
CREATE TABLE config_test (config_name VARCHAR, config_value VARCHAR);
INSERT INTO config_test VALUES ('memory_limit', (SELECT current_setting('memory_limit')));
SELECT * FROM config_test WHERE config_value = '10GB';
SET memory_limit = (SELECT AVG(config_value) FROM config_test WHERE config_name = 'memory_limit');
RESET default_collation;
SELECT current_setting('sort_order') UNION SELECT current_setting('threads');