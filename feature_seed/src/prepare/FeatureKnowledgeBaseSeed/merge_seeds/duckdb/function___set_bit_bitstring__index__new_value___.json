CREATE TABLE bitstrings (id INT, bitstring BITSTRING);
INSERT INTO bitstrings VALUES (1, '0110010'::BITSTRING), (2, '1111111'::BITSTRING), (3, '0000000'::BITSTRING);
SELECT set_bit(bitstring, 0, 1) FROM bitstrings WHERE id = 1;
SELECT set_bit(bitstring, 1, 0) FROM (SELECT bitstring FROM bitstrings WHERE id = 2) AS temp;
SELECT set_bit(bitstring, 6, 1) FROM bitstrings WHERE id IN (1, 2);
SELECT set_bit(set_bit(bitstring, 2, 0), 4, 1) FROM bitstrings ORDER BY id;
SELECT id, set_bit(bitstring, 3, (CASE WHEN id = 1 THEN 1 ELSE 0 END)) FROM bitstrings;
CREATE TABLE new_bitstrings AS SELECT id, set_bit(bitstring, 2, 1) AS new_value FROM bitstrings;
SELECT nb.id, nb.new_value, set_bit(nb.new_value, 5, 0) FROM new_bitstrings nb WHERE nb.id = 3;
WITH updated_bitstrings AS (SELECT id, set_bit(bitstring, 1, 1) AS modified FROM bitstrings) SELECT * FROM updated_bitstrings WHERE modified != bitstring;