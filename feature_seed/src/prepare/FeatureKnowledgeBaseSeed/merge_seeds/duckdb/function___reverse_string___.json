CREATE TABLE test_strings (id INT, original_string VARCHAR);
INSERT INTO test_strings VALUES (1, 'hello'), (2, 'DuckDB'), (3, '');
SELECT reverse(original_string) FROM test_strings WHERE id = 1;
SELECT id, reverse(original_string) AS reversed_string FROM test_strings;
SELECT id, reverse(original_string) FROM test_strings WHERE LENGTH(original_string) > 0;
SELECT id, reverse(original_string) AS reversed_string FROM test_strings WHERE id IN (SELECT id FROM test_strings WHERE LENGTH(original_string) > 0);
CREATE TABLE more_strings (id INT, additional_string VARCHAR);
INSERT INTO more_strings VALUES (1, 'world'), (2, 'DBDuck'), (3, 'Testing');
SELECT ts.id, reverse(ts.original_string) AS reversed, ms.additional_string FROM test_strings ts JOIN more_strings ms ON ts.id = ms.id;
SELECT id, reverse(CONCAT(original_string, ' ', additional_string)) AS full_reversed FROM test_strings ts JOIN more_strings ms ON ts.id = ms.id;
SELECT reverse(original_string) FROM test_strings WHERE CHAR_LENGTH(original_string) < 5;
SELECT reverse(NULLIF(original_string, '')) FROM test_strings;
SELECT reverse(COALESCE(original_string, 'default')) AS reversed_default FROM test_strings;