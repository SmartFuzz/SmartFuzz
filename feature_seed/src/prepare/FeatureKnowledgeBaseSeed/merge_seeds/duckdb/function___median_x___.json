CREATE TABLE numbers (value FLOAT);
INSERT INTO numbers VALUES (1), (2), (3), (4), (5);
SELECT median(value) FROM numbers;
CREATE TABLE even_numbers (value FLOAT);
INSERT INTO even_numbers VALUES (1), (2), (3), (4);
SELECT median(value) FROM even_numbers;
CREATE TABLE mixed_values (id INT, value FLOAT);
INSERT INTO mixed_values VALUES (1, 1.5), (2, 2.5), (3, 3.5), (4, 4.5), (5, 5.5);
SELECT id, median(value) OVER() AS median_value FROM mixed_values;
CREATE TABLE subquery_test AS SELECT value FROM numbers WHERE value > 0;
SELECT median(value) FROM (SELECT value FROM subquery_test);
CREATE TABLE test_joins1 (id INT, value FLOAT);
INSERT INTO test_joins1 VALUES (1, 5), (2, 10);
CREATE TABLE test_joins2 (id INT, value FLOAT);
INSERT INTO test_joins2 VALUES (1, 3), (2, 7);
SELECT median(t1.value + t2.value) FROM test_joins1 t1 JOIN test_joins2 t2 ON t1.id = t2.id;
CREATE TABLE large_values (value FLOAT);
INSERT INTO large_values SELECT 1.0 * i FROM range(1, 1000) AS i;
SELECT median(value) FROM large_values;
CREATE TABLE nested_table AS SELECT value FROM (SELECT value FROM numbers WHERE value >= 0);
SELECT median(value) FROM nested_table;
SELECT median(value) FROM (SELECT value FROM (SELECT value FROM mixed_values) AS temp);