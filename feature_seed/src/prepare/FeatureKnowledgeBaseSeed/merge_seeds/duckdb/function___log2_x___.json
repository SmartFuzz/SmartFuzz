CREATE TABLE test_values (value FLOAT);
INSERT INTO test_values VALUES (1), (2), (4), (8), (16), (0.5), (0), (-1);
SELECT value, log2(value) AS log2_value FROM test_values WHERE value > 0;
SELECT value, log2(value) AS log2_value FROM test_values WHERE value < 1;
SELECT AVG(log2(value)) FROM test_values WHERE value > 0;
SELECT MAX(log2(value)) FROM (SELECT value FROM test_values WHERE value > 0) AS sub;
SELECT t1.value, t2.value, log2(t1.value + t2.value) AS sum_log2 FROM test_values t1 JOIN test_values t2 ON t1.value < t2.value;
WITH log_values AS (SELECT value, log2(value) AS log_value FROM test_values WHERE value > 0) SELECT AVG(log_value) FROM log_values;
CREATE TABLE another_table (id INT, value FLOAT);
INSERT INTO another_table VALUES (1, 4), (2, 16), (3, 32);
SELECT a.id, log2(a.value) AS log2_value, log2(b.value) AS log2_other_value FROM another_table a JOIN test_values b ON a.id = (b.value / 2) WHERE b.value > 0;
SELECT log2(COALESCE(NULLIF(MAX(value), 0), 1)) FROM test_values;