CREATE TABLE lineitem (l_orderkey INTEGER, l_partkey INTEGER, l_quantity INTEGER, l_extendedprice FLOAT, l_discount FLOAT, l_tax FLOAT, l_returnflag CHAR(1), l_linestatus CHAR(1), l_shipdate DATE, l_commitdate DATE, l_receiptdate DATE, l_shipinstruct VARCHAR, l_shipmode VARCHAR, l_comment VARCHAR);
COPY lineitem FROM 'lineitem.csv' (DELIMITER ',', HEADER true);
COPY lineitem FROM 'lineitem_pipe.txt' (DELIMITER '|', HEADER false);
COPY lineitem FROM 'lineitem.parquet' (FORMAT parquet);
COPY lineitem FROM 'lineitem.json' (FORMAT json, AUTO_DETECT true);
INSERT INTO lineitem VALUES (1, 1, 5, 100.0, 0.05, 0.1, 'N', 'O', '2021-01-01', '2021-01-02', '2021-01-03', 'DELIVER IN PERSON', 'AIR', 'Some comment here');
COPY (SELECT l_orderkey, l_partkey FROM lineitem WHERE l_quantity > 0) TO 'positive_quantity.csv' (DELIMITER ',', HEADER true);
CREATE TABLE category (id INTEGER, name VARCHAR);
INSERT INTO category VALUES (1, 'Electronics'), (2, 'Books'), (3, 'Clothing');
COPY (SELECT c.name, COUNT(l.l_orderkey) AS order_count FROM category c JOIN lineitem l ON c.id = l.l_partkey GROUP BY c.name) TO 'category_order_count.csv' (DELIMITER ',', HEADER true);
COPY (SELECT l_orderkey, l_extendedprice FROM lineitem WHERE l_discount < 0.05 ORDER BY l_extendedprice DESC) TO 'discounted_orders.csv' (DELIMITER ',', HEADER true);
COPY lineitem TO 'lineitem_copy.csv' (FORMAT csv, HEADER true);
SET VARIABLE source_file = 'lineitem.json';
COPY lineitem FROM (getvariable('source_file'));
COPY (SELECT l_orderkey, l_partkey FROM lineitem WHERE l_quantity IS NULL) TO 'null_quantity.csv' (DELIMITER ',', HEADER false);
CREATE TABLE another_lineitem (key INTEGER, value FLOAT);
COPY another_lineitem FROM 'another_lineitem.csv' (DELIMITER ',', HEADER true);
COPY (SELECT l_orderkey || '-' || l_partkey AS key_value FROM lineitem) TO 'key_value.csv' (DELIMITER ',', HEADER true);
ALTER TABLE lineitem ADD COLUMN l_comment_long TEXT;
COPY (SELECT l_orderkey, l_partkey, l_comment_long FROM lineitem) TO 'full_lineitem.csv' (DELIMITER ',', HEADER true);
ATTACH 'db1.db' AS db1;
ATTACH 'db2.db' AS db2;
COPY FROM DATABASE db1 TO db2;
COPY (SELECT 'Hello' AS message, CURRENT_DATE AS date) TO 'greeting.json' (FORMAT json, ARRAY false);
COPY (SELECT l_orderkey, l_partkey FROM lineitem WHERE l_tax BETWEEN 0.05 AND 0.1) TO 'tax_range.csv' (DELIMITER ',', HEADER true);
COPY (SELECT COUNT(*) AS total_orders FROM lineitem) TO 'order_summary.json' (FORMAT json);
WITH temp AS (SELECT l_orderkey, l_extendedprice FROM lineitem WHERE l_quantity > 10) COPY temp TO 'temp_orders.csv' (DELIMITER ',', HEADER true);
PREPARE v1 AS COPY lineitem FROM ($1);
EXECUTE v1('lineitem.csv');
COPY lineitem TO 'lineitem_output.tsv' (DELIMITER '\t', HEADER true);
CREATE TABLE summary AS SELECT l_orderkey, SUM(l_extendedprice * (1 - l_discount)) AS revenue FROM lineitem GROUP BY l_orderkey;
COPY summary TO 'summary_output.parquet' (FORMAT parquet);