CREATE TABLE nums (a DOUBLE, b DOUBLE);
INSERT INTO nums VALUES (5, 2), (7.5, 1.5), (3, 4), (1.0, 0.0), (8.9, 2.2);
SELECT fmod(a, b) AS result FROM nums;
SELECT fmod(a + 10, b) AS result FROM nums;
SELECT fmod(fmod(a, 2), b) AS result FROM nums;
SELECT fmod((SELECT AVG(a) FROM nums), (SELECT AVG(b) FROM nums)) AS average_modulo;
SELECT n1.a, fmod(n1.a, n2.b) AS mod_result FROM nums n1 JOIN nums n2 ON n1.a < n2.a;
CREATE TABLE more_nums (x DOUBLE);
INSERT INTO more_nums VALUES (12.5), (3.1), (5.7), (9.99);
SELECT fmod((SELECT SUM(x) FROM more_nums), (SELECT COUNT(*) FROM more_nums)) AS sum_mod_count;
INSERT INTO nums VALUES (NULL, 2);
SELECT fmod(a, b) AS mod_result FROM nums WHERE b IS NOT NULL;
SELECT fmod(fmod(a, 5.5), 2.0) AS nested_mod FROM nums WHERE a > 0;
SELECT fmod(COALESCE(a, 0), COALESCE(b, 1)) AS safe_fmod FROM nums;
CREATE TABLE test_fmod (x DOUBLE NOT NULL, y DOUBLE NOT NULL);
INSERT INTO test_fmod VALUES (15, 4), (NULL, 3), (25, NULL), (NULL, NULL);
SELECT fmod(x, y) AS test_result FROM test_fmod WHERE COALESCE(x, 0) != 0 AND COALESCE(y, 1) != 0;