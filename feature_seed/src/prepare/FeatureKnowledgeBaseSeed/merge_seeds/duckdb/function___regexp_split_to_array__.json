CREATE TABLE test_strings (data STRING);
INSERT INTO test_strings VALUES ('hello world;
42'), ('apple,banana,pear'), ('one|two|three'), ('a;
b;
c;
d;
e'), ('first second,third;
fourth--fifth');
SELECT str_split_regex(data, ';
? ') FROM test_strings;
SELECT data, str_split_regex(data, '[ ,;
]') AS split_data FROM test_strings;
SELECT data, str_split_regex(data, '[;
|,| ]') AS split_data FROM test_strings;
SELECT str_split_regex(data, '(;
|,| )') AS split_data FROM test_strings WHERE data LIKE '%;
%' OR data LIKE '%,%';
SELECT data, str_split_regex(data, '[\s,;
]') AS split_data FROM (SELECT data FROM test_strings WHERE data LIKE '% %');
WITH split_results AS (SELECT data, str_split_regex(data, '[ -;
]') AS split_data FROM test_strings) SELECT * FROM split_results WHERE array_length(split_data) > 3;
CREATE TABLE other_table (number INTEGER);
INSERT INTO other_table VALUES (1), (2), (3);
SELECT a.data, b.number FROM test_strings a JOIN other_table b ON array_length(str_split_regex(a.data, '[ ,;
]')) > b.number;
SELECT str_split_regex(data, ';
') AS split_data FROM test_strings WHERE EXISTS (SELECT 1 FROM other_table WHERE other_table.number = 2);
SELECT str_split_regex(data, '[ \t]+') AS split_data FROM (SELECT data FROM test_strings WHERE data IS NOT NULL);
SELECT str_split_regex(REPLACE(data, ',', ';
'), ';
') AS split_data FROM test_strings;
SELECT str_split_regex(REGEXP_REPLACE(data, '[;
]+', ';
'), ';
') AS split_data FROM test_strings;