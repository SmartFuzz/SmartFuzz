CREATE TABLE test_floats (value FLOAT);
INSERT INTO test_floats VALUES (1.0), (0.0), (NaN), ('Infinity'::float), ('-Infinity'::float);
SELECT value, isinf(value) FROM test_floats;
SELECT value, isinf(value) FROM (SELECT value FROM test_floats WHERE value IS NOT NULL) AS subquery;
CREATE TABLE other_floats (other_value FLOAT);
INSERT INTO other_floats VALUES (2.0), ('Infinity'::float), (3.5), (NaN);
SELECT a.value, b.other_value, isinf(a.value) AS a_isinf, isinf(b.other_value) AS b_isinf FROM test_floats AS a JOIN other_floats AS b ON a.value < b.other_value;
SELECT (SELECT COUNT(*) FROM test_floats WHERE isinf(value)) AS count_infinite, (SELECT COUNT(*) FROM test_floats) AS total_count;
INSERT INTO test_floats VALUES (NULL);
SELECT value, isinf(value), (SELECT SUM(isinf(value)) FROM test_floats) AS total_infinite FROM test_floats;
SELECT CASE WHEN isinf(value) THEN 'Infinite' ELSE 'Finite' END AS infinity_status FROM (SELECT value FROM test_floats) AS categorized;