CREATE TABLE numbers (a INTEGER, b INTEGER);
INSERT INTO numbers VALUES (10, 2), (12, 3), (8, 0), (15, 4);
SELECT a, b, divide(a, b) AS result FROM numbers;
SELECT a, b, divide(a, b) AS result FROM numbers WHERE b > 0;
SELECT a, b, divide(a, b) AS result FROM numbers WHERE b IS NOT NULL;
SELECT a, b, CASE WHEN b != 0 THEN divide(a, b) ELSE NULL END AS safe_divide FROM numbers;
SELECT a, b, (SELECT divide(a, b) FROM numbers AS n WHERE n.a = 10 AND n.b = 2) AS fixed_division_result;
CREATE TABLE additional_values AS SELECT 1 AS num UNION ALL SELECT 3 UNION ALL SELECT 4 UNION ALL SELECT 5;
SELECT num, divide((SELECT SUM(a) FROM numbers), (SELECT COUNT(b) FROM additional_values)) AS average_divide FROM additional_values;
SELECT a, b, (SELECT divide(SELECT AVG(a) FROM numbers, (SELECT MAX(b) FROM numbers)) AS avg_divide) FROM numbers;
WITH div_results AS (SELECT a, b, divide(a, b) AS division_result FROM numbers WHERE b != 0) SELECT AVG(division_result) FROM div_results;
SELECT a, b, divide(a, (SELECT MAX(b) FROM numbers)) AS divide_max_b FROM numbers;
SELECT a, b, divide(a, ROUND(b, 0)) AS rounded_divide FROM numbers;
CREATE TABLE division_check AS SELECT a, b, divide(a, b) AS division_result FROM numbers WHERE b IS NOT NULL AND b != 0;