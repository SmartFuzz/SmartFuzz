CREATE TABLE dates (event_date DATE);
INSERT INTO dates VALUES (DATE '1992-02-15'), (DATE '2023-10-20'), (DATE '2000-01-01');
SELECT timezone_hour(event_date) FROM dates;
SELECT COUNT(*), timezone_hour(event_date) FROM dates GROUP BY timezone_hour(event_date);
SELECT A.event_date, timezone_hour(A.event_date) FROM dates A WHERE A.event_date > (SELECT MIN(event_date) FROM dates);
SELECT A.event_date, timezone_hour(A.event_date) AS timezone_offset FROM dates A JOIN (SELECT DISTINCT event_date FROM dates) B ON A.event_date = B.event_date;
CREATE TABLE additional_dates (event_date DATE, region VARCHAR(50));
INSERT INTO additional_dates VALUES (DATE '1992-02-15', 'UTC'), (DATE '1999-12-31', 'UTC+5'), (DATE '2023-10-20', 'UTC-3');
SELECT timezone_hour(d.event_date) AS offset_hour, ad.region FROM dates d JOIN additional_dates ad ON d.event_date = ad.event_date;
SELECT event_date, timezone_hour(event_date) FROM dates WHERE timezone_hour(event_date) BETWEEN -12 AND 14;
WITH timezone_info AS (SELECT event_date, timezone_hour(event_date) AS tz_hour FROM dates) SELECT * FROM timezone_info WHERE tz_hour IN (SELECT DISTINCT timezone_hour FROM timezone_info);