CREATE TABLE numbers (a INTEGER, b INTEGER);
INSERT INTO numbers VALUES (42, 57), (0, 0), (10, 0), (0, 10), (100, 1), (15, 5), (1000000, 250000);
SELECT greatest_common_divisor(a, b) FROM numbers;
SELECT greatest_common_divisor(MAX(a), MIN(b)) FROM numbers;
SELECT a, b, greatest_common_divisor(a, b) as gcd FROM numbers WHERE a > 0 AND b > 0;
CREATE TABLE more_numbers (x INTEGER, y INTEGER);
INSERT INTO more_numbers VALUES (12, 15), (18, 24);
SELECT n.a, n.b, m.x, m.y, greatest_common_divisor(greatest_common_divisor(n.a, n.b), greatest_common_divisor(m.x, m.y)) AS overall_gcd FROM numbers n JOIN more_numbers m ON n.b = m.x;
WITH gcd_values AS (SELECT a, b, greatest_common_divisor(a, b) AS gcd FROM numbers) SELECT SUM(gcd) FROM gcd_values;
SELECT a, b, greatest_common_divisor(a * 10, b * 10) AS scaled_gcd FROM numbers;
SELECT n.a, n.b, greatest_common_divisor(n.a, (SELECT MAX(b) FROM numbers WHERE b > 0)) AS gcd_with_max_b FROM numbers n;