CREATE TABLE test_structs (data STRUCT<i INTEGER, v2 INTEGER, v3 INTEGER>);
INSERT INTO test_structs VALUES (STRUCT(3, 3, 0));
SELECT struct_extract(data, 'i') FROM test_structs;
SELECT struct_extract(data, 'v2') FROM test_structs;
SELECT struct_extract(data, 'v3') FROM test_structs;
INSERT INTO test_structs VALUES (STRUCT(4, 5, 6));
SELECT struct_extract(data, 'i') FROM test_structs WHERE struct_extract(data, 'v2') > 2;
CREATE TABLE secondary_structs (info STRUCT<name VARCHAR, age INTEGER>);
INSERT INTO secondary_structs VALUES (STRUCT('Alice', 30));
SELECT s.name, struct_extract(t.data, 'i') FROM test_structs t JOIN secondary_structs s ON struct_extract(t.data, 'v2') > s.age;
SELECT struct_extract(data, 'non_existing_field') FROM test_structs;
CREATE TABLE complex_structs (meta STRUCT<a STRUCT<b INTEGER, c INTEGER>, d INTEGER>);
INSERT INTO complex_structs VALUES (STRUCT(STRUCT(1, 2), 3));
SELECT struct_extract(meta, 'a') FROM complex_structs;
SELECT struct_extract(struct_extract(meta, 'a'), 'b') FROM complex_structs;
SELECT struct_extract(meta, 'd') FROM complex_structs WHERE struct_extract(meta, 'a').c > 1;
CREATE TABLE deep_structs (info STRUCT<details STRUCT<id INTEGER, value FLOAT>, name VARCHAR>);
INSERT INTO deep_structs VALUES (STRUCT(STRUCT(100, 10.5), 'example'));
SELECT struct_extract(info, 'details').id FROM deep_structs;
SELECT struct_extract(info, 'details').value FROM deep_structs WHERE struct_extract(info, 'details').id = 100;