CREATE TABLE test_strings (s1 VARCHAR, s2 VARCHAR);
INSERT INTO test_strings VALUES ('duck', 'luck'), ('hello', 'world'), ('abc', 'abc'), ('abcd', 'abce'), ('ABCDE', 'abcde');
SELECT mismatches(s1, s2) FROM test_strings;
SELECT mismatches(t1.s1, t2.s2) FROM test_strings AS t1 JOIN test_strings AS t2 ON LENGTH(t1.s1) = LENGTH(t2.s2) WHERE t1.s1 <> t2.s2;
SELECT COUNT(*) AS mismatch_count FROM (SELECT mismatches(s1, s2) AS mismatch_value FROM test_strings) WHERE mismatch_value > 0;
SELECT s1, s2, mismatches(s1, s2) AS num_mismatches FROM test_strings WHERE LENGTH(s1) = LENGTH(s2);
WITH string_pairs AS (SELECT s1, s2 FROM test_strings WHERE LENGTH(s1) = LENGTH(s2)) SELECT s1, s2, mismatches(s1, s2) FROM string_pairs;
SELECT CASE WHEN mismatches(s1, s2) = 0 THEN 'Match' ELSE 'No Match' END AS result FROM test_strings;
CREATE TABLE additional_test_strings (s1 VARCHAR, s2 VARCHAR);
INSERT INTO additional_test_strings VALUES ('testing', 'TESTING'), ('fuzzy', 'duzzy'), ('case', 'CASE'), ('same', 'same');
SELECT mismatches(t1.s1, t2.s2) FROM test_strings t1, additional_test_strings t2 WHERE LENGTH(t1.s1) = LENGTH(t2.s2);
SELECT mismatches(s1, s2) FROM (SELECT s1, s2 FROM test_strings WHERE s1 LIKE 'd%') AS filtered;