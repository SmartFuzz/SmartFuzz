CREATE TABLE events (id INT, event_time TIMESTAMP);
INSERT INTO events VALUES (1, TIMESTAMP '2022-01-01 10:00:00'), (2, TIMESTAMP '2022-01-01 10:03:00'), (3, TIMESTAMP '2022-01-01 10:12:00');
SELECT time_bucket(INTERVAL '5 minutes', event_time) AS bucketed_time FROM events ORDER BY bucketed_time;
SELECT time_bucket(INTERVAL '1 hour', event_time, INTERVAL '15 minutes') AS bucketed_time FROM events;
SELECT MAX(time_bucket(INTERVAL '30 minutes', event_time)) AS max_bucketed_time FROM events;
CREATE TABLE user_actions (user_id INT, action_time TIMESTAMP);
INSERT INTO user_actions VALUES (1, TIMESTAMP '2022-01-01 09:50:00'), (1, TIMESTAMP '2022-01-01 10:05:00'), (2, TIMESTAMP '2022-01-01 10:15:00');
SELECT u.user_id, COUNT(*), time_bucket(INTERVAL '10 minutes', u.action_time) AS action_bucket FROM user_actions u GROUP BY u.user_id, action_bucket;
SELECT * FROM (SELECT time_bucket(INTERVAL '15 minutes', event_time) AS bucketed_time, COUNT(*) FROM events GROUP BY bucketed_time) AS bucketed_events WHERE bucketed_time >= TIMESTAMP '2022-01-01 10:00:00';
CREATE TABLE temperature_readings (city VARCHAR, reading_time TIMESTAMP, temperature FLOAT);
INSERT INTO temperature_readings VALUES ('CityA', TIMESTAMP '2022-01-01 10:00:00', 25.0), ('CityA', TIMESTAMP '2022-01-01 10:10:00', 26.0), ('CityB', TIMESTAMP '2022-01-01 10:05:00', 22.0);
SELECT city, time_bucket(INTERVAL '20 minutes', reading_time) AS temp_bucket, AVG(temperature) AS avg_temp FROM temperature_readings GROUP BY city, temp_bucket;
SELECT t.city, COUNT(*) AS readings_count, time_bucket(INTERVAL '1 hour', t.reading_time, INTERVAL '10 minutes') AS bucketed_time FROM temperature_readings t GROUP BY t.city, bucketed_time ORDER BY bucketed_time;
CREATE TABLE consolidated_data AS SELECT time_bucket(INTERVAL '1 hour', u.action_time, INTERVAL '20 minutes') AS bucket, COUNT(*) AS action_count FROM user_actions u GROUP BY bucket;
SELECT bucket, AVG(action_count) FROM consolidated_data GROUP BY bucket;