CREATE TABLE transactions (id BIGINT, amount FLOAT);
INSERT INTO transactions VALUES (1, 100.0), (2, 200.0);
BEGIN;
SELECT txid_current();
COMMIT;
BEGIN;
INSERT INTO transactions (id, amount) VALUES (txid_current(), 150.0);
COMMIT;
BEGIN;
INSERT INTO transactions (id, amount) SELECT txid_current(), SUM(amount) FROM transactions;
COMMIT;
CREATE TABLE accounts (id BIGINT, balance FLOAT);
INSERT INTO accounts VALUES (1, 1000.0), (2, 2000.0);
BEGIN;
SELECT a.id, a.balance, txid_current() as transaction_id FROM accounts a WHERE a.balance > 1500;
COMMIT;
CREATE TABLE logs (transaction_id BIGINT, log_message TEXT);
BEGIN;
INSERT INTO logs (transaction_id, log_message) VALUES (txid_current(), 'Transaction started');
COMMIT;
BEGIN;
INSERT INTO logs (transaction_id, log_message) SELECT txid_current(), 'Inserted new amount: ' || CAST(SUM(amount) AS TEXT) FROM transactions;
COMMIT;
CREATE TABLE temp_trans AS SELECT id, amount FROM transactions WHERE amount > 100;
CREATE TABLE temp_summary AS SELECT txid_current() as transaction_id, COUNT(*) as total_transactions FROM temp_trans;
SELECT * FROM temp_summary;