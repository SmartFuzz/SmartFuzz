CREATE TABLE test_interval (id INTEGER);
INSERT INTO test_interval VALUES (1), (2), (3);
SELECT to_days(id) AS days_interval FROM test_interval;
SELECT id, to_days(id) AS days_interval FROM test_interval WHERE id > 0;
SELECT (SELECT to_days(id) FROM test_interval WHERE id = 1) * 2 AS double_days_interval;
CREATE TABLE additional_data (category VARCHAR, value INTEGER);
INSERT INTO additional_data VALUES ('A', 5), ('B', 10), ('C', 15);
SELECT a.id, b.category, to_days(a.id + b.value) AS total_days_interval FROM test_interval a JOIN additional_data b ON a.id = 1;
SELECT SUM(to_days(id)) AS total_days FROM test_interval;
SELECT AVG(to_days(id)) AS average_days FROM test_interval WHERE id BETWEEN 1 AND 3;
WITH daily_intervals AS (SELECT to_days(id) AS days FROM test_interval) SELECT MIN(days) AS min_days, MAX(days) AS max_days FROM daily_intervals;