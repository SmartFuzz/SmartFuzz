CREATE TABLE strings (val VARCHAR CHECK (length(val) <= 10));
INSERT INTO strings (val) VALUES ('Hello');
INSERT INTO strings (val) VALUES ('world');
INSERT INTO strings (val) VALUES ('Hello World');
INSERT INTO strings (val) VALUES ('Testing');
CREATE TABLE more_strings (id INTEGER, val VARCHAR);
INSERT INTO more_strings (id, val) VALUES (1, 'Test String');
INSERT INTO more_strings (id, val) VALUES (2, 'Example');
SELECT val FROM strings WHERE length(val) <= 10;
SELECT val FROM strings WHERE val LIKE 'H%' OR val LIKE '%d';
SELECT s.val, m.val FROM strings s INNER JOIN more_strings m ON substr(s.val, 1, 5) = substr(m.val, 1, 5);
SELECT CASE WHEN length(val) > 5 THEN 'Long' ELSE 'Short' END AS length_description FROM strings;
SELECT LENGTH(val) AS length_of_string FROM strings WHERE val IS NOT NULL;
CREATE TABLE combined_strings (val1 VARCHAR, val2 VARCHAR);
INSERT INTO combined_strings (val1, val2) VALUES ('A', 'B'), ('C', 'D');
SELECT CONCAT(cs.val1, cs.val2) AS combined_value FROM combined_strings cs;
SELECT 'Hello ' || val FROM strings;
SELECT REPLACE(val, 'o', '0') AS modified_string FROM strings;
SELECT * FROM strings WHERE val NOT IN (SELECT val FROM more_strings);
CREATE TABLE restricted_strings (val VARCHAR CHECK (length(val) <= 10));
INSERT INTO restricted_strings (val) VALUES ('Short1');
INSERT INTO restricted_strings (val) VALUES ('TooLongString');
SELECT chr(10) || 'New Line!' AS new_line_example;