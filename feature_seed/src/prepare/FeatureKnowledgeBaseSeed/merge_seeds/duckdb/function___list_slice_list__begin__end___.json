CREATE TABLE test_list (my_list LIST);
INSERT INTO test_list VALUES (ARRAY[4, 5, 6, 7, 8]);
SELECT list_slice(my_list, 2, 4) FROM test_list;
CREATE TABLE t2 (id INT, val LIST);
INSERT INTO t2 VALUES (1, ARRAY[1, 2, 3, 4, 5]), (2, ARRAY[10, 20, 30]);
SELECT id, list_slice(val, 1, 3) FROM t2;
SELECT list_slice(my_list, -3, -1) FROM test_list;
CREATE TABLE t3 (key INT, data LIST);
INSERT INTO t3 VALUES (1, ARRAY[10, 20, 30, 40]), (2, ARRAY[5, 6, 7, 8, 9]);
SELECT key, list_slice(data, -2, 5) FROM t3 WHERE key = 2;
SELECT list_slice(ARRAY[NULL, 'a', 'b', 'c', 'd'], 1, 4) AS sliced FROM (SELECT 1);
SELECT DISTINCT list_slice(ARRAY[1, 2, 3, 4], 0, 0) AS empty_slice FROM (SELECT 1);
CREATE TABLE base_table (id INT, numbers LIST);
INSERT INTO base_table VALUES (1, ARRAY[1, 2, 3, 4, 5]), (2, ARRAY[6, 7]);
SELECT id, list_slice(numbers, 0, 10) FROM base_table;
WITH subquery AS (SELECT numbers FROM base_table WHERE id = 1) SELECT list_slice(numbers, 1, 3) FROM subquery;
SELECT list_slice(ARRAY[5, 10, 15, 20], -4, 2) AS partial_slice FROM (SELECT 1);
SELECT list_slice(NULL, 0, 4) AS null_slice;