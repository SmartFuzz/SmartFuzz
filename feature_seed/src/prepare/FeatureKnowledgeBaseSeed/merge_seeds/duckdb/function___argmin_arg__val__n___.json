CREATE TABLE data (A INT, B FLOAT);
INSERT INTO data VALUES (1, 10.0), (2, 20.0), (3, 30.0), (4, 40.0), (5, 50.0);
SELECT argmin(A, B, 2) FROM data;
CREATE TABLE more_data (C INT, D FLOAT);
INSERT INTO more_data VALUES (1, 15.0), (2, 25.0), (3, 35.0), (4, 45.0), (5, 55.0);
SELECT argmin(A, B, 3) FROM data UNION ALL SELECT argmin(C, D, 3) FROM more_data;
CREATE TABLE temp_data AS SELECT A, B FROM data ORDER BY B ASC LIMIT 3;
SELECT argmin(A, B, 2) FROM (SELECT A, B FROM temp_data) AS subquery;
CREATE TABLE additional_data (ID INT, Value FLOAT);
INSERT INTO additional_data VALUES (1, 5.0), (2, 12.0), (3, 8.0), (4, 6.0), (5, 4.0);
SELECT argmin(A, B, 2) FROM data JOIN additional_data ON data.A = additional_data.ID ORDER BY additional_data.Value;
SELECT argmin(A, B, 2) FROM (SELECT A, B FROM data WHERE B > 15.0) AS filtered_data;