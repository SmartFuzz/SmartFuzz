CREATE TABLE time_intervals (id INTEGER, duration INTEGER);
INSERT INTO time_intervals VALUES (1, 5);
INSERT INTO time_intervals VALUES (2, 10);
INSERT INTO time_intervals VALUES (3, 15);
INSERT INTO time_intervals VALUES (4, 20);
INSERT INTO time_intervals VALUES (5, -5);
INSERT INTO time_intervals VALUES (6, 0);
SELECT id, to_minutes(duration) AS minute_interval FROM time_intervals WHERE duration >= 0;
SELECT id, to_minutes(duration) AS minute_interval FROM time_intervals WHERE duration < 0;
SELECT id, duration, (SELECT to_minutes(MAX(duration)) FROM time_intervals) AS max_interval FROM time_intervals;
SELECT id, duration, to_minutes(duration) AS minute_interval FROM time_intervals ORDER BY to_minutes(duration);
CREATE TABLE extra_intervals (id INTEGER, new_duration INTEGER);
INSERT INTO extra_intervals VALUES (1, 30), (2, 45);
SELECT ti.id, ti.duration, ei.new_duration, to_minutes(ti.duration + ei.new_duration) AS total_minutes FROM time_intervals ti JOIN extra_intervals ei ON ti.id = ei.id;
WITH calculated_minutes AS (SELECT id, to_minutes(duration) AS minute_interval FROM time_intervals) SELECT * FROM calculated_minutes WHERE minute_interval >= 10;
SELECT SUM(to_minutes(duration)) AS total_minutes FROM time_intervals;
CREATE TABLE additional_data (id INTEGER, info TEXT);
INSERT INTO additional_data VALUES (1, 'Sample Text 1'), (2, 'Sample Text 2');
SELECT ad.info, ti.id, to_minutes(ti.duration) AS minute_interval FROM additional_data ad LEFT JOIN time_intervals ti ON ad.id = ti.id;
SELECT id FROM time_intervals WHERE id IN (SELECT id FROM additional_data);
SELECT ti.id, to_minutes(ti.duration) FROM time_intervals ti WHERE EXISTS (SELECT 1 FROM additional_data ad WHERE ad.id = ti.id);