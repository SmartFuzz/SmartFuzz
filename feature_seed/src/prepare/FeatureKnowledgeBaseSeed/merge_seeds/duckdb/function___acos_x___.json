CREATE TABLE angles (x FLOAT);
INSERT INTO angles VALUES (0.5), (1.0), (-1.0), (2.0), (-2.0), (0.0), (0.999999), (-0.999999);
SELECT x, acos(x) AS arccosine FROM angles;
SELECT a.x, acos(a.x) AS arccosine FROM angles a WHERE a.x BETWEEN -1 AND 1;
CREATE TABLE results AS SELECT x, acos(x) AS arccosine FROM angles;
SELECT arccosine FROM results WHERE arccosine IS NOT NULL;
SELECT a.x, b.y, acos(a.x) AS arccosine_a, acos(b.y) AS arccosine_b FROM angles a JOIN angles b ON a.x = b.y;
SELECT CASE WHEN a.x > 0 THEN acos(a.x) ELSE NULL END AS arccosine_positive FROM angles a;
SELECT DISTINCT acos(x) AS arccosine FROM (SELECT x FROM angles) AS subquery WHERE x BETWEEN -1 AND 1;
WITH angle_values AS (SELECT x FROM angles) SELECT x, acos(x) FROM angle_values WHERE x IN (0, 0.5, 1);