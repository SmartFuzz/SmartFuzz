CREATE TABLE test_struct (data STRUCT<field1 INTEGER, field2 INTEGER>);
INSERT INTO test_struct VALUES (row(42, 84));
SELECT data[1] FROM test_struct;
SELECT data[2] FROM test_struct;
CREATE TABLE test_struct_multi (data STRUCT<name STRING, details STRUCT<age INTEGER, height INTEGER>>);
INSERT INTO test_struct_multi VALUES (row('John', row(30, 175)));
SELECT data.details[1] FROM test_struct_multi WHERE data.name = 'John';
SELECT data.details[2] FROM test_struct_multi;
CREATE TABLE t1 (id INTEGER, info STRUCT<value1 INTEGER, value2 INTEGER>);
INSERT INTO t1 VALUES (1, row(100, 200));
INSERT INTO t1 VALUES (2, row(300, 400));
SELECT info[1] FROM t1 WHERE id = 1;
SELECT info[2] FROM t1;
CREATE TABLE t2 (user_id INTEGER, user_info STRUCT<username STRING, score INTEGER>);
INSERT INTO t2 VALUES (1, row('Alice', 85));
INSERT INTO t2 VALUES (2, row('Bob', 90));
SELECT t1.id, t2.user_info[1] FROM t1 JOIN t2 ON t1.id = t2.user_id;
SELECT t2.user_info[2], t1.info[1] FROM t2 JOIN t1 ON t1.id = t2.user_id;
CREATE TABLE complex_struct (record STRUCT<id INTEGER, stats STRUCT<score INTEGER, level INTEGER>>);
INSERT INTO complex_struct VALUES (row(1, row(10, 2)));
INSERT INTO complex_struct VALUES (row(2, row(20, 3)));
SELECT record.stats[1] FROM complex_struct;
SELECT record.stats[2] FROM complex_struct WHERE record.id = 2;
WITH temp AS (SELECT row(1, 2) AS nested_struct) SELECT nested_struct[1];
WITH temp AS (SELECT row(100, 200) AS nested_info) SELECT nested_info[2];
CREATE TABLE join_test (a STRUCT<value1 INTEGER, value2 INTEGER>);
INSERT INTO join_test VALUES (row(5, 10));
INSERT INTO join_test VALUES (row(15, 20));
SELECT a[1], a[2] FROM join_test;
SELECT (SELECT a[1] FROM join_test) + (SELECT a[2] FROM join_test) AS total;