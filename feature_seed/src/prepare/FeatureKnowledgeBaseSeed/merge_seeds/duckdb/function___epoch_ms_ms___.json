CREATE TABLE timestamps (epoch_ms BIGINT);
INSERT INTO timestamps VALUES (0), (701222400000), (1622548800000), (-62135596800000);
SELECT epoch_ms(epoch_ms) AS converted_timestamp FROM timestamps;
SELECT epoch_ms(epoch_ms) + INTERVAL '5 hours' AS adjusted_timestamp FROM timestamps;
SELECT e.epoch_ms, epoch_ms(e.epoch_ms) AS timestamp FROM (SELECT epoch_ms FROM timestamps) e;
CREATE TABLE additional_info (info_id INT, related_epoch_ms BIGINT);
INSERT INTO additional_info VALUES (1, 701222400000), (2, 1622548800000), (3, -62135596800000);
SELECT a.info_id, epoch_ms(a.related_epoch_ms) AS converted_timestamp, epoch_ms(t.epoch_ms) AS original_timestamp FROM additional_info a JOIN timestamps t ON a.related_epoch_ms = t.epoch_ms;
SELECT DISTINCT epoch_ms(epoch_ms) FROM (SELECT epoch_ms FROM timestamps UNION SELECT -62135596800000 UNION SELECT 0) AS combined;
SELECT COUNT(*) AS count, epoch_ms(epoch_ms) AS converted FROM timestamps GROUP BY converted HAVING COUNT(*) > 1;