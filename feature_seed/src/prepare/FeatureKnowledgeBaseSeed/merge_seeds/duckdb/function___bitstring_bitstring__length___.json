CREATE TABLE test_table (id INT, bit_str BIT(10));
INSERT INTO test_table VALUES (1, '1010'::BIT), (2, '1110'::BIT), (3, '0001'::BIT);
SELECT bitstring(bit_str, 5) FROM test_table;
SELECT id, bitstring(bit_str, 8) AS extended_bits FROM test_table WHERE id = 2;
CREATE TABLE another_table (code BIT(5));
INSERT INTO another_table VALUES ('01'::BIT), ('11001'::BIT);
SELECT a.id, bitstring(a.bit_str, LENGTH(b.code) + 3) AS complex_bitstring FROM test_table a JOIN another_table b ON bitstring(a.bit_str, 5)=b.code;
CREATE TABLE complex_table (value BIT(6) NOT NULL);
INSERT INTO complex_table VALUES ('100001'::BIT), ('010110'::BIT);
SELECT bitstring(value, 5) AS alt_bit FROM complex_table WHERE value IS NOT NULL;
SELECT id, bitstring(bit_str, 7) AS padded_bits FROM test_table WHERE id IN (SELECT id FROM test_table WHERE id < 3);
WITH temp AS (SELECT id, bitstring(bit_str, 11) AS longer_bits FROM test_table) SELECT * FROM temp WHERE id = 1;
SELECT bitstring('101011'::BIT, 5);
SELECT bitstring('1100'::BIT, LENGTH('11000')) AS test_case_length;