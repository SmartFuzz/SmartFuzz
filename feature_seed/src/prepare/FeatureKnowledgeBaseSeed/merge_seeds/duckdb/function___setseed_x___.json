CREATE TABLE random_test (id INTEGER, value FLOAT);
INSERT INTO random_test VALUES (1, 1.0), (2, 2.0), (3, 3.0);
SETSEED(0);
SELECT RANDOM() FROM random_test;
SETSEED(1);
SELECT RANDOM() FROM random_test WHERE id = 1;
SETSEED(42);
SELECT RANDOM() as rand_value FROM random_test WHERE id IN (SELECT id FROM random_test WHERE value > 1.5);
SETSEED(-1);
SELECT RANDOM() FROM random_test;
CREATE TABLE more_random (rand_id INTEGER, rand_value FLOAT);
INSERT INTO more_random SELECT id, RANDOM() FROM random_test;
SETSEED(0.5);
SELECT AVG(rand_value) FROM more_random;
SETSEED(0.42);
SELECT COUNT(*) FROM more_random WHERE rand_value > (SELECT AVG(rand_value) FROM more_random);
SETSEED(5);
SELECT SUM(value * RANDOM()) AS weighted_random FROM random_test GROUP BY id;
SETSEED(100);
SELECT value, RANDOM() FROM random_test ORDER BY RANDOM();