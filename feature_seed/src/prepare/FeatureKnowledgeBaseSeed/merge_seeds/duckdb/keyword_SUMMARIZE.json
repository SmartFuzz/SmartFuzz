CREATE TABLE tbl (id INTEGER, value DOUBLE);
INSERT INTO tbl VALUES (1, 10.5), (2, 20.5), (3, 30.5);
SUMMARIZE tbl;
SUMMARIZE SELECT value FROM tbl;
SUMMARIZE SELECT AVG(value) AS avg_value FROM tbl;
CREATE TABLE tbl2 (id INTEGER, value DOUBLE);
INSERT INTO tbl2 VALUES (1, 5.5), (2, 15.5);
SUMMARIZE SELECT SUM(value) AS total_value FROM (SELECT * FROM tbl UNION ALL SELECT * FROM tbl2);
SUMMARIZE SELECT id, COUNT(*) FROM tbl GROUP BY id;
SUMMARIZE SELECT id, SUM(value) FROM tbl GROUP BY id HAVING SUM(value) > 15;
SUMMARIZE SELECT id, value FROM tbl WHERE value < 25;
SUMMARIZE SELECT t1.id, t1.value, t2.value FROM tbl t1 JOIN tbl2 t2 ON t1.id = t2.id;
SUMMARIZE SELECT * FROM (SELECT id, AVG(value) AS avg_value FROM tbl GROUP BY id) AS subquery;
SUMMARIZE SELECT COUNT(*) FROM (SELECT DISTINCT value FROM tbl);
SUMMARIZE SELECT id, MAX(value) FROM tbl GROUP BY id ORDER BY MAX(value);