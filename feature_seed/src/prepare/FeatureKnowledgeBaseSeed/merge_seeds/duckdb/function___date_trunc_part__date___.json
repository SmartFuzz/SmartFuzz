CREATE TABLE test_dates (event_date DATE);
INSERT INTO test_dates VALUES (DATE '2023-01-15'), (DATE '2023-01-30'), (DATE '2023-02-05'), (DATE '2023-03-21');
SELECT date_trunc('month', event_date) AS truncated_month FROM test_dates;
SELECT date_trunc('year', event_date) AS truncated_year FROM test_dates;
SELECT date_trunc('week', event_date) AS truncated_week FROM test_dates;
SELECT date_trunc('day', event_date) AS truncated_day FROM test_dates;
SELECT date_trunc('quarter', event_date) AS truncated_quarter FROM test_dates;
SELECT e.event_date, date_trunc('month', e.event_date) AS truncated_month FROM test_dates e WHERE e.event_date > DATE '2023-01-01';
SELECT e.event_date, date_trunc('month', e.event_date) AS truncated_month FROM test_dates e JOIN (SELECT event_date FROM test_dates WHERE event_date < DATE '2023-02-01') AS sub_query ON e.event_date = sub_query.event_date;
WITH truncated_dates AS (SELECT date_trunc('month', event_date) AS truncated_date FROM test_dates) SELECT DISTINCT truncated_date FROM truncated_dates ORDER BY truncated_date;
CREATE TABLE additional_dates (start_date DATE, end_date DATE);
INSERT INTO additional_dates VALUES (DATE '2023-01-01', DATE '2023-01-31'), (DATE '2023-02-01', DATE '2023-02-28');
SELECT ad.start_date, ad.end_date, date_trunc('month', ad.start_date) AS truncated_start, date_trunc('month', ad.end_date) AS truncated_end FROM additional_dates ad;
SELECT date_trunc('day', DATE '2023-05-01') - date_trunc('day', DATE '2023-04-30') AS day_difference;
SELECT date_trunc('month', DATE '2023-02-28') AS truncated_feb, date_trunc('month', DATE '2023-02-29') AS truncated_leap;
SELECT date_trunc('year', x.event_date) FROM (SELECT event_date FROM test_dates WHERE event_date BETWEEN DATE '2023-01-01' AND DATE '2023-12-31') AS x;
SELECT date_trunc('week', DATE '2023-03-01'), date_trunc('week', DATE '2023-02-29');
SELECT date_trunc('month', DATE_TRUNC('month', DATE '2023-02-15')) AS nested_truncation;