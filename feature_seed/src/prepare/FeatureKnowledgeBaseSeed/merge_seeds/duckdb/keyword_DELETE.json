CREATE TABLE tbl (i INTEGER, value VARCHAR);
INSERT INTO tbl VALUES (1, 'one'), (2, 'two'), (3, 'three');
DELETE FROM tbl WHERE i = 2;
DELETE FROM tbl;
CREATE TABLE employees (name VARCHAR, age INTEGER);
INSERT INTO employees VALUES ('Kat', 32), ('John', 40), ('Doe', 25);
DELETE FROM employees RETURNING name, 2025 - age AS approx_birthyear;
CREATE TABLE orders (order_id INTEGER, employee_name VARCHAR);
INSERT INTO orders VALUES (101, 'Kat'), (102, 'John'), (103, 'Doe');
DELETE FROM orders WHERE employee_name IN (SELECT name FROM employees WHERE age >= 30);
CREATE TABLE departments (dept_id INTEGER, emp_name VARCHAR);
INSERT INTO departments VALUES (1, 'Kat'), (2, 'John'), (3, 'Alice');
DELETE FROM departments USING employees WHERE departments.emp_name = employees.name AND employees.age < 35;
TRUNCATE tbl;
CREATE TABLE temp_table (id INTEGER, description VARCHAR);
INSERT INTO temp_table VALUES (1, 'temp1'), (2, 'temp2');
DELETE FROM temp_table WHERE id IN (SELECT id FROM temp_table WHERE description LIKE 'temp%');