CREATE TABLE test_tinyint (value TINYINT);
INSERT INTO test_tinyint VALUES (127), (-128), (128);
SELECT value FROM test_tinyint WHERE value BETWEEN -128 AND 127;
CREATE TABLE test_smallint (value SMALLINT);
INSERT INTO test_smallint VALUES (32767), (-32768), (32768);
SELECT value FROM test_smallint WHERE value BETWEEN -32768 AND 32767;
CREATE TABLE test_integer (value INTEGER);
INSERT INTO test_integer VALUES (2147483647), (-2147483648), (2147483648);
SELECT value FROM test_integer WHERE value BETWEEN -2147483648 AND 2147483647;
CREATE TABLE test_bigint (value BIGINT);
INSERT INTO test_bigint VALUES (9223372036854775807), (-9223372036854775808), (9223372036854775808);
SELECT value FROM test_bigint WHERE value BETWEEN -9223372036854775808 AND 9223372036854775807;
CREATE TABLE test_hugeint (value HUGEINT);
INSERT INTO test_hugeint VALUES (170141183460469231731687303715884105727), (-170141183460469231731687303715884105728), (170141183460469231731687303715884105728);
SELECT value FROM test_hugeint WHERE value BETWEEN -170141183460469231731687303715884105728 AND 170141183460469231731687303715884105727;
CREATE TABLE test_decimal (value DECIMAL(10, 2));
INSERT INTO test_decimal VALUES (12345.67), (123456.78), (1234567890.12);
SELECT value FROM test_decimal WHERE value <= 12345.67;
CREATE TABLE test_float (value FLOAT);
INSERT INTO test_float VALUES (1.5), (NaN), (Infinity), (-Infinity);
SELECT value FROM test_float WHERE value IS NOT NULL;
CREATE TABLE test_double (value DOUBLE);
INSERT INTO test_double VALUES (1.234567891234567), (1.5e10), (-1.5e-10);
SELECT AVG(value) FROM test_double;
CREATE TABLE test_uuid (id UUID);
INSERT INTO test_uuid VALUES (uuid()), (uuid()), (uuid());
SELECT id FROM test_uuid;
CREATE TABLE multi_table (id INT, value FLOAT);
INSERT INTO multi_table VALUES (1, 1.5), (2, 2.5);
CREATE TABLE another_table (id INT, value FLOAT);
INSERT INTO another_table VALUES (1, 2.5), (2, 3.5);
SELECT mt.id, mt.value + at.value AS total FROM multi_table mt JOIN another_table at ON mt.id = at.id WHERE mt.value > 1;