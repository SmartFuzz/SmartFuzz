CREATE TABLE test_strings (id INT, str VARCHAR);
INSERT INTO test_strings VALUES (1, 'hello_world'), (2, 'globally_accepted'), (3, '123_numbers'), (4, 'mixed_case_Example');
SELECT id, regexp_extract(str, '([a-zA-Z_]+)', 1) AS extracted FROM test_strings;
SELECT id, regexp_extract(str, '([_a-z]+)_', 1) AS extracted FROM test_strings WHERE id IN (1, 2);
WITH extracted_values AS (SELECT id, regexp_extract(str, '([a-zA-Z ]+)', 1) AS extracted FROM test_strings) SELECT * FROM extracted_values WHERE extracted IS NOT NULL;
SELECT t1.id, t1.str, regexp_extract(t2.str, '([a-zA-Z]+)\d+', 1) AS extracted FROM test_strings t1 JOIN test_strings t2 ON t1.id < t2.id;
CREATE TABLE additional_data (data VARCHAR);
INSERT INTO additional_data VALUES ('example_1_data'), ('test_2_string'), ('another_example_3');
SELECT ad.data, regexp_extract(ad.data, '([a-zA-Z]+)_\d+', 1) AS extracted FROM additional_data ad WHERE regexp_extract(ad.data, '([a-zA-Z]+)_\d+', 1) IS NOT NULL;
SELECT id, regexp_extract(str, '([A-Z_]+)', 1) AS uppercase_extracted FROM test_strings WHERE str LIKE '%_Example%';
SELECT id, regexp_extract(NULL, '([a-zA-Z]+)', 1) AS extracted_null FROM test_strings;
SELECT id, regexp_extract('edge_case_example', '^([a-zA-Z_]+)', 1) AS start_extracted FROM test_strings WHERE id = 4;
SELECT id, regexp_extract('end_case_example', '([a-zA-Z_]+)$', 1) AS end_extracted FROM test_strings WHERE id = 4;
CREATE TABLE complex_data (data VARCHAR);
INSERT INTO complex_data VALUES ('one1'), ('two2'), ('three3');
SELECT cd.data, regexp_extract(cd.data, '([a-z]+)(\d)', 1) AS number_extracted FROM complex_data cd WHERE cd.data LIKE '%1%';