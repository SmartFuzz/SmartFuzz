CREATE TABLE intervals (id INTEGER, duration INTERVAL);
INSERT INTO intervals VALUES (1, INTERVAL 5 HOUR), (2, INTERVAL 3 HOUR), (3, INTERVAL 10 MINUTE);
SELECT id, epoch(duration) FROM intervals;
CREATE TABLE additional_intervals (value INTERVAL);
INSERT INTO additional_intervals VALUES (INTERVAL 2 HOUR), (INTERVAL 30 MINUTE), (INTERVAL 15 SECOND);
SELECT EPOCH((SELECT SUM(value) FROM additional_intervals)) AS total_seconds;
SELECT id, epoch(duration) * 2 AS double_seconds FROM intervals WHERE epoch(duration) > 10000;
SELECT a.id, epoch(a.duration) + epoch(b.value) AS combined_epoch FROM intervals a JOIN additional_intervals b ON TRUE;
WITH total AS (SELECT SUM(epoch(duration)) as total_seconds FROM intervals) SELECT total_seconds FROM total;
SELECT INTERVAL '1 DAY' + INTERVAL '12 HOUR' AS combined_interval, epoch(INTERVAL '1 DAY' + INTERVAL '12 HOUR') AS epoch_seconds;
SELECT EPOCH(INTERVAL '30 MINUTE') AS thirty_minute_epoch, EPOCH(INTERVAL '7200 SECOND') AS two_hour_epoch;