CREATE TABLE test_strings (id INT, str VARCHAR);
INSERT INTO test_strings VALUES (1, '>>>>test<<'), (2, '====example===='), (3, '??hello??'), (4, 'normal string'), (5, '>>>>>multiple spaces    '), (6, '    #hash# ');
SELECT id, trim(str, '><') AS trimmed FROM test_strings WHERE id IN (1, 2);
SELECT id, trim(str, '=') AS trimmed FROM test_strings WHERE str LIKE '====%';
SELECT id, trim(str, '# ') AS trimmed FROM test_strings WHERE str LIKE '#%';
SELECT id, trim(str, ' ') AS trimmed FROM test_strings WHERE str IS NOT NULL;
WITH trimmed_strings AS (SELECT id, trim(str, '><') AS trimmed FROM test_strings) SELECT trimmed, COUNT(*) FROM trimmed_strings GROUP BY trimmed;
SELECT ts.id, ts.str, ts2.trimmed FROM test_strings ts JOIN (SELECT id, trim(str, ' =<>#') AS trimmed FROM test_strings) ts2 ON ts.id = ts2.id;
SELECT id, trim('   superfluous   ', ' ') AS trimmed, COUNT(*) OVER() AS total_count FROM test_strings;
SELECT id, trim(str, ' '), UPPER(trim(str, ' ')) AS upper_trimmed FROM test_strings WHERE str <> 'normal string' ORDER BY id;