CREATE TABLE test_data (id INT, x FLOAT, y FLOAT);
INSERT INTO test_data VALUES (1, 1.0, 2.0), (2, 2.0, NULL), (3, NULL, 3.0), (4, 1.0, 4.0), (5, 5.0, NULL);
SELECT regr_avgy(y, x) FROM test_data WHERE y IS NOT NULL;
SELECT x, regr_avgy(y, x) FROM test_data GROUP BY x;
CREATE TABLE additional_data (id INT, x FLOAT, y FLOAT);
INSERT INTO additional_data VALUES (1, 1.0, 5.0), (2, 3.0, NULL), (3, 1.0, 6.0);
SELECT d.x, regr_avgy(y, x) FROM test_data d JOIN additional_data a ON d.x = a.x GROUP BY d.x;
SELECT regr_avgy(y, x) FROM (SELECT x, y FROM test_data WHERE x IS NOT NULL UNION SELECT x, y FROM additional_data WHERE y IS NOT NULL) AS combined_data;
CREATE TABLE empty_table (x FLOAT, y FLOAT);
SELECT regr_avgy(y, x) FROM empty_table;
INSERT INTO empty_table VALUES (NULL, NULL);
SELECT regr_avgy(y, x) FROM empty_table;