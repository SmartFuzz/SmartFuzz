CREATE TABLE dates_table (id INTEGER, event_date DATE);
INSERT INTO dates_table VALUES (1, DATE '1992-01-01');
INSERT INTO dates_table VALUES (2, DATE '2000-02-29');
INSERT INTO dates_table VALUES (3, DATE '2010-12-31');
INSERT INTO dates_table VALUES (4, DATE '2021-06-15');
SELECT strftime(event_date, '%Y-%m-%d') FROM dates_table WHERE id = 1;
SELECT strftime(event_date, '%a, %-d %B %Y') FROM dates_table WHERE event_date = DATE '1992-01-01';
SELECT strftime(event_date, '%Y-%m-%d') AS formatted_date FROM (SELECT event_date FROM dates_table WHERE id = 2);
SELECT d.id, strftime(d.event_date, '%d/%m/%Y') AS formatted_date FROM dates_table d WHERE d.event_date < DATE '2015-01-01';
SELECT d1.id, d2.id, strftime(d1.event_date, '%Y-%m-%d') AS date1, strftime(d2.event_date, '%Y-%m-%d') AS date2 FROM dates_table d1 JOIN dates_table d2 ON d1.event_date < d2.event_date;
CREATE TABLE additional_dates (id INTEGER, additional_date DATE);
INSERT INTO additional_dates VALUES (1, DATE '2023-01-01');
INSERT INTO additional_dates VALUES (2, DATE '2022-07-10');
SELECT a.id, strftime(a.additional_date, '%Y-%m-%d'), strftime(d.event_date, '%Y-%m-%d') FROM additional_dates a LEFT JOIN dates_table d ON a.id = d.id;
SELECT strftime(d.event_date, '%Y-%m-%d %H:%M:%S') FROM dates_table d WHERE d.event_date IS NOT NULL;
SELECT strftime('2023-02-28', '%Y-%m-%d') AS static_date;