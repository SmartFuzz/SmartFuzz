CREATE TABLE angles (angle FLOAT);
INSERT INTO angles VALUES (0), (30), (45), (60), (90), (180), (270), (360);
SELECT angle, sin(angle) FROM angles;
CREATE TABLE radians (rad FLOAT);
INSERT INTO radians VALUES (0), (PI()/6), (PI()/4), (PI()/3), (PI()/2), (PI), (3*PI()/2), (2*PI());
SELECT rad, sin(rad) FROM radians;
SELECT sin(90 + angle) FROM angles;
SELECT sin(angle) + sin(30) AS adjusted_sin FROM angles;
SELECT sin(2 * angle) FROM angles;
CREATE TABLE nested_sin (value FLOAT);
INSERT INTO nested_sin (value) SELECT sin(angle) FROM angles;
SELECT value, sin(value) FROM nested_sin;
SELECT angles.angle, sin(angles.angle) AS sin_value, sin(radians.rad) AS sin_rad_value FROM angles JOIN radians ON angles.angle = radians.rad * 180/PI;