SELECT pi();
CREATE TABLE circle (radius FLOAT);
INSERT INTO circle VALUES (1.0), (2.0), (3.0);
SELECT radius, radius * radius * pi() AS area FROM circle;
CREATE TABLE sphere (radius FLOAT);
INSERT INTO sphere VALUES (1.0), (2.0), (3.0);
SELECT radius, (4.0/3.0) * pi() * radius * radius * radius AS volume FROM sphere;
CREATE TABLE geometry (shape VARCHAR, radius FLOAT);
INSERT INTO geometry VALUES ('circle', 1.0), ('circle', 2.0), ('sphere', 1.0);
SELECT shape, radius, CASE WHEN shape = 'circle' THEN radius * radius * pi() ELSE (4.0/3.0) * pi() * radius * radius * radius END AS measure FROM geometry;
WITH circle_area AS (SELECT radius, radius * radius * pi() AS area FROM circle) SELECT AVG(area) FROM circle_area;
CREATE TABLE measurements (length FLOAT);
INSERT INTO measurements VALUES (1.0), (2.0), (3.0);
SELECT m.length, 2 * pi() * m.length AS circumference FROM measurements m;
SELECT pi() * (SELECT COUNT(*) FROM circle) AS total_circle_area;