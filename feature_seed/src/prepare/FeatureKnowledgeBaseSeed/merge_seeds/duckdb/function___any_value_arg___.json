CREATE TABLE test_table (id INT, value TEXT);
INSERT INTO test_table VALUES (1, 'A'), (2, NULL), (3, 'B'), (4, 'C'), (5, NULL);
SELECT any_value(value) FROM test_table;
CREATE TABLE another_table (ref_id INT, ref_value TEXT);
INSERT INTO another_table VALUES (1, 'X'), (2, 'Y'), (3, NULL), (4, 'Z');
SELECT any_value(t.value) FROM test_table t JOIN another_table a ON t.id = a.ref_id;
CREATE TABLE nested_table (group_id INT, item_id INT, item_value TEXT);
INSERT INTO nested_table VALUES (1, 1, NULL), (1, 2, 'D'), (2, 3, NULL), (2, 4, 'E');
SELECT group_id, any_value(item_value) FROM nested_table GROUP BY group_id;
CREATE TABLE complex_table (user_id INT, score INT);
INSERT INTO complex_table VALUES (1, 10), (1, NULL), (2, 20), (2, 30), (2, NULL);
SELECT user_id, any_value(score) FROM complex_table GROUP BY user_id ORDER BY user_id;
CREATE TABLE combined_table (category TEXT, detail TEXT);
INSERT INTO combined_table VALUES ('A', 'A1'), ('A', NULL), ('B', 'B1'), ('B', 'B2');
SELECT category, any_value(detail) FROM combined_table GROUP BY category;
CREATE TABLE join_table1 (id INT, name TEXT);
INSERT INTO join_table1 VALUES (1, 'Alpha'), (2, 'Beta');
CREATE TABLE join_table2 (id INT, description TEXT);
INSERT INTO join_table2 VALUES (1, 'Desc1'), (2, NULL);
SELECT j1.name, any_value(j2.description) FROM join_table1 j1 LEFT JOIN join_table2 j2 ON j1.id = j2.id GROUP BY j1.name;
CREATE TABLE order_table (order_id INT, product TEXT, customer TEXT);
INSERT INTO order_table VALUES (1, 'Product1', 'CustomerA'), (1, 'Product2', NULL), (2, NULL, 'CustomerB');
SELECT order_id, any_value(product), any_value(customer) FROM order_table GROUP BY order_id;
CREATE TABLE empty_table (id INT, value INT);
SELECT any_value(value) FROM empty_table;
CREATE TABLE mixed_table (timestamp TIMESTAMP, event TEXT);
INSERT INTO mixed_table VALUES ('2023-01-01 10:00:00', 'Start'), (NULL, 'Continue'), ('2023-01-01 12:00:00', 'End');
SELECT any_value(event) FROM mixed_table WHERE timestamp IS NOT NULL;
CREATE TABLE duplicate_table (key_value INT, unique_value TEXT);
INSERT INTO duplicate_table VALUES (1, 'A'), (1, 'B'), (2, 'C'), (3, NULL);
SELECT key_value, any_value(unique_value) FROM duplicate_table GROUP BY key_value ORDER BY key_value;