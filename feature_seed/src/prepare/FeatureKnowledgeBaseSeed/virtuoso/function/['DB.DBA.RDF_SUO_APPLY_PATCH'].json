[
    "CREATE GRAPH <http://example.org/targetGraph>;",
    "CREATE GRAPH <http://example.org/defaultGraph>;",
    "INSERT DATA { GRAPH <http://example.org/targetGraph> { <http://example.org/subject> <http://example.org/predicate> <http://example.org/object> } };",
    "INSERT DATA { GRAPH <http://example.org/defaultGraph> { <http://example.org/subject2> <http://example.org/predicate2> <http://example.org/object2> } };",
    "SELECT * FROM <http://example.org/targetGraph> WHERE { ?s ?p ?o };",
    "SELECT * FROM <http://example.org/defaultGraph> WHERE { ?s ?p ?o };",
    "SET DEFAULT GRAPH <http://example.org/defaultGraph>;",
    "SELECT * WHERE { GRAPH <http://example.org/targetGraph> { ?s ?p ?o } } LIMIT 10;",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/targetGraph>', '<http://example.org/defaultGraph>');",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/targetGraph>', NULL);",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH(NULL, '<http://example.org/defaultGraph>');",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/invalidGraph>', '<http://example.org/anotherGraph>');",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/targetGraph>', '<http://example.org/invalidGraph>') RETURNING ?result;",
    "SELECT ?status WHERE { CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/targetGraph>', '<http://example.org/defaultGraph>') AS ?status };",
    "INSERT DATA { GRAPH <http://example.org/targetGraph> { _:blank1 <http://example.org/predicate> <http://example.org/object> } };",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/targetGraph>', '<http://example.org/defaultGraph>');",
    "INSERT DATA { GRAPH <http://example.org/emptyGraph> { <http://example.org/subject> <http://example.org/predicate> <http://example.org/object> } };",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/emptyGraph>', '<http://example.org/defaultGraph>');",
    "CALL DB.DBA.RDF_SUO_APPLY_PATCH('<http://example.org/targetGraph>', '<http://example.org/defaultGraph>');"
]