    "CREATE GRAPH <http://example.com/Anna/system>;",
    "CREATE USER Anna IDENTIFIED BY 'password';",
    "GRANT SELECT ON GRAPH <http://example.com/Anna/system> TO Anna;",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Anna/system', 'Anna');",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Anna/system', 'NonExistentUser');",
    "CREATE USER Bob IDENTIFIED BY 'password';",
    "GRANT UPDATE ON GRAPH <http://example.com/Anna/system> TO Bob;",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Anna/system', 'Bob');",
    "CREATE GRAPH <http://example.com/Bob/system>;",
    "GRANT SELECT, UPDATE ON GRAPH <http://example.com/Bob/system> TO Anna;",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Bob/system', 'Anna');",
    "CREATE GRAPH <http://example.com/ComplexGraph/system>;",
    "CREATE USER Peter IDENTIFIED BY 'password';",
    "GRANT ALL ON GRAPH <http://example.com/ComplexGraph/system> TO Peter;",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/ComplexGraph/system', 'Peter');",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/ComplexGraph/system', 'Anna') UNION SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Bob/system', 'Bob');",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/ComplexGraph/system', 'Peter') INTERSECT SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Bob/system', 'Anna');",
    "SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/ComplexGraph/system', 'Peter') EXCEPT SELECT DB.DBA.RDF_GRAPH_USER_PERMS_GET ('http://example.com/Anna/system', 'Anna');"
