[
    "CREATE GRAPH <http://testgraph.com>;",
    "INSERT INTO GRAPH <http://testgraph.com> { <http://testgraph.com/item1> <value> 5; <http://testgraph.com/item2> <value> 3; <http://testgraph.com/item3> <value> 7; };",
    " SELECT __min(2, 3, 5, 1.5);",
    " SELECT __min(-1, -5, 0);",
    "SELECT ?s (bif:__min(?val1, ?val2)) FROM <http://testgraph.com> WHERE { ?s <value> ?val1. ?s <value> ?val2. };",
    "SELECT ?s (bif:__min((SELECT ?val FROM <http://testgraph.com> WHERE ?s <value> ?val1), 10)) WHERE { ?s <value> ?val1; };",
    "SELECT (bif:__min(SELECT ?price1 FROM <http://mygraph.com> WHERE ?price1 > 0)) AS MinPrice FROM <http://mygraph.com>;",
    "SELECT * FROM (SELECT ?s (bif:__min(?val)) AS MinVal FROM <http://testgraph.com> GROUP BY ?s);",
    "INSERT INTO GRAPH <http://testgraph.com> { <http://testgraph.com/item4> <value> -10; <http://testgraph.com/item5> <value> 0; };",
    "SELECT (bif:__min(SELECT ?value FROM <http://testgraph.com>)) AS OverallMin FROM <http://testgraph.com>;",
    "SELECT (bif:__min(SELECT (bif:__min(?value1, ?value2)) FROM <http://testgraph.com>)) AS NestedMin FROM <http://testgraph.com>;"
]