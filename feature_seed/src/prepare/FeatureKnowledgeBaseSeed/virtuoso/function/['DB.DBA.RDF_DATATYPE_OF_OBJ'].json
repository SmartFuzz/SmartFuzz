[
    "CREATE GRAPH <test_datatype>;",
    "INSERT INTO <test_datatype> { <a> <string> \"string 1\"^^xsd:string . };",
    "INSERT INTO <test_datatype> { <b> <string> \"string 2\"^^xsd:string . };",
    "INSERT INTO <test_datatype> { <c> <string> \"string 3\" . };",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) FROM <test_datatype> { <a> <string> ?o} ;",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) FROM <test_datatype> { <b> <string> ?o} ;",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) FROM <test_datatype> { <c> <string> ?o} ;",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) FROM <test_datatype> { <a> <string> ?o} UNION { <b> <string> ?o} ;",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) WHERE { { SELECT ?o FROM <test_datatype> { <a> <string> ?o} } UNION { SELECT ?o FROM <test_datatype> { <b> <string> ?o} } } ;",
    "INSERT INTO <test_datatype> { <d> <string> \"string 4\"^^xsd:integer . };",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) FROM <test_datatype> { <d> <string> ?o} ;",
    "SELECT ?o (iri(sql:RDF_DATATYPE_OF_OBJ(?o, 'untyped!'))) FROM <test_datatype> { <a> <string> ?o} ORDER BY ?o LIMIT 10;"
]