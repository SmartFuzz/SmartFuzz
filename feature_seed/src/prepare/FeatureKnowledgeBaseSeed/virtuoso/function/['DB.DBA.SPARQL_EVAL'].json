    "SELECT ?s WHERE { GRAPH <http://example/bookStore> { ?s a ?type . } } LIMIT 5;",
    "SELECT ?s WHERE { GRAPH <http://example/bookStore> { ?s ?p ?o } } ORDER BY ?o LIMIT 10;"
