    "INSERT DATA { GRAPH <http://example/bookStore> { <http://example/book2> <http://purl.org/dc/elements/1.1/date> '2010-06-15T00:00:00' . } };",
    "INSERT DATA { GRAPH <http://example/bookStore> { <http://example/book3> <http://purl.org/dc/elements/1.1/title> 'SPARQL for Beginners' . } };",
