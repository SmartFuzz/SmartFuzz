[
    "CREATE GRAPH <http://mygraph3.com>;",
    "INSERT INTO GRAPH <http://mygraph3.com> { <http://mygraph3.com/data1> <value> 100 ; <value> 200 ; <value> 300 . } ;",
    "INSERT INTO GRAPH <http://mygraph3.com> { <http://mygraph3.com/data2> <value> 50 ; <value> 150 ; <value> 250 . } ;",
    "INSERT INTO GRAPH <http://mygraph3.com> { <http://mygraph3.com/data3> <value> 70 ; <value> 80 ; <value> 90 . } ;",
    "SELECT __max(1, 2, 3, 4, 5);",
    "SELECT __max(-1, -2, -3, -4, -5);",
    "SELECT __max(0, -50, 25);",
    "SELECT ?s (bif:__max(?val1, ?val2, ?val3)) FROM <http://mygraph3.com> WHERE { ?s <value> ?val1 ; <value> ?val2 ; <value> ?val3 . };",
    "SELECT __max((SELECT MAX(<value>) FROM <http://mygraph3.com> WHERE <value> > 0), (SELECT MIN(<value>) FROM <http://mygraph3.com> WHERE <value> < 100));",
    "SELECT __max(SELECT <value> FROM <http://mygraph3.com/data1>), (SELECT AVG(<value>) FROM <http://mygraph3.com/data2>);",
    "SELECT __max(SELECT MAX(?x) FROM { SELECT ?x WHERE { ?s <value> ?x . } } );"
]