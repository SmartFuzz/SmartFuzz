[
    "CREATE GRAPH <http://mygraph.com>;",
    "CREATE TABLE test_numbers (id INTEGER, value FLOAT);",
    "INSERT INTO test_numbers VALUES (1, 1.0), (2, 'not-a-number'), (3, 3.5), (4, infinity), (5, -inf);",
    "SPARQL SELECT ?s (bif:isfinitenumeric(?value)) FROM <http://mygraph.com> WHERE { GRAPH <http://mygraph.com> { ?s <http://mygraph.com/value> ?value } };",
    "SELECT id, bif:isfinitenumeric(value) AS is_finite FROM test_numbers WHERE value IS NOT NULL;",
    "SPARQL SELECT ?s (bif:isfinitenumeric(?val1) + bif:isfinitenumeric(?val2)) FROM <http://mygraph.com> WHERE { ?s <http://mygraph.com/val1> ?val1; <http://mygraph.com/val2> ?val2; };",
    "INSERT INTO <http://mygraph.com> { <http://mygraph2.com/pricing/#QVal4> <price1> 2.5 ; };",
    "SPARQL SELECT ?s (bif:isfinitenumeric(?price1)) FROM <http://mygraph.com> WHERE { ?s <price1> ?price1 . FILTER(bif:isfinitenumeric(?price1) = 0) };",
    "SPARQL SELECT (COUNT(?s) AS ?count_finite) WHERE { ?s <price1> ?pr1 . FILTER(bif:isfinitenumeric(?pr1) = 1) };"
]