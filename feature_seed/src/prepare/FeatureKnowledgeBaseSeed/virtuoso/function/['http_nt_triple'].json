    "INSERT INTO triples VALUES ('<http://example.org/subject3>', '<http://example.org/predicate3>', '<http://example.org/object3>');",
    "DECLARE VARIABLE ses any;",
    "DECLARE VARIABLE triples any;",
    "SET triples := (SELECT ARRAY_AGG(triples) FROM triples);",
    "CALL dump_rdftriples_to_nt(triples, ses);",
    "CREATE TABLE other_info (details VARCHAR);",
    "INSERT INTO other_info VALUES ('Additional Info');",
    "DECLARE VARIABLE combined_triples any;",
    "SET combined_triples := (SELECT ARRAY_AGG(triples) FROM triples JOIN other_info ON some_condition);",
    "CALL dump_rdftriples_to_nt(combined_triples, ses);",
    "DECLARE VARIABLE empty_triples any;",
    "SET empty_triples := (SELECT ARRAY_AGG(triples) FROM triples WHERE subject IS NULL);",
    "CALL dump_rdftriples_to_nt(empty_triples, ses);",
    "DECLARE VARIABLE nested_triples any;",
    "SET nested_triples := (SELECT ARRAY_AGG((SELECT <http://example.org/subject> FROM triples WHERE predicate = '<http://example.org/predicate1>')) FROM triples);",
