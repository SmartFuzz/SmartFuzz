    "sql_array": [
        "CREATE VIEW cat AS SELECT \"CategoryID\", \"Description\" FROM \"Demo\".\"demo\".\"Categories\";",
        "INSERT INTO \"Demo\".\"demo\".\"Categories\" (\"CategoryID\", \"Description\") VALUES (1, 'Electronics');",
        "UPDATE \"Demo\".\"demo\".\"Categories\" SET \"Description\" = 'Updated Description' WHERE \"CategoryID\" = 1;",
        "SELECT * FROM \"cat\";",
        "SELECT \"C\".\"CategoryID\", \"P\".\"ProductName\" FROM \"cat\" \"C\" JOIN \"Demo\".\"demo\".\"Products\" \"P\" ON \"C\".\"CategoryID\" = \"P\".\"CategoryID\";"
