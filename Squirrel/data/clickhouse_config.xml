
<!-- Config that is used when server is run without config file. -->
<clickhouse>
    <stacktrace>
        <enabled>true</enabled>
    </stacktrace>
    <logger>
        <level>fatal</level>
        <console>true</console>
        <log>/var/log/clickhouse-server/clickhouse-server.log</log>
        <errorlog>/var/log/clickhouse-server/clickhouse-server.err.log</errorlog>
    </logger>

    <http_port>8123</http_port>
    <tcp_port>9000</tcp_port>
    <mysql_port>9004</mysql_port>

    <path>/tmp/ch_data/</path>
    <tmp_path>/tmp/ch_tmp/</tmp_path>
    <store_path>/tmp/ch_store/</store_path>
    <dictionaries_lib>/tmp/ch_dict/</dictionaries_lib>
    <format_schemas_path>/tmp/ch_formats/</format_schemas_path>

    <mlock_executable>true</mlock_executable>

    <users>
        <default>
            <password/>

            <networks>
                <ip>::/0</ip>
            </networks>

            <profile>default</profile>
            <quota>default</quota>
            <access_management>1</access_management>
        </default>
    </users>

    <profiles>
        <default/>
    </profiles>

    <quotas>
        <default/>
    </quotas>
</clickhouse>
