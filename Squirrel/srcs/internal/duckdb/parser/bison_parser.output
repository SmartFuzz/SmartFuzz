Grammar

    0 $accept: input $end

    1 input: statement_list opt_semicolon

    2 statement_list: statement
    3               | statement_list ';' statement

    4 statement: prepare_statement opt_hints
    5          | preparable_statement opt_hints
    6          | show_statement
    7          | cmd
    8          | comment_literal statement

    9 cmd: cmd_pragma
   10    | cmd_reindex
   11    | cmd_analyze
   12    | cmd_attach
   13    | cmd_detach
   14    | cmd_release
   15    | rollback_statement
   16    | vacuum_statement
   17    | begin_statement
   18    | commit_statement

   19 cmd_release: RELEASE SAVEPOINT savepoint_name
   20            | RELEASE savepoint_name
   21            | comment_literal cmd_release
   22            | cmd_release comment_literal

   23 savepoint_name: IDENTIFIER

   24 cmd_pragma: PRAGMA pragma_key
   25           | PRAGMA pragma_key '=' pragma_value
   26           | PRAGMA pragma_key '(' pragma_value ')'
   27           | comment_literal cmd_pragma
   28           | cmd_pragma comment_literal

   29 cmd_reindex: REINDEX
   30            | REINDEX table_name
   31            | comment_literal cmd_reindex
   32            | cmd_reindex comment_literal

   33 cmd_analyze: ANALYZE
   34            | ANALYZE table_name
   35            | comment_literal cmd_analyze
   36            | cmd_analyze comment_literal

   37 cmd_attach: ATTACH expr AS schema_name
   38           | ATTACH DATABASE expr AS schema_name
   39           | comment_literal cmd_attach
   40           | cmd_attach comment_literal

   41 cmd_detach: DETACH schema_name
   42           | DETACH DATABASE schema_name
   43           | comment_literal cmd_detach
   44           | cmd_detach comment_literal

   45 pragma_key: pragma_name
   46           | schema_name '.' pragma_name

   47 pragma_value: num_literal
   48             | string_literal
   49             | IDENTIFIER
   50             | ON
   51             | DELETE
   52             | DEFAULT
   53             | comment_literal pragma_value
   54             | pragma_value comment_literal

   55 schema_name: IDENTIFIER

   56 pragma_name: IDENTIFIER

   57 preparable_statement: select_statement
   58                     | import_statement
   59                     | create_statement
   60                     | insert_statement
   61                     | delete_statement
   62                     | truncate_statement
   63                     | update_statement
   64                     | drop_statement
   65                     | execute_statement
   66                     | alter_statement

   67 rollback_statement: ROLLBACK opt_transaction opt_to_savepoint
   68                   | comment_literal rollback_statement
   69                   | rollback_statement comment_literal

   70 opt_transaction: TRANSACTION
   71                | ε
   72                | comment_literal opt_transaction
   73                | opt_transaction comment_literal

   74 opt_to_savepoint: TO savepoint_name
   75                 | TO SAVEPOINT savepoint_name
   76                 | ε
   77                 | comment_literal opt_to_savepoint
   78                 | opt_to_savepoint comment_literal

   79 vacuum_statement: VACUUM opt_schema_name INTO file_path
   80                 | VACUUM opt_schema_name
   81                 | comment_literal vacuum_statement
   82                 | vacuum_statement comment_literal

   83 opt_schema_name: schema_name
   84                | ε

   85 begin_statement: BEGIN opt_transaction
   86                | BEGIN DEFFERED opt_transaction
   87                | BEGIN IMEDIATE opt_transaction
   88                | BEGIN EXCLUSIVE opt_transaction
   89                | comment_literal begin_statement
   90                | begin_statement comment_literal

   91 commit_statement: COMMIT opt_transaction
   92                 | END opt_transaction
   93                 | comment_literal commit_statement
   94                 | commit_statement comment_literal

   95 opt_upsert_clause: upsert_clause
   96                  | ε

   97 upsert_clause: ON CONFLICT DO NOTHING
   98              | ON CONFLICT DO UPDATE SET assign_list opt_where
   99              | ON CONFLICT '(' indexed_column_list ')' opt_where DO NOTHING
  100              | ON CONFLICT '(' indexed_column_list ')' opt_where DO UPDATE SET assign_list opt_where
  101              | comment_literal upsert_clause
  102              | upsert_clause comment_literal

  103 indexed_column_list: indexed_column
  104                    | indexed_column_list ',' indexed_column

  105 indexed_column: expr opt_collate opt_order_type

  106 opt_collate: COLLATE collation_name
  107            | ε
  108            | comment_literal opt_collate
  109            | opt_collate comment_literal

  110 assign_list: assign_clause
