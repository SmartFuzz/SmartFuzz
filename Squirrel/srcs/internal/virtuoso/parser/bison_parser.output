Grammar

    0 $accept: program $end

    1 program: stmtlist

    2 stmtlist: stmt OP_SEMI stmtlist
    3         | stmt OP_SEMI
    4         | comment_literal stmtlist
    5         | stmtlist comment_literal

    6 stmt: create_stmt
    7     | drop_stmt
    8     | select_stmt
    9     | update_stmt
   10     | insert_stmt
   11     | alter_stmt

   12 create_stmt: create_table_stmt
   13            | create_index_stmt
   14            | create_trigger_stmt
   15            | create_view_stmt

   16 drop_stmt: drop_index_stmt
   17          | drop_table_stmt
   18          | drop_trigger_stmt
   19          | drop_view_stmt

   20 alter_stmt: ALTER TABLE table_name alter_action
   21           | comment_literal alter_stmt
   22           | alter_stmt comment_literal

   23 select_stmt: select_no_parens
   24            | select_with_parens

   25 select_with_parens: OP_LP select_no_parens OP_RP
   26                   | OP_LP select_with_parens OP_RP
   27                   | comment_literal select_with_parens
   28                   | select_with_parens comment_literal

   29 select_no_parens: opt_with_clause select_clause_list opt_order_clause opt_limit_clause

   30 select_clause_list: select_clause
   31                   | select_clause combine_clause select_clause_list

   32 select_clause: SELECT opt_all_or_distinct select_target opt_from_clause opt_where_clause opt_group_clause opt_window_clause
   33              | comment_literal select_clause
   34              | select_clause comment_literal

   35 combine_clause: UNION
   36               | INTERSECT
   37               | EXCEPT
   38               | comment_literal combine_clause
   39               | combine_clause comment_literal

   40 opt_from_clause: from_clause
   41                | ε

   42 select_target: expr_list

   43 opt_window_clause: window_clause
   44                  | ε

   45 window_clause: WINDOW window_def_list
   46              | comment_literal window_clause
   47              | window_clause comment_literal

   48 window_def_list: window_def
   49                | window_def OP_COMMA window_def_list

   50 window_def: window_name AS OP_LP window OP_RP
   51           | comment_literal window_def
   52           | window_def comment_literal

   53 window_name: identifier

   54 window: opt_exist_window_name opt_partition opt_order_clause opt_frame_clause

   55 opt_partition: PARTITION BY expr_list
   56              | ε
   57              | comment_literal opt_partition
   58              | opt_partition comment_literal

   59 opt_frame_clause: range_or_rows frame_bound_start
   60                 | range_or_rows BETWEEN frame_bound_start AND frame_bound_end
   61                 | ε

   62 range_or_rows: RANGE
   63              | ROWS
   64              | GROUPS
   65              | comment_literal range_or_rows
   66              | range_or_rows comment_literal

   67 frame_bound_start: frame_bound
   68                  | UNBOUNDED PRECEDING
   69                  | comment_literal frame_bound_start
   70                  | frame_bound_start comment_literal

   71 frame_bound_end: frame_bound
   72                | UNBOUNDED FOLLOWING
   73                | comment_literal frame_bound_end
   74                | frame_bound_end comment_literal

   75 frame_bound: expr PRECEDING
   76            | expr FOLLOWING
   77            | CURRENT ROW
   78            | comment_literal frame_bound
   79            | frame_bound comment_literal

   80 opt_exist_window_name: identifier
   81                      | ε

   82 opt_group_clause: GROUP BY expr_list opt_having_clause
   83                 | ε
   84                 | comment_literal opt_group_clause
   85                 | opt_group_clause comment_literal

   86 opt_having_clause: HAVING expr
   87                  | ε
   88                  | comment_literal opt_having_clause
   89                  | opt_having_clause comment_literal

   90 opt_where_clause: where_clause
   91                 | ε

   92 where_clause: WHERE expr
   93             | comment_literal where_clause
   94             | where_clause comment_literal

   95 from_clause: FROM table_ref
   96            | comment_literal from_clause
   97            | from_clause comment_literal

   98 table_ref: opt_table_prefix table_name opt_as_alias opt_index opt_on opt_using
   99          | opt_table_prefix function_name OP_LP expr_list OP_RP opt_as_alias opt_on opt_using
  100          | opt_table_prefix OP_LP select_no_parens OP_RP opt_as_alias opt_on opt_using
  101          | opt_table_prefix OP_LP table_ref OP_RP opt_as_alias opt_on opt_using

  102 opt_index: INDEXED BY column_name
  103          | NOT INDEXED
  104          | ε
  105          | comment_literal opt_index
  106          | opt_index comment_literal

  107 opt_on: ON expr
  108       | ε
  109       | comment_literal opt_on
  110       | opt_on comment_literal

  111 opt_using: USING OP_LP column_name_list OP_RP
  112          | ε
  113          | comment_literal opt_using
  114          | opt_using comment_literal

  115 column_name_list: column_name
  116                 | column_name OP_COMMA column_name_list

  117 opt_table_prefix: table_ref join_op
  118                 | ε

  119 join_op: OP_COMMA
  120        | JOIN
  121        | NATURAL opt_join_type JOIN
  122        | comment_literal join_op
  123        | join_op comment_literal

  124 opt_join_type: LEFT
  125              | LEFT OUTER
  126              | INNER
  127              | CROSS
  128              | ε
  129              | comment_literal opt_join_type
  130              | opt_join_type comment_literal

  131 expr_list: expr opt_as_alias OP_COMMA expr_list
  132          | expr opt_as_alias

  133 opt_limit_clause: limit_clause
  134                 | ε

  135 limit_clause: LIMIT expr
  136             | LIMIT expr OFFSET expr
  137             | LIMIT expr OP_COMMA expr
  138             | comment_literal limit_clause
  139             | limit_clause comment_literal

  140 opt_limit_row_count: LIMIT expr
  141                    | ε
  142                    | comment_literal opt_limit_row_count
  143                    | opt_limit_row_count comment_literal

  144 opt_order_clause: ORDER BY order_item_list
  145                 | ε
  146                 | comment_literal opt_order_clause
  147                 | opt_order_clause comment_literal

  148 opt_order_nulls: NULLS FIRST
  149                | NULLS LAST
  150                | ε
  151                | comment_literal opt_order_nulls
  152                | opt_order_nulls comment_literal

  153 order_item_list: order_item
  154                | order_item OP_COMMA order_item_list

